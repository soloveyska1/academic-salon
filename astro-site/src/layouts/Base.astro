---
import ClientRouter from 'astro/components/ClientRouter.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

import '../styles/design-tokens.css';
import '../styles/components.css';
import '../styles/nav.css';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = 'Библиотека академического салона — студенческие работы',
  description = 'Библиотека академического салона: 235+ бесплатных документов по психологии, социальной работе. Курсовые, ВКР, рефераты — скачивай или закажи индивидуально.',
  currentPath = Astro.url.pathname,
} = Astro.props;

const isHomePage = currentPath === '/';
---

<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="ru_RU" />
  <meta name="theme-color" content="#d4af37" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Библиотека АС" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta property="og:image" content="https://bibliosaloon.ru/og-image.png" />
  <meta property="og:url" content={`https://bibliosaloon.ru${Astro.url.pathname}`} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="canonical" href={`https://bibliosaloon.ru${Astro.url.pathname}`} />

  <!-- Yandex.Metrika counter -->
  <script is:inline>
    (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
    m[i].l=1*new Date();
    for(var j=0;j<document.scripts.length;j++){if(document.scripts[j].src===r)return;}
    k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
    (window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");
    ym(108363627, "init", { clickmap:true, trackLinks:true, accurateTrackBounce:true, webvisor:true });
  </script>
  <noscript><div><img src="https://mc.yandex.ru/watch/108363627" style="position:absolute; left:-9999px;" alt="" /></div></noscript>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    "name": "Библиотека академического салона",
    "url": "https://bibliosaloon.ru",
    "description": "Библиотека студенческих работ: психология, социальная работа, конфликтология. Бесплатный каталог и индивидуальные заказы.",
    "sameAs": [
      "https://vk.com/academicsaloon",
      "https://t.me/academicsaloon"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "academsaloon@mail.ru",
      "contactType": "customer service"
    }
  })} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Inter:wght@300..700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
  <!-- Apply saved theme before paint to prevent FOUC -->
  <script is:inline>
    (function() {
      var t = localStorage.getItem('theme');
      if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
    })();
  </script>
  <!-- Capture click position for circle-reveal view transition -->
  <script is:inline>
    document.addEventListener('click', function(e) {
      var link = e.target.closest('a[href]');
      if (!link) return;
      var href = link.getAttribute('href');
      if (!href || href.startsWith('#') || href.startsWith('http') || href.startsWith('mailto')) return;
      var x = ((e.clientX / window.innerWidth) * 100).toFixed(1) + '%';
      var y = ((e.clientY / window.innerHeight) * 100).toFixed(1) + '%';
      document.documentElement.style.setProperty('--vt-x', x);
      document.documentElement.style.setProperty('--vt-y', y);
      if (window.__setAcademicSalonRouteTarget) {
        try {
          var path = new URL(href, window.location.origin).pathname;
          var label = (link.textContent || '').replace(/\s+/g, ' ').trim();
          window.__setAcademicSalonRouteTarget(path, label);
        } catch (_) {}
      }
    });
  </script>
  <!-- Critical inline CSS — prevents FOUC by rendering layout before external CSS loads -->
  <style is:inline>
    /* Colors */
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{background:#09080a;color:#f0ede8;font-family:Inter,system-ui,sans-serif;overflow-x:clip}
    [data-theme="light"] body{background:#faf8f2;color:#1a1610}
    a{color:inherit;text-decoration:none}
    /* Nav */
    .nav{position:fixed;top:0;left:0;right:0;z-index:100;height:72px;display:flex;align-items:center;justify-content:space-between;padding:0 48px;background:transparent;border-bottom:1px solid rgba(255,255,255,.06)}
    .nav-links{display:flex;align-items:center;gap:40px}
    .nav-logo{text-decoration:none;display:flex;align-items:center;gap:12px}
    .nav-actions{display:flex;align-items:center;gap:16px}
    .nav-burger{display:none}
    /* Main */
    .main{position:relative;z-index:1;padding-top:72px;min-height:100vh}
    /* Curtain — visible immediately to cover any flash */
    .curtain{position:fixed;inset:0;z-index:9999;pointer-events:none;display:flex}
    .curtain-left,.curtain-right{flex:1;background:#09080a}
    [data-theme="light"] .curtain-left,[data-theme="light"] .curtain-right{background:#faf8f2}
    /* Route shield — persists across client-side navigations and masks raw DOM during swaps */
    .route-shield{position:fixed;inset:0;z-index:9998;pointer-events:none;display:grid;place-items:center;padding:32px 24px;opacity:0;visibility:hidden;background:linear-gradient(180deg,rgba(9,8,10,.965),rgba(9,8,10,.992)),radial-gradient(circle at 50% 18%,rgba(212,175,55,.08),transparent 42%);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);transition:opacity .18s ease,visibility 0s linear .18s}
    .route-shield::before,.route-shield::after{content:'';position:absolute;left:50%;transform:translateX(-50%);pointer-events:none}
    .route-shield::before{top:0;width:min(260px,56vw);height:1px;background:linear-gradient(90deg,transparent,rgba(212,175,55,.45),transparent);opacity:.58}
    .route-shield::after{top:14%;width:1px;height:72%;background:linear-gradient(180deg,transparent,rgba(212,175,55,.32),transparent);opacity:0;transition:opacity .18s ease,transform .24s cubic-bezier(.22,1,.36,1);transform:translateX(-50%) scaleY(.72)}
    .route-shield__frame{position:relative;width:min(440px,100%);padding:26px 24px 24px;border:1px solid rgba(212,175,55,.12);border-radius:22px;background:linear-gradient(180deg,rgba(20,18,22,.96),rgba(11,10,13,.92));box-shadow:0 24px 80px rgba(0,0,0,.28),inset 0 1px 0 rgba(255,255,255,.035);overflow:hidden;opacity:0;transform:translateY(10px) scale(.985);transition:opacity .18s ease,transform .24s cubic-bezier(.22,1,.36,1),border-color .18s ease}
    .route-shield__frame::after{content:'';position:absolute;inset:-30% -18%;background:linear-gradient(112deg,transparent 36%,rgba(246,226,122,.11) 49%,rgba(255,255,255,.03) 54%,transparent 68%);transform:translateX(-70%) rotate(9deg);opacity:0}
    .route-shield__line{width:56px;height:1px;background:linear-gradient(90deg,rgba(212,175,55,.92),transparent);opacity:.7}
    .route-shield__eyebrow{margin-top:16px;font:400 10px/1 Inter,system-ui,sans-serif;letter-spacing:.18em;text-transform:uppercase;color:#9b9590}
    .route-shield__title{margin-top:14px;font:400 clamp(28px,7vw,40px)/1.05 'Cormorant Garamond',Georgia,serif;letter-spacing:.02em;color:#f0ede8;text-wrap:balance}
    .route-shield__ghost{margin-top:18px;display:grid;gap:10px}
    .route-shield__block{display:block;height:12px;border-radius:999px;background:linear-gradient(90deg,rgba(212,175,55,.14),rgba(255,255,255,.03));box-shadow:inset 0 0 0 1px rgba(212,175,55,.08)}
    .route-shield__block--lg{width:100%}
    .route-shield__block--md{width:72%}
    .route-shield__chips{margin-top:18px;display:flex;gap:10px;flex-wrap:wrap}
    .route-shield__chips span{display:block;height:24px;border-radius:999px;border:1px solid rgba(212,175,55,.1);background:linear-gradient(180deg,rgba(212,175,55,.08),rgba(255,255,255,.02))}
    .route-shield__chips span:nth-child(1){width:78px}
    .route-shield__chips span:nth-child(2){width:96px}
    .route-shield__chips span:nth-child(3){width:68px}
    .route-shield.is-active{opacity:1;visibility:visible;transition-delay:0s}
    .route-shield.is-active::after{opacity:1;transform:translateX(-50%) scaleY(1)}
    .route-shield.is-active .route-shield__frame{opacity:1;transform:translateY(0) scale(1);border-color:rgba(212,175,55,.18)}
    .route-shield.is-active .route-shield__frame::after{opacity:1;animation:route-shield-sweep 1.9s ease-in-out infinite}
    [data-theme="light"] .route-shield{background:linear-gradient(180deg,rgba(250,248,242,.97),rgba(250,248,242,.992)),radial-gradient(circle at 50% 18%,rgba(212,175,55,.06),transparent 40%)}
    [data-theme="light"] .route-shield::before{background:linear-gradient(90deg,transparent,rgba(160,120,24,.34),transparent)}
    [data-theme="light"] .route-shield::after{background:linear-gradient(180deg,transparent,rgba(160,120,24,.24),transparent)}
    [data-theme="light"] .route-shield__frame{background:linear-gradient(180deg,rgba(255,255,255,.98),rgba(246,242,234,.96));border-color:rgba(160,120,24,.12);box-shadow:0 24px 80px rgba(72,54,10,.12),inset 0 1px 0 rgba(255,255,255,.6)}
    [data-theme="light"] .route-shield__eyebrow{color:#7d7464}
    [data-theme="light"] .route-shield__title{color:#1a1610}
    [data-theme="light"] .route-shield__block{background:linear-gradient(90deg,rgba(180,140,20,.14),rgba(160,120,24,.03));box-shadow:inset 0 0 0 1px rgba(160,120,24,.08)}
    [data-theme="light"] .route-shield__chips span{border-color:rgba(160,120,24,.12);background:linear-gradient(180deg,rgba(180,140,20,.1),rgba(255,255,255,.55))}
    /* Decorative — hidden until CSS loads */
    .film-grain,.scroll-progress,.bg-mesh,.hero-canvas{opacity:0}
    /* Bottom nav */
    .bottom-nav{display:none}
    .bottom-sheet{position:fixed;bottom:0;left:0;right:0;z-index:99;transform:translateY(100%);pointer-events:none}
    .sheet-backdrop{position:fixed;inset:0;z-index:98;opacity:0;pointer-events:none}
    /* Mobile */
    @media(max-width:768px){
      .nav{padding:0 20px;height:56px}
      .nav-links{display:none}
      .nav-burger{display:flex;flex-direction:column;justify-content:center;align-items:center;width:48px;height:48px;border:none;background:transparent;gap:8px}
      .burger-line{display:block;width:20px;height:1.5px;background:#f0ede8;border-radius:1px}
      .main{padding-top:56px;padding-bottom:calc(64px + env(safe-area-inset-bottom,0px))}
      .bottom-nav{display:flex;position:fixed;bottom:0;left:0;right:0;z-index:100;height:calc(64px + env(safe-area-inset-bottom,0px));padding-bottom:env(safe-area-inset-bottom,0px);background:rgba(9,8,12,.97);border-top:1px solid rgba(255,255,255,.06)}
      .bottom-nav-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;padding:10px 0;color:#656060;background:none;border:none;font-family:inherit;cursor:pointer;min-height:48px}
      .bottom-nav-item.active{color:#d4af37}
      .bottom-nav-icon{width:26px;height:26px}
      .bottom-nav-label{font:400 11px/1 Inter,system-ui,sans-serif}
      [data-theme="light"] .bottom-nav{background:rgba(245,241,234,.97)}
      [data-theme="light"] .burger-line{background:#1a1610}
      /* Hide sheet content until CSS loads — prevents raw link flash */
      .sheet-link,.sheet-contact,.sheet-reading,.sheet-divider,.sheet-contacts{opacity:0}
      .bottom-sheet.is-open .sheet-link,.bottom-sheet.is-open .sheet-contact,.bottom-sheet.is-open .sheet-reading,.bottom-sheet.is-open .sheet-contacts{opacity:1}
    }
  </style>
  {isHomePage && (
    <style is:inline>
      .hero{position:relative;min-height:100svh;margin-top:-72px;padding:72px 24px 0;display:flex;flex-direction:column;align-items:center;justify-content:center;overflow:hidden;background:#09080a}
      [data-theme="light"] .hero{background:#faf8f2}
      .hero-canvas{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0}
      .hero-glow{position:absolute;width:min(1200px,100vw);height:min(1000px,85vw);top:42%;left:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:0;background:radial-gradient(ellipse 60% 50% at 50% 50%,rgba(200,165,40,.18) 0%,transparent 70%),radial-gradient(ellipse 40% 35% at 50% 45%,rgba(212,175,55,.1) 0%,transparent 55%)}
      .hero-inner{position:relative;z-index:1;max-width:960px;text-align:center;padding:0 8px}
      .hero-eyebrow{margin-bottom:24px;font:400 clamp(11px,1.3vw,12px)/1 Inter,system-ui,sans-serif;letter-spacing:.18em;text-transform:uppercase;color:#9b9590}
      .hero-title{font:300 clamp(48px,10vw,100px)/.92 'Cormorant Garamond',Georgia,serif;color:#f0ede8;letter-spacing:.02em;text-wrap:balance}
      [data-theme="light"] .hero-title{color:#1a1610}
      .word{display:inline-block}
      .hero-rule{width:48px;height:1px;margin:32px auto 0;background:#d4af37;opacity:.25}
      .hero-sub{max-width:52ch;margin:28px auto 0;font:400 clamp(14px,1.8vw,16px)/1.65 Inter,system-ui,sans-serif;color:#9b9590;letter-spacing:.04em;word-break:break-word;overflow-wrap:break-word}
      .hero-actions{margin-top:48px;display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
      .hero .btn{display:inline-flex;align-items:center;justify-content:center;min-height:48px;padding:18px 48px;border:.5px solid rgba(212,175,55,.2);color:#f0ede8;text-transform:uppercase;letter-spacing:.12em;font:400 12px/1 Inter,system-ui,sans-serif}
      .hero .btn--primary{background:rgba(255,255,255,.03)}
      .hero .btn--ghost{background:transparent}
      [data-theme="light"] .hero .btn{color:#1a1610}
      .hero-metrics{position:absolute;left:24px;right:24px;bottom:80px;display:flex;justify-content:center;gap:80px;flex-wrap:wrap;z-index:1}
      .metric{text-align:center}
      .metric-value{display:block;font:300 clamp(42px,8vw,68px)/1 'JetBrains Mono',monospace;color:#d4af37;letter-spacing:-.02em;font-variant-numeric:tabular-nums}
      .metric-label{display:block;margin-top:12px;font:400 11px/1.3 Inter,system-ui,sans-serif;color:#656060;text-transform:uppercase;letter-spacing:.12em}
      @media(max-width:639px){
        .hero{min-height:75svh;padding:56px 16px calc(64px + env(safe-area-inset-bottom,0px))}
        .hero-title{font-size:clamp(38px,10vw,52px);line-height:1.1}
        .hero-actions{margin-top:32px;flex-direction:column;align-items:stretch;gap:8px}
        .hero .btn{text-align:center;padding:16px 32px;font-size:13px}
        .hero-metrics{position:relative;left:auto;right:auto;bottom:auto;margin-top:32px;gap:32px;padding:0 16px}
        .metric-value{font-size:clamp(32px,10vw,48px)}
      }
    </style>
  )}
  <ClientRouter />
</head>
<body>
  <!-- ═══════ PAGE LOAD CURTAIN ═══════ -->
  <div class="curtain" id="curtain" aria-hidden="true">
    <div class="curtain-left"></div>
    <div class="curtain-right"></div>
    <div class="curtain-line"></div>
  </div>
  <div class="route-shield" id="routeShield" transition:persist="route-shield" aria-hidden="true">
    <div class="route-shield__frame">
      <div class="route-shield__line"></div>
      <p class="route-shield__eyebrow" id="routeShieldEyebrow">Открываем раздел</p>
      <h2 class="route-shield__title" id="routeShieldTitle">Библиотека</h2>
      <div class="route-shield__ghost" aria-hidden="true">
        <span class="route-shield__block route-shield__block--lg"></span>
        <span class="route-shield__block route-shield__block--md"></span>
      </div>
      <div class="route-shield__chips" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>
  </div>

  <!-- custom cursor removed — interferes with usability -->

  <!-- ═══════ FILM GRAIN ═══════ -->
  <div class="film-grain" aria-hidden="true"></div>

  <!-- ═══════ SCROLL PROGRESS ═══════ -->
  <div class="scroll-progress" id="scrollProgress" aria-hidden="true"></div>

  <!-- Background aurora mesh -->
  <div class="bg-mesh" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>

  <Nav currentPath={currentPath} />

  <main class="main">
    <slot />
  </main>

  <Footer />

  <!-- ═══════ BOTTOM NAVIGATION (mobile only) ═══════ -->
  <nav class="bottom-nav" id="bottomNav" aria-label="Навигация">
    <div class="nav-slider" id="navSlider"></div>
    <a href="/" class:list={['bottom-nav-item', { active: currentPath === '/' }]}>
      <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span class="bottom-nav-label">Главная</span>
    </a>
    <a href="/catalog" class:list={['bottom-nav-item', { active: currentPath === '/catalog' || currentPath?.startsWith('/doc') }]}>
      <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      <span class="bottom-nav-label">Каталог</span>
    </a>
    <a href="/order" class:list={['bottom-nav-item', { active: currentPath === '/order' }]}>
      <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      <span class="bottom-nav-label">Заказать</span>
    </a>
    <button class="bottom-nav-item" id="bottomNavMore" type="button" aria-label="Меню">
      <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      <span class="bottom-nav-label">Ещё</span>
    </button>
  </nav>

  <!-- Unregister old service workers (once, not purge all caches) -->
  <script is:inline>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.getRegistrations().then(function(regs) {
        regs.forEach(function(r) { r.unregister(); });
      });
    }
  </script>

  <!-- Lenis Smooth Scroll CDN (async — non-blocking) -->
  <script is:inline>
    // Load Lenis only on desktop (pointer: fine) — don't block mobile at all
    if (!window.matchMedia('(pointer: coarse)').matches && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      var s = document.createElement('script');
      s.src = 'https://unpkg.com/lenis@1.1.18/dist/lenis.min.js';
      s.onload = function() {
        var lenis = new Lenis({ duration: 1.2, easing: function(t) { return Math.min(1, 1.001 - Math.pow(2, -10 * t)) }, touchMultiplier: 1, infinite: false });
        var rafId;
        function raf(time) { lenis.raf(time); rafId = requestAnimationFrame(raf); }
        rafId = requestAnimationFrame(raf);
        window.__lenis = lenis;
        document.addEventListener('astro:before-swap', function() { if (rafId) cancelAnimationFrame(rafId); lenis.destroy(); }, { once: true });
      };
      document.head.appendChild(s);
    }
  </script>

  <!-- Global Premium Effects -->
  <script is:inline>
    (function initRouteShield() {
      var win = window;
      if (win.__academicSalonRouteShieldInit) return;
      win.__academicSalonRouteShieldInit = true;

      var hideFrameA = 0;
      var hideFrameB = 0;
      var routeMeta = null;
      var ROUTE_MAP = {
        '/': { eyebrow: 'Возвращаемся в библиотеку', title: 'Главная' },
        '/catalog': { eyebrow: 'Открываем раздел', title: 'Каталог' },
        '/order': { eyebrow: 'Переходим к заказу', title: 'Заказать' },
        '/about': { eyebrow: 'Открываем раздел', title: 'О нас' },
        '/contribute': { eyebrow: 'Открываем раздел', title: 'Поделиться' },
        '/admin': { eyebrow: 'Открываем раздел', title: 'Админ' }
      };

      function getShield() {
        return document.getElementById('routeShield');
      }

      function normalizeLabel(label, limit) {
        var clean = (label || '').replace(/\s+/g, ' ').trim();
        if (!clean) return '';
        if (clean.length <= limit) return clean;
        return clean.slice(0, limit - 1).trim() + '…';
      }

      function buildRouteMeta(path, fallbackLabel) {
        if (path && path.indexOf('/doc/') === 0) {
          var docLabel = normalizeLabel(
            fallbackLabel || document.title.split(' — ')[0] || 'Документ',
            54
          );
          return {
            eyebrow: 'Открываем работу',
            title: docLabel || 'Документ'
          };
        }

        if (ROUTE_MAP[path]) return ROUTE_MAP[path];

        return {
          eyebrow: 'Открываем раздел',
          title: normalizeLabel(fallbackLabel || 'Раздел', 40) || 'Раздел'
        };
      }

      function renderRouteMeta() {
        var eyebrow = document.getElementById('routeShieldEyebrow');
        var title = document.getElementById('routeShieldTitle');
        if (!routeMeta) routeMeta = buildRouteMeta(window.location.pathname);
        if (eyebrow) eyebrow.textContent = routeMeta.eyebrow;
        if (title) title.textContent = routeMeta.title;
      }

      win.__setAcademicSalonRouteTarget = function(path, fallbackLabel) {
        routeMeta = buildRouteMeta(path, fallbackLabel);
        renderRouteMeta();
      };

      function cancelHideFrames() {
        if (hideFrameA) cancelAnimationFrame(hideFrameA);
        if (hideFrameB) cancelAnimationFrame(hideFrameB);
        hideFrameA = 0;
        hideFrameB = 0;
      }

      function showRouteShield() {
        var shield = getShield();
        if (!shield) return;
        cancelHideFrames();
        renderRouteMeta();
        document.documentElement.setAttribute('data-route-transitioning', '1');
        shield.classList.add('is-active');
      }

      function hideRouteShield() {
        cancelHideFrames();
        hideFrameA = requestAnimationFrame(function() {
          hideFrameB = requestAnimationFrame(function() {
            var shield = getShield();
            if (!shield) return;
            shield.classList.remove('is-active');
            document.documentElement.removeAttribute('data-route-transitioning');
          });
        });
      }

      win.__setAcademicSalonRouteTarget(window.location.pathname);
      document.addEventListener('astro:before-preparation', showRouteShield);
      document.addEventListener('astro:before-swap', showRouteShield);
      document.addEventListener('astro:page-load', function() {
        hideRouteShield();
        window.setTimeout(function() {
          win.__setAcademicSalonRouteTarget(window.location.pathname);
        }, 220);
      });
      window.addEventListener('pageshow', function() {
        hideRouteShield();
        window.setTimeout(function() {
          win.__setAcademicSalonRouteTarget(window.location.pathname);
        }, 220);
      });
    })();

    // ═══════ PAGE LOAD CURTAIN ═══════
    (function initCurtain() {
      var curtain = document.getElementById('curtain');
      if (!curtain) return;
      var isMobile = window.matchMedia('(pointer: coarse)').matches;
      if (sessionStorage.getItem('curtain-shown') || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        curtain.style.display = 'none';
        return;
      }
      sessionStorage.setItem('curtain-shown', '1');

      var released = false;

      function releaseCurtain() {
        if (released) return;
        released = true;
        requestAnimationFrame(function() {
          curtain.classList.add('open');
        });
        window.setTimeout(function() {
          curtain.style.display = 'none';
        }, isMobile ? 360 : 440);
      }

      var pending = 0;
      var styleLinks = Array.prototype.slice.call(document.querySelectorAll('link[rel="stylesheet"]')).filter(function(link) {
        var href = link.getAttribute('href') || '';
        return href.indexOf('/_assets/') === 0;
      });

      function onStyleSettled() {
        pending -= 1;
        if (pending <= 0) releaseCurtain();
      }

      styleLinks.forEach(function(link) {
        if (link.sheet) return;
        pending += 1;
        link.addEventListener('load', onStyleSettled, { once: true });
        link.addEventListener('error', onStyleSettled, { once: true });
      });

      if (!pending) {
        window.setTimeout(releaseCurtain, isMobile ? 60 : 100);
        return;
      }

      window.setTimeout(releaseCurtain, isMobile ? 320 : 420);
    })();

    // ═══════ GOLD RIPPLE TOUCH EFFECT (mobile only) ═══════
    (function initRipple() {
      if (!window.matchMedia('(pointer: coarse)').matches) return;

      var SELECTORS = '.btn, .card, .chip, .pill, .faq-q, .bottom-nav-item, .guarantee, .gallery-more, .mobile-link, .attach-trigger';

      function createRipple(e) {
        var el = e.currentTarget;
        var rect = el.getBoundingClientRect();
        var size = Math.max(rect.width, rect.height) * 2;
        var x = (e.touches ? e.touches[0].clientX : e.clientX) - rect.left - size / 2;
        var y = (e.touches ? e.touches[0].clientY : e.clientY) - rect.top - size / 2;

        var circle = document.createElement('span');
        circle.className = 'ripple-circle';
        circle.style.width = circle.style.height = size + 'px';
        circle.style.left = x + 'px';
        circle.style.top = y + 'px';
        el.appendChild(circle);

        // Haptic feedback (Android)
        if (navigator.vibrate) navigator.vibrate(8);

        circle.addEventListener('animationend', function() { circle.remove(); });
      }

      function bind() {
        document.querySelectorAll(SELECTORS).forEach(function(el) {
          if (el.dataset.ripple) return;
          el.dataset.ripple = '1';
          el.addEventListener('touchstart', createRipple, { passive: true });
        });
      }

      bind();
      document.addEventListener('astro:page-load', bind);
    })();

    // ═══════ MAGNETIC BUTTONS ═══════
    (function initMagnetic() {
      if (window.matchMedia('(pointer: coarse)').matches) return;
      var magnets = document.querySelectorAll('.btn-primary, .btn-pill, .nav-cta, .float-cta-btn, .hero-path');

      magnets.forEach(function(el) {
        el.addEventListener('mousemove', function(e) {
          var rect = el.getBoundingClientRect();
          var x = e.clientX - rect.left - rect.width / 2;
          var y = e.clientY - rect.top - rect.height / 2;
          el.style.transform = 'translate(' + (x * 0.2) + 'px,' + (y * 0.2) + 'px)';
        });
        el.addEventListener('mouseleave', function() {
          el.style.transform = '';
          el.style.transition = 'transform 0.4s cubic-bezier(.22,1,.36,1)';
          setTimeout(function() { el.style.transition = '' }, 400);
        });
      });
    })();

    // ═══════ SCROLL PROGRESS BAR (JS fallback — CSS handles it if supported) ═══════
    (function initScrollProgress() {
      if (CSS.supports && CSS.supports('animation-timeline', 'scroll()')) return;
      var bar = document.getElementById('scrollProgress');
      if (!bar) return;
      bar.style.width = '0%';
      bar.style.transform = 'none';
      window.addEventListener('scroll', function() {
        var h = document.documentElement.scrollHeight - window.innerHeight;
        var pct = h > 0 ? (window.scrollY / h) * 100 : 0;
        bar.style.width = pct + '%';
      }, { passive: true });
    })();

    // ═══════ TOAST UTILITY ═══════
    (function initToast() {
      // Create container if not exists
      var container = document.getElementById('toast-container');
      if (!container) {
        container = document.createElement('div');
        container.id = 'toast-container';
        container.className = 'toast-container';
        document.body.appendChild(container);
      }
      window.showToast = function(msg, type, duration) {
        type = type || 'success';
        duration = duration || 3000;
        var toast = document.createElement('div');
        toast.className = 'toast toast--' + type;
        toast.setAttribute('role', 'alert');
        toast.textContent = msg;
        container.appendChild(toast);
        setTimeout(function() {
          toast.classList.add('toast--exit');
          setTimeout(function() { toast.remove(); }, 300);
        }, duration);
      };
    })();

    // ═══════ REVEAL OBSERVER ═══════
    (function initReveal() {
      var observer = new IntersectionObserver(
        function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach(function(el) { observer.observe(el) });
    })();

    // Clean up before view transition swap
    document.addEventListener('astro:before-swap', function() {
      // Stop Lenis to prevent scroll jank during transition
      if (window.__lenis) window.__lenis.stop();
      // Hide decorative overlays
      var grain = document.querySelector('.film-grain');
      if (grain) grain.style.visibility = 'hidden';
      var progress = document.querySelector('.scroll-progress');
      if (progress) progress.style.visibility = 'hidden';
    });

    // Re-init after Astro view transitions
    document.addEventListener('astro:after-swap', function() {
      document.querySelectorAll('.reveal:not(.visible)').forEach(function(el) {
        new IntersectionObserver(function(entries, obs) {
          entries.forEach(function(e) {
            if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target) }
          });
        }, { threshold: 0.1 }).observe(el);
      });

      // Hide decorative layers during transitions
      var curtain = document.getElementById('curtain');
      if (curtain) curtain.style.display = 'none';
      var grain = document.querySelector('.film-grain');
      if (grain) grain.style.visibility = 'hidden';
      var progress = document.querySelector('.scroll-progress');
      if (progress) progress.style.visibility = 'hidden';
      // Restore after transition completes
      setTimeout(function() {
        if (grain) grain.style.visibility = '';
        if (progress) progress.style.visibility = '';
      }, 300);

      // Magnetic buttons re-init handled by index.astro's own cleanup system
    });
    // ═══════ BOTTOM NAV "ЕЩЁ" → MOBILE MENU ═══════
    (function initBottomNavMore() {
      function bind() {
        var moreBtn = document.getElementById('bottomNavMore');
        if (!moreBtn) return;
        moreBtn.addEventListener('click', function() {
          var burger = document.getElementById('navBurger');
          if (burger) burger.click();
        });
      }
      bind();
      document.addEventListener('astro:after-swap', bind);
    })();

    // ═══════ BOTTOM NAV SLIDING INDICATOR ═══════
    (function initNavSlider() {
      function position() {
        var slider = document.getElementById('navSlider');
        var nav = document.getElementById('bottomNav');
        var active = nav?.querySelector('.bottom-nav-item.active');
        if (!slider || !active || !nav) return;
        var navRect = nav.getBoundingClientRect();
        var rect = active.getBoundingClientRect();
        slider.style.left = (rect.left - navRect.left + rect.width * 0.2) + 'px';
        slider.style.width = (rect.width * 0.6) + 'px';
      }
      position();
      document.addEventListener('astro:page-load', position);
      window.addEventListener('resize', position);
    })();

    // ═══════ HIDDEN ADMIN ENTRY ═══════
    (function initAdminTrigger() {
      var clicks = 0;
      var lastClickAt = 0;
      document.addEventListener('click', function(event) {
        var target = event.target.closest('.footer-copy, .ftr-copy, .colophon, .end-copy');
        if (!target) return;
        var now = Date.now();
        if (now - lastClickAt > 2500) clicks = 0;
        lastClickAt = now;
        clicks += 1;
        if (clicks >= 7) {
          clicks = 0;
          window.location.href = '/admin';
        }
      });
    })();
  </script>
</body>
</html>

<style is:global>
  /* Background — Aurora Gradient */
