---
import ClientRouter from 'astro/components/ClientRouter.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

import '../styles/design-tokens.css';
import '../styles/components.css';
import '../styles/nav.css';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = 'Библиотека академического салона — студенческие работы',
  description = 'Библиотека академического салона: 235+ бесплатных документов по психологии, социальной работе. Курсовые, ВКР, рефераты — скачивай или закажи индивидуально.',
  currentPath = Astro.url.pathname,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="ru_RU" />
  <meta name="theme-color" content="#d4af37" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/icon-192.svg" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="БиблиоСалон" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta property="og:image" content="https://bibliosaloon.ru/og-image.png" />
  <meta property="og:url" content={`https://bibliosaloon.ru${Astro.url.pathname}`} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="canonical" href={`https://bibliosaloon.ru${Astro.url.pathname}`} />

  <!-- Yandex.Metrika counter -->
  <script is:inline>
    (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
    m[i].l=1*new Date();
    for(var j=0;j<document.scripts.length;j++){if(document.scripts[j].src===r)return;}
    k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
    (window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");
    ym(108363627, "init", { clickmap:true, trackLinks:true, accurateTrackBounce:true, webvisor:true });
  </script>
  <noscript><div><img src="https://mc.yandex.ru/watch/108363627" style="position:absolute; left:-9999px;" alt="" /></div></noscript>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "EducationalOrganization",
    "name": "Библиотека академического салона",
    "url": "https://bibliosaloon.ru",
    "description": "Библиотека студенческих работ: психология, социальная работа, конфликтология. Бесплатный каталог и индивидуальные заказы.",
    "sameAs": [
      "https://vk.com/academicsaloon",
      "https://t.me/academicsaloon"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "academsaloon@mail.ru",
      "contactType": "customer service"
    }
  })} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Inter:wght@300..700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <!-- Apply saved theme before paint to prevent FOUC -->
  <script is:inline>
    (function() {
      var t = localStorage.getItem('theme');
      if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
    })();
  </script>
  <!-- Capture click position for circle-reveal view transition -->
  <script is:inline>
    document.addEventListener('click', function(e) {
      var link = e.target.closest('a[href]');
      if (!link) return;
      var href = link.getAttribute('href');
      if (!href || href.startsWith('#') || href.startsWith('http') || href.startsWith('mailto')) return;
      var x = ((e.clientX / window.innerWidth) * 100).toFixed(1) + '%';
      var y = ((e.clientY / window.innerHeight) * 100).toFixed(1) + '%';
      document.documentElement.style.setProperty('--vt-x', x);
      document.documentElement.style.setProperty('--vt-y', y);
    });
  </script>
  <!-- Prevent FOUC: force default colors inline before any CSS loads -->
  <style is:inline>
    body { background: #09080a; color: #f0ede8; }
    [data-theme="light"] body { background: #faf8f2; color: #1a1610; }
    a { color: inherit; }
  </style>
  <ClientRouter />
</head>
<body>
  <!-- ═══════ PAGE LOAD CURTAIN ═══════ -->
  <div class="curtain" id="curtain" aria-hidden="true">
    <div class="curtain-left"></div>
    <div class="curtain-right"></div>
    <div class="curtain-line"></div>
  </div>

  <!-- custom cursor removed — interferes with usability -->

  <!-- ═══════ FILM GRAIN ═══════ -->
  <div class="film-grain" aria-hidden="true"></div>

  <!-- ═══════ SCROLL PROGRESS ═══════ -->
  <div class="scroll-progress" id="scrollProgress" aria-hidden="true"></div>

  <!-- Background aurora mesh -->
  <div class="bg-mesh" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>

  <Nav currentPath={currentPath} />

  <main class="main">
    <slot />
  </main>

  <Footer />

  <!-- ═══════ BOTTOM NAVIGATION (mobile only) ═══════ -->
  <nav class="bottom-nav" id="bottomNav" aria-label="Навигация">
    <a href="/" class:list={['bottom-nav-item', { active: currentPath === '/' }]}>
      <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span class="bottom-nav-label">Главная</span>
    </a>
    <a href="/catalog" class:list={['bottom-nav-item', { active: currentPath === '/catalog' || currentPath?.startsWith('/doc') }]}>
      <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      <span class="bottom-nav-label">Каталог</span>
    </a>
    <a href="/order" class:list={['bottom-nav-item', { active: currentPath === '/order' }]}>
      <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      <span class="bottom-nav-label">Заказать</span>
    </a>
    <button class="bottom-nav-item" id="bottomNavMore" type="button" aria-label="Меню">
      <svg class="bottom-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      <span class="bottom-nav-label">Ещё</span>
    </button>
  </nav>

  <!-- Kill old Service Worker + clear caches -->
  <script is:inline>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.getRegistrations().then(regs => {
        regs.forEach(r => r.unregister());
      });
      caches.keys().then(keys => {
        keys.forEach(k => caches.delete(k));
      });
    }
  </script>

  <!-- Lenis Smooth Scroll CDN -->
  <script is:inline src="https://unpkg.com/lenis@1.1.18/dist/lenis.min.js"></script>

  <!-- Global Premium Effects -->
  <script is:inline>
    // ═══════ LENIS SMOOTH SCROLL (desktop only) ═══════
    (function initLenis() {
      if (typeof Lenis === 'undefined') return;
      // Skip on touch devices — native iOS/Android scroll is already smooth
      if (window.matchMedia('(pointer: coarse)').matches) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      var lenis = new Lenis({
        duration: 1.2,
        easing: function(t) { return Math.min(1, 1.001 - Math.pow(2, -10 * t)) },
        touchMultiplier: 1,
        infinite: false,
      });
      var rafId;
      function raf(time) {
        lenis.raf(time);
        rafId = requestAnimationFrame(raf);
      }
      rafId = requestAnimationFrame(raf);
      window.__lenis = lenis;
      // Cleanup on view transitions
      document.addEventListener('astro:before-swap', function() {
        if (rafId) cancelAnimationFrame(rafId);
        lenis.destroy();
      }, { once: true });
    })();

    // ═══════ PAGE LOAD CURTAIN ═══════
    (function initCurtain() {
      var curtain = document.getElementById('curtain');
      if (!curtain) return;
      // If already visited this session, skip curtain
      if (sessionStorage.getItem('curtain-shown')) {
        curtain.style.display = 'none';
        return;
      }
      sessionStorage.setItem('curtain-shown', '1');
      // Shorter curtain on mobile (800ms total vs 2200ms)
      var isMobile = window.matchMedia('(pointer: coarse)').matches;
      setTimeout(function() { curtain.classList.add('open') }, isMobile ? 200 : 800);
      setTimeout(function() { curtain.style.display = 'none' }, isMobile ? 800 : 2200);
    })();

    // ═══════ GOLD RIPPLE TOUCH EFFECT (mobile only) ═══════
    (function initRipple() {
      if (!window.matchMedia('(pointer: coarse)').matches) return;

      var SELECTORS = '.btn, .card, .chip, .pill, .faq-q, .bottom-nav-item, .guarantee, .gallery-more, .mobile-link, .attach-trigger';

      function createRipple(e) {
        var el = e.currentTarget;
        var rect = el.getBoundingClientRect();
        var size = Math.max(rect.width, rect.height) * 2;
        var x = (e.touches ? e.touches[0].clientX : e.clientX) - rect.left - size / 2;
        var y = (e.touches ? e.touches[0].clientY : e.clientY) - rect.top - size / 2;

        var circle = document.createElement('span');
        circle.className = 'ripple-circle';
        circle.style.width = circle.style.height = size + 'px';
        circle.style.left = x + 'px';
        circle.style.top = y + 'px';
        el.appendChild(circle);

        // Haptic feedback (Android)
        if (navigator.vibrate) navigator.vibrate(8);

        circle.addEventListener('animationend', function() { circle.remove(); });
      }

      function bind() {
        document.querySelectorAll(SELECTORS).forEach(function(el) {
          if (el.dataset.ripple) return;
          el.dataset.ripple = '1';
          el.addEventListener('touchstart', createRipple, { passive: true });
        });
      }

      bind();
      document.addEventListener('astro:page-load', bind);
    })();

    // ═══════ MAGNETIC BUTTONS ═══════
    (function initMagnetic() {
      if (window.matchMedia('(pointer: coarse)').matches) return;
      var magnets = document.querySelectorAll('.btn-primary, .btn-pill, .nav-cta, .float-cta-btn, .hero-path');

      magnets.forEach(function(el) {
        el.addEventListener('mousemove', function(e) {
          var rect = el.getBoundingClientRect();
          var x = e.clientX - rect.left - rect.width / 2;
          var y = e.clientY - rect.top - rect.height / 2;
          el.style.transform = 'translate(' + (x * 0.2) + 'px,' + (y * 0.2) + 'px)';
        });
        el.addEventListener('mouseleave', function() {
          el.style.transform = '';
          el.style.transition = 'transform 0.4s cubic-bezier(.22,1,.36,1)';
          setTimeout(function() { el.style.transition = '' }, 400);
        });
      });
    })();

    // ═══════ SCROLL PROGRESS BAR (JS fallback — CSS handles it if supported) ═══════
    (function initScrollProgress() {
      if (CSS.supports && CSS.supports('animation-timeline', 'scroll()')) return;
      var bar = document.getElementById('scrollProgress');
      if (!bar) return;
      bar.style.width = '0%';
      bar.style.transform = 'none';
      window.addEventListener('scroll', function() {
        var h = document.documentElement.scrollHeight - window.innerHeight;
        var pct = h > 0 ? (window.scrollY / h) * 100 : 0;
        bar.style.width = pct + '%';
      }, { passive: true });
    })();

    // ═══════ TOAST UTILITY ═══════
    (function initToast() {
      // Create container if not exists
      var container = document.getElementById('toast-container');
      if (!container) {
        container = document.createElement('div');
        container.id = 'toast-container';
        container.className = 'toast-container';
        document.body.appendChild(container);
      }
      window.showToast = function(msg, type, duration) {
        type = type || 'success';
        duration = duration || 3000;
        var toast = document.createElement('div');
        toast.className = 'toast toast--' + type;
        toast.setAttribute('role', 'alert');
        toast.textContent = msg;
        container.appendChild(toast);
        setTimeout(function() {
          toast.classList.add('toast--exit');
          setTimeout(function() { toast.remove(); }, 300);
        }, duration);
      };
    })();

    // ═══════ REVEAL OBSERVER ═══════
    (function initReveal() {
      var observer = new IntersectionObserver(
        function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              observer.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach(function(el) { observer.observe(el) });
    })();

    // Re-init after Astro view transitions
    document.addEventListener('astro:after-swap', function() {
      document.querySelectorAll('.reveal:not(.visible)').forEach(function(el) {
        new IntersectionObserver(function(entries, obs) {
          entries.forEach(function(e) {
            if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target) }
          });
        }, { threshold: 0.1 }).observe(el);
      });

      // Re-init curtain skip
      var curtain = document.getElementById('curtain');
      if (curtain) curtain.style.display = 'none';

      // Magnetic buttons re-init handled by index.astro's own cleanup system
    });
    // ═══════ BOTTOM NAV "ЕЩЁ" → MOBILE MENU ═══════
    (function initBottomNavMore() {
      function bind() {
        var moreBtn = document.getElementById('bottomNavMore');
        if (!moreBtn) return;
        moreBtn.addEventListener('click', function() {
          var burger = document.getElementById('navBurger');
          if (burger) burger.click();
        });
      }
      bind();
      document.addEventListener('astro:after-swap', bind);
    })();

    // ═══════ HIDDEN ADMIN ENTRY ═══════
    (function initAdminTrigger() {
      var clicks = 0;
      var lastClickAt = 0;
      document.addEventListener('click', function(event) {
        var target = event.target.closest('.footer-copy, .ftr-copy, .colophon, .end-copy');
        if (!target) return;
        var now = Date.now();
        if (now - lastClickAt > 2500) clicks = 0;
        lastClickAt = now;
        clicks += 1;
        if (clicks >= 7) {
          clicks = 0;
          window.location.href = '/admin';
        }
      });
    })();
  </script>
</body>
</html>

<style is:global>
  /* Background — Aurora Gradient */
  .bg-mesh {
    position: fixed; inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }
  [data-theme="light"] .bg-mesh { opacity: 0.5 }
  [data-theme="light"] .orb-1 { background: rgba(122,95,18, 0.04); }
  [data-theme="light"] .orb-2 { background: rgba(109,40,217, 0.025); }
  [data-theme="light"] .orb-3 { background: rgba(122,95,18, 0.03); }
  [data-theme="light"] .bg-mesh::after {
    background:
      radial-gradient(ellipse 80% 60% at 15% 20%, rgba(122,95,18,.03) 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 85% 75%, rgba(109,40,217,.02) 0%, transparent 70%),
      radial-gradient(ellipse 50% 40% at 50% 50%, rgba(122,95,18,.015) 0%, transparent 60%);
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    will-change: transform;
  }
  .orb-1 {
    width: 700px; height: 700px;
    top: -15%; left: -10%;
    background: var(--ac-sh);
    animation: orb-float-1 25s ease-in-out infinite alternate;
  }
  .orb-2 {
    width: 500px; height: 500px;
    bottom: -15%; right: -10%;
    background: rgba(167,139,250,.035);
    animation: orb-float-2 22s ease-in-out infinite alternate;
  }
  .orb-3 {
    width: 600px; height: 600px;
    top: 40%; left: 50%;
    background: var(--ac-t);
    animation: orb-float-3 30s ease-in-out infinite alternate;
  }
  @keyframes orb-float-1 {
    0%   { transform: translate(0,0) scale(1) }
    33%  { transform: translate(80px,-80px) scale(1.15) }
    66%  { transform: translate(-40px,40px) scale(0.9) }
    100% { transform: translate(20px,-20px) scale(1.05) }
  }
  @keyframes orb-float-2 {
    0%   { transform: translate(0,0) scale(1) }
    33%  { transform: translate(-60px,-50px) scale(1.12) }
    66%  { transform: translate(30px,30px) scale(0.88) }
    100% { transform: translate(-10px,20px) scale(1.08) }
  }
  @keyframes orb-float-3 {
    0%   { transform: translate(-50%,-50%) scale(1) }
    50%  { transform: translate(calc(-50% + 100px), calc(-50% - 80px)) scale(1.2) }
    100% { transform: translate(calc(-50% - 60px), calc(-50% + 40px)) scale(0.85) }
  }

  /* Aurora overlay — subtle animated gradient mesh */
  .bg-mesh::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 15% 20%, var(--ac-g2) 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 85% 75%, rgba(167,139,250,.03) 0%, transparent 70%),
      radial-gradient(ellipse 50% 40% at 50% 50%, var(--ac-t) 0%, transparent 60%);
    animation: aurora-shift 20s ease-in-out infinite alternate;
  }
  @keyframes aurora-shift {
    0%   { opacity: 0.8; filter: hue-rotate(0deg); }
    50%  { opacity: 1; filter: hue-rotate(5deg); }
    100% { opacity: 0.7; filter: hue-rotate(-3deg); }
  }

  .main {
    position: relative;
    z-index: 1;
    padding-top: var(--nav-h);
    min-height: 100vh;
  }

  /* View transition defaults — circle clip reveal */
  ::view-transition-old(root) {
    animation: vt-clip-out .4s cubic-bezier(.4,0,.2,1) forwards;
    z-index: 1;
  }
  ::view-transition-new(root) {
    animation: vt-clip-in .5s cubic-bezier(.4,0,.2,1) forwards;
    z-index: 2;
  }
  ::view-transition-group(root) {
    animation-duration: 0.5s;
  }

  @keyframes vt-clip-out {
    from { opacity: 1; }
    to   { opacity: 0; }
  }
  @keyframes vt-clip-in {
    from {
      clip-path: circle(0% at var(--vt-x, 50%) var(--vt-y, 50%));
    }
    to {
      clip-path: circle(150% at var(--vt-x, 50%) var(--vt-y, 50%));
    }
  }

  /* Named transitions for persistent elements */
  .nav-logo { view-transition-name: site-logo; }
  ::view-transition-old(site-logo),
  ::view-transition-new(site-logo) {
    animation-duration: 0.25s;
  }

  /* ═══════ PAGE LOAD CURTAIN ═══════ */
  .curtain {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    display: flex;
  }
  .curtain-left, .curtain-right {
    flex: 1;
    background: var(--bg);
    transition: transform 1.2s cubic-bezier(.76,0,.24,1);
  }
  .curtain.open .curtain-left { transform: translateX(-100%) }
  .curtain.open .curtain-right { transform: translateX(100%) }
  .curtain-line {
    position: absolute;
    top: 0; bottom: 0;
    left: 50%;
    width: 2px;
    background: linear-gradient(180deg, transparent, var(--ac), var(--ac3), var(--ac), transparent);
    transform: translateX(-50%) scaleY(0);
    animation: curtain-line-in .6s var(--ease) .1s forwards;
  }
  .curtain.open .curtain-line {
    opacity: 0;
    transition: opacity .3s;
  }
  @keyframes curtain-line-in {
    to { transform: translateX(-50%) scaleY(1) }
  }

  /* ═══════ FILM GRAIN ═══════ */
  .film-grain {
    position: fixed;
    inset: 0;
    z-index: 9000;
    pointer-events: none;
    opacity: .035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)'/%3E%3C/svg%3E");
    background-size: 256px;
    animation: grain 0.5s steps(4) infinite;
  }
  @keyframes grain {
    0%   { transform: translate(0, 0) }
    25%  { transform: translate(-5%, -5%) }
    50%  { transform: translate(5%, 5%) }
    75%  { transform: translate(-2%, 7%) }
    100% { transform: translate(7%, -2%) }
  }

  /* Light theme: film grain less visible, scroll progress softer */
  [data-theme="light"] .film-grain { opacity: .015; }
  [data-theme="light"] .scroll-progress {
    box-shadow: 0 0 4px var(--ac-line);
  }
  /* Light: scrollbar */
  [data-theme="light"] ::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, var(--ac), var(--ac2));
  }

  /* ═══════ SCROLL PROGRESS (CSS scroll-driven — no JS) ═══════ */
  .scroll-progress {
    position: fixed;
    top: 0; left: 0;
    height: 2px;
    width: 100%;
    background: linear-gradient(90deg, var(--ac), var(--ac3), var(--ac));
    z-index: 9500;
    transform-origin: left;
    transform: scaleX(0);
    box-shadow: 0 0 8px var(--ac-b3);
  }
  /* Progressive enhancement: CSS scroll-driven if supported */
  @supports (animation-timeline: scroll()) {
    .scroll-progress {
      animation: scroll-scale linear;
