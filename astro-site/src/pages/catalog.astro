---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const categories = [...new Set(D.map((d: any) => d.category).filter(Boolean))].sort();
const totalDocs = D.length;

function catCount(cat: string) {
  return D.filter((d: any) => d.category === cat).length;
}
---

<Base title="Каталог — Академический Салон" currentPath="/catalog">

  <section class="cat-hero">
    <h1 class="cat-heading">Каталог</h1>
    <p class="cat-total"><span id="countDisplay">{totalDocs}</span> документов</p>
  </section>

  <section class="cat-body">
    <aside class="sidebar" id="sidebar">
      <button class="sidebar-toggle" id="sidebarToggle" type="button" aria-expanded="false">Фильтры</button>

      <div class="sidebar-inner" id="sidebarInner">
        <div class="sb-block">
          <input
            type="text"
            id="searchInput"
            class="search-field"
            placeholder="Поиск..."
            autocomplete="off"
          />
        </div>

        <div class="sb-block">
          <p class="sb-label">Сортировка</p>
          <div class="sort-list">
            <button class="sort-opt active" data-sort="default">По умолчанию</button>
            <button class="sort-opt" data-sort="az">А — Я</button>
            <button class="sort-opt" data-sort="za">Я — А</button>
            <button class="sort-opt" data-sort="size">По размеру</button>
          </div>
        </div>

        <div class="sb-block">
          <p class="sb-label">Категории</p>
          <div class="cat-list">
            <button class="cat-opt active" data-cat="all">
              <span>Все</span><span class="cat-n">{totalDocs}</span>
            </button>
            {categories.map(cat => (
              <button class="cat-opt" data-cat={cat}>
                <span>{cat}</span><span class="cat-n">{catCount(cat)}</span>
              </button>
            ))}
          </div>
        </div>
      </div>
    </aside>

    <main class="list-area">
      <div class="list-status" id="listStatus"></div>
      <div class="doc-list" id="docList">
        {D.map((doc: any, i: number) => {
          const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
          const desc = doc.catalogDescription || doc.description || '';
          const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
          const tags = [doc.category, doc.subject, doc.course].filter(Boolean);
          return (
            <a
              href={`/doc/${doc.file}`}
              class="doc-row"
              data-title={(doc.catalogTitle || doc.title || doc.filename || '').toLowerCase()}
              data-desc={(doc.catalogDescription || doc.description || '').toLowerCase()}
              data-cat={doc.category || ''}
              data-subject={(doc.subject || '').toLowerCase()}
              data-course={(doc.course || '').toLowerCase()}
              data-tags={(doc.tags || []).join(' ').toLowerCase()}
              data-size={doc.size || ''}
              data-index={i}
            >
              <div class="doc-main">
                <span class="doc-ext">{ext}</span>
                <h3 class="doc-title">{title}</h3>
                {desc && <p class="doc-desc">{desc}</p>}
              </div>
              <div class="doc-foot">
                <span class="doc-tags">{tags.join(' · ')}</span>
                {doc.size && <span class="doc-size">{doc.size}</span>}
              </div>
            </a>
          );
        })}
      </div>
      <div class="doc-empty" id="docEmpty" style="display:none;">
        <p class="empty-msg">Ничего не найдено</p>
        <button class="reset-btn" id="resetBtn">Сбросить фильтры</button>
      </div>
    </main>
  </section>

</Base>

<style>
  /* ═══════ HERO ═══════ */
  .cat-hero {
    padding: 120px 48px 64px;
    text-align: center;
  }

  .cat-heading {
    font: 300 clamp(40px, 7vw, 64px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  .cat-total {
    margin-top: 16px;
    font: 400 12px/1 var(--fm);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--t3);
    opacity: .4;
  }

  /* ═══════ LAYOUT ═══════ */
  .cat-body {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 48px;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 48px 120px;
    align-items: start;
  }

  /* ═══════ SIDEBAR ═══════ */
  .sidebar {
    position: sticky;
    top: calc(var(--nav-h) + 24px);
  }

  .sidebar-toggle {
    display: none;
    width: 100%;
    padding: 12px 0;
    background: none;
    border: none;
    border-bottom: 1px solid rgba(201,165,90,.08);
    color: var(--t2);
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    cursor: pointer;
    text-align: left;
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .sb-block {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .sb-label {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--t3);
    opacity: .45;
  }

  /* Search */
  .search-field {
    width: 100%;
    padding: 10px 0;
    border: none;
    border-bottom: 1px solid rgba(201,165,90,.1);
    background: transparent;
    color: var(--t1);
    font: 400 14px/1.4 var(--fi);
    outline: none;
    transition: border-color .4s cubic-bezier(.25,0,0,1);
  }

  .search-field::placeholder {
    color: var(--t3);
    opacity: .4;
  }

  .search-field:focus {
    border-bottom-color: rgba(201,165,90,.3);
  }

  /* Sort */
  .sort-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sort-opt {
    background: none;
    border: none;
    padding: 6px 0;
    text-align: left;
    font: 400 13px/1.3 var(--fi);
    color: var(--t1);
    opacity: .35;
    cursor: pointer;
    transition: opacity .3s cubic-bezier(.25,0,0,1);
  }

  .sort-opt:hover { opacity: .7; }
  .sort-opt.active { opacity: 1; }

  /* Categories */
  .cat-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cat-opt {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    background: none;
    border: none;
    border-left: 2px solid transparent;
    padding: 7px 0 7px 12px;
    text-align: left;
    font: 400 13px/1.3 var(--fi);
    color: var(--t1);
    opacity: .4;
    cursor: pointer;
    transition: opacity .3s cubic-bezier(.25,0,0,1), border-color .3s cubic-bezier(.25,0,0,1);
  }

  .cat-opt:hover { opacity: .7; }

  .cat-opt.active {
    opacity: 1;
    border-left-color: var(--ac);
  }

  .cat-n {
    font: 400 11px/1 var(--fm);
    opacity: .25;
  }

  /* ═══════ LIST ═══════ */
  .list-area {
    min-width: 0;
  }

  .list-status {
    font: 400 12px/1 var(--fm);
    color: var(--t3);
    opacity: .4;
    margin-bottom: 16px;
    min-height: 16px;
  }

  .doc-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: rgba(201,165,90,.04);
  }

  .doc-row {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px 24px;
    background: var(--bg);
    text-decoration: none;
    color: inherit;
    transition: background .5s cubic-bezier(.25,0,0,1);
  }

  .doc-row:hover {
    background: rgba(255,255,255,.02);
  }

  .doc-row.hidden {
    display: none;
  }

  .doc-main {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .doc-ext {
    font: 400 10px/1 var(--fm);
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--t3);
    opacity: .3;
  }

  .doc-title {
    font: 400 clamp(16px, 2vw, 18px)/1.35 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .doc-desc {
    font: 400 13px/1.5 var(--fi);
    color: var(--t2);
    opacity: .45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .doc-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .doc-tags {
    font: 400 10px/1 var(--fm);
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--t3);
    opacity: .3;
  }

  .doc-size {
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    opacity: .2;
    flex-shrink: 0;
  }

  /* ═══════ EMPTY ═══════ */
  .doc-empty {
    text-align: center;
    padding: 80px 24px;
  }

  .empty-msg {
    font: 400 16px/1 var(--fi);
    color: var(--t3);
    opacity: .5;
  }

  .reset-btn {
    margin-top: 24px;
    background: none;
    border: .5px solid rgba(201,165,90,.2);
    padding: 12px 32px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t1);
    cursor: pointer;
    transition: border-color .4s cubic-bezier(.25,0,0,1);
  }

  .reset-btn:hover {
    border-color: rgba(201,165,90,.4);
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 860px) {
    .cat-hero { padding: 96px 24px 48px; }

    .cat-body {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 0 24px 80px;
    }

    .sidebar {
      position: relative;
      top: 0;
    }

    .sidebar-toggle { display: block; }

    .sidebar-inner {
      display: none;
      padding-top: 24px;
    }

    .sidebar-inner.open { display: flex; }
  }
</style>

<script>
  function initCatalog() {
    var grid = document.getElementById('docList');
    var searchInput = document.getElementById('searchInput');
    var statusEl = document.getElementById('listStatus');
    var emptyEl = document.getElementById('docEmpty');
    var resetBtn = document.getElementById('resetBtn');
    var countDisplay = document.getElementById('countDisplay');
    var sidebarToggle = document.getElementById('sidebarToggle');
    var sidebarInner = document.getElementById('sidebarInner');

    if (!grid || !searchInput) return;

    var items = Array.from(grid.querySelectorAll('.doc-row'));
    var sortBtns = document.querySelectorAll('.sort-opt');
    var catBtns = document.querySelectorAll('.cat-opt');

    var currentQuery = '';
    var currentCat = 'all';
    var currentSort = 'default';

    var urlParams = new URLSearchParams(window.location.search);
    var qParam = urlParams.get('q');
    if (qParam) {
      searchInput.value = qParam;
      currentQuery = qParam.toLowerCase();
    }

    if (sidebarToggle && sidebarInner) {
      sidebarToggle.addEventListener('click', function() {
        var open = sidebarInner.classList.toggle('open');
        sidebarToggle.setAttribute('aria-expanded', String(open));
      });
    }

    searchInput.addEventListener('input', function() {
      currentQuery = searchInput.value.toLowerCase().trim();
      applyFilters();
    });

    catBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        catBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        currentCat = btn.dataset.cat || 'all';
        applyFilters();
      });
    });

    sortBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        sortBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        currentSort = btn.dataset.sort || 'default';
        applySort();
        applyFilters();
      });
    });

    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        searchInput.value = '';
        currentQuery = '';
        currentCat = 'all';
        currentSort = 'default';
        catBtns.forEach(function(b) { b.classList.remove('active'); });
        sortBtns.forEach(function(b) { b.classList.remove('active'); });
        var allBtn = document.querySelector('.cat-opt[data-cat="all"]');
        var defBtn = document.querySelector('.sort-opt[data-sort="default"]');
        if (allBtn) allBtn.classList.add('active');
        if (defBtn) defBtn.classList.add('active');
        applyFilters();
      });
    }

    function parseSize(s) {
      if (!s) return 0;
      var match = s.match(/([\d.,]+)\s*(МБ|MB|КБ|KB|Б|B)?/i);
      if (!match) return 0;
      var val = parseFloat(match[1].replace(',', '.'));
      var unit = (match[2] || '').toUpperCase();
      if (unit === 'КБ' || unit === 'KB') val *= 1024;
      if (unit === 'МБ' || unit === 'MB') val *= 1024 * 1024;
      return val;
    }

    function applySort() {
      var sorted = items.slice();
      if (currentSort === 'az') {
        sorted.sort(function(a, b) { return (a.dataset.title || '').localeCompare(b.dataset.title || '', 'ru'); });
      } else if (currentSort === 'za') {
        sorted.sort(function(a, b) { return (b.dataset.title || '').localeCompare(a.dataset.title || '', 'ru'); });
      } else if (currentSort === 'size') {
        sorted.sort(function(a, b) { return parseSize(b.dataset.size || '') - parseSize(a.dataset.size || ''); });
      } else {
        sorted.sort(function(a, b) { return parseInt(a.dataset.index || '0') - parseInt(b.dataset.index || '0'); });
      }
      sorted.forEach(function(el) { grid.appendChild(el); });
    }

    function applyFilters() {
      var visibleCount = 0;
      items.forEach(function(item) {
        var show = true;

        if (currentCat !== 'all') {
          if (item.dataset.cat !== currentCat) show = false;
        }

        if (show && currentQuery) {
          var haystack = [
            item.dataset.title,
            item.dataset.desc,
            (item.dataset.cat || '').toLowerCase(),
            item.dataset.subject,
            item.dataset.course,
            item.dataset.tags,
          ].join(' ');
          var words = currentQuery.split(/\s+/);
          show = words.every(function(w) { return haystack.includes(w); });
        }

        if (show) {
          item.classList.remove('hidden');
          visibleCount++;
        } else {
          item.classList.add('hidden');
        }
      });

      if (statusEl) {
        if (currentQuery || currentCat !== 'all') {
          statusEl.textContent = 'Найдено: ' + visibleCount;
        } else {
          statusEl.textContent = '';
        }
      }

      if (countDisplay) {
        countDisplay.textContent = String(visibleCount);
      }

      if (emptyEl) {
        emptyEl.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    }

    applyFilters();
  }

  initCatalog();
  document.addEventListener('astro:after-swap', initCatalog);
</script>
