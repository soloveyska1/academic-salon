---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const totalDocs = D.length;
const currentYear = String(new Date().getFullYear());

const categories = [...new Set(D.map((d: any) => d.category).filter(Boolean))].sort();

const typeShort: Record<string, string> = {
  'Самостоятельная работа': 'Самостоятельная',
  'Выпускная квалификационная работа': 'ВКР',
  'Экзаменационные материалы': 'Экзамен',
  'Контрольная работа': 'Контрольная',
  'Курсовая работа': 'Курсовая',
  'Отчет по практике': 'Отчёт по практике',
  'Отчет о научно-практической работе': 'Науч. отчёт',
  'Справочный материал': 'Справочник',
  'Нормативный документ': 'Нормативный',
  'Учебный документ': 'Учебный',
  'Шаблон документа': 'Шаблон',
  'Аналитический документ': 'Аналитика',
  'Практическое задание': 'Практическое',
  'Методические материалы': 'Методичка',
  'Учебная работа': 'Учебная',
  'Учебный материал': 'Учебный',
};

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const m = blob.match(/(?:19|20)\d{2}/);
  return m ? m[0] : currentYear;
}
---

<Base title="Каталог — Академический Салон" currentPath="/catalog">

  <!-- Compact sticky header -->
  <div class="hd" id="hd">
    <!-- Row 1: title + count + views -->
    <div class="hd-row1">
      <h1 class="hd-title">Каталог</h1>
      <span class="hd-count"><span id="cntN">{totalDocs}</span> из {totalDocs}</span>
      <div class="hd-views">
        <button class="hd-vbtn active" data-view="grid" aria-label="Сетка">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2"><rect x=".5" y=".5" width="5" height="5"/><rect x="8.5" y=".5" width="5" height="5"/><rect x=".5" y="8.5" width="5" height="5"/><rect x="8.5" y="8.5" width="5" height="5"/></svg>
        </button>
        <button class="hd-vbtn" data-view="list" aria-label="Список">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2"><line x1="0" y1="2.5" x2="14" y2="2.5"/><line x1="0" y1="7" x2="14" y2="7"/><line x1="0" y1="11.5" x2="14" y2="11.5"/></svg>
        </button>
      </div>
    </div>
    <!-- Row 2: search -->
    <div class="hd-row2">
      <input type="text" id="q" class="hd-q" placeholder="Поиск по названию или предмету" autocomplete="off" />
      <kbd class="hd-kbd" id="qHint">/</kbd>
    </div>
    <!-- Row 3: dropdowns -->
    <div class="hd-row3">
      <select class="hd-sel" id="catSel">
        <option value="all">Все категории</option>
        {categories.map(c => (
          <option value={c}>{c}</option>
        ))}
      </select>
      <select class="hd-sel" id="sortSel">
        <option value="default">По умолчанию</option>
        <option value="az">А — Я</option>
        <option value="za">Я — А</option>
        <option value="size">По размеру</option>
      </select>
    </div>
  </div>

  <!-- Content -->
  <main class="ct">
    <div class="ct-grid" id="grid" data-view="grid">
      {D.map((doc: any, i: number) => {
        const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
        const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
        const rawType = doc.docType || doc.category || '';
        const docType = typeShort[rawType] || rawType;
        const subject = doc.subject || '';
        const year = extractYear(doc);
        const meta = [subject, year, ext, doc.size].filter(Boolean).join(' · ');
        return (
          <a
            href={`/doc/${doc.file}`}
            class:list={['dc', { 'dc-lead': i === 0 }]}
            data-t={title.toLowerCase()}
            data-d={(doc.catalogDescription || doc.description || '').toLowerCase()}
            data-c={doc.category || ''}
            data-s={subject.toLowerCase()}
            data-k={(doc.course || '').toLowerCase()}
            data-g={(doc.tags || []).join(' ').toLowerCase()}
            data-z={doc.size || ''}
            data-i={i}
          >
            <span class="dc-type">{docType}</span>
            <h3 class="dc-name">{title}</h3>
            <span class="dc-meta">{meta}</span>
          </a>
        );
      })}
    </div>

    <div class="ct-empty" id="empty" style="display:none">
      <p class="ct-empty-t">Ничего не найдено</p>
      <p class="ct-empty-h">Измените запрос или сбросьте фильтры</p>
      <button class="ct-empty-btn" id="resetBtn">Сбросить</button>
    </div>
  </main>

</Base>

<style>
  /* ═══════ HEADER ═══════ */
  .hd {
    position: sticky;
    top: var(--nav-h);
    z-index: 40;
    background: #09090b;
    padding: 24px 48px 0;
    border-bottom: 1px solid rgba(255,255,255,.04);
  }

  .hd-row1 {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    align-items: baseline;
    gap: 16px;
  }

  .hd-title {
    font: 300 32px/1 var(--fd);
    color: rgba(255,255,255,.85);
    letter-spacing: .02em;
  }

  .hd-count {
    font: 400 11px/1 var(--fm);
    color: rgba(255,255,255,.25);
    letter-spacing: .04em;
    font-variant-numeric: tabular-nums;
    margin-right: auto;
  }

  .hd-views {
    display: flex;
    gap: 2px;
  }

  .hd-vbtn {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: rgba(255,255,255,.25);
    cursor: pointer;
    transition: color .3s cubic-bezier(.25,0,0,1);
  }

  .hd-vbtn:hover { color: rgba(255,255,255,.5); }
  .hd-vbtn.active { color: rgba(255,255,255,.85); }

  /* Row 2: search */
  .hd-row2 {
    max-width: var(--max-w);
    margin: 16px auto 0;
    position: relative;
  }

  .hd-q {
    width: 100%;
    padding: 12px 0;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,.08);
    background: transparent;
    color: rgba(255,255,255,.85);
    font: 400 15px/1.3 var(--fi);
    outline: none;
    transition: border-color .4s cubic-bezier(.25,0,0,1);
  }

  .hd-q::placeholder { color: rgba(255,255,255,.2); }
  .hd-q:focus { border-bottom-color: rgba(255,255,255,.2); }
  .hd-q:focus ~ .hd-kbd { display: none; }

  .hd-kbd {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font: 400 10px/1 var(--fm);
    color: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,.08);
    padding: 3px 7px;
    pointer-events: none;
  }

  /* Row 3: dropdowns */
  .hd-row3 {
    max-width: var(--max-w);
    margin: 12px auto 0;
    display: flex;
    gap: 24px;
    padding-bottom: 16px;
  }

  .hd-sel {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: none;
    font: 400 12px/1 var(--fi);
    color: rgba(255,255,255,.4);
    cursor: pointer;
    padding: 6px 0;
    outline: none;
    transition: color .3s cubic-bezier(.25,0,0,1);
  }

  .hd-sel:hover, .hd-sel:focus { color: rgba(255,255,255,.7); }

  .hd-sel option {
    background: #09090b;
    color: rgba(255,255,255,.85);
  }

  /* ═══════ CONTENT ═══════ */
  .ct {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 40px 48px 120px;
  }

  /* ── GRID VIEW ── */
  .ct-grid[data-view="grid"] {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .ct-grid[data-view="grid"] .dc {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 28px 24px;
    background: rgba(255,255,255,.02);
    border: 1px solid transparent;
    text-decoration: none;
    color: inherit;
    transition:
      background .5s cubic-bezier(.25,0,0,1),
      border-color .5s cubic-bezier(.25,0,0,1);
  }

  .ct-grid[data-view="grid"] .dc:hover {
    background: rgba(255,255,255,.04);
    border-color: rgba(255,255,255,.06);
  }

  .ct-grid[data-view="grid"] .dc-lead {
    grid-column: span 2;
  }

  /* ── LIST VIEW ── */
  .ct-grid[data-view="list"] {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .ct-grid[data-view="list"] .dc {
    display: grid;
    grid-template-columns: 100px 1fr 160px 90px;
    align-items: baseline;
    gap: 16px;
    padding: 13px 0;
    border-bottom: 1px solid rgba(255,255,255,.04);
    text-decoration: none;
    color: inherit;
    transition: background .5s cubic-bezier(.25,0,0,1);
  }

  .ct-grid[data-view="list"] .dc:hover {
    background: rgba(255,255,255,.02);
  }

  .ct-grid[data-view="list"] .dc-name {
    font: 400 14px/1.35 var(--fi);
    -webkit-line-clamp: 1;
  }

  .ct-grid[data-view="list"] .dc-meta {
    text-align: right;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Shared ── */
  .dc.hidden { display: none !important; }

  .dc-type {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .08em;
    color: rgba(255,255,255,.3);
  }

  .dc-name {
    font: 400 20px/1.3 var(--fd);
    color: rgba(255,255,255,.85);
    letter-spacing: .01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .dc-meta {
    font: 400 11px/1.3 var(--fm);
    color: rgba(255,255,255,.2);
    letter-spacing: .02em;
  }

  /* ═══════ EMPTY ═══════ */
  .ct-empty {
    text-align: center;
    padding: 96px 24px;
  }

  .ct-empty-t {
    font: 300 italic 24px/1.2 var(--fd);
    color: rgba(255,255,255,.5);
  }

  .ct-empty-h {
    margin-top: 10px;
    font: 400 13px/1.5 var(--fi);
    color: rgba(255,255,255,.2);
  }

  .ct-empty-btn {
    margin-top: 24px;
    background: none;
    border: .5px solid rgba(255,255,255,.12);
    padding: 12px 36px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: rgba(255,255,255,.5);
    cursor: pointer;
    transition: color .4s cubic-bezier(.25,0,0,1), border-color .4s cubic-bezier(.25,0,0,1);
  }

  .ct-empty-btn:hover { color: rgba(255,255,255,.85); border-color: rgba(255,255,255,.25); }

  /* ═══════ TABLET ═══════ */
  @media (max-width: 1024px) {
    .ct-grid[data-view="grid"] { grid-template-columns: repeat(2, 1fr); }
    .ct-grid[data-view="grid"] .dc-lead { grid-column: span 2; }
    .ct-grid[data-view="list"] .dc { grid-template-columns: 80px 1fr 90px; }
    .ct-grid[data-view="list"] .dc-meta:first-of-type { display: none; }
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 640px) {
    .hd { padding: 20px 24px 0; }
    .hd-title { font-size: 24px; }
    .ct { padding: 32px 24px 80px; }

    .ct-grid[data-view="grid"] { grid-template-columns: 1fr; }
    .ct-grid[data-view="grid"] .dc-lead { grid-column: span 1; }

    .ct-grid[data-view="list"] .dc {
      grid-template-columns: 1fr auto;
      gap: 8px;
    }
    .ct-grid[data-view="list"] .dc-type { display: none; }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .dc, .hd-q, .hd-sel, .hd-vbtn, .ct-empty-btn {
      transition: none !important;
    }
  }
</style>

<script>
  function initCatalog() {
    var grid = document.getElementById('grid');
    var input = document.getElementById('q');
    var hint = document.getElementById('qHint');
    var emptyEl = document.getElementById('empty');
    var resetBtn = document.getElementById('resetBtn');
    var cntEl = document.getElementById('cntN');
    var catSel = document.getElementById('catSel');
    var sortSel = document.getElementById('sortSel');
    var viewBtns = document.querySelectorAll('.hd-vbtn');

    if (!grid || !input) return;

    var docs = Array.from(grid.querySelectorAll('.dc'));
    var query = '';
    var cat = 'all';
    var sort = 'default';
    var timer = 0;

    var qp = new URLSearchParams(window.location.search).get('q');
    if (qp) { input.value = qp; query = qp.toLowerCase(); }

    /* Search — 200ms debounce */
    input.addEventListener('input', function() {
      clearTimeout(timer);
      timer = setTimeout(function() {
        query = input.value.toLowerCase().trim();
        run();
      }, 200);
    });

    input.addEventListener('focus', function() { if (hint) hint.style.display = 'none'; });
    input.addEventListener('blur', function() { if (hint && !input.value) hint.style.display = ''; });

    /* Category dropdown */
    if (catSel) catSel.addEventListener('change', function() { cat = catSel.value; run(); });

    /* Sort dropdown */
    if (sortSel) sortSel.addEventListener('change', function() { sort = sortSel.value; doSort(); run(); });

    /* View switch */
    viewBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        viewBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        grid.setAttribute('data-view', btn.dataset.view);
      });
    });

    /* Reset */
    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        input.value = ''; query = ''; cat = 'all'; sort = 'default';
        if (catSel) catSel.value = 'all';
        if (sortSel) sortSel.value = 'default';
        run();
      });
    }

    /* Keyboard: / to search, Escape to clear */
    document.addEventListener('keydown', function(e) {
      var tag = e.target.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') {
        if (e.key === 'Escape') { input.blur(); input.value = ''; query = ''; run(); }
        return;
      }
      if (e.key === '/') { e.preventDefault(); input.focus(); }
    });

    function parseSize(s) {
      if (!s) return 0;
      var m = s.match(/([\d.,]+)\s*(МБ|MB|КБ|KB|Б|B)?/i);
      if (!m) return 0;
      var v = parseFloat(m[1].replace(',', '.'));
      var u = (m[2] || '').toUpperCase();
      if (u === 'КБ' || u === 'KB') v *= 1024;
      if (u === 'МБ' || u === 'MB') v *= 1048576;
      return v;
    }

    function doSort() {
      var arr = docs.slice();
      if (sort === 'az') arr.sort(function(a,b) { return (a.dataset.t||'').localeCompare(b.dataset.t||'','ru'); });
      else if (sort === 'za') arr.sort(function(a,b) { return (b.dataset.t||'').localeCompare(a.dataset.t||'','ru'); });
      else if (sort === 'size') arr.sort(function(a,b) { return parseSize(b.dataset.z||'') - parseSize(a.dataset.z||''); });
      else arr.sort(function(a,b) { return parseInt(a.dataset.i||'0') - parseInt(b.dataset.i||'0'); });
      arr.forEach(function(el) { grid.appendChild(el); });
    }

    function run() {
      var n = 0;
      docs.forEach(function(el) {
        var ok = true;
        if (cat !== 'all' && el.dataset.c !== cat) ok = false;
        if (ok && query) {
          var h = [el.dataset.t, el.dataset.d, (el.dataset.c||'').toLowerCase(), el.dataset.s, el.dataset.k, el.dataset.g].join(' ');
          var words = query.split(/\s+/);
          ok = words.every(function(w) { return h.includes(w); });
        }
        if (ok) { el.classList.remove('hidden'); n++; }
        else { el.classList.add('hidden'); }
      });
      if (cntEl) cntEl.textContent = String(n);
      if (emptyEl) emptyEl.style.display = n === 0 ? 'block' : 'none';
    }

    run();
  }

  initCatalog();
  document.addEventListener('astro:after-swap', initCatalog);
</script>
