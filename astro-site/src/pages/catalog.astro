---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const total = D.length;
const year = String(new Date().getFullYear());

const shortType: Record<string, string> = {
  'Самостоятельная работа': 'Самост.',
  'Выпускная квалификационная работа': 'ВКР',
  'Экзаменационные материалы': 'Экзамен',
  'Контрольная работа': 'Контрольная',
  'Курсовая работа': 'Курсовая',
  'Отчет по практике': 'Практика',
  'Отчет о научно-практической работе': 'НПР',
  'Справочный материал': 'Справочник',
  'Нормативный документ': 'Норматив',
  'Учебный документ': 'Учебный',
  'Шаблон документа': 'Шаблон',
  'Аналитический документ': 'Аналитика',
  'Практическое задание': 'Практич.',
  'Методические материалы': 'Методичка',
  'Учебная работа': 'Учебная',
  'Учебный материал': 'Учебный',
};

function getYear(doc: any) {
  const s = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const m = s.match(/(?:19|20)\d{2}/);
  return m ? m[0] : year;
}

function shortCatName(cat: string): string {
  const map: Record<string, string> = {
    'Самостоятельные работы': 'Самост.',
    'Методические материалы': 'Методич.',
    'Отчёты по практике': 'Практика',
    'ВКР и дипломы': 'ВКР',
    'Конспекты лекций': 'Конспекты',
    'Курсовые работы': 'Курсовые',
    'Рефераты': 'Рефераты',
  };
  return map[cat] || cat;
}

/* Group documents by category, sorted by count (largest first) */
const categoryMap = new Map<string, any[]>();
for (const doc of D) {
  const cat = (doc as any).category || 'Разное';
  if (!categoryMap.has(cat)) categoryMap.set(cat, []);
  categoryMap.get(cat)!.push(doc);
}
const sortedCategories = [...categoryMap.entries()].sort((a, b) => b[1].length - a[1].length);
---

<Base title="Каталог -- Библиотека академического салона" description="Каталог студенческих работ: курсовые, рефераты, ВКР, отчёты по практике. Бесплатное скачивание без регистрации." currentPath="/catalog">

  <!-- ============================================================
       HERO -- compact, atmospheric
       ============================================================ -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <h1 class="hero-title">Каталог</h1>
      <div class="hero-rule" aria-hidden="true"></div>
      <p class="hero-sub">{total} работ -- бесплатно, без регистрации</p>
      <button class="search-trigger" id="searchTrigger" type="button">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span>Найти работу...</span>
        <kbd>/</kbd>
      </button>
    </div>
  </section>

  <!-- ============================================================
       SIDE NAV -- floating category index
       ============================================================ -->
  <nav class="side-nav" id="sideNav" aria-label="Категории">
    {sortedCategories.map(([cat, _docs], i) => (
      <a href={'#cat-' + i} class="side-dot" data-cat={i} title={cat}>
        <span class="side-label">{shortCatName(cat)}</span>
      </a>
    ))}
  </nav>

  <!-- ============================================================
       MAGAZINE CONTENT -- category spreads
       ============================================================ -->
  <div class="magazine" id="magazine">
    {sortedCategories.map(([category, docs], catIndex) => (
      <section class="spread" id={'cat-' + catIndex} data-cat-name={category}>
        <header class="spread-head">
          <span class="spread-num" aria-hidden="true">{String(catIndex + 1).padStart(2, '0')}</span>
          <h2 class="spread-title">{category}</h2>
          <span class="spread-count">{docs.length}</span>
        </header>
        <div class="spread-body">
          {docs.map((doc: any) => {
            const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
            const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
            const rawType = doc.docType || doc.category || '';
            const type = shortType[rawType] || rawType;
            const subj = doc.subject || '';
            const yr = getYear(doc);
            return (
              <a href={'/doc/' + doc.file} class="entry" data-t={title.toLowerCase()} data-s={subj.toLowerCase()} data-c={category.toLowerCase()}>
                <span class="entry-type">{type}</span>
                <span class="entry-title">{title}</span>
                <span class="entry-meta">{[subj, yr, ext].filter(Boolean).join(' \u00b7 ')}</span>
              </a>
            );
          })}
        </div>
      </section>
    ))}
  </div>

  <!-- ============================================================
       SEARCH OVERLAY -- command palette style
       ============================================================ -->
  <div class="search-overlay" id="searchOverlay" aria-hidden="true">
    <div class="search-panel">
      <div class="search-header">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" id="q" placeholder="Тема, предмет или тип работы..." autocomplete="off" autocorrect="off" spellcheck="false" aria-label="Поиск документов" />
        <button class="search-close" id="searchClose" type="button">
          <kbd>Esc</kbd>
        </button>
      </div>
      <div class="search-results" id="searchResults">
        <!-- Filled by JS -->
      </div>
    </div>
  </div>

  <!-- ============================================================
       ORDER CTA
       ============================================================ -->
  <section class="order rv">
    <div class="order-inner">
      <h2 class="order-title">Не нашли нужную работу?</h2>
      <p class="order-sub">Напишем индивидуально -- от 3 000 &#8381;</p>
      <a href="/order" class="btn btn--primary">Заказать</a>
    </div>
  </section>

  <!-- ============================================================
       FOOTER
       ============================================================ -->
  <footer class="foot">
    <span>&copy; 2020&ndash;2026 Библиотека академического салона</span>
  </footer>

  <!-- Back to top -->
  <button class="top-btn" id="topBtn" type="button" aria-label="Наверх">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>

</Base>

<style>
  /* ================================================================
     CATALOG -- Editorial Magazine
     Monocle meets command palette. Gold on obsidian. CSS columns.
     Each category is a "spread" with editorial numbering.
     ================================================================ */

  :global(.footer) { display: none; }

  /* ----------------------------------------------------------------
     ANIMATIONS
     ---------------------------------------------------------------- */
  @keyframes fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes glow-breathe {
    0%, 100% { opacity: .65; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.06); }
  }

  .rv {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .6s var(--ease), transform .6s var(--ease);
  }
  .rv.vis { opacity: 1; transform: translateY(0); }

  /* ----------------------------------------------------------------
     BUTTONS -- exact homepage match
     ---------------------------------------------------------------- */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 16px 40px;
    border-radius: 0;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    text-decoration: none;
    color: var(--t1);
    border: 1px solid var(--ac-b);
    cursor: pointer;
    transition:
      transform .3s var(--ease),
      border-color .3s var(--ease),
      box-shadow .3s var(--ease);
  }
  .btn--primary {
    background: var(--surf);
    border-color: var(--ac-b);
  }
  .btn:hover {
    transform: translateY(-2px);
    border-color: var(--ac-b3);
    box-shadow: 0 12px 40px var(--ac-sh);
  }
  .btn--primary:hover { box-shadow: 0 12px 40px var(--ac-g); }

  /* ----------------------------------------------------------------
     HERO -- compact, atmospheric, same glow as homepage
     ---------------------------------------------------------------- */
  .hero {
    position: relative;
    padding: calc(var(--nav-h) + 80px) 24px 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-glow {
    position: absolute;
    width: min(1100px, 95vw);
    height: min(900px, 85vw);
    top: 45%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45% at 50% 48%, rgba(212,175,55,.22) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 48% 44%, rgba(212,175,55,.14) 0%, transparent 50%),
      radial-gradient(ellipse 75% 55% at 42% 52%, rgba(180,130,20,.08) 0%, transparent 75%);
    pointer-events: none;
    z-index: 0;
    animation: glow-breathe 10s ease-in-out infinite;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 960px;
    text-align: center;
    padding: 0 8px;
  }

  .hero-title {
    font: 300 clamp(48px, 10vw, 80px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: -.02em;
    text-shadow: 0 0 120px rgba(212,175,55,.06), 0 4px 24px rgba(0,0,0,.3);
  }

  .hero-rule {
    width: 48px;
    height: 1px;
    margin: 24px auto 0;
    background: linear-gradient(90deg, transparent, var(--ac), transparent);
    opacity: .35;
  }

  .hero-sub {
    margin-top: 20px;
    font: 400 15px/1.6 var(--fi);
    color: var(--t2);
    max-width: 52ch;
    margin-inline: auto;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out .4s forwards;
  }

  /* ----------------------------------------------------------------
     SEARCH TRIGGER BUTTON (opens command palette)
     ---------------------------------------------------------------- */
  .search-trigger {
    display: flex;
    align-items: center;
    gap: 12px;
    max-width: 480px;
    width: 100%;
    margin: 32px auto 0;
    padding: 14px 20px;
    border: 1px solid var(--brd);
    border-radius: 999px;
    background: rgba(255,255,255,.04);
    color: var(--t3);
    font: 400 15px/1 var(--fi);
    cursor: pointer;
    transition: border-color .3s, background .3s;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out .6s forwards;
  }

  .search-trigger:hover {
    border-color: rgba(255,255,255,.12);
    background: rgba(255,255,255,.06);
  }

  .search-trigger:focus-visible {
    outline: 2px solid var(--ac-b2);
    outline-offset: 2px;
  }

  .search-trigger svg { opacity: .5; flex-shrink: 0; }
  .search-trigger span { flex: 1; text-align: left; }
  .search-trigger kbd {
    font: 400 10px/1 var(--fm);
    border: 1px solid var(--brd);
    padding: 3px 7px;
    border-radius: 4px;
    opacity: .5;
  }

  /* ----------------------------------------------------------------
     SIDE NAVIGATION -- floating category dots
     ---------------------------------------------------------------- */
  .side-nav {
    position: fixed;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 80;
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-end;
  }

  .side-dot {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--t3);
    transition: color .2s;
  }

  .side-dot::after {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--t3);
    opacity: .3;
    transition: opacity .2s, transform .2s, background .2s;
    flex-shrink: 0;
  }

  .side-dot:hover::after,
  .side-dot.active::after {
    opacity: 1;
    background: var(--ac);
    transform: scale(1.4);
  }

  .side-label {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .08em;
    opacity: 0;
    transform: translateX(4px);
    transition: opacity .2s, transform .2s;
    white-space: nowrap;
  }

  .side-dot:hover .side-label,
  .side-dot.active .side-label {
    opacity: 1;
    transform: translateX(0);
  }

  /* ----------------------------------------------------------------
     MAGAZINE SPREADS -- editorial layout
     ---------------------------------------------------------------- */
  .magazine {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 48px 80px;
    background: var(--bg);
  }

  .spread {
    padding: 80px 0;
    border-bottom: 1px solid var(--brd);
  }

  .spread:last-child { border-bottom: none; }

  .spread-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 48px;
  }

  .spread-num {
    font: 300 48px/1 var(--fm);
    color: var(--ac);
    opacity: .1;
  }

  .spread-title {
    font: 300 clamp(28px, 5vw, 40px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  .spread-count {
    font: 400 13px/1 var(--fm);
    color: var(--t3);
  }

  /* CSS COLUMNS -- the magazine magic */
  .spread-body {
    column-count: 2;
    column-gap: 32px;
    column-rule: 1px solid rgba(255,255,255,.04);
  }

  /* ----------------------------------------------------------------
     ENTRY -- document item (editorial, compact, not a card)
     ---------------------------------------------------------------- */
  .entry {
    display: block;
    break-inside: avoid;
    padding: 20px 0;
    border-bottom: 1px solid rgba(255,255,255,.04);
    text-decoration: none;
    color: var(--t1);
    transition: border-color .2s;
  }

  .entry:last-child { border-bottom: none; }

  .entry:hover {
    border-bottom-color: rgba(212,175,55,.15);
  }

  .entry:focus-visible {
    outline: 2px solid var(--ac-b2);
    outline-offset: 2px;
  }

  .entry-type {
    display: block;
    font: 400 9px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--ac);
    opacity: .5;
    margin-bottom: 6px;
  }

  .entry-title {
    display: block;
    font: 400 16px/1.4 var(--fd);
    color: var(--t1);
    transition: color .2s;
  }

  .entry:hover .entry-title { color: var(--ac); }

  .entry-meta {
    display: block;
    margin-top: 6px;
    font: 400 11px/1 var(--fi);
    color: var(--t3);
  }

  /* ----------------------------------------------------------------
     SEARCH OVERLAY -- command palette
     ---------------------------------------------------------------- */
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: min(20vh, 160px);
    background: rgba(0,0,0,.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    opacity: 0;
    visibility: hidden;
    transition: opacity .2s, visibility .2s;
  }

  .search-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .search-panel {
    width: min(640px, 90vw);
    max-height: 70vh;
    background: rgba(20,18,24,.95);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0,0,0,.5);
    transform: scale(.96) translateY(-8px);
    transition: transform .2s ease-out;
  }

  .search-overlay.is-open .search-panel {
    transform: scale(1) translateY(0);
  }

  .search-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255,255,255,.06);
  }

  .search-header svg { color: var(--t3); flex-shrink: 0; }

  .search-header input {
    flex: 1;
    border: none;
    background: none;
    color: var(--t1);
    font: 400 16px/1.4 var(--fi);
    outline: none;
  }

  .search-header input::placeholder { color: var(--t3); }

  .search-close {
    border: none;
    background: none;
    cursor: pointer;
    padding: 0;
  }

  .search-close kbd {
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    border: 1px solid rgba(255,255,255,.1);
    padding: 4px 8px;
    border-radius: 4px;
  }

  .search-results {
    max-height: calc(70vh - 56px);
    overflow-y: auto;
    padding: 8px;
  }

  /* Search result items */
  :global(.sr-item) {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 16px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--t1);
    transition: background .15s;
  }

  :global(.sr-item:hover),
  :global(.sr-item.focused) {
    background: rgba(255,255,255,.06);
  }

  :global(.sr-type) {
    font: 400 9px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--ac);
    opacity: .6;
  }

  :global(.sr-title) {
    font: 400 15px/1.3 var(--fi);
    color: var(--t1);
  }

  :global(.sr-meta) {
    font: 400 11px/1 var(--fi);
    color: var(--t3);
  }

  :global(.sr-empty) {
    padding: 32px 16px;
    text-align: center;
    font: 400 14px/1.5 var(--fi);
    color: var(--t3);
  }

  :global(.hl) {
    background: rgba(212,175,55,.2);
    color: var(--ac);
    border-radius: 2px;
    padding: 0 2px;
  }

  /* ----------------------------------------------------------------
     ORDER CTA
     ---------------------------------------------------------------- */
  .order {
    padding: 120px 24px;
    background: var(--bg);
  }

  .order-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    text-align: center;
  }

  .order-title {
    font: 300 clamp(28px, 5vw, 40px)/1.2 var(--fd);
    color: var(--t1);
    margin-bottom: 16px;
  }

  .order-sub {
    font: 400 14px/1.6 var(--fi);
    color: var(--t3);
    margin-bottom: 40px;
  }

  /* ----------------------------------------------------------------
     FOOTER
     ---------------------------------------------------------------- */
  .foot {
    padding: 64px 24px;
    background: var(--bg);
    text-align: center;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    letter-spacing: .04em;
  }

  /* ----------------------------------------------------------------
     BACK TO TOP
     ---------------------------------------------------------------- */
  .top-btn {
    position: fixed;
    bottom: calc(80px + env(safe-area-inset-bottom, 0px));
    right: 24px;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ac-b);
    border-radius: 999px;
    background: var(--bg);
    color: var(--ac);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity .3s, transform .3s, border-color .3s;
    z-index: 50;
  }
  .top-btn.is-visible { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .top-btn:hover { border-color: var(--ac-b3); box-shadow: 0 8px 24px var(--ac-sh); }
  .top-btn:focus-visible { outline: 2px solid var(--ac-b2); outline-offset: 2px; }

  /* ----------------------------------------------------------------
     LIGHT THEME OVERRIDES
     ---------------------------------------------------------------- */
  :global([data-theme="light"]) .hero-glow {
    background:
      radial-gradient(ellipse 55% 45% at 50% 48%, rgba(180,145,30,.12) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 48% 44%, rgba(180,145,30,.08) 0%, transparent 50%),
      radial-gradient(ellipse 75% 55% at 42% 52%, rgba(160,120,15,.05) 0%, transparent 75%);
  }

  :global([data-theme="light"]) .search-trigger {
    background: rgba(0,0,0,.03);
    border-color: rgba(0,0,0,.1);
  }

  :global([data-theme="light"]) .search-trigger:hover {
    background: rgba(0,0,0,.05);
    border-color: rgba(0,0,0,.15);
  }

  :global([data-theme="light"]) .entry {
    border-color: rgba(0,0,0,.06);
  }

  :global([data-theme="light"]) .entry:hover {
    border-bottom-color: rgba(122,95,18,.2);
  }

  :global([data-theme="light"]) .spread {
    border-color: rgba(0,0,0,.06);
  }

  :global([data-theme="light"]) .spread-body {
    column-rule-color: rgba(0,0,0,.06);
  }

  :global([data-theme="light"]) .search-panel {
    background: rgba(255,255,255,.98);
    border-color: rgba(0,0,0,.08);
  }

  :global([data-theme="light"]) .search-header {
    border-bottom-color: rgba(0,0,0,.06);
  }

  :global([data-theme="light"]) .search-header input {
    color: var(--t1);
  }

  :global([data-theme="light"]) .search-close kbd {
    color: var(--t3);
    border-color: rgba(0,0,0,.1);
  }

  :global([data-theme="light"]) :global(.sr-item:hover),
  :global([data-theme="light"]) :global(.sr-item.focused) {
    background: rgba(0,0,0,.04);
  }

  :global([data-theme="light"]) .side-dot::after {
    background: var(--t3);
  }

  :global([data-theme="light"]) :global(.hl) {
    background: rgba(180,140,20,.12);
    color: #8b6914;
  }

  :global([data-theme="light"]) .search-overlay {
    background: rgba(255,255,255,.6);
  }

  /* ----------------------------------------------------------------
     REDUCED MOTION
     ---------------------------------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    .hero-sub,
    .search-trigger {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .hero-glow {
      animation: none;
      opacity: .8;
      transform: translate(-50%, -50%);
    }
    .rv { opacity: 1; transform: none; transition: none; }
    .search-panel { transition: none; }
    .search-overlay { transition: none; }
  }

  /* ----------------------------------------------------------------
     MOBILE (max 768px)
     ---------------------------------------------------------------- */
  @media (max-width: 768px) {
    .side-nav { display: none; }
    .magazine { padding: 0 20px 48px; }
    .spread { padding: 48px 0; }
    .spread-body { column-count: 1; }
    .spread-num { font-size: 32px; }
    .search-trigger kbd { display: none; }

    .hero { padding: calc(var(--nav-h) + 48px) 20px 48px; }
    .order { padding: 64px 20px; }
    .order .btn { width: 100%; max-width: 320px; }
    .foot { padding: 48px 20px; }
    .spread-head { gap: 12px; margin-bottom: 32px; }
    .entry { padding: 16px 0; }

    .top-btn { bottom: calc(60px + env(safe-area-inset-bottom, 0px)); }
  }
</style>

<script>
  function init() {
    /* ============================================================
       SEARCH OVERLAY -- Command Palette
       ============================================================ */
    var overlay = document.getElementById('searchOverlay');
    var searchInput = document.getElementById('q') as HTMLInputElement | null;
    var searchResults = document.getElementById('searchResults');
    var trigger = document.getElementById('searchTrigger');
    var closeBtn = document.getElementById('searchClose');

    if (!overlay || !searchInput || !searchResults || !trigger || !closeBtn) return;
    if ((overlay as any).__bound) return;
    (overlay as any).__bound = true;

    /* All entries for search */
    var allEntries = Array.from(document.querySelectorAll('.entry'));

    function openSearch() {
      overlay!.classList.add('is-open');
      overlay!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      setTimeout(function() { searchInput!.focus(); }, 100);
    }

    function closeSearch() {
      overlay!.classList.remove('is-open');
      overlay!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      searchInput!.value = '';
      searchResults!.innerHTML = '';
    }

    trigger.addEventListener('click', openSearch);
    closeBtn.addEventListener('click', closeSearch);
    overlay.addEventListener('click', function(e) {
      if (e.target === overlay) closeSearch();
    });

    /* "/" keyboard shortcut */
    document.addEventListener('keydown', function(e) {
      if (e.key === '/' && !['INPUT','TEXTAREA','SELECT'].includes((document.activeElement || {} as any).tagName)) {
        e.preventDefault();
        openSearch();
      }
      if (e.key === 'Escape' && overlay!.classList.contains('is-open')) {
        closeSearch();
      }
    });

    /* Live search with fuzzy matching */
    var timer = 0;
    searchInput.addEventListener('input', function() {
      clearTimeout(timer);
      timer = window.setTimeout(function() {
        var q = searchInput!.value.trim().toLowerCase();
        if (!q) { searchResults!.innerHTML = ''; return; }

        var words = q.split(/\s+/);
        var matches: Element[] = [];

        allEntries.forEach(function(entry) {
          var hay = [
            (entry as HTMLElement).dataset.t,
            (entry as HTMLElement).dataset.s,
            (entry as HTMLElement).dataset.c
          ].join(' ');
          var ok = words.every(function(w) {
            if (hay.includes(w)) return true;
            /* Fuzzy: allow 1 char diff for words >= 4 chars */
            if (w.length >= 4) {
              for (var i = 0; i <= hay.length - w.length; i++) {
                var diff = 0;
                for (var j = 0; j < w.length; j++) {
                  if (hay[i + j] !== w[j]) diff++;
                  if (diff > 1) break;
                }
                if (diff <= 1) return true;
              }
            }
            return false;
          });
          if (ok) matches.push(entry);
        });

        if (matches.length === 0) {
          searchResults!.innerHTML = '<div class="sr-empty">Ничего не найдено. <a href="/order" style="color:var(--ac)">Заказать работу?</a></div>';
          return;
        }

        /* Render results (max 20) */
        searchResults!.innerHTML = matches.slice(0, 20).map(function(entry) {
          var titleEl = entry.querySelector('.entry-title');
          var typeEl = entry.querySelector('.entry-type');
          var metaEl = entry.querySelector('.entry-meta');
          var title = titleEl ? titleEl.textContent || '' : '';
          var type = typeEl ? typeEl.textContent || '' : '';
          var meta = metaEl ? metaEl.textContent || '' : '';

          /* Highlight matches */
          words.forEach(function(w) {
            var re = new RegExp('(' + w.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
            title = title.replace(re, '<span class="hl">$1</span>');
          });

          return '<a href="' + entry.getAttribute('href') + '" class="sr-item">' +
            '<span class="sr-type">' + type + '</span>' +
            '<span class="sr-title">' + title + '</span>' +
            '<span class="sr-meta">' + meta + '</span>' +
          '</a>';
        }).join('');

        if (matches.length > 20) {
          searchResults!.innerHTML += '<div class="sr-empty">Показано 20 из ' + matches.length + '</div>';
        }
      }, 150);
    });

    /* URL ?q= param sync */
    var qp = new URLSearchParams(window.location.search).get('q');
    if (qp) {
      openSearch();
      searchInput.value = qp;
      searchInput.dispatchEvent(new Event('input'));
    }

    /* ============================================================
       SIDE NAV -- active state on scroll
       ============================================================ */
    var sideNav = document.getElementById('sideNav');
    if (sideNav) {
      var dots = Array.from(sideNav.querySelectorAll('.side-dot'));
      var spreads = Array.from(document.querySelectorAll('.spread'));

      var sideObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (!e.isIntersecting) return;
          var idx = spreads.indexOf(e.target as HTMLElement);
          dots.forEach(function(d, i) { d.classList.toggle('active', i === idx); });
        });
      }, { threshold: 0.3 });

      spreads.forEach(function(s) { sideObserver.observe(s); });

      /* Smooth scroll on dot click */
      dots.forEach(function(dot) {
        dot.addEventListener('click', function(e) {
          e.preventDefault();
          var href = dot.getAttribute('href');
          if (href) {
            var target = document.querySelector(href);
            if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    }

    /* ============================================================
       SCROLL REVEAL
       ============================================================ */
    if ('IntersectionObserver' in window) {
      var rvObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.classList.add('vis'); rvObserver.unobserve(e.target); }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.rv').forEach(function(el) { rvObserver.observe(el); });
    } else {
      document.querySelectorAll('.rv').forEach(function(el) { el.classList.add('vis'); });
    }

    /* ============================================================
       BACK TO TOP
       ============================================================ */
    var topBtn = document.getElementById('topBtn');
    if (topBtn) {
      window.addEventListener('scroll', function() {
        topBtn!.classList.toggle('is-visible', window.scrollY > window.innerHeight);
      }, { passive: true });
      topBtn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>
