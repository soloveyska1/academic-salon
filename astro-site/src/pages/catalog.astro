</style>

<script>
// Russian-academic vocabulary aliases — «диплом» finds «ВКР» etc.
// All keys + values must be lowercase; the lookup happens against
// already-lowercased haystacks (data-t / data-s / etc.).
const SEARCH_SYNONYMS: Record<string, string[]> = {
  'диплом':         ['вкр', 'квалификационная', 'выпускная', 'дипломная'],
  'дипломная':      ['вкр', 'квалификационная', 'выпускная', 'диплом'],
  'вкр':            ['диплом', 'дипломная', 'квалификационная', 'выпускная'],
  'квалификационная': ['диплом', 'дипломная', 'вкр', 'выпускная'],
  'выпускная':      ['диплом', 'дипломная', 'вкр', 'квалификационная'],
  'курсовая':       ['семестровая'],
  'семестровая':    ['курсовая'],
  'реферат':        ['доклад'],
  'доклад':         ['реферат'],
  'эссе':           ['сочинение'],
  'сочинение':      ['эссе'],
  'кр':             ['контрольная'],
  'контрольная':    ['кр'],
  'магистерская':   ['магистратура'],
  'магистратура':   ['магистерская'],
  'практика':       ['практическая'],
  'самостоятельная': ['самостоятельно', 'самраб'],
};

function expandSynonyms(word: string): string[] {
  const aliases = SEARCH_SYNONYMS[word];
  return aliases ? [word, ...aliases] : [word];
}

function fuzzyContains(hay: string, needle: string): boolean {
  if (hay.includes(needle)) return true;
  // 1-char tolerance for words ≥4 chars (typo-resilience)
  if (needle.length < 4) return false;
  for (let i = 0; i <= hay.length - needle.length; i++) {
    let diff = 0;
    for (let j = 0; j < needle.length; j++) {
      if (hay[i + j] !== needle[j]) diff++;
      if (diff > 1) break;
    }
    if (diff <= 1) return true;
  }
  return false;
}

function initCatalog() {
  const app = document.querySelector('.app') as HTMLElement | null;
  if (!app || app.dataset.bound === '1') return;
  app.dataset.bound = '1';

  const input = document.getElementById('q') as HTMLInputElement | null;
  const rows = Array.from(document.querySelectorAll<HTMLElement>('.row'));
  const tabs = Array.from(document.querySelectorAll<HTMLElement>('.tab'));
  const nil = document.getElementById('nil');
  const tableWrap = document.getElementById('tableWrap');
  const tableBody = document.getElementById('tableBody');
  const visCountEl = document.getElementById('visCount');
  const visCountFootEl = document.getElementById('visCountFoot');
  const resetBtn = document.getElementById('resetBtn');
  const hint = document.getElementById('hint');
  const clearBtn = document.getElementById('clearBtn');
  const sortBtn = document.getElementById('sortBtn');
  const sortMenu = document.getElementById('sortMenu');
  const sortOpts = Array.from(document.querySelectorAll<HTMLElement>('.sort-opt'));
  const searchWrap = input?.closest('.topbar-search') as HTMLElement | null;

  if (!input || !rows.length) return;

  let q = '', cat = 'all';
  let timer = 0;

  // #8 — Store original titles + subjects once to prevent highlight corruption
  const origTitles = new Map<HTMLElement, string>();
  const origSubjs = new Map<HTMLElement, string>();
  rows.forEach(row => {
    const el = row.querySelector('.td-title');
    if (el) origTitles.set(row, el.textContent || '');
    const sEl = row.querySelector('.td-subj');
    if (sEl) origSubjs.set(row, sEl.textContent || '');
  });

  // #2 — Favorites: load from localStorage
  function getFavs(): Set<string> {
    try { return new Set(JSON.parse(localStorage.getItem('favorites') || '[]')); }
    catch { return new Set(); }
  }
  function saveFavs(favs: Set<string>) {
    try { localStorage.setItem('favorites', JSON.stringify([...favs])); } catch (_) {}
  }
  function syncFavs() {
    const favs = getFavs();
    rows.forEach(row => {
      const btn = row.querySelector('.td-fav') as HTMLElement | null;
      if (btn) {
        const file = btn.dataset.file || '';
        btn.classList.toggle('is-fav', favs.has(file));
      }
    });
  }
  syncFavs();

  // Cross-tab sync — if user toggles favourite in another tab/doc page, refresh UI here.
  window.addEventListener('storage', (e: StorageEvent) => {
    if (e.key === 'favorites') {
      syncFavs();
      if (typeof updateFavTabCount === 'function') updateFavTabCount();
    }
  });

  // #13 — Favorites count in tab
  function updateFavTabCount() {
    const el = document.getElementById('favTabCount');
    if (el) el.textContent = String(getFavs().size);
  }
  updateFavTabCount();

  // #2 — Favorites: event delegation on tableBody. localStorage stays
  // the source of truth for the unauthenticated case; when the user is
  // signed in we mirror the toggle to /api/me/favorites in the
  // background so all their devices stay in sync without a page reload.
  function syncFavWithServer(file: string, added: boolean) {
    const opts: RequestInit = {
      method: added ? 'POST' : 'DELETE',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ file }),
    };
    // Fail-silent: 401 just means the user isn't signed in here, that
    // is the normal anonymous flow, no UI noise.
    fetch('/api/me/favorites', opts).catch(() => {});
  }

  if (tableBody) {
    tableBody.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.td-fav') as HTMLElement | null;
      if (!btn) return;
      e.preventDefault();
      e.stopPropagation();
      const file = btn.dataset.file || '';
      const favs = getFavs();
      const added = !favs.has(file);
      if (added) favs.add(file); else favs.delete(file);
      saveFavs(favs);
      btn.classList.toggle('is-fav', added);
      updateFavTabCount();
      syncFavWithServer(file, added);
      // Re-filter if fav tab is active
      if (cat === '__fav') run();
    });
  }

  // #5 — Clear button visibility
  function updateClearBtn() {
    if (clearBtn) clearBtn.style.display = input!.value.length > 0 ? '' : 'none';
  }

  function run() {
    // #2 — Remove letter separators before filtering
    tableBody?.querySelectorAll('.letter-sep').forEach(el => el.remove());

    var n = 0;
    var words = q ? q.split(/\s+/) : [];
    const scored: { el: HTMLElement; score: number }[] = [];

    rows.forEach(function(row) {
      var el = row as HTMLElement;
      var ok = true;

      // Category filter
      if (cat === '__fav') {
        const favs = getFavs();
        const btn = el.querySelector('.td-fav') as HTMLElement | null;
        const file = btn?.dataset.file || '';
        if (!favs.has(file)) ok = false;
      } else if (cat !== 'all' && el.dataset.c !== cat) ok = false;

      // Search with relevance scoring (#23) + synonym expansion (#40)
      var score = 0;
      if (ok && words.length) {
        var titleHay = el.dataset.t || '';
        var subjHay = el.dataset.s || '';
        var catHay = (el.dataset.c || '').toLowerCase();
        var descHay = (el.dataset.desc || '').toLowerCase();
        var tagsHay = (el.dataset.tags || '').toLowerCase();
        var hay = [titleHay, subjHay, catHay, descHay, tagsHay].join(' ');
        // Each word matches if ANY of its synonym candidates matches.
        // Direct matches still score higher than synonym hits.
        ok = words.every(function(w) {
          return expandSynonyms(w).some(function(c) { return fuzzyContains(hay, c); });
        });
        if (ok) {
          words.forEach(function(w) {
            var alts = expandSynonyms(w);
            var bestForWord = 0;
            alts.forEach(function(c) {
              // Synonym hits get a 0.7× factor — direct word still wins.
              var penalty = (c === w) ? 1 : 0.7;
              var s = 0;
              if (titleHay.includes(c)) s += 3 * penalty;
              if (subjHay.includes(c))  s += 2 * penalty;
              if (catHay.includes(c))   s += 1 * penalty;
              if (tagsHay.includes(c))  s += 1.5 * penalty;
              if (descHay.includes(c))  s += 0.5 * penalty;
              if (s > bestForWord) bestForWord = s;
            });
            score += bestForWord;
          });
        }
      }

      el.classList.toggle('hid', !ok);
      if (ok) {
        n++;
        scored.push({ el, score });
        // #8 — Highlight title using origTitles (prevents corruption)
        var titleEl = el.querySelector('.td-title');
        if (titleEl) {
          var orig = origTitles.get(el) || titleEl.textContent || '';
          if (!q) { titleEl.innerHTML = orig; }
          else {
            var html = orig;
            words.forEach(function(w) {
              var re = new RegExp('(' + w.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
              html = html.replace(re, '<span class="hl">$1</span>');
            });
            titleEl.innerHTML = html;
          }
        }
        // #27 — Highlight in subject column too
        var subjEl = el.querySelector('.td-subj');
        if (subjEl) {
          var origS = origSubjs.get(el) || subjEl.textContent || '';
          if (!q) { subjEl.innerHTML = origS; }
          else {
            var htmlS = origS;
            words.forEach(function(w) {
              var re = new RegExp('(' + w.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
              htmlS = htmlS.replace(re, '<span class="hl">$1</span>');
            });
            subjEl.innerHTML = htmlS;
          }
        }
      }
    });

    // #23 — Reorder visible rows by relevance score (only when searching)
    if (words.length && tableBody && scored.length) {
      scored.sort((a, b) => b.score - a.score);
      scored.forEach(({ el }) => tableBody.appendChild(el));
    }

    // Maintain sort order when no search is active
    if (!words.length) {
      const currentSort = localStorage.getItem('catalog-sort') || 'default';
      if (currentSort !== 'default') {
        const sorted = [...rows].filter(r => !r.classList.contains('hid'));
        if (currentSort === 'az') sorted.sort((a,b) => (a.dataset.t||'').localeCompare(b.dataset.t||'','ru'));
        else if (currentSort === 'za') sorted.sort((a,b) => (b.dataset.t||'').localeCompare(a.dataset.t||'','ru'));
        else if (currentSort === 'subj') sorted.sort((a,b) => { const c = (a.dataset.s||'').localeCompare(b.dataset.s||'','ru'); return c || (a.dataset.t||'').localeCompare(b.dataset.t||'','ru'); });
        sorted.forEach(r => tableBody?.appendChild(r));
      }
    }

    // #3 — Dynamic tab counts
    const catCounts = new Map<string, number>();
    catCounts.set('all', 0);
    rows.forEach(row => {
      if (row.classList.contains('hid')) return;
      catCounts.set('all', (catCounts.get('all') || 0) + 1);
      const c = row.dataset.c || '';
      catCounts.set(c, (catCounts.get(c) || 0) + 1);
    });
    tabs.forEach(tab => {
      const countEl = tab.querySelector('.tab-n');
      const tabCat = tab.dataset.cat || 'all';
      const count = catCounts.get(tabCat) || 0;
      if (countEl) {
        countEl.textContent = String(count);
        if (count === 0) countEl.setAttribute('data-zero', '');
        else countEl.removeAttribute('data-zero');
      }
    });

    if (visCountFootEl) visCountFootEl.textContent = String(n);
    if (visCountEl) {
      visCountEl.textContent = String(n);
      visCountEl.classList.toggle('is-zero', n === 0);
    }
    if (nil && tableWrap) {
      nil.style.display = n === 0 ? 'flex' : 'none';
      tableWrap.style.display = n === 0 ? 'none' : '';
      if (n === 0) {
        const hintEl = nil.querySelector('.nil-hint');
        if (hintEl) {
          if (q) hintEl.textContent = '\u041f\u043e \u0437\u0430\u043f\u0440\u043e\u0441\u0443 \u00ab' + input!.value + '\u00bb \u043d\u0438\u0447\u0435\u0433\u043e \u043d\u0435 \u043d\u0430\u0439\u0434\u0435\u043d\u043e';
          else if (cat !== 'all') hintEl.textContent = '\u0412 \u043a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u0438 \u00ab' + cat + '\u00bb \u043d\u0435\u0442 \u0440\u0430\u0431\u043e\u0442';
          else hintEl.textContent = '\u041f\u043e\u043f\u0440\u043e\u0431\u0443\u0439\u0442\u0435 \u0438\u0437\u043c\u0435\u043d\u0438\u0442\u044c \u0437\u0430\u043f\u0440\u043e\u0441 \u0438\u043b\u0438 \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u0434\u0440\u0443\u0433\u0443\u044e \u043a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u044e';
        }
      }
    }

    // #5 — Update clear button visibility
    updateClearBtn();

    // #18 — Scroll to top on search
    if (tableBody) tableBody.scrollTop = 0;

    // URL sync
    var url = new URL(window.location.href);
    if (q) url.searchParams.set('q', q); else url.searchParams.delete('q');
    if (cat !== 'all' && cat !== '__fav') url.searchParams.set('cat', cat); else url.searchParams.delete('cat');
    history.replaceState(null, '', url.toString());

    // #15 — Persist search to sessionStorage
    try { sessionStorage.setItem('catalog-q', q); } catch {}

    // #35 — Update page title to reflect filter
    const baseTitle = 'Каталог — Библиотека академического салона';
    document.title = (q || cat !== 'all') ? `Каталог (${n}) — Библиотека академического салона` : baseTitle;

    // #3 — Update fav tab count (always shows total favs)
    updateFavTabCount();

    // #8 — Contextual bottombar info
    const infoEl = document.querySelector('.bottombar-info');
    if (infoEl) {
      if (cat === '__fav') infoEl.textContent = '\u0412 \u0438\u0437\u0431\u0440\u0430\u043d\u043d\u043e\u043c: ' + n;
      else if (q) infoEl.textContent = '\u041f\u043e \u0437\u0430\u043f\u0440\u043e\u0441\u0443 \u00ab' + input!.value + '\u00bb \u2014 ' + n + ' \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u043e\u0432';
      else if (cat !== 'all') infoEl.textContent = '\u041f\u043e\u043a\u0430\u0437\u0430\u043d\u043e ' + n + ' \u0438\u0437 ' + rows.length;
      else infoEl.textContent = rows.length + ' \u0440\u0430\u0431\u043e\u0442 \u00b7 \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u043e';
    }
  }

  // Search with debounce loading indicator (#16)
  input.addEventListener('input', () => {
    clearTimeout(timer);
    if (searchWrap) searchWrap.classList.add('is-loading');
    timer = window.setTimeout(() => {
      if (searchWrap) searchWrap.classList.remove('is-loading');
      q = input.value.trim().toLowerCase();
      run();
    }, 100);
  });

  // #10 — Enter to navigate to first visible result
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const firstVisible = rows.find(r => !r.classList.contains('hid'));
      if (firstVisible) {
        window.location.href = firstVisible.getAttribute('href') || '';
      }
    }
  });

  // #5 — Clear button click (#8: preventDefault, #31: also reset category)
  if (clearBtn) {
    clearBtn.addEventListener('click', (e) => {
      e.preventDefault();
      input!.value = '';
      q = '';
      cat = 'all';
      tabs.forEach(t => t.classList.remove('active'));
      tabs[0]?.classList.add('active');
      run();
      input!.focus();
    });
  }

  // Category tabs (#26: clicking active tab deselects to "all")
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const clickedCat = tab.dataset.cat || 'all';
      if (clickedCat === cat && clickedCat !== 'all') {
        // Deselect: go back to "all"
        tabs.forEach(t => t.classList.remove('active'));
        tabs[0]?.classList.add('active');
        cat = 'all';
      } else {
        tabs.forEach((t) => t.classList.remove('active'));
        tab.classList.add('active');
        cat = clickedCat;
      }
      run();
      // #32 — Scroll clicked tab into view
      tab.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      // #9 — Scroll table to top on tab change
      if (tableBody) tableBody.scrollTop = 0;
    });
  });

  // #1 — Sort dropdown toggle (robust)
  let sortOpen = false;
  function toggleSort() {
    sortOpen = !sortOpen;
    if (sortMenu) sortMenu.classList.toggle('is-open', sortOpen);
  }
  function closeSort() {
    sortOpen = false;
    if (sortMenu) sortMenu.classList.remove('is-open');
  }
  if (sortBtn) {
    sortBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      e.preventDefault();
      toggleSort();
    });
  }
  document.addEventListener('click', (e) => {
    if (sortOpen && sortMenu && !sortMenu.contains(e.target as Node)) closeSort();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && sortOpen) { closeSort(); e.stopPropagation(); }
    // #7 — Arrow key navigation inside sort menu
    if (sortOpen && (e.key === 'ArrowDown' || e.key === 'ArrowUp')) {
      e.preventDefault();
      const focused = document.activeElement as HTMLElement;
      const idx = sortOpts.indexOf(focused);
      let next: HTMLElement;
      if (e.key === 'ArrowDown') {
        next = idx < 0 ? sortOpts[0] : sortOpts[(idx + 1) % sortOpts.length];
      } else {
        next = idx < 0 ? sortOpts[sortOpts.length - 1] : sortOpts[(idx - 1 + sortOpts.length) % sortOpts.length];
      }
      next?.focus();
    }
    if (sortOpen && e.key === 'Enter') {
      const focused = document.activeElement as HTMLElement;
      if (focused && sortOpts.includes(focused)) {
        applySort(focused.dataset.sort || 'default');
        closeSort();
      }
    }
  }, true);

  // #1 — Sort options + #15 persistence + #8 highlight
  function applySort(mode: string) {
    if (!tableBody) return;
    tableBody.classList.add('is-sorting');
    const sorted = [...rows];
    if (mode === 'az') {
      sorted.sort((a, b) => (a.dataset.t || '').localeCompare(b.dataset.t || '', 'ru'));
    } else if (mode === 'za') {
      sorted.sort((a, b) => (b.dataset.t || '').localeCompare(a.dataset.t || '', 'ru'));
    } else if (mode === 'subj') {
      sorted.sort((a, b) => {
        const cmp = (a.dataset.s || '').localeCompare(b.dataset.s || '', 'ru');
        return cmp !== 0 ? cmp : (a.dataset.t || '').localeCompare(b.dataset.t || '', 'ru');
      });
    } else {
      sorted.sort((a, b) => Number(a.dataset.i || 0) - Number(b.dataset.i || 0));
    }
    // #4: Remove old letter separators
    tableBody.querySelectorAll('.letter-sep').forEach(el => el.remove());
    sorted.forEach(row => tableBody.appendChild(row));
    // #4: Insert letter dividers for A-Z sort
    if (mode === 'az') {
      let lastLetter = '';
      sorted.forEach(row => {
        if (row.classList.contains('hid')) return;
        const first = ((row.dataset.t || '')[0] || '').toUpperCase();
        if (first && first !== lastLetter) {
          lastLetter = first;
          const sep = document.createElement('div');
          sep.className = 'letter-sep';
          sep.textContent = first;
          tableBody.insertBefore(sep, row);
        }
      });
    }
    sortOpts.forEach(o => o.classList.toggle('active', o.dataset.sort === mode));
    if (sortBtn) sortBtn.classList.toggle('is-sorted', mode !== 'default');
    try { localStorage.setItem('catalog-sort', mode); } catch {}
    requestAnimationFrame(() => tableBody.classList.remove('is-sorting'));
  }

  sortOpts.forEach((opt) => {
    opt.addEventListener('click', () => {
      applySort(opt.dataset.sort || 'default');
      closeSort();
    });
  });

  // #7 — Title column header sort toggle
  const thTitle = document.getElementById('thTitle');
  const thTitleArrow = document.getElementById('thTitleArrow');
  if (thTitle) {
    thTitle.addEventListener('click', () => {
      const cur = localStorage.getItem('catalog-sort') || 'default';
      let next = 'az';
      if (cur === 'az') next = 'za';
      else if (cur === 'za') next = 'default';
      applySort(next);
      if (thTitleArrow) thTitleArrow.textContent = next === 'az' ? '\u2191' : next === 'za' ? '\u2193' : '';
    });
  }

  // #15 — Restore saved sort on load (with validation)
  const validSorts = ['default', 'az', 'za', 'subj'];
  let savedSort = 'default';
  try { savedSort = localStorage.getItem('catalog-sort') || 'default'; } catch {}
  if (!validSorts.includes(savedSort)) savedSort = 'default';
  if (savedSort !== 'default') applySort(savedSort);

  // Keyboard shortcuts (#29: Cmd+K / Ctrl+K)
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      input.focus();
    }
    if (e.key === '/' && document.activeElement !== input) {
      e.preventDefault();
      input.focus();
    }
    if (e.key === 'Escape' && document.activeElement === input) {
      if (input.value) {
        input.value = ''; q = ''; run();
      } else if (cat !== 'all') {
        cat = 'all';
        tabs.forEach(t => t.classList.remove('active'));
        tabs[0]?.classList.add('active');
        run();
        input.blur();
      } else {
        input.blur();
      }
    }
  });

  // Reset
  if (resetBtn) resetBtn.addEventListener('click', () => {
    input.value = '';
    q = '';
    cat = 'all';
    tabs.forEach((t) => t.classList.remove('active'));
    if (tabs[0]) tabs[0].classList.add('active');
    run();
  });

  // #14 — Search suggestion terms
  document.querySelectorAll<HTMLElement>('.nil-term').forEach(btn => {
    btn.addEventListener('click', () => {
      input.value = btn.dataset.term || '';
      q = input.value.toLowerCase();
      cat = 'all';
      tabs.forEach(t => t.classList.remove('active'));
      tabs[0]?.classList.add('active');
      run();
      input.focus();
    });
  });

  // Focus hint
  input.addEventListener('focus', () => { if (hint) hint.style.display = 'none'; });
  input.addEventListener('blur', () => { if (hint && !input.value) hint.style.display = ''; });

  // URL params on load (with sessionStorage fallback)
  const params = new URLSearchParams(window.location.search);
  let qp = params.get('q');
  const cp = params.get('cat');
  if (!qp) { try { qp = sessionStorage.getItem('catalog-q') || null; } catch {} }
  if (qp) { input.value = qp; q = qp.toLowerCase(); }
  if (cp) {
    cat = cp;
    tabs.forEach((t) => {
      t.classList.toggle('active', t.dataset.cat === cp);
    });
  }
  if (qp || cp) run();

  // #5 — Initial clear button state
  updateClearBtn();

  // #3 — Tab keyboard navigation (left/right arrows)
  const tabsContainer = document.getElementById('tabs');
  if (tabsContainer) {
    tabsContainer.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
      const focusedTab = document.activeElement as HTMLElement;
      if (!focusedTab || !focusedTab.classList.contains('tab')) return;
      const idx = tabs.indexOf(focusedTab);
      if (idx < 0) return;
      e.preventDefault();
      const next = e.key === 'ArrowRight'
        ? tabs[(idx + 1) % tabs.length]
        : tabs[(idx - 1 + tabs.length) % tabs.length];
      next?.focus();
    });
  }

  // #17 — Scroll shadow on table head
  if (tableBody) {
    tableBody.addEventListener('scroll', () => {
      const scrolled = tableBody.scrollTop > 0;
      tableBody.parentElement?.classList.toggle('is-scrolled', scrolled);
    }, { passive: true });
  }

  // #2 — Hover description tooltip (desktop only, 500ms delay)
  if (window.matchMedia('(hover: hover)').matches && tableBody) {
    let tooltipEl: HTMLElement | null = null;
    let hoverTimer = 0;
    const removeTooltip = () => {
      clearTimeout(hoverTimer);
      if (tooltipEl) { tooltipEl.remove(); tooltipEl = null; }
    };
    tableBody.addEventListener('mouseover', (e) => {
      const row = (e.target as HTMLElement).closest('.row') as HTMLElement | null;
      if (!row) { removeTooltip(); return; }
      const desc = row.dataset.desc || '';
      if (desc.length < 10) { removeTooltip(); return; }
      clearTimeout(hoverTimer);
      hoverTimer = window.setTimeout(() => {
        removeTooltip();
        const rect = row.getBoundingClientRect();
        tooltipEl = document.createElement('div');
        tooltipEl.className = 'catalog-tooltip';
        tooltipEl.textContent = desc.length > 200 ? desc.slice(0, 200) + '...' : desc;
        tooltipEl.style.left = Math.min(rect.left + 90, window.innerWidth - 380) + 'px';
        tooltipEl.style.top = Math.min(rect.bottom + 4, window.innerHeight - 100) + 'px';
        document.body.appendChild(tooltipEl);
      }, 300);
    });
    tableBody.addEventListener('mouseout', (e) => {
      const row = (e.target as HTMLElement).closest('.row');
      if (!row) removeTooltip();
    });
    tableBody.addEventListener('mouseleave', removeTooltip);
    // #1 — Close tooltip on scroll
    tableBody.addEventListener('scroll', removeTooltip, { passive: true });
  }

  // #34 — Mobile: long-press row to copy document link
  if ('ontouchstart' in window && tableBody) {
    let longPressTimer = 0;
    let touchRow: HTMLElement | null = null;
    tableBody.addEventListener('touchstart', (e) => {
      const row = (e.target as HTMLElement).closest('.row') as HTMLAnchorElement | null;
      if (!row) return;
      touchRow = row;
      longPressTimer = window.setTimeout(() => {
        const href = row.href || (row.getAttribute('href') || '');
        const fullUrl = href.startsWith('/') ? window.location.origin + href : href;
        navigator.clipboard.writeText(fullUrl).then(() => {
          const toast = document.createElement('div');
          toast.className = 'copy-toast';
          toast.textContent = 'Ссылка скопирована';
          document.body.appendChild(toast);
          setTimeout(() => toast.remove(), 1800);
        }).catch(() => {});
        touchRow = null;
      }, 600);
    }, { passive: true });
    tableBody.addEventListener('touchend', () => { clearTimeout(longPressTimer); touchRow = null; });
    tableBody.addEventListener('touchmove', () => { clearTimeout(longPressTimer); touchRow = null; }, { passive: true });
  }
}

initCatalog();
document.addEventListener('astro:page-load', initCatalog);
</script>
