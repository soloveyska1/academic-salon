---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const total = D.length;
const year = String(new Date().getFullYear());
const BATCH = 30;

const typeCount = new Map<string, number>();
for (const doc of D) {
  const t = (doc as any).category || '';
  if (t) typeCount.set(t, (typeCount.get(t) || 0) + 1);
}
const typeChips = [...typeCount.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8);

const shortType: Record<string, string> = {
  'Самостоятельная работа': 'Самост.',
  'Выпускная квалификационная работа': 'ВКР',
  'Экзаменационные материалы': 'Экзамен',
  'Контрольная работа': 'Контрольная',
  'Курсовая работа': 'Курсовая',
  'Отчет по практике': 'Практика',
  'Отчет о научно-практической работе': 'НПР',
  'Справочный материал': 'Справочник',
  'Нормативный документ': 'Норматив',
  'Учебный документ': 'Учебный',
  'Шаблон документа': 'Шаблон',
  'Аналитический документ': 'Аналитика',
  'Практическое задание': 'Практич.',
  'Методические материалы': 'Методичка',
  'Учебная работа': 'Учебная',
  'Учебный материал': 'Учебный',
};

function getYear(doc: any) {
  const s = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const m = s.match(/(?:19|20)\d{2}/);
  return m ? m[0] : year;
}
---

<Base title="Каталог — Библиотека академического салона" description="Каталог студенческих работ: курсовые, рефераты, ВКР, отчёты по практике. Бесплатное скачивание без регистрации." currentPath="/catalog">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <h1 class="hero-title">Каталог</h1>
      <div class="hero-rule" aria-hidden="true"></div>
      <p class="hero-sub"><span id="cnt">{total}</span> работ — бесплатно, без регистрации</p>
      <div class="hero-search">
        <svg class="hero-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" id="q" placeholder="Найти работу..." autocomplete="off" inputmode="search" enterkeyhint="search" autocorrect="off" spellcheck="false" aria-label="Поиск документов" />
        <kbd id="hint">/</kbd>
      </div>
    </div>
  </section>

  <!-- FILTERS -->
  <div class="filters rv">
    <div class="filters-row" id="pills">
      <button class="pill active" data-cat="all">Все</button>
      {typeChips.map(([name, count]) => (
        <button class="pill" data-cat={name}>{name} <span class="pill-n">{count}</span></button>
      ))}
    </div>
  </div>

  <!-- CARDS -->
  <section class="catalog rv">
    <div class="catalog-inner">
      <div class="catalog-grid" id="cards">
        {D.map((doc: any, i: number) => {
          const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
          const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
          const rawType = doc.docType || doc.category || '';
          const type = shortType[rawType] || rawType;
          const subj = doc.subject || '';
          const yr = getYear(doc);
          return (
            <a
              href={`/doc/${doc.file}`}
              class="card"
              data-t={title.toLowerCase()}
              data-d={(doc.catalogDescription || doc.description || '').toLowerCase()}
              data-c={doc.category || ''}
              data-s={subj.toLowerCase()}
              data-k={(doc.course || '').toLowerCase()}
              data-g={(doc.tags || []).join(' ').toLowerCase()}
              data-z={doc.size || ''}
              data-i={i}
              data-file={doc.file}
            >
              <span class="card-type">{type}</span>
              <h3 class="card-title">{title}</h3>
              <div class="card-foot">
                <span class="card-meta">{[subj, yr].filter(Boolean).join(' \u00b7 ')}</span>
                <span class="card-ext">{ext}</span>
              </div>
              <div class="card-actions">
                <button class="card-act card-act--fav" data-fav={doc.file} type="button" aria-label="В избранное">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </button>
              </div>
            </a>
          );
        })}
      </div>
      <div class="more" id="more">
        <button id="moreBtn" class="btn btn--ghost">Показать ещё</button>
      </div>
      <div class="nil" id="nil" style="display:none">
        <p class="nil-title">Ничего не найдено</p>
        <p class="nil-hint">Попробуйте другой запрос или сбросьте фильтры</p>
        <button class="nil-reset" id="resetBtn">Сбросить</button>
      </div>
    </div>
  </section>

  <!-- ORDER CTA -->
  <section class="order rv">
    <div class="order-inner">
      <h2 class="order-title">Не нашли нужную работу?</h2>
      <p class="order-sub">Напишем индивидуально — от 3 000 &#8381;</p>
      <a href="/order" class="btn btn--primary">Заказать работу</a>
    </div>
  </section>

  <footer class="foot">
    <span class="foot-copy">&copy; 2020&ndash;2026 Библиотека академического салона</span>
  </footer>

  <!-- Back to top -->
  <button class="top-btn" id="topBtn" type="button" aria-label="Наверх">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>

  <!-- Quick Preview (touch) -->
  <div class="peek" id="peek" aria-hidden="true">
    <div class="peek-backdrop" id="peekBackdrop"></div>
    <div class="peek-card" id="peekCard">
      <div class="peek-handle"><span></span></div>
      <span class="peek-type" id="peekType"></span>
      <h3 class="peek-title" id="peekTitle"></h3>
      <p class="peek-desc" id="peekDesc"></p>
      <div class="peek-meta" id="peekMeta"></div>
      <div class="peek-actions">
        <a class="peek-btn peek-btn--primary" id="peekOpen" href="#">Открыть</a>
        <a class="peek-btn peek-btn--order" href="/order">Заказать похожую</a>
      </div>
    </div>
  </div>

</Base>

<style>
  /* ================================================================
     CATALOG v4 — Unified with homepage design language
     Same glass cards, gold glow, Cormorant Garamond 300, editorial feel
     ================================================================ */

  :global(.footer) { display: none; }

  /* ----------------------------------------------------------------
     ANIMATIONS
     ---------------------------------------------------------------- */
  @keyframes fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes glow-breathe {
    0%, 100% { opacity: .65; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.06); }
  }

  .rv {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .6s var(--ease), transform .6s var(--ease);
  }
  .rv.vis { opacity: 1; transform: translateY(0); }

  /* ----------------------------------------------------------------
     BUTTONS — exact homepage match
     ---------------------------------------------------------------- */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 16px 40px;
    border-radius: 0;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    text-decoration: none;
    color: var(--t1);
    border: 1px solid var(--ac-b);
    cursor: pointer;
    transition:
      transform .3s var(--ease),
      border-color .3s var(--ease),
      box-shadow .3s var(--ease);
  }
  .btn--primary {
    background: var(--surf);
    border-color: var(--ac-b);
  }
  .btn--ghost {
    background: transparent;
    border-color: var(--ac-line);
    color: var(--t2);
  }
  .btn:hover {
    transform: translateY(-2px);
    border-color: var(--ac-b3);
    box-shadow: 0 12px 40px var(--ac-sh);
  }
  .btn--primary:hover { box-shadow: 0 12px 40px var(--ac-g); }
  .btn--ghost:hover { color: var(--t1); border-color: var(--ac-b2); }

  /* ----------------------------------------------------------------
     HERO — same multi-layer glow as homepage, shorter height
     ---------------------------------------------------------------- */
  .hero {
    position: relative;
    padding: calc(var(--nav-h) + 80px) 24px 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-glow {
    position: absolute;
    width: min(1100px, 95vw);
    height: min(900px, 85vw);
    top: 45%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45% at 50% 48%, rgba(212,175,55,.22) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 48% 44%, rgba(212,175,55,.14) 0%, transparent 50%),
      radial-gradient(ellipse 75% 55% at 42% 52%, rgba(180,130,20,.08) 0%, transparent 75%);
    pointer-events: none;
    z-index: 0;
    animation: glow-breathe 10s ease-in-out infinite;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 960px;
    text-align: center;
    padding: 0 8px;
  }

  .hero-title {
    font: 300 clamp(48px, 10vw, 80px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: -.02em;
    text-shadow: 0 0 120px rgba(212,175,55,.06), 0 4px 24px rgba(0,0,0,.3);
  }

  .hero-rule {
    width: 48px;
    height: 1px;
    margin: 24px auto 0;
    background: linear-gradient(90deg, transparent, var(--ac), transparent);
    opacity: .35;
  }

  .hero-sub {
    margin-top: 20px;
    font: 400 15px/1.6 var(--fi);
    color: var(--t2);
    max-width: 52ch;
    margin-inline: auto;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out .4s forwards;
  }

  .hero-search {
    position: relative;
    max-width: 480px;
    margin: 32px auto 0;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out .6s forwards;
  }

  .hero-search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--t3);
    pointer-events: none;
  }

  .hero-search input {
    width: 100%;
    padding: 14px 20px 14px 42px;
    border: 1px solid var(--brd);
    border-radius: 999px;
    background: rgba(255,255,255,.04);
    color: var(--t1);
    font: 400 16px/1.4 var(--fi);
    outline: none;
    transition: border-color .3s, box-shadow .3s, background .3s;
  }

  .hero-search input::placeholder { color: var(--t3); }

  .hero-search input:focus {
    border-color: var(--ac-b);
    box-shadow: 0 0 0 3px rgba(212,175,55,.1);
    background: rgba(255,255,255,.06);
  }

  .hero-search input:focus ~ kbd { display: none; }

  .hero-search kbd {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    border: 1px solid var(--brd);
    padding: 2px 6px;
    border-radius: 4px;
    pointer-events: none;
  }

  /* ----------------------------------------------------------------
     FILTERS — centered pills below hero
     ---------------------------------------------------------------- */
  .filters {
    padding: 0 24px 64px;
    display: flex;
    justify-content: center;
    background: var(--bg);
  }

  .filters-row {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
    padding: 4px 0;
  }
  .filters-row::-webkit-scrollbar { display: none; }

  .pill {
    flex-shrink: 0;
    padding: 8px 20px;
    border: 1px solid var(--brd);
    border-radius: 999px;
    background: transparent;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    cursor: pointer;
    transition: border-color .3s, color .3s, background .3s;
    white-space: nowrap;
  }
  .pill:hover { color: var(--t1); border-color: rgba(255,255,255,.12); }
  .pill:focus-visible { outline: 2px solid var(--ac-b2); outline-offset: 2px; }
  .pill.active { color: var(--ac); border-color: var(--ac-b); background: var(--surf); }

  .pill-n {
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    margin-left: 4px;
  }
  .pill.active .pill-n { color: var(--ac); opacity: .6; }

  /* ----------------------------------------------------------------
     CATALOG GRID
     ---------------------------------------------------------------- */
  .catalog {
    padding: 0 24px 120px;
    background: var(--bg);
  }

  .catalog-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    content-visibility: auto;
    contain-intrinsic-size: auto 2000px;
  }

  /* ----------------------------------------------------------------
     CARDS — glass style, gold shimmer, exact homepage match
     ---------------------------------------------------------------- */
  .card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px;
    background: rgba(255,255,255,.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,.06);
    border-radius: var(--rs);
    text-decoration: none;
    color: var(--t1);
    position: relative;
    overflow: hidden;
    transition:
      border-color .3s var(--ease),
      transform .3s var(--ease),
      box-shadow .3s var(--ease);
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 20%, var(--ac) 50%, transparent 80%);
    opacity: 0;
    transition: opacity .3s;
  }

  .card:hover {
    border-color: rgba(212,175,55,.15);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,.3), 0 0 0 1px rgba(212,175,55,.08);
  }

  .card:hover::before { opacity: .4; }
  .card:focus-visible { outline: 2px solid var(--ac-b2); outline-offset: 2px; }
  .card.hid { display: none !important; }

  .card-type {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--ac);
    opacity: .6;
  }

  .card-title {
    font: 400 18px/1.35 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color .3s var(--ease);
  }

  .card:hover .card-title { color: var(--ac2, var(--ac)); }

  .card-foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-top: auto;
  }

  .card-meta {
    font: 400 12px/1 var(--fi);
    color: var(--t3);
  }

  .card-ext {
    font: 400 9px/1 var(--fm);
    text-transform: uppercase;
    color: var(--t3);
    opacity: .4;
  }

  /* Search highlight */
  :global(.hl) {
    background: var(--ac-b);
    color: var(--ac2);
    border-radius: 4px;
    padding: 1px 4px;
  }
  :global([data-theme="light"]) :global(.hl) {
    background: rgba(180,140,20,.12);
    color: #8b6914;
  }

  /* Hover fav button */
  .card-actions {
    position: absolute;
    bottom: 16px;
    right: 16px;
    display: flex;
    gap: 6px;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity .2s, transform .2s;
    z-index: 2;
  }
  .card:hover .card-actions { opacity: 1; transform: translateY(0); }

  .card-act {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,.1);
    background: rgba(0,0,0,.5);
    backdrop-filter: blur(8px);
    color: var(--t3);
    cursor: pointer;
    transition: color .2s, border-color .2s, background .2s;
  }
  .card-act:hover { color: var(--ac); border-color: var(--ac-b); background: rgba(0,0,0,.7); }
  .card-act:focus-visible { outline: 2px solid var(--ac-b2); outline-offset: 2px; }
  .card-act--fav.is-fav { color: var(--ac); }
  .card-act--fav.is-fav svg { fill: var(--ac); }

  /* ----------------------------------------------------------------
     MORE / EMPTY STATE
     ---------------------------------------------------------------- */
  .more {
    text-align: center;
    padding: 48px 0;
  }

  .nil {
    text-align: center;
    padding: 96px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .nil-title {
    font: 300 22px/1.3 var(--fd);
    color: var(--t2);
  }

  .nil-hint {
    font: 400 13px/1.5 var(--fi);
    color: var(--t3);
  }

  .nil-reset {
    margin-top: 16px;
    background: none;
    border: 1px solid var(--ac-b);
    border-radius: 0;
    padding: 12px 36px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    cursor: pointer;
    transition: color .3s, border-color .3s;
  }
  .nil-reset:hover { color: var(--ac); border-color: var(--ac-b2); background: var(--surf); }

  /* ----------------------------------------------------------------
     ORDER CTA — same as homepage
     ---------------------------------------------------------------- */
  .order {
    padding: 120px 24px;
    background: var(--bg);
  }

  .order-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    text-align: center;
  }

  .order-title {
    font: 300 clamp(28px, 5vw, 40px)/1.2 var(--fd);
    color: var(--t1);
    margin-bottom: 16px;
  }

  .order-sub {
    font: 400 14px/1.6 var(--fi);
    color: var(--t3);
    margin-bottom: 40px;
  }

  /* ----------------------------------------------------------------
     FOOTER
     ---------------------------------------------------------------- */
  .foot {
    padding: 64px 24px;
    background: var(--bg);
    text-align: center;
  }

  .foot-copy {
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    letter-spacing: .04em;
  }

  /* ----------------------------------------------------------------
     BACK TO TOP
     ---------------------------------------------------------------- */
  .top-btn {
    position: fixed;
    bottom: calc(80px + env(safe-area-inset-bottom, 0px));
    right: 24px;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ac-b);
    border-radius: 999px;
    background: var(--bg);
    color: var(--ac);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity .3s, transform .3s, border-color .3s;
    z-index: 50;
  }
  .top-btn.is-visible { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .top-btn:hover { border-color: var(--ac-b3); box-shadow: 0 8px 24px var(--ac-sh); }
  .top-btn:focus-visible { outline: 2px solid var(--ac-b2); outline-offset: 2px; }

  /* ----------------------------------------------------------------
     QUICK PREVIEW (touch)
     ---------------------------------------------------------------- */
  .peek {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
  }
  .peek.is-open { display: block; }

  .peek-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.6);
    animation: peek-fade .2s ease forwards;
  }
  @keyframes peek-fade { from { opacity: 0; } to { opacity: 1; } }

  .peek-card {
    position: absolute;
    bottom: calc(64px + var(--safe-bottom, 0px));
    left: 16px;
    right: 16px;
    background: rgba(20,18,15,.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: var(--r, 12px);
    padding: 8px 24px 24px;
    box-shadow: 0 -8px 40px rgba(0,0,0,.4);
    animation: peek-up .3s cubic-bezier(.22,1,.36,1) forwards;
    max-height: 60vh;
    overflow-y: auto;
  }
  @keyframes peek-up {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .peek-handle { display: flex; justify-content: center; padding: 8px 0; }
  .peek-handle span { width: 40px; height: 4px; border-radius: 2px; background: rgba(255,255,255,.12); }

  .peek-type {
    display: inline-block;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--ac);
    margin-bottom: 8px;
  }

  .peek-title { font: 400 20px/1.3 var(--fd); color: var(--t1); margin-bottom: 12px; }

  .peek-desc {
    font: 400 14px/1.6 var(--fi);
    color: var(--t2);
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .peek-meta { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
  .peek-meta span {
    padding: 4px 12px;
    border-radius: 999px;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.06);
    font: 400 12px/1.3 var(--fi);
    color: var(--t2);
  }

  .peek-actions { display: flex; gap: 8px; }
  .peek-btn {
    flex: 1;
    text-align: center;
    padding: 14px 16px;
    border-radius: var(--rs);
    font: 500 14px/1 var(--fi);
    text-decoration: none;
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .2s;
  }
  .peek-btn--primary { background: linear-gradient(135deg, #d4af37, #f6e27a); color: #09080a; }
  .peek-btn--order { background: transparent; border: 1px solid var(--ac-b2); color: var(--ac); }

  /* ----------------------------------------------------------------
     LIGHT THEME
     ---------------------------------------------------------------- */
  :global([data-theme="light"]) .hero-glow {
    background:
      radial-gradient(ellipse 55% 45% at 50% 48%, rgba(180,145,30,.12) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 48% 44%, rgba(180,145,30,.08) 0%, transparent 50%),
      radial-gradient(ellipse 75% 55% at 42% 52%, rgba(160,120,15,.05) 0%, transparent 75%);
  }

  :global([data-theme="light"]) .hero-search input {
    background: rgba(0,0,0,.03);
    border-color: rgba(0,0,0,.1);
  }
  :global([data-theme="light"]) .hero-search input:focus {
    border-color: var(--ac-b);
    background: rgba(0,0,0,.04);
  }

  :global([data-theme="light"]) .card {
    background: #fff;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-color: var(--brd);
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }
  :global([data-theme="light"]) .card:hover {
    box-shadow: 0 12px 40px rgba(0,0,0,.1), 0 0 0 1px rgba(212,175,55,.12);
  }

  :global([data-theme="light"]) .pill:hover {
    border-color: rgba(0,0,0,.15);
  }

  :global([data-theme="light"]) .card-act {
    border-color: rgba(0,0,0,.1);
    background: rgba(255,255,255,.8);
  }
  :global([data-theme="light"]) .card-act:hover {
    background: rgba(255,255,255,.95);
  }

  :global([data-theme="light"]) .peek-card {
    background: rgba(255,255,255,.97);
    border-color: rgba(0,0,0,.08);
  }
  :global([data-theme="light"]) .peek-handle span { background: rgba(0,0,0,.12); }
  :global([data-theme="light"]) .peek-meta span {
    background: rgba(0,0,0,.04);
    border-color: rgba(0,0,0,.06);
  }

  /* ----------------------------------------------------------------
     REDUCED MOTION
     ---------------------------------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    .hero-sub, .hero-search {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .hero-glow {
      animation: none;
      opacity: .8;
      transform: translate(-50%, -50%);
    }
    .rv { opacity: 1; transform: none; transition: none; }
  }

  /* ----------------------------------------------------------------
     TABLET (max 900px)
     ---------------------------------------------------------------- */
  @media (max-width: 900px) {
    .catalog-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ----------------------------------------------------------------
     MOBILE (max 639px)
     ---------------------------------------------------------------- */
  @media (max-width: 639px) {
    .hero { padding: calc(var(--nav-h) + 48px) 20px 48px; }

    .filters { padding: 0 20px 40px; }
    .pill { padding: 6px 14px; font-size: 11px; }

    .catalog { padding: 0 20px 64px; }
    .catalog-grid { grid-template-columns: 1fr; gap: 12px; }

    .card { padding: 20px; }
    .card-actions { display: none; }

    .order { padding: 64px 20px; }
    .order .btn { width: 100%; max-width: 320px; }

    .more { padding: 32px 0; }
    .more .btn { width: 100%; }

    .foot { padding: 48px 20px; }

    .hero-search input { min-height: 44px; font-size: 16px; }
    .hero-search kbd { display: none; }
  }
</style>

<script>
  function init() {
    var app = window.academicSalon || {};
    var showGlobalToast = app.showToast || window.showToast || function() {};
    var track = app.track || function() {};

    var grid = document.getElementById('cards');
    var input = document.getElementById('q');
    var hint = document.getElementById('hint');
    var nil = document.getElementById('nil');
    var resetBtn = document.getElementById('resetBtn');
    var moreBtn = document.getElementById('moreBtn');
    var moreWrap = document.getElementById('more');

    if (!grid || !input) return;
    if (grid.dataset.bound === '1') return;
    grid.dataset.bound = '1';

    var allCards = Array.from(grid.querySelectorAll('.card'));
    var origTitles = new Map();
    allCards.forEach(function(el) {
      var t = el.querySelector('.card-title');
      if (t) origTitles.set(el, t.textContent);
    });

    var q = '', cat = 'all', srt = 'default', favOnly = false;
    var shown = 30, step = 30, all = false, timer = 0;
    var lastResultCount = allCards.length;
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* URL PARAMS */
    var urlParams = new URLSearchParams(window.location.search);
    var qp = urlParams.get('q');
    if (qp) { input.value = qp; q = qp.toLowerCase(); all = true; }
    var cp = urlParams.get('cat');
    if (cp) { cat = cp; if (cat !== 'all') all = true; }
    var sp = urlParams.get('sort');
    if (sp) { srt = sp; doSort(); }

    if (cat !== 'all') {
      document.querySelectorAll('.pill').forEach(function(p) {
        p.classList.toggle('active', p.dataset.cat === cat);
      });
    }

    function syncUrl() {
      var p = new URLSearchParams();
      if (q) p.set('q', q);
      if (cat !== 'all') p.set('cat', cat);
      if (srt !== 'default') p.set('sort', srt);
      var qs = p.toString();
      history.replaceState(null, '', window.location.pathname + (qs ? '?' + qs : ''));
    }

    /* HIDE INITIAL OVERFLOW */
    allCards.forEach(function(el, i) {
      if (i >= shown && !all) el.style.display = 'none';
    });

    /* SEARCH */
    input.addEventListener('input', function() {
      clearTimeout(timer);
      timer = setTimeout(function() {
        q = input.value.toLowerCase().trim();
        if (q) all = true;
        run();
        syncUrl();
      }, 200);
    });

    input.addEventListener('focus', function() { if (hint) hint.style.display = 'none'; });
    input.addEventListener('blur', function() { if (hint && !input.value) hint.style.display = ''; });

    /* PILLS */
    var pills = document.querySelectorAll('.pill');
    pills.forEach(function(pill) {
      pill.addEventListener('click', function() {
        pills.forEach(function(p) { p.classList.remove('active'); });
        pill.classList.add('active');
        cat = pill.dataset.cat;
        if (cat !== 'all') all = true;
        track('catalog_filter', { category: cat });
        run();
        syncUrl();
      });
    });

    /* FAVORITES */
    function updateFavCount() {
      var favs = JSON.parse(localStorage.getItem('favorites') || '[]');
      /* Reflect in nav if present */
      var navFav = document.querySelector('.fav-count');
      if (navFav) navFav.textContent = favs.length > 0 ? favs.length : '';
    }
    updateFavCount();

    function syncCardFavButtons() {
      var favs = JSON.parse(localStorage.getItem('favorites') || '[]');
      document.querySelectorAll('.card-act--fav').forEach(function(btn) {
        btn.classList.toggle('is-fav', favs.indexOf(btn.dataset.fav) !== -1);
      });
    }

    grid.addEventListener('click', function(e) {
      var btn = e.target.closest('.card-act--fav');
      if (!btn) return;
      e.preventDefault();
      e.stopPropagation();
      var file = btn.dataset.fav;
      if (!file) return;
      var favs = JSON.parse(localStorage.getItem('favorites') || '[]');
      var idx = favs.indexOf(file);
      if (idx === -1) favs.push(file); else favs.splice(idx, 1);
      localStorage.setItem('favorites', JSON.stringify(favs));
      btn.classList.toggle('is-fav', idx === -1);
      updateFavCount();
    });

    syncCardFavButtons();
    window.addEventListener('storage', function(e) {
      if (e.key === 'favorites') { syncCardFavButtons(); updateFavCount(); }
    });

    /* SORT */
    function parseSize(s) {
      if (!s) return 0;
      var m = s.match(/([\d.,]+)\s*(МБ|MB|КБ|KB|Б|B)?/i);
      if (!m) return 0;
      var v = parseFloat(m[1].replace(',', '.'));
      var u = (m[2] || '').toUpperCase();
      if (u === 'КБ' || u === 'KB') v *= 1024;
      if (u === 'МБ' || u === 'MB') v *= 1048576;
      return v;
    }

    function doSort() {
      var a = allCards.slice();
      if (srt === 'az') a.sort(function(x,y) { return (x.dataset.t||'').localeCompare(y.dataset.t||'','ru'); });
      else if (srt === 'za') a.sort(function(x,y) { return (y.dataset.t||'').localeCompare(x.dataset.t||'','ru'); });
      else if (srt === 'size') a.sort(function(x,y) { return parseSize(y.dataset.z||'') - parseSize(x.dataset.z||''); });
      else a.sort(function(x,y) { return parseInt(x.dataset.i||'0') - parseInt(y.dataset.i||'0'); });
      a.forEach(function(el) { grid.appendChild(el); });
    }

    /* HIGHLIGHT */
    function highlight(el) {
      var titleEl = el.querySelector('.card-title');
      if (!titleEl) return;
      var orig = origTitles.get(el) || titleEl.textContent;
      if (!q) { titleEl.innerHTML = orig; return; }
      var words = q.split(/\s+/).filter(Boolean);
      var html = orig;
      words.forEach(function(w) {
        var re = new RegExp('(' + w.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
        html = html.replace(re, '<mark class="hl">$1</mark>');
      });
      titleEl.innerHTML = html;
    }

    /* MAIN FILTER */
    function run() {
      var n = 0, vis = 0;

      allCards.forEach(function(el) {
        var ok = true;
        if (cat !== 'all' && el.dataset.c !== cat) ok = false;
        if (ok && favOnly) {
          var favs = JSON.parse(localStorage.getItem('favorites') || '[]');
          var href = el.getAttribute('href') || '';
          if (favs.indexOf(href.replace(/^\/doc\//, '')) === -1) ok = false;
        }
        if (ok && q) {
          var h = [el.dataset.t, el.dataset.d, (el.dataset.c||'').toLowerCase(), el.dataset.s, el.dataset.k, el.dataset.g].join(' ');
          ok = q.split(/\s+/).every(function(w) {
            if (h.includes(w)) return true;
            if (w.length >= 4) {
              for (var ci = 0; ci < h.length - w.length + 1; ci++) {
                var diff = 0;
                for (var cj = 0; cj < w.length; cj++) {
                  if (h[ci + cj] !== w[cj]) diff++;
                  if (diff > 1) break;
                }
                if (diff <= 1) return true;
              }
            }
            return false;
          });
        }
        if (ok) {
          n++;
          if (all || n <= shown) {
            el.classList.remove('hid');
            el.style.display = '';
            highlight(el);
            vis++;
          } else {
            el.style.display = 'none';
            el.classList.remove('hid');
          }
        } else {
          el.classList.add('hid');
          el.style.display = '';
          highlight(el);
        }
      });

      /* Rank: title match first */
      if (q && q.length >= 2) {
        var visible = [];
        allCards.forEach(function(el) {
          if (el.classList.contains('hid') || el.style.display === 'none') return;
          var titleMatch = (el.dataset.t || '').indexOf(q) !== -1;
          var subjMatch = (el.dataset.s || '').indexOf(q) !== -1;
          visible.push({ el: el, score: titleMatch ? 3 : (subjMatch ? 2 : 1) });
        });
        visible.sort(function(a, b) { return b.score - a.score; });
        visible.forEach(function(item) { grid.appendChild(item.el); });
      }

      if (nil) nil.style.display = n === 0 ? 'block' : 'none';
      if (moreWrap) moreWrap.style.display = (!all && n > shown) ? 'block' : 'none';
      if (n === 0 && lastResultCount !== 0) {
        track('catalog_no_results', { query: q || '', category: cat, favorites: favOnly ? 1 : 0 });
      }
      lastResultCount = n;

      var cntEl = document.getElementById('cnt');
      if (cntEl) cntEl.textContent = String(n);
    }

    /* LOAD MORE */
    function loadMore() {
      shown += step;
      run();
    }
    if (moreBtn) moreBtn.addEventListener('click', loadMore);

    if (moreWrap && 'IntersectionObserver' in window) {
      var scrollObs = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting && moreWrap.style.display !== 'none') loadMore();
      }, { rootMargin: '200px' });
      scrollObs.observe(moreWrap);
    }

    /* RESET */
    if (resetBtn) resetBtn.addEventListener('click', function() {
      input.value = ''; q = ''; cat = 'all'; srt = 'default'; all = false; shown = step;
      pills.forEach(function(p) { p.classList.toggle('active', p.dataset.cat === 'all'); });
      run();
      syncUrl();
    });

    /* KEYBOARD */
    document.addEventListener('keydown', function(e) {
      var tag = e.target.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') {
        if (e.key === 'Escape') { input.blur(); input.value = ''; q = ''; run(); }
        return;
      }
      if (e.key === '/') { e.preventDefault(); input.focus(); }
    });

    /* SCROLL REVEAL */
    if ('IntersectionObserver' in window) {
      var rvObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) { entry.target.classList.add('vis'); rvObs.unobserve(entry.target); }
        });
      }, { rootMargin: '50px', threshold: 0.05 });
      document.querySelectorAll('.rv').forEach(function(el) { rvObs.observe(el); });
    } else {
      document.querySelectorAll('.rv').forEach(function(el) { el.classList.add('vis'); });
    }

    run();
  }

  init();
  document.addEventListener('astro:after-swap', init);

  /* BACK TO TOP */
  var topBtn = document.getElementById('topBtn');
  if (topBtn) {
    window.addEventListener('scroll', function() {
      topBtn.classList.toggle('is-visible', window.scrollY > window.innerHeight * 2);
    }, { passive: true });
    topBtn.addEventListener('click', function() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  /* QUICK PREVIEW (long-press on touch) */
  (function initPeek() {
    if (!window.matchMedia('(pointer: coarse)').matches) return;

    var peek = document.getElementById('peek');
    var peekBackdrop = document.getElementById('peekBackdrop');
    var peekCard = document.getElementById('peekCard');
    var peekType = document.getElementById('peekType');
    var peekTitle = document.getElementById('peekTitle');
    var peekDesc = document.getElementById('peekDesc');
    var peekMeta = document.getElementById('peekMeta');
    var peekOpen = document.getElementById('peekOpen');
    if (!peek || !peekType || !peekTitle || !peekDesc || !peekOpen || !peekBackdrop || !peekCard) return;

    var holdTimer = null;
    var startX = 0, startY = 0;

    function openPeek(card) {
      var title = card.querySelector('.card-title')?.textContent || '';
      var type = card.querySelector('.card-type')?.textContent || '';
      var desc = card.dataset.d || '';
      var subj = card.dataset.s || '';
      var catName = card.dataset.c || '';
      var size = card.dataset.z || '';
      var href = card.getAttribute('href') || '';

      peekType.textContent = type;
      peekTitle.textContent = title;
      peekDesc.textContent = desc || 'Описание недоступно';
      peekOpen.href = href;

      var tags = [catName, subj, size].filter(Boolean);
      peekMeta.innerHTML = tags.map(function(t) { return '<span>' + t + '</span>'; }).join('');

      peek.classList.add('is-open');
      peek.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      if (navigator.vibrate) navigator.vibrate(15);
    }

    function closePeek() {
      peek.classList.remove('is-open');
      peek.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    peekBackdrop.addEventListener('click', closePeek);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && peek.classList.contains('is-open')) closePeek();
    });

    var dragY = 0;
    peekCard.addEventListener('touchstart', function(e) { dragY = e.touches[0].clientY; }, { passive: true });
    peekCard.addEventListener('touchmove', function(e) {
      var dy = e.touches[0].clientY - dragY;
      if (dy > 0) peekCard.style.transform = 'translateY(' + dy + 'px)';
    }, { passive: true });
    peekCard.addEventListener('touchend', function(e) {
      var dy = (e.changedTouches[0]?.clientY || 0) - dragY;
      peekCard.style.transform = '';
      if (dy > 60) closePeek();
    });

    var cardsEl = document.getElementById('cards');
    if (!cardsEl) return;

    cardsEl.addEventListener('touchstart', function(e) {
      var card = e.target.closest('.card');
      if (!card) return;
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
      holdTimer = setTimeout(function() {
        e.preventDefault();
        openPeek(card);
        holdTimer = null;
      }, 500);
    }, { passive: false });

    cardsEl.addEventListener('touchmove', function(e) {
      if (!holdTimer) return;
      if (Math.abs(e.touches[0].clientX - startX) > 10 || Math.abs(e.touches[0].clientY - startY) > 10) {
        clearTimeout(holdTimer);
        holdTimer = null;
      }
    }, { passive: true });

    cardsEl.addEventListener('touchend', function() {
      if (holdTimer) { clearTimeout(holdTimer); holdTimer = null; }
    });
  })();
</script>
