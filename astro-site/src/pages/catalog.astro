---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const total = D.length;
const year = String(new Date().getFullYear());

const shortType: Record<string, string> = {
  'Самостоятельная работа': 'Самост.',
  'Выпускная квалификационная работа': 'ВКР',
  'Экзаменационные материалы': 'Экзамен',
  'Контрольная работа': 'Контрольная',
  'Курсовая работа': 'Курсовая',
  'Отчет по практике': 'Практика',
  'Отчет о научно-практической работе': 'НПР',
  'Справочный материал': 'Справочник',
  'Нормативный документ': 'Норматив',
  'Учебный документ': 'Учебный',
  'Шаблон документа': 'Шаблон',
  'Аналитический документ': 'Аналитика',
  'Практическое задание': 'Практич.',
  'Методические материалы': 'Методичка',
  'Учебная работа': 'Учебная',
  'Учебный материал': 'Учебный',
};

function getYear(doc: any) {
  const s = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const m = s.match(/(?:19|20)\d{2}/);
  return m ? m[0] : year;
}

function shortCatLabel(cat: string): string {
  const map: Record<string, string> = {
    'Самостоятельные работы': 'Самост.',
    'Методические материалы': 'Методич.',
    'Отчёты по практике': 'Практика',
    'ВКР и дипломы': 'ВКР',
    'Конспекты лекций': 'Конспекты',
    'Курсовые работы': 'Курсовые',
    'Рефераты': 'Рефераты',
  };
  return map[cat] || cat;
}

/* Category chips: sorted by count descending */
const catMap = new Map<string, number>();
for (const doc of D) {
  const c = (doc as any).category || 'Разное';
  catMap.set(c, (catMap.get(c) || 0) + 1);
}
const typeChips = [...catMap.entries()].sort((a, b) => b[1] - a[1]);
---

<Base title="Каталог -- Библиотека академического салона" description="Каталог студенческих работ: курсовые, рефераты, ВКР, отчёты по практике. Бесплатное скачивание без регистрации." currentPath="/catalog">

  <div class="app">
    <!-- TOP PANEL: title + search unified -->
    <div class="topbar">
      <h1 class="topbar-title">Каталог</h1>
      <div class="topbar-search">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" id="q" placeholder="Поиск..." autocomplete="off" autocorrect="off" spellcheck="false" aria-label="Поиск документов" />
        <kbd class="topbar-kbd" id="hint">/</kbd>
      </div>
      <span class="topbar-count"><span id="visCount">{total}</span> из {total}</span>
    </div>

    <!-- CATEGORY TABS -->
    <div class="tabs" id="tabs">
      <button class="tab active" data-cat="all">Все <span class="tab-n">{total}</span></button>
      {typeChips.map(([name, count]) => (
        <button class="tab" data-cat={name}>{shortCatLabel(name)} <span class="tab-n">{count}</span></button>
      ))}
    </div>

    <!-- TABLE -->
    <div class="table-wrap" id="tableWrap">
      <!-- Column headers -->
      <div class="table-head">
        <span class="th th-type">Тип</span>
        <span class="th th-title">Название</span>
        <span class="th th-subj">Предмет · Год</span>
        <span class="th th-fmt">Формат</span>
      </div>

      <!-- Rows -->
      <div class="table-body" id="tableBody">
        {D.map((doc: any, i: number) => {
          const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
          const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
          const type = shortType[doc.docType || doc.category || ''] || doc.docType || '';
          const subj = doc.subject || '';
          return (
            <a href={'/doc/' + doc.file} class="row"
               data-t={title.toLowerCase()}
               data-s={subj.toLowerCase()}
               data-c={doc.category || ''}
               data-i={i}>
              <span class="td td-type">{type}</span>
              <span class="td td-title">{title}</span>
              <span class="td td-subj">{[subj, getYear(doc)].filter(Boolean).join(' · ')}</span>
              <span class="td td-fmt">{ext}</span>
            </a>
          );
        })}
      </div>
    </div>

    <!-- EMPTY STATE -->
    <div class="nil" id="nil" style="display:none">
      <p>Ничего не найдено</p>
      <button id="resetBtn">Сбросить</button>
      <a href="/order">Заказать работу &rarr;</a>
    </div>

    <!-- BOTTOM BAR -->
    <div class="bottombar">
      <span class="bottombar-info">Бесплатно, без регистрации</span>
      <a href="/order" class="bottombar-cta">Нужна уникальная? Заказать &rarr;</a>
    </div>
  </div>

</Base>

<style>
  /* ================================================================
     CATALOG APP -- Dense Table
     Linear meets Raycast. One viewport. Data, beautifully presented.
     ================================================================ */

  :global(.footer) { display: none; }

  /* ----------------------------------------------------------------
     APP CONTAINER -- one viewport height, no page scroll
     ---------------------------------------------------------------- */
  .app {
    display: flex;
    flex-direction: column;
    height: calc(100svh - var(--nav-h));
    overflow: hidden;
    background: var(--bg);
  }

  /* ----------------------------------------------------------------
     TOP BAR -- title + search + count, all in one clean row
     ---------------------------------------------------------------- */
  .topbar {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 32px;
    border-bottom: 1px solid var(--brd);
    flex-shrink: 0;
  }

  .topbar-title {
    font: 300 20px/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    flex-shrink: 0;
  }

  .topbar-search {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border: 1px solid var(--brd);
    border-radius: 8px;
    background: rgba(255,255,255,.02);
    transition: border-color .2s, background .2s;
  }

  .topbar-search:focus-within {
    border-color: var(--ac-b);
    background: rgba(255,255,255,.04);
  }

  .topbar-search svg {
    color: var(--t3);
    opacity: .4;
    flex-shrink: 0;
  }

  .topbar-search input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--t1);
    font: 400 13px/1 var(--fi);
    outline: none;
    min-width: 0;
  }

  .topbar-search input::placeholder { color: var(--t3); opacity: .5; }

  .topbar-kbd {
    font: 400 9px/1 var(--fm);
    color: var(--t3);
    border: 1px solid var(--brd);
    padding: 2px 5px;
    border-radius: 3px;
    opacity: .35;
    transition: opacity .15s;
  }

  .topbar-search:focus-within .topbar-kbd {
    opacity: 0;
    pointer-events: none;
  }

  .topbar-count {
    font: 400 11px/1 var(--fm);
    color: var(--t3);
    opacity: .4;
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* ----------------------------------------------------------------
     CATEGORY TABS
     ---------------------------------------------------------------- */
  .tabs {
    display: flex;
    gap: 0;
    padding: 0 32px;
    border-bottom: 1px solid var(--brd);
    overflow-x: auto;
    scrollbar-width: none;
    flex-shrink: 0;
  }

  .tabs::-webkit-scrollbar { display: none; }

  .tab {
    flex-shrink: 0;
    padding: 12px 20px;
    border: none;
    background: transparent;
    color: var(--t3);
    font: 400 12px/1 var(--fi);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color .2s, border-color .2s;
    white-space: nowrap;
  }

  .tab:hover { color: var(--t1); }

  .tab.active {
    color: var(--ac);
    border-bottom-color: var(--ac);
  }

  .tab-n {
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    margin-left: 6px;
    opacity: .5;
  }

  /* ----------------------------------------------------------------
     TABLE
     ---------------------------------------------------------------- */
  .table-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .table-head {
    display: grid;
    grid-template-columns: 90px 1fr 160px 70px;
    gap: 0;
    padding: 0 32px;
    border-bottom: 1px solid var(--brd);
    flex-shrink: 0;
  }

  .th {
    padding: 10px 12px;
    font: 500 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    opacity: .5;
  }

  .table-body {
    flex: 1;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,.08) transparent;
  }

  .row {
    display: grid;
    grid-template-columns: 90px 1fr 160px 70px;
    gap: 0;
    padding: 0 32px;
    text-decoration: none;
    color: var(--t1);
    border-bottom: 1px solid rgba(255,255,255,.03);
    transition: background .12s;
  }

  .row:hover {
    background: rgba(255,255,255,.04);
  }

  .row:hover .td-title {
    color: var(--t1);
    text-decoration: underline;
    text-decoration-color: rgba(255,255,255,.2);
    text-underline-offset: 3px;
  }

  .td {
    padding: 14px 12px;
    font: 400 13px/1.4 var(--fi);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .td-type {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--t3);
    display: flex;
    align-items: center;
  }

  .td-title {
    font: 400 14px/1.4 var(--fd);
    white-space: normal;
    -webkit-line-clamp: 2;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color .15s;
  }

  .td-subj {
    color: var(--t3);
    font-size: 12px;
  }

  .td-fmt {
    font: 400 10px/1 var(--fm);
    text-transform: uppercase;
    color: var(--t3);
    opacity: .4;
    display: flex;
    align-items: center;
  }

  /* Alternating rows for readability */
  .row:nth-child(even) {
    background: rgba(255,255,255,.015);
  }

  .row:nth-child(even):hover {
    background: rgba(255,255,255,.05);
  }

  /* Active/focused row */
  .row:active {
    background: rgba(255,255,255,.06);
  }

  /* Hidden rows */
  :global(.row.hid) { display: none; }

  /* ----------------------------------------------------------------
     BOTTOM BAR
     ---------------------------------------------------------------- */
  .bottombar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 32px;
    border-top: 1px solid var(--brd);
    flex-shrink: 0;
  }

  .bottombar-info {
    font: 400 11px/1 var(--fi);
    color: var(--t3);
  }

  .bottombar-cta {
    font: 400 11px/1 var(--fi);
    color: var(--t3);
    text-decoration: none;
    transition: color .2s;
  }

  .bottombar-cta:hover { color: var(--t1); }

  /* ----------------------------------------------------------------
     EMPTY STATE
     ---------------------------------------------------------------- */
  .nil {
    flex: 1;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    color: var(--t3);
    font: 400 14px/1.5 var(--fi);
  }

  .nil button {
    padding: 8px 24px;
    border: 1px solid var(--brd);
    border-radius: 8px;
    background: transparent;
    color: var(--t2);
    font: 400 12px/1 var(--fi);
    cursor: pointer;
  }

  .nil a {
    color: var(--ac);
    text-decoration: none;
    font-size: 12px;
  }

  /* ----------------------------------------------------------------
     HIGHLIGHT
     ---------------------------------------------------------------- */
  :global(.hl) {
    background: rgba(212,175,55,.2);
    color: var(--ac);
    border-radius: 2px;
    padding: 0 1px;
  }

  /* ----------------------------------------------------------------
     LIGHT THEME OVERRIDES
     ---------------------------------------------------------------- */
  :global([data-theme="light"]) .row:hover { background: rgba(0,0,0,.02); }
  :global([data-theme="light"]) .row:nth-child(even) { background: rgba(0,0,0,.01); }
  :global([data-theme="light"]) .row:nth-child(even):hover { background: rgba(0,0,0,.03); }
  :global([data-theme="light"]) .tab.active { color: var(--ac); border-bottom-color: var(--ac); }
  :global([data-theme="light"]) .topbar-search input { color: var(--t1); }
  :global([data-theme="light"]) .topbar-btn:hover { border-color: rgba(0,0,0,.12); }

  :global([data-theme="light"]) :global(.hl) {
    background: rgba(180,140,20,.12);
    color: #8b6914;
  }

  /* ----------------------------------------------------------------
     REDUCED MOTION
     ---------------------------------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    .row, .tab, .topbar-btn { transition: none; }
  }

  /* ----------------------------------------------------------------
     MOBILE (max 768px)
     ---------------------------------------------------------------- */
  @media (max-width: 768px) {
    .topbar {
      padding: 10px 16px;
      gap: 10px;
    }
    .topbar-title { font-size: 16px; }
    .topbar-kbd { display: none; }
    .topbar-count { display: none; }
    .tabs { padding: 0 16px; }

    .table-head { display: none; }

    .row {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: 12px 16px;
      border-bottom: 1px solid rgba(255,255,255,.04);
    }

    .td-type { font-size: 10px; }
    .td-title { font-size: 15px; white-space: normal; }
    .td-subj { font-size: 12px; }
    .td-fmt { font-size: 10px; }

    .bottombar { padding: 10px 16px; }

    .app {
      height: calc(100svh - 56px - 60px); /* nav + bottom tab bar */
    }

    :global([data-theme="light"]) .row {
      border-bottom-color: rgba(0,0,0,.04);
    }
  }
</style>

<script>
function initCatalog() {
  const input = document.getElementById('q') as HTMLInputElement | null;
  const rows = Array.from(document.querySelectorAll<HTMLElement>('.row'));
  const tabs = Array.from(document.querySelectorAll<HTMLElement>('.tab'));
  const nil = document.getElementById('nil');
  const tableWrap = document.getElementById('tableWrap');
  const visCountEl = document.getElementById('visCount');
  const resetBtn = document.getElementById('resetBtn');
  const hint = document.getElementById('hint');

  if (!input || !rows.length) return;

  let q = '', cat = 'all';
  let timer = 0;

  function run() {
    var n = 0;
    var words = q ? q.split(/\s+/) : [];

    rows.forEach(function(row) {
      var el = row as HTMLElement;
      var ok = true;

      // Category filter
      if (cat !== 'all' && el.dataset.c !== cat) ok = false;

      // Search
      if (ok && words.length) {
        var hay = [el.dataset.t, el.dataset.s, (el.dataset.c || '').toLowerCase()].join(' ');
        ok = words.every(function(w) {
          if (hay.includes(w)) return true;
          // Fuzzy: 1-char tolerance for words >= 4 chars
          if (w.length >= 4) {
            for (var i = 0; i <= hay.length - w.length; i++) {
              var diff = 0;
              for (var j = 0; j < w.length; j++) {
                if (hay[i+j] !== w[j]) diff++;
                if (diff > 1) break;
              }
              if (diff <= 1) return true;
            }
          }
          return false;
        });
      }

      el.classList.toggle('hid', !ok);
      if (ok) {
        n++;
        // Highlight
        var titleEl = el.querySelector('.td-title');
        if (titleEl) {
          var orig = titleEl.textContent || '';
          if (!q) { titleEl.innerHTML = orig; }
          else {
            var html = orig;
            words.forEach(function(w) {
              var re = new RegExp('(' + w.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
              html = html.replace(re, '<span class="hl">$1</span>');
            });
            titleEl.innerHTML = html;
          }
        }
      }
    });

    if (visCountEl) visCountEl.textContent = String(n);
    if (nil && tableWrap) {
      nil.style.display = n === 0 ? 'flex' : 'none';
      tableWrap.style.display = n === 0 ? 'none' : '';
    }

    // URL sync
    var url = new URL(window.location.href);
    if (q) url.searchParams.set('q', q); else url.searchParams.delete('q');
    if (cat !== 'all') url.searchParams.set('cat', cat); else url.searchParams.delete('cat');
    history.replaceState(null, '', url.toString());
  }

  // Search
  input.addEventListener('input', () => {
    clearTimeout(timer);
    timer = window.setTimeout(() => {
      q = input.value.trim().toLowerCase();
      run();
    }, 100);
  });

  // Category tabs
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      cat = tab.dataset.cat || 'all';
      run();
    });
  });

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement !== input) {
      e.preventDefault();
      input.focus();
    }
    if (e.key === 'Escape' && document.activeElement === input) {
      input.value = '';
      q = '';
      run();
      input.blur();
    }
  });

  // Reset
  if (resetBtn) resetBtn.addEventListener('click', () => {
    input.value = '';
    q = '';
    cat = 'all';
    tabs.forEach((t) => t.classList.remove('active'));
    if (tabs[0]) tabs[0].classList.add('active');
    run();
  });

  // Focus hint
  input.addEventListener('focus', () => { if (hint) hint.style.display = 'none'; });
  input.addEventListener('blur', () => { if (hint && !input.value) hint.style.display = ''; });

  // URL params on load
  const params = new URLSearchParams(window.location.search);
  const qp = params.get('q');
  const cp = params.get('cat');
  if (qp) { input.value = qp; q = qp.toLowerCase(); }
  if (cp) {
    cat = cp;
    tabs.forEach((t) => {
      t.classList.toggle('active', t.dataset.cat === cp);
    });
  }
  if (qp || cp) run();
}

initCatalog();
document.addEventListener('astro:page-load', initCatalog);
</script>
