---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const total = D.length;
const year = String(new Date().getFullYear());

const shortType: Record<string, string> = {
  'Самостоятельная работа': 'Самост.',
  'Выпускная квалификационная работа': 'ВКР',
  'Экзаменационные материалы': 'Экзамен',
  'Контрольная работа': 'Контрольная',
  'Курсовая работа': 'Курсовая',
  'Отчет по практике': 'Практика',
  'Отчет о научно-практической работе': 'НПР',
  'Справочный материал': 'Справочник',
  'Нормативный документ': 'Норматив',
  'Учебный документ': 'Учебный',
  'Шаблон документа': 'Шаблон',
  'Аналитический документ': 'Аналитика',
  'Практическое задание': 'Практич.',
  'Методические материалы': 'Методичка',
  'Учебная работа': 'Учебная',
  'Учебный материал': 'Учебный',
};

function getYear(doc: any) {
  const s = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const m = s.match(/(?:19|20)\d{2}/);
  return m ? m[0] : year;
}

function shortCatLabel(cat: string): string {
  const map: Record<string, string> = {
    'Самостоятельные работы': 'Самост.',
    'Методические материалы': 'Методич.',
    'Отчёты по практике': 'Практика',
    'ВКР и дипломы': 'ВКР',
    'Конспекты лекций': 'Конспекты',
    'Курсовые работы': 'Курсовые',
    'Рефераты': 'Рефераты',
  };
  return map[cat] || cat;
}

/* Category chips: sorted by count descending */
const catMap = new Map<string, number>();
for (const doc of D) {
  const c = (doc as any).category || 'Разное';
  catMap.set(c, (catMap.get(c) || 0) + 1);
}
const typeChips = [...catMap.entries()].sort((a, b) => b[1] - a[1]);
---

<Base title="Каталог -- Библиотека академического салона" description="Каталог студенческих работ: курсовые, рефераты, ВКР, отчёты по практике. Бесплатное скачивание без регистрации." currentPath="/catalog">

  <div class="app">
    <!-- TOP PANEL: title + search unified -->
    <div class="topbar">
      <h1 class="topbar-title">Каталог</h1>
      <div class="topbar-search">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" id="q" placeholder="Поиск..." autocomplete="off" autocorrect="off" spellcheck="false" aria-label="Поиск документов" />
        <button class="topbar-clear" id="clearBtn" type="button" aria-label="Очистить" style="display:none">&times;</button>
        <kbd class="topbar-kbd" id="hint">/</kbd>
      </div>
      <span class="topbar-count" role="status" aria-live="polite"><span id="visCount">{total}</span> из <span id="totalCount">{total}</span></span>
      <div class="sort-wrap">
        <button class="topbar-icon" id="sortBtn" type="button" aria-label="Сортировка">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h12M3 18h6"/></svg>
        </button>
        <div class="sort-menu" id="sortMenu" style="display:none">
          <button class="sort-opt active" data-sort="default">По умолчанию</button>
          <button class="sort-opt" data-sort="az">А — Я</button>
          <button class="sort-opt" data-sort="za">Я — А</button>
          <button class="sort-opt" data-sort="subj">По предмету</button>
        </div>
      </div>
    </div>

    <!-- CATEGORY TABS -->
    <div class="tabs" id="tabs">
      <button class="tab active" data-cat="all">Все <span class="tab-n">{total}</span></button>
      {typeChips.map(([name, count]) => (
        <button class="tab" data-cat={name}>{shortCatLabel(name)} <span class="tab-n">{count}</span></button>
      ))}
      <button class="tab tab--fav" data-cat="__fav">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <span class="tab-n" id="favTabCount">0</span>
      </button>
    </div>

    <!-- TABLE -->
    <div class="table-wrap" id="tableWrap">
      <!-- Column headers -->
      <div class="table-head">
        <span class="th th-type">Тип</span>
        <span class="th th-title">Название</span>
        <span class="th th-subj">Предмет · Год</span>
        <span class="th th-fmt">Формат</span>
        <span class="th th-fav"></span>
      </div>

      <!-- Rows -->
      <div class="table-body" id="tableBody">
        {D.map((doc: any, i: number) => {
          const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
          const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
          const type = shortType[doc.docType || doc.category || ''] || doc.docType || '';
          const subj = doc.subject || '';
          return (
            <a href={'/doc/' + doc.file} class="row"
               data-t={title.toLowerCase()}
               data-s={subj.toLowerCase()}
               data-c={doc.category || ''}
               data-i={i}
               data-desc={doc.catalogDescription || doc.description || ''}>
              <span class="td td-type">{type}</span>
              <span class="td td-title">{title}</span>
              <span class="td td-subj">{[subj, getYear(doc)].filter(Boolean).join(' · ')}</span>
              <span class="td td-fmt">{ext}</span>
              <button class="td-fav" data-file={doc.file} type="button" aria-label="В избранное">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </button>
            </a>
          );
        })}
      </div>
    </div>

    <!-- EMPTY STATE -->
    <div class="nil" id="nil" style="display:none">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
      <p class="nil-title">Ничего не найдено</p>
      <p class="nil-hint">Попробуйте изменить запрос или выбрать другую категорию</p>
      <p class="nil-suggest">Попробуйте: <button class="nil-term" data-term="психология">психология</button> · <button class="nil-term" data-term="курсовая">курсовая</button> · <button class="nil-term" data-term="ВКР">ВКР</button></p>
      <div class="nil-actions">
        <button id="resetBtn" class="nil-btn">Сбросить фильтры</button>
        <a href="/order" class="nil-link">Заказать работу &rarr;</a>
      </div>
    </div>

    <!-- BOTTOM BAR -->
    <div class="bottombar">
      <span class="bottombar-info">Бесплатно, без регистрации</span>
      <a href="/order" class="bottombar-cta">Нужна уникальная? Заказать &rarr;</a>
    </div>
  </div>

</Base>

<style>
  /* ================================================================
     CATALOG APP -- Dense Table
     Linear meets Raycast. One viewport. Data, beautifully presented.
     ================================================================ */

  :global(.footer) { display: none; }

  /* ----------------------------------------------------------------
     APP CONTAINER -- one viewport height, no page scroll
     ---------------------------------------------------------------- */
  .app {
    display: flex;
    flex-direction: column;
    height: calc(100svh - var(--nav-h));
    overflow: hidden;
    background: var(--bg);
  }

  /* ----------------------------------------------------------------
     TOP BAR -- title + search + count, all in one clean row
     ---------------------------------------------------------------- */
  .topbar {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 32px;
    border-bottom: 1px solid var(--brd);
    flex-shrink: 0;
  }

  .topbar-title {
    font: 300 20px/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    flex-shrink: 0;
  }

  .topbar-search {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border: 1px solid var(--brd);
    border-radius: 8px;
    background: rgba(255,255,255,.02);
    transition: border-color .2s, background .2s;
  }

  .topbar-search:focus-within {
    border-color: rgba(255,255,255,.15);
    background: rgba(255,255,255,.04);
  }

  .topbar-search svg {
    color: var(--t3);
    opacity: .4;
    flex-shrink: 0;
  }

  .topbar-search input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--t1);
    font: 400 13px/1 var(--fi);
    outline: none;
    min-width: 0;
  }

  .topbar-search input::placeholder { color: var(--t3); opacity: .5; }

  .topbar-kbd {
    font: 400 9px/1 var(--fm);
    color: var(--t3);
    border: 1px solid var(--brd);
    padding: 2px 5px;
    border-radius: 3px;
    opacity: .35;
    transition: opacity .15s;
  }

  .topbar-search:focus-within .topbar-kbd {
    opacity: 0;
    pointer-events: none;
  }

  .topbar-count {
    font: 400 11px/1 var(--fm);
    color: var(--t3);
    opacity: .4;
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* ----------------------------------------------------------------
     CATEGORY TABS
     ---------------------------------------------------------------- */
  .tabs {
    display: flex;
    gap: 0;
    padding: 0 32px;
    border-bottom: 1px solid var(--brd);
    overflow-x: auto;
    scrollbar-width: none;
    flex-shrink: 0;
  }

  .tabs::-webkit-scrollbar { display: none; }

  .tab {
    flex-shrink: 0;
    padding: 12px 20px;
    border: none;
    background: transparent;
    color: var(--t3);
    font: 400 12px/1 var(--fi);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color .2s, border-color .2s;
    white-space: nowrap;
  }

  .tab:hover { color: var(--t1); }

  .tab.active {
    color: var(--ac);
    border-bottom-color: var(--ac);
  }

  .tab-n {
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    margin-left: 6px;
    opacity: .5;
  }

  /* ----------------------------------------------------------------
     TABLE
     ---------------------------------------------------------------- */
  .table-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .table-head {
    display: grid;
    grid-template-columns: 90px 1fr 160px 70px 36px;
    gap: 0;
    padding: 0 32px;
    border-bottom: 1px solid var(--brd);
    flex-shrink: 0;
  }

  .th {
    padding: 10px 12px;
    font: 500 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    opacity: .5;
  }

  .table-body {
    flex: 1;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,.08) transparent;
    scroll-behavior: smooth;
  }

  .row {
    display: grid;
    grid-template-columns: 90px 1fr 160px 70px 36px;
    gap: 0;
    padding: 0 32px;
    min-height: 48px;
    text-decoration: none;
    color: var(--t1);
    border-bottom: 1px solid rgba(255,255,255,.03);
    transition: background .12s, opacity .2s;
    align-items: center;
  }

  .row:hover {
    background: rgba(255,255,255,.04);
  }

  .row:hover .td-title {
    color: var(--t1);
    text-decoration: underline;
    text-decoration-color: rgba(255,255,255,.2);
    text-underline-offset: 3px;
  }

  .td {
    padding: 14px 12px;
    font: 400 13px/1.4 var(--fi);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .td-type {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--t3);
    display: flex;
    align-items: center;
  }

  .td-title {
    font: 400 14px/1.4 var(--fd);
    white-space: normal;
    -webkit-line-clamp: 2;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color .15s;
  }

  .td-subj {
    color: var(--t3);
    font-size: 12px;
  }

  .td-fmt {
    font: 400 10px/1 var(--fm);
    text-transform: uppercase;
    color: var(--t3);
    opacity: .4;
    display: flex;
    align-items: center;
  }

  /* Alternating rows for readability */
  .row:nth-child(even) {
    background: rgba(255,255,255,.015);
  }

  .row:nth-child(even):hover {
    background: rgba(255,255,255,.05);
  }

  /* Active/focused row */
  .row:active {
    background: rgba(255,255,255,.06);
  }

  /* Hidden rows */
  :global(.row.hid) { display: none; }

  /* ----------------------------------------------------------------
     BOTTOM BAR
     ---------------------------------------------------------------- */
  .bottombar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 32px;
    border-top: 1px solid var(--brd);
    flex-shrink: 0;
  }

  .bottombar-info {
    font: 400 11px/1 var(--fi);
    color: var(--t3);
  }

  .bottombar-cta {
    font: 400 11px/1 var(--fi);
    color: var(--t3);
    text-decoration: none;
    transition: color .2s;
  }

  .bottombar-cta:hover { color: var(--t1); }

  /* ----------------------------------------------------------------
     SORT DROPDOWN
     ---------------------------------------------------------------- */
  .sort-wrap { position: relative; }
  .topbar-icon {
    border: none;
    background: none;
    color: var(--t3);
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    transition: color .15s;
  }
  .topbar-icon:hover { color: var(--t1); }
  .sort-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 160px;
    padding: 6px;
    background: rgba(18,16,20,.95);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 10px;
    box-shadow: 0 12px 40px rgba(0,0,0,.4);
    z-index: 100;
  }
  .sort-opt {
    display: block;
    width: 100%;
    padding: 8px 14px;
    border: none;
    background: none;
    color: var(--t2);
    font: 400 12px/1 var(--fi);
    text-align: left;
    cursor: pointer;
    border-radius: 6px;
    transition: background .12s;
  }
  .sort-opt:hover { background: rgba(255,255,255,.06); color: var(--t1); }
  .sort-opt.active { color: var(--ac); }

  /* ----------------------------------------------------------------
     FAVORITES
     ---------------------------------------------------------------- */
  .td-fav {
    opacity: 0;
    border: none;
    background: none;
    color: var(--t3);
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    transition: opacity .15s, color .15s;
  }
  .row:hover .td-fav { opacity: 1; }
  .td-fav.is-fav { opacity: 1; color: var(--ac); }
  .td-fav.is-fav svg { fill: var(--ac); }
  .td-fav:hover { color: var(--ac); }

  /* ----------------------------------------------------------------
     SEARCH CLEAR BUTTON
     ---------------------------------------------------------------- */
  .topbar-clear {
    border: none;
    background: none;
    color: var(--t3);
    font-size: 16px;
    cursor: pointer;
    padding: 0 4px;
    transition: color .15s;
    line-height: 1;
  }
  .topbar-clear:hover { color: var(--t1); }

  /* ----------------------------------------------------------------
     EMPTY STATE
     ---------------------------------------------------------------- */
  .nil {
    flex: 1;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    color: var(--t3);
    font: 400 14px/1.5 var(--fi);
  }

  .nil svg { color: var(--t3); opacity: .3; margin-bottom: 8px; }
  .nil-title { font: 300 20px/1 var(--fd); color: var(--t2); }
  .nil-hint { font: 400 13px/1.5 var(--fi); color: var(--t3); margin-top: 4px; }
  .nil-actions { display: flex; gap: 16px; align-items: center; margin-top: 16px; }
  .nil-btn { padding: 8px 20px; border: 1px solid var(--brd); border-radius: 6px; background: none; color: var(--t2); font: 400 12px/1 var(--fi); cursor: pointer; transition: border-color .2s, color .2s; }
  .nil-btn:hover { border-color: rgba(255,255,255,.15); color: var(--t1); }
  .nil-link { font: 400 12px/1 var(--fi); color: var(--t3); text-decoration: none; transition: color .2s; }
  .nil-link:hover { color: var(--t1); }

  /* ----------------------------------------------------------------
     KEYBOARD ROW FOCUS
     ---------------------------------------------------------------- */
  .row:focus-visible {
    outline: 1px solid var(--ac-b);
    outline-offset: -1px;
    background: rgba(255,255,255,.04);
  }

  /* ----------------------------------------------------------------
     HIGHLIGHT
     ---------------------------------------------------------------- */
  :global(.hl) {
    background: rgba(212,175,55,.2);
    color: var(--ac);
    border-radius: 2px;
    padding: 0 1px;
  }

  /* ----------------------------------------------------------------
     LIGHT THEME OVERRIDES
     ---------------------------------------------------------------- */
  :global([data-theme="light"]) .row:hover { background: rgba(0,0,0,.02); }
  :global([data-theme="light"]) .row:nth-child(even) { background: rgba(0,0,0,.01); }
  :global([data-theme="light"]) .row:nth-child(even):hover { background: rgba(0,0,0,.03); }
  :global([data-theme="light"]) .tab.active { color: var(--ac); border-bottom-color: var(--ac); }
  :global([data-theme="light"]) .topbar-search input { color: var(--t1); }
  :global([data-theme="light"]) .topbar-btn:hover { border-color: rgba(0,0,0,.12); }

  :global([data-theme="light"]) :global(.hl) {
    background: rgba(180,140,20,.12);
    color: #8b6914;
  }

  :global([data-theme="light"]) .topbar { border-color: rgba(0,0,0,.06); }
  :global([data-theme="light"]) .topbar-search { border-color: rgba(0,0,0,.1); background: rgba(0,0,0,.02); }
  :global([data-theme="light"]) .topbar-search:focus-within { border-color: rgba(0,0,0,.2); background: rgba(0,0,0,.03); }
  :global([data-theme="light"]) .tabs { border-color: rgba(0,0,0,.06); }
  :global([data-theme="light"]) .table-head { border-color: rgba(0,0,0,.06); }
  :global([data-theme="light"]) .row { border-color: rgba(0,0,0,.04); }
  :global([data-theme="light"]) .bottombar { border-color: rgba(0,0,0,.06); }
  :global([data-theme="light"]) .sort-menu { background: rgba(255,255,255,.97); border-color: rgba(0,0,0,.08); box-shadow: 0 8px 32px rgba(0,0,0,.1); }
  :global([data-theme="light"]) .sort-opt:hover { background: rgba(0,0,0,.04); }
  :global([data-theme="light"]) .nil-btn { border-color: rgba(0,0,0,.12); }
  :global([data-theme="light"]) .topbar-clear { color: var(--t3); }

  /* ----------------------------------------------------------------
     REDUCED MOTION
     ---------------------------------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    .row, .tab, .topbar-btn { transition: none; }
  }

  /* ----------------------------------------------------------------
     UPGRADE: download hint on format cell (#2)
     ---------------------------------------------------------------- */
  .td-fmt::after { content: ' \2193'; opacity: 0; transition: opacity .15s; }
  .row:hover .td-fmt::after { opacity: 1; }

  /* UPGRADE: tab active count gold (#6) */
  .tab.active .tab-n { color: var(--ac); opacity: .7; }

  /* UPGRADE: sort button active state (#8) */
  .topbar-icon.is-sorted { color: var(--ac); }

  /* UPGRADE: placeholder fade on focus (#10) */
  .topbar-search:focus-within input::placeholder { opacity: .3; }

  /* UPGRADE: search debounce pulse (#16) */
  .topbar-search.is-loading svg { animation: search-pulse .6s ease infinite; }
  @keyframes search-pulse { 0%,100% { opacity: .4; } 50% { opacity: .8; } }

  /* UPGRADE: fav tab style */
  .tab--fav { display: flex; align-items: center; gap: 4px; }
  .tab--fav svg { width: 12px; height: 12px; }

  /* UPGRADE: nil suggest terms (#4) */
  .nil-suggest { font: 400 13px/1.5 var(--fi); color: var(--t3); margin-top: 8px; }
  .nil-term { border: 1px solid var(--brd); border-radius: 4px; background: none; color: var(--t2); font: 400 12px/1 var(--fi); padding: 4px 10px; cursor: pointer; transition: border-color .2s, color .2s; }
  .nil-term:hover { border-color: rgba(255,255,255,.15); color: var(--t1); }

  /* #5: Topbar responsive — very small screens */
  @media (max-width: 375px) {
    .topbar-title { display: none; }
  }

  /* #6: Search input 16px on mobile to prevent iOS zoom */
  @media (max-width: 768px) {
    .topbar-search input { font-size: 16px; }
  }

  /* #8: Row active state — touch feedback */
  @media (hover: none) {
    .row:active { background: rgba(255,255,255,.07); }
  }

  /* #9: Nil empty state fade-in animation */
  .nil[style*="flex"] { animation: nil-fade .3s ease-out; }
  @keyframes nil-fade { from { opacity: 0; transform: translateY(8px); } }

  /* #10: Light theme scrollbar styling */
  :global([data-theme="light"]) .table-body { scrollbar-color: rgba(0,0,0,.08) transparent; }

  /* #2: Hover description tooltip */
  .catalog-tooltip {
    position: fixed;
    z-index: 200;
    max-width: 360px;
    padding: 10px 14px;
    background: rgba(18,16,20,.95);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0,0,0,.3);
    font: 400 12px/1.5 var(--fi);
    color: var(--t2);
    pointer-events: none;
    animation: tooltip-in .15s ease-out;
  }
  :global([data-theme="light"]) .catalog-tooltip {
    background: rgba(255,255,255,.96);
    border-color: rgba(0,0,0,.08);
    box-shadow: 0 8px 32px rgba(0,0,0,.08);
    color: var(--t2);
  }
  @keyframes tooltip-in { from { opacity: 0; transform: translateY(4px); } }

  /* #4: Letter separator for A-Z sort */
  :global(.letter-sep) {
    grid-column: 1 / -1;
    padding: 4px 12px;
    font: 500 11px/1 var(--fi);
    color: var(--t3);
    opacity: .3;
    background: rgba(255,255,255,.02);
  }

  /* ----------------------------------------------------------------
     MOBILE (max 768px)
     ---------------------------------------------------------------- */
  @media (max-width: 768px) {
    .topbar {
      padding: 10px 16px;
      gap: 10px;
    }
    .topbar-title { font-size: 16px; }
    .topbar-kbd { display: none; }
    .topbar-count { display: none; }
    .tabs {
      padding: 0 16px;
      mask-image: linear-gradient(90deg, #000 90%, transparent);
      -webkit-mask-image: linear-gradient(90deg, #000 90%, transparent);
    }

    .table-head { display: none; }

    .row {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 6px 8px;
      padding: 12px 16px;
      border-bottom: 1px solid rgba(255,255,255,.04);
    }

    .td-type { font-size: 10px; flex-shrink: 0; }
    .td-title { flex: 1; min-width: 0; font-size: 15px; white-space: normal; }
    .td-subj { width: 100%; font-size: 12px; }
    .td-fmt { display: none; }
    .td-fav { display: none; }
    .th-fav { display: none; }

    .bottombar { padding: 10px 16px; }

    .app {
      height: calc(100svh - 56px - 60px); /* nav + bottom tab bar */
    }

    :global([data-theme="light"]) .row {
      border-bottom-color: rgba(0,0,0,.04);
    }
  }
</style>

<script>
function initCatalog() {
  const app = document.querySelector('.app') as HTMLElement | null;
  if (!app || app.dataset.bound === '1') return;
  app.dataset.bound = '1';

  const input = document.getElementById('q') as HTMLInputElement | null;
  const rows = Array.from(document.querySelectorAll<HTMLElement>('.row'));
  const tabs = Array.from(document.querySelectorAll<HTMLElement>('.tab'));
  const nil = document.getElementById('nil');
  const tableWrap = document.getElementById('tableWrap');
  const tableBody = document.getElementById('tableBody');
  const visCountEl = document.getElementById('visCount');
  const resetBtn = document.getElementById('resetBtn');
  const hint = document.getElementById('hint');
  const clearBtn = document.getElementById('clearBtn');
  const sortBtn = document.getElementById('sortBtn');
  const sortMenu = document.getElementById('sortMenu');
  const sortOpts = Array.from(document.querySelectorAll<HTMLElement>('.sort-opt'));
  const searchWrap = input?.closest('.topbar-search') as HTMLElement | null;

  if (!input || !rows.length) return;

  let q = '', cat = 'all';
  let timer = 0;

  // #8 — Store original titles once to prevent highlight corruption
  const origTitles = new Map<HTMLElement, string>();
  rows.forEach(row => {
    const el = row.querySelector('.td-title');
    if (el) origTitles.set(row, el.textContent || '');
  });

  // #2 — Favorites: load from localStorage
  function getFavs(): Set<string> {
    try { return new Set(JSON.parse(localStorage.getItem('favorites') || '[]')); }
    catch { return new Set(); }
  }
  function saveFavs(favs: Set<string>) {
    localStorage.setItem('favorites', JSON.stringify([...favs]));
  }
  function syncFavs() {
    const favs = getFavs();
    rows.forEach(row => {
      const btn = row.querySelector('.td-fav') as HTMLElement | null;
      if (btn) {
        const file = btn.dataset.file || '';
        btn.classList.toggle('is-fav', favs.has(file));
      }
    });
  }
  syncFavs();

  // #13 — Favorites count in tab
  function updateFavTabCount() {
    const el = document.getElementById('favTabCount');
    if (el) el.textContent = String(getFavs().size);
  }
  updateFavTabCount();

  // #2 — Favorites: event delegation on tableBody
  if (tableBody) {
    tableBody.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.td-fav') as HTMLElement | null;
      if (!btn) return;
      e.preventDefault();
      e.stopPropagation();
      const file = btn.dataset.file || '';
      const favs = getFavs();
      if (favs.has(file)) favs.delete(file); else favs.add(file);
      saveFavs(favs);
      btn.classList.toggle('is-fav', favs.has(file));
      updateFavTabCount();
      // Re-filter if fav tab is active
      if (cat === '__fav') run();
    });
  }

  // #5 — Clear button visibility
  function updateClearBtn() {
    if (clearBtn) clearBtn.style.display = input!.value.length > 0 ? '' : 'none';
  }

  function run() {
    var n = 0;
    var words = q ? q.split(/\s+/) : [];

    rows.forEach(function(row) {
      var el = row as HTMLElement;
      var ok = true;

      // Category filter
      if (cat === '__fav') {
        const favs = getFavs();
        const btn = el.querySelector('.td-fav') as HTMLElement | null;
        const file = btn?.dataset.file || '';
        if (!favs.has(file)) ok = false;
      } else if (cat !== 'all' && el.dataset.c !== cat) ok = false;

      // Search
      if (ok && words.length) {
        var hay = [el.dataset.t, el.dataset.s, (el.dataset.c || '').toLowerCase()].join(' ');
        ok = words.every(function(w) {
          if (hay.includes(w)) return true;
          // Fuzzy: 1-char tolerance for words >= 4 chars
          if (w.length >= 4) {
            for (var i = 0; i <= hay.length - w.length; i++) {
              var diff = 0;
              for (var j = 0; j < w.length; j++) {
                if (hay[i+j] !== w[j]) diff++;
                if (diff > 1) break;
              }
              if (diff <= 1) return true;
            }
          }
          return false;
        });
      }

      el.classList.toggle('hid', !ok);
      if (ok) {
        n++;
        // #8 — Highlight using origTitles (prevents corruption)
        var titleEl = el.querySelector('.td-title');
        if (titleEl) {
          var orig = origTitles.get(el) || titleEl.textContent || '';
          if (!q) { titleEl.innerHTML = orig; }
          else {
            var html = orig;
            words.forEach(function(w) {
              var re = new RegExp('(' + w.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
              html = html.replace(re, '<span class="hl">$1</span>');
            });
            titleEl.innerHTML = html;
          }
        }
      }
    });

    // #3 — Dynamic tab counts
    const catCounts = new Map<string, number>();
    catCounts.set('all', 0);
    rows.forEach(row => {
      if (row.classList.contains('hid')) return;
      catCounts.set('all', (catCounts.get('all') || 0) + 1);
      const c = row.dataset.c || '';
      catCounts.set(c, (catCounts.get(c) || 0) + 1);
    });
    tabs.forEach(tab => {
      const countEl = tab.querySelector('.tab-n');
      const tabCat = tab.dataset.cat || 'all';
      const count = catCounts.get(tabCat) || 0;
      if (countEl) countEl.textContent = String(count);
    });

    if (visCountEl) visCountEl.textContent = String(n);
    if (nil && tableWrap) {
      nil.style.display = n === 0 ? 'flex' : 'none';
      tableWrap.style.display = n === 0 ? 'none' : '';
    }

    // #5 — Update clear button visibility
    updateClearBtn();

    // #18 — Scroll to top on search
    if (tableBody) tableBody.scrollTop = 0;

    // URL sync
    var url = new URL(window.location.href);
    if (q) url.searchParams.set('q', q); else url.searchParams.delete('q');
    if (cat !== 'all' && cat !== '__fav') url.searchParams.set('cat', cat); else url.searchParams.delete('cat');
    history.replaceState(null, '', url.toString());
  }

  // Search with debounce loading indicator (#16)
  input.addEventListener('input', () => {
    clearTimeout(timer);
    if (searchWrap) searchWrap.classList.add('is-loading');
    timer = window.setTimeout(() => {
      if (searchWrap) searchWrap.classList.remove('is-loading');
      q = input.value.trim().toLowerCase();
      run();
    }, 100);
  });

  // #5 — Clear button click
  if (clearBtn) {
    clearBtn.addEventListener('click', () => {
      input!.value = '';
      q = '';
      run();
      input!.focus();
    });
  }

  // Category tabs
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.classList.remove('active'));
      tab.classList.add('active');
      cat = tab.dataset.cat || 'all';
      run();
      // #9 — Scroll to top on tab change
      if (tableBody) tableBody.scrollTop = 0;
    });
  });

  // #1 — Sort dropdown toggle (robust)
  let sortOpen = false;
  function toggleSort() {
    sortOpen = !sortOpen;
    if (sortMenu) sortMenu.style.display = sortOpen ? 'block' : 'none';
  }
  function closeSort() {
    sortOpen = false;
    if (sortMenu) sortMenu.style.display = 'none';
  }
  if (sortBtn) {
    sortBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      e.preventDefault();
      toggleSort();
    });
  }
  document.addEventListener('click', (e) => {
    if (sortOpen && sortMenu && !sortMenu.contains(e.target as Node)) closeSort();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && sortOpen) { closeSort(); e.stopPropagation(); }
  }, true);

  // #1 — Sort options + #15 persistence + #8 highlight
  function applySort(mode: string) {
    if (!tableBody) return;
    const sorted = [...rows];
    if (mode === 'az') {
      sorted.sort((a, b) => (a.dataset.t || '').localeCompare(b.dataset.t || '', 'ru'));
    } else if (mode === 'za') {
      sorted.sort((a, b) => (b.dataset.t || '').localeCompare(a.dataset.t || '', 'ru'));
    } else if (mode === 'subj') {
      sorted.sort((a, b) => {
        const cmp = (a.dataset.s || '').localeCompare(b.dataset.s || '', 'ru');
        return cmp !== 0 ? cmp : (a.dataset.t || '').localeCompare(b.dataset.t || '', 'ru');
      });
    } else {
      sorted.sort((a, b) => Number(a.dataset.i || 0) - Number(b.dataset.i || 0));
    }
    // #4: Remove old letter separators
    tableBody.querySelectorAll('.letter-sep').forEach(el => el.remove());
    sorted.forEach(row => tableBody.appendChild(row));
    // #4: Insert letter dividers for A-Z sort
    if (mode === 'az') {
      let lastLetter = '';
      sorted.forEach(row => {
        if (row.classList.contains('hid')) return;
        const first = ((row.dataset.t || '')[0] || '').toUpperCase();
        if (first && first !== lastLetter) {
          lastLetter = first;
          const sep = document.createElement('div');
          sep.className = 'letter-sep';
          sep.textContent = first;
          tableBody.insertBefore(sep, row);
        }
      });
    }
    sortOpts.forEach(o => o.classList.toggle('active', o.dataset.sort === mode));
    if (sortBtn) sortBtn.classList.toggle('is-sorted', mode !== 'default');
    localStorage.setItem('catalog-sort', mode);
  }

  sortOpts.forEach((opt) => {
    opt.addEventListener('click', () => {
      applySort(opt.dataset.sort || 'default');
      closeSort();
    });
  });

  // #15 — Restore saved sort on load
  const savedSort = localStorage.getItem('catalog-sort') || 'default';
  if (savedSort !== 'default') applySort(savedSort);

  // Keyboard shortcuts
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement !== input) {
      e.preventDefault();
      input.focus();
    }
    if (e.key === 'Escape' && document.activeElement === input) {
      if (input.value) {
        input.value = ''; q = ''; run();
      } else if (cat !== 'all') {
        cat = 'all';
        tabs.forEach(t => t.classList.remove('active'));
        tabs[0]?.classList.add('active');
        run();
        input.blur();
      } else {
        input.blur();
      }
    }
  });

  // Reset
  if (resetBtn) resetBtn.addEventListener('click', () => {
    input.value = '';
    q = '';
    cat = 'all';
    tabs.forEach((t) => t.classList.remove('active'));
    if (tabs[0]) tabs[0].classList.add('active');
    run();
  });

  // #14 — Search suggestion terms
  document.querySelectorAll<HTMLElement>('.nil-term').forEach(btn => {
    btn.addEventListener('click', () => {
      input.value = btn.dataset.term || '';
      q = input.value.toLowerCase();
      cat = 'all';
      tabs.forEach(t => t.classList.remove('active'));
      tabs[0]?.classList.add('active');
      run();
      input.focus();
    });
  });

  // Focus hint
  input.addEventListener('focus', () => { if (hint) hint.style.display = 'none'; });
  input.addEventListener('blur', () => { if (hint && !input.value) hint.style.display = ''; });

  // URL params on load
  const params = new URLSearchParams(window.location.search);
  const qp = params.get('q');
  const cp = params.get('cat');
  if (qp) { input.value = qp; q = qp.toLowerCase(); }
  if (cp) {
    cat = cp;
    tabs.forEach((t) => {
      t.classList.toggle('active', t.dataset.cat === cp);
    });
  }
  if (qp || cp) run();

  // #5 — Initial clear button state
  updateClearBtn();

  // #3 — Tab keyboard navigation (left/right arrows)
  const tabsContainer = document.getElementById('tabs');
  if (tabsContainer) {
    tabsContainer.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
      const focusedTab = document.activeElement as HTMLElement;
      if (!focusedTab || !focusedTab.classList.contains('tab')) return;
      const idx = tabs.indexOf(focusedTab);
      if (idx < 0) return;
      e.preventDefault();
      const next = e.key === 'ArrowRight'
        ? tabs[(idx + 1) % tabs.length]
        : tabs[(idx - 1 + tabs.length) % tabs.length];
      next?.focus();
    });
  }

  // #2 — Hover description tooltip (desktop only, 500ms delay)
  if (window.matchMedia('(hover: hover)').matches && tableBody) {
    let tooltipEl: HTMLElement | null = null;
    let hoverTimer = 0;
    const removeTooltip = () => {
      clearTimeout(hoverTimer);
      if (tooltipEl) { tooltipEl.remove(); tooltipEl = null; }
    };
    tableBody.addEventListener('mouseover', (e) => {
      const row = (e.target as HTMLElement).closest('.row') as HTMLElement | null;
      if (!row) { removeTooltip(); return; }
      const desc = row.dataset.desc || '';
      if (desc.length < 10) { removeTooltip(); return; }
      clearTimeout(hoverTimer);
      hoverTimer = window.setTimeout(() => {
        removeTooltip();
        const rect = row.getBoundingClientRect();
        tooltipEl = document.createElement('div');
        tooltipEl.className = 'catalog-tooltip';
        tooltipEl.textContent = desc.length > 200 ? desc.slice(0, 200) + '...' : desc;
        tooltipEl.style.left = rect.left + 90 + 'px';
        tooltipEl.style.top = rect.bottom + 4 + 'px';
        document.body.appendChild(tooltipEl);
      }, 500);
    });
    tableBody.addEventListener('mouseout', (e) => {
      const row = (e.target as HTMLElement).closest('.row');
      if (!row) removeTooltip();
    });
    tableBody.addEventListener('mouseleave', removeTooltip);
  }
}

initCatalog();
document.addEventListener('astro:page-load', initCatalog);
</script>
