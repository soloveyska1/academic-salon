---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const total = D.length;
const year = String(new Date().getFullYear());
const BATCH = 30;

const categories = [...new Set(D.map((d: any) => d.category).filter(Boolean))].sort();

const shortType: Record<string, string> = {
  'Самостоятельная работа': 'Самост.',
  'Выпускная квалификационная работа': 'ВКР',
  'Экзаменационные материалы': 'Экзамен',
  'Контрольная работа': 'Контрольная',
  'Курсовая работа': 'Курсовая',
  'Отчет по практике': 'Практика',
  'Отчет о научно-практической работе': 'НПР',
  'Справочный материал': 'Справочник',
  'Нормативный документ': 'Норматив',
  'Учебный документ': 'Учебный',
  'Шаблон документа': 'Шаблон',
  'Аналитический документ': 'Аналитика',
  'Практическое задание': 'Практич.',
  'Методические материалы': 'Методичка',
  'Учебная работа': 'Учебная',
  'Учебный материал': 'Учебный',
};

const catBorder: Record<string, string> = {
  'ВКР и дипломы': 'gold',
  'Курсовые': 'blue',
  'Рефераты': 'purple',
  'Эссе': 'purple',
  'Отчёты по практике': 'green',
  'НПР': 'blue',
  'Конспекты лекций': 'green',
};

function getYear(doc: any) {
  const s = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const m = s.match(/(?:19|20)\d{2}/);
  return m ? m[0] : year;
}
---

<Base title="Каталог — Библиотека академического салона" currentPath="/catalog">

  <div class="page">
    <!-- Header line -->
    <div class="hdr">
      <h1 class="hdr-t">Каталог</h1>
      <span class="hdr-n" id="cnt">{total}</span>
    </div>

    <!-- Toolbar (NOT sticky — scrolls with page) -->
    <div class="bar">
      <div class="bar-q">
        <input type="text" id="q" placeholder="Поиск..." autocomplete="off" />
        <kbd id="hint">/</kbd>
      </div>
      <select class="bar-sel" id="cat">
        <option value="all">Все категории</option>
        {categories.map(c => <option value={c}>{c}</option>)}
      </select>
      <select class="bar-sel" id="sort">
        <option value="default">По умолчанию</option>
        <option value="az">А — Я</option>
        <option value="za">Я — А</option>
        <option value="size">По размеру</option>
      </select>
      <div class="bar-v">
        <button class="vb active" data-v="grid" aria-label="Сетка">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="1" y="1" width="6" height="6"/><rect x="11" y="1" width="6" height="6"/><rect x="1" y="11" width="6" height="6"/><rect x="11" y="11" width="6" height="6"/></svg>
        </button>
        <button class="vb" data-v="list" aria-label="Список">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.3"><line x1="1" y1="3.5" x2="17" y2="3.5"/><line x1="1" y1="9" x2="17" y2="9"/><line x1="1" y1="14.5" x2="17" y2="14.5"/></svg>
        </button>
      </div>
    </div>

    <!-- Cards -->
    <div class="g" id="g" data-v="grid">
      {D.map((doc: any, i: number) => {
        const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
        const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
        const rawType = doc.docType || doc.category || '';
        const type = shortType[rawType] || rawType;
        const subj = doc.subject || '';
        const yr = getYear(doc);
        const left = [subj, yr].filter(Boolean).join(' · ');
        const right = [ext, doc.size].filter(Boolean).join(' · ');
        const clr = catBorder[doc.category] || '';
        return (
          <a
            href={`/doc/${doc.file}`}
            class="c"
            data-clr={clr}
            data-t={title.toLowerCase()}
            data-d={(doc.catalogDescription || doc.description || '').toLowerCase()}
            data-c={doc.category || ''}
            data-s={subj.toLowerCase()}
            data-k={(doc.course || '').toLowerCase()}
            data-g={(doc.tags || []).join(' ').toLowerCase()}
            data-z={doc.size || ''}
            data-i={i}
          >
            <span class="c-type">{type}</span>
            <h3 class="c-name">{title}</h3>
            <div class="c-bot">
              <span class="c-left">{left}</span>
              <span class="c-right">{right}</span>
            </div>
          </a>
        );
      })}
    </div>

    <!-- Load more -->
    <div class="more" id="more">
      <button id="moreBtn"><em>Ещё</em></button>
    </div>

    <!-- Empty -->
    <div class="nil" id="nil" style="display:none">
      <p class="nil-t">Ничего не найдено</p>
      <button class="nil-btn" id="resetBtn">Сбросить</button>
    </div>

    <!-- Closing -->
    <div class="end">
      <p class="end-t">Не нашли нужную работу?</p>
      <div class="end-actions">
        <a href="/order" class="end-btn">Заказать</a>
        <a href="#share-work" class="end-btn end-btn--ghost">Поделиться своей</a>
      </div>
    </div>

    <section class="share" id="share-work">
      <div class="share-head">
        <div>
          <p class="share-kicker">Библиотека растёт вместе с вами</p>
          <h2 class="share-title">Отправьте свою работу на модерацию</h2>
        </div>
        <p class="share-lead">
          Если у вас есть полезная работа, методичка или материал по психологии, социальной работе и смежным дисциплинам,
          отправьте файл через форму. Мы проверим его, отсмотрим в Telegram и решим, добавлять ли в каталог.
        </p>
      </div>

      <div class="share-shell">
        <form class="share-form" id="shareForm" enctype="multipart/form-data">
          <div class="share-grid">
            <div class="share-field">
              <label for="shareTitle">Название работы <span class="req">*</span></label>
              <input type="text" id="shareTitle" name="title" placeholder="Например, Курсовая по возрастной психологии" required />
            </div>
            <div class="share-field">
              <label for="shareContact">Куда ответить <span class="req">*</span></label>
              <input type="text" id="shareContact" name="contact" placeholder="Telegram, VK, почта или телефон" required />
            </div>
            <div class="share-field">
              <label for="shareSubject">Предмет</label>
              <input type="text" id="shareSubject" name="subject" placeholder="Психология, социальная работа, конфликтология..." />
            </div>
            <div class="share-field">
              <label for="shareCategory">Категория</label>
              <select id="shareCategory" name="category">
                <option value="Другое">Другое</option>
                {categories.map((c) => <option value={c}>{c}</option>)}
              </select>
            </div>
            <div class="share-field">
              <label for="shareDocType">Тип документа</label>
              <input type="text" id="shareDocType" name="docType" placeholder="Курсовая, реферат, методичка, практика..." />
            </div>
            <div class="share-field">
              <label for="shareCourse">Курс / программа</label>
              <input type="text" id="shareCourse" name="course" placeholder="Например, 3 курс или магистратура" />
            </div>
            <div class="share-field">
              <label for="shareName">Как вас подписать</label>
              <input type="text" id="shareName" name="authorName" placeholder="Имя, инициалы или псевдоним" />
            </div>
            <div class="share-field">
              <label for="shareTags">Теги</label>
              <input type="text" id="shareTags" name="tags" placeholder="Через запятую: СПбГИПСР, практика, ВКР..." />
            </div>
          </div>

          <div class="share-field">
            <label for="shareDescription">Описание</label>
            <textarea id="shareDescription" name="description" rows="4" placeholder="Что это за работа, для какой дисциплины, чем может быть полезна другим студентам"></textarea>
          </div>

          <div class="share-field">
            <label for="shareComment">Комментарий для модерации</label>
            <textarea id="shareComment" name="comment" rows="3" placeholder="Например, можно ли публиковать под вашим именем, есть ли ограничения, что важно учесть"></textarea>
          </div>

          <div class="share-field share-field--upload">
            <label for="shareFiles">Файлы <span class="req">*</span></label>
            <div class="share-upload">
              <input
                type="file"
                id="shareFiles"
                name="files"
                multiple
                accept=".pdf,.doc,.docx,.odt,.rtf,.txt,.xls,.xlsx,.csv,.ppt,.pptx,.jpg,.jpeg,.png,.webp,.heic,.heif,.zip,.rar,.7z"
                required
              />
              <span class="share-upload-btn">Добавить файлы</span>
              <div class="share-upload-copy">
                <span class="share-upload-title">Работа, титульник, приложения, скриншоты</span>
                <span class="share-upload-meta">До 5 файлов, суммарно до 45 МБ. Перед отправкой файлы проверяются антивирусом.</span>
              </div>
            </div>
            <div class="share-files" id="shareFilesList" aria-live="polite">
              <span class="share-files-empty">Файлы не выбраны</span>
            </div>
          </div>

          <div class="share-actions">
            <button type="submit" class="share-submit" id="shareSubmit">
              <span class="share-submit-text">Отправить в библиотеку</span>
            </button>
            <p class="share-note">Работа не публикуется автоматически. Сначала она попадает в отдельный Telegram topic на проверку.</p>
            <p class="share-progress" id="shareProgress" aria-live="polite"></p>
            <div class="share-meter" id="shareMeter" aria-hidden="true"><span class="share-meter-fill"></span></div>
          </div>
        </form>

        <div class="share-done" id="shareDone" style="display:none">
          <span class="share-done-icon">&#10003;</span>
          <p class="share-done-title">Работа отправлена</p>
          <p class="share-done-text">Мы получили файлы и уже передали их на антивирусную проверку. После этого работа попадёт на модерацию.</p>
        </div>

        <aside class="share-side">
          <div class="share-side-card">
            <span class="share-side-num">01</span>
            <p class="share-side-title">Антивирус до модерации</p>
            <p class="share-side-text">Файлы сначала проходят антивирусную проверку. Заражённое или подозрительное не попадёт в Telegram.</p>
          </div>
          <div class="share-side-card">
            <span class="share-side-num">02</span>
            <p class="share-side-title">Отдельный topic в Telegram</p>
            <p class="share-side-text">Каждая присланная работа создаёт отдельную тему в вашей группе, чтобы материалы не смешивались с заказами.</p>
          </div>
          <div class="share-side-card">
            <span class="share-side-num">03</span>
            <p class="share-side-title">Публикация только после проверки</p>
            <p class="share-side-text">Ничего не добавляется в каталог автоматически. Сначала вы смотрите файл, описание и решаете, пропускать ли дальше.</p>
          </div>
        </aside>
      </div>
    </div>

    <!-- Footer line -->
    <div class="ftr">
      <nav class="ftr-links">
        <a href="/catalog">Каталог</a>
        <a href="/order">Заказать</a>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
      </nav>
      <span class="ftr-copy">© 2022–2026</span>
    </div>
  </div>

</Base>

<style>
  :global(.footer) { display: none; }

  .page {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 48px 48px 0;
  }

  /* ═══════ HEADER ═══════ */
  .hdr {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: 32px;
  }

  .hdr-t {
    font: 300 28px/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  .hdr-n {
    font: 400 14px/1 var(--fm);
    color: var(--t3);
    font-variant-numeric: tabular-nums;
  }

  /* ═══════ TOOLBAR ═══════ */
  .bar {
    display: flex;
    align-items: center;
    gap: 24px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--brd);
  }

  .bar-q {
    flex: 1;
    max-width: 50%;
    position: relative;
  }

  .bar-q input {
    width: 100%;
    padding: 10px 0;
    border: none;
    border-bottom: 1px solid var(--brd);
    background: transparent;
    color: var(--t1);
    font: 400 14px/1.3 var(--fi);
    outline: none;
    transition: border-color .4s cubic-bezier(.25,0,0,1);
  }

  .bar-q input::placeholder { color: var(--t3); }
  .bar-q input:focus { border-bottom-color: rgba(212,175,55,.2); }
  .bar-q input:focus ~ kbd { display: none; }

  .bar-q kbd {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    border: 1px solid var(--brd);
    padding: 2px 6px;
    border-radius: 4px;
    pointer-events: none;
  }

  .bar-sel {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: none;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    cursor: pointer;
    outline: none;
    transition: color .3s cubic-bezier(.25,0,0,1);
  }

  .bar-sel:hover, .bar-sel:focus { color: var(--t1); }
  .bar-sel option { background: var(--bg); color: var(--t1); }

  .bar-v {
    display: flex;
    gap: 4px;
    margin-left: auto;
  }

  .vb {
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--t3);
    cursor: pointer;
    transition: color .3s cubic-bezier(.25,0,0,1);
  }

  .vb:hover { color: var(--t2); }
  .vb.active { color: var(--t1); }

  /* ═══════ GRID VIEW ═══════ */
  .g[data-v="grid"] {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding-top: 32px;
    content-visibility: auto;
    contain-intrinsic-size: auto 2000px;
  }

  .g[data-v="grid"] .c {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 28px 26px;
    background: var(--card);
    border: 1px solid var(--brd);
    border-top: 2px solid rgba(212,175,55,.2);
    border-radius: 2px 2px var(--rx) var(--rx);
    text-decoration: none;
    color: inherit;
    opacity: 0;
    transform: translateY(8px);
    overflow: hidden;
    transition:
      background .4s cubic-bezier(.25,0,0,1),
      border-color .4s cubic-bezier(.25,0,0,1),
      box-shadow .5s cubic-bezier(.25,0,0,1),
      transform .4s cubic-bezier(.25,0,0,1),
      opacity .4s cubic-bezier(.25,0,0,1);
  }

  /* Animated gradient border on hover */
  .g[data-v="grid"] .c::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: conic-gradient(
      from var(--gradient-angle),
      var(--ac) 0%, var(--ac3) 25%,
      var(--ac4) 50%, var(--ac3) 75%, var(--ac) 100%
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: gradient-rotate 4s linear infinite;
    opacity: 0;
    transition: opacity 0.4s var(--ease);
    pointer-events: none;
  }
  .g[data-v="grid"] .c:hover::before {
    opacity: 1;
  }

  .g[data-v="grid"] .c[data-clr="gold"]   { border-top-color: rgba(212,175,55,.35); }
  .g[data-v="grid"] .c[data-clr="blue"]   { border-top-color: rgba(120,160,220,.3); }
  .g[data-v="grid"] .c[data-clr="purple"] { border-top-color: rgba(167,139,250,.25); }
  .g[data-v="grid"] .c[data-clr="green"]  { border-top-color: rgba(52,211,153,.2); }

  .g[data-v="grid"] .c.vis {
    opacity: 1;
    transform: translateY(0);
  }

  .g[data-v="grid"] .c:hover {
    background: var(--card-h);
    border-color: rgba(212,175,55,.18);
    border-top-color: rgba(212,175,55,.5);
    box-shadow: 0 8px 32px rgba(212,175,55,.04);
    transform: translateY(-3px);
  }

  .g[data-v="grid"] .c:hover .c-name { color: var(--ac3); }

  /* ═══════ LIST VIEW ═══════ */
  .g[data-v="list"] {
    display: flex;
    flex-direction: column;
    padding-top: 32px;
    gap: 4px;
  }

  .g[data-v="list"] .c {
    display: grid;
    grid-template-columns: 100px 1fr auto auto;
    align-items: center;
    gap: 20px;
    padding: 16px 20px;
    border: 1px solid transparent;
    border-radius: var(--rx);
    text-decoration: none;
    color: inherit;
    transition:
      background .4s cubic-bezier(.25,0,0,1),
      border-color .4s cubic-bezier(.25,0,0,1),
      box-shadow .4s cubic-bezier(.25,0,0,1);
  }

  .g[data-v="list"] .c:hover {
    background: var(--card);
    border-color: var(--brd);
    box-shadow: 0 4px 16px rgba(0,0,0,.15);
  }

  .g[data-v="list"] .c:hover .c-name { color: var(--ac3); }

  .g[data-v="list"] .c-type {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .g[data-v="list"] .c-name {
    font: 400 14px/1.4 var(--fi);
    -webkit-line-clamp: 1;
  }

  .g[data-v="list"] .c-bot { display: contents; }
  .g[data-v="list"] .c-left { text-align: right; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .g[data-v="list"] .c-right { text-align: right; white-space: nowrap; }

  /* ═══════ SEARCH HIGHLIGHT ═══════ */
  .hl {
    background: rgba(212,175,55,.2);
    color: var(--ac3);
    border-radius: 2px;
    padding: 0 2px;
  }

  /* ═══════ TILT ═══════ */
  .g[data-v="grid"] .c {
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* ═══════ SHARED CARD ═══════ */
  .c.hid { display: none !important; }

  .c-type {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--t3);
  }

  .c-name {
    font: 400 19px/1.4 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .c-bot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-top: auto;
    padding-top: 8px;
    border-top: 1px solid var(--brd);
  }

  .c-left {
    font: 400 11px/1.3 var(--fi);
    color: var(--t3);
  }

  .c-right {
    font: 400 11px/1 var(--fm);
    color: var(--t3);
    opacity: .5;
    flex-shrink: 0;
  }

  /* ═══════ MORE / EMPTY / CLOSING ═══════ */
  .more {
    text-align: center;
    padding: 48px 0;
  }

  .more button {
    background: none;
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    padding: 14px 56px;
    cursor: pointer;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    transition: border-color .4s cubic-bezier(.25,0,0,1), color .4s cubic-bezier(.25,0,0,1);
  }

  .more button em {
    font-style: normal;
  }

  .more button:hover { border-color: var(--brd-h); color: var(--t1); }

  .nil {
    text-align: center;
    padding: 96px 24px;
  }

  .nil-t {
    font: 300 22px/1.3 var(--fd);
    color: var(--t2);
  }

  .nil-btn {
    margin-top: 20px;
    background: none;
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    padding: 10px 32px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    cursor: pointer;
    transition: color .4s cubic-bezier(.25,0,0,1), border-color .4s cubic-bezier(.25,0,0,1);
  }

  .nil-btn:hover { color: var(--t1); border-color: var(--brd-h); }

  .end {
    text-align: center;
    padding: 80px 24px 0;
  }

  .end-t {
    font: 300 24px/1.3 var(--fd);
    color: var(--t2);
  }

  .end-btn {
    display: inline-block;
    margin-top: 24px;
    padding: 14px 48px;
    border: 1px solid rgba(212,175,55,.2);
    border-radius: var(--rx);
