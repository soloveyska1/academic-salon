---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';


const total = D.length;
const year = String(new Date().getFullYear());
const BATCH = 30;

const categories = [...new Set(D.map((d: any) => d.category).filter(Boolean))].sort();

/* Document type chips with counts */
const typeCount = new Map<string, number>();
for (const doc of D) {
  const t = (doc as any).category || '';
  if (t) typeCount.set(t, (typeCount.get(t) || 0) + 1);
}
const typeChips = [...typeCount.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8);

/* Subject list for autocomplete */
const subjects = [...new Set(D.map((d: any) => d.subject).filter(Boolean))].sort();

/* Popular search terms from titles */
const popularTerms = [...new Set(
  D.slice(0, 50).map((d: any) => (d as any).subject).filter(Boolean)
)].slice(0, 6);

const shortType: Record<string, string> = {
  'Самостоятельная работа': 'Самост.',
  'Выпускная квалификационная работа': 'ВКР',
  'Экзаменационные материалы': 'Экзамен',
  'Контрольная работа': 'Контрольная',
  'Курсовая работа': 'Курсовая',
  'Отчет по практике': 'Практика',
  'Отчет о научно-практической работе': 'НПР',
  'Справочный материал': 'Справочник',
  'Нормативный документ': 'Норматив',
  'Учебный документ': 'Учебный',
  'Шаблон документа': 'Шаблон',
  'Аналитический документ': 'Аналитика',
  'Практическое задание': 'Практич.',
  'Методические материалы': 'Методичка',
  'Учебная работа': 'Учебная',
  'Учебный материал': 'Учебный',
};

const catBorder: Record<string, string> = {
  'ВКР и дипломы': 'gold',
  'Курсовые': 'blue',
  'Рефераты': 'purple',
  'Эссе': 'purple',
  'Отчёты по практике': 'green',
  'НПР': 'blue',
  'Конспекты лекций': 'green',
};

function getYear(doc: any) {
  const s = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const m = s.match(/(?:19|20)\d{2}/);
  return m ? m[0] : year;
}
---

<Base title="Каталог — Библиотека академического салона" currentPath="/catalog">

  <div class="page">
    <!-- Header line -->
    <div class="hdr">
      <h1 class="hdr-t">Каталог</h1>
      <span class="hdr-n" id="cnt">{total}</span>
    </div>

    <!-- Toolbar (NOT sticky — scrolls with page) -->
    <div class="bar">
      <div class="bar-q">
        <input type="search" id="q" placeholder="Поиск..." autocomplete="off" inputmode="search" enterkeyhint="search" autocorrect="off" spellcheck="false" />
        <kbd id="hint">/</kbd>
      </div>
      <button class="bar-fav" id="favFilter" type="button" aria-label="Показать избранное" title="Избранное">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </button>
      <select class="bar-sel" id="cat">
        <option value="all">Все категории</option>
        {categories.map(c => <option value={c}>{c}</option>)}
      </select>
      <select class="bar-sel" id="sort">
        <option value="default">По умолчанию</option>
        <option value="az">А — Я</option>
        <option value="za">Я — А</option>
        <option value="size">По размеру</option>
      </select>
      <div class="bar-v">
        <button class="vb active" data-v="grid" aria-label="Сетка">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="1" y="1" width="6" height="6"/><rect x="11" y="1" width="6" height="6"/><rect x="1" y="11" width="6" height="6"/><rect x="11" y="11" width="6" height="6"/></svg>
        </button>
        <button class="vb" data-v="list" aria-label="Список">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.3"><line x1="1" y1="3.5" x2="17" y2="3.5"/><line x1="1" y1="9" x2="17" y2="9"/><line x1="1" y1="14.5" x2="17" y2="14.5"/></svg>
        </button>
      </div>
    </div>

    <!-- Type filter chips -->
    <div class="type-chips" id="typeChips">
      <button class="type-chip active" data-type="all">Все <span class="type-count">{total}</span></button>
      {typeChips.map(([name, count]) => (
        <button class="type-chip" data-type={name}>{name} <span class="type-count">{count}</span></button>
      ))}
    </div>

    <!-- Search suggestions (popular tags only — clean, no messy autocomplete) -->
    <div class="ac-dropdown" id="acDropdown" style="display:none">
      <div class="ac-popular" id="acPopular">
        <span class="ac-label">Популярные предметы</span>
        {popularTerms.map(t => (
          <button class="ac-tag" data-term={t}>{t}</button>
        ))}
      </div>
    </div>

    <!-- Smart recommendations (filled by JS) -->
    <div class="recs" id="recsSection" style="display:none">
      <div class="recs-header">
        <h3 class="recs-title">Для вас</h3>
        <span class="recs-badge" id="recsBadge"></span>
      </div>
      <div class="recs-list" id="recsList"></div>
    </div>

    <!-- Recently viewed (filled by JS from localStorage) -->
    <div class="recent" id="recentSection" style="display:none">
      <h3 class="recent-title">Недавно просмотренные</h3>
      <div class="recent-list" id="recentList"></div>
    </div>

    <!-- Subject data for autocomplete -->
    <script id="subjectData" type="application/json" set:html={JSON.stringify(subjects)}></script>

    <!-- Cards -->
    <div class="g" id="g" data-v="grid">
      {D.map((doc: any, i: number) => {
        const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
        const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
        const rawType = doc.docType || doc.category || '';
        const type = shortType[rawType] || rawType;
        const subj = doc.subject || '';
        const yr = getYear(doc);
        const left = [subj, yr].filter(Boolean).join(' · ');
        const right = [ext, doc.size].filter(Boolean).join(' · ');
        const clr = catBorder[doc.category] || '';
        return (
          <a
            href={`/doc/${doc.file}`}
            class="c"
            data-clr={clr}
            data-t={title.toLowerCase()}
            data-d={(doc.catalogDescription || doc.description || '').toLowerCase()}
            data-c={doc.category || ''}
            data-s={subj.toLowerCase()}
            data-k={(doc.course || '').toLowerCase()}
            data-g={(doc.tags || []).join(' ').toLowerCase()}
            data-z={doc.size || ''}
            data-i={i}
            data-file={doc.file}
            data-desc={doc.catalogDescription || doc.description || ''}
          >
            <span class="c-type">{type}</span>
            <h3 class="c-name">{title}</h3>
            <div class="c-bot">
              <span class="c-left">{left}</span>
              <span class="c-views" data-views></span>
              <span class="c-right">{right}</span>
            </div>
          </a>
        );
      })}
    </div>

    <!-- Quick Preview Modal (long-press on card) -->
    <div class="peek" id="peek" aria-hidden="true">
      <div class="peek-backdrop" id="peekBackdrop"></div>
      <div class="peek-card" id="peekCard">
        <div class="peek-handle"><span></span></div>
        <span class="peek-type" id="peekType"></span>
        <h3 class="peek-title" id="peekTitle"></h3>
        <p class="peek-desc" id="peekDesc"></p>
        <div class="peek-meta" id="peekMeta"></div>
        <div class="peek-actions">
          <a class="peek-btn peek-btn--primary" id="peekOpen" href="#">Открыть</a>
          <a class="peek-btn peek-btn--order" href="/order">Заказать похожую</a>
        </div>
      </div>
    </div>

    <!-- Load more (auto via IntersectionObserver, button as fallback) -->
    <div class="more" id="more">
      <div class="more-spinner" aria-hidden="true"></div>
      <button id="moreBtn"><em>Ещё</em></button>
    </div>

    <!-- Empty -->
    <div class="nil" id="nil" style="display:none">
      <p class="nil-t">Ничего не найдено</p>
      <button class="nil-btn" id="resetBtn">Сбросить</button>
    </div>

    <!-- Closing -->
    <div class="end">
      <p class="end-t">Не нашли нужную работу?</p>
      <div class="end-actions">
        <a href="/order" class="end-btn">Заказать</a>
        <a href="/contribute" class="end-btn end-btn--ghost">Поделиться своей</a>
      </div>
    </div>

    <!-- Footer line -->
    <div class="ftr">
      <nav class="ftr-links">
        <a href="/catalog">Каталог</a>
        <a href="/order">Заказать</a>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
      </nav>
      <span class="ftr-copy">© 2022–2026</span>
    </div>
  </div>

</Base>

<style>
  :global(.footer) { display: none; }

  .page {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 48px 48px 0;
  }

  /* ═══════ HEADER ═══════ */
  .hdr {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: 32px;
  }

  .hdr-t {
    font: 300 28px/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  .hdr-n {
    font: 400 14px/1 var(--fm);
    color: var(--t3);
    font-variant-numeric: tabular-nums;
  }

  /* ═══════ TOOLBAR ═══════ */
  .bar {
    display: flex;
    align-items: center;
    gap: 24px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--brd);
  }

  .bar-q {
    flex: 1;
    max-width: 50%;
    position: relative;
  }

  .bar-q input {
    width: 100%;
    padding: 10px 0;
    border: none;
    border-bottom: 1px solid var(--brd);
    background: transparent;
    color: var(--t1);
    font: 400 14px/1.3 var(--fi);
    outline: none;
    transition: border-color var(--dur-slow) var(--ease);
  }

  .bar-q input::placeholder { color: var(--t3); }
  .bar-q input:focus { border-bottom-color: var(--ac-b); }
  .bar-q input:focus ~ kbd { display: none; }

  .bar-q kbd {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    border: 1px solid var(--brd);
    padding: 2px 6px;
    border-radius: 4px;
    pointer-events: none;
  }

  .bar-fav {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    background: none;
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    color: var(--t3);
    cursor: pointer;
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease);
    flex-shrink: 0;
  }
  .bar-fav:hover { color: var(--ac); border-color: var(--brd-h); }
  .bar-fav.active { color: var(--ac); border-color: var(--ac-b); }
  .bar-fav.active svg { fill: var(--ac); }

  .bar-sel {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: none;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    cursor: pointer;
    outline: none;
    transition: color var(--dur) var(--ease);
  }

  .bar-sel:hover, .bar-sel:focus { color: var(--t1); }
  .bar-sel option { background: var(--bg); color: var(--t1); }

  .bar-v {
    display: flex;
    gap: 4px;
    margin-left: auto;
  }

  .vb {
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--t3);
    cursor: pointer;
    transition: color var(--dur) var(--ease);
  }

  .vb:hover { color: var(--t2); }
  .vb.active { color: var(--t1); }

  /* ═══════ GRID VIEW ═══════ */
  .g[data-v="grid"] {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding-top: 32px;
    content-visibility: auto;
    contain-intrinsic-size: auto 2000px;
  }

  .g[data-v="grid"] .c {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px;
    background: var(--card);
    border: 1px solid var(--brd);
    border-top: 2px solid var(--ac-b);
    border-radius: var(--rm);
    text-decoration: none;
    color: inherit;
    opacity: 0;
    transform: translateY(8px);
    overflow: hidden;
    transition:
      background var(--dur-slow) var(--ease),
      border-color var(--dur-slow) var(--ease),
      box-shadow var(--dur-slow) var(--ease),
      transform var(--dur-slow) var(--ease),
      opacity var(--dur-slow) var(--ease);
  }

  /* Animated gradient border on hover */
  .g[data-v="grid"] .c::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: conic-gradient(
      from var(--gradient-angle),
      var(--ac) 0%, var(--ac3) 25%,
      var(--ac4) 50%, var(--ac3) 75%, var(--ac) 100%
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: gradient-rotate 4s linear infinite;
    opacity: 0;
    transition: opacity 0.4s var(--ease);
    pointer-events: none;
  }
  .g[data-v="grid"] .c:hover::before {
    opacity: 1;
  }

  .g[data-v="grid"] .c[data-clr="gold"]   { border-top-color: var(--ac-b2); }
  .g[data-v="grid"] .c[data-clr="blue"]   { border-top-color: rgba(120,160,220,.3); }
  .g[data-v="grid"] .c[data-clr="purple"] { border-top-color: rgba(167,139,250,.25); }
  .g[data-v="grid"] .c[data-clr="green"]  { border-top-color: rgba(52,211,153,.2); }

  .g[data-v="grid"] .c.vis {
    opacity: 1;
    transform: translateY(0);
  }

  .g[data-v="grid"] .c:hover {
    background: var(--card-h);
    border-color: var(--ac-glow);
    border-top-color: var(--ac-b3);
    box-shadow: 0 8px 32px var(--ac-t);
    transform: translateY(-3px);
  }

  .g[data-v="grid"] .c:hover .c-name { color: var(--ac3); }

  /* ═══════ LIST VIEW ═══════ */
  .g[data-v="list"] {
    display: flex;
    flex-direction: column;
    padding-top: 32px;
    gap: 4px;
  }

  .g[data-v="list"] .c {
    display: grid;
    grid-template-columns: 100px 1fr auto auto;
    align-items: center;
    gap: 20px;
    padding: 16px 20px;
    border: 1px solid transparent;
    border-radius: var(--rx);
    text-decoration: none;
    color: inherit;
    transition:
      background var(--dur-slow) var(--ease),
      border-color var(--dur-slow) var(--ease),
      box-shadow var(--dur-slow) var(--ease);
  }

  .g[data-v="list"] .c:hover {
    background: var(--card);
    border-color: var(--brd);
    box-shadow: 0 4px 16px var(--ac-sh);
  }

  .g[data-v="list"] .c:hover .c-name { color: var(--ac3); }

  .g[data-v="list"] .c-type {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .g[data-v="list"] .c-name {
    font: 400 14px/1.4 var(--fi);
    -webkit-line-clamp: 1;
  }

  .g[data-v="list"] .c-bot { display: contents; }
  .g[data-v="list"] .c-left { text-align: right; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .g[data-v="list"] .c-right { text-align: right; white-space: nowrap; }

  /* ═══════ SEARCH HIGHLIGHT ═══════ */
  .hl {
    background: rgba(212,175,55,.2);
    color: var(--ac2);
    border-radius: 4px;
    padding: 1px 4px;
  }
  :global([data-theme="light"]) .hl {
    background: rgba(180,140,20,.12);
    color: #8b6914;
  }

  /* ═══════ TILT ═══════ */
  .g[data-v="grid"] .c {
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* ═══════ SHARED CARD ═══════ */
  .c.hid { display: none !important; }

  .c-type {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--t3);
  }

  .c-name {
    font: 400 19px/1.4 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--dur-slow) var(--ease);
  }

  .c-bot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-top: auto;
    padding-top: 8px;
    border-top: 1px solid var(--brd);
  }

  .c-left {
    font: 400 11px/1.3 var(--fi);
    color: var(--t3);
  }

  .c-right {
    font: 400 11px/1 var(--fm);
    color: var(--t3);
    opacity: .5;
    flex-shrink: 0;
  }

  /* ═══════ MORE / EMPTY / CLOSING ═══════ */
  .more {
    text-align: center;
    padding: 48px 0;
  }

  .more-spinner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--brd);
    border-top-color: var(--ac-b3);
    border-radius: 50%;
    animation: more-spin .7s linear infinite;
    margin: 0 auto 16px;
  }
  @keyframes more-spin { to { transform: rotate(360deg); } }

  .more button {
    background: none;
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    padding: 16px 48px;
    cursor: pointer;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    transition: border-color var(--dur-slow) var(--ease), color var(--dur-slow) var(--ease);
  }

  .more button em {
    font-style: normal;
  }

  .more button:hover { border-color: var(--brd-h); color: var(--t1); }

  .nil {
    text-align: center;
    padding: 96px 24px;
  }

  .nil-t {
    font: 300 22px/1.3 var(--fd);
    color: var(--t2);
  }

  .nil-btn {
    margin-top: 20px;
    background: none;
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    padding: 10px 32px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    cursor: pointer;
    transition: color var(--dur-slow) var(--ease), border-color var(--dur-slow) var(--ease);
  }

  .nil-btn:hover { color: var(--t1); border-color: var(--brd-h); }

  .end {
    text-align: center;
    padding: 80px 24px 0;
  }

  .end-t {
    font: 300 24px/1.3 var(--fd);
    color: var(--t2);
  }

  .end-btn {
    display: inline-block;
    margin-top: 24px;
    padding: 14px 48px;
    border: 1px solid var(--ac-b);
    border-radius: var(--rx);
    background: var(--surf);
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t1);
    text-decoration: none;
    transition: all var(--dur-slow) var(--ease);
  }

  .end-btn:hover {
    background: var(--surf-h);
    border-color: var(--ac-b2);
    box-shadow: 0 8px 32px var(--ac-sh);
    transform: translateY(-2px);
  }

  .end-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 24px;
  }

  .end-btn--ghost {
    background: transparent;
    color: var(--t2);
    border-color: var(--brd);
  }

  .end-btn--ghost:hover {
    color: var(--t1);
    border-color: var(--ac-b2);
    box-shadow: none;
  }

  .share {
    margin-top: 72px;
    padding: 40px 0 0;
    border-top: 1px solid var(--brd);
  }

  .share-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 440px);
    gap: 32px;
    align-items: end;
  }

  .share-kicker {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .16em;
    color: var(--ac);
    opacity: .72;
  }

  .share-title {
    margin-top: 12px;
    font: 300 clamp(28px, 4vw, 40px)/1.05 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
  }

  .share-lead {
    font: 400 14px/1.7 var(--fi);
    color: var(--t2);
  }

  .share-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(260px, .8fr);
    gap: 28px;
    margin-top: 32px;
    align-items: start;
  }

  .share-form,
  .share-done {
    padding: 28px;
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    background:
      radial-gradient(circle at top left, var(--ac-g), transparent 42%),
      var(--surf);
    box-shadow: 0 20px 80px rgba(0,0,0,.16);
  }

  .share-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px 20px;
  }

  .share-field {
    margin-top: 18px;
  }

  .share-field:first-child,
  .share-grid .share-field {
    margin-top: 0;
  }

  .share-field label {
    display: block;
    margin-bottom: 10px;
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--t3);
  }

  .share-field input,
  .share-field select,
  .share-field textarea {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid var(--brd);
    border-radius: var(--rs);
    background: var(--surf);
    color: var(--t1);
    font: 400 14px/1.5 var(--fi);
    outline: none;
    transition:
      border-color var(--dur) var(--ease),
      background var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }

  .share-field input::placeholder,
  .share-field textarea::placeholder {
    color: var(--t3);
  }

  .share-field input:focus,
  .share-field select:focus,
  .share-field textarea:focus {
    border-color: var(--ac-b2);
    background: var(--surf);
    transform: translateY(-1px);
  }

  .share-field textarea {
    resize: vertical;
    min-height: 110px;
  }

  .req {
    color: var(--ac);
    opacity: .7;
  }

  .share-field--upload {
    margin-top: 22px;
  }

  .share-upload {
    position: relative;
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 18px 20px;
    border: 1px solid var(--brd);
    border-radius: var(--rm);
    background: var(--surf);
    overflow: hidden;
    transition:
      border-color var(--dur) var(--ease),
      background var(--dur) var(--ease);
  }

  .share-upload:hover,
  .share-upload:focus-within {
    border-color: var(--ac-b2);
    background: var(--surf);
  }

  .share-upload input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }

  .share-upload-btn {
    flex-shrink: 0;
    padding: 12px 18px;
    border: 1px solid var(--ac-b);
    border-radius: 999px;
    color: var(--t1);
    background: var(--surf);
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
  }

  .share-upload-copy {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .share-upload-title {
    color: var(--t1);
    font: 400 14px/1.4 var(--fi);
  }

  .share-upload-meta {
    color: var(--t3);
    font: 400 11px/1.5 var(--fi);
  }

  .share-files {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }

  .share-files-empty {
    color: var(--t3);
    font: 400 11px/1.4 var(--fi);
  }

  .share-file,
  .share-file-total {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border: 1px solid var(--brd);
    border-radius: 999px;
    background: var(--surf);
    color: var(--t2);
    font: 400 11px/1.3 var(--fi);
  }

  .share-file strong {
    color: var(--t1);
    font-weight: 400;
  }

  .share-actions {
    margin-top: 24px;
  }

  .share-submit {
    width: 100%;
    padding: 18px 24px;
    border: 1px solid var(--ac-b);
    border-radius: var(--rm);
    background: var(--surf-h);
    color: var(--t1);
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    cursor: pointer;
    transition:
      transform var(--dur) var(--ease),
      border-color var(--dur) var(--ease),
      background var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }

  .share-submit:hover {
    transform: translateY(-2px);
    border-color: var(--ac-b2);
    background: var(--surf-h);
    box-shadow: 0 12px 40px var(--ac-g);
  }

  .share-submit.is-loading {
    cursor: progress;
    opacity: .78;
    transform: none;
  }

  .share-note {
    margin-top: 12px;
    font: 400 11px/1.6 var(--fi);
    color: var(--t3);
  }

  .share-progress {
    min-height: 20px;
    margin-top: 12px;
    color: var(--t3);
    font: 400 12px/1.6 var(--fi);
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }

  .share-progress::before {
    content: '';
    display: inline-block;
    width: 7px;
    height: 7px;
    margin-right: 8px;
    border-radius: 999px;
    background: var(--ac-b3);
    opacity: 0;
    vertical-align: middle;
  }

  .share-progress.is-active {
    opacity: 1;
    color: var(--t2);
  }

  .share-progress.is-active::before {
    opacity: 1;
    animation: shareProgressPulse 1.1s var(--ease) infinite;
  }

  .share-meter {
    position: relative;
    height: 2px;
    width: min(420px, 100%);
    margin-top: 10px;
    border-radius: 999px;
    background: var(--ac-g);
    overflow: hidden;
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease);
  }

  .share-meter.is-active {
    opacity: 1;
  }

  .share-meter-fill {
    display: block;
    width: 100%;
    height: 100%;
    transform-origin: left center;
    transform: scaleX(0);
    background: linear-gradient(90deg, var(--ac-b3) 0%, var(--ac) 100%);
    transition: transform .18s linear;
  }

  @keyframes shareProgressPulse {
    0%, 100% { transform: scale(1); opacity: .45; }
    50% { transform: scale(1.45); opacity: 1; }
  }

  .share-done {
    text-align: center;
  }

  .share-done-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 54px;
    height: 54px;
    border-radius: 50%;
    border: 1px solid var(--ac-b);
    color: var(--ac);
    font-size: 24px;
  }

  .share-done-title {
    margin-top: 18px;
    font: 300 28px/1.2 var(--fd);
    color: var(--t1);
  }

  .share-done-text {
    margin-top: 10px;
    color: var(--t2);
    font: 400 14px/1.7 var(--fi);
  }

  .share-side {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .share-side-card {
    position: relative;
    padding: 22px 20px 20px;
    border: 1px solid var(--brd);
    border-radius: var(--r);
    background: var(--surf);
  }

  .share-side-num {
    font: 300 34px/1 var(--fm);
    color: var(--ac);
    opacity: .22;
  }

  .share-side-title {
    margin-top: 16px;
    color: var(--t1);
    font: 400 15px/1.4 var(--fd);
  }

  .share-side-text {
    margin-top: 8px;
    color: var(--t3);
    font: 400 12px/1.7 var(--fi);
  }

  /* ═══════ FOOTER LINE ═══════ */
  .ftr {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 64px 0 48px;
    border-top: 1px solid var(--brd);
    margin-top: 64px;
  }

  .ftr-links {
    display: flex;
    gap: 24px;
  }

  .ftr-links a {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    transition: color var(--dur-slow) var(--ease);
  }

  .ftr-links a:hover { color: var(--t1); }

  .ftr-copy {
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    opacity: .4;
    letter-spacing: .1em;
  }

  /* ═══════ TABLET ═══════ */
  @media (max-width: 1024px) {
    .g[data-v="grid"] { grid-template-columns: repeat(2, 1fr); }
    .g[data-v="list"] .c { grid-template-columns: 90px 1fr auto; }
    .g[data-v="list"] .c-left { display: none; }
    .share-head,
    .share-shell { grid-template-columns: 1fr; }
  }

  /* ═══════ SKELETON LOADING ═══════ */
  @keyframes skeleton-pulse {
    0%, 100% { opacity: 0.04; }
    50% { opacity: 0.08; }
  }

  .g[data-v="grid"] .c:not(.vis) .c-type,
  .g[data-v="grid"] .c:not(.vis) .c-name,
  .g[data-v="grid"] .c:not(.vis) .c-bot {
    color: transparent;
    background: var(--brd);
    border-radius: 4px;
    animation: skeleton-pulse 1.5s var(--ease) infinite;
  }

  .g[data-v="grid"] .c:not(.vis) .c-name {
    min-height: 2.8em;
  }

  /* ═══════ LIGHT THEME ═══════ */
  :global([data-theme="light"]) .page {
    color: var(--t1);
  }

  :global([data-theme="light"]) .g[data-v="grid"] .c {
    background: #ffffff;
    border-color: rgba(26,24,20, 0.08);
    box-shadow: 0 1px 3px rgba(60,48,20, 0.04), 0 2px 8px rgba(60,48,20, 0.04);
  }

  :global([data-theme="light"]) .g[data-v="grid"] .c:hover {
    background: #ffffff;
    border-color: rgba(122,95,18, 0.15);
    box-shadow: 0 4px 12px rgba(60,48,20, 0.06), 0 8px 24px rgba(60,48,20, 0.08);
  }

  :global([data-theme="light"]) .g[data-v="grid"] .c::before {
    background: conic-gradient(
      from var(--gradient-angle),
      #7a5f12 0%, #9a7b1c 25%,
      #c9a832 50%, #9a7b1c 75%, #7a5f12 100%
    );
  }

  :global([data-theme="light"]) .g[data-v="list"] .c:hover {
    background: rgba(122,95,18, 0.03);
    border-color: rgba(122,95,18, 0.10);
  }

  :global([data-theme="light"]) .bar {
    border-bottom-color: rgba(26,24,20, 0.08);
  }

  :global([data-theme="light"]) .bar-q input {
    border-bottom-color: rgba(26,24,20, 0.12);
  }

  :global([data-theme="light"]) .bar-q input:focus {
    border-bottom-color: rgba(122,95,18, 0.35);
  }

  :global([data-theme="light"]) .end-btn {
    border-color: rgba(122,95,18, 0.20);
  }

  :global([data-theme="light"]) .end-btn:hover {
    background: rgba(122,95,18, 0.04);
    border-color: rgba(122,95,18, 0.35);
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 768px) {
    .page { padding: 16px var(--sp-page, 16px) 0; }

    /* Sticky search bar — always accessible */
    .bar {
      position: sticky;
      top: 56px;
      z-index: 50;
      background: var(--bg);
      padding: 12px 0;
      margin-left: calc(var(--sp-page, 16px) * -1);
      margin-right: calc(var(--sp-page, 16px) * -1);
      padding-left: var(--sp-page, 16px);
      padding-right: var(--sp-page, 16px);
    }
    [data-theme="light"] .bar { background: var(--bg); }

    /* Premium search input */
    .bar-q {
      max-width: 100%;
      flex-basis: 100%;
    }
    .bar-q input {
      min-height: 48px;
      font-size: 16px;
      border-radius: 12px;
      background: rgba(255,255,255,.04);
      border: 1px solid var(--brd);
      padding: 0 16px;
      transition: border-color .2s, background .2s;
    }
    .bar-q input:focus {
      background: rgba(255,255,255,.06);
      border-color: var(--ac-b);
    }
    .bar-q kbd { display: none; }

    .bar-fav { width: 44px; height: 44px; }
    .bar-sel { min-height: 44px; font-size: 14px; padding: 8px 12px; border-radius: 8px; }
    .vb { width: 44px; height: 44px; }
    .bar { flex-wrap: wrap; gap: 8px; }

    /* Cards visible immediately on mobile (no waiting for JS) */
    .g[data-v="grid"] .c,
    .g[data-v="list"] .c {
      opacity: 1 !important;
      transform: none !important;
    }

    /* Premium card styling */
    .g[data-v="grid"] {
      grid-template-columns: 1fr;
      gap: 12px;
    }
    .g[data-v="grid"] .c {
      padding: 16px;
      border-radius: var(--rm);
      border-top-width: 3px;
      box-shadow: 0 2px 8px rgba(0,0,0,.12), inset 0 1px 0 rgba(255,255,255,.03);
    }
    .g[data-v="grid"] .c .c-name {
      font-size: 17px;
      line-height: 1.45;
    }
    .g[data-v="grid"] .c .c-type {
      font-size: 12px;
    }
    .g[data-v="grid"] .c .c-bot {
      font-size: 13px;
    }

    /* Show subject+year in list view (don't hide) */
    .g[data-v="list"] .c {
      grid-template-columns: 1fr auto;
      gap: 8px;
    }
    .g[data-v="list"] .c-type { display: none; }
    .g[data-v="list"] .c-left {
      font-size: var(--fs-xs, 11px);
      opacity: .6;
    }

    .share-grid { grid-template-columns: 1fr; }
    .share-upload { flex-direction: column; align-items: flex-start; }
    .end { padding: 32px 16px 0; }
    .end-t { font-size: 20px; }
    .end-actions { flex-direction: column; gap: 12px; }
    .end-btn { min-height: 52px; border-radius: 12px; text-align: center; }
    /* Hide catalog footer nav — bottom nav handles it */
    .ftr { display: none; }
  }

  /* ═══════ SMART RECOMMENDATIONS ═══════ */
  .recs { padding: 8px 0 16px; }
  .recs-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }
  .recs-title {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    opacity: .5;
  }
  .recs-badge {
    font: 500 10px/1 var(--fi);
    color: var(--ac);
    padding: 2px 8px;
    border-radius: 8px;
    background: rgba(212,175,55,.08);
  }
  .recs-list {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .recs-list::-webkit-scrollbar { display: none; }
  .rec-card {
    flex-shrink: 0;
    width: 200px;
    padding: 16px;
    border-radius: var(--rm);
    background: rgba(255,255,255,.02);
    border: 1px solid var(--brd);
    border-top: 2px solid rgba(212,175,55,.15);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: border-color .2s, box-shadow .2s;
  }
  .rec-card:hover, .rec-card:active {
    border-color: rgba(212,175,55,.2);
    box-shadow: 0 4px 16px var(--ac-sh);
  }
  .rec-card-type {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--ac);
    opacity: .6;
  }
  .rec-card-title {
    font: 400 14px/1.35 var(--fd);
    color: var(--t1);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .rec-card-meta {
    font: 400 11px/1.3 var(--fi);
    color: var(--t3);
  }

  /* ═══════ RECENTLY VIEWED ═══════ */
  .recent {
    padding: 8px 0 16px;
  }
  .recent-title {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    margin-bottom: 8px;
    opacity: .5;
  }
  .recent-list {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .recent-list::-webkit-scrollbar { display: none; }
  .recent-item {
    flex-shrink: 0;
    padding: 8px 16px;
    border-radius: 24px;
    background: rgba(212,175,55,.06);
    border: 1px solid rgba(212,175,55,.12);
    font: 400 13px/1.3 var(--fi);
    color: var(--ac2);
    text-decoration: none;
    white-space: nowrap;
    transition: background .2s, border-color .2s;
  }
  .recent-item:hover, .recent-item:active {
    background: rgba(212,175,55,.1);
    border-color: rgba(212,175,55,.25);
  }

  @media (max-width: 375px) {
    .page { padding: 24px 12px 0; }
  }

  /* ═══════ TYPE FILTER CHIPS ═══════ */
  .type-chips {
    display: flex;
    gap: 8px;
    padding: 16px 4px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    max-width: 100%;
  }
  .type-chips::-webkit-scrollbar { display: none; }

  .type-chip {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border: 1px solid var(--brd);
    border-radius: 24px;
    background: transparent;
    color: var(--t2);
    font: 400 13px/1 var(--fi);
    cursor: pointer;
    transition: all .2s var(--ease-out, ease);
    white-space: nowrap;
  }

  .type-chip:hover { border-color: rgba(212,175,55,.2); color: var(--t1); }

  .type-chip.active {
    background: rgba(212,175,55,.1);
    border-color: rgba(212,175,55,.3);
    color: var(--ac);
  }

  .type-count {
    font: 400 11px/1 var(--fm);
    opacity: .5;
  }

  .type-chip.active .type-count { opacity: .8; }

  /* ═══════ SEARCH SUGGESTIONS ═══════ */
  .ac-dropdown {
    position: relative;
    z-index: 60;
    background: var(--bg3);
    border: 1px solid var(--brd);
    border-radius: var(--rm);
    padding: 16px;
    margin-top: -4px;
    margin-bottom: 8px;
    box-shadow: 0 8px 24px rgba(0,0,0,.2);
  }

  .ac-popular {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 8px 8px 0;
  }

  .ac-label {
    width: 100%;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--t3);
    margin-bottom: 4px;
  }

  .ac-tag {
    padding: 8px 16px;
    border-radius: var(--rm);
    border: 1px solid var(--brd);
    background: transparent;
    color: var(--t2);
    font: 400 13px/1 var(--fi);
    cursor: pointer;
    transition: all .15s;
  }

  .ac-tag:hover { border-color: rgba(212,175,55,.2); color: var(--ac); }

  /* ═══════ QUICK PREVIEW MODAL ═══════ */
  .peek {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
  }
  .peek.is-open { display: block; }

  .peek-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.6);
    animation: peek-fade-in .2s ease forwards;
  }
  @keyframes peek-fade-in { from { opacity: 0; } to { opacity: 1; } }

  .peek-card {
    position: absolute;
    bottom: calc(64px + var(--safe-bottom, 0px));
    left: 16px;
    right: 16px;
    background: var(--bg3);
    border: 1px solid var(--brd);
    border-radius: 24px;
    padding: 8px 24px 24px;
    box-shadow: 0 -8px 40px rgba(0,0,0,.4);
    animation: peek-slide-up .3s var(--ease-spring, cubic-bezier(.34,1.56,.64,1)) forwards;
    max-height: 60vh;
    overflow-y: auto;
  }
  @keyframes peek-slide-up {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .peek-handle {
    display: flex;
    justify-content: center;
    padding: 8px 0;
  }
  .peek-handle span {
    width: 40px; height: 4px;
    border-radius: 2px;
    background: rgba(255,255,255,.12);
  }

  .peek-type {
    display: inline-block;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--ac);
    margin-bottom: 8px;
  }

  .peek-title {
    font: 400 20px/1.3 var(--fd);
    color: var(--t1);
    margin-bottom: 12px;
  }

  .peek-desc {
    font: 400 14px/1.6 var(--fi);
    color: var(--t2);
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .peek-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }
  .peek-meta span {
    padding: 4px 12px;
    border-radius: var(--rm);
    background: rgba(255,255,255,.04);
    border: 1px solid var(--brd);
    font: 400 12px/1.3 var(--fi);
    color: var(--t2);
  }

  .peek-actions {
    display: flex;
    gap: 8px;
  }
  .peek-btn {
    flex: 1;
    text-align: center;
    padding: 14px 16px;
    border-radius: var(--rm);
    font: 500 14px/1 var(--fi);
    text-decoration: none;
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .2s;
  }
  .peek-btn--primary {
    background: linear-gradient(135deg, #d4af37, #f6e27a);
    color: #09080a;
  }
  .peek-btn--order {
    background: transparent;
    border: 1px solid rgba(212,175,55,.3);
    color: var(--ac);
  }

  /* ═══════ VIEW COUNTER BADGE ═══════ */
  .c-views {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font: 400 11px/1 var(--fm);
    color: var(--t3);
    opacity: .6;
  }

  .c-views svg { width: 12px; height: 12px; opacity: .5; }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .c, .bar-q input, .bar-sel, .vb, .nil-btn, .end-btn, .more button, .share-submit, .share-upload, .share-field input, .share-field select, .share-field textarea {
      transition: none !important;
    }
    .g[data-v="grid"] .c { opacity: 1; transform: none; }
  }
</style>

<script>
  function init() {
    var page = document.querySelector('.page');
    if (!page) return;
    if (page.dataset.bound === '1') return;
    page.dataset.bound = '1';

    var grid = document.getElementById('g');
    var input = document.getElementById('q');
    var hint = document.getElementById('hint');
    var nil = document.getElementById('nil');
    var resetBtn = document.getElementById('resetBtn');
    var cntEl = document.getElementById('cnt');
    var catSel = document.getElementById('cat');
    var sortSel = document.getElementById('sort');
    var moreBtn = document.getElementById('moreBtn');
    var moreWrap = document.getElementById('more');
    var vBtns = document.querySelectorAll('.vb');
    var favFilterBtn = document.getElementById('favFilter');
    var shareForm = document.getElementById('shareForm');
    var shareDone = document.getElementById('shareDone');
    var shareSubmit = document.getElementById('shareSubmit');
    var shareFilesInput = document.getElementById('shareFiles');
    var shareFilesList = document.getElementById('shareFilesList');
    var shareProgress = document.getElementById('shareProgress');
    var shareMeter = document.getElementById('shareMeter');

    if (!grid || !input) return;

    var cards = Array.from(grid.querySelectorAll('.c'));
    var origTitles = new Map();
    cards.forEach(function(el) {
      var nameEl = el.querySelector('.c-name');
      if (nameEl) origTitles.set(el, nameEl.textContent);
    });
    var q = '', cat = 'all', srt = 'default', favOnly = false;
    var shown = 30, step = 30, all = false, timer = 0;
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var maxShareFiles = 5;
    var maxShareSize = 45 * 1024 * 1024;
    var shareUploadCache = { signature: '', uploadId: '' };

    function formatBytes(size) {
      if (size < 1024) return size + ' B';
      if (size < 1024 * 1024) return (size / 1024).toFixed(1) + ' KB';
      return (size / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function selectedShareFiles() {
      return Array.prototype.slice.call((shareFilesInput && shareFilesInput.files) || []);
    }

    function setShareProgress(message) {
      if (!shareProgress) return;
      shareProgress.textContent = message || '';
      shareProgress.classList.toggle('is-active', Boolean(message));
    }

    function setShareMeter(percent) {
      if (!shareMeter) return;
      var fill = shareMeter.querySelector('.share-meter-fill');
      if (typeof percent !== 'number' || !isFinite(percent)) {
        shareMeter.classList.remove('is-active');
        if (fill) fill.style.transform = 'scaleX(0)';
        return;
      }
      var normalized = Math.max(0, Math.min(100, percent));
      shareMeter.classList.add('is-active');
      if (fill) fill.style.transform = 'scaleX(' + (normalized / 100) + ')';
    }

    function setShareSubmitState(text, disabled) {
      if (!shareSubmit) return;
      shareSubmit.disabled = Boolean(disabled);
      shareSubmit.classList.toggle('is-loading', Boolean(disabled));
      var label = shareSubmit.querySelector('.share-submit-text');
      if (label) label.textContent = text;
    }

    function parseJsonText(text, status) {
      try {
        return JSON.parse(text);
      } catch (err) {
        throw new Error(text || ('HTTP ' + status));
      }
    }

    function postJson(url, payload) {
      return fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload || {}),
      }).then(function(res) {
        return res.text().then(function(text) {
          var data = parseJsonText(text, res.status);
          if (!res.ok || !data || data.ok === false) {
            throw new Error((data && data.error) || text || ('HTTP ' + res.status));
          }
          return data;
        });
      });
    }

    function uploadChunkRequest(url, body, onProgress) {
      return new Promise(function(resolve, reject) {
        var xhr = new XMLHttpRequest();
        xhr.open('POST', url, true);
        xhr.setRequestHeader('Content-Type', 'application/octet-stream');

        xhr.upload.addEventListener('progress', function(event) {
          if (!event.lengthComputable || !onProgress) return;
          onProgress(event.loaded, event.total);
        });

        xhr.onerror = function() {
          reject(new Error('network-error'));
        };

        xhr.onabort = function() {
          reject(new Error('request-aborted'));
        };

        xhr.onload = function() {
          var text = xhr.responseText || '';
          try {
            var data = parseJsonText(text, xhr.status);
            if (xhr.status >= 200 && xhr.status < 300 && data && data.ok !== false) {
              resolve(data);
              return;
            }
            reject(new Error((data && data.error) || text || ('HTTP ' + xhr.status)));
          } catch (err) {
            reject(new Error(text || ('HTTP ' + xhr.status)));
          }
        };

        xhr.send(body);
      });
    }

    function formDataToPayload(formData) {
      var payload = {};
      formData.forEach(function(value, key) {
        if (typeof File !== 'undefined' && value instanceof File) return;
        payload[key] = String(value == null ? '' : value);
      });
      return payload;
    }

    function filesSignature(files) {
      return files.map(function(file) {
        return [file.name || '', file.size || 0, file.lastModified || 0].join(':');
      }).join('|');
    }

    function createUploadDescriptors(files) {
      return files.map(function(file) {
        return {
          name: file.name || 'file',
          size: file.size || 0,
          contentType: file.type || 'application/octet-stream',
        };
      });
    }

    function stagedUpload(kind, files, hooks) {
      hooks = hooks || {};
      if (!files.length) return Promise.resolve('');

      var totalBytes = files.reduce(function(sum, file) {
        return sum + (file.size || 0);
      }, 0);
      var uploadedBytes = 0;

      function emitProgress(extraLoaded) {
        if (!hooks.onProgress) return;
        var loaded = Math.max(0, Math.min(totalBytes, uploadedBytes + (extraLoaded || 0)));
        var percent = totalBytes ? Math.max(1, Math.min(100, Math.round((loaded / totalBytes) * 100))) : 100;
        hooks.onProgress(percent, loaded, totalBytes);
      }

      if (hooks.onPrepare) hooks.onPrepare();

      return postJson('/api/uploads/init', {
        kind: kind,
        files: createUploadDescriptors(files),
      }).then(function(data) {
        var upload = data.upload || {};
        var uploadId = upload.id || '';
        var chunkSize = Math.max(262144, Number(upload.chunkSize) || (1024 * 1024));
        if (!uploadId) throw new Error('Не удалось подготовить сессию загрузки.');

        function uploadNext(fileIndex, chunkIndex) {
          if (fileIndex >= files.length) {
            if (hooks.onFinalize) hooks.onFinalize();
            return postJson('/api/uploads/complete', { uploadId: uploadId }).then(function() {
              return uploadId;
            });
          }
          var file = files[fileIndex];
          var start = chunkIndex * chunkSize;
          if (start >= file.size) {
            return uploadNext(fileIndex + 1, 0);
          }
          var end = Math.min(file.size, start + chunkSize);
          var chunk = file.slice(start, end);
          var url = '/api/uploads/chunk?uploadId=' + encodeURIComponent(uploadId) +
            '&fileIndex=' + fileIndex + '&chunkIndex=' + chunkIndex;
          return uploadChunkRequest(url, chunk, function(loaded) {
            emitProgress(loaded);
          }).then(function() {
            uploadedBytes += chunk.size;
            emitProgress(0);
            return uploadNext(fileIndex, chunkIndex + 1);
          });
        }

        emitProgress(0);
        return uploadNext(0, 0);
      });
    }

    function validateShareFiles(files) {
      if (!files.length) return 'Прикрепите хотя бы один файл.';
      if (files.length > maxShareFiles) return 'Можно прикрепить не больше 5 файлов.';
      var totalSize = files.reduce(function(sum, file) { return sum + (file.size || 0); }, 0);
      if (totalSize > maxShareSize) return 'Суммарный размер файлов не должен превышать 45 МБ.';
      return '';
    }

    function renderShareFiles() {
      if (!shareFilesList) return;
      var files = selectedShareFiles();
      shareFilesList.innerHTML = '';
      if (!files.length) {
        var empty = document.createElement('span');
        empty.className = 'share-files-empty';
        empty.textContent = 'Файлы не выбраны';
        shareFilesList.appendChild(empty);
        return;
      }
      files.forEach(function(file) {
        var item = document.createElement('span');
        item.className = 'share-file';
        var title = document.createElement('strong');
        title.textContent = file.name;
        var meta = document.createElement('span');
        meta.textContent = formatBytes(file.size || 0);
        item.appendChild(title);
        item.appendChild(meta);
        shareFilesList.appendChild(item);
      });
      var total = document.createElement('span');
      total.className = 'share-file-total';
      total.textContent = files.length + ' файл(ов), ' + formatBytes(files.reduce(function(sum, file) {
        return sum + (file.size || 0);
      }, 0));
      shareFilesList.appendChild(total);
    }

    /* URL params — restore state from query string */
    var urlParams = new URLSearchParams(window.location.search);
    var qp = urlParams.get('q');
    if (qp) { input.value = qp; q = qp.toLowerCase(); all = true; }
    var cp = urlParams.get('cat');
    if (cp && catSel) { catSel.value = cp; cat = cp; if (cat !== 'all') all = true; }
    var sp = urlParams.get('sort');
    if (sp && sortSel) { sortSel.value = sp; srt = sp; doSort(); }
    var vp = urlParams.get('view');
    if (vp && (vp === 'grid' || vp === 'list')) {
      grid.setAttribute('data-v', vp);
      vBtns.forEach(function(b) { b.classList.toggle('active', b.dataset.v === vp); });
    }

    function syncUrl() {
      var p = new URLSearchParams();
      if (q) p.set('q', q);
      if (cat !== 'all') p.set('cat', cat);
      if (srt !== 'default') p.set('sort', srt);
      var v = grid.getAttribute('data-v');
      if (v && v !== 'grid') p.set('view', v);
      var qs = p.toString();
      var url = window.location.pathname + (qs ? '?' + qs : '');
      history.replaceState(null, '', url);
    }

    /* Initial reveal */
    cards.forEach(function(el, i) {
      if (i >= shown) { el.style.display = 'none'; return; }
      if (reduced) { el.classList.add('vis'); return; }
      setTimeout(function() { el.classList.add('vis'); }, i * 30);
    });

    /* Search */
    input.addEventListener('input', function() {
      clearTimeout(timer);
      timer = setTimeout(function() {
        q = input.value.toLowerCase().trim();
        if (q) all = true;
        run();
        syncUrl();
      }, 200);
    });

    input.addEventListener('focus', function() { if (hint) hint.style.display = 'none'; });
    input.addEventListener('blur', function() { if (hint && !input.value) hint.style.display = ''; });

    /* Dropdowns */
    if (catSel) catSel.addEventListener('change', function() {
      cat = catSel.value;
      if (cat !== 'all') all = true;
      run();
      syncUrl();
    });

    if (sortSel) sortSel.addEventListener('change', function() {
      srt = sortSel.value;
      doSort();
      run();
      syncUrl();
    });

    /* Views */
    vBtns.forEach(function(b) {
      b.addEventListener('click', function() {
        vBtns.forEach(function(x) { x.classList.remove('active'); });
        b.classList.add('active');
        grid.setAttribute('data-v', b.dataset.v);
        syncUrl();
      });
    });

    /* Favorites filter */
    if (favFilterBtn) {
      favFilterBtn.addEventListener('click', function() {
        favOnly = !favOnly;
        favFilterBtn.classList.toggle('active', favOnly);
        if (favOnly) all = true;
        run();
        syncUrl();
      });
    }

    /* Infinite scroll */
    function loadMore() {
      shown += step;
      run();
      cards.forEach(function(el) {
        if (!el.classList.contains('hid') && el.style.display !== 'none') {
          el.classList.add('vis');
        }
      });
    }

    if (moreBtn) moreBtn.addEventListener('click', loadMore);

    if (moreWrap && 'IntersectionObserver' in window) {
      var scrollObserver = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting && moreWrap.style.display !== 'none') {
          loadMore();
        }
      }, { rootMargin: '200px' });
      scrollObserver.observe(moreWrap);
    }

    /* Reset */
    if (resetBtn) resetBtn.addEventListener('click', function() {
      input.value = ''; q = ''; cat = 'all'; srt = 'default'; all = false; shown = step;
      if (catSel) catSel.value = 'all';
      if (sortSel) sortSel.value = 'default';
      run();
      syncUrl();
    });

    /* Keyboard */
    document.addEventListener('keydown', function(e) {
      var tag = e.target.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') {
        if (e.key === 'Escape') { input.blur(); input.value = ''; q = ''; run(); acHide(); }
        return;
      }
      if (e.key === '/') { e.preventDefault(); input.focus(); }
    });

    /* ═══════ TYPE FILTER CHIPS ═══════ */
    var typeChips = document.querySelectorAll('.type-chip');
    var activeType = 'all';

    typeChips.forEach(function(chip) {
      chip.addEventListener('click', function() {
        typeChips.forEach(function(c) { c.classList.remove('active'); });
        chip.classList.add('active');
        activeType = chip.dataset.type;
        /* Sync with category dropdown */
        if (catSel) catSel.value = activeType === 'all' ? 'all' : activeType;
        cat = activeType === 'all' ? 'all' : activeType;
        if (cat !== 'all') all = true;
        run();
        syncUrl();
      });
    });

    /* ═══════ SEARCH SUGGESTIONS (popular tags only) ═══════ */
    var acDropdown = document.getElementById('acDropdown');
    var acPopular = document.getElementById('acPopular');

    function acHide() { if (acDropdown) acDropdown.style.display = 'none'; }
    function acShow() { if (acDropdown) acDropdown.style.display = ''; }

    /* Popular tag click → fill search */
    document.querySelectorAll('.ac-tag').forEach(function(tag) {
      tag.addEventListener('click', function() {
        input.value = tag.dataset.term;
        q = tag.dataset.term.toLowerCase();
        all = true;
        run();
        syncUrl();
        acHide();
      });
    });

    /* Show popular on focus when search is empty */
    input.addEventListener('focus', function() {
      if (hint) hint.style.display = 'none';
      if (!input.value) acShow();
    });

    /* Hide when typing or clicking outside */
    input.addEventListener('input', function() { acHide(); });
    document.addEventListener('click', function(e) {
      if (!e.target.closest('.bar-q') && !e.target.closest('.ac-dropdown')) acHide();
    });

    /* Integrate with search input */
    var origInputHandler = null;
    input.addEventListener('input', function() {
      clearTimeout(timer);
      timer = setTimeout(function() {
        q = input.value.toLowerCase().trim();
        if (q) all = true;
        run();
        syncUrl();
      }, 150);
    });

    function parseSize(s) {
      if (!s) return 0;
      var m = s.match(/([\d.,]+)\s*(МБ|MB|КБ|KB|Б|B)?/i);
      if (!m) return 0;
      var v = parseFloat(m[1].replace(',', '.'));
      var u = (m[2] || '').toUpperCase();
      if (u === 'КБ' || u === 'KB') v *= 1024;
      if (u === 'МБ' || u === 'MB') v *= 1048576;
      return v;
    }

    function doSort() {
      var a = cards.slice();
      if (srt === 'az') a.sort(function(x,y) { return (x.dataset.t||'').localeCompare(y.dataset.t||'','ru'); });
      else if (srt === 'za') a.sort(function(x,y) { return (y.dataset.t||'').localeCompare(x.dataset.t||'','ru'); });
      else if (srt === 'size') a.sort(function(x,y) { return parseSize(y.dataset.z||'') - parseSize(x.dataset.z||''); });
      else a.sort(function(x,y) { return parseInt(x.dataset.i||'0') - parseInt(y.dataset.i||'0'); });
      a.forEach(function(el) { grid.appendChild(el); });
    }

    function highlight(el) {
      var nameEl = el.querySelector('.c-name');
      if (!nameEl) return;
      var orig = origTitles.get(el) || nameEl.textContent;
      if (!q) { nameEl.innerHTML = orig; return; }
      var words = q.split(/\s+/).filter(Boolean);
      var html = orig;
      words.forEach(function(w) {
        var re = new RegExp('(' + w.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
        html = html.replace(re, '<mark class="hl">$1</mark>');
      });
      nameEl.innerHTML = html;
    }

    function run() {
      var n = 0, vis = 0;
      cards.forEach(function(el) {
        var ok = true;
        if (cat !== 'all' && el.dataset.c !== cat) ok = false;
        if (ok && favOnly) {
          var favs = JSON.parse(localStorage.getItem('favorites') || '[]');
          var href = el.getAttribute('href') || '';
          var filePath = href.replace(/^\/doc\//, '');
          if (favs.indexOf(filePath) === -1) ok = false;
        }
        if (ok && q) {
          var h = [el.dataset.t, el.dataset.d, (el.dataset.c||'').toLowerCase(), el.dataset.s, el.dataset.k, el.dataset.g].join(' ');
          ok = q.split(/\s+/).every(function(w) {
            if (h.includes(w)) return true;
            /* Fuzzy: allow 1-char typos for words >= 4 chars */
            if (w.length >= 4) {
              for (var ci = 0; ci < h.length - w.length + 1; ci++) {
                var diff = 0;
                for (var cj = 0; cj < w.length; cj++) {
                  if (h[ci + cj] !== w[cj]) diff++;
                  if (diff > 1) break;
                }
                if (diff <= 1) return true;
              }
            }
            return false;
          });
        }
        if (ok) {
          n++;
          if (all || n <= shown) {
            el.classList.remove('hid');
            el.style.display = '';
            el.classList.add('vis');
            highlight(el);
            vis++;
          } else {
            el.style.display = 'none';
            el.classList.remove('hid');
          }
        } else {
          el.classList.add('hid');
          el.style.display = '';
          highlight(el);
        }
      });
      var totalCards = cards.length;
      if (cntEl) cntEl.textContent = (q || cat !== 'all' || favOnly) ? n + ' из ' + totalCards : String(totalCards);
      if (nil) nil.style.display = n === 0 ? 'block' : 'none';
      if (moreWrap) moreWrap.style.display = (!all && n > shown) ? 'block' : 'none';
    }

    /* ═══════ 3D TILT EFFECT ═══════ */
    function initTilt() {
      if (window.matchMedia('(pointer: coarse)').matches) return;
      if (reduced) return;

      grid.addEventListener('mousemove', function(e) {
        var card = e.target.closest('.c');
        if (!card || grid.dataset.v !== 'grid') return;
        var rect = card.getBoundingClientRect();
        var x = (e.clientX - rect.left) / rect.width - 0.5;
        var y = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transform = 'perspective(600px) rotateY(' + (x * 8) + 'deg) rotateX(' + (-y * 8) + 'deg) translateY(-3px)';
      });

      grid.addEventListener('mouseleave', function(e) {
        var card = e.target && e.target.closest ? e.target.closest('.c') : null;
        if (card) {
          card.style.transform = '';
          card.style.transition = 'transform .5s cubic-bezier(.22,1,.36,1)' /* --ease-spring */;
          setTimeout(function() { card.style.transition = ''; }, 500);
        }
      }, true);
    }

    /* ═══════ KEYBOARD SHORTCUTS ═══════ */
    document.addEventListener('keydown', function(e) {
      /* / to focus search */
      if (e.key === '/' && document.activeElement !== qInput) {
        e.preventDefault();
        qInput.focus();
      }
      /* Escape to clear search and blur */
      if (e.key === 'Escape' && document.activeElement === qInput) {
        qInput.value = '';
        q = '';
        qInput.blur();
        run();
      }
    });

    initTilt();
    run();


    if (shareFilesInput) {
      shareFilesInput.addEventListener('change', function() {
        var files = selectedShareFiles();
        var fileError = validateShareFiles(files);
        if (fileError && files.length) {
          shareFilesInput.value = '';
          renderShareFiles();
          shareUploadCache.signature = '';
          shareUploadCache.uploadId = '';
          setShareProgress('');
          setShareMeter(NaN);
          alert(fileError);
          return;
        }
        shareUploadCache.signature = '';
        shareUploadCache.uploadId = '';
        setShareProgress('');
        setShareMeter(NaN);
        renderShareFiles();
      });
      renderShareFiles();
    }

    if (shareForm && shareDone) {
      shareForm.addEventListener('submit', function(e) {
        e.preventDefault();

        var files = selectedShareFiles();
        var fileError = validateShareFiles(files);
        if (fileError) {
          alert(fileError);
          return;
        }

        var titleField = document.getElementById('shareTitle');
        var contactField = document.getElementById('shareContact');
        if (!String((titleField || {}).value || '').trim()) {
          if (titleField) titleField.focus();
          return;
        }
        if (!String((contactField || {}).value || '').trim()) {
          if (contactField) contactField.focus();
          return;
        }

        var formData = new FormData(shareForm);
        var payload = formDataToPayload(formData);
        payload.source = 'Сайт · отправка работы в библиотеку';
        payload.sourcePath = window.location.pathname;
        payload.entryUrl = window.location.href;
        payload.referrer = document.referrer || '';

        setShareSubmitState('Загружаем файлы...', true);
        setShareMeter(0);
        setShareProgress('Подготавливаем защищённую загрузку...');

        var signature = filesSignature(files);
        var uploadPromise;
        if (shareUploadCache.uploadId && shareUploadCache.signature === signature) {
          setShareMeter(100);
          setShareProgress('Файлы уже загружены. Отправляем работу...');
          uploadPromise = Promise.resolve(shareUploadCache.uploadId);
        } else {
          uploadPromise = stagedUpload('library', files, {
            onPrepare: function() {
              setShareSubmitState('Загружаем файлы...', true);
              setShareMeter(0);
              setShareProgress('Подготавливаем защищённую загрузку...');
            },
            onProgress: function(percent) {
              setShareMeter(percent);
              setShareProgress('Загружаем файлы: ' + percent + '%');
            },
            onFinalize: function() {
              setShareMeter(100);
              setShareProgress('Файлы загружены. Подтверждаем загрузку...');
            },
          }).then(function(uploadId) {
            shareUploadCache.signature = signature;
            shareUploadCache.uploadId = uploadId;
            return uploadId;
          });
        }

        uploadPromise.then(function(uploadId) {
          payload.uploadSessionId = uploadId;
          setShareSubmitState('Отправляем в библиотеку...', true);
          setShareMeter(100);
          setShareProgress('Файлы приняты. Отправляем работу...');
          return postJson('/api/library-submit', payload);
        }).then(function(data) {
          if (data.ok) {
            shareUploadCache.signature = '';
            shareUploadCache.uploadId = '';
            setShareProgress('');
            setShareMeter(NaN);
            shareForm.style.display = 'none';
            shareDone.style.display = 'block';
          } else {
            setShareSubmitState('Отправить в библиотеку', false);
            setShareProgress('');
            setShareMeter(NaN);
            alert(data.error || 'Не удалось отправить работу');
          }
        }).catch(function() {
          setShareSubmitState('Отправить в библиотеку', false);
          setShareProgress('');
          setShareMeter(NaN);
          window.open('https://t.me/academicsaloon', '_blank');
          alert('Сервер временно недоступен. Откроем Telegram, чтобы вы могли отправить материалы вручную.');
        });
      });
    }
  }

  init();
  document.addEventListener('astro:after-swap', init);

  /* ═══════ QUICK PREVIEW (long-press on card) ═══════ */
  (function initPeek() {
    if (!window.matchMedia('(pointer: coarse)').matches) return;

    var peek = document.getElementById('peek');
    var peekBackdrop = document.getElementById('peekBackdrop');
    var peekCard = document.getElementById('peekCard');
    var peekType = document.getElementById('peekType');
    var peekTitle = document.getElementById('peekTitle');
    var peekDesc = document.getElementById('peekDesc');
    var peekMeta = document.getElementById('peekMeta');
    var peekOpen = document.getElementById('peekOpen');
    if (!peek) return;

    var holdTimer = null;
    var startX = 0, startY = 0;

    function openPeek(card) {
      var title = card.querySelector('.c-name')?.textContent || '';
      var type = card.querySelector('.c-type')?.textContent || '';
      var desc = card.dataset.desc || '';
      var subj = card.dataset.s || '';
      var cat = card.dataset.c || '';
      var size = card.dataset.z || '';
      var href = card.getAttribute('href') || '';

      peekType.textContent = type;
      peekTitle.textContent = title;
      peekDesc.textContent = desc || 'Описание недоступно';
      peekOpen.href = href;

      var tags = [cat, subj, size].filter(Boolean);
      peekMeta.innerHTML = tags.map(function(t) {
        return '<span>' + t + '</span>';
      }).join('');

      peek.classList.add('is-open');
      peek.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';

      if (navigator.vibrate) navigator.vibrate(15);
    }

    function closePeek() {
      peek.classList.remove('is-open');
      peek.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    peekBackdrop.addEventListener('click', closePeek);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && peek.classList.contains('is-open')) closePeek();
    });

    /* Swipe down to dismiss */
    var dragY = 0;
    peekCard.addEventListener('touchstart', function(e) {
      dragY = e.touches[0].clientY;
    }, { passive: true });
    peekCard.addEventListener('touchmove', function(e) {
      var dy = e.touches[0].clientY - dragY;
      if (dy > 0) peekCard.style.transform = 'translateY(' + dy + 'px)';
    }, { passive: true });
    peekCard.addEventListener('touchend', function(e) {
      var dy = (e.changedTouches[0]?.clientY || 0) - dragY;
      peekCard.style.transform = '';
      if (dy > 60) closePeek();
    });

    /* Long-press detection on cards */
    var cardContainer = document.getElementById('g');
    if (!cardContainer) return;

    cardContainer.addEventListener('touchstart', function(e) {
      var card = e.target.closest('.c');
      if (!card) return;
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
      holdTimer = setTimeout(function() {
        e.preventDefault();
        openPeek(card);
        holdTimer = null;
      }, 500);
    }, { passive: false });

    cardContainer.addEventListener('touchmove', function(e) {
      if (!holdTimer) return;
      var dx = Math.abs(e.touches[0].clientX - startX);
      var dy = Math.abs(e.touches[0].clientY - startY);
      if (dx > 10 || dy > 10) {
        clearTimeout(holdTimer);
        holdTimer = null;
      }
    }, { passive: true });

    cardContainer.addEventListener('touchend', function() {
      if (holdTimer) {
        clearTimeout(holdTimer);
        holdTimer = null;
      }
    });
  })();

  /* ═══════ RECENTLY VIEWED ═══════ */
  (function loadRecent() {
    try {
      var history = JSON.parse(localStorage.getItem('viewHistory') || '[]');
      if (!history.length) return;
      var section = document.getElementById('recentSection');
      var list = document.getElementById('recentList');
      if (!section || !list) return;
      section.style.display = '';
      history.slice(0, 5).forEach(function(item) {
        var a = document.createElement('a');
        a.className = 'recent-item';
        a.href = item.file;
        /* Truncate to 30 chars */
        var t = item.title || 'Документ';
        a.textContent = t.length > 30 ? t.substring(0, 30) + '…' : t;
        list.appendChild(a);
      });
    } catch(e) {}
  })();

  /* ═══════ SMART RECOMMENDATIONS ═══════ */
  (function loadRecs() {
    try {
      var history = JSON.parse(localStorage.getItem('viewHistory') || '[]');
      if (history.length < 2) return;

      /* Count subjects from history */
      var subjectFreq = {};
      history.forEach(function(h) {
        /* Extract subject from cards that match the path */
        cards.forEach(function(c) {
          var href = c.getAttribute('href') || '';
          if (h.file && h.file.includes(href.replace('/doc/', ''))) {
            var s = c.dataset.s;
            if (s) subjectFreq[s] = (subjectFreq[s] || 0) + 1;
          }
        });
      });

      /* Find top subjects */
      var topSubjects = Object.keys(subjectFreq).sort(function(a, b) {
        return subjectFreq[b] - subjectFreq[a];
      }).slice(0, 3);
      if (!topSubjects.length) return;

      /* Find unvisited cards matching those subjects */
      var viewedPaths = history.map(function(h) { return h.file; });
      var recs = [];
      cards.forEach(function(c) {
        if (recs.length >= 6) return;
        var s = c.dataset.s || '';
        var href = c.getAttribute('href') || '';
        if (topSubjects.indexOf(s) === -1) return;
        if (viewedPaths.some(function(p) { return p && p.includes(href.replace('/doc/', '')); })) return;
        recs.push(c);
      });

      if (recs.length < 2) return;

      var section = document.getElementById('recsSection');
      var list = document.getElementById('recsList');
      var badge = document.getElementById('recsBadge');
      if (!section || !list) return;

      section.style.display = '';
      if (badge) badge.textContent = recs.length + ' подборка';

      recs.slice(0, 4).forEach(function(c) {
        var a = document.createElement('a');
        a.className = 'rec-card';
        a.href = c.getAttribute('href') || '';
        var type = c.querySelector('.c-type')?.textContent || '';
        var title = c.querySelector('.c-name')?.textContent || '';
        var meta = c.querySelector('.c-left')?.textContent || '';
        a.innerHTML = '<span class="rec-card-type">' + type + '</span>' +
          '<span class="rec-card-title">' + (title.length > 50 ? title.substring(0, 50) + '…' : title) + '</span>' +
          '<span class="rec-card-meta">' + meta + '</span>';
        list.appendChild(a);
      });
    } catch(e) {}
  })();

  /* ═══════ VIEW COUNTER BADGES ═══════ */
  (function loadViewCounts() {
    var allFiles = [];
    document.querySelectorAll('.c[data-file]').forEach(function(el) {
      allFiles.push(el.dataset.file);
    });
    if (!allFiles.length) return;

    fetch('/api/doc-stats/batch', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ files: allFiles.slice(0, 50) })
    }).then(function(r) { return r.json(); }).then(function(data) {
      if (!data || !data.stats) return;
      Object.keys(data.stats).forEach(function(file) {
        var s = data.stats[file];
        var views = (s.views || 0) + (s.downloads || 0);
        if (views < 1) return;
        var el = document.querySelector('.c[data-file="' + file + '"] .c-views');
        if (el) {
          el.innerHTML = '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 3C4 3 1.5 8 1.5 8s2.5 5 6.5 5 6.5-5 6.5-5S12 3 8 3z"/><circle cx="8" cy="8" r="2"/></svg>' + views;
        }
      });
    }).catch(function() { /* silent fail */ });
  })();
</script>

<!-- ═══════ GSAP Catalog Animations ═══════ -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';

  gsap.registerPlugin(ScrollTrigger, SplitText);

  function initCatalogGSAP() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.innerWidth <= 768) return;
    ScrollTrigger.getAll().forEach(st => st.kill());

    // Header title
    const hdrT = document.querySelector('.hdr-t');
    if (hdrT) {
      const split = new SplitText(hdrT, { type: 'chars', charsClass: 'gsap-char' });
      gsap.from(split.chars, {
        opacity: 0, y: 20, stagger: 0.03,
        duration: 0.6, ease: 'power3.out', delay: 0.2,
      });
    }

    // Toolbar fade in
    const bar = document.querySelector('.bar');
    if (bar) {
      gsap.from(bar, { opacity: 0, y: 12, duration: 0.5, delay: 0.4, ease: 'power2.out' });
    }

    // End CTA reveal
    const end = document.querySelector('.end');
    if (end) {
      gsap.from(end, {
        opacity: 0, y: 20, duration: 0.6, ease: 'power3.out',
        scrollTrigger: { trigger: end, start: 'top 90%', once: true },
      });
    }

    ScrollTrigger.refresh();
  }

  document.addEventListener('astro:page-load', initCatalogGSAP);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCatalogGSAP);
  } else {
    initCatalogGSAP();
  }
</script>
