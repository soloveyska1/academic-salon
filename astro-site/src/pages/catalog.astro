---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const total = D.length;
const year = String(new Date().getFullYear());

const shortType: Record<string, string> = {
  'Самостоятельная работа': 'Самост.',
  'Выпускная квалификационная работа': 'ВКР',
  'Экзаменационные материалы': 'Экзамен',
  'Контрольная работа': 'Контрольная',
  'Курсовая работа': 'Курсовая',
  'Отчет по практике': 'Практика',
  'Отчет о научно-практической работе': 'НПР',
  'Справочный материал': 'Справочник',
  'Нормативный документ': 'Норматив',
  'Учебный документ': 'Учебный',
  'Шаблон документа': 'Шаблон',
  'Аналитический документ': 'Аналитика',
  'Практическое задание': 'Практич.',
  'Методические материалы': 'Методичка',
  'Учебная работа': 'Учебная',
  'Учебный материал': 'Учебный',
};

function getYear(doc: any) {
  const s = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const m = s.match(/(?:19|20)\d{2}/);
  return m ? m[0] : year;
}

/* Group documents by category, sorted by count (largest first) */
const categoryMap = new Map<string, any[]>();
for (const doc of D) {
  const cat = (doc as any).category || 'Разное';
  if (!categoryMap.has(cat)) categoryMap.set(cat, []);
  categoryMap.get(cat)!.push(doc);
}
const sortedCategories = [...categoryMap.entries()].sort((a, b) => b[1].length - a[1].length);
---

<Base title="Каталог — Библиотека академического салона" description="Каталог студенческих работ: курсовые, рефераты, ВКР, отчёты по практике. Бесплатное скачивание без регистрации." currentPath="/catalog">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <h1 class="hero-title">Каталог</h1>
      <div class="hero-rule" aria-hidden="true"></div>
      <p class="hero-sub">{total} работ — бесплатно, без регистрации</p>
      <div class="hero-search">
        <svg class="hero-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" id="q" placeholder="Найти работу..." autocomplete="off" inputmode="search" enterkeyhint="search" autocorrect="off" spellcheck="false" aria-label="Поиск документов" />
        <kbd id="hint">/</kbd>
      </div>
    </div>
  </section>

  <!-- SHELVES: one row per category -->
  <div class="shelves" id="shelves">
    {sortedCategories.map(([category, docs]) => (
      <section class="shelf rv" data-category={category}>
        <div class="shelf-head">
          <h2 class="shelf-title">{category} <span class="shelf-count">{docs.length}</span></h2>
        </div>
        <div class="shelf-track">
          {docs.map((doc: any) => {
            const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
            const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
            const rawType = doc.docType || doc.category || '';
            const type = shortType[rawType] || rawType;
            const subj = doc.subject || '';
            const yr = getYear(doc);
            return (
              <a
                href={`/doc/${doc.file}`}
                class="card"
                data-t={title.toLowerCase()}
                data-s={subj.toLowerCase()}
                data-c={(doc.category || '').toLowerCase()}
                data-file={doc.file}
              >
                <span class="card-type">{type}</span>
                <h3 class="card-name">{title}</h3>
                <span class="card-meta">{[subj, yr].filter(Boolean).join(' \u00b7 ')}</span>
                <span class="card-ext">{ext}</span>
              </a>
            );
          })}
        </div>
      </section>
    ))}
  </div>

  <!-- EMPTY STATE -->
  <div class="nil" id="nil" style="display:none">
    <p class="nil-title">Ничего не найдено</p>
    <button class="nil-reset" id="resetBtn">Сбросить</button>
    <a href="/order" class="nil-link">Заказать работу &rarr;</a>
  </div>

  <!-- ORDER CTA -->
  <section class="order rv">
    <div class="order-inner">
      <h2 class="order-title">Не нашли нужную работу?</h2>
      <p class="order-sub">Напишем индивидуально — от 3 000 &#8381;</p>
      <a href="/order" class="btn btn--primary">Заказать работу</a>
    </div>
  </section>

  <footer class="foot">
    <span class="foot-copy">&copy; 2020&ndash;2026 Библиотека академического салона</span>
  </footer>

  <!-- Back to top -->
  <button class="top-btn" id="topBtn" type="button" aria-label="Наверх">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>

</Base>

<style>
  /* ================================================================
     CATALOG v5 — Netflix Shelves
     Horizontal scrolling rows grouped by category.
     Same glass/gold design language as homepage.
     ================================================================ */

  :global(.footer) { display: none; }

  /* ----------------------------------------------------------------
     ANIMATIONS
     ---------------------------------------------------------------- */
  @keyframes fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes glow-breathe {
    0%, 100% { opacity: .65; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.06); }
  }

  .rv {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .6s var(--ease), transform .6s var(--ease);
  }
  .rv.vis { opacity: 1; transform: translateY(0); }

  /* ----------------------------------------------------------------
     BUTTONS — exact homepage match
     ---------------------------------------------------------------- */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 16px 40px;
    border-radius: 0;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    text-decoration: none;
    color: var(--t1);
    border: 1px solid var(--ac-b);
    cursor: pointer;
    transition:
      transform .3s var(--ease),
      border-color .3s var(--ease),
      box-shadow .3s var(--ease);
  }
  .btn--primary {
    background: var(--surf);
    border-color: var(--ac-b);
  }
  .btn:hover {
    transform: translateY(-2px);
    border-color: var(--ac-b3);
    box-shadow: 0 12px 40px var(--ac-sh);
  }
  .btn--primary:hover { box-shadow: 0 12px 40px var(--ac-g); }

  /* ----------------------------------------------------------------
     HERO — same glow as homepage, compact ~40vh
     ---------------------------------------------------------------- */
  .hero {
    position: relative;
    padding: calc(var(--nav-h) + 80px) 24px 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-glow {
    position: absolute;
    width: min(1100px, 95vw);
    height: min(900px, 85vw);
    top: 45%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45% at 50% 48%, rgba(212,175,55,.22) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 48% 44%, rgba(212,175,55,.14) 0%, transparent 50%),
      radial-gradient(ellipse 75% 55% at 42% 52%, rgba(180,130,20,.08) 0%, transparent 75%);
    pointer-events: none;
    z-index: 0;
    animation: glow-breathe 10s ease-in-out infinite;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 960px;
    text-align: center;
    padding: 0 8px;
  }

  .hero-title {
    font: 300 clamp(48px, 10vw, 80px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: -.02em;
    text-shadow: 0 0 120px rgba(212,175,55,.06), 0 4px 24px rgba(0,0,0,.3);
  }

  .hero-rule {
    width: 48px;
    height: 1px;
    margin: 24px auto 0;
    background: linear-gradient(90deg, transparent, var(--ac), transparent);
    opacity: .35;
  }

  .hero-sub {
    margin-top: 20px;
    font: 400 15px/1.6 var(--fi);
    color: var(--t2);
    max-width: 52ch;
    margin-inline: auto;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out .4s forwards;
  }

  .hero-search {
    position: relative;
    max-width: 480px;
    margin: 32px auto 0;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out .6s forwards;
  }

  .hero-search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--t3);
    pointer-events: none;
  }

  .hero-search input {
    width: 100%;
    padding: 14px 20px 14px 42px;
    border: 1px solid var(--brd);
    border-radius: 999px;
    background: rgba(255,255,255,.04);
    color: var(--t1);
    font: 400 16px/1.4 var(--fi);
    outline: none;
    transition: border-color .3s, box-shadow .3s, background .3s;
  }

  .hero-search input::placeholder { color: var(--t3); }

  .hero-search input:focus {
    border-color: var(--ac-b);
    box-shadow: 0 0 0 3px rgba(212,175,55,.1);
    background: rgba(255,255,255,.06);
  }

  .hero-search input:focus ~ kbd { display: none; }

  .hero-search kbd {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    border: 1px solid var(--brd);
    padding: 2px 6px;
    border-radius: 4px;
    pointer-events: none;
  }

  /* ----------------------------------------------------------------
     SHELVES — horizontal scrolling rows
     ---------------------------------------------------------------- */
  .shelves {
    padding: 0 0 80px;
    background: var(--bg);
  }

  .shelf {
    padding: 48px 0 24px;
  }

  .shelf-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 0 48px;
    margin-bottom: 24px;
  }

  .shelf-title {
    font: 300 24px/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  .shelf-count {
    font: 400 13px/1 var(--fm);
    color: var(--t3);
  }

  /* THE HORIZONTAL SCROLLING TRACK */
  .shelf-track {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x proximity;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding: 0 48px;
    /* Fade masks on edges */
    mask-image: linear-gradient(90deg, transparent, #000 48px, #000 calc(100% - 48px), transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 48px, #000 calc(100% - 48px), transparent);
  }

  .shelf-track::-webkit-scrollbar { display: none; }

  /* ----------------------------------------------------------------
     CARDS — glass style inside shelves
     ---------------------------------------------------------------- */
  .card {
    flex: 0 0 280px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px;
    min-height: 160px;
    background: rgba(255,255,255,.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,.06);
    border-radius: var(--rs);
    text-decoration: none;
    color: var(--t1);
    scroll-snap-align: start;
    position: relative;
    overflow: hidden;
    transition: border-color .3s, transform .3s, box-shadow .3s;
  }

  /* Gold shimmer line on hover */
  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 20%, var(--ac) 50%, transparent 80%);
    opacity: 0;
    transition: opacity .3s;
  }

  .card:hover {
    border-color: rgba(212,175,55,.15);
    transform: translateY(-3px);
    box-shadow: 0 16px 48px rgba(0,0,0,.25);
  }

  .card:hover::before { opacity: .4; }
  .card:focus-visible { outline: 2px solid var(--ac-b2); outline-offset: 2px; }

  .card-type {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--ac);
    opacity: .6;
  }

  .card-name {
    font: 400 17px/1.35 var(--fd);
    color: var(--t1);
    -webkit-line-clamp: 3;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .card:hover .card-name { color: var(--ac2, var(--ac)); }

  .card-meta {
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    margin-top: auto;
  }

  .card-ext {
    font: 400 9px/1 var(--fm);
    text-transform: uppercase;
    color: var(--t3);
    opacity: .4;
  }

  /* Search highlight */
  :global(.hl) {
    background: var(--ac-b);
    color: var(--ac2);
    border-radius: 4px;
    padding: 1px 4px;
  }
  :global([data-theme="light"]) :global(.hl) {
    background: rgba(180,140,20,.12);
    color: #8b6914;
  }

  /* ----------------------------------------------------------------
     EMPTY STATE
     ---------------------------------------------------------------- */
  .nil {
    text-align: center;
    padding: 96px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    background: var(--bg);
  }

  .nil-title {
    font: 300 22px/1.3 var(--fd);
    color: var(--t2);
  }

  .nil-reset {
    background: none;
    border: 1px solid var(--ac-b);
    border-radius: 0;
    padding: 12px 36px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    cursor: pointer;
    transition: color .3s, border-color .3s, background .3s;
  }
  .nil-reset:hover { color: var(--ac); border-color: var(--ac-b2); background: var(--surf); }

  .nil-link {
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    text-decoration: none;
    letter-spacing: .04em;
    transition: color .3s;
  }
  .nil-link:hover { color: var(--ac); }

  /* ----------------------------------------------------------------
     ORDER CTA — same as homepage
     ---------------------------------------------------------------- */
  .order {
    padding: 120px 24px;
    background: var(--bg);
  }

  .order-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    text-align: center;
  }

  .order-title {
    font: 300 clamp(28px, 5vw, 40px)/1.2 var(--fd);
    color: var(--t1);
    margin-bottom: 16px;
  }

  .order-sub {
    font: 400 14px/1.6 var(--fi);
    color: var(--t3);
    margin-bottom: 40px;
  }

  /* ----------------------------------------------------------------
     FOOTER
     ---------------------------------------------------------------- */
  .foot {
    padding: 64px 24px;
    background: var(--bg);
    text-align: center;
  }

  .foot-copy {
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    letter-spacing: .04em;
  }

  /* ----------------------------------------------------------------
     BACK TO TOP
     ---------------------------------------------------------------- */
  .top-btn {
    position: fixed;
    bottom: calc(80px + env(safe-area-inset-bottom, 0px));
    right: 24px;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ac-b);
    border-radius: 999px;
    background: var(--bg);
    color: var(--ac);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity .3s, transform .3s, border-color .3s;
    z-index: 50;
  }
  .top-btn.is-visible { opacity: 1; pointer-events: auto; transform: translateY(0); }
  .top-btn:hover { border-color: var(--ac-b3); box-shadow: 0 8px 24px var(--ac-sh); }
  .top-btn:focus-visible { outline: 2px solid var(--ac-b2); outline-offset: 2px; }

  /* ----------------------------------------------------------------
     LIGHT THEME
     ---------------------------------------------------------------- */
  :global([data-theme="light"]) .hero-glow {
    background:
      radial-gradient(ellipse 55% 45% at 50% 48%, rgba(180,145,30,.12) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 48% 44%, rgba(180,145,30,.08) 0%, transparent 50%),
      radial-gradient(ellipse 75% 55% at 42% 52%, rgba(160,120,15,.05) 0%, transparent 75%);
  }

  :global([data-theme="light"]) .hero-search input {
    background: rgba(0,0,0,.03);
    border-color: rgba(0,0,0,.1);
  }
  :global([data-theme="light"]) .hero-search input:focus {
    border-color: var(--ac-b);
    background: rgba(0,0,0,.04);
  }

  :global([data-theme="light"]) .card {
    background: #fff;
    border-color: var(--brd);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }
  :global([data-theme="light"]) .card:hover {
    box-shadow: 0 12px 40px rgba(0,0,0,.1);
  }

  /* ----------------------------------------------------------------
     REDUCED MOTION
     ---------------------------------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    .hero-sub, .hero-search {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .hero-glow {
      animation: none;
      opacity: .8;
      transform: translate(-50%, -50%);
    }
    .rv { opacity: 1; transform: none; transition: none; }
  }

  /* ----------------------------------------------------------------
     MOBILE (max 639px)
     ---------------------------------------------------------------- */
  @media (max-width: 639px) {
    .hero { padding: calc(var(--nav-h) + 48px) 20px 48px; }

    .shelf-head { padding: 0 20px; }
    .shelf-track { padding: 0 20px; gap: 12px;
      mask-image: linear-gradient(90deg, transparent, #000 20px, #000 calc(100% - 20px), transparent);
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 20px, #000 calc(100% - 20px), transparent);
    }
    .card { flex: 0 0 260px; min-height: 140px; padding: 20px; }
    .shelf-title { font-size: 20px; }
    .hero-inner { padding: 0 20px; }

    .order { padding: 64px 20px; }
    .order .btn { width: 100%; max-width: 320px; }

    .foot { padding: 48px 20px; }

    .hero-search input { min-height: 44px; font-size: 16px; }
    .hero-search kbd { display: none; }
  }
</style>

<script>
  function init() {
    var input = document.getElementById('q') as HTMLInputElement | null;
    var shelvesWrap = document.getElementById('shelves');
    var nil = document.getElementById('nil');
    var hint = document.getElementById('hint');
    var resetBtn = document.getElementById('resetBtn');

    if (!input || !shelvesWrap) return;
    if (shelvesWrap.dataset.bound === '1') return;
    shelvesWrap.dataset.bound = '1';

    var shelves = Array.from(shelvesWrap.querySelectorAll('.shelf'));
    var allCards = Array.from(document.querySelectorAll('.card'));
    var origNames = new Map<Element, string>();
    allCards.forEach(function(el) {
      var n = el.querySelector('.card-name');
      if (n) origNames.set(el, n.textContent || '');
    });

    var q = '';
    var timer = 0;
    /* Store original shelf counts for reset */
    var origCounts = new Map<Element, string>();
    shelves.forEach(function(shelf) {
      var countEl = shelf.querySelector('.shelf-count');
      if (countEl) origCounts.set(shelf, countEl.textContent || '');
    });

    /* HIGHLIGHT */
    function highlight(el: Element) {
      var nameEl = el.querySelector('.card-name');
      if (!nameEl) return;
      var orig = origNames.get(el) || nameEl.textContent || '';
      if (!q) { nameEl.innerHTML = orig; return; }
      var words = q.split(/\s+/).filter(Boolean);
      var html = orig;
      words.forEach(function(w) {
        var re = new RegExp('(' + w.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
        html = html.replace(re, '<mark class="hl">$1</mark>');
      });
      nameEl.innerHTML = html;
    }

    /* MAIN FILTER */
    function run() {
      var totalVisible = 0;

      shelves.forEach(function(shelf) {
        var cards = Array.from(shelf.querySelectorAll('.card'));
        var shelfVisible = 0;

        cards.forEach(function(card) {
          var ok = true;
          if (q) {
            var haystack = [
              (card as HTMLElement).dataset.t,
              (card as HTMLElement).dataset.s,
              (card as HTMLElement).dataset.c
            ].join(' ');
            ok = q.split(/\s+/).every(function(w) {
              if (haystack.includes(w)) return true;
              /* Fuzzy: allow 1 char diff for words >= 4 chars */
              if (w.length >= 4) {
                for (var ci = 0; ci <= haystack.length - w.length; ci++) {
                  var diff = 0;
                  for (var cj = 0; cj < w.length; cj++) {
                    if (haystack[ci + cj] !== w[cj]) diff++;
                    if (diff > 1) break;
                  }
                  if (diff <= 1) return true;
                }
              }
              return false;
            });
          }
          (card as HTMLElement).style.display = ok ? '' : 'none';
          if (ok) shelfVisible++;
          highlight(card);
        });

        (shelf as HTMLElement).style.display = shelfVisible > 0 ? '' : 'none';
        totalVisible += shelfVisible;

        /* Update shelf count during search */
        var countEl = shelf.querySelector('.shelf-count');
        if (countEl) {
          countEl.textContent = q ? String(shelfVisible) : (origCounts.get(shelf) || '');
        }
      });

      /* Show/hide empty state */
      if (nil) nil.style.display = totalVisible === 0 ? '' : 'none';

      /* URL sync */
      var url = new URL(window.location.href);
      if (q) url.searchParams.set('q', q); else url.searchParams.delete('q');
      history.replaceState(null, '', url.toString());
    }

    /* SEARCH INPUT */
    input.addEventListener('input', function() {
      clearTimeout(timer);
      timer = window.setTimeout(function() {
        q = input!.value.trim().toLowerCase();
        run();
      }, 150);
    });

    /* URL PARAM */
    var qp = new URLSearchParams(window.location.search).get('q');
    if (qp) { input.value = qp; q = qp.toLowerCase(); run(); }

    /* KEYBOARD */
    document.addEventListener('keydown', function(e) {
      if (e.key === '/' && !['INPUT','TEXTAREA','SELECT'].includes((document.activeElement || {} as any).tagName)) {
        e.preventDefault(); input!.focus();
      }
      if (e.key === 'Escape' && document.activeElement === input) {
        input!.value = ''; q = ''; run(); input!.blur();
      }
    });

    /* RESET */
    if (resetBtn) resetBtn.addEventListener('click', function() {
      input!.value = ''; q = ''; run();
    });

    /* BACK TO TOP */
    var topBtn = document.getElementById('topBtn');
    if (topBtn) {
      window.addEventListener('scroll', function() {
        topBtn!.classList.toggle('is-visible', window.scrollY > window.innerHeight);
      }, { passive: true });
      topBtn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    /* SCROLL REVEAL */
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) { e.target.classList.add('vis'); observer.unobserve(e.target); }
        });
      }, { threshold: 0.1 });
      document.querySelectorAll('.rv').forEach(function(el) { observer.observe(el); });
    } else {
      document.querySelectorAll('.rv').forEach(function(el) { el.classList.add('vis'); });
    }

    /* FOCUS HINT */
    if (hint) {
      input.addEventListener('focus', function() { hint!.style.display = 'none'; });
      input.addEventListener('blur', function() { if (!input!.value) hint!.style.display = ''; });
    }
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>
