---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const totalDocs = D.length;
const currentYear = String(new Date().getFullYear());
const INITIAL_COUNT = 30;

const categories = [...new Set(D.map((d: any) => d.category).filter(Boolean))].sort();

const typeShort: Record<string, string> = {
  'Самостоятельная работа': 'Самостоятельная',
  'Выпускная квалификационная работа': 'ВКР',
  'Экзаменационные материалы': 'Экзамен',
  'Контрольная работа': 'Контрольная',
  'Курсовая работа': 'Курсовая',
  'Отчет по практике': 'Отчёт по практике',
  'Отчет о научно-практической работе': 'Науч. отчёт',
  'Справочный материал': 'Справочник',
  'Нормативный документ': 'Нормативный',
  'Учебный документ': 'Учебный',
  'Шаблон документа': 'Шаблон',
  'Аналитический документ': 'Аналитика',
  'Практическое задание': 'Практическое',
  'Методические материалы': 'Методичка',
  'Учебная работа': 'Учебная',
  'Учебный материал': 'Учебный',
};

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const m = blob.match(/(?:19|20)\d{2}/);
  return m ? m[0] : currentYear;
}
---

<Base title="Каталог — Академический Салон" currentPath="/catalog">

  <!-- Mini-hero -->
  <header class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <h1 class="hero-t">Каталог</h1>
    <div class="hero-rule" aria-hidden="true"></div>
    <p class="hero-n"><span id="cntN">{totalDocs}</span> документов</p>
  </header>

  <!-- Sticky toolbar -->
  <div class="tb" id="toolbar">
    <div class="tb-inner">
      <div class="tb-search">
        <input type="text" id="q" class="tb-q" placeholder="Название, тема, предмет..." autocomplete="off" />
        <kbd class="tb-kbd" id="qHint">/</kbd>
      </div>
      <select class="tb-sel" id="catSel">
        <option value="all">Все категории</option>
        {categories.map(c => (
          <option value={c}>{c}</option>
        ))}
      </select>
      <select class="tb-sel" id="sortSel">
        <option value="default">По умолчанию</option>
        <option value="az">А — Я</option>
        <option value="za">Я — А</option>
        <option value="size">По размеру</option>
      </select>
      <div class="tb-views">
        <button class="vbtn active" data-view="grid" aria-label="Сетка">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="7" height="7"/><rect x="12" y="1" width="7" height="7"/><rect x="1" y="12" width="7" height="7"/><rect x="12" y="12" width="7" height="7"/></svg>
        </button>
        <button class="vbtn" data-view="list" aria-label="Список">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="1" y1="4" x2="19" y2="4"/><line x1="1" y1="10" x2="19" y2="10"/><line x1="1" y1="16" x2="19" y2="16"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Grid -->
  <main class="ct">
    <div class="ct-grid" id="grid" data-view="grid">
      {D.map((doc: any, i: number) => {
        const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
        const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
        const rawType = doc.docType || doc.category || '';
        const docType = typeShort[rawType] || rawType;
        const subject = doc.subject || '';
        const year = extractYear(doc);
        const subjectYear = [subject, year].filter(Boolean).join(' · ');
        const fileInfo = [ext, doc.size].filter(Boolean).join(' · ');
        return (
          <a
            href={`/doc/${doc.file}`}
            class:list={['dc', { 'dc-lead': i === 0 }]}
            data-t={title.toLowerCase()}
            data-d={(doc.catalogDescription || doc.description || '').toLowerCase()}
            data-c={doc.category || ''}
            data-s={subject.toLowerCase()}
            data-k={(doc.course || '').toLowerCase()}
            data-g={(doc.tags || []).join(' ').toLowerCase()}
            data-z={doc.size || ''}
            data-i={i}
            style={i < INITIAL_COUNT ? '' : 'display:none'}
          >
            <span class="dc-arrow" aria-hidden="true">→</span>
            <span class="dc-type">{docType}</span>
            <h3 class="dc-name">{title}</h3>
            <div class="dc-foot">
              <span class="dc-sub">{subjectYear}</span>
              <span class="dc-file">{fileInfo}</span>
            </div>
          </a>
        );
      })}
    </div>

    <!-- Load more -->
    <div class="ct-more" id="moreWrap">
      <button class="ct-more-btn" id="moreBtn">Показать ещё</button>
    </div>

    <!-- Empty -->
    <div class="ct-empty" id="empty" style="display:none">
      <p class="ct-empty-t">Ничего не найдено</p>
      <p class="ct-empty-h">Измените запрос или сбросьте фильтры</p>
      <button class="ct-empty-btn" id="resetBtn">Сбросить</button>
    </div>

    <!-- Closing CTA -->
    <div class="ct-closing">
      <p class="ct-closing-t">Не нашли нужную работу?</p>
      <a href="/order" class="ct-closing-btn">Заказать</a>
      <div class="ct-closing-links">
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
      </div>
    </div>
  </main>

  <!-- Scroll to top -->
  <button class="scroll-top" id="scrollTop" aria-label="Наверх">↑</button>

</Base>

<style>
  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    text-align: center;
    padding: 100px 48px 0;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    width: 800px;
    height: 600px;
    top: 30%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse 60% 50%, rgba(200,165,40,.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-t {
    position: relative;
    font: 300 clamp(40px, 7vw, 64px)/1 var(--fd);
    color: rgba(255,255,255,.85);
    letter-spacing: .02em;
  }

  .hero-rule {
    width: 60px;
    height: 1px;
    margin: 20px auto 0;
    background: var(--ac);
    opacity: .2;
  }

  .hero-n {
    position: relative;
    margin-top: 16px;
    font: 400 11px/1 var(--fm);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: rgba(255,255,255,.25);
    font-variant-numeric: tabular-nums;
    padding-bottom: 40px;
  }

  /* ═══════ STICKY TOOLBAR ═══════ */
  .tb {
    position: sticky;
    top: var(--nav-h);
    z-index: 40;
    background: #09090b;
    border-bottom: 1px solid rgba(201,165,90,.08);
    padding: 0 48px;
  }

  .tb-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    height: 56px;
    gap: 24px;
  }

  .tb-search {
    width: 300px;
    flex-shrink: 0;
    position: relative;
  }

  .tb-q {
    width: 100%;
    padding: 8px 0;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,.08);
    background: transparent;
    color: rgba(255,255,255,.85);
    font: 300 italic 14px/1.3 var(--fd);
    outline: none;
    transition: border-color .4s cubic-bezier(.25,0,0,1);
  }

  .tb-q::placeholder { color: rgba(255,255,255,.2); font-style: italic; }
  .tb-q:focus { border-bottom-color: rgba(201,165,90,.3); }
  .tb-q:focus ~ .tb-kbd { display: none; }

  .tb-kbd {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font: 400 10px/1 var(--fm);
    color: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,.08);
    padding: 3px 7px;
    pointer-events: none;
  }

  .tb-sel {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: none;
    font: 400 11px/1 var(--fi);
    color: rgba(255,255,255,.35);
    cursor: pointer;
    padding: 4px 0;
    outline: none;
  }

  .tb-sel:hover, .tb-sel:focus { color: rgba(255,255,255,.6); }
  .tb-sel option { background: #09090b; color: rgba(255,255,255,.85); }

  .tb-views, .hero-views { display: flex; gap: 4px; }
  .tb-views { margin-left: auto; }

  .vbtn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: rgba(255,255,255,.3);
    cursor: pointer;
    position: relative;
    transition: color .3s cubic-bezier(.25,0,0,1);
  }

  .vbtn:hover { color: rgba(255,255,255,.5); }
  .vbtn.active { color: rgba(255,255,255,.8); }

  .vbtn.active::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 8px;
    right: 8px;
    height: 2px;
    background: var(--ac);
    opacity: .6;
    animation: vline .3s cubic-bezier(.25,0,0,1);
  }

  @keyframes vline { from { transform: scaleX(0); } to { transform: scaleX(1); } }

  /* ═══════ CONTENT ═══════ */
  .ct {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 32px 48px 0;
  }

  .ct-grid { transition: opacity .2s cubic-bezier(.25,0,0,1); }
  .ct-grid.switching { opacity: 0; }

  /* ── GRID VIEW ── */
  .ct-grid[data-view="grid"] {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .ct-grid[data-view="grid"] .dc {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 28px 24px;
    background: rgba(255,255,255,.025);
    border: 1px solid rgba(255,255,255,.03);
    text-decoration: none;
    color: inherit;
    position: relative;
    opacity: 0;
    transform: translateY(12px);
    transition:
      background .5s cubic-bezier(.25,0,0,1),
      border-color .5s cubic-bezier(.25,0,0,1),
      opacity .4s cubic-bezier(.25,0,0,1),
      transform .4s cubic-bezier(.25,0,0,1);
  }

  .ct-grid[data-view="grid"] .dc.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .ct-grid[data-view="grid"] .dc:hover {
    background: rgba(255,255,255,.04);
    border-color: rgba(255,255,255,.08);
  }

  .ct-grid[data-view="grid"] .dc:hover .dc-name { color: rgba(201,165,90,.85); }
  .ct-grid[data-view="grid"] .dc:hover .dc-type { opacity: .5; }
  .ct-grid[data-view="grid"] .dc:hover .dc-arrow { opacity: .3; }

  .ct-grid[data-view="grid"] .dc-lead {
    grid-column: span 2;
    padding: 36px 32px;
  }

  .ct-grid[data-view="grid"] .dc-lead .dc-name { font-size: 24px; }

  /* ── LIST VIEW ── */
  .ct-grid[data-view="list"] {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .ct-grid[data-view="list"] .dc {
    display: grid;
    grid-template-columns: 80px 1fr auto auto;
    align-items: baseline;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,.04);
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: background .5s cubic-bezier(.25,0,0,1);
  }

  .ct-grid[data-view="list"] .dc:hover { background: rgba(255,255,255,.02); }
  .ct-grid[data-view="list"] .dc:hover .dc-name { color: rgba(201,165,90,.85); }

  .ct-grid[data-view="list"] .dc-name {
    font: 400 14px/1.35 var(--fi);
    -webkit-line-clamp: 1;
    transition: color .5s cubic-bezier(.25,0,0,1);
  }

  .ct-grid[data-view="list"] .dc-foot { display: contents; }
  .ct-grid[data-view="list"] .dc-sub { text-align: right; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ct-grid[data-view="list"] .dc-file { text-align: right; white-space: nowrap; }
  .ct-grid[data-view="list"] .dc-arrow { display: none; }

  /* ── Shared ── */
  .dc.hidden { display: none !important; }

  .dc-arrow {
    position: absolute;
    top: 16px;
    right: 16px;
    font: 400 14px/1 var(--fi);
    color: rgba(255,255,255,.5);
    opacity: 0;
    transition: opacity .5s cubic-bezier(.25,0,0,1);
  }

  .dc-type {
    font: 400 9px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: rgba(255,255,255,.25);
    transition: opacity .5s cubic-bezier(.25,0,0,1);
  }

  .dc-name {
    font: 400 18px/1.3 var(--fd);
    color: rgba(255,255,255,.85);
    letter-spacing: .01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color .5s cubic-bezier(.25,0,0,1);
  }

  .dc-foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-top: auto;
  }

  .dc-sub { font: 400 11px/1.3 var(--fm); color: rgba(255,255,255,.2); }
  .dc-file { font: 400 11px/1 var(--fm); color: rgba(255,255,255,.15); flex-shrink: 0; }

  /* ═══════ LOAD MORE ═══════ */
  .ct-more {
    text-align: center;
    padding: 48px 0;
  }

  .ct-more-btn {
    background: none;
    border: .5px solid rgba(255,255,255,.1);
    padding: 14px 48px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: rgba(255,255,255,.4);
    cursor: pointer;
    transition: color .4s cubic-bezier(.25,0,0,1), border-color .4s cubic-bezier(.25,0,0,1);
  }

  .ct-more-btn:hover { color: rgba(255,255,255,.8); border-color: rgba(255,255,255,.2); }

  /* ═══════ EMPTY ═══════ */
  .ct-empty { text-align: center; padding: 96px 24px; }
  .ct-empty-t { font: 300 italic 24px/1.2 var(--fd); color: rgba(255,255,255,.5); }
  .ct-empty-h { margin-top: 10px; font: 400 13px/1.5 var(--fi); color: rgba(255,255,255,.2); }

  .ct-empty-btn {
    margin-top: 24px;
    background: none;
    border: .5px solid rgba(255,255,255,.12);
    padding: 12px 36px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: rgba(255,255,255,.5);
    cursor: pointer;
    transition: color .4s cubic-bezier(.25,0,0,1), border-color .4s cubic-bezier(.25,0,0,1);
  }

  .ct-empty-btn:hover { color: rgba(255,255,255,.85); border-color: rgba(255,255,255,.25); }

  /* ═══════ CLOSING CTA ═══════ */
  .ct-closing {
    text-align: center;
    padding: 120px 24px 80px;
    border-top: 1px solid rgba(255,255,255,.04);
    margin-top: 48px;
  }

  .ct-closing-t {
    font: 300 clamp(22px, 4vw, 28px)/1.2 var(--fd);
    color: rgba(255,255,255,.7);
  }

  .ct-closing-btn {
    display: inline-block;
    margin-top: 28px;
    padding: 14px 48px;
    border: .5px solid rgba(255,255,255,.12);
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: rgba(255,255,255,.5);
    text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1), border-color .4s cubic-bezier(.25,0,0,1);
  }

  .ct-closing-btn:hover { color: rgba(255,255,255,.85); border-color: rgba(255,255,255,.25); }

  .ct-closing-links {
    margin-top: 20px;
    display: flex;
    justify-content: center;
    gap: 16px;
  }

  .ct-closing-links a {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: rgba(255,255,255,.2);
    text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .ct-closing-links a:hover { color: rgba(255,255,255,.6); }

  /* ═══════ SCROLL TOP ═══════ */
  .scroll-top {
    position: fixed;
    bottom: 32px;
    right: 32px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #09090b;
    border: 1px solid rgba(255,255,255,.1);
    color: rgba(255,255,255,.4);
    font: 400 16px/1 var(--fi);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    z-index: 30;
    transition: opacity .4s cubic-bezier(.25,0,0,1), color .3s cubic-bezier(.25,0,0,1);
  }

  .scroll-top.visible { opacity: .5; pointer-events: auto; }
  .scroll-top:hover { opacity: .8; color: rgba(255,255,255,.8); }

  /* ═══════ TABLET ═══════ */
  @media (max-width: 1024px) {
    .ct-grid[data-view="grid"] { grid-template-columns: repeat(2, 1fr); }
    .ct-grid[data-view="grid"] .dc-lead { grid-column: span 2; }
    .ct-grid[data-view="list"] .dc { grid-template-columns: 80px 1fr 90px; }
    .ct-grid[data-view="list"] .dc-sub { display: none; }
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 640px) {
    .hero { padding: 88px 24px 0; }
    .tb { padding: 0 24px; }
    .tb-search { width: auto; flex: 1; }
    .tb-sel { display: none; }
    .ct { padding: 24px 24px 0; }

    .ct-grid[data-view="grid"] { grid-template-columns: 1fr; }
    .ct-grid[data-view="grid"] .dc-lead { grid-column: span 1; padding: 28px 24px; }
    .ct-grid[data-view="grid"] .dc-lead .dc-name { font-size: 18px; }

    .ct-grid[data-view="list"] .dc {
      grid-template-columns: 1fr auto;
      gap: 8px;
    }
    .ct-grid[data-view="list"] .dc-type { display: none; }
    .ct-grid[data-view="list"] .dc-sub { display: none; }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .dc, .tb-q, .vbtn, .ct-empty-btn, .ct-more-btn, .ct-closing-btn, .scroll-top, .ct-grid {
      transition: none !important;
    }
    .ct-grid[data-view="grid"] .dc { opacity: 1; transform: none; }
    .vbtn.active::after { animation: none; }
  }
</style>

<script>
  function initCatalog() {
    var grid = document.getElementById('grid');
    var input = document.getElementById('q');
    var hint = document.getElementById('qHint');
    var emptyEl = document.getElementById('empty');
    var resetBtn = document.getElementById('resetBtn');
    var cntEl = document.getElementById('cntN');
    var catSel = document.getElementById('catSel');
    var sortSel = document.getElementById('sortSel');
    var moreBtn = document.getElementById('moreBtn');
    var moreWrap = document.getElementById('moreWrap');
    var scrollTopBtn = document.getElementById('scrollTop');
    var viewBtns = document.querySelectorAll('.vbtn');

    if (!grid || !input) return;

    var docs = Array.from(grid.querySelectorAll('.dc'));
    var query = '';
    var cat = 'all';
    var sort = 'default';
    var timer = 0;
    var showAll = false;
    var BATCH = 30;

    var qp = new URLSearchParams(window.location.search).get('q');
    if (qp) { input.value = qp; query = qp.toLowerCase(); showAll = true; }

    /* Stagger reveal for initial cards */
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduced) {
      docs.forEach(function(el, i) {
        if (i < BATCH) {
          setTimeout(function() { el.classList.add('revealed'); }, i * 40);
        }
      });
    } else {
      docs.forEach(function(el) { el.classList.add('revealed'); });
    }

    /* Search */
    input.addEventListener('input', function() {
      clearTimeout(timer);
      timer = setTimeout(function() {
        query = input.value.toLowerCase().trim();
        if (query) showAll = true;
        run();
      }, 200);
    });

    input.addEventListener('focus', function() { if (hint) hint.style.display = 'none'; });
    input.addEventListener('blur', function() { if (hint && !input.value) hint.style.display = ''; });

    /* Category */
    if (catSel) catSel.addEventListener('change', function() {
      cat = catSel.value;
      if (cat !== 'all') showAll = true;
      run();
    });

    /* Sort */
    if (sortSel) sortSel.addEventListener('change', function() {
      sort = sortSel.value;
      doSort(); run();
    });

    /* View switch with fade */
    viewBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var v = btn.dataset.view;
        if (grid.getAttribute('data-view') === v) return;
        viewBtns.forEach(function(b) { b.classList.toggle('active', b.dataset.view === v); });
        grid.classList.add('switching');
        setTimeout(function() {
          grid.setAttribute('data-view', v);
          grid.classList.remove('switching');
        }, 200);
      });
    });

    /* Load more */
    if (moreBtn) {
      moreBtn.addEventListener('click', function() {
        showAll = true;
        run();
        docs.forEach(function(el) { el.classList.add('revealed'); });
      });
    }

    /* Reset */
    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        input.value = ''; query = ''; cat = 'all'; sort = 'default'; showAll = false;
        if (catSel) catSel.value = 'all';
        if (sortSel) sortSel.value = 'default';
        run();
      });
    }

    /* Keyboard */
    document.addEventListener('keydown', function(e) {
      var tag = e.target.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') {
        if (e.key === 'Escape') { input.blur(); input.value = ''; query = ''; run(); }
        return;
      }
      if (e.key === '/') { e.preventDefault(); input.focus(); }
    });

    /* Scroll to top */
    if (scrollTopBtn) {
      var stTicking = false;
      window.addEventListener('scroll', function() {
        if (!stTicking) {
          requestAnimationFrame(function() {
            scrollTopBtn.classList.toggle('visible', window.scrollY > 500);
            stTicking = false;
          });
          stTicking = true;
        }
      }, { passive: true });

      scrollTopBtn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    function parseSize(s) {
      if (!s) return 0;
      var m = s.match(/([\d.,]+)\s*(МБ|MB|КБ|KB|Б|B)?/i);
      if (!m) return 0;
      var v = parseFloat(m[1].replace(',', '.'));
      var u = (m[2] || '').toUpperCase();
      if (u === 'КБ' || u === 'KB') v *= 1024;
      if (u === 'МБ' || u === 'MB') v *= 1048576;
      return v;
    }

    function doSort() {
      var arr = docs.slice();
      if (sort === 'az') arr.sort(function(a,b) { return (a.dataset.t||'').localeCompare(b.dataset.t||'','ru'); });
      else if (sort === 'za') arr.sort(function(a,b) { return (b.dataset.t||'').localeCompare(a.dataset.t||'','ru'); });
      else if (sort === 'size') arr.sort(function(a,b) { return parseSize(b.dataset.z||'') - parseSize(a.dataset.z||''); });
      else arr.sort(function(a,b) { return parseInt(a.dataset.i||'0') - parseInt(b.dataset.i||'0'); });
      arr.forEach(function(el) { grid.appendChild(el); });
    }

    function run() {
      var n = 0;
      var shown = 0;
      docs.forEach(function(el) {
        var ok = true;
        if (cat !== 'all' && el.dataset.c !== cat) ok = false;
        if (ok && query) {
          var h = [el.dataset.t, el.dataset.d, (el.dataset.c||'').toLowerCase(), el.dataset.s, el.dataset.k, el.dataset.g].join(' ');
          var words = query.split(/\s+/);
          ok = words.every(function(w) { return h.includes(w); });
        }
        if (ok) {
          n++;
          if (showAll || n <= BATCH) {
            el.classList.remove('hidden');
            el.style.display = '';
            el.classList.add('revealed');
            shown++;
          } else {
            el.style.display = 'none';
          }
        } else {
          el.classList.add('hidden');
          el.style.display = '';
        }
      });
      if (cntEl) cntEl.textContent = String(n);
      if (emptyEl) emptyEl.style.display = n === 0 ? 'block' : 'none';
      if (moreWrap) moreWrap.style.display = (!showAll && n > BATCH) ? 'block' : 'none';
    }

    run();
  }

  initCatalog();
  document.addEventListener('astro:after-swap', initCatalog);
</script>
