---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const totalDocs = D.length;
const currentYear = String(new Date().getFullYear());

const categoryMap: Record<string, string> = {
  'ВКР и дипломы': 'ВКР',
  'Курсовые работы': 'Курсовые',
  'Курсовые': 'Курсовые',
  'Рефераты': 'Рефераты',
  'Отчёты по практике': 'Практика',
  'Самостоятельные работы': 'Самостоятельные',
  'Методические материалы': 'Методички',
};

const categories = [...new Set(D.map((d: any) => d.category).filter(Boolean))].sort();

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const m = blob.match(/(?:19|20)\d{2}/);
  return m ? m[0] : currentYear;
}
---

<Base title="Каталог — Академический Салон" currentPath="/catalog">

  <!-- Header -->
  <header class="ch">
    <h1 class="ch-title">Каталог</h1>
    <p class="ch-count"><span id="cntN">{totalDocs}</span> документов</p>
    <div class="ch-search">
      <input type="text" id="q" class="ch-input" placeholder="Название, тема, предмет..." autocomplete="off" />
      <kbd class="ch-kbd" id="qHint">/</kbd>
    </div>
  </header>

  <!-- Filter bar (sticky) -->
  <div class="fb" id="filterBar">
    <div class="fb-inner">
      <nav class="fb-cats" id="cats">
        <button class="fb-cat active" data-cat="all">Все</button>
        {categories.map(c => (
          <button class="fb-cat" data-cat={c}>{categoryMap[c] || c}</button>
        ))}
      </nav>
      <div class="fb-right">
        <select class="fb-sort" id="sortSel">
          <option value="default">По умолчанию</option>
          <option value="az">А — Я</option>
          <option value="za">Я — А</option>
          <option value="size">По размеру</option>
        </select>
        <div class="fb-views">
          <button class="fb-view active" data-view="grid" title="Сетка" aria-label="Сетка">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2"><rect x=".5" y=".5" width="5" height="5"/><rect x="8.5" y=".5" width="5" height="5"/><rect x=".5" y="8.5" width="5" height="5"/><rect x="8.5" y="8.5" width="5" height="5"/></svg>
          </button>
          <button class="fb-view" data-view="list" title="Список" aria-label="Список">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2"><line x1="0" y1="2.5" x2="14" y2="2.5"/><line x1="0" y1="7" x2="14" y2="7"/><line x1="0" y1="11.5" x2="14" y2="11.5"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Grid -->
  <main class="cg">
    <div class="cg-grid" id="grid" data-view="grid">
      {D.map((doc: any, i: number) => {
        const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
        const desc = doc.catalogDescription || doc.description || '';
        const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
        const docType = doc.docType || doc.category || '';
        const subject = doc.subject || '';
        const year = extractYear(doc);
        return (
          <a
            href={`/doc/${doc.file}`}
            class="dc"
            data-t={title.toLowerCase()}
            data-d={desc.toLowerCase()}
            data-c={doc.category || ''}
            data-s={(doc.subject || '').toLowerCase()}
            data-k={(doc.course || '').toLowerCase()}
            data-g={(doc.tags || []).join(' ').toLowerCase()}
            data-z={doc.size || ''}
            data-i={i}
          >
            <span class="dc-type">{docType}</span>
            <h3 class="dc-title">{title}</h3>
            <span class="dc-sub">{subject}{subject && year ? ' · ' : ''}{year}</span>
            <span class="dc-file">{ext} {doc.size ? '· ' + doc.size : ''}</span>
          </a>
        );
      })}
    </div>

    <!-- Empty -->
    <div class="cg-empty" id="empty" style="display:none">
      <p class="cg-empty-t">Ничего не найдено</p>
      <p class="cg-empty-h">Попробуйте изменить запрос или категорию</p>
      <button class="cg-empty-btn" id="resetBtn">Сбросить фильтры</button>
    </div>
  </main>

</Base>

<style>
  /* ═══════ HEADER ═══════ */
  .ch {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 120px 48px 0;
    text-align: center;
  }

  .ch-title {
    font: 300 clamp(36px, 6vw, 48px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  .ch-count {
    margin-top: 14px;
    font: 400 11px/1 var(--fm);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--t3);
    opacity: .4;
    font-variant-numeric: tabular-nums;
  }

  .ch-search {
    position: relative;
    max-width: 640px;
    margin: 40px auto 0;
  }

  .ch-input {
    width: 100%;
    padding: 16px 0;
    border: none;
    border-bottom: 1px solid rgba(201,165,90,.1);
    background: transparent;
    color: var(--t1);
    font: 300 italic 18px/1.3 var(--fd);
    letter-spacing: .01em;
    outline: none;
    transition: border-color .4s cubic-bezier(.25,0,0,1);
  }

  .ch-input::placeholder {
    color: var(--t3);
    opacity: .3;
    font-style: italic;
  }

  .ch-input:focus {
    border-bottom-color: rgba(201,165,90,.35);
  }

  .ch-input:focus ~ .ch-kbd { display: none; }

  .ch-kbd {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    opacity: .2;
    border: 1px solid rgba(201,165,90,.08);
    padding: 3px 7px;
    pointer-events: none;
  }

  /* ═══════ FILTER BAR ═══════ */
  .fb {
    position: sticky;
    top: var(--nav-h);
    z-index: 40;
    background: var(--bg);
    border-bottom: 1px solid rgba(201,165,90,.06);
    padding: 0 48px;
    margin-top: 40px;
  }

  .fb-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    height: 48px;
    gap: 24px;
  }

  .fb-cats {
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    flex: 1;
    min-width: 0;
  }

  .fb-cats::-webkit-scrollbar { display: none; }

  .fb-cat {
    flex-shrink: 0;
    padding: 6px 14px;
    background: none;
    border: none;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t1);
    opacity: .3;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity .3s cubic-bezier(.25,0,0,1);
  }

  .fb-cat:hover { opacity: .6; }
  .fb-cat.active { opacity: 1; }

  .fb-right {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  .fb-sort {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: none;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--t1);
    opacity: .4;
    cursor: pointer;
    padding: 4px 0;
  }

  .fb-sort:focus { outline: none; opacity: .7; }

  .fb-views {
    display: flex;
    gap: 2px;
  }

  .fb-view {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--t3);
    opacity: .25;
    cursor: pointer;
    transition: opacity .3s cubic-bezier(.25,0,0,1);
  }

  .fb-view:hover { opacity: .5; }
  .fb-view.active { opacity: 1; color: var(--t1); }

  /* ═══════ CONTENT ═══════ */
  .cg {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 48px 120px;
  }

  /* ── GRID VIEW ── */
  .cg-grid[data-view="grid"] {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(201,165,90,.04);
    margin-top: 0;
  }

  .cg-grid[data-view="grid"] .dc {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    aspect-ratio: 4 / 3;
    padding: 24px;
    background: rgba(255,255,255,.018);
    text-decoration: none;
    color: inherit;
    transition: background .5s cubic-bezier(.25,0,0,1);
  }

  .cg-grid[data-view="grid"] .dc:hover {
    background: rgba(255,255,255,.04);
  }

  .cg-grid[data-view="grid"] .dc-file {
    position: absolute;
    bottom: 12px;
    right: 16px;
  }

  .cg-grid[data-view="grid"] .dc {
    position: relative;
  }

  /* ── LIST VIEW ── */
  .cg-grid[data-view="list"] {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    margin-top: 0;
  }

  .cg-grid[data-view="list"] .dc {
    display: grid;
    grid-template-columns: 100px 1fr 180px 80px;
    align-items: baseline;
    gap: 20px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(201,165,90,.04);
    text-decoration: none;
    color: inherit;
    transition: background .5s cubic-bezier(.25,0,0,1);
  }

  .cg-grid[data-view="list"] .dc:hover {
    background: rgba(255,255,255,.02);
  }

  .cg-grid[data-view="list"] .dc-title {
    font: 400 15px/1.35 var(--fi);
    -webkit-line-clamp: 1;
  }

  .cg-grid[data-view="list"] .dc-sub {
    text-align: right;
  }

  .cg-grid[data-view="list"] .dc-file {
    text-align: right;
  }

  /* ── Shared doc elements ── */
  .dc.hidden { display: none !important; }

  .dc-type {
    font: 400 10px/1 var(--fm);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--ac);
    opacity: .6;
    margin-bottom: 10px;
  }

  .dc-title {
    font: 400 clamp(16px, 2vw, 20px)/1.3 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 8px;
  }

  .dc-sub {
    font: 400 12px/1.3 var(--fi);
    color: var(--t3);
    opacity: .3;
  }

  .dc-file {
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    opacity: .2;
    margin-top: 4px;
  }

  /* ═══════ EMPTY ═══════ */
  .cg-empty {
    text-align: center;
    padding: 120px 24px;
  }

  .cg-empty-t {
    font: 300 italic clamp(22px, 4vw, 32px)/1.2 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    opacity: .6;
  }

  .cg-empty-h {
    margin-top: 12px;
    font: 400 13px/1.5 var(--fi);
    color: var(--t3);
    opacity: .35;
  }

  .cg-empty-btn {
    margin-top: 28px;
    background: none;
    border: .5px solid rgba(201,165,90,.15);
    padding: 12px 36px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t1);
    opacity: .6;
    cursor: pointer;
    transition: opacity .4s cubic-bezier(.25,0,0,1), border-color .4s cubic-bezier(.25,0,0,1);
  }

  .cg-empty-btn:hover { opacity: 1; border-color: rgba(201,165,90,.3); }

  /* ═══════ TABLET ═══════ */
  @media (max-width: 1024px) {
    .cg-grid[data-view="grid"] { grid-template-columns: repeat(2, 1fr); }

    .cg-grid[data-view="list"] .dc {
      grid-template-columns: 80px 1fr 80px;
    }

    .cg-grid[data-view="list"] .dc-sub { display: none; }
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 640px) {
    .ch { padding: 96px 24px 0; }
    .fb { padding: 0 24px; }
    .cg { padding: 0 24px 80px; }

    .fb-cats { scroll-snap-type: x mandatory; }
    .fb-cat { scroll-snap-align: start; }

    .fb-views .fb-view[data-view="list"] { display: none; }

    .cg-grid[data-view="grid"] { grid-template-columns: 1fr; }

    .cg-grid[data-view="list"] .dc {
      grid-template-columns: 1fr auto;
      gap: 8px;
    }

    .cg-grid[data-view="list"] .dc-type { display: none; }
    .cg-grid[data-view="list"] .dc-sub { display: none; }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .dc, .ch-input, .fb-cat, .fb-view, .cg-empty-btn {
      transition: none !important;
    }
  }
</style>

<script>
  function initCatalog() {
    var grid = document.getElementById('grid');
    var input = document.getElementById('q');
    var hint = document.getElementById('qHint');
    var emptyEl = document.getElementById('empty');
    var resetBtn = document.getElementById('resetBtn');
    var cntEl = document.getElementById('cntN');
    var sortSel = document.getElementById('sortSel');

    if (!grid || !input) return;

    var docs = Array.from(grid.querySelectorAll('.dc'));
    var catBtns = document.querySelectorAll('.fb-cat');
    var viewBtns = document.querySelectorAll('.fb-view');

    var query = '';
    var cat = 'all';
    var sort = 'default';
    var timer = 0;

    /* URL param */
    var qp = new URLSearchParams(window.location.search).get('q');
    if (qp) { input.value = qp; query = qp.toLowerCase(); }

    /* Search (debounced 200ms) */
    input.addEventListener('input', function() {
      clearTimeout(timer);
      timer = setTimeout(function() {
        query = input.value.toLowerCase().trim();
        run();
      }, 200);
    });

    input.addEventListener('focus', function() { if (hint) hint.style.display = 'none'; });
    input.addEventListener('blur', function() { if (hint && !input.value) hint.style.display = ''; });

    /* Categories */
    catBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        catBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        cat = btn.dataset.cat || 'all';
        run();
      });
    });

    /* Sort */
    if (sortSel) {
      sortSel.addEventListener('change', function() {
        sort = sortSel.value;
        doSort();
        run();
      });
    }

    /* View switch */
    viewBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        viewBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        grid.setAttribute('data-view', btn.dataset.view);
      });
    });

    /* Reset */
    if (resetBtn) {
      resetBtn.addEventListener('click', function() {
        input.value = '';
        query = '';
        cat = 'all';
        sort = 'default';
        if (sortSel) sortSel.value = 'default';
        catBtns.forEach(function(b) { b.classList.remove('active'); });
        var a = document.querySelector('.fb-cat[data-cat="all"]');
        if (a) a.classList.add('active');
        run();
      });
    }

    /* Keyboard */
    document.addEventListener('keydown', function(e) {
      var tag = e.target.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') {
        if (e.key === 'Escape') { input.blur(); input.value = ''; query = ''; run(); }
        return;
      }
      if (e.key === '/') { e.preventDefault(); input.focus(); }
    });

    function parseSize(s) {
      if (!s) return 0;
      var m = s.match(/([\d.,]+)\s*(МБ|MB|КБ|KB|Б|B)?/i);
      if (!m) return 0;
      var v = parseFloat(m[1].replace(',', '.'));
      var u = (m[2] || '').toUpperCase();
      if (u === 'КБ' || u === 'KB') v *= 1024;
      if (u === 'МБ' || u === 'MB') v *= 1048576;
      return v;
    }

    function doSort() {
      var arr = docs.slice();
      if (sort === 'az') arr.sort(function(a,b) { return (a.dataset.t||'').localeCompare(b.dataset.t||'','ru'); });
      else if (sort === 'za') arr.sort(function(a,b) { return (b.dataset.t||'').localeCompare(a.dataset.t||'','ru'); });
      else if (sort === 'size') arr.sort(function(a,b) { return parseSize(b.dataset.z||'') - parseSize(a.dataset.z||''); });
      else arr.sort(function(a,b) { return parseInt(a.dataset.i||'0') - parseInt(b.dataset.i||'0'); });
      arr.forEach(function(el) { grid.appendChild(el); });
    }

    function run() {
      var n = 0;
      docs.forEach(function(el) {
        var ok = true;
        if (cat !== 'all' && el.dataset.c !== cat) ok = false;
        if (ok && query) {
          var h = [el.dataset.t, el.dataset.d, (el.dataset.c||'').toLowerCase(), el.dataset.s, el.dataset.k, el.dataset.g].join(' ');
          var words = query.split(/\s+/);
          ok = words.every(function(w) { return h.includes(w); });
        }
        if (ok) { el.classList.remove('hidden'); n++; }
        else { el.classList.add('hidden'); }
      });
      if (cntEl) cntEl.textContent = String(n);
      if (emptyEl) emptyEl.style.display = n === 0 ? 'block' : 'none';
    }

    run();
  }

  initCatalog();
  document.addEventListener('astro:after-swap', initCatalog);
</script>
