---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const total = D.length;
const year = String(new Date().getFullYear());
const BATCH = 30;

const categories = [...new Set(D.map((d: any) => d.category).filter(Boolean))].sort();

const shortType: Record<string, string> = {
  'Самостоятельная работа': 'Самостоятельная',
  'Выпускная квалификационная работа': 'ВКР',
  'Экзаменационные материалы': 'Экзамен',
  'Контрольная работа': 'Контрольная',
  'Курсовая работа': 'Курсовая',
  'Отчет по практике': 'Отчёт',
  'Отчет о научно-практической работе': 'НПР',
  'Справочный материал': 'Справочник',
  'Нормативный документ': 'Нормативный',
  'Учебный документ': 'Учебный',
  'Шаблон документа': 'Шаблон',
  'Аналитический документ': 'Аналитика',
  'Практическое задание': 'Практическое',
  'Методические материалы': 'Методичка',
  'Учебная работа': 'Учебная',
  'Учебный материал': 'Учебный',
};

const catBorder: Record<string, string> = {
  'ВКР и дипломы': 'gold',
  'Курсовые': 'blue',
  'Рефераты': 'purple',
  'Эссе': 'purple',
  'Отчёты по практике': 'green',
  'НПР': 'blue',
  'Конспекты лекций': 'green',
};

function getYear(doc: any) {
  const s = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const m = s.match(/(?:19|20)\d{2}/);
  return m ? m[0] : year;
}
---

<Base title="Каталог — Академический Салон" currentPath="/catalog">

  <div class="page">
    <!-- Header line -->
    <div class="hdr">
      <h1 class="hdr-t">Каталог</h1>
      <span class="hdr-n" id="cnt">{total}</span>
    </div>

    <!-- Toolbar (NOT sticky — scrolls with page) -->
    <div class="bar">
      <div class="bar-q">
        <input type="text" id="q" placeholder="Поиск..." autocomplete="off" />
        <kbd id="hint">/</kbd>
      </div>
      <select class="bar-sel" id="cat">
        <option value="all">Все категории</option>
        {categories.map(c => <option value={c}>{c}</option>)}
      </select>
      <select class="bar-sel" id="sort">
        <option value="default">По умолчанию</option>
        <option value="az">А — Я</option>
        <option value="za">Я — А</option>
        <option value="size">По размеру</option>
      </select>
      <div class="bar-v">
        <button class="vb active" data-v="grid" aria-label="Сетка">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.3"><rect x="1" y="1" width="6" height="6"/><rect x="11" y="1" width="6" height="6"/><rect x="1" y="11" width="6" height="6"/><rect x="11" y="11" width="6" height="6"/></svg>
        </button>
        <button class="vb" data-v="list" aria-label="Список">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.3"><line x1="1" y1="3.5" x2="17" y2="3.5"/><line x1="1" y1="9" x2="17" y2="9"/><line x1="1" y1="14.5" x2="17" y2="14.5"/></svg>
        </button>
      </div>
    </div>

    <!-- Cards -->
    <div class="g" id="g" data-v="grid">
      {D.map((doc: any, i: number) => {
        const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
        const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
        const rawType = doc.docType || doc.category || '';
        const type = shortType[rawType] || rawType;
        const subj = doc.subject || '';
        const yr = getYear(doc);
        const left = [subj, yr].filter(Boolean).join(' · ');
        const right = [ext, doc.size].filter(Boolean).join(' · ');
        const clr = catBorder[doc.category] || '';
        return (
          <a
            href={`/doc/${doc.file}`}
            class="c"
            data-clr={clr}
            data-t={title.toLowerCase()}
            data-d={(doc.catalogDescription || doc.description || '').toLowerCase()}
            data-c={doc.category || ''}
            data-s={subj.toLowerCase()}
            data-k={(doc.course || '').toLowerCase()}
            data-g={(doc.tags || []).join(' ').toLowerCase()}
            data-z={doc.size || ''}
            data-i={i}
          >
            <span class="c-type">{type}</span>
            <h3 class="c-name">{title}</h3>
            <div class="c-bot">
              <span class="c-left">{left}</span>
              <span class="c-right">{right}</span>
            </div>
          </a>
        );
      })}
    </div>

    <!-- Load more -->
    <div class="more" id="more">
      <button id="moreBtn"><em>Ещё</em></button>
    </div>

    <!-- Empty -->
    <div class="nil" id="nil" style="display:none">
      <p class="nil-t">Ничего не найдено</p>
      <button class="nil-btn" id="resetBtn">Сбросить</button>
    </div>

    <!-- Closing -->
    <div class="end">
      <p class="end-t">Не нашли нужную работу?</p>
      <a href="/order" class="end-btn">Заказать</a>
    </div>

    <!-- Footer line -->
    <div class="ftr">
      <nav class="ftr-links">
        <a href="/catalog">Каталог</a>
        <a href="/order">Заказать</a>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
      </nav>
      <span class="ftr-copy">© 2022–2026</span>
    </div>
  </div>

</Base>

<style>
  :global(.footer) { display: none; }

  .page {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 48px 48px 0;
  }

  /* ═══════ HEADER ═══════ */
  .hdr {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: 32px;
  }

  .hdr-t {
    font: 300 28px/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  .hdr-n {
    font: 400 14px/1 var(--fm);
    color: var(--t3);
    font-variant-numeric: tabular-nums;
  }

  /* ═══════ TOOLBAR ═══════ */
  .bar {
    display: flex;
    align-items: center;
    gap: 24px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--brd);
  }

  .bar-q {
    flex: 1;
    max-width: 50%;
    position: relative;
  }

  .bar-q input {
    width: 100%;
    padding: 10px 0;
    border: none;
    border-bottom: 1px solid var(--brd);
    background: transparent;
    color: var(--t1);
    font: 400 14px/1.3 var(--fi);
    outline: none;
    transition: border-color .4s cubic-bezier(.25,0,0,1);
  }

  .bar-q input::placeholder { color: var(--t3); }
  .bar-q input:focus { border-bottom-color: rgba(212,175,55,.2); }
  .bar-q input:focus ~ kbd { display: none; }

  .bar-q kbd {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    border: 1px solid var(--brd);
    padding: 2px 6px;
    border-radius: 4px;
    pointer-events: none;
  }

  .bar-sel {
    appearance: none;
    -webkit-appearance: none;
    background: none;
    border: none;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    cursor: pointer;
    outline: none;
    transition: color .3s cubic-bezier(.25,0,0,1);
  }

  .bar-sel:hover, .bar-sel:focus { color: var(--t1); }
  .bar-sel option { background: var(--bg); color: var(--t1); }

  .bar-v {
    display: flex;
    gap: 4px;
    margin-left: auto;
  }

  .vb {
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--t3);
    cursor: pointer;
    transition: color .3s cubic-bezier(.25,0,0,1);
  }

  .vb:hover { color: var(--t2); }
  .vb.active { color: var(--t1); }

  /* ═══════ GRID VIEW ═══════ */
  .g[data-v="grid"] {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    padding-top: 32px;
  }

  .g[data-v="grid"] .c {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px 22px;
    background: var(--card);
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    text-decoration: none;
    color: inherit;
    opacity: 0;
    transform: translateY(8px);
    transition:
      background .4s cubic-bezier(.25,0,0,1),
      border-color .4s cubic-bezier(.25,0,0,1),
      box-shadow .5s cubic-bezier(.25,0,0,1),
      transform .4s cubic-bezier(.25,0,0,1),
      opacity .4s cubic-bezier(.25,0,0,1);
  }

  .g[data-v="grid"] .c.vis {
    opacity: 1;
    transform: translateY(0);
  }

  .g[data-v="grid"] .c:hover {
    background: var(--card-h);
    border-color: rgba(212,175,55,.15);
    box-shadow: 0 8px 32px rgba(212,175,55,.04);
    transform: translateY(-3px);
  }

  .g[data-v="grid"] .c:hover .c-name { color: var(--ac3); }

  /* ═══════ LIST VIEW ═══════ */
  .g[data-v="list"] {
    display: flex;
    flex-direction: column;
    padding-top: 32px;
  }

  .g[data-v="list"] .c {
    display: grid;
    grid-template-columns: 90px 1fr auto auto;
    align-items: baseline;
    gap: 16px;
    padding: 14px 0 14px 8px;
    border-bottom: 1px solid var(--brd);
    text-decoration: none;
    color: inherit;
    transition: background .5s cubic-bezier(.25,0,0,1);
  }

  .g[data-v="list"] .c:hover { background: var(--card); }
  .g[data-v="list"] .c:hover .c-name { color: var(--ac3); }

  .g[data-v="list"] .c-name {
    font: 400 14px/1.35 var(--fi);
    -webkit-line-clamp: 1;
  }

  .g[data-v="list"] .c-bot { display: contents; }
  .g[data-v="list"] .c-left { text-align: right; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .g[data-v="list"] .c-right { text-align: right; white-space: nowrap; }

  /* ═══════ SEARCH HIGHLIGHT ═══════ */
  .hl {
    background: rgba(212,175,55,.2);
    color: var(--ac3);
    border-radius: 2px;
    padding: 0 2px;
  }

  /* ═══════ TILT ═══════ */
  .g[data-v="grid"] .c {
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* ═══════ SHARED CARD ═══════ */
  .c.hid { display: none !important; }

  .c-type {
    font: 500 9px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--ac);
    opacity: .6;
  }

  .c-name {
    font: 400 18px/1.35 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .c-bot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-top: auto;
  }

  .c-left {
    font: 400 11px/1.3 var(--fi);
    color: var(--t3);
  }

  .c-right {
    font: 400 11px/1 var(--fm);
    color: var(--t3);
    opacity: .6;
    flex-shrink: 0;
  }

  /* ═══════ MORE / EMPTY / CLOSING ═══════ */
  .more {
    text-align: center;
    padding: 48px 0;
  }

  .more button {
    background: none;
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    padding: 14px 56px;
    cursor: pointer;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    transition: border-color .4s cubic-bezier(.25,0,0,1), color .4s cubic-bezier(.25,0,0,1);
  }

  .more button em {
    font-style: normal;
  }

  .more button:hover { border-color: var(--brd-h); color: var(--t1); }

  .nil {
    text-align: center;
    padding: 96px 24px;
  }

  .nil-t {
    font: 300 22px/1.3 var(--fd);
    color: var(--t2);
  }

  .nil-btn {
    margin-top: 20px;
    background: none;
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    padding: 10px 32px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    cursor: pointer;
    transition: color .4s cubic-bezier(.25,0,0,1), border-color .4s cubic-bezier(.25,0,0,1);
  }

  .nil-btn:hover { color: var(--t1); border-color: var(--brd-h); }

  .end {
    text-align: center;
    padding: 80px 24px 0;
  }

  .end-t {
    font: 300 24px/1.3 var(--fd);
    color: var(--t2);
  }

  .end-btn {
    display: inline-block;
    margin-top: 24px;
    padding: 14px 48px;
    border: 1px solid rgba(212,175,55,.2);
    border-radius: var(--rx);
    background: rgba(212,175,55,.06);
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t1);
    text-decoration: none;
    transition: all .4s cubic-bezier(.25,0,0,1);
  }

  .end-btn:hover {
    background: rgba(212,175,55,.1);
    border-color: rgba(212,175,55,.35);
    box-shadow: 0 8px 32px rgba(212,175,55,.06);
    transform: translateY(-2px);
  }

  /* ═══════ FOOTER LINE ═══════ */
  .ftr {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 64px 0 48px;
    border-top: 1px solid var(--brd);
    margin-top: 64px;
  }

  .ftr-links {
    display: flex;
    gap: 24px;
  }

  .ftr-links a {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .ftr-links a:hover { color: var(--t1); }

  .ftr-copy {
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    opacity: .4;
    letter-spacing: .1em;
  }

  /* ═══════ TABLET ═══════ */
  @media (max-width: 1024px) {
    .g[data-v="grid"] { grid-template-columns: repeat(2, 1fr); }
    .g[data-v="list"] .c { grid-template-columns: 80px 1fr 90px; }
    .g[data-v="list"] .c-left { display: none; }
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 640px) {
    .page { padding: 32px 20px 0; }

    .bar {
      flex-wrap: wrap;
      gap: 12px;
    }

    .bar-q { max-width: 100%; flex-basis: 100%; }

    .g[data-v="grid"] { grid-template-columns: 1fr; gap: 12px; }

    .g[data-v="list"] .c {
      grid-template-columns: 1fr auto;
      gap: 8px;
    }

    .g[data-v="list"] .c-type { display: none; }
    .g[data-v="list"] .c-left { display: none; }

    .ftr { flex-direction: column; gap: 16px; align-items: center; }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .c, .bar-q input, .bar-sel, .vb, .nil-btn, .end-btn, .more button {
      transition: none !important;
    }
    .g[data-v="grid"] .c { opacity: 1; transform: none; }
  }
</style>

<script>
  function init() {
    var grid = document.getElementById('g');
    var input = document.getElementById('q');
    var hint = document.getElementById('hint');
    var nil = document.getElementById('nil');
    var resetBtn = document.getElementById('resetBtn');
    var cntEl = document.getElementById('cnt');
    var catSel = document.getElementById('cat');
    var sortSel = document.getElementById('sort');
    var moreBtn = document.getElementById('moreBtn');
    var moreWrap = document.getElementById('more');
    var vBtns = document.querySelectorAll('.vb');

    if (!grid || !input) return;

    var cards = Array.from(grid.querySelectorAll('.c'));
    var q = '', cat = 'all', srt = 'default';
    var shown = 30, step = 30, all = false, timer = 0;
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* URL param */
    var qp = new URLSearchParams(window.location.search).get('q');
    if (qp) { input.value = qp; q = qp.toLowerCase(); all = true; }

    /* Initial reveal */
    cards.forEach(function(el, i) {
      if (i >= shown) { el.style.display = 'none'; return; }
      if (reduced) { el.classList.add('vis'); return; }
      setTimeout(function() { el.classList.add('vis'); }, i * 30);
    });

    /* Search */
    input.addEventListener('input', function() {
      clearTimeout(timer);
      timer = setTimeout(function() {
        q = input.value.toLowerCase().trim();
        if (q) all = true;
        run();
      }, 200);
    });

    input.addEventListener('focus', function() { if (hint) hint.style.display = 'none'; });
    input.addEventListener('blur', function() { if (hint && !input.value) hint.style.display = ''; });

    /* Dropdowns */
    if (catSel) catSel.addEventListener('change', function() {
      cat = catSel.value;
      if (cat !== 'all') all = true;
      run();
    });

    if (sortSel) sortSel.addEventListener('change', function() {
      srt = sortSel.value;
      doSort();
      run();
    });

    /* Views */
    vBtns.forEach(function(b) {
      b.addEventListener('click', function() {
        vBtns.forEach(function(x) { x.classList.remove('active'); });
        b.classList.add('active');
        grid.setAttribute('data-v', b.dataset.v);
      });
    });

    /* More */
    if (moreBtn) moreBtn.addEventListener('click', function() {
      shown += step;
      run();
      /* Reveal newly visible */
      cards.forEach(function(el) {
        if (!el.classList.contains('hid') && el.style.display !== 'none') {
          el.classList.add('vis');
        }
      });
    });

    /* Reset */
    if (resetBtn) resetBtn.addEventListener('click', function() {
      input.value = ''; q = ''; cat = 'all'; srt = 'default'; all = false; shown = step;
      if (catSel) catSel.value = 'all';
      if (sortSel) sortSel.value = 'default';
      run();
    });

    /* Keyboard */
    document.addEventListener('keydown', function(e) {
      var tag = e.target.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') {
        if (e.key === 'Escape') { input.blur(); input.value = ''; q = ''; run(); }
        return;
      }
      if (e.key === '/') { e.preventDefault(); input.focus(); }
    });

    function parseSize(s) {
      if (!s) return 0;
      var m = s.match(/([\d.,]+)\s*(МБ|MB|КБ|KB|Б|B)?/i);
      if (!m) return 0;
      var v = parseFloat(m[1].replace(',', '.'));
      var u = (m[2] || '').toUpperCase();
      if (u === 'КБ' || u === 'KB') v *= 1024;
      if (u === 'МБ' || u === 'MB') v *= 1048576;
      return v;
    }

    function doSort() {
      var a = cards.slice();
      if (srt === 'az') a.sort(function(x,y) { return (x.dataset.t||'').localeCompare(y.dataset.t||'','ru'); });
      else if (srt === 'za') a.sort(function(x,y) { return (y.dataset.t||'').localeCompare(x.dataset.t||'','ru'); });
      else if (srt === 'size') a.sort(function(x,y) { return parseSize(y.dataset.z||'') - parseSize(x.dataset.z||''); });
      else a.sort(function(x,y) { return parseInt(x.dataset.i||'0') - parseInt(y.dataset.i||'0'); });
      a.forEach(function(el) { grid.appendChild(el); });
    }

    /* Store original titles for highlight restore */
    var origTitles = new Map();
    cards.forEach(function(el) {
      var nameEl = el.querySelector('.c-name');
      if (nameEl) origTitles.set(el, nameEl.textContent);
    });

    function highlight(el) {
      var nameEl = el.querySelector('.c-name');
      if (!nameEl) return;
      var orig = origTitles.get(el) || nameEl.textContent;
      if (!q) { nameEl.innerHTML = orig; return; }
      var words = q.split(/\s+/).filter(Boolean);
      var html = orig;
      words.forEach(function(w) {
        var re = new RegExp('(' + w.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
        html = html.replace(re, '<mark class="hl">$1</mark>');
      });
      nameEl.innerHTML = html;
    }

    function run() {
      var n = 0, vis = 0;
      cards.forEach(function(el) {
        var ok = true;
        if (cat !== 'all' && el.dataset.c !== cat) ok = false;
        if (ok && q) {
          var h = [el.dataset.t, el.dataset.d, (el.dataset.c||'').toLowerCase(), el.dataset.s, el.dataset.k, el.dataset.g].join(' ');
          ok = q.split(/\s+/).every(function(w) { return h.includes(w); });
        }
        if (ok) {
          n++;
          if (all || n <= shown) {
            el.classList.remove('hid');
            el.style.display = '';
            el.classList.add('vis');
            highlight(el);
            vis++;
          } else {
            el.style.display = 'none';
            el.classList.remove('hid');
          }
        } else {
          el.classList.add('hid');
          el.style.display = '';
          highlight(el);
        }
      });
      if (cntEl) cntEl.textContent = String(n);
      if (nil) nil.style.display = n === 0 ? 'block' : 'none';
      if (moreWrap) moreWrap.style.display = (!all && n > shown) ? 'block' : 'none';
    }

    /* ═══════ 3D TILT EFFECT ═══════ */
    function initTilt() {
      if (window.matchMedia('(pointer: coarse)').matches) return;
      if (reduced) return;

      grid.addEventListener('mousemove', function(e) {
        var card = e.target.closest('.c');
        if (!card || grid.dataset.v !== 'grid') return;
        var rect = card.getBoundingClientRect();
        var x = (e.clientX - rect.left) / rect.width - 0.5;
        var y = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transform = 'perspective(600px) rotateY(' + (x * 8) + 'deg) rotateX(' + (-y * 8) + 'deg) translateY(-3px)';
      });

      grid.addEventListener('mouseleave', function(e) {
        var card = e.target.closest('.c');
        if (card) {
          card.style.transform = '';
          card.style.transition = 'transform .5s cubic-bezier(.22,1,.36,1)';
          setTimeout(function() { card.style.transition = ''; }, 500);
        }
      }, true);

      /* Reset tilt when mouse leaves a specific card */
      cards.forEach(function(card) {
        card.addEventListener('mouseleave', function() {
          card.style.transform = '';
          card.style.transition = 'transform .5s cubic-bezier(.22,1,.36,1)';
          setTimeout(function() { card.style.transition = ''; }, 500);
        });
      });
    }

    initTilt();
    run();
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>
