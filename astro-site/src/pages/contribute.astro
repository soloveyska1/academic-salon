    .contrib-privacy .chapter-head,
    .contrib-flow .chapter-head {
      grid-template-columns: 1fr;
      gap: 24px;
      padding-bottom: 32px;
    }
  }
  .contrib-prelude .chapter-num,
  .contrib-method .chapter-num,
  .contrib-taking .chapter-num,
  .contrib-privacy .chapter-num,
  .contrib-flow .chapter-num {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .contrib-prelude .roman,
  .contrib-method .roman,
  .contrib-taking .roman,
  .contrib-privacy .roman,
  .contrib-flow .roman {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(80px, 9vw, 140px);
    line-height: 0.8;
    color: var(--gold-ref);
    font-weight: 400;
    letter-spacing: -0.03em;
    opacity: 1;
    margin: 0;
  }
  .contrib-prelude .chapter-label,
  .contrib-method .chapter-label,
  .contrib-taking .chapter-label,
  .contrib-privacy .chapter-label,
  .contrib-flow .chapter-label {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .contrib-prelude .chapter-title-block,
  .contrib-method .chapter-title-block,
  .contrib-taking .chapter-title-block,
  .contrib-privacy .chapter-title-block,
  .contrib-flow .chapter-title-block {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .contrib-prelude .chapter-h,
  .contrib-method .chapter-h,
  .contrib-taking .chapter-h,
  .contrib-privacy .chapter-h,
  .contrib-flow .chapter-h {
    font-family: var(--fd);
    font-size: clamp(40px, 5.5vw, 88px);
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: var(--cream);
    font-weight: 400;
    max-width: 18ch;
    margin: 0;
    text-align: left;
    text-shadow: none;
  }
  .contrib-prelude .chapter-h em,
  .contrib-prelude .chapter-h .it,
  .contrib-method .chapter-h em,
  .contrib-method .chapter-h .it,
  .contrib-taking .chapter-h em,
  .contrib-taking .chapter-h .it,
  .contrib-privacy .chapter-h em,
  .contrib-privacy .chapter-h .it,
  .contrib-flow .chapter-h em,
  .contrib-flow .chapter-h .it {
    font-style: italic;
    color: var(--gold-ref);
    font-weight: 400;
  }
  .contrib-prelude .chapter-lede,
  .contrib-method .chapter-lede,
  .contrib-taking .chapter-lede,
  .contrib-privacy .chapter-lede,
  .contrib-flow .chapter-lede {
    max-width: 60ch;
    font-family: var(--fd);
    font-size: clamp(16px, 1.3vw, 19px);
    line-height: 1.55;
    color: var(--cream-2);
    font-weight: 400;
    margin: 0;
  }
  .contrib-prelude .chapter-lede em,
  .contrib-prelude .chapter-lede .it,
  .contrib-method .chapter-lede em,
  .contrib-method .chapter-lede .it,
  .contrib-taking .chapter-lede em,
  .contrib-taking .chapter-lede .it,
  .contrib-privacy .chapter-lede em,
  .contrib-privacy .chapter-lede .it,
  .contrib-flow .chapter-lede em,
  .contrib-flow .chapter-lede .it {
    font-style: italic;
    color: var(--gold-ref);
  }
  .contrib-inline-link {
    color: var(--gold-ref);
    border-bottom: 1px solid var(--gold-line);
    padding-bottom: 1px;
    text-decoration: none;
  }
  .contrib-inline-link:hover { border-bottom-color: var(--gold-ref); }

  /* ── Prelude ── */
  .contrib-prelude.hero {
    min-height: auto;
    padding: calc(var(--nav-h) + 48px) clamp(20px, 4vw, 48px) clamp(48px, 8vw, 96px);
    display: block;
    text-align: left;
    overflow: visible;
  }
  .contrib-prelude .hero-glow,
  .contrib-prelude .hero-rule,
  .contrib-prelude .prelude-eyebrow,
  .contrib-prelude .prelude-cue { display: none !important; }
  .contrib-prelude-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
    position: relative;
  }
  .contrib-prelude-h { max-width: 20ch; }
  .contrib-prelude-lede { max-width: 60ch; }

  .contrib-prelude-stats {
    margin-top: clamp(36px, 5vw, 56px);
    padding: clamp(20px, 3vw, 28px) 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 4vw, 48px);
    border-top: 1px solid var(--line-ref);
    border-bottom: 1px solid var(--line-ref);
  }
  @media (max-width: 720px) {
    .contrib-prelude-stats { grid-template-columns: 1fr; gap: 16px; }
  }
  .contrib-prelude-stats .col {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .contrib-prelude-stats .lbl {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .contrib-prelude-stats .val {
    font-family: var(--fd);
    font-style: normal;
    font-size: clamp(17px, 1.8vw, 22px);
    color: var(--cream);
    line-height: 1.2;
  }
  .contrib-prelude-stats .it {
    font-style: italic;
    color: var(--gold-ref);
  }
  .contrib-prelude-actions {
    margin-top: clamp(32px, 4vw, 48px);
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  /* ── Method (3 tenet-tiles) ── */
  .contrib-method {
    padding: clamp(64px, 10vw, 128px) clamp(20px, 4vw, 48px);
  }
  .contrib-method-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
    display: block;
    grid-template-columns: none;
  }
  .contrib-method .proc-line { display: none; }
  .contrib-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line-ref);
    border-top: 1px solid var(--line-ref);
    border-bottom: 1px solid var(--line-ref);
  }
  @media (max-width: 900px) {
    .contrib-steps { grid-template-columns: 1fr; }
  }
  .contrib-step-tile {
    background: var(--ink);
    padding: clamp(32px, 4vw, 56px) clamp(24px, 3vw, 40px);
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    transition: background .5s var(--ease-silk);
  }
  .contrib-step-tile:hover { background: var(--ink-2); }
  .contrib-step-tile::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 0; height: 1px;
    background: var(--gold-ref);
    transition: width .7s var(--ease-silk);
  }
  .contrib-step-tile:hover::before { width: 100%; }
  .contrib-step-tile .tile-num {
    font-family: var(--fd);
    font-style: italic;
    font-size: 28px;
    color: var(--gold-ref);
    line-height: 1;
    opacity: 0.85;
  }
  .contrib-step-tile .tile-latin {
    font-family: var(--fd);
    font-style: italic;
    font-size: 13px;
    color: var(--mute);
    line-height: 1;
  }
  .contrib-step-tile .tile-h {
    font-family: var(--fd);
    font-size: clamp(22px, 2.2vw, 28px);
    font-weight: 500;
    color: var(--cream);
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin: 6px 0 0;
  }
  .contrib-step-tile .tile-p {
    font-family: var(--fd);
    font-size: 15px;
    line-height: 1.55;
    color: var(--mute);
    font-style: italic;
    margin: 0;
  }

  /* ── "Что принимаем / не принимаем" ── */
  .contrib-taking {
    padding: clamp(64px, 10vw, 128px) clamp(20px, 4vw, 48px);
    background: var(--ink-2);
  }
  .contrib-taking-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
  }
  .contrib-take-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--line-ref);
    border: 1px solid var(--line-ref);
  }
  @media (max-width: 720px) {
    .contrib-take-grid { grid-template-columns: 1fr; }
  }
  .take-col {
    background: var(--ink);
    padding: clamp(28px, 4vw, 44px);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .take-col--no { background: var(--ink-2); }
  .take-badge {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--gold-ref);
    border: 1px solid var(--gold-line);
    padding: 6px 10px;
    align-self: flex-start;
    border-radius: 0;
  }
  .take-badge--no { color: var(--mute); border-color: var(--line-2-ref); }
  .take-h {
    font-family: var(--fd);
    font-size: clamp(22px, 2.2vw, 28px);
    color: var(--cream);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin: 0;
  }
  .take-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .take-list li {
    font-family: var(--fd);
    font-size: 15px;
    line-height: 1.5;
    color: var(--cream-2);
    padding-left: 26px;
    position: relative;
  }
  .take-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 11px;
    width: 14px;
    height: 1px;
    background: var(--gold-ref);
  }
  .take-col--no .take-list li::before {
    background: var(--mute);
  }

  /* ── Privacy (3 colons) ── */
  .contrib-privacy {
    padding: clamp(64px, 10vw, 128px) clamp(20px, 4vw, 48px);
  }
  .contrib-privacy-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
  }
  .contrib-privacy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line-ref);
    border: 1px solid var(--line-ref);
  }
  @media (max-width: 900px) {
    .contrib-privacy-grid { grid-template-columns: 1fr; }
  }
  .privacy-col {
    background: var(--ink);
    padding: clamp(28px, 4vw, 44px);
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
  }
  .privacy-col::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 0; height: 1px;
    background: var(--gold-ref);
    transition: width .7s var(--ease-silk);
  }
  .privacy-col:hover::before { width: 100%; }
  .privacy-mark {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(26px, 3vw, 36px);
    color: var(--gold-ref);
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .privacy-h {
    font-family: var(--fd);
    font-size: clamp(20px, 2vw, 24px);
    font-weight: 500;
    color: var(--cream);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .privacy-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .privacy-list li {
    font-family: var(--fd);
    font-style: italic;
    font-size: 15px;
    line-height: 1.5;
    color: var(--cream-2);
    padding-left: 22px;
    position: relative;
  }
  .privacy-list li::before {
    content: "·";
    position: absolute;
    left: 6px;
    top: 0;
    color: var(--gold-ref);
  }
  .privacy-note {
    font-family: var(--fd);
    font-style: italic;
    font-size: 14px;
    color: var(--mute);
    line-height: 1.5;
    margin: 8px 0 0;
  }

  /* ── Form ── */
  .contrib-flow {
    padding: clamp(64px, 10vw, 128px) clamp(20px, 4vw, 48px);
    background: var(--ink-2);
  }
  .contrib-flow-inner {
    max-width: var(--wrap-narrow);
    margin: 0 auto;
    display: block;
  }
  .contrib-flow .contrib-main {
    margin-top: clamp(24px, 3vw, 40px);
  }
  .contrib-flow .frm {
    display: flex;
    flex-direction: column;
    gap: clamp(32px, 5vw, 56px);
  }
  .contrib-flow .contrib-step {
    padding: 0;
    margin: 0;
    background: transparent;
    border: 0;
  }
  .contrib-flow .step-head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 20px;
    align-items: baseline;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line-ref);
  }
  .contrib-flow .step-badge {
    font-family: var(--fd);
    font-style: italic;
    font-size: 22px;
    color: var(--gold-ref);
    line-height: 1;
    padding: 0;
    background: transparent;
    border: 0;
  }
  .contrib-flow .step-heading {
    font-family: var(--fd);
    font-size: clamp(22px, 2.2vw, 28px);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--cream);
    font-weight: 400;
    margin: 0;
  }

  /* Upload zone — editorial */
  .contrib-flow .upload-zone {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: clamp(36px, 5vw, 64px) 24px;
    border: 1px dashed var(--line-2-ref);
    background: transparent;
    cursor: pointer;
    transition: border-color .4s var(--ease-silk), background .4s;
    border-radius: 0;
    position: relative;
  }
  .contrib-flow .upload-zone:hover,
  .contrib-flow .upload-zone:focus-visible,
  .contrib-flow .upload-zone.dragover {
    border-color: var(--gold-ref);
    background: var(--gold-soft);
    outline: none;
  }
  .contrib-flow .upload-icon { color: var(--gold-ref); }
  .contrib-flow .upload-text {
    font-family: var(--fd);
    font-size: clamp(18px, 1.8vw, 20px);
    color: var(--cream);
    margin: 0;
  }
  .contrib-flow .upload-hint {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--mute);
    margin: 0;
  }
  .contrib-flow .upload-hint strong {
    color: var(--gold-ref);
    font-weight: 500;
  }
  .contrib-flow .upload-input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }

  /* Filled state */
  .contrib-flow .upload-zone.has-file {
    border-color: var(--gold-line);
    background: transparent;
  }
  .contrib-flow .upload-preview {
    margin-top: 14px;
  }
  .contrib-flow .upload-file-info {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: 12px;
    align-items: center;
    padding: 14px 16px;
    border: 1px solid var(--gold-line);
    background: var(--ink);
  }
  .contrib-flow .upload-file-ext {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold-ref);
    padding: 4px 8px;
    border: 1px solid var(--gold-line);
  }
  .contrib-flow .upload-file-name {
    font-family: var(--fd);
    font-size: 15px;
    color: var(--cream);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .contrib-flow .upload-file-size {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--mute);
    white-space: nowrap;
  }
  .contrib-flow .upload-file-rm {
    width: 28px;
    height: 28px;
    background: transparent;
    border: 1px solid var(--line-2-ref);
    color: var(--mute);
    font-size: 16px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color .3s, border-color .3s;
  }
  .contrib-flow .upload-file-rm:hover { color: var(--gold-ref); border-color: var(--gold-ref); }

  /* Fields — editorial underline */
  .contrib-flow .fields-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  @media (max-width: 720px) {
    .contrib-flow .fields-row { grid-template-columns: 1fr; gap: 16px; }
  }
  .contrib-flow .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
    position: relative;
  }
  .contrib-flow .field label {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .contrib-flow .field .required {
    color: var(--gold-ref);
    font-style: italic;
    font-family: var(--fd);
    letter-spacing: 0;
    text-transform: none;
  }
  .contrib-flow .field input[type="text"],
  .contrib-flow .field textarea {
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--line-2-ref);
    padding: 10px 0;
    color: var(--cream);
    font-family: var(--fd);
    font-size: clamp(16px, 1.5vw, 19px);
    outline: none;
    transition: border-color .4s var(--ease-silk);
    font-weight: 400;
    border-radius: 0;
  }
  .contrib-flow .field input::placeholder,
  .contrib-flow .field textarea::placeholder {
    color: var(--mute-2);
    font-style: italic;
  }
  .contrib-flow .field input:focus,
  .contrib-flow .field textarea:focus { border-bottom-color: var(--gold-ref); }
  .contrib-flow .field textarea { min-height: 72px; resize: vertical; line-height: 1.5; }
  .contrib-flow .field-hint,
  .contrib-flow .field-error {
    font-family: var(--fd);
    font-style: italic;
    font-size: 13px;
    color: var(--mute);
    margin: 0;
  }
  .contrib-flow .field-error:empty { display: none; }

  /* Submit — editorial solid-gold */
  .contrib-flow .contrib-submit {
    margin-top: clamp(8px, 2vw, 16px);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .contrib-flow .trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .contrib-flow .trust-chip {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mute);
    padding: 6px 12px;
    border: 1px solid var(--line-ref);
    background: transparent;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: 0;
  }
  .contrib-flow .trust-check {
    color: var(--gold-ref);
    font-family: var(--fd);
    font-style: italic;
    font-size: 14px;
  }
  .contrib-flow .submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 22px 32px;
    border: 1px solid var(--gold-ref);
    background: var(--gold-ref);
    color: var(--ink);
    font-family: var(--fi);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color .5s var(--ease-silk), border-color .5s, background .5s;
    border-radius: 0;
    box-shadow: none;
    min-height: 56px;
    width: 100%;
  }
  .contrib-flow .submit-btn:hover {
    background: var(--cream);
    border-color: var(--cream);
    color: var(--ink);
    transform: none;
    box-shadow: none;
  }
  .contrib-flow .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .contrib-flow .contrib-submit-note {
    font-family: var(--fd);
    font-style: italic;
    font-size: 13px;
    line-height: 1.45;
    color: var(--mute);
    text-align: center;
    margin: 0;
  }

  /* Success — editorial */
  .contrib-flow .frm-done.premium-success {
    background: var(--ink);
    border: 1px solid var(--gold-line);
    padding: clamp(40px, 5vw, 72px);
    text-align: left;
    position: relative;
    overflow: hidden;
    box-shadow: none;
  }
  .contrib-flow .frm-done.premium-success::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-ref), transparent);
  }
  .contrib-flow .premium-success__crest {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 20px;
  }
  .contrib-flow .premium-success__seal {
    font-family: var(--fd);
    font-style: italic;
    font-size: 56px;
    color: var(--gold-ref);
    line-height: 1;
    letter-spacing: -0.02em;
    background: transparent;
    border: 0;
    padding: 0;
    box-shadow: none;
    width: auto;
    height: auto;
  }
  .contrib-flow .premium-success__folio {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .contrib-flow .premium-success__code {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold-ref);
  }
  .contrib-flow .premium-success__deck {
    font-family: var(--fd);
    font-style: italic;
    font-size: 18px;
    color: var(--cream);
  }
  .contrib-flow .premium-success__eyebrow {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
    display: block;
    margin-bottom: 16px;
  }
  .contrib-flow .frm-done.premium-success .done-title {
    font-family: var(--fd);
    font-size: clamp(28px, 3vw, 36px);
    line-height: 1.15;
    color: var(--cream);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0 0 10px;
  }
  .contrib-flow .frm-done.premium-success .done-title em {
    font-style: italic;
    color: var(--gold-ref);
  }
  .contrib-flow .frm-done.premium-success .done-desc {
    font-family: var(--fd);
    font-size: 16px;
    line-height: 1.55;
