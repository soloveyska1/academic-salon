  .contrib-flow .chapter-head::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 60px;
    height: 1px;
    background: var(--gold-ref);
  }
  @media (max-width: 900px) {
    .contrib-prelude .chapter-head,
