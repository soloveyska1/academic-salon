---
import Base from '../layouts/Base.astro';
---

<Base title="Поделиться работой — Академический Салон" description="Загрузите курсовую, реферат, ВКР или другой студенческий текст в свободный архив. Обезличенно, после модерации — в помощь следующим поколениям." currentPath="/contribute">

  <!-- ============================================================
       I · PRELUDE — editorial hero for the library contribution
       ============================================================ -->
  <section class="hero prelude">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <span class="prelude-eyebrow">
        <span class="prelude-eyebrow-rule" aria-hidden="true"></span>
        <span class="prelude-eyebrow-num">I</span>
        Caput · Поделиться
      </span>

      <h1 class="hero-t prelude-title">
        <span class="ln"><span class="w" style="--i:0">Ваша</span> <span class="w" style="--i:1">работа&nbsp;—</span></span>
        <span class="ln"><em class="it"><span class="w" style="--i:2">чьё-то</span> <span class="w" style="--i:3">спасение</span></em>.</span>
      </h1>

      <div class="hero-rule" aria-hidden="true"></div>

      <p class="hero-sub prelude-lede">
        Сданная курсовая, защищённый диплом, удачный реферат&nbsp;— всё, что лежит у&nbsp;вас на&nbsp;диске после сессии, может помочь следующим студентам. Мы&nbsp;<em class="it">обезличим</em>, проверим и&nbsp;добавим в&nbsp;свободный архив. Контакт автора виден только модератору.
      </p>
    </div>
  </section>

  <!-- ============================================================
       II · METHOD — how contribution works
       ============================================================ -->
  <section class="proc">
    <header class="chapter-head chapter-head--contrib">
      <div class="chapter-num">
        <span class="roman" aria-hidden="true">II</span>
        <span class="chapter-label">Caput Primum · Как&nbsp;это работает</span>
      </div>
      <div class="chapter-title-block">
        <h2 class="chapter-h chapter-h--contrib">Три <em class="it">шага</em>.</h2>
        <p class="chapter-lede">Без&nbsp;регистрации, без&nbsp;персональных данных в&nbsp;публичной карточке. Вы&nbsp;загружаете файл, мы&nbsp;смотрим, что тема подходит архиву&nbsp;— и&nbsp;публикуем.</p>
      </div>
    </header>
    <div class="proc-inner">
      <div class="proc-line" aria-hidden="true"></div>
      <div class="step">
        <span class="step-no-r">I</span>
        <span class="step-latin">Oblatio</span>
        <b class="step-t">Загрузка</b>
        <p class="step-d">Выбираете файл, указываете предмет и&nbsp;тему, оставляете контакт.</p>
      </div>
      <div class="step">
        <span class="step-no-r">II</span>
        <span class="step-latin">Examinatio</span>
        <b class="step-t">Проверка</b>
        <p class="step-d">Антивирус, модерация содержания, соответствие дисциплинам архива&nbsp;— обычно в&nbsp;течение суток.</p>
      </div>
      <div class="step">
        <span class="step-no-r">III</span>
        <span class="step-latin">Publicatio</span>
        <b class="step-t">Публикация</b>
        <p class="step-d">Обезличенная работа появляется в&nbsp;каталоге. Ваш контакт остаётся у&nbsp;модератора, в&nbsp;карточке его нет.</p>
      </div>
    </div>
  </section>

  <!-- UPLOAD FORM -->
  <section class="contrib-flow" id="form">
    <div class="contrib-inner">

      <div class="contrib-main">
        <form class="frm" id="contribForm">

          <div class="contrib-step">
            <div class="step-head">
              <span class="step-badge">01</span>
              <h2 class="step-heading">Выберите файл</h2>
            </div>

            <div class="upload-zone" id="uploadZone" tabindex="0" role="button" aria-label="Выбрать файл для загрузки">
              <svg class="upload-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="12" y1="18" x2="12" y2="12"/>
                <polyline points="9 15 12 12 15 15"/>
              </svg>
              <p class="upload-text">Нажмите или перетащите файл</p>
              <p class="upload-hint">PDF, DOCX, DOC, PPTX, XLSX, ODT, TXT &middot; <strong>до 50 МБ</strong></p>
              <input type="file" id="contribFile" accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.rtf,.odt" class="upload-input" />
            </div>

            <div class="upload-preview" id="uploadPreview" style="display:none">
              <div class="upload-file-info">
                <span class="upload-file-ext" id="uploadExt"></span>
                <span class="upload-file-name" id="uploadName"></span>
                <span class="upload-file-size" id="uploadSize"></span>
                <button type="button" class="upload-file-rm" id="uploadRm" aria-label="Удалить">&times;</button>
              </div>
            </div>
          </div>

          <div class="contrib-step">
            <div class="step-head">
              <span class="step-badge">02</span>
              <h2 class="step-heading">Опишите работу</h2>
            </div>

            <div class="fields-row">
              <div class="field">
                <label for="cTitle">Название</label>
                <input type="text" id="cTitle" name="title" placeholder="Название работы" autocomplete="off" autocapitalize="sentences" />
              </div>
              <div class="field">
                <label for="cSubject">Предмет</label>
                <input type="text" id="cSubject" name="subject" placeholder="Например, психология" autocomplete="off" autocapitalize="words" spellcheck="false" />
              </div>
            </div>

            <div class="fields-row">
              <div class="field">
                <label for="cCategory">Тип работы</label>
                <input type="text" id="cCategory" name="category" placeholder="Курсовая, реферат, ВКР..." autocomplete="off" autocapitalize="words" />
              </div>
              <div class="field">
                <label for="cContact">Ваш контакт <span class="required">*</span></label>
                <input type="text" id="cContact" name="contact" placeholder="VK, Telegram или телефон" required autocapitalize="none" autocorrect="off" spellcheck="false" />
              </div>
            </div>

            <div class="field">
              <label for="cDesc">Описание</label>
              <textarea id="cDesc" name="description" rows="2" placeholder="Краткое описание содержания..." autocomplete="off" autocapitalize="sentences"></textarea>
            </div>
          </div>

          <!-- Submit -->
          <div class="contrib-submit">
            <button type="submit" class="submit-btn" id="contribBtn">
              <span class="submit-text">Отправить на модерацию</span>
            </button>
          </div>
        </form>

        <div class="frm-done premium-success" id="contribDone" style="display:none">
          <div class="premium-success__crest">
            <span class="premium-success__seal" aria-hidden="true">АС</span>
            <div class="premium-success__folio">
              <span class="premium-success__code">LIB-02</span>
              <span class="premium-success__deck">Работа принята</span>
            </div>
          </div>
          <span class="premium-success__eyebrow">Файл ушёл на модерацию и архивную проверку</span>
          <p class="done-title">Работа отправлена</p>
          <p class="done-desc">Файл проверяется. После модерации он появится в каталоге.</p>
          <div class="done-contact">
            <p class="done-contact-text">Хотите загрузить ещё?</p>
            <div class="done-links">
              <button class="done-link done-link--vk" id="contribAgain" type="button">Загрузить ещё</button>
              <a href="/catalog" class="done-link">Каталог</a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- CLOSING removed: contacts live in the global editorial footer (Phase 2) -->

</Base>

<style>
  /* Global editorial footer is intentionally visible on /contribute */

  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    padding: calc(var(--nav-h) + 80px) 24px 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    width: min(800px, 90vw);
    height: min(600px, 80vw);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45%, var(--ac-g) 0%, transparent 70%),
      radial-gradient(ellipse 35% 30%, var(--ac-g2) 0%, transparent 50%);
    animation: glow 10s cubic-bezier(.4,0,.2,1) infinite;
    pointer-events: none;
  }

  @keyframes glow {
    0%, 100% { opacity: .5; transform: translate(-50%,-50%) scale(1); }
    50% { opacity: .8; transform: translate(-50%,-50%) scale(1.08); }
  }

  .hero-inner { position: relative; z-index: 1; max-width: 640px; }

  .hero-t {
    font: 300 clamp(36px, 7vw, 64px)/.92 var(--fd);
    color: var(--t1);
    letter-spacing: -.02em;
    text-wrap: balance;
    text-shadow: 0 0 80px rgba(212,175,55,.08), 0 0 40px rgba(212,175,55,.04);
  }

  .w {
    display: inline-block;
    opacity: 0;
    transform: translateY(20px);
    animation: win 400ms cubic-bezier(.4,0,.2,1) forwards;
    animation-delay: calc(var(--i) * 110ms + 200ms);
  }

  @keyframes win { to { opacity: 1; transform: translateY(0); } }

  .hero-sub {
    margin-top: 20px;
    font: 400 clamp(13px, 2vw, 15px)/1.6 var(--fi);
    color: var(--t2);
    opacity: 0;
    transform: translateY(10px);
    animation: fin 400ms cubic-bezier(.4,0,.2,1) .6s forwards;
  }

  .hero-rule {
    width: 48px; height: 1px;
    margin: 20px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
    animation: rin 400ms cubic-bezier(.4,0,.2,1) .8s forwards;
  }

  @keyframes rin { to { opacity: .2; transform: scaleX(1); } }
  @keyframes fin { to { opacity: 1; transform: translateY(0); } }

  /* ═══════ PROCESS ═══════ */
  .proc { padding: 80px 48px; }

  .proc-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    position: relative;
  }

  .proc-line {
    position: absolute;
    top: 32px; left: 60px; right: 60px;
    height: 1px;
    background: var(--brd);
  }

  .step { position: relative; padding-top: 48px; padding-left: 16px; }

  .step-n {
    position: absolute; top: 0; left: 0;
    font: 300 72px/1 var(--fm);
    color: var(--ac); opacity: .06;
    user-select: none;
  }

  .step-t {
    display: block;
    font: 500 14px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t1);
  }

  .step-d {
    margin-top: 8px;
    font: 400 14px/1.5 var(--fi);
    color: var(--t3);
  }

  /* ═══════ CONTRIBUTE FLOW ═══════ */
  .contrib-flow { padding: 0 48px 80px; }

  .contrib-inner {
    max-width: 680px;
    margin: 0 auto;
    border-top: 1px solid var(--brd);
    padding-top: 56px;
  }

  .contrib-main { min-width: 0; }

  .contrib-step { margin-bottom: 36px; }

  .step-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
  }

  .step-badge {
    font: 300 22px/1 var(--fm);
    color: var(--ac);
    opacity: .12;
  }

  .step-heading {
    font: 300 clamp(18px, 3vw, 22px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  /* Upload zone */
  .upload-zone {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 48px 24px;
    border: 1px dashed var(--brd);
    border-radius: var(--rx);
    cursor: pointer;
    position: relative;
    transition: border-color var(--dur) var(--ease), background var(--dur);
  }

  .upload-zone:hover,
  .upload-zone.is-dragover {
    border-color: var(--ac-b);
    background: var(--ac-t);
  }

  .upload-icon {
    color: var(--t3);
    opacity: .4;
    transition: color var(--dur), opacity var(--dur);
  }

  .upload-zone:hover .upload-icon { color: var(--ac); opacity: .6; }

  .upload-text {
    font: 400 13px/1 var(--fi);
    color: var(--t3);
  }

  .upload-hint {
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    opacity: .4;
    letter-spacing: .02em;
  }

  .upload-hint strong {
    font-weight: 500;
    color: var(--t2);
    opacity: .8;
  }

  .upload-input {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    opacity: 0;
    cursor: pointer;
  }

  /* Upload preview */
  .upload-preview { margin-top: 12px; }

  .upload-file-info {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--surf);
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    animation: chip-in .25s cubic-bezier(.22,1,.36,1);
  }

  @keyframes chip-in {
    from { opacity: 0; transform: scale(.9); }
    to { opacity: 1; transform: scale(1); }
  }

  .upload-file-ext {
    font: 500 10px/1 var(--fm);
    color: var(--ac);
    text-transform: uppercase;
    letter-spacing: .04em;
    opacity: .7;
  }

  .upload-file-name {
    font: 400 13px/1 var(--fi);
    color: var(--t2);
    max-width: 240px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .upload-file-size {
    font: 400 11px/1 var(--fm);
    color: var(--t3);
    opacity: .5;
  }

  .upload-file-rm {
    min-width: 44px; min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    color: var(--t3);
    font-size: 16px;
    cursor: pointer;
    opacity: .4;
    transition: opacity .2s, color .2s;
    padding: 0; line-height: 1;
  }

  .upload-file-rm:hover { opacity: 1; color: var(--red); }

  /* Form fields */
  .fields-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .field {
    margin-bottom: 20px;
    position: relative;
  }
  .field::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ac), var(--ac3), var(--ac));
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 400ms cubic-bezier(.4,0,.2,1);
    pointer-events: none;
  }
  .field:focus-within::after {
    transform: scaleX(1);
  }

  .field label {
    display: block;
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    margin-bottom: 8px;
  }

  .field input, .field textarea {
    width: 100%;
    padding: 12px 0;
    border: none;
    border-bottom: 1px solid var(--brd);
    background: transparent;
    color: var(--t1);
    font: 400 15px/1.4 var(--fi);
    outline: none;
    transition: border-color var(--dur-slow) var(--ease);
  }

  .field input::placeholder, .field textarea::placeholder { color: var(--t3); }
  .required { color: var(--ac); opacity: .5; }
  .field input:focus, .field textarea:focus { border-bottom-color: var(--ac-b2); }
  .field textarea { resize: vertical; min-height: 56px; }

  /* Submit */
  .contrib-submit { padding-top: 8px; }

  .submit-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 18px 22px;
    background: var(--surf);
    border: 1px solid var(--ac-b);
    border-top: 2px solid var(--ac-b2);
    border-radius: 0;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t1);
    cursor: pointer;
    transition: all var(--dur-slow) var(--ease);
  }

  .submit-btn:hover {
    background: var(--surf-h);
    border-color: var(--ac-b3);
    box-shadow: 0 8px 32px rgba(0,0,0,.2);
    transform: translateY(-2px);
  }

  /* Success state */
  .frm-done {
    text-align: center;
    padding: 34px 28px 30px;
  }

  .done-title {
    margin-top: 18px;
    font: 300 30px/1.12 var(--fd);
    color: var(--t1);
  }

  .done-desc {
    max-width: 34ch;
    margin: 10px auto 0;
    font: 400 14px/1.65 var(--fi);
    color: var(--t2);
  }

  .done-contact {
    margin-top: 32px;
    padding: 20px 18px 0;
    border-radius: var(--r);
    background: linear-gradient(180deg, var(--surf), transparent 72%);
  }

  .done-contact-text {
    font: 400 13px/1.5 var(--fi);
    color: var(--t3);
    margin-bottom: 20px;
  }

  .done-links {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .done-link {
    padding: 16px 32px;
    border: 1px solid var(--ac-b);
    border-radius: 0;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t2);
    text-decoration: none;
    background: var(--card);
    cursor: pointer;
    transition: all var(--dur) var(--ease);
  }

  .done-link:hover {
    border-color: var(--ac-b2);
    color: var(--t1);
    transform: translateY(-2px);
  }

  .done-link--vk {
    border-color: var(--ac-b2);
    background: var(--ac-g);
    color: var(--t1);
  }

  /* ═══════ CLOSING ═══════ */
  .closing {
    text-align: center;
    padding: 120px 24px 64px;
    border-top: 1px solid var(--brd);
  }

  .closing-t {
    font: 300 clamp(22px, 4vw, 28px)/1.4 var(--fd);
    color: var(--t2);
  }

  .closing-btns {
    margin-top: 32px;
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .closing-btn {
    padding: 16px 36px;
    border: 1px solid var(--ac-b);
    border-radius: 0;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t2);
    text-decoration: none;
    transition: all var(--dur-slow) var(--ease);
  }

  .closing-btn:hover {
    border-color: var(--brd-h);
    color: var(--t1);
    transform: translateY(-2px);
  }

  .closing-btn--vk {
    background: var(--surf);
    border-color: var(--ac-b);
    color: var(--t1);
  }

  .closing-btn--vk:hover {
    background: var(--surf-h);
    border-color: var(--ac-b2);
    box-shadow: 0 8px 32px rgba(0,0,0,.2);
  }

  .closing-links {
    margin-top: 40px;
    display: flex;
    justify-content: center;
    gap: 24px;
  }

  .closing-links a {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    transition: color var(--dur-slow) var(--ease);
  }

  .closing-links a:hover { color: var(--t2); }

  .closing-copy {
    margin-top: 24px;
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    letter-spacing: .1em;
  }

  /* ═══════ LIGHT THEME ═══════ */
  :global([data-theme="light"]) .hero-glow {
    background:
      radial-gradient(ellipse 55% 45%, rgba(122,95,18,.05) 0%, transparent 70%),
      radial-gradient(ellipse 35% 30%, rgba(122,95,18,.03) 0%, transparent 50%);
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 860px) {
    .proc { padding: 60px 24px; }
    .proc-inner { grid-template-columns: 1fr; gap: 40px; }
    .proc-line { display: none; }
    .contrib-flow { padding: 0 24px 64px; }
    .fields-row { grid-template-columns: 1fr; gap: 0; }
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 768px) {
    .submit-btn {
      min-height: 56px;
      font-size: 15px;
      border-radius: 0;
      background: linear-gradient(135deg, #d4af37, #f6e27a) !important;
      color: #09080a !important;
      border: none !important;
      border-top: none !important;
      font-weight: 600;
      letter-spacing: .06em;
      box-shadow: 0 4px 20px var(--ac-b2);
      text-transform: none;
    }
    .submit-btn:hover,
    .submit-btn:active {
      background: linear-gradient(135deg, #e6c040, #f6e27a) !important;
      color: #09080a !important;
      transform: none;
    }
    .frm-done {
      padding: 28px 18px 24px;
    }
    .field input, .field textarea, .field select {
      border: 1px solid rgba(255,255,255,.1);
      border-radius: var(--rx);
      background: var(--surf);
      padding: 14px 16px;
      font-size: 16px;
      min-height: 52px;
    }
    .field input:focus, .field textarea:focus, .field select:focus {
      border-color: var(--ac);
      box-shadow: 0 0 0 3px var(--ac-line);
    }
    .field label { font-size: 12px; letter-spacing: .06em; }
    .contrib-flow { padding: 0 16px 48px; }
    .hero { min-height: auto; padding-top: calc(var(--nav-h) + 32px); padding-bottom: 24px; }
    .hero-t { font-size: clamp(28px, 7vw, 40px); line-height: 1.15; }
    .upload-zone {
      padding: 32px 16px;
      border-radius: var(--rx);
      border: 2px dashed var(--ac-b);
    }
    .proc { padding: 40px 16px; }
    .closing { padding: 40px 16px 32px; }
    .closing-btn {
      width: 100%;
      text-align: center;
      padding: 16px 24px;
      border-radius: 0;
      min-height: 48px;
    }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .w, .hero-sub, .hero-rule {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
    .hero-rule { opacity: .2 !important; }
    .hero-glow { animation: none !important; }
  }

  /* ══════════════════════════════════════════════════════════════
     EDITORIAL OVERLAY — Phase 6 (/contribute)
     Prelude, chapter head, latin step markers; form logic untouched.
     ══════════════════════════════════════════════════════════════ */
  .prelude-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: clamp(20px, 3vw, 36px);
    font: 400 11px/1 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--ac);
  }
  .prelude-eyebrow-rule {
    width: 28px; height: 1px; background: var(--ac); display: inline-block;
  }
  .prelude-eyebrow-num {
    font: italic 400 18px/1 var(--fd);
    color: var(--ac);
    letter-spacing: 0;
    text-transform: none;
  }
  .prelude-title {
    /* min 34px keeps 'чьё-то спасение' within 320px viewport with padding */
    font: 300 clamp(34px, 7.5vw, 120px)/.98 var(--fd) !important;
    letter-spacing: -.025em !important;
    max-width: 20ch;
    margin: 0 auto;
    text-wrap: balance;
    font-feature-settings: "dlig", "liga", "kern";
  }
  .prelude-title .ln { display: block; }
  .prelude-title .it,
  .prelude-lede .it,
  .chapter-h--contrib .it {
    font-style: italic;
    color: var(--ac);
    font-feature-settings: "swsh", "dlig", "liga";
  }
  .prelude-lede {
    max-width: 58ch;
    margin: 28px auto 0;
    font: 400 clamp(15px, 1.6vw, 18px)/1.65 var(--fi);
    color: var(--t2);
    text-wrap: balance;
  }

  /* Chapter head for the process */
  .chapter-head--contrib {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: clamp(24px, 5vw, 80px);
    align-items: start;
    max-width: 1080px;
    margin: 0 auto clamp(32px, 5vw, 56px);
    padding: 0 clamp(20px, 3vw, 48px);
  }
  .chapter-head--contrib .chapter-num {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .chapter-head--contrib .roman {
    font: italic 400 clamp(42px, 5vw, 64px)/1 var(--fd);
    color: var(--ac);
    font-feature-settings: "swsh";
  }
  .chapter-head--contrib .chapter-label {
    font: 400 10px/1.4 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--t3);
  }
  .chapter-h--contrib {
    font: 400 clamp(30px, 4.2vw, 56px)/1.02 var(--fd);
    color: var(--t1);
    letter-spacing: -.02em;
    margin: 0 0 clamp(14px, 1.6vw, 22px);
    text-wrap: balance;
  }
  .chapter-lede {
    font: 400 clamp(15px, 1.6vw, 18px)/1.6 var(--fi);
    color: var(--t2);
    max-width: 56ch;
  }
  @media (max-width: 760px) {
    .chapter-head--contrib { grid-template-columns: 1fr; gap: 14px; }
    .chapter-head--contrib .chapter-num { flex-direction: row; align-items: baseline; gap: 14px; }
    .chapter-head--contrib .roman { font-size: 38px; }
  }

  /* Latin step markers on top of existing .step markup */
  .proc .step .step-no-r {
    font: italic 400 24px/1 var(--fd);
    color: var(--ac);
    font-feature-settings: "swsh";
    display: block;
    margin-bottom: 6px;
  }
  .proc .step .step-latin {
    font: 400 10px/1 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--t3);
    display: block;
    margin-bottom: 10px;
  }
  /* Hide the old numeric badge to avoid doubling */
  .proc .step .step-n { display: none; }
</style>

<script>
  function initContribute() {
    var app = window.academicSalon || {};
    var showGlobalToast = app.showToast || window.showToast || function() {};
    var track = app.track || function() {};
    var fileInput = document.getElementById('contribFile');
    var zone = document.getElementById('uploadZone');
    var preview = document.getElementById('uploadPreview');
    var nameEl = document.getElementById('uploadName');
    var extEl = document.getElementById('uploadExt');
    var sizeEl = document.getElementById('uploadSize');
    var rmBtn = document.getElementById('uploadRm');
    var selectedFile = null;
    var draftHandle = null;

    function formatSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' КБ';
      return (bytes / (1024 * 1024)).toFixed(1) + ' МБ';
    }

    function showFile(file) {
      selectedFile = file;
      var parts = file.name.split('.');
      var ext = parts.length > 1 ? parts.pop().toUpperCase() : '';
      if (extEl) extEl.textContent = ext;
      if (nameEl) nameEl.textContent = file.name;
      if (sizeEl) sizeEl.textContent = formatSize(file.size);
      if (zone) zone.style.display = 'none';
      if (preview) preview.style.display = 'block';
    }

    function clearFile() {
      selectedFile = null;
      if (fileInput) fileInput.value = '';
      if (zone) zone.style.display = '';
      if (preview) preview.style.display = 'none';
    }

    if (fileInput && fileInput.dataset.bound !== 'true') {
      fileInput.dataset.bound = 'true';
      fileInput.addEventListener('change', function() {
        if (fileInput.files && fileInput.files[0]) {
          var f = fileInput.files[0];
          if (f.size > 50 * 1024 * 1024) {
            showGlobalToast('Файл слишком большой: максимум 50 МБ', 'error');
            fileInput.value = '';
            track('contribute_file_rejected', { reason: 'size' });
            return;
          }
          showFile(f);
        }
      });
    }

    if (rmBtn && rmBtn.dataset.bound !== 'true') {
      rmBtn.dataset.bound = 'true';
      rmBtn.addEventListener('click', clearFile);
    }

    /* Drag & drop */
    if (zone && zone.dataset.bound !== 'true') {
      zone.dataset.bound = 'true';
      zone.addEventListener('dragover', function(e) {
        e.preventDefault();
        zone.classList.add('is-dragover');
      });
      zone.addEventListener('dragleave', function() {
        zone.classList.remove('is-dragover');
      });
      zone.addEventListener('drop', function(e) {
        e.preventDefault();
        zone.classList.remove('is-dragover');
        if (e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0]) {
          var f = e.dataTransfer.files[0];
          if (f.size > 50 * 1024 * 1024) {
            showGlobalToast('Файл слишком большой: максимум 50 МБ', 'error');
            track('contribute_file_rejected', { reason: 'size' });
            return;
          }
          showFile(f);
        }
      });
    }

    /* Form submit */
    var form = document.getElementById('contribForm');
    var done = document.getElementById('contribDone');

    if (form && app.bindDraft && form.dataset.draftBound !== 'true') {
      form.dataset.draftBound = 'true';
      draftHandle = app.bindDraft(form, { key: 'contribute-work' });
      draftHandle.restore();
    }

    if (form && done && form.dataset.bound !== 'true') {
      form.dataset.bound = 'true';
      form.addEventListener('submit', function(e) {
        e.preventDefault();

        var contact = (document.getElementById('cContact') || {}).value || '';
        if (!contact.trim()) {
          showGlobalToast('Укажите контакт для обратной связи', 'error');
          var contactEl = document.getElementById('cContact');
          if (contactEl) contactEl.focus();
          return;
        }

        var contactOk = /^(https?:\/\/)/.test(contact) ||
          /^@/.test(contact) ||
          /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(contact) ||
          /[\d\-\+\(\)]{7,}/.test(contact);
        if (!contactOk) {
          showGlobalToast('Введите VK, Telegram, email или телефон', 'error');
          var contactEl = document.getElementById('cContact');
          if (contactEl) contactEl.focus();
          return;
        }

        if (!selectedFile) {
          showGlobalToast('Выберите файл для загрузки', 'error');
          return;
        }

        var btn = document.getElementById('contribBtn');
        function setContribSubmitState(label, eyebrow, busy) {
          if (!btn) return;
          btn.disabled = Boolean(busy);
          btn.classList.toggle('is-busy', Boolean(busy));
          btn.setAttribute('aria-busy', busy ? 'true' : 'false');
          var textEl = btn.querySelector('.submit-text');
          if (textEl && label) textEl.textContent = label;
        }
        setContribSubmitState('Отправляем работу', '', true);

        if (!navigator.onLine) {
          setContribSubmitState('Отправить на модерацию', 'Модерация архива', false);
          showGlobalToast('Нет соединения. Черновик сохранён, отправьте работу, когда сеть вернётся.', 'error');
          track('contribute_submit_error', { reason: 'offline' });
          return;
        }

        var fd = new FormData();
        fd.append('file', selectedFile);
        fd.append('title', (document.getElementById('cTitle') || {}).value || '');
        fd.append('subject', (document.getElementById('cSubject') || {}).value || '');
        fd.append('category', (document.getElementById('cCategory') || {}).value || '');
        fd.append('contact', contact);
        fd.append('description', (document.getElementById('cDesc') || {}).value || '');

        fetch('/api/contribute/', {
          method: 'POST',
          body: fd,
        }).then(function(res) {
          return res.json();
        }).then(function(data) {
          if (data.ok) {
            if (draftHandle) draftHandle.clear();
            var descField = document.getElementById('cDesc');
            track('contribute_submit_success', { has_description: descField && descField.value ? 1 : 0 });
            form.style.display = 'none';
            done.style.display = 'block';
            // #22: Auto-scroll success message into view
            setTimeout(function() { done.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 100);
          } else {
            setContribSubmitState('Отправить на модерацию', 'Модерация архива', false);
            track('contribute_submit_error', { reason: 'api' });
            showGlobalToast(data.error || 'Ошибка при загрузке', 'error');
          }
        }).catch(function() {
          setContribSubmitState('Отправить на модерацию', 'Модерация архива', false);
          track('contribute_submit_error', { reason: 'network' });
          window.open('https://vk.me/academicsaloon', '_blank');
          showGlobalToast('Сервер временно недоступен. Откроем VK для ручной отправки.', 'error');
        });
      });
    }

    /* "Upload another" button */
    var againBtn = document.getElementById('contribAgain');
    if (againBtn && form && done) {
      againBtn.addEventListener('click', function() {
        done.style.display = 'none';
        form.style.display = '';
        form.reset();
        if (draftHandle) draftHandle.clear();
        clearFile();
        var btn = document.getElementById('contribBtn');
        if (btn) {
          btn.disabled = false;
          btn.classList.remove('is-busy');
          btn.setAttribute('aria-busy', 'false');
          var textEl = btn.querySelector('.submit-text');
          if (textEl) textEl.textContent = 'Отправить на модерацию';
        }
      });
    }
  }

  initContribute();
  document.addEventListener('astro:after-swap', initContribute);
</script>
