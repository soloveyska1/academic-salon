---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const totalDocs = D.length;
const nextTotal = totalDocs + 1;
---

<Base title="Поделиться работой — Академический Салон" description="Загрузите курсовую, реферат, ВКР или другой студенческий текст в свободный архив. Обезличенно, после модерации — в помощь следующим поколениям." currentPath="/contribute">

  <!-- ============================================================
       PRELUDE — editorial hero, no big-H glow (Dark Couture)
       ============================================================ -->
  <section class="hero prelude contrib-prelude" aria-label="Вступление">
    <div class="hero-inner contrib-prelude-inner">
      <header class="chapter-head contrib-chapter-head">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">I</span>
          <span class="chapter-label">Caput · Prima · Donatio</span>
        </div>
        <div class="chapter-title-block">
          <h1 class="chapter-h contrib-prelude-h">Сделайте архив чуть <em class="it">больше</em>.</h1>
          <p class="chapter-lede contrib-prelude-lede">
            Курсовая, которую вы уже сдали. Защищённая ВКР. Удачный реферат. Всё, что лежит у&nbsp;вас на&nbsp;диске после сессии, может помочь следующим студентам. Мы&nbsp;обезличим, проверим и&nbsp;добавим в&nbsp;свободный архив. В&nbsp;публичной карточке не&nbsp;будет ни&nbsp;вашего имени, ни&nbsp;ВУЗа, ни&nbsp;контакта.
          </p>
        </div>
      </header>

      <div class="contrib-prelude-stats" aria-label="Архив в цифрах">
        <div class="col">
          <span class="lbl">В&nbsp;архиве</span>
          <span class="val">{totalDocs} <i class="it">работ</i></span>
        </div>
        <div class="col">
          <span class="lbl">Формат</span>
          <span class="val"><i class="it">бесплатно</i> · без регистрации</span>
        </div>
        <div class="col">
          <span class="lbl">Модерация</span>
          <span class="val">24–48 <i class="it">часов</i></span>
        </div>
      </div>

      <div class="contrib-prelude-actions">
        <a href="#form" class="btn btn-gold btn-lg" id="heroScroll">Загрузить работу</a>
        <a href="/catalog" class="btn btn-ghost-gold btn-lg">Сначала — в&nbsp;архив</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       II · METHOD — how it works, 3 steps (editorial tenets pattern)
       ============================================================ -->
  <section class="proc contrib-method" aria-label="Как это работает">
    <div class="proc-inner contrib-method-inner">
      <header class="chapter-head">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">II</span>
          <span class="chapter-label">Caput Secundum · Как это работает</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">Три <em class="it">шага</em>.</h2>
          <p class="chapter-lede">Без&nbsp;регистрации, без&nbsp;персональных данных в&nbsp;публичной карточке. Вы&nbsp;загружаете файл, мы&nbsp;смотрим, что тема подходит архиву&nbsp;— и&nbsp;публикуем.</p>
        </div>
      </header>

      <ol class="contrib-steps" role="list">
        <li class="contrib-step-tile">
          <span class="tile-num">I</span>
          <span class="tile-latin">Oblatio</span>
          <h3 class="tile-h">Загрузка</h3>
          <p class="tile-p">Выбираете файл, указываете предмет и&nbsp;тему, оставляете контакт&nbsp;— куда нам написать о&nbsp;результате.</p>
        </li>
        <li class="contrib-step-tile">
          <span class="tile-num">II</span>
          <span class="tile-latin">Examinatio</span>
          <h3 class="tile-h">Проверка</h3>
          <p class="tile-p">Антивирус, модерация содержания, соответствие дисциплинам архива, обезличивание ФИО и&nbsp;ВУЗа&nbsp;— обычно в&nbsp;течение суток.</p>
        </li>
        <li class="contrib-step-tile">
          <span class="tile-num">III</span>
          <span class="tile-latin">Publicatio</span>
          <h3 class="tile-h">Публикация</h3>
          <p class="tile-p">Обезличенная работа появляется в&nbsp;каталоге. Ваш контакт остаётся у&nbsp;модератора&nbsp;— в&nbsp;карточке его нет.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ============================================================
       III · WHAT WE TAKE — принимаем / не принимаем
       ============================================================ -->
  <section class="contrib-taking" aria-label="Что подходит">
    <div class="contrib-taking-inner">
      <header class="chapter-head">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">III</span>
          <span class="chapter-label">Caput Tertium · Что подходит</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">Что <em class="it">принимаем</em>.</h2>
          <p class="chapter-lede">Архив&nbsp;— про реальные студенческие работы. Без&nbsp;скачанных с&nbsp;бирж шаблонов и&nbsp;без&nbsp;дубликатов того, что уже есть. Если сомневаетесь&nbsp;— <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="contrib-inline-link">напишите в&nbsp;Telegram</a>, подскажем.</p>
        </div>
      </header>

      <div class="contrib-take-grid">
        <article class="take-col take-col--yes">
          <span class="take-badge">Да</span>
          <h3 class="take-h">Принимаем</h3>
          <ul class="take-list">
            <li>Курсовые, ВКР, дипломные, магистерские</li>
            <li>Рефераты, эссе, контрольные</li>
            <li>Отчёты по&nbsp;практике</li>
            <li>Конспекты лекций, методические материалы</li>
            <li>Самостоятельные и&nbsp;НПР</li>
            <li>Темы, близкие к&nbsp;дисциплинам архива: психология, социальная работа, педагогика, гуманитарные, экономика, право</li>
          </ul>
        </article>

        <article class="take-col take-col--no">
          <span class="take-badge take-badge--no">Нет</span>
          <h3 class="take-h">Не&nbsp;принимаем</h3>
          <ul class="take-list">
            <li>Чужие работы, где вы&nbsp;не&nbsp;автор</li>
            <li>Файлы с&nbsp;незакрытыми персональными данными (скан паспорта, зачётки)</li>
            <li>Работы, которые уже есть в&nbsp;архиве или в&nbsp;открытых библиотеках 1-в-1</li>
            <li>Контент, нарушающий закон РФ</li>
            <li>Работы без&nbsp;авторского текста (полностью copy-paste или&nbsp;ИИ)</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       IV · PRIVACY — что остаётся у вас, что идёт в архив
       ============================================================ -->
  <section class="contrib-privacy" aria-label="Приватность">
    <div class="contrib-privacy-inner">
      <header class="chapter-head">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">IV</span>
          <span class="chapter-label">Caput Quartum · Приватность</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">Что видит <em class="it">архив</em>, что остаётся у&nbsp;нас.</h2>
          <p class="chapter-lede">Мы&nbsp;вычищаем персональные данные из&nbsp;файла перед публикацией. Контакт автора остаётся только у&nbsp;модератора&nbsp;— чтобы написать, если работа подошла, и&nbsp;забыть, если нет.</p>
        </div>
      </header>

      <div class="contrib-privacy-grid">
        <article class="privacy-col">
          <span class="privacy-mark" aria-hidden="true">§&nbsp;I</span>
          <h3 class="privacy-h">В&nbsp;публичной карточке</h3>
          <ul class="privacy-list">
            <li>Название работы</li>
            <li>Предмет и&nbsp;категория</li>
            <li>Краткое описание</li>
            <li>Файл без&nbsp;ФИО, группы, научрука, ВУЗа</li>
          </ul>
        </article>

        <article class="privacy-col">
          <span class="privacy-mark" aria-hidden="true">§&nbsp;II</span>
          <h3 class="privacy-h">Остаётся у&nbsp;модератора</h3>
          <ul class="privacy-list">
            <li>Ваш контакт для связи</li>
            <li>Исходный файл до&nbsp;обезличивания (в&nbsp;закрытом хранилище)</li>
            <li>История сообщений</li>
          </ul>
          <p class="privacy-note">Не&nbsp;передаём третьим лицам. По&nbsp;запросу удаляем запись и&nbsp;работу из&nbsp;архива.</p>
        </article>

        <article class="privacy-col">
          <span class="privacy-mark" aria-hidden="true">§&nbsp;III</span>
          <h3 class="privacy-h">Что вычищаем вручную</h3>
          <ul class="privacy-list">
            <li>Титульный лист с&nbsp;ФИО и&nbsp;группой</li>
            <li>Имя научного руководителя</li>
            <li>Название ВУЗа и&nbsp;кафедры</li>
            <li>Приложения со&nbsp;сканами и&nbsp;скриншотами переписок</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       V · UPLOAD FORM  (logic untouched — only chrome)
       ============================================================ -->
  <section class="contrib-flow" id="form" aria-label="Загрузка работы">
    <div class="contrib-inner contrib-flow-inner">
      <header class="chapter-head">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">V</span>
          <span class="chapter-label">Caput Quintum · Загрузка</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">Отправить <em class="it">работу</em>.</h2>
          <p class="chapter-lede">Файл, контакт и&nbsp;пара полей. Ответ в&nbsp;течение 1–2&nbsp;суток в&nbsp;ваш мессенджер.</p>
        </div>
      </header>

      <div class="contrib-main">
        <form class="frm" id="contribForm">

          <div class="contrib-step">
            <div class="step-head">
              <span class="step-badge">i</span>
              <h2 class="step-heading">Выберите файл</h2>
            </div>

            <div class="upload-zone" id="uploadZone" tabindex="0" role="button" aria-label="Выбрать файл для загрузки">
              <svg class="upload-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="12" y1="18" x2="12" y2="12"/>
                <polyline points="9 15 12 12 15 15"/>
              </svg>
              <p class="upload-text">Нажмите или перетащите файл</p>
              <p class="upload-hint">PDF, DOCX, DOC, PPTX, XLSX, ODT, TXT&nbsp;· <strong>до&nbsp;50&nbsp;МБ</strong></p>
              <input type="file" id="contribFile" accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.rtf,.odt" class="upload-input" />
            </div>

            <div class="upload-preview" id="uploadPreview" style="display:none">
              <div class="upload-file-info">
                <span class="upload-file-ext" id="uploadExt"></span>
                <span class="upload-file-name" id="uploadName"></span>
                <span class="upload-file-size" id="uploadSize"></span>
                <button type="button" class="upload-file-rm" id="uploadRm" aria-label="Удалить">&times;</button>
              </div>
            </div>
          </div>

          <div class="contrib-step">
            <div class="step-head">
              <span class="step-badge">ii</span>
              <h2 class="step-heading">Опишите работу</h2>
            </div>

            <div class="fields-row">
              <div class="field">
                <label for="cTitle">Название</label>
                <input type="text" id="cTitle" name="title" placeholder="Название работы" autocomplete="off" autocapitalize="sentences" />
              </div>
              <div class="field">
                <label for="cSubject">Предмет</label>
                <input type="text" id="cSubject" name="subject" placeholder="Психология, социология..." autocomplete="off" autocapitalize="words" spellcheck="false" />
              </div>
            </div>

            <div class="fields-row">
              <div class="field">
                <label for="cCategory">Тип работы</label>
                <input type="text" id="cCategory" name="category" placeholder="Курсовая, реферат, ВКР..." autocomplete="off" autocapitalize="words" />
              </div>
              <div class="field">
                <label for="cContact">Ваш контакт <span class="required">*</span></label>
                <input type="text" id="cContact" name="contact" placeholder="@telegram / vk.com/... / email" required autocapitalize="none" autocorrect="off" spellcheck="false" />
                <p class="field-hint">Куда написать о&nbsp;результате. В&nbsp;публичной карточке архива не&nbsp;появится.</p>
              </div>
            </div>

            <div class="field">
              <label for="cDesc">Описание</label>
              <textarea id="cDesc" name="description" rows="2" placeholder="Коротко о&nbsp;чём работа. Если не&nbsp;знаете — оставьте пустым, мы&nbsp;напишем сами после проверки."></textarea>
            </div>
          </div>

          <div class="contrib-submit">
            <div class="trust-row">
              <span class="trust-chip"><span class="trust-check" aria-hidden="true">✓</span> Без&nbsp;регистрации</span>
              <span class="trust-chip"><span class="trust-check" aria-hidden="true">✓</span> Анонимно в&nbsp;архиве</span>
              <span class="trust-chip"><span class="trust-check" aria-hidden="true">✓</span> Модерация 24–48&nbsp;ч</span>
            </div>

            <button type="submit" class="submit-btn" id="contribBtn">
              <span class="submit-text">Отправить в&nbsp;архив</span>
            </button>

            <p class="contrib-submit-note">Отправляя работу, вы&nbsp;подтверждаете, что это ваш текст и&nbsp;его публикация не&nbsp;нарушает чьи-либо права.</p>
          </div>
        </form>

        <div class="frm-done premium-success" id="contribDone" style="display:none">
          <div class="premium-success__crest">
            <span class="premium-success__seal" aria-hidden="true">АС</span>
            <div class="premium-success__folio">
              <span class="premium-success__code">LIB-{nextTotal}</span>
              <span class="premium-success__deck">Работа принята</span>
            </div>
          </div>
          <span class="premium-success__eyebrow">Спасибо, что поделились</span>
          <p class="done-title">Теперь в&nbsp;архиве <em class="it">{nextTotal}</em> работ.</p>
          <p class="done-desc">
            Мы&nbsp;проверим её&nbsp;в&nbsp;течение 1–2&nbsp;суток и&nbsp;напишем в&nbsp;ваш мессенджер: подошла ли, нужно&nbsp;ли что-то уточнить, или опубликовали. Если опубликовали&nbsp;— пришлём ссылку на&nbsp;карточку в&nbsp;архиве.
          </p>

          <div class="done-contact">
            <p class="done-contact-text">Есть ещё работы?</p>
            <div class="done-links">
              <button class="done-link done-link--vk" id="contribAgain" type="button">Загрузить ещё</button>
              <a href="/catalog" class="done-link">Посмотреть архив</a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- CLOSING removed: contacts live in the global editorial footer (Phase 2) -->

</Base>

<style>
  /* Global editorial footer is intentionally visible on /contribute */

  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    padding: calc(var(--nav-h) + 80px) 24px 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    width: min(800px, 90vw);
    height: min(600px, 80vw);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45%, var(--ac-g) 0%, transparent 70%),
      radial-gradient(ellipse 35% 30%, var(--ac-g2) 0%, transparent 50%);
    animation: glow 10s cubic-bezier(.4,0,.2,1) infinite;
    pointer-events: none;
  }

  @keyframes glow {
    0%, 100% { opacity: .5; transform: translate(-50%,-50%) scale(1); }
    50% { opacity: .8; transform: translate(-50%,-50%) scale(1.08); }
  }

  .hero-inner { position: relative; z-index: 1; max-width: 640px; }

  .hero-t {
    font: 300 clamp(36px, 7vw, 64px)/.92 var(--fd);
    color: var(--t1);
    letter-spacing: -.02em;
    text-wrap: balance;
    text-shadow: 0 0 80px rgba(212,175,55,.08), 0 0 40px rgba(212,175,55,.04);
  }

  .w {
    display: inline-block;
    opacity: 0;
    transform: translateY(20px);
    animation: win 400ms cubic-bezier(.4,0,.2,1) forwards;
    animation-delay: calc(var(--i) * 110ms + 200ms);
  }

  @keyframes win { to { opacity: 1; transform: translateY(0); } }

  .hero-sub {
    margin-top: 20px;
    font: 400 clamp(13px, 2vw, 15px)/1.6 var(--fi);
    color: var(--t2);
    opacity: 0;
    transform: translateY(10px);
    animation: fin 400ms cubic-bezier(.4,0,.2,1) .6s forwards;
  }

  .hero-rule {
    width: 48px; height: 1px;
    margin: 20px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
    animation: rin 400ms cubic-bezier(.4,0,.2,1) .8s forwards;
  }

  @keyframes rin { to { opacity: .2; transform: scaleX(1); } }
  @keyframes fin { to { opacity: 1; transform: translateY(0); } }

  /* ═══════ PROCESS ═══════ */
  .proc { padding: 80px 48px; }

  .proc-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    position: relative;
  }

  .proc-line {
    position: absolute;
    top: 32px; left: 60px; right: 60px;
    height: 1px;
    background: var(--brd);
  }

  .step { position: relative; padding-top: 48px; padding-left: 16px; }

  .step-n {
    position: absolute; top: 0; left: 0;
    font: 300 72px/1 var(--fm);
    color: var(--ac); opacity: .06;
    user-select: none;
  }

  .step-t {
    display: block;
    font: 500 14px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t1);
  }

  .step-d {
    margin-top: 8px;
    font: 400 14px/1.5 var(--fi);
    color: var(--t3);
  }

  /* ═══════ CONTRIBUTE FLOW ═══════ */
  .contrib-flow { padding: 0 48px 80px; }

  .contrib-inner {
    max-width: 680px;
    margin: 0 auto;
    border-top: 1px solid var(--brd);
    padding-top: 56px;
  }

  .contrib-main { min-width: 0; }

  .contrib-step { margin-bottom: 36px; }

  .step-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
  }

  .step-badge {
    font: 300 22px/1 var(--fm);
    color: var(--ac);
    opacity: .12;
  }

  .step-heading {
    font: 300 clamp(18px, 3vw, 22px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  /* Upload zone */
  .upload-zone {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 48px 24px;
    border: 1px dashed var(--brd);
    border-radius: var(--rx);
    cursor: pointer;
    position: relative;
    transition: border-color var(--dur) var(--ease), background var(--dur);
  }

  .upload-zone:hover,
  .upload-zone.is-dragover {
    border-color: var(--ac-b);
    background: var(--ac-t);
  }

  .upload-icon {
    color: var(--t3);
    opacity: .4;
    transition: color var(--dur), opacity var(--dur);
  }

  .upload-zone:hover .upload-icon { color: var(--ac); opacity: .6; }

  .upload-text {
    font: 400 13px/1 var(--fi);
    color: var(--t3);
  }

  .upload-hint {
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    opacity: .4;
    letter-spacing: .02em;
  }

  .upload-hint strong {
    font-weight: 500;
    color: var(--t2);
    opacity: .8;
  }

  .upload-input {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    opacity: 0;
    cursor: pointer;
  }

  /* Upload preview */
  .upload-preview { margin-top: 12px; }

  .upload-file-info {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--surf);
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    animation: chip-in .25s cubic-bezier(.22,1,.36,1);
  }

  @keyframes chip-in {
    from { opacity: 0; transform: scale(.9); }
    to { opacity: 1; transform: scale(1); }
  }

  .upload-file-ext {
    font: 500 10px/1 var(--fm);
    color: var(--ac);
    text-transform: uppercase;
    letter-spacing: .04em;
    opacity: .7;
  }

  .upload-file-name {
    font: 400 13px/1 var(--fi);
    color: var(--t2);
    max-width: 240px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .upload-file-size {
    font: 400 11px/1 var(--fm);
    color: var(--t3);
    opacity: .5;
  }

  .upload-file-rm {
    min-width: 44px; min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    color: var(--t3);
    font-size: 16px;
    cursor: pointer;
    opacity: .4;
    transition: opacity .2s, color .2s;
    padding: 0; line-height: 1;
  }

  .upload-file-rm:hover { opacity: 1; color: var(--red); }

  /* Form fields */
  .fields-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .field {
    margin-bottom: 20px;
    position: relative;
  }
  .field::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ac), var(--ac3), var(--ac));
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 400ms cubic-bezier(.4,0,.2,1);
    pointer-events: none;
  }
  .field:focus-within::after {
    transform: scaleX(1);
  }

  .field label {
    display: block;
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
