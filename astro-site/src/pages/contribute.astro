</style>

<script>
  function initContribute() {
    var app = window.academicSalon || {};
    var showGlobalToast = app.showToast || window.showToast || function() {};
    var track = app.track || function() {};
    var fileInput = document.getElementById('contribFile');
    var zone = document.getElementById('uploadZone');
    var preview = document.getElementById('uploadPreview');
    var nameEl = document.getElementById('uploadName');
    var extEl = document.getElementById('uploadExt');
    var sizeEl = document.getElementById('uploadSize');
    var rmBtn = document.getElementById('uploadRm');
    var selectedFile = null;
    var draftHandle = null;

    function formatSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' КБ';
      return (bytes / (1024 * 1024)).toFixed(1) + ' МБ';
    }

    function showFile(file) {
      selectedFile = file;
      var parts = file.name.split('.');
      var ext = parts.length > 1 ? parts.pop().toUpperCase() : '';
      if (extEl) extEl.textContent = ext;
      if (nameEl) nameEl.textContent = file.name;
      if (sizeEl) sizeEl.textContent = formatSize(file.size);
      if (zone) zone.style.display = 'none';
      if (preview) preview.style.display = 'block';
    }

    function clearFile() {
      selectedFile = null;
      if (fileInput) fileInput.value = '';
      if (zone) zone.style.display = '';
      if (preview) preview.style.display = 'none';
    }

    if (fileInput && fileInput.dataset.bound !== 'true') {
      fileInput.dataset.bound = 'true';
      fileInput.addEventListener('change', function() {
        if (fileInput.files && fileInput.files[0]) {
          var f = fileInput.files[0];
          if (f.size > 50 * 1024 * 1024) {
            showGlobalToast('Файл слишком большой: максимум 50 МБ', 'error');
            fileInput.value = '';
            track('contribute_file_rejected', { reason: 'size' });
            return;
          }
          showFile(f);
        }
      });
    }

    if (rmBtn && rmBtn.dataset.bound !== 'true') {
      rmBtn.dataset.bound = 'true';
      rmBtn.addEventListener('click', clearFile);
    }

    /* Drag & drop + keyboard trigger (Enter / Space) */
    if (zone && zone.dataset.bound !== 'true') {
      zone.dataset.bound = 'true';
      zone.addEventListener('click', function(e) {
        /* Click on zone (not the inner input) opens file picker */
        if (e.target === zone && fileInput) fileInput.click();
      });
      zone.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          if (fileInput) fileInput.click();
        }
      });
      zone.addEventListener('dragover', function(e) {
        e.preventDefault();
        zone.classList.add('is-dragover');
      });
      zone.addEventListener('dragleave', function() {
        zone.classList.remove('is-dragover');
      });
      zone.addEventListener('drop', function(e) {
        e.preventDefault();
        zone.classList.remove('is-dragover');
        if (e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0]) {
          var f = e.dataTransfer.files[0];
          if (f.size > 50 * 1024 * 1024) {
            showGlobalToast('Файл слишком большой: максимум 50 МБ', 'error');
            track('contribute_file_rejected', { reason: 'size' });
            return;
          }
          showFile(f);
        }
      });
    }

    /* Form submit */
    var form = document.getElementById('contribForm');
    var done = document.getElementById('contribDone');

    if (form && app.bindDraft && form.dataset.draftBound !== 'true') {
      form.dataset.draftBound = 'true';
      draftHandle = app.bindDraft(form, { key: 'contribute-work' });
      draftHandle.restore();
    }

    if (form && done && form.dataset.bound !== 'true') {
      form.dataset.bound = 'true';
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        /* Double-submit guard */
        if (form.dataset.submitting === 'true') return;

        var contact = (document.getElementById('cContact') || {}).value || '';
        if (!contact.trim()) {
          showGlobalToast('Укажите контакт для обратной связи', 'error');
          var contactEl = document.getElementById('cContact');
          if (contactEl) contactEl.focus();
          return;
        }

        var contactOk = /^(https?:\/\/)/.test(contact) ||
          /^@/.test(contact) ||
          /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(contact) ||
          /[\d\-\+\(\)]{7,}/.test(contact);
        if (!contactOk) {
          showGlobalToast('Введите VK, Telegram, email или телефон', 'error');
          var contactEl = document.getElementById('cContact');
          if (contactEl) contactEl.focus();
          return;
        }

        if (!selectedFile) {
          showGlobalToast('Выберите файл для загрузки', 'error');
          return;
        }

        var btn = document.getElementById('contribBtn');
        function setContribSubmitState(label, eyebrow, busy) {
          if (!btn) return;
          btn.disabled = Boolean(busy);
          btn.classList.toggle('is-busy', Boolean(busy));
          btn.setAttribute('aria-busy', busy ? 'true' : 'false');
          var textEl = btn.querySelector('.submit-text');
          if (textEl && label) textEl.textContent = label;
        }
        setContribSubmitState('Отправляем работу', '', true);
        form.dataset.submitting = 'true';

        if (!navigator.onLine) {
          form.dataset.submitting = '';
          setContribSubmitState('Отправить на модерацию', 'Модерация архива', false);
          showGlobalToast('Нет соединения. Черновик сохранён, отправьте работу, когда сеть вернётся.', 'error');
          track('contribute_submit_error', { reason: 'offline' });
          return;
        }

        var fd = new FormData();
        fd.append('file', selectedFile);
        fd.append('title', (document.getElementById('cTitle') || {}).value || '');
        fd.append('subject', (document.getElementById('cSubject') || {}).value || '');
        fd.append('category', (document.getElementById('cCategory') || {}).value || '');
        fd.append('contact', contact);
        fd.append('description', (document.getElementById('cDesc') || {}).value || '');

        fetch('/api/contribute/', {
          method: 'POST',
          body: fd,
        }).then(function(res) {
          if (!res.ok) throw new Error('contribute ' + res.status);
          return res.json();
        }).then(function(data) {
          if (data && data.ok) {
            if (draftHandle) draftHandle.clear();
            var descField = document.getElementById('cDesc');
            track('contribute_submit_success', { has_description: descField && descField.value ? 1 : 0 });
            form.style.display = 'none';
            done.style.display = 'block';
            form.dataset.submitting = '';
            setTimeout(function() { done.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 100);
          } else {
            form.dataset.submitting = '';
            setContribSubmitState('Отправить на модерацию', 'Модерация архива', false);
            track('contribute_submit_error', { reason: 'api' });
            showGlobalToast((data && data.error) || 'Ошибка при загрузке', 'error');
          }
        }).catch(function() {
          form.dataset.submitting = '';
          setContribSubmitState('Отправить на модерацию', 'Модерация архива', false);
          track('contribute_submit_error', { reason: 'network' });
          window.open('https://vk.me/academicsaloon', '_blank');
          showGlobalToast('Сервер временно недоступен. Откроем VK для ручной отправки.', 'error');
        });
      });
    }

    /* "Upload another" button */
    var againBtn = document.getElementById('contribAgain');
    if (againBtn && form && done) {
      againBtn.addEventListener('click', function() {
        done.style.display = 'none';
        form.style.display = '';
        form.reset();
        if (draftHandle) draftHandle.clear();
        clearFile();
        var btn = document.getElementById('contribBtn');
        if (btn) {
          btn.disabled = false;
          btn.classList.remove('is-busy');
          btn.setAttribute('aria-busy', 'false');
          var textEl = btn.querySelector('.submit-text');
          if (textEl) textEl.textContent = 'Отправить на модерацию';
        }
      });
    }
  }

  initContribute();
  document.addEventListener('astro:after-swap', initContribute);
</script>

<!--
