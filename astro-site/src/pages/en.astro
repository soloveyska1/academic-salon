---
/**
 * /en — English starter page.
 *
 * The site itself stays Russian (235 works, all native; subjects and
 * formats specific to Russian academia). This page exists so that
 * international visitors who land here from search or referral can:
 *   - figure out within 10 seconds what the service is
 *   - decide whether to engage (it's likely not for them, and that's
 *     the honest framing)
 *   - find direct contact channels if they DO want a custom paper
 *
 * Design intentionally minimal — single-screen poster, mirrors /about
 * Russian manifest in shape so the brand reads as the same thing.
 */
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';
import { breadcrumb } from '../lib/schema';

const total = D.length;
const subjectsCount = new Set((D as any[]).map((d) => d.subject).filter(Boolean)).size;
const yearsSince = new Date().getFullYear() - 2020;
---

<Base
  title="Academic Salon — Russian student-paper library and custom writing"
  description="Bibliosaloon.ru is a Russian-language workshop and free archive of student papers (since 2020). The catalogue is in Russian; this page summarises the service in English."
  currentPath="/en"
  ogTitle="Academic Salon — Russian-academic workshop"
  ogDescription="Free Russian-language archive of 235+ student papers + custom writing for Russian universities."
  extraSchema={breadcrumb([{ name: 'English', url: '/en/' }])}
>

  <article class="en-folio">

    <!-- Brand line — same letterspacing as /about Latin treatment -->
    <header class="en-eyebrow" aria-hidden="true">
      <span class="mark">АС</span>
      <span class="title">Academicus Salo</span>
      <span class="est">MMXX</span>
    </header>

    <h1 class="en-h1">A Russian student-paper workshop. <em class="it">Quietly.</em></h1>

    <p class="en-lede">
      Since 2020, we run a small workshop and a free archive of student papers
      written for Russian universities — coursework, theses, essays, abstracts.
      Around <strong>{total}</strong> works in <strong>{subjectsCount}</strong> disciplines, all in Russian.
    </p>

    <div class="en-rule" aria-hidden="true">
      <span class="seg"></span>
      <span class="dot"></span>
      <span class="seg"></span>
    </div>

    <section class="en-block">
      <h2 class="en-h2">What you'll find here</h2>
      <ul class="en-list">
        <li><strong>An open archive</strong> — {total}+ Russian student papers, free to download. Authors share them voluntarily.</li>
        <li><strong>A custom-writing service</strong> — coursework, diploma, master's, all written from scratch by domain authors. Russian only. Pricing in roubles.</li>
        <li><strong>Direct human contact</strong> — Telegram, VK, email. No call centre, no menu trees.</li>
      </ul>
    </section>

    <section class="en-block">
      <h2 class="en-h2">Is this for you?</h2>
      <p class="en-p">
        Probably <em class="it">only</em> if you're a Russian-speaking student or
        researcher working with a Russian-language university. The full site
        operates in Russian; we don't currently translate works or offer English
        academic writing as a service.
      </p>
      <p class="en-p">
        If you're an international researcher curious about <em class="it">how</em>
        Russian theses are structured, the catalogue is open — you can browse
        formats, methodologies, citation styles even without reading the texts.
      </p>
    </section>

    <section class="en-block">
      <h2 class="en-h2">Get in touch</h2>
      <p class="en-p">
        We answer in Russian by default; if you write in English we'll do our
        best, but please don't expect native fluency.
      </p>
      <ul class="en-contacts">
        <li><a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram — @academicsaloon</a></li>
        <li><a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VKontakte — vk.com/academicsaloon</a></li>
        <li><a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a></li>
      </ul>
    </section>

    <footer class="en-footer">
      <div class="en-meta">
        <span>{yearsSince} {yearsSince === 1 ? 'year' : 'years'} of practice · since 2020</span>
        <span class="dot" aria-hidden="true">·</span>
        <span>Russian content only</span>
      </div>
      <div class="en-actions">
        <a href="/" class="en-btn en-btn--primary">Открыть сайт по-русски</a>
        <a href="/catalog" class="en-btn en-btn--ghost">Browse the archive</a>
      </div>
    </footer>

  </article>

</Base>

<style is:global>
  .en-folio {
    max-width: 760px;
    margin: 0 auto;
    padding: clamp(48px, 7vw, 96px) clamp(24px, 4vw, 48px) clamp(80px, 10vw, 120px);
    color: var(--cream);
  }

  .en-folio .en-eyebrow {
    display: flex;
    gap: 18px;
    align-items: baseline;
    margin: 0 0 32px;
    font: 400 11px/1 var(--fm);
    letter-spacing: .24em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .en-folio .en-eyebrow .mark { color: var(--gold-ref); font-style: italic; font-size: 14px; letter-spacing: .04em; }
  .en-folio .en-eyebrow .title { color: var(--cream-2); }
  .en-folio .en-eyebrow .est { color: var(--gold-ref); font-feature-settings: "tnum"; }

  .en-folio .en-h1 {
    font: 400 clamp(36px, 5vw, 56px)/1.08 var(--fd);
    color: var(--cream);
    letter-spacing: -.02em;
    margin: 0 0 24px;
    text-wrap: balance;
  }
  .en-folio .en-h1 em, .en-folio .en-h1 .it {
    font-style: italic;
    color: var(--gold-ref);
    font-feature-settings: "swsh", "dlig";
  }

  .en-folio .en-lede {
    font: 400 clamp(15px, 1.6vw, 18px)/1.65 var(--fi);
    color: var(--cream-2);
    margin: 0 0 32px;
    max-width: 60ch;
  }
  .en-folio .en-lede strong {
    color: var(--gold-ref);
    font-weight: 400;
    font-style: italic;
    font-feature-settings: "tnum";
  }

  .en-folio .en-rule {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 0 0 40px;
    color: var(--gold-ref);
  }
  .en-folio .en-rule .seg {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-line), transparent);
  }
  .en-folio .en-rule .dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--gold-ref);
  }

  .en-folio .en-block {
    margin: 0 0 36px;
  }
  .en-folio .en-h2 {
    font: 400 clamp(20px, 2vw, 24px)/1.3 var(--fd);
    color: var(--cream);
    letter-spacing: -.005em;
    margin: 0 0 14px;
  }
  .en-folio .en-p {
    font: 400 15px/1.65 var(--fi);
    color: var(--cream-2);
    margin: 0 0 12px;
    max-width: 64ch;
  }
  .en-folio .en-p em, .en-folio .en-p .it {
    font-style: italic; color: var(--gold-ref);
  }
  .en-folio .en-list,
  .en-folio .en-contacts {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .en-folio .en-list li {
    font: 400 15px/1.55 var(--fi);
    color: var(--cream-2);
    padding-left: 18px;
    position: relative;
  }
  .en-folio .en-list li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--gold-ref);
  }
  .en-folio .en-list li strong {
    color: var(--cream);
    font-weight: 400;
    font-style: italic;
  }
  .en-folio .en-contacts li {
    font: 400 15px/1.4 var(--fi);
  }
  .en-folio .en-contacts a {
    color: var(--gold-ref);
    text-decoration: underline;
    text-decoration-color: var(--gold-line);
    text-underline-offset: 4px;
    transition: text-decoration-color .25s var(--ease, ease);
  }
  .en-folio .en-contacts a:hover { text-decoration-color: var(--gold-ref); }

  .en-folio .en-footer {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--brd);
  }
  .en-folio .en-meta {
    font: 400 11px/1.5 var(--fm);
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--mute);
    display: flex;
    gap: 8px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }
  .en-folio .en-meta .dot { color: var(--gold-ref); }
  .en-folio .en-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .en-folio .en-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 24px;
    font: 500 12px/1 var(--fm);
    letter-spacing: .14em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all .25s var(--ease, ease);
  }
  .en-folio .en-btn--primary {
    background: var(--gold-ref);
    color: var(--ink);
  }
  .en-folio .en-btn--primary:hover { background: var(--gold-hi, var(--gold-ref)); }
  .en-folio .en-btn--ghost {
    border: 1px solid var(--gold-line);
    color: var(--cream-2);
    background: transparent;
  }
  .en-folio .en-btn--ghost:hover { border-color: var(--gold-ref); color: var(--gold-ref); }
</style>
