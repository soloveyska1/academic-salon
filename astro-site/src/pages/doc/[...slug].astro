---
import Base from '../../layouts/Base.astro';
import { D } from '../../data/catalog.js';

export function getStaticPaths() {
  return D.map((doc: any) => ({
    params: { slug: doc.file },
    props: { doc },
  }));
}

const { doc } = Astro.props;

const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
const desc = doc.catalogDescription || doc.description || '';
const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
const fileUrl = doc.file.startsWith('files/') ? `/${doc.file}` : `/files/${doc.file}`;
const currentYear = String(new Date().getFullYear());

const yearBlob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
const yearMatch = yearBlob.match(/(?:19|20)\d{2}/);
const year = yearMatch ? yearMatch[0] : currentYear;

const shortType: Record<string, string> = {
  'Самостоятельная работа': 'Самостоятельная',
  'Выпускная квалификационная работа': 'ВКР',
  'Экзаменационные материалы': 'Экзамен',
  'Контрольная работа': 'Контрольная',
  'Курсовая работа': 'Курсовая',
  'Отчет по практике': 'Отчёт',
  'Отчет о научно-практической работе': 'НПР',
  'Справочный материал': 'Справочник',
  'Нормативный документ': 'Нормативный',
  'Шаблон документа': 'Шаблон',
  'Аналитический документ': 'Аналитика',
  'Методические материалы': 'Методичка',
};

const rawType = doc.docType || '';
const docType = shortType[rawType] || rawType;

const catBorder: Record<string, string> = {
  'ВКР и дипломы': 'gold',
  'Курсовые': 'blue',
  'Рефераты': 'purple',
  'Эссе': 'purple',
  'Отчёты по практике': 'green',
  'НПР': 'blue',
  'Конспекты лекций': 'green',
};

const clr = catBorder[doc.category] || '';

const meta = [
  doc.subject ? { k: 'Предмет', v: doc.subject } : null,
  doc.category ? { k: 'Категория', v: doc.category } : null,
  { k: 'Формат', v: ext.toUpperCase() + (doc.size ? ' · ' + doc.size : '') },
  { k: 'Год', v: year },
  doc.course ? { k: 'Курс', v: doc.course } : null,
].filter(Boolean) as { k: string; v: string }[];

const related = D.filter((d: any) =>
  d.file !== doc.file &&
  ((doc.category && d.category === doc.category) ||
   (doc.subject && d.subject === doc.subject))
).slice(0, 3);

function relType(d: any) {
  const raw = d.docType || '';
  return shortType[raw] || raw;
}

function relYear(d: any) {
  const s = [d.filename, d.newFilename, d.title, d.catalogTitle, d.text].filter(Boolean).join(' ');
  const m = s.match(/(?:19|20)\d{2}/);
  return m ? m[0] : currentYear;
}
---

<Base title={title + ' — Академический Салон'} description={desc}>

  <article class="doc">

    <!-- Breadcrumb -->
    <nav class="crumb" aria-label="Навигация">
      <a href="/catalog">Каталог</a>
      <span aria-hidden="true">→</span>
      <span>{title.length > 60 ? title.slice(0, 60) + '…' : title}</span>
    </nav>

    <!-- Type -->
    {docType && <p class="doc-type" data-clr={clr}>{docType}</p>}

    <!-- Title -->
    <h1 class="doc-title">{title}</h1>

    <!-- Hairline -->
    <div class="doc-rule" aria-hidden="true"></div>

    <!-- Description -->
    {desc && <p class="doc-desc">{desc}</p>}

    <!-- Metadata -->
    <dl class="doc-meta">
      {meta.map(m => (
        <div class="doc-meta-row">
          <dt>{m.k}</dt>
          <dd>{m.v}</dd>
        </div>
      ))}
    </dl>

    <!-- Download -->
    <a href={fileUrl} class="doc-dl" download>Скачать</a>

    <!-- Related -->
    {related.length > 0 && (
      <section class="rel">
        <h2 class="rel-t">Похожие</h2>
        <div class="rel-grid">
          {related.map((r: any) => {
            const rTitle = r.catalogTitle || r.title || r.filename || 'Документ';
            const rExt = (r.filename?.split('.').pop() || 'docx').toLowerCase();
            const rSubj = r.subject || '';
            const rYear = relYear(r);
            const rLeft = [rSubj, rYear].filter(Boolean).join(' · ');
            const rRight = [rExt, r.size].filter(Boolean).join(' · ');
            const rClr = catBorder[r.category] || '';
            return (
              <a href={`/doc/${r.file}`} class="c" data-clr={rClr}>
                <span class="c-type">{relType(r)}</span>
                <h3 class="c-name">{rTitle}</h3>
                <div class="c-bot">
                  <span class="c-left">{rLeft}</span>
                  <span class="c-right">{rRight}</span>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

  </article>

</Base>

<style>
  .doc {
    max-width: 800px;
    margin: 0 auto;
    padding: 32px 48px 120px;
  }

  /* ═══════ BREADCRUMB ═══════ */
  .crumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font: 400 12px/1 var(--fi);
    color: rgba(255,255,255,.25);
    margin-bottom: 48px;
  }

  .crumb a {
    color: rgba(255,255,255,.3);
    text-decoration: none;
    transition: color .3s cubic-bezier(.25,0,0,1);
  }

  .crumb a:hover { color: rgba(255,255,255,.6); }

  /* ═══════ TYPE ═══════ */
  .doc-type {
    font: 500 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: rgba(255,255,255,.3);
    margin-bottom: 16px;
    padding-left: 12px;
    border-left: 2px solid transparent;
  }

  .doc-type[data-clr="gold"]   { border-left-color: rgba(201,165,90,.25); }
  .doc-type[data-clr="blue"]   { border-left-color: rgba(79,125,245,.2); }
  .doc-type[data-clr="purple"] { border-left-color: rgba(165,90,201,.2); }
  .doc-type[data-clr="green"]  { border-left-color: rgba(90,201,165,.2); }

  /* ═══════ TITLE ═══════ */
  .doc-title {
    font: 400 clamp(28px, 5vw, 42px)/1.2 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    max-width: 700px;
  }

  /* ═══════ HAIRLINE ═══════ */
  .doc-rule {
    width: 40px;
    height: 1px;
    background: rgba(255,255,255,.06);
    margin: 24px 0;
  }

  /* ═══════ DESCRIPTION ═══════ */
  .doc-desc {
    font: 400 15px/1.7 var(--fi);
    color: rgba(255,255,255,.55);
    max-width: 600px;
    margin-bottom: 40px;
  }

  /* ═══════ METADATA ═══════ */
  .doc-meta {
    max-width: 400px;
    margin-bottom: 40px;
  }

  .doc-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255,255,255,.04);
  }

  .doc-meta-row dt {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: rgba(255,255,255,.25);
  }

  .doc-meta-row dd {
    font: 400 14px/1 var(--fi);
    color: rgba(255,255,255,.7);
  }

  /* ═══════ DOWNLOAD ═══════ */
  .doc-dl {
    display: inline-block;
    padding: 16px 48px;
    border: 1px solid rgba(201,165,90,.2);
    font: 300 italic 15px/1 var(--fd);
    color: rgba(255,255,255,.7);
    text-decoration: none;
    transition:
      background .5s cubic-bezier(.25,0,0,1),
      border-color .5s cubic-bezier(.25,0,0,1),
      color .5s cubic-bezier(.25,0,0,1);
  }

  .doc-dl:hover {
    background: rgba(201,165,90,.06);
    border-color: rgba(201,165,90,.3);
    color: var(--t1);
  }

  /* ═══════ RELATED ═══════ */
  .rel {
    padding-top: 80px;
    border-top: 1px solid rgba(255,255,255,.04);
    margin-top: 64px;
  }

  .rel-t {
    font: 300 24px/1 var(--fd);
    color: rgba(255,255,255,.6);
    margin-bottom: 32px;
  }

  .rel-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* ═══════ CARD (same as catalog) ═══════ */
  .c {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 28px 24px;
    background: rgba(255,255,255,.018);
    border: 1px solid rgba(255,255,255,.03);
    text-decoration: none;
    color: inherit;
    transition:
      background .5s cubic-bezier(.25,0,0,1),
      border-color .5s cubic-bezier(.25,0,0,1);
  }

  .c:hover {
    background: rgba(255,255,255,.04);
    border-color: rgba(255,255,255,.08);
  }

  .c:hover .c-name { color: rgba(201,165,90,.85); }

  .c[data-clr="gold"]   { border-left: 2px solid rgba(201,165,90,.2); }
  .c[data-clr="blue"]   { border-left: 2px solid rgba(79,125,245,.15); }
  .c[data-clr="purple"] { border-left: 2px solid rgba(165,90,201,.15); }
  .c[data-clr="green"]  { border-left: 2px solid rgba(90,201,165,.15); }

  .c-type {
    font: 500 9px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: rgba(255,255,255,.3);
  }

  .c-name {
    font: 400 17px/1.35 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color .5s cubic-bezier(.25,0,0,1);
  }

  .c-bot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-top: auto;
  }

  .c-left { font: 400 11px/1.3 var(--fi); color: rgba(255,255,255,.3); }
  .c-right { font: 400 11px/1 var(--fm); color: rgba(255,255,255,.2); flex-shrink: 0; }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 640px) {
    .doc { padding: 24px 20px 80px; }
    .crumb { margin-bottom: 32px; }
    .doc-title { font-size: 26px; }
    .rel-grid { grid-template-columns: 1fr; }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .c, .doc-dl {
      transition: none !important;
    }
  }
</style>
