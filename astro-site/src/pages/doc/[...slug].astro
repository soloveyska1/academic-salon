---
import Base from '../../layouts/Base.astro';
import { D } from '../../data/catalog.js';


export function getStaticPaths() {
  return D.map((doc: any) => ({
    params: { slug: doc.file },
    props: { doc },
  }));
}

const { doc } = Astro.props;

const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
const desc = doc.catalogDescription || doc.description || '';
const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
const fileUrl = doc.file.startsWith('files/') ? `/${doc.file}` : `/files/${doc.file}`;
const currentYear = String(new Date().getFullYear());

const yearBlob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
const yearMatch = yearBlob.match(/(?:19|20)\d{2}/);
const year = yearMatch ? yearMatch[0] : currentYear;
const archiveCode = `SAL-${year.slice(-2)}-${ext.toUpperCase()}`;
const archiveDeck = doc.subject || doc.category || 'Фонд библиотеки';

const shortType: Record<string, string> = {
  'Самостоятельная работа': 'Самостоятельная',
  'Выпускная квалификационная работа': 'ВКР',
  'Экзаменационные материалы': 'Экзамен',
  'Контрольная работа': 'Контрольная',
  'Курсовая работа': 'Курсовая',
  'Отчет по практике': 'Отчёт',
  'Отчет о научно-практической работе': 'НПР',
  'Справочный материал': 'Справочник',
  'Нормативный документ': 'Нормативный',
  'Шаблон документа': 'Шаблон',
  'Аналитический документ': 'Аналитика',
  'Методические материалы': 'Методичка',
};

const rawType = doc.docType || '';
const docType = shortType[rawType] || rawType;

const meta = [
  doc.subject ? { k: 'Предмет', v: doc.subject } : null,
  doc.category ? { k: 'Категория', v: doc.category } : null,
  { k: 'Формат', v: ext.toUpperCase() + (doc.size ? ' · ' + doc.size : '') },
  { k: 'Год', v: year },
  doc.course ? { k: 'Курс', v: doc.course } : null,
].filter(Boolean) as { k: string; v: string }[];

const related = D.filter((d: any) =>
  d.file !== doc.file &&
  ((doc.category && d.category === doc.category) ||
   (doc.subject && d.subject === doc.subject))
).slice(0, 3);

function relType(d: any) {
  const raw = d.docType || '';
  return shortType[raw] || raw;
}

function relYear(d: any) {
  const s = [d.filename, d.newFilename, d.title, d.catalogTitle, d.text].filter(Boolean).join(' ');
  const m = s.match(/(?:19|20)\d{2}/);
  return m ? m[0] : currentYear;
}
---

<Base title={title + ' — Библиотека академического салона'} description={desc}>

  <article class="doc">

    <!-- Breadcrumb -->
    <nav class="crumb" aria-label="Навигация">
      <a href="/catalog">Каталог</a>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <span>{title.length > 50 ? title.slice(0, 50) + '…' : title}</span>
    </nav>

    <div class="doc-ledger">
      <span class="doc-ledger-seal" aria-hidden="true">АС</span>
      <div class="doc-ledger-copy">
        <span class="doc-ledger-label">Фонд библиотеки</span>
        <span class="doc-ledger-code">{archiveCode}</span>
      </div>
      <span class="doc-ledger-note">{archiveDeck}</span>
    </div>

    <!-- Header -->
    <header class="doc-header">
      <div class="doc-format-badge" aria-hidden="true">
        <span class="format-ext">{ext}</span>
      </div>
      <div class="doc-header-text">
        {docType && <p class="doc-type">{docType}</p>}
        <h1 class="doc-title">{title}</h1>
      </div>
    </header>

    <!-- Rule -->
    <div class="doc-rule" aria-hidden="true"></div>

    <!-- Description -->
    {desc && <p class="doc-desc">{desc}</p>}

    <!-- Metadata -->
    <div class="doc-meta-grid">
      {meta.map(m => (
        <div class="doc-meta-item">
          <span class="doc-meta-label">{m.k}</span>
          <span class="doc-meta-value">{m.v}</span>
        </div>
      ))}
      <div class="doc-meta-item doc-meta-stats" id="docStats" style="display:none">
        <span class="doc-meta-label">Популярность</span>
        <span class="doc-meta-value" id="docStatsValue"></span>
      </div>
    </div>

    <!-- Download card -->
    <div class="doc-card">
      <div class="doc-card-top">
        <div class="doc-card-crest">
          <span class="doc-card-seal" aria-hidden="true">АС</span>
          <div class="doc-card-crest-copy">
            <span class="doc-card-crest-label">Выдача из фонда</span>
            <span class="doc-card-crest-code">{archiveCode}</span>
          </div>
        </div>
        <span class="doc-card-shelf">{archiveDeck}</span>
      </div>
      <div class="doc-card-body">
        <div class="doc-card-left">
          <div class="doc-card-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <div class="doc-card-info">
            <span class="doc-card-name">{doc.filename || title}</span>
            <span class="doc-card-meta">{ext.toUpperCase()} · {doc.size || ''}</span>
          </div>
        </div>
        <div class="doc-card-actions">
          <a href={fileUrl} class="doc-dl" download>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Скачать
          </a>
          <button class="doc-share" id="shareBtn" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            <span id="shareBtnText">Скопировать</span>
          </button>
          <button class="doc-fav" id="favBtn" type="button" data-file={doc.file} aria-label="В избранное">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Related -->
    {related.length > 0 && (
      <section class="rel">
        <h2 class="rel-title">Похожие работы</h2>
        <div class="rel-grid">
          {related.map((r: any) => {
            const rTitle = r.catalogTitle || r.title || r.filename || 'Документ';
            const rSubj = r.subject || '';
            const rYear = relYear(r);
            return (
              <a href={`/doc/${r.file}`} class="rel-card">
                <span class="rel-card-type">{relType(r)}</span>
                <h3 class="rel-card-title">{rTitle}</h3>
                <span class="rel-card-meta">{[rSubj, rYear].filter(Boolean).join(' · ')}</span>
              </a>
            );
          })}
        </div>
      </section>
    )}

  </article>

</Base>

<style>
  .doc {
    max-width: 800px;
    margin: 0 auto;
    padding: 32px 48px 48px;
  }

  /* ═══════ BREADCRUMB ═══════ */
  .crumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    margin-bottom: 48px;
  }

  .crumb svg {
    opacity: .4;
  }

  .crumb a {
    color: var(--t3);
    text-decoration: none;
    transition: color .3s cubic-bezier(.25,0,0,1);
  }

  .crumb a:hover { color: var(--ac); }

  .doc-ledger {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 14px;
    margin-bottom: 22px;
    padding: 14px 18px;
    border: 1px solid rgba(212,175,55,.12);
    border-radius: 22px;
    background:
      linear-gradient(180deg, rgba(20,18,22,.96), rgba(12,11,14,.9)),
      radial-gradient(circle at 0% 0%, rgba(212,175,55,.08), transparent 42%);
    box-shadow:
      0 22px 56px rgba(0,0,0,.2),
      0 0 28px rgba(212,175,55,.04),
      inset 0 1px 0 rgba(255,255,255,.04);
  }

  .doc-ledger-seal {
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    border-radius: 14px;
    border: 1px solid rgba(212,175,55,.18);
    background:
      radial-gradient(circle at 50% 30%, rgba(246,226,122,.16), rgba(212,175,55,.08) 45%, rgba(255,255,255,.02) 100%);
    font: 600 11px/1 var(--fm);
    letter-spacing: .24em;
    text-indent: .24em;
    color: var(--ac2);
    box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
  }

  .doc-ledger-copy {
    display: grid;
    gap: 4px;
    min-width: 0;
  }

  .doc-ledger-label,
  .doc-ledger-note {
    font: 400 10px/1 var(--fi);
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--t3);
  }

  .doc-ledger-code {
    font: 500 11px/1 var(--fm);
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ac);
  }

  /* ═══════ HEADER ═══════ */
  .doc-header {
    position: relative;
    display: flex;
    gap: 24px;
    align-items: flex-start;
    padding: 30px 30px 28px;
    border: 1px solid rgba(212,175,55,.12);
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(20,18,22,.98), rgba(11,10,13,.94)),
      radial-gradient(circle at 85% 0%, rgba(212,175,55,.08), transparent 34%);
    box-shadow:
      0 24px 72px rgba(0,0,0,.22),
      inset 0 1px 0 rgba(255,255,255,.04),
      0 0 0 1px rgba(212,175,55,.04);
    overflow: hidden;
  }

  .doc-header::before,
  .doc-header::after {
    content: '';
    position: absolute;
    pointer-events: none;
  }

  .doc-header::before {
    inset: 12px;
    border-radius: 20px;
    border: 1px solid rgba(212,175,55,.08);
  }

  .doc-header::after {
    top: -14%;
    right: -8%;
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(212,175,55,.14), transparent 72%);
    filter: blur(14px);
    opacity: .72;
  }

  .doc-format-badge {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 18px;
    background:
      radial-gradient(circle at 50% 30%, rgba(246,226,122,.16), rgba(212,175,55,.08) 45%, rgba(255,255,255,.02) 100%);
    border: 1px solid rgba(212,175,55,.18);
    box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
  }

  .format-ext {
    font: 600 11px/1 var(--fm);
    text-transform: uppercase;
    letter-spacing: .5px;
    color: var(--ac);
  }

  .doc-header-text {
    position: relative;
    z-index: 1;
    flex: 1;
    min-width: 0;
  }

  .doc-type {
    font: 500 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--ac);
    opacity: .6;
    margin-bottom: 12px;
  }

  .doc-title {
    font: 400 clamp(26px, 4.5vw, 38px)/1.2 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
  }

  /* ═══════ RULE ═══════ */
  .doc-rule {
    width: 48px;
    height: 1px;
    background: linear-gradient(90deg, var(--ac), transparent);
    opacity: .2;
    margin: 32px 0;
  }

  /* ═══════ DESCRIPTION ═══════ */
  .doc-desc {
    font: 400 15px/1.8 var(--fi);
    color: var(--t2);
    max-width: 600px;
    margin-bottom: 40px;
  }

  /* ═══════ METADATA ═══════ */
  .doc-meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
    gap: 10px;
    margin-bottom: 28px;
  }

  .doc-meta-item {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px;
    background: linear-gradient(180deg, var(--card), rgba(255,255,255,.01));
    border: 1px solid rgba(212,175,55,.08);
    border-radius: 16px;
  }

  .doc-meta-label {
    font: 400 9px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
  }

  .doc-meta-value {
    font: 400 14px/1.2 var(--fi);
    color: var(--t1);
  }

  /* ═══════ DOWNLOAD CARD ═══════ */
  .doc-card {
    position: relative;
    display: grid;
    gap: 18px;
    padding: 22px;
    margin-bottom: 48px;
    background:
      linear-gradient(180deg, rgba(20,18,22,.98), rgba(11,10,13,.94)),
      radial-gradient(circle at 100% 0%, rgba(212,175,55,.08), transparent 34%);
    border: 1px solid rgba(212,175,55,.12);
    border-radius: 24px;
    box-shadow:
      0 22px 72px rgba(0,0,0,.2),
      inset 0 1px 0 rgba(255,255,255,.04),
      0 0 0 1px rgba(212,175,55,.04);
    overflow: hidden;
    transition:
      border-color .4s cubic-bezier(.25,0,0,1),
      box-shadow .4s cubic-bezier(.25,0,0,1),
      transform .4s cubic-bezier(.25,0,0,1);
  }

  .doc-card::before,
  .doc-card::after {
    content: '';
    position: absolute;
    pointer-events: none;
  }

  .doc-card::before {
    inset: 12px;
    border-radius: 18px;
    border: 1px solid rgba(212,175,55,.08);
  }

  .doc-card::after {
    inset: -30% -18%;
    background: linear-gradient(112deg, transparent 36%, rgba(246,226,122,.12) 49%, rgba(255,255,255,.03) 54%, transparent 68%);
    transform: translateX(-72%) rotate(9deg);
    opacity: 0;
  }

  .doc-card:hover {
    border-color: rgba(212,175,55,.24);
    box-shadow:
      0 28px 88px rgba(0,0,0,.24),
      inset 0 1px 0 rgba(255,255,255,.04),
      0 0 0 1px rgba(212,175,55,.06);
    transform: translateY(-2px);
  }

  .doc-card:hover::after {
    opacity: 1;
    animation: doc-folio-sweep 1.9s ease-in-out infinite;
  }

  .doc-card-top,
  .doc-card-body {
    position: relative;
    z-index: 1;
  }

  .doc-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 16px;
    margin: -2px -2px 0;
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(255,255,255,.025), rgba(255,255,255,.01));
  }

  .doc-card-crest {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .doc-card-seal {
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    flex-shrink: 0;
    border-radius: 14px;
    border: 1px solid rgba(212,175,55,.18);
    background:
      radial-gradient(circle at 50% 30%, rgba(246,226,122,.16), rgba(212,175,55,.08) 45%, rgba(255,255,255,.02) 100%);
    font: 600 11px/1 var(--fm);
    letter-spacing: .24em;
    text-indent: .24em;
    color: var(--ac2);
    box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
  }

  .doc-card-crest-copy {
    display: grid;
    gap: 4px;
    min-width: 0;
  }

  .doc-card-crest-label,
  .doc-card-shelf {
    font: 400 10px/1 var(--fi);
    letter-spacing: .16em;
    text-transform: uppercase;
    color: var(--t3);
  }

  .doc-card-crest-code {
    font: 500 11px/1 var(--fm);
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ac);
  }

  .doc-card-shelf {
    white-space: nowrap;
    padding: 8px 12px;
    border: 1px solid rgba(212,175,55,.1);
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.012));
  }

  .doc-card-body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .doc-card-left {
    display: flex;
    align-items: center;
    gap: 16px;
    min-width: 0;
  }

  .doc-card-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: var(--surf);
    border: 1px solid var(--ac-g);
    color: var(--ac);
  }

  .doc-card-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .doc-card-name {
    font: 400 13px/1.3 var(--fi);
    color: var(--t2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .doc-card-meta {
    font: 400 11px/1 var(--fm);
    color: var(--t3);
    opacity: .6;
  }

  .doc-card-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .doc-dl {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 28px;
    background: var(--surf);
    border: 1px solid var(--ac-b);
    border-radius: var(--rx);
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t1);
    text-decoration: none;
    transition:
      background .4s cubic-bezier(.25,0,0,1),
      border-color .4s cubic-bezier(.25,0,0,1),
      box-shadow .4s cubic-bezier(.25,0,0,1),
      transform .4s cubic-bezier(.25,0,0,1);
  }

  .doc-dl:hover {
    background: var(--ac-line);
    border-color: var(--ac-b2);
    box-shadow: 0 8px 32px var(--ac-g);
    transform: translateY(-2px);
  }

  .doc-share {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    background: transparent;
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    cursor: pointer;
    transition:
      border-color .3s cubic-bezier(.25,0,0,1),
      color .3s cubic-bezier(.25,0,0,1);
  }

  .doc-share:hover {
    border-color: var(--brd-h);
    color: var(--t1);
  }

  .doc-fav {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    padding: 12px 0;
    background: transparent;
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    color: var(--t3);
    cursor: pointer;
    transition:
      border-color .3s cubic-bezier(.25,0,0,1),
      color .3s cubic-bezier(.25,0,0,1);
  }
  .doc-fav:hover { border-color: var(--brd-h); color: var(--ac); }
  .doc-fav.is-active { color: var(--ac); border-color: var(--ac-b); }
  .doc-fav.is-active svg { fill: var(--ac); }

  @keyframes doc-folio-sweep {
    0% {
      transform: translateX(-72%) rotate(9deg);
      opacity: 0;
    }
    18% {
      opacity: 1;
    }
    100% {
      transform: translateX(88%) rotate(9deg);
      opacity: 0;
    }
  }

  [data-theme="light"] .doc-ledger,
  [data-theme="light"] .doc-header,
  [data-theme="light"] .doc-card {
    border-color: rgba(160,120,24,.12);
    background:
      linear-gradient(180deg, rgba(255,255,255,.985), rgba(246,242,234,.965)),
      radial-gradient(circle at 100% 0%, rgba(180,140,20,.06), transparent 34%);
    box-shadow:
      0 24px 80px rgba(72,54,10,.12),
      inset 0 1px 0 rgba(255,255,255,.7),
      0 0 0 1px rgba(160,120,24,.04);
  }

  [data-theme="light"] .doc-ledger-seal,
  [data-theme="light"] .doc-format-badge,
  [data-theme="light"] .doc-card-seal {
    border-color: rgba(160,120,24,.18);
    background:
      radial-gradient(circle at 50% 30%, rgba(180,140,20,.18), rgba(180,140,20,.08) 45%, rgba(255,255,255,.72) 100%);
    color: #8d6b18;
  }

  [data-theme="light"] .doc-header::before,
  [data-theme="light"] .doc-card::before {
    border-color: rgba(160,120,24,.08);
  }

  [data-theme="light"] .doc-header::after {
    background: radial-gradient(circle, rgba(160,120,24,.15), transparent 72%);
  }

  [data-theme="light"] .doc-card-top {
    background: linear-gradient(180deg, rgba(255,255,255,.82), rgba(255,255,255,.58));
  }

  @media (max-width: 640px) {
    .doc-ledger {
      grid-template-columns: auto 1fr;
      gap: 12px;
      padding: 12px 14px;
    }
    .doc-ledger-note {
      grid-column: 1 / -1;
      padding-left: 54px;
    }
    .doc-card-top,
    .doc-card-body {
      flex-direction: column;
      align-items: stretch;
      gap: 16px;
    }
    .doc-card-actions {
      display: grid;
      grid-template-columns: 1fr auto;
    }
    .doc-dl { justify-content: center; }
    .doc-share { justify-content: center; }
  }

  /* ═══════ RELATED ═══════ */
  .rel {
    padding-top: 64px;
    border-top: 1px solid var(--brd);
  }

  .rel-title {
    font: 300 clamp(22px, 4vw, 28px)/1 var(--fd);
    color: var(--t1);
    margin-bottom: 32px;
  }

  .rel-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .rel-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 16px;
    padding: 24px;
    min-height: 160px;
    background: var(--card);
    border: 1px solid var(--brd);
    border-top: 2px solid var(--ac-b);
    border-radius: 16px;
    text-decoration: none;
    color: inherit;
    transition:
      background .4s cubic-bezier(.25,0,0,1),
      border-color .4s cubic-bezier(.25,0,0,1),
      box-shadow .4s cubic-bezier(.25,0,0,1),
      transform .4s cubic-bezier(.25,0,0,1);
  }

  .rel-card:hover {
    background: var(--card-h);
    border-color: var(--ac-glow);
    border-top-color: var(--ac-b3);
    box-shadow: 0 8px 32px var(--ac-t);
    transform: translateY(-3px);
  }

  .rel-card-type {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--t3);
  }

  .rel-card-title {
    font: 400 clamp(16px, 2vw, 19px)/1.4 var(--fd);
    color: var(--t1);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color .3s cubic-bezier(.25,0,0,1);
  }

  .rel-card:hover .rel-card-title {
    color: var(--ac3);
  }

  .rel-card-meta {
    font: 400 11px/1.3 var(--fi);
    color: var(--t3);
    padding-top: 8px;
    border-top: 1px solid var(--brd);
  }

  /* ═══════ MOBILE ═══════ */
  /* ═══════ MOBILE ENTRANCE ANIMATIONS ═══════ */
  @media (max-width: 768px) {
    .crumb, .doc-ledger, .doc-header, .doc-description, .doc-card, .doc-meta-grid, .rel {
      opacity: 0;
      transform: translateY(16px);
      animation: doc-enter .5s cubic-bezier(.16,1,.3,1) forwards;
    }
    .crumb { animation-delay: 0s; }
    .doc-ledger { animation-delay: .04s; }
    .doc-header { animation-delay: .08s; }
    .doc-description { animation-delay: .16s; }
    .doc-card { animation-delay: .2s; }
    .doc-meta-grid { animation-delay: .28s; }
    .rel { animation-delay: .35s; }

    @keyframes doc-enter {
      to { opacity: 1; transform: translateY(0); }
    }
  }

  @media (max-width: 640px) {
    .doc { padding: 20px 16px 88px; }
    .crumb { margin-bottom: 16px; font-size: 13px; }

    .doc-header {
      flex-direction: column;
      gap: 16px;
      padding: 24px 18px 22px;
    }

    .doc-title {
      font-size: clamp(24px, 6vw, 32px);
      line-height: 1.2;
    }

    .doc-format-badge {
      width: 48px;
      height: 48px;
    }

    /* Sticky download bar at bottom */
    .doc-card {
      border-radius: 20px;
      padding: 20px;
      position: sticky;
      bottom: calc(64px + var(--safe-bottom, 0px));
      z-index: 40;
      background:
        linear-gradient(180deg, rgba(20,18,22,.98), rgba(11,10,13,.94)),
        radial-gradient(circle at 100% 0%, rgba(212,175,55,.08), transparent 34%);
      box-shadow: 0 -2px 16px rgba(0,0,0,.2);
    }

    .doc-card-top {
      padding-bottom: 14px;
    }

    .doc-card-shelf {
      align-self: flex-start;
      white-space: normal;
    }

    .doc-card-left {
      align-items: flex-start;
    }

    .doc-card-info {
      gap: 6px;
    }

    .doc-card-name {
      white-space: normal;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .doc-dl {
      min-height: 52px;
      border-radius: 12px;
      font-size: 14px;
    }

    .doc-meta-grid {
      gap: 8px;
      grid-template-columns: repeat(2, 1fr);
    }

    .doc-meta-item {
      padding: 12px;
      border-radius: 12px;
      font-size: 13px;
    }

    .rel { padding-top: 40px; }
    .rel-grid { grid-template-columns: 1fr; gap: 8px; }

    .rel-card {
      border-radius: 16px;
      padding: 16px;
      min-height: auto;
    }

    .doc-card-actions {
      width: 100%;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 52px;
      grid-template-areas:
        "dl dl"
        "share fav";
      gap: 10px;
      align-items: stretch;
    }

    .doc-dl {
      grid-area: dl;
      width: 100%;
      justify-content: center;
      background: linear-gradient(135deg, #d4af37, #f6e27a);
      color: #09080a;
      font-weight: 600;
      border: none;
    }

    .doc-share {
      grid-area: share;
      min-height: 48px;
      justify-content: center;
      padding: 0 14px;
      border-radius: 12px;
    }

    .doc-fav {
      grid-area: fav;
      width: 52px;
      min-height: 48px;
      padding: 0;
      border-radius: 12px;
    }
  }

  @media (min-width: 641px) and (max-width: 900px) {
    .rel-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .rel-card, .doc-dl, .doc-share {
      transition: none !important;
    }
  }
</style>

<script>
  function initDocPage() {
    var app = window.academicSalon || {};
    var showGlobalToast = app.showToast || window.showToast || function() {};
    var track = app.track || function() {};
    var btn = document.getElementById('shareBtn');
    var text = document.getElementById('shareBtnText');
    if (btn && text && btn.dataset.bound !== 'true') {
      btn.dataset.bound = 'true';
      btn.dataset.defaultLabel = text.textContent || 'Скопировать';
      btn.addEventListener('click', function() {
        var copy = app.copyText ? app.copyText(window.location.href) : navigator.clipboard.writeText(window.location.href);
        copy.then(function() {
          text.textContent = 'Скопировано!';
          track('doc_share_copy', { path: window.location.pathname });
          setTimeout(function() { text.textContent = btn.dataset.defaultLabel || 'Скопировать'; }, 2000);
        }).catch(function() {
          showGlobalToast('Не удалось скопировать ссылку', 'error');
        });
      });
    }

    /* Doc stats */
    var statsEl = document.getElementById('docStats');
    var statsVal = document.getElementById('docStatsValue');
    if (statsEl && statsVal) {
      var filePath = statsEl.closest('.doc')?.querySelector('[data-file]')?.dataset.file
        || window.location.pathname.replace('/doc/', '').replace(/\/$/, '');
      fetch('/api/doc-stats/batch', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ files: [decodeURIComponent(filePath)] }),
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (!data.ok || !data.stats) return;
        var keys = Object.keys(data.stats);
        if (!keys.length) return;
        var s = data.stats[keys[0]];
        var views = s.views || 0;
        var downloads = s.downloads || 0;
        if (views + downloads === 0) return;
        var parts = [];
        if (views) parts.push(views + ' просм.');
        if (downloads) parts.push(downloads + ' скач.');
        statsVal.textContent = parts.join(' · ');
        statsEl.style.display = '';
      }).catch(function() {});
    }

    /* Favorites */
    var favBtn = document.getElementById('favBtn');
    if (favBtn && favBtn.dataset.bound !== 'true') {
      favBtn.dataset.bound = 'true';
      var fileKey = favBtn.dataset.file;
      var favs = JSON.parse(localStorage.getItem('favorites') || '[]');
      if (favs.indexOf(fileKey) !== -1) favBtn.classList.add('is-active');
      favBtn.addEventListener('click', function() {
        var favs = JSON.parse(localStorage.getItem('favorites') || '[]');
        var idx = favs.indexOf(fileKey);
        if (idx === -1) { favs.push(fileKey); } else { favs.splice(idx, 1); }
        localStorage.setItem('favorites', JSON.stringify(favs));
        favBtn.classList.toggle('is-active', idx === -1);
        track(idx === -1 ? 'doc_favorite_add' : 'doc_favorite_remove', { file: fileKey });
      });
    }
  }

  /* Auto-scroll to Related after download + save to history */
  var docApp = window.academicSalon || {};
  var track = docApp.track || function() {};
  var dlBtn = document.querySelector('.doc-dl');
  if (dlBtn && dlBtn.dataset.bound !== 'true') {
    dlBtn.dataset.bound = 'true';
    dlBtn.addEventListener('click', function() {
      /* Save to browsing history */
      try {
        var history = JSON.parse(localStorage.getItem('viewHistory') || '[]');
        var entry = { file: window.location.pathname, title: document.querySelector('.doc-title')?.textContent || '', time: Date.now() };
        history = history.filter(function(h) { return h.file !== entry.file; });
        history.unshift(entry);
        if (history.length > 20) history = history.slice(0, 20);
        localStorage.setItem('viewHistory', JSON.stringify(history));
      } catch(e) {}

      /* Toast + scroll to related */
      if (typeof showToast === 'function') showToast('Скачивание началось', 'success');
      var file = dlBtn.getAttribute('href') || window.location.pathname;
      track('doc_download_start', { file: file });
      setTimeout(function() {
        var rel = document.querySelector('.rel');
        if (rel) rel.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 1500);
    });
  }

  /* Save page view to history */
  try {
    var hist = JSON.parse(localStorage.getItem('viewHistory') || '[]');
    var path = window.location.pathname;
    var titleEl = document.querySelector('.doc-title');
    if (titleEl && !hist.some(function(h) { return h.file === path; })) {
      hist.unshift({ file: path, title: titleEl.textContent || '', time: Date.now() });
      if (hist.length > 20) hist = hist.slice(0, 20);
      localStorage.setItem('viewHistory', JSON.stringify(hist));
    }
  } catch(e) {}

  initDocPage();
  document.addEventListener('astro:after-swap', initDocPage);
</script>

<!-- ═══════ GSAP Doc Animations ═══════ -->
<script>
  var docGsapModules;

  function loadDocGsap() {
    if (!docGsapModules) {
      docGsapModules = Promise.all([
        import('gsap'),
        import('gsap/ScrollTrigger')
      ]).then(function(mods) {
        var gsap = mods[0].gsap;
        var ScrollTrigger = mods[1].ScrollTrigger;
        gsap.registerPlugin(ScrollTrigger);
        return { gsap: gsap, ScrollTrigger: ScrollTrigger };
      });
    }
    return docGsapModules;
  }

  async function initDocGSAP() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.innerWidth <= 768) return;
    var mods = await loadDocGsap();
    var gsap = mods.gsap;
    var ScrollTrigger = mods.ScrollTrigger;
    ScrollTrigger.getAll().forEach(function(st) { st.kill(); });

    // Document title entrance
    const docTitle = document.querySelector('.doc-title');
    if (docTitle) {
      gsap.from(docTitle, {
        opacity: 0, y: 20, duration: 0.7, delay: 0.2, ease: 'power3.out',
      });
    }

    // Meta items stagger
    const metaItems = document.querySelectorAll('.meta-row');
    if (metaItems.length) {
      gsap.from(metaItems, {
        opacity: 0, x: -12, stagger: 0.06,
        duration: 0.5, delay: 0.4, ease: 'power2.out',
      });
    }

    // Download button entrance
    const dlBtn = document.querySelector('.dl-btn');
    if (dlBtn) {
      gsap.from(dlBtn, {
        opacity: 0, y: 12, duration: 0.5, delay: 0.6, ease: 'power2.out',
      });
    }

    // Related cards
    const related = document.querySelectorAll('.rel-card');
    if (related.length) {
      gsap.from(related, {
        opacity: 0, y: 16, stagger: 0.08,
        duration: 0.5, ease: 'power3.out',
        scrollTrigger: { trigger: '.rel', start: 'top 85%', once: true },
      });
    }
  }

  document.addEventListener('astro:page-load', initDocGSAP);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDocGSAP);
  } else {
    initDocGSAP();
  }
</script>
