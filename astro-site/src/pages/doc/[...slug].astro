---
import Base from '../../layouts/Base.astro';
import { D } from '../../data/catalog.js';


export function getStaticPaths() {
  return D.map((doc: any) => ({
    params: { slug: doc.file },
    props: { doc },
  }));
}

const { doc } = Astro.props;

const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
const desc = doc.catalogDescription || doc.description || '';
const fullText = doc.text || desc || '';
const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
const tags = (doc.tags || []).filter(Boolean) as string[];
const fileUrl = doc.file.startsWith('files/') ? `/${doc.file}` : `/files/${doc.file}`;
const currentYear = String(new Date().getFullYear());

const yearBlob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
const yearMatch = yearBlob.match(/(?:19|20)\d{2}/);
const year = yearMatch ? yearMatch[0] : currentYear;

const shortType: Record<string, string> = {
  'Самостоятельная работа': 'Самостоятельная',
  'Выпускная квалификационная работа': 'ВКР',
  'Экзаменационные материалы': 'Экзамен',
  'Контрольная работа': 'Контрольная',
  'Курсовая работа': 'Курсовая',
  'Отчет по практике': 'Отчёт',
  'Отчет о научно-практической работе': 'НПР',
  'Справочный материал': 'Справочник',
  'Нормативный документ': 'Нормативный',
  'Шаблон документа': 'Шаблон',
  'Аналитический документ': 'Аналитика',
  'Методические материалы': 'Методичка',
};

const rawType = doc.docType || '';
const docType = shortType[rawType] || rawType;

const meta = [
  doc.subject ? { k: 'Предмет', v: doc.subject } : null,
  doc.category ? { k: 'Категория', v: doc.category } : null,
  { k: 'Формат', v: ext.toUpperCase() + (doc.size ? ' · ' + doc.size : '') },
  { k: 'Год', v: year },
  doc.course ? { k: 'Курс', v: doc.course } : null,
].filter(Boolean) as { k: string; v: string }[];

const related = D.filter((d: any) =>
  d.file !== doc.file &&
  ((doc.category && d.category === doc.category) ||
   (doc.subject && d.subject === doc.subject))
).slice(0, 3);

function relType(d: any) {
  const raw = d.docType || '';
  return shortType[raw] || raw;
}

function relYear(d: any) {
  const s = [d.filename, d.newFilename, d.title, d.catalogTitle, d.text].filter(Boolean).join(' ');
  const m = s.match(/(?:19|20)\d{2}/);
  return m ? m[0] : currentYear;
}

/* Map doc type to order calculator pill value */
const typeToOrderVal: Record<string, string> = {
  'Курсовая работа': 'kurs_t',
  'Выпускная квалификационная работа': 'diplom',
  'Контрольная работа': 'kont',
  'Отчет по практике': 'ref',
  'Самостоятельная работа': 'ref',
  'Методические материалы': 'ref',
};
const orderType = typeToOrderVal[rawType] || 'ref';
const orderParams = new URLSearchParams({
  type: orderType,
  subject: doc.subject || '',
  topic: title,
}).toString();
const orderUrl = `/order?${orderParams}`;
---

<Base
  title={title + ' — Библиотека академического салона'}
  description={desc}
  ogTitle={title}
  ogDescription={[docType, doc.subject, year].filter(Boolean).join(' · ') + ' — скачать бесплатно'}
>

  <article class="doc">

    <!-- Breadcrumb -->
    <nav class="crumb" aria-label="Навигация">
      <a href="/catalog">Каталог</a>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <span>{title.length > 50 ? title.slice(0, 50) + '…' : title}</span>
    </nav>

    <!-- Header -->
    <header class="doc-header">
      <div class="doc-format-badge" aria-hidden="true">
        <span class="format-ext">{ext}</span>
      </div>
      <div class="doc-header-text">
        {docType && <p class="doc-type">{docType}</p>}
        <h1 class="doc-title">{title}</h1>
      </div>
    </header>

    <!-- Rule -->
    <div class="doc-rule" aria-hidden="true"></div>

    <!-- Description -->
    {desc && <p class="doc-desc">{desc}</p>}

    <!-- Extended preview -->
    {fullText && fullText !== desc && fullText.length > desc.length + 20 && (
      <details class="doc-preview">
        <summary class="doc-preview-toggle">
          <span>Подробнее о документе</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <p class="doc-preview-text">{fullText}</p>
      </details>
    )}

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="doc-tags">
        {tags.map(tag => (
          <span class="doc-tag">{tag}</span>
        ))}
      </div>
    )}

    <!-- Metadata -->
    <div class="doc-meta-grid">
      {meta.map(m => (
        <div class="doc-meta-item">
          <span class="doc-meta-label">{m.k}</span>
          <span class="doc-meta-value">{m.v}</span>
        </div>
      ))}
      <div class="doc-meta-item doc-meta-stats" id="docStats" style="display:none">
        <span class="doc-meta-label">Популярность</span>
        <span class="doc-meta-value" id="docStatsValue"></span>
      </div>
    </div>

    <!-- Download card -->
    <div class="doc-card">
      <div class="doc-card-body">
        <div class="doc-card-left">
          <div class="doc-card-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <div class="doc-card-info">
            <span class="doc-card-name">{doc.filename || title}</span>
            <span class="doc-card-meta">{ext.toUpperCase()} · {doc.size || ''}</span>
          </div>
        </div>
        <div class="doc-card-actions">
          <a href={fileUrl} class="doc-dl" download>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Скачать
          </a>
          <button class="doc-share" id="shareBtn" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            <span id="shareBtnText">Скопировать</span>
          </button>
          <a class="doc-share doc-share-social" href={'https://t.me/share/url?url=' + encodeURIComponent('https://bibliosaloon.ru/doc/' + doc.file) + '&text=' + encodeURIComponent(title + ' — скачать бесплатно')} target="_blank" rel="noopener" aria-label="Поделиться в Telegram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2.5L2 10l7 3 3 7 9.5-18z"/><line x1="9" y1="13" x2="13.5" y2="8.5"/></svg>
            TG
          </a>
          <a class="doc-share doc-share-social" href={'https://vk.com/share.php?url=' + encodeURIComponent('https://bibliosaloon.ru/doc/' + doc.file) + '&title=' + encodeURIComponent(title)} target="_blank" rel="noopener" aria-label="Поделиться в VK">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M12.5 16.5c-3.5 0-5.5-2.5-5.6-5h2c.1 1.8 1.3 2.5 2.3 2.7V11.5c-1.5-.2-3-1-3-3.5 0-1.7 1.2-2.9 3-3v3"/></svg>
            VK
          </a>
          <button class="doc-fav" id="favBtn" type="button" data-file={doc.file} aria-label="В избранное">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Order similar CTA -->
    <div class="doc-order-cta">
      <p class="doc-order-text">Нужна похожая работа под ваши требования?</p>
      <a href={orderUrl} class="doc-order-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 12 15 15"/></svg>
        Заказать похожую
      </a>
    </div>

    <!-- Related -->
    {related.length > 0 && (
      <section class="rel">
        <h2 class="rel-title">Похожие работы</h2>
        <div class="rel-grid">
          {related.map((r: any) => {
            const rTitle = r.catalogTitle || r.title || r.filename || 'Документ';
            const rSubj = r.subject || '';
            const rYear = relYear(r);
            return (
              <a href={`/doc/${r.file}`} class="rel-card">
                <span class="rel-card-type">{relType(r)}</span>
                <h3 class="rel-card-title">{rTitle}</h3>
                <span class="rel-card-meta">{[rSubj, rYear].filter(Boolean).join(' · ')}</span>
              </a>
            );
          })}
        </div>
      </section>
    )}

  </article>

</Base>

<style>
  .doc {
    max-width: 800px;
    margin: 0 auto;
    padding: 32px 48px 48px;
  }

  /* ═══════ BREADCRUMB ═══════ */
  .crumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    margin-bottom: 48px;
  }

  .crumb svg {
    opacity: .4;
  }

  .crumb a {
    color: var(--t3);
    text-decoration: none;
    transition: color var(--dur) var(--ease);
  }

  .crumb a:hover { color: var(--ac); }

  /* ═══════ HEADER ═══════ */
  .doc-header {
    display: flex;
    gap: 24px;
    align-items: flex-start;
    padding: 30px 30px 28px;
    border: 1px solid var(--brd);
    border-radius: 0;
    background: var(--card);
  }

  .doc-format-badge {
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0;
    background:
      radial-gradient(circle at 50% 30%, rgba(246,226,122,.16), var(--ac-sh) 45%, var(--surf) 100%);
    border: 1px solid var(--ac-b);
    box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
  }

  .format-ext {
    font: 600 11px/1 var(--fm);
    text-transform: uppercase;
    letter-spacing: .5px;
    color: var(--ac);
  }

  .doc-header-text {
    position: relative;
    z-index: 1;
    flex: 1;
    min-width: 0;
  }

  .doc-type {
    font: 500 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--ac);
    opacity: .6;
    margin-bottom: 12px;
  }

  .doc-title {
    font: 400 clamp(26px, 4.5vw, 38px)/1.2 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
  }

  /* ═══════ RULE ═══════ */
  .doc-rule {
    width: 48px;
    height: 1px;
    background: linear-gradient(90deg, var(--ac), transparent);
    opacity: .2;
    margin: 32px 0;
  }

  /* ═══════ DESCRIPTION ═══════ */
  .doc-desc {
    font: 400 15px/1.8 var(--fi);
    color: var(--t2);
    max-width: 600px;
    margin-bottom: 40px;
  }

  /* ═══════ PREVIEW / TAGS ═══════ */
  .doc-preview {
    margin-bottom: 32px;
  }

  .doc-preview-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    list-style: none;
    transition: color var(--dur) var(--ease);
  }

  .doc-preview-toggle::-webkit-details-marker { display: none; }
  .doc-preview-toggle::marker { display: none; content: ''; }
  .doc-preview-toggle:hover { color: var(--ac); }

  .doc-preview-toggle svg {
    transition: transform var(--dur) var(--ease);
  }
  .doc-preview[open] .doc-preview-toggle svg {
    transform: rotate(180deg);
  }

  .doc-preview-text {
    margin-top: 16px;
    font: 400 14px/1.7 var(--fi);
    color: var(--t2);
    max-width: 600px;
  }

  .doc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 32px;
  }

  .doc-tag {
    padding: 4px 12px;
    border: 1px solid var(--brd);
    font: 400 11px/1 var(--fi);
    color: var(--t3);
    text-transform: lowercase;
  }

  /* ═══════ METADATA ═══════ */
  .doc-meta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
    gap: 10px;
    margin-bottom: 28px;
  }

  .doc-meta-item {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px;
    background: linear-gradient(180deg, var(--card), rgba(255,255,255,.01));
    border: 1px solid var(--ac-sh);
    border-radius: 0;
  }

  .doc-meta-label {
    font: 400 9px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
  }

  .doc-meta-value {
    font: 400 14px/1.2 var(--fi);
    color: var(--t1);
  }

  /* ═══════ DOWNLOAD CARD ═══════ */
  .doc-card {
    position: relative;
    display: grid;
    padding: 22px;
    margin-bottom: 48px;
    background: var(--card);
    border: 1px solid var(--brd);
    border-radius: 0;
    transition:
      border-color var(--dur-slow) var(--ease);
  }

  .doc-card:hover {
    border-color: var(--ac-b);
  }

  .doc-card-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(228px, 272px);
    align-items: center;
    gap: 18px;
  }

  .doc-card-left {
    display: flex;
    align-items: center;
    gap: 16px;
    min-width: 0;
  }

  .doc-card-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0;
    background: var(--surf);
    border: 1px solid var(--ac-g);
    color: var(--ac);
  }

  .doc-card-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .doc-card-name {
    font: 400 13px/1.3 var(--fi);
    color: var(--t2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .doc-card-meta {
    font: 400 11px/1 var(--fm);
    color: var(--t3);
    opacity: .6;
  }

  .doc-card-actions {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-areas:
      "dl dl dl dl"
      "share tg vk fav";
    gap: 8px;
    align-items: stretch;
    width: 100%;
    min-width: 0;
  }

  .doc-dl {
    grid-area: dl;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 16px 40px;
    background: transparent;
    border: 1px solid var(--ac-b);
    border-radius: 0;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t1);
    text-decoration: none;
    transition:
      background var(--dur-slow) var(--ease),
      border-color var(--dur-slow) var(--ease),
      color var(--dur-slow) var(--ease);
  }

  .doc-dl:hover {
    background: var(--ac-line);
    border-color: var(--ac-b2);
  }

  .doc-share {
    grid-area: share;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-width: 0;
    padding: 12px 8px;
    background: transparent;
    border: 1px solid var(--ac-b);
    border-radius: 0;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--t3);
    cursor: pointer;
    transition:
      border-color var(--dur) var(--ease),
      color var(--dur) var(--ease);
  }

  .doc-share:hover {
    border-color: var(--brd-h);
    color: var(--t1);
  }

  /* #28: Copy link button feedback animation */
  .doc-share.is-copied {
    border-color: var(--ac-b);
    color: var(--ac);
  }

  .doc-share-social {
    padding: 12px 8px;
    text-decoration: none;
  }

  .doc-share-social:nth-of-type(2) { grid-area: tg; }
  .doc-share-social:nth-of-type(3) { grid-area: vk; }

  .doc-fav {
    grid-area: fav;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 8px;
    background: transparent;
    border: 1px solid var(--ac-b);
    border-radius: 0;
    color: var(--t3);
    cursor: pointer;
    transition:
      border-color var(--dur) var(--ease),
      color var(--dur) var(--ease);
  }
  .doc-fav:hover { border-color: var(--brd-h); color: var(--ac); }
  .doc-fav.is-active { color: var(--ac); border-color: var(--ac-b); }
  .doc-fav.is-active svg { fill: var(--ac); }

  [data-theme="light"] .doc-header,
  [data-theme="light"] .doc-card {
    border-color: rgba(160,120,24,.12);
  }

  [data-theme="light"] .doc-format-badge {
    border-color: rgba(160,120,24,.18);
    background:
      radial-gradient(circle at 50% 30%, rgba(180,140,20,.18), rgba(180,140,20,.08) 45%, rgba(255,255,255,.72) 100%);
    color: #8d6b18;
  }


  @media (max-width: 640px) {
    .doc-card-body {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 16px;
    }
    .doc-card-actions {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-areas:
        "dl dl dl dl"
        "share tg vk fav";
    }
    .doc-dl { justify-content: center; }
    .doc-share { justify-content: center; padding: 14px 12px; }
    .doc-share-social { padding: 14px 12px; font-size: 11px; }
  }

  /* ═══════ ORDER SIMILAR CTA ═══════ */
  .doc-order-cta {
    margin-top: 48px;
    padding: 28px 32px;
    border: 1px solid var(--ac-b);
    border-top: 2px solid var(--ac-b2);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .doc-order-text {
    font: 400 14px/1.5 var(--fi);
    color: var(--t2);
  }

  .doc-order-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: var(--surf);
    border: 1px solid var(--ac-b2);
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--ac);
    text-decoration: none;
    transition:
      background var(--dur-slow) var(--ease),
      border-color var(--dur-slow) var(--ease),
      box-shadow var(--dur-slow) var(--ease),
      transform var(--dur-slow) var(--ease);
  }

  .doc-order-btn:hover {
    background: var(--ac-g);
    border-color: var(--ac-b3);
    box-shadow: 0 8px 32px var(--ac-sh);
    transform: translateY(-2px);
  }

  @media (max-width: 640px) {
    .doc-order-cta {
      flex-direction: column;
      text-align: center;
      padding: 24px 20px;
    }
    .doc-order-btn {
      width: 100%;
      justify-content: center;
    }
  }

  /* ═══════ RELATED ═══════ */
  .rel {
    padding-top: 64px;
    border-top: 1px solid var(--brd);
  }

  .rel-title {
    font: 300 clamp(22px, 4vw, 28px)/1 var(--fd);
    color: var(--t1);
    margin-bottom: 32px;
  }

  .rel-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .rel-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 16px;
    padding: 24px;
    min-height: 160px;
    background: var(--card);
    border: 1px solid var(--brd);
    border-top: 2px solid var(--ac-b);
    border-radius: 0;
    text-decoration: none;
    color: inherit;
    transition:
      background var(--dur-slow) var(--ease),
      border-color var(--dur-slow) var(--ease),
      box-shadow var(--dur-slow) var(--ease),
      transform var(--dur-slow) var(--ease);
  }

  .rel-card:hover {
    background: var(--card-h);
    border-color: var(--ac-glow);
    border-top-color: var(--ac-b3);
    box-shadow: 0 8px 32px var(--ac-t);
    transform: translateY(-3px);
  }

  .rel-card-type {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--t3);
  }

  .rel-card-title {
    font: 400 clamp(16px, 2vw, 19px)/1.4 var(--fd);
    color: var(--t1);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--dur) var(--ease);
  }

  .rel-card:hover .rel-card-title {
    color: var(--ac3);
  }

  .rel-card-meta {
    font: 400 11px/1.3 var(--fi);
    color: var(--t3);
    padding-top: 8px;
    border-top: 1px solid var(--brd);
  }

  /* ═══════ MOBILE ═══════ */
  /* ═══════ MOBILE ENTRANCE ANIMATIONS ═══════ */
  @media (max-width: 768px) {
    .crumb, .doc-header, .doc-description, .doc-card, .doc-meta-grid, .rel {
      opacity: 0;
      transform: translateY(16px);
      animation: doc-enter .5s cubic-bezier(.16,1,.3,1) forwards;
    }
    .crumb { animation-delay: 0s; }
    .doc-header { animation-delay: .06s; }
    .doc-description { animation-delay: .14s; }
    .doc-card { animation-delay: .18s; }
    .doc-meta-grid { animation-delay: .24s; }
    .rel { animation-delay: .3s; }

    @keyframes doc-enter {
      to { opacity: 1; transform: translateY(0); }
    }
  }

  @media (max-width: 640px) {
    .doc { padding: 20px 16px 88px; }
    .crumb { margin-bottom: 16px; font-size: 13px; }

    .doc-header {
      flex-direction: column;
      gap: 16px;
      padding: 24px 18px 22px;
    }

    .doc-title {
      font-size: clamp(24px, 6vw, 32px);
      line-height: 1.2;
    }

    .doc-format-badge {
      width: 48px;
      height: 48px;
    }

    /* Sticky download bar at bottom */
    .doc-card {
      border-radius: 0;
      padding: 20px;
      position: sticky;
      bottom: calc(64px + var(--safe-bottom, 0px));
      z-index: 40;
      background: var(--card);
      box-shadow: 0 -2px 16px rgba(0,0,0,.2);
    }

    .doc-card-left {
      align-items: flex-start;
    }

    .doc-card-info {
      gap: 6px;
    }

    .doc-card-name {
      white-space: normal;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .doc-dl {
      padding: 16px 40px;
      border-radius: 0;
      font-size: 14px;
    }

    .doc-meta-grid {
      gap: 8px;
      grid-template-columns: repeat(2, 1fr);
    }

    .doc-meta-item {
      padding: 12px;
      border-radius: 0;
      font-size: 13px;
    }

    .rel { padding-top: 40px; }
    .rel-grid { grid-template-columns: 1fr; gap: 8px; }

    .rel-card {
      border-radius: 0;
      padding: 16px;
      min-height: auto;
    }

    .doc-dl {
      background: linear-gradient(135deg, #d4af37, #f6e27a);
      color: #09080a;
      font-weight: 600;
      border: none;
      border-radius: 0;
    }
  }

  @media (max-width: 900px) {
    .doc-card-body {
      grid-template-columns: 1fr;
      align-items: stretch;
    }

    .doc-card-actions {
      max-width: none;
    }
  }

  @media (min-width: 641px) and (max-width: 900px) {
    .rel-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .rel-card, .doc-dl, .doc-share, .doc-share-social {
      transition: none !important;
    }
  }
</style>

<script>
  function initDocPage() {
    var app = window.academicSalon || {};
    var showGlobalToast = app.showToast || window.showToast || function() {};
    var track = app.track || function() {};
    var btn = document.getElementById('shareBtn');
    var text = document.getElementById('shareBtnText');
    if (btn && text && btn.dataset.bound !== 'true') {
      btn.dataset.bound = 'true';
      btn.dataset.defaultLabel = text.textContent || 'Скопировать';
      btn.addEventListener('click', function() {
        if (navigator.share) {
          navigator.share({
            title: document.title,
            text: document.querySelector('meta[name="description"]')?.getAttribute('content') || '',
            url: window.location.href
          }).then(function() {
            track('doc_share_native', { path: window.location.pathname });
          }).catch(function() {});
        } else {
          var copy = app.copyText ? app.copyText(window.location.href) : navigator.clipboard.writeText(window.location.href);
          copy.then(function() {
            text.textContent = 'Скопировано!';
            btn.classList.add('is-copied');
            track('doc_share_copy', { path: window.location.pathname });
            setTimeout(function() { text.textContent = btn.dataset.defaultLabel || 'Скопировать'; btn.classList.remove('is-copied'); }, 2000);
          }).catch(function() {
            showGlobalToast('Не удалось скопировать ссылку', 'error');
          });
        }
      });
    }

    /* Doc stats */
    var statsEl = document.getElementById('docStats');
    var statsVal = document.getElementById('docStatsValue');
    if (statsEl && statsVal) {
      var filePath = statsEl.closest('.doc')?.querySelector('[data-file]')?.dataset.file
        || window.location.pathname.replace('/doc/', '').replace(/\/$/, '');
      fetch('/api/doc-stats/batch', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ files: [decodeURIComponent(filePath)] }),
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (!data.ok || !data.stats) return;
        var keys = Object.keys(data.stats);
        if (!keys.length) return;
        var s = data.stats[keys[0]];
        var views = s.views || 0;
        var downloads = s.downloads || 0;
        if (views + downloads === 0) return;
        var parts = [];
        if (views) parts.push(views + ' просм.');
        if (downloads) parts.push(downloads + ' скач.');
        statsVal.textContent = parts.join(' · ');
        statsEl.style.display = '';
      }).catch(function() {});
    }

    /* Favorites */
    var favBtn = document.getElementById('favBtn');
    if (favBtn && favBtn.dataset.bound !== 'true') {
      favBtn.dataset.bound = 'true';
      var fileKey = favBtn.dataset.file;
      var favs = JSON.parse(localStorage.getItem('favorites') || '[]');
      if (favs.indexOf(fileKey) !== -1) favBtn.classList.add('is-active');
      favBtn.addEventListener('click', function() {
        var favs = JSON.parse(localStorage.getItem('favorites') || '[]');
        var idx = favs.indexOf(fileKey);
        if (idx === -1) { favs.push(fileKey); } else { favs.splice(idx, 1); }
        localStorage.setItem('favorites', JSON.stringify(favs));
        favBtn.classList.toggle('is-active', idx === -1);
        track(idx === -1 ? 'doc_favorite_add' : 'doc_favorite_remove', { file: fileKey });
      });
    }
  }

  /* Auto-scroll to Related after download + save to history */
  var docApp = window.academicSalon || {};
  var track = docApp.track || function() {};
  var dlBtn = document.querySelector('.doc-dl');
  if (dlBtn && dlBtn.dataset.bound !== 'true') {
    dlBtn.dataset.bound = 'true';
    dlBtn.addEventListener('click', function() {
      /* Save to browsing history */
      try {
        var history = JSON.parse(localStorage.getItem('viewHistory') || '[]');
        var entry = { file: window.location.pathname, title: document.querySelector('.doc-title')?.textContent || '', time: Date.now() };
        history = history.filter(function(h) { return h.file !== entry.file; });
        history.unshift(entry);
        if (history.length > 20) history = history.slice(0, 20);
        localStorage.setItem('viewHistory', JSON.stringify(history));
      } catch(e) {}

      /* Toast + scroll to related */
      if (typeof showToast === 'function') showToast('Скачивание началось', 'success');
      var file = dlBtn.getAttribute('href') || window.location.pathname;
      track('doc_download_start', { file: file });
      setTimeout(function() {
        var rel = document.querySelector('.rel');
        if (rel) rel.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 1500);
    });
  }

  /* Save page view to history */
  try {
    var hist = JSON.parse(localStorage.getItem('viewHistory') || '[]');
    var path = window.location.pathname;
    var titleEl = document.querySelector('.doc-title');
    if (titleEl && !hist.some(function(h) { return h.file === path; })) {
      hist.unshift({ file: path, title: titleEl.textContent || '', time: Date.now() });
      if (hist.length > 20) hist = hist.slice(0, 20);
      localStorage.setItem('viewHistory', JSON.stringify(hist));
    }
  } catch(e) {}

  /* #26: Save to recentDocs for future "recently viewed" features */
  try {
    var recentDocs = JSON.parse(localStorage.getItem('recentDocs') || '[]');
    var slug = window.location.pathname.replace('/doc/', '').replace(/\/$/, '');
    var docTitle = document.querySelector('.doc-title')?.textContent || '';
    recentDocs = recentDocs.filter(function(d) { return d.slug !== slug; });
    recentDocs.unshift({ slug: slug, title: docTitle, ts: Date.now() });
    if (recentDocs.length > 10) recentDocs = recentDocs.slice(0, 10);
    localStorage.setItem('recentDocs', JSON.stringify(recentDocs));
  } catch(e) {}

  initDocPage();
  document.addEventListener('astro:after-swap', initDocPage);
</script>

<!-- ═══════ GSAP Doc Animations ═══════ -->
<script>
  var docGsapModules;

  function loadDocGsap() {
    if (!docGsapModules) {
      docGsapModules = Promise.all([
        import('gsap'),
        import('gsap/ScrollTrigger')
      ]).then(function(mods) {
        var gsap = mods[0].gsap;
        var ScrollTrigger = mods[1].ScrollTrigger;
        gsap.registerPlugin(ScrollTrigger);
        return { gsap: gsap, ScrollTrigger: ScrollTrigger };
      });
    }
    return docGsapModules;
  }

  async function initDocGSAP() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.innerWidth <= 768) return;
    var mods = await loadDocGsap();
    var gsap = mods.gsap;
    var ScrollTrigger = mods.ScrollTrigger;
    ScrollTrigger.getAll().forEach(function(st) { st.kill(); });

    // Document title entrance
    const docTitle = document.querySelector('.doc-title');
    if (docTitle) {
      gsap.from(docTitle, {
        opacity: 0, y: 20, duration: 0.7, delay: 0.2, ease: 'power3.out',
      });
    }

    // Meta items stagger
    const metaItems = document.querySelectorAll('.doc-meta-item');
    if (metaItems.length) {
      gsap.from(metaItems, {
        opacity: 0, x: -12, stagger: 0.06,
        duration: 0.5, delay: 0.4, ease: 'power2.out',
      });
    }

    // Download button entrance
    const dlBtn = document.querySelector('.doc-dl');
    if (dlBtn) {
      gsap.from(dlBtn, {
        opacity: 0, y: 12, duration: 0.5, delay: 0.6, ease: 'power2.out',
      });
    }

    // Related cards
    const related = document.querySelectorAll('.rel-card');
    if (related.length) {
      gsap.from(related, {
        opacity: 0, y: 16, stagger: 0.08,
        duration: 0.5, ease: 'power3.out',
        scrollTrigger: { trigger: '.rel', start: 'top 85%', once: true },
      });
    }
  }

  document.addEventListener('astro:page-load', initDocGSAP);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDocGSAP);
  } else {
    initDocGSAP();
  }
</script>
