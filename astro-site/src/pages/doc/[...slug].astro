---
import Base from '../../layouts/Base.astro';
import { D } from '../../data/catalog.js';


export function getStaticPaths() {
  return D.map((doc: any) => ({
    params: { slug: doc.file },
    props: { doc },
  }));
}

const { doc } = Astro.props;

const title = doc.catalogTitle || doc.title || doc.filename || 'Документ';
const desc = doc.catalogDescription || doc.description || '';
const fullText = doc.text || desc || '';
const ext = (doc.filename?.split('.').pop() || 'docx').toLowerCase();
const tags = (doc.tags || []).filter(Boolean) as string[];
const fileUrl = doc.file.startsWith('files/') ? `/${doc.file}` : `/files/${doc.file}`;
const currentYear = String(new Date().getFullYear());

const yearBlob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
const yearMatch = yearBlob.match(/(?:19|20)\d{2}/);
const year = yearMatch ? yearMatch[0] : currentYear;

const shortType: Record<string, string> = {
  'Самостоятельная работа': 'Самостоятельная',
  'Выпускная квалификационная работа': 'ВКР',
  'Экзаменационные материалы': 'Экзамен',
  'Контрольная работа': 'Контрольная',
  'Курсовая работа': 'Курсовая',
  'Отчет по практике': 'Отчёт',
  'Отчет о научно-практической работе': 'НПР',
  'Справочный материал': 'Справочник',
  'Нормативный документ': 'Нормативный',
  'Шаблон документа': 'Шаблон',
  'Аналитический документ': 'Аналитика',
  'Методические материалы': 'Методичка',
};

const rawType = doc.docType || '';
const docType = shortType[rawType] || rawType;

const meta = [
  doc.subject ? { k: 'Предмет', v: doc.subject } : null,
  doc.category ? { k: 'Категория', v: doc.category } : null,
  { k: 'Формат', v: ext.toUpperCase() + (doc.size ? ' · ' + doc.size : '') },
  { k: 'Год', v: year },
  doc.course ? { k: 'Курс', v: doc.course } : null,
].filter(Boolean) as { k: string; v: string }[];

/* Related — fallback цепочка: subject&category → subject → category → год → random. */
function pickRelated(source: any, count = 5) {
  const seen = new Set<string>([source.file]);
  const pool: any[] = [];
  const push = (arr: any[]) => {
    for (const d of arr) {
      if (seen.has(d.file)) continue;
      seen.add(d.file);
      pool.push(d);
      if (pool.length >= count) break;
    }
  };
  // 1 — сильное совпадение: тот же subject И та же category
  if (source.subject && source.category) {
    push(D.filter((d: any) => d.subject === source.subject && d.category === source.category));
  }
  // 2 — тот же subject
  if (pool.length < count && source.subject) {
    push(D.filter((d: any) => d.subject === source.subject));
  }
  // 3 — та же category
  if (pool.length < count && source.category) {
    push(D.filter((d: any) => d.category === source.category));
  }
  // 4 — тот же год (извлекаем быстро)
  if (pool.length < count) {
    push(D.filter((d: any) => {
      const blob = [d.filename, d.newFilename, d.title, d.catalogTitle].filter(Boolean).join(' ');
      const m = blob.match(/(?:19|20)\d{2}/);
      return m && m[0] === year;
    }));
  }
  // 5 — любые оставшиеся (детерминированно, не random, чтобы SSG был стабилен)
  if (pool.length < count) {
    push(D);
  }
  return pool.slice(0, count);
}
const related = pickRelated(doc, 5);

function relType(d: any) {
  const raw = d.docType || '';
  return shortType[raw] || raw;
}

function relYear(d: any) {
  const s = [d.filename, d.newFilename, d.title, d.catalogTitle, d.text].filter(Boolean).join(' ');
  const m = s.match(/(?:19|20)\d{2}/);
  return m ? m[0] : currentYear;
}

/* Map doc type to order calculator pill value */
const typeToOrderVal: Record<string, string> = {
  'Курсовая работа': 'kurs_t',
  'Выпускная квалификационная работа': 'diplom',
  'Контрольная работа': 'kont',
  'Отчет по практике': 'ref',
  'Самостоятельная работа': 'ref',
  'Методические материалы': 'ref',
};
const orderType = typeToOrderVal[rawType] || 'ref';
const orderParams = new URLSearchParams({
  type: orderType,
  subject: doc.subject || '',
  topic: title,
}).toString();
const orderUrl = `/order?${orderParams}`;

/* Schema.org ScholarlyArticle — для SEO, вставляется в тело страницы. */
const canonicalUrl = `https://bibliosaloon.ru/doc/${doc.file}`;

/* ГОСТ-цитата (ГОСТ Р 7.0.100-2018, электронный ресурс) — стабильная строка для копирования. */
const citationParts = [
  `Академический Салон. ${title} [Электронный ресурс]`,
  rawType ? ` : ${rawType.toLowerCase()}` : '',
  `. — ${year}`,
  `. — URL: ${canonicalUrl}`,
  '.',
];
const citationText = citationParts.join('');
const schemaLd = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  headline: title,
  description: desc || title,
  datePublished: `${year}-01-01`,
  inLanguage: 'ru',
  author: { '@type': 'Organization', name: 'Академический Салон', url: 'https://bibliosaloon.ru' },
  publisher: { '@type': 'Organization', name: 'Академический Салон', url: 'https://bibliosaloon.ru' },
  about: doc.subject ? { '@type': 'Thing', name: doc.subject } : undefined,
  keywords: tags.length ? tags.join(', ') : undefined,
  url: canonicalUrl,
  isAccessibleForFree: true,
  encodingFormat: ext === 'pdf' ? 'application/pdf'
    : ext === 'docx' ? 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
    : ext === 'doc' ? 'application/msword'
    : undefined,
};
/* Удалим undefined-поля для чистого JSON-LD */
Object.keys(schemaLd).forEach((k) => {
  if ((schemaLd as any)[k] === undefined) delete (schemaLd as any)[k];
});
---

<Base
  title={title + ' — Библиотека академического салона'}
  description={desc}
  ogTitle={title}
  ogDescription={[docType, doc.subject, year].filter(Boolean).join(' · ') + ' — скачать бесплатно'}
>

  <!-- Schema.org ScholarlyArticle — SEO для Google Scholar / Bing Academic -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaLd)} />

  <article class="doc-folio">

    <!-- Breadcrumb — минимальная мето-навигация -->
    <nav class="doc-crumb" aria-label="Навигация">
      <a href="/catalog">Каталог</a>
      <span class="sep" aria-hidden="true">›</span>
      <span class="current">{title.length > 56 ? title.slice(0, 56) + '…' : title}</span>
    </nav>

    <!-- Eyebrow: тип · предмет · год -->
    <p class="doc-eyebrow">
      {docType && <><span class="type">{docType}</span><span class="dot" aria-hidden="true">·</span></>}
      {doc.subject && <><span class="subj">{doc.subject}</span><span class="dot" aria-hidden="true">·</span></>}
      <span class="year">{year}</span>
    </p>

    <!-- H1 — заголовок без коробок -->
    <h1 class="doc-title">{title}</h1>

    <!-- Lede — описание курсивом, узкой колонкой -->
    {desc && <p class="doc-lede">{desc}</p>}

    <!-- Full text — раскрываемый editorial-блок, если текст длиннее описания -->
    {fullText && fullText !== desc && fullText.length > (desc?.length ?? 0) + 20 && (
      <details class="doc-expand">
        <summary>
          <span class="doc-expand-lbl">Прочесть развёрнуто</span>
          <span class="doc-expand-chev" aria-hidden="true">+</span>
        </summary>
        <div class="doc-expand-body"><p>{fullText}</p></div>
      </details>
    )}

    <hr class="doc-hairline" aria-hidden="true" />

    <!-- Action-bar — основное действие + тонкие вторичные -->
    <div class="doc-actions" aria-label="Действия с документом">
      <div class="doc-actions-file">
        <span class="doc-actions-ext">{ext.toUpperCase()}</span>
        {doc.size && <span class="doc-actions-size">{doc.size}</span>}
        {doc.filename && <span class="doc-actions-name" title={doc.filename}>{doc.filename}</span>}
      </div>

      <div class="doc-actions-main">
        <a href={fileUrl} class="btn btn-gold" download>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Скачать
        </a>
        <button type="button" class="doc-action-link" id="favBtn" data-file={doc.file} aria-pressed="false">
          <span class="fav-star" aria-hidden="true">★</span>
          <span class="fav-lbl">сохранить</span>
        </button>
        <button type="button" class="doc-action-link" id="shareBtn">
          <span id="shareBtnText">копировать ссылку</span>
        </button>
      </div>

      <div class="doc-actions-share">
        <span class="share-lbl">поделиться:</span>
        <a
          class="share-link"
          href={'https://t.me/share/url?url=' + encodeURIComponent(canonicalUrl) + '&text=' + encodeURIComponent(title + ' — скачать бесплатно')}
          target="_blank" rel="noopener">Telegram</a>
        <span class="dot" aria-hidden="true">·</span>
        <a
          class="share-link"
          href={'https://vk.com/share.php?url=' + encodeURIComponent(canonicalUrl) + '&title=' + encodeURIComponent(title)}
          target="_blank" rel="noopener">VK</a>
      </div>
    </div>

    <hr class="doc-hairline" aria-hidden="true" />

    <!-- Meta-table — editorial «выходные данные» с dotted leader -->
    <dl class="doc-meta">
      {meta.map((m) => (
        <div class="meta-row">
          <dt>{m.k}</dt>
          <dd>{m.v}</dd>
        </div>
      ))}
      <div class="meta-row" id="docStats" hidden>
        <dt>Скачано</dt>
        <dd id="docStatsValue">—</dd>
      </div>
    </dl>

    <!-- Citation — editorial ГОСТ-цитата, раскрывается одним кликом -->
    <details class="doc-citation">
      <summary>
        <span class="doc-citation-lbl">Скопировать как цитату</span>
        <span class="doc-citation-hint" aria-hidden="true">ГОСТ Р 7.0.100-2018</span>
        <span class="doc-citation-chev" aria-hidden="true">+</span>
      </summary>
      <div class="doc-citation-body">
        <p class="doc-citation-text" id="citationText">{citationText}</p>
        <button type="button" class="doc-action-link" id="citationCopyBtn" data-default-label="скопировать">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          <span id="citationCopyLbl">скопировать</span>
        </button>
      </div>
    </details>

    <hr class="doc-hairline" aria-hidden="true" />

    <!-- Related — editorial-список, как Archive на главной -->
    {related.length > 0 && (
      <section class="doc-related" aria-label="Похожие работы">
        <header class="doc-related-head">
          <span class="roman" aria-hidden="true">V</span>
          <div class="head-body">
            <span class="eyebrow">Похожие работы</span>
            <h2>В архиве того же <em class="it">направления</em></h2>
          </div>
        </header>

        <ol class="doc-related-list" role="list">
          {related.map((r: any, i: number) => {
            const rTitle = r.catalogTitle || r.title || r.filename || 'Документ';
            return (
              <a href={`/doc/${r.file}`} class="doc-related-row">
                <span class="rr-no">№&nbsp;{String(i + 1).padStart(2, '0')}</span>
                <span class="rr-title">{rTitle}</span>
                <span class="rr-type">{relType(r)}</span>
                <span class="rr-subj">{r.subject || '—'}</span>
                <span class="rr-year">{relYear(r)}</span>
              </a>
            );
          })}
        </ol>
      </section>
    )}

    <!-- CTA «Под вашу тему» — editorial-плашка, как calendar-hint на главной -->
    <aside class="doc-cta" aria-label="Заказать похожую работу">
      <span class="doc-cta-glyph" aria-hidden="true">⁘</span>
      <div class="doc-cta-body">
        <h3>Нужна похожая работа <em class="it">под вашу тему</em>?</h3>
        <p>Напишем с&nbsp;нуля под&nbsp;вашего руководителя и&nbsp;кафедру. Плана касаемся за&nbsp;разговором, цифры&nbsp;— в&nbsp;калькуляторе.</p>
      </div>
      <a href={orderUrl} class="btn btn-gold btn-sm">
        Рассчитать
        <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 7h10m-3-3l3 3-3 3"/></svg>
      </a>
    </aside>

  </article>

</Base>

<!--
  /doc/[slug] — editorial folio.
  is:global c `.doc-folio` префиксом — защищает от утечки стилей.
  Ширина колонки 820px, минимальные gold-акценты, dotted leader в мета.
-->
<style is:global>
  .doc-folio {
    max-width: 820px;
    margin: 0 auto;
    padding: clamp(24px, 4vw, 48px) clamp(20px, 4vw, 32px) clamp(64px, 8vw, 96px);
    color: var(--cream);
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 2vw, 22px);
  }

  /* Breadcrumb */
  .doc-folio .doc-crumb {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
    margin: 0 0 clamp(16px, 2.5vw, 28px);
    flex-wrap: wrap;
  }
  .doc-folio .doc-crumb a {
    color: var(--mute);
    text-decoration: none;
    transition: color .3s var(--ease-silk);
  }
  .doc-folio .doc-crumb a:hover { color: var(--gold-ref); }
  .doc-folio .doc-crumb .sep { color: var(--gold-ref); opacity: 0.6; }
  .doc-folio .doc-crumb .current {
    color: var(--cream);
    max-width: 62ch;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Eyebrow — тип · предмет · год */
  .doc-folio .doc-eyebrow {
    margin: 0;
    font-family: var(--fm);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold-ref);
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }
  .doc-folio .doc-eyebrow .dot {
    color: var(--gold-ref);
    opacity: 0.5;
  }
  .doc-folio .doc-eyebrow .subj { color: var(--cream-2); }
  .doc-folio .doc-eyebrow .year { color: var(--mute); font-feature-settings: "tnum"; }

  /* H1 — на воздухе, без коробок */
  .doc-folio .doc-title {
    font-family: var(--fd);
    font-weight: 400;
    font-size: clamp(30px, 4.4vw, 56px);
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--cream);
    margin: 0;
    text-wrap: balance;
  }

  /* Lede — описание */
  .doc-folio .doc-lede {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.55;
    color: var(--cream-2);
    margin: 0;
    max-width: 62ch;
  }

  /* Expand — развёрнутый текст */
  .doc-folio .doc-expand {
    margin: 0;
  }
  .doc-folio .doc-expand summary {
    list-style: none;
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    cursor: pointer;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
    padding: 6px 0;
    transition: color .3s var(--ease-silk);
  }
  .doc-folio .doc-expand summary::-webkit-details-marker { display: none; }
  .doc-folio .doc-expand summary:hover { color: var(--gold-ref); }
  .doc-folio .doc-expand .doc-expand-chev {
    font-family: var(--fd);
    font-style: italic;
    font-size: 18px;
    color: var(--gold-ref);
    transition: transform .4s var(--ease-silk);
    line-height: 1;
  }
  .doc-folio .doc-expand[open] .doc-expand-chev { transform: rotate(45deg); }
  .doc-folio .doc-expand-body {
    padding: 12px 0 0;
  }
  .doc-folio .doc-expand-body p {
    font-family: var(--fd);
    font-size: clamp(15px, 1.3vw, 17px);
    line-height: 1.65;
    color: var(--cream-2);
    max-width: 64ch;
    margin: 0;
    white-space: pre-wrap;
  }

  /* Gold hairline */
  .doc-folio .doc-hairline {
    border: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-line) 20%, var(--gold-line) 80%, transparent);
    margin: clamp(8px, 1.5vw, 16px) 0;
  }

  /* Action-bar */
  .doc-folio .doc-actions {
    display: flex;
    flex-direction: column;
    gap: clamp(14px, 2vw, 20px);
    align-items: flex-start;
  }
  .doc-folio .doc-actions-file {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .doc-folio .doc-actions-ext {
    color: var(--gold-ref);
    border: 1px solid var(--gold-line);
    padding: 5px 9px;
    letter-spacing: 0.22em;
    font-weight: 500;
  }
  .doc-folio .doc-actions-size { color: var(--cream-2); }
  .doc-folio .doc-actions-name {
    color: var(--cream-2);
    letter-spacing: 0.04em;
    text-transform: none;
    font-family: var(--fm);
    font-size: 12px;
    max-width: 44ch;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    opacity: 0.7;
  }

  .doc-folio .doc-actions-main {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px 22px;
  }
  .doc-folio .doc-actions-main .btn-gold {
    padding: 14px 24px;
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .doc-folio .doc-actions-main .btn-gold svg {
    width: 16px; height: 16px;
  }
  .doc-folio .doc-action-link {
    background: transparent;
    border: 0;
    padding: 6px 0;
    color: var(--mute);
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: color .3s var(--ease-silk);
    border-bottom: 1px solid transparent;
  }
  .doc-folio .doc-action-link:hover { color: var(--gold-ref); border-bottom-color: var(--gold-line); }
  .doc-folio .doc-action-link .fav-star { color: var(--gold-ref); font-size: 12px; }
  .doc-folio .doc-action-link[aria-pressed="true"] { color: var(--gold-ref); }
  .doc-folio .doc-action-link[aria-pressed="true"] .fav-star { color: var(--gold-hi); }

  .doc-folio .doc-actions-share {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px 10px;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .doc-folio .doc-actions-share .share-lbl { color: var(--mute); }
  .doc-folio .doc-actions-share .share-link {
    color: var(--cream-2);
    text-decoration: none;
    border-bottom: 1px solid var(--line-2-ref);
    padding-bottom: 1px;
    transition: color .3s, border-color .3s;
  }
  .doc-folio .doc-actions-share .share-link:hover {
    color: var(--gold-ref);
    border-bottom-color: var(--gold-line);
  }
  .doc-folio .doc-actions-share .dot { color: var(--gold-ref); opacity: 0.4; }

  /* Meta — компактная таблица «выходные данные», max ~440px, без бесконечного leader */
  .doc-folio .doc-meta {
    margin: 0;
    max-width: 460px;
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: clamp(20px, 3vw, 32px);
    row-gap: 10px;
  }
  .doc-folio .doc-meta .meta-row {
    display: contents;
  }
  .doc-folio .doc-meta .meta-row dt {
    margin: 0;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
    align-self: baseline;
    padding-top: 3px;
  }
  .doc-folio .doc-meta .meta-row dd {
    margin: 0;
    font-family: var(--fd);
    font-size: clamp(15px, 1.3vw, 17px);
    color: var(--cream);
    text-align: left;
    line-height: 1.35;
    font-feature-settings: "tnum";
  }

  /* Citation — editorial `<details>` с ГОСТ-цитатой */
  .doc-folio .doc-citation {
    margin: 0;
  }
  .doc-folio .doc-citation > summary {
    list-style: none;
    display: inline-flex;
    align-items: baseline;
    gap: 12px;
    cursor: pointer;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
    padding: 6px 0;
