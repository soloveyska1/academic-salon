---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const totalDocs = D.length;

const categoryAlias: Record<string, string> = {
  'ВКР и дипломы': 'ВКР',
  'Курсовые работы': 'Курсовые',
  'Курсовые': 'Курсовые',
  'Рефераты': 'Рефераты',
  'Отчёты по практике': 'Практика',
  'Самостоятельные работы': 'Самостоятельные',
  'Методические материалы': 'Методички',
};

const preferredCategories = [
  'ВКР и дипломы',
  'Курсовые работы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
  'Методические материалы',
];

const categoryCount = new Map<string, number>();
for (const doc of D) {
  const key = (doc as any).category || 'Разное';
  categoryCount.set(key, (categoryCount.get(key) || 0) + 1);
}

const uniqueCategories = categoryCount.size;

const currentYear = String(new Date().getFullYear());

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const match = blob.match(/(?:19|20)\d{2}/);
  return match ? match[0] : currentYear;
}

function normalizeDoc(doc: any, index: number) {
  return {
    id: `${doc.file}-${index}`,
    slug: doc.file,
    title: doc.catalogTitle || doc.title || doc.filename || 'Студенческая работа',
    type: doc.docType || doc.category || 'Работа',
    subject: doc.subject || 'Психология',
    year: extractYear(doc),
    group: doc.category || 'Разное',
  };
}

const pickedDocs: any[] = [];
for (const category of preferredCategories) {
  const nextDocs = D.filter((doc: any) => doc.category === category).slice(0, 2);
  pickedDocs.push(...nextDocs);
}
if (pickedDocs.length < 9) {
  for (const doc of D) {
    if (pickedDocs.includes(doc)) continue;
    pickedDocs.push(doc);
    if (pickedDocs.length >= 9) break;
  }
}

const cards = pickedDocs.slice(0, 9).map(normalizeDoc);
const filters = ['Все', ...Array.from(new Set(cards.map((c) => c.group))).slice(0, 5)].map((name) => ({
  key: name,
  label: name === 'Все' ? 'Все' : (categoryAlias[name] || name),
}));

const steps = [
  { num: '01', title: 'Тема', note: 'Фиксируем задачу и срок.' },
  { num: '02', title: 'Черновик', note: 'Сверяем логику и формат.' },
  { num: '03', title: 'Сдача', note: 'Отдаём финальную версию.' },
];

const subjectCount = new Map<string, number>();
for (const doc of D) {
  const s = (doc as any).subject;
  if (s) subjectCount.set(s, (subjectCount.get(s) || 0) + 1);
}

const metrics = [
  { value: totalDocs, suffix: '+', label: 'готовых работ' },
  { value: uniqueCategories, suffix: '', label: 'категорий' },
  { value: subjectCount.size, suffix: '+', label: 'предметов' },
];
---

<Base
  title="Библиотека академического салона — студенческие работы без паники"
  description="Библиотека готовых студенческих работ: психология, социальная работа, конфликтология и другие гуманитарные дисциплины. Или закажите индивидуальную подготовку."
  currentPath="/"
>

  <!-- ═══════ 1. HERO ═══════ -->
  <section class="hero" id="hero">
    <canvas class="hero-canvas" id="heroCanvas" aria-hidden="true"></canvas>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <p class="hero-eyebrow" id="heroEyebrow">Библиотека академического салона</p>
      <h1 class="hero-title" id="heroTitle" aria-label="Без паники перед дедлайном.">
        <span class="word" style="--i:0">Без</span>
        <span class="word" style="--i:1">паники</span>
        <br aria-hidden="true" />
        <span class="word" style="--i:2">перед</span>
        <span class="word" style="--i:3">дедлайном.</span>
      </h1>
      <div class="hero-rule" aria-hidden="true"></div>
      <p class="hero-sub" id="heroSub">{totalDocs}+ готовых работ бесплатно&ensp;·&ensp;или закажем под ваши требования</p>
      <div class="hero-actions" id="heroActions">
        <a href="/catalog" class="btn btn--primary">Смотреть каталог</a>
        <a href="/order" class="btn btn--ghost">Заказать работу</a>
      </div>
      <div class="hero-unfold" aria-hidden="true"></div>
    </div>

    <div class="hero-metrics" id="proof">
      {metrics.map((m, i) => (
        <div class="metric" style={`--i:${i}`}>
          <span class="metric-value" data-target={m.value} data-suffix={m.suffix}>0{m.suffix}</span>
          <span class="metric-label">{m.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════ 3. КАТАЛОГ ═══════ -->
  <section class="gallery" id="gallery">
    <div class="gallery-inner">
      <header class="gallery-head">
        <h2 class="section-title">Каталог</h2>
        <nav class="gallery-filters" role="tablist" aria-label="Фильтр работ">
          {filters.map((f, idx) => (
            <button
              class:list={['chip', { 'chip--active': idx === 0 }]}
              type="button"
              role="tab"
              aria-selected={idx === 0 ? 'true' : 'false'}
              data-filter={f.key}
            >
              {f.label}
            </button>
          ))}
        </nav>
      </header>

      <div class="grid" id="bento">
        {cards.map((card, idx) => (
          <article
            class="card"
            data-group={card.group}
            style={`--i:${idx}`}
          >
            <a href={`/doc/${card.slug}`} class="card-link">
              <span class="card-type">{card.type}</span>
              <h3 class="card-title">{card.title}</h3>
              <span class="card-subject">{card.subject} · {card.year}</span>
            </a>
          </article>
        ))}
      </div>

      <a href="/catalog" class="gallery-more reveal">Полный каталог →</a>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"><span></span><span class="diamond">&#9670;</span><span></span></div>

  <!-- ═══════ 4. ОТЗЫВЫ ═══════ -->
  <section class="reviews" id="reviews">
    <div class="reviews-inner">
      <h2 class="section-title reveal">Что говорят студенты</h2>
      <p class="reviews-lead reveal">Реальные переписки, не выдуманные цитаты</p>
    </div>
    <div class="carousel-wrap">
      <div class="carousel" id="carousel">
        <div class="carousel-track" id="carouselTrack">
          <img src="/reviews/1.webp" alt="Отзыв: Спасибо за работу — Я довольна" class="review-img" loading="lazy" />
          <img src="/reviews/2.webp" alt="Отзыв: У меня 5, работа очень хорошая" class="review-img" loading="lazy" />
          <img src="/reviews/3.webp" alt="Отзыв: Четвёрка твёрдая, отлично всё, шикарно" class="review-img" loading="lazy" />
          <img src="/reviews/4.webp" alt="Отзыв: Автомат, 5 — спасибо огромное за работу" class="review-img" loading="lazy" />
          <img src="/reviews/5.webp" alt="Отзыв: Сдали с первого раза, даже правок нет" class="review-img" loading="lazy" />
          <img src="/reviews/6.webp" alt="Отзыв: Сдала на 4, сказали очень хорошая работа" class="review-img" loading="lazy" />
          <img src="/reviews/7.webp" alt="Отзыв: Кайф, благодарю за быструю работу" class="review-img" loading="lazy" />
          <img src="/reviews/8.webp" alt="Отзыв: Вы мой кумир, как вы это делаете" class="review-img" loading="lazy" />
          <img src="/reviews/9.webp" alt="Отзыв: В шоке, не думала что на след день отправишь" class="review-img" loading="lazy" />
          <img src="/reviews/10.webp" alt="Отзыв: Оценена на 30 баллов — от души" class="review-img" loading="lazy" />
          <!-- Clones for infinite loop -->
          <img src="/reviews/1.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/2.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/3.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/4.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/5.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/6.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/7.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/8.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/9.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/10.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
        </div>
      </div>
      <p class="carousel-hint">Нажмите на скриншот, чтобы увеличить</p>
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox-close" id="lightboxClose" aria-label="Закрыть">&times;</button>
    <img class="lightbox-img" id="lightboxImg" alt="" />
  </div>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"><span></span><span class="diamond">&#9670;</span><span></span></div>

  <!-- ═══════ 5. ГАРАНТИИ ═══════ -->
  <section class="guarantees reveal" id="guarantees">
    <div class="guarantees-inner">
      <h2 class="section-title">Почему мы</h2>
      <div class="guarantees-grid">
        <div class="guarantee">
          <span class="guarantee-icon" aria-hidden="true">&#8734;</span>
          <b class="guarantee-title">Работаем до результата</b>
          <p class="guarantee-note">Бесплатные правки, пока преподаватель не примет работу. Не бросаем на полпути.</p>
        </div>
        <div class="guarantee">
          <span class="guarantee-icon" aria-hidden="true">&#9670;</span>
          <b class="guarantee-title">Антиплагиат</b>
          <p class="guarantee-note">Гарантируем заявленный процент уникальности. Проверка в системе Антиплагиат.</p>
        </div>
        <div class="guarantee">
          <span class="guarantee-icon" aria-hidden="true">&#9201;</span>
          <b class="guarantee-title">Сроки от 1 дня</b>
          <p class="guarantee-note">Стандарт — 2 недели. Срочно — от 1 дня. Дедлайн фиксируем заранее.</p>
        </div>
        <div class="guarantee">
          <span class="guarantee-icon" aria-hidden="true">0&#8381;</span>
          <b class="guarantee-title">{totalDocs}+ работ бесплатно</b>
          <p class="guarantee-note">Каталог готовых работ — без регистрации, без ограничений, без подвоха.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"><span></span><span class="diamond">&#9670;</span><span></span></div>

  <!-- ═══════ 6. ПРОЦЕСС ═══════ -->
  <section class="process reveal" id="process">
    <div class="process-inner">
      <h2 class="section-title">От темы до защиты — за 3 шага</h2>

      <div class="steps">
        <div class="steps-line" id="stepsLine" aria-hidden="true"></div>
        {steps.map((s) => (
          <div class="step">
            <span class="step-num" aria-hidden="true">{s.num}</span>
            <b class="step-title">{s.title}</b>
            <p class="step-note">{s.note}</p>
          </div>
        ))}
      </div>

      <div class="process-actions">
        <a href="/order" class="btn btn--ghost">Отправить тему</a>
        <span class="process-channels">
          <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="link-text">Telegram</a>
          <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener" class="link-text">VK</a>
        </span>
      </div>
    </div>
  </section>

  <!-- ═══════ 7. FAQ-ПРЕВЬЮ ═══════ -->
  <section class="faq-preview reveal" id="faqPreview">
    <div class="faq-preview-inner">
      <h2 class="section-title">Частые вопросы</h2>
      <div class="faq-preview-list">
        <details class="faq-item">
          <summary class="faq-q">
            <span>Это бесплатно? В чём подвох?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <p class="faq-a">Каталог полностью бесплатный — скачивайте без регистрации. Заказ индивидуальных работ — платная услуга, она поддерживает проект.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">
            <span>Какие гарантии вы даёте?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <p class="faq-a">Уникальность по Антиплагиату, выполнение в срок, соответствие методичке и бесплатные правки до тех пор, пока преподаватель не примет работу.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">
            <span>Сколько стоит заказать работу?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <p class="faq-a">Реферат — от 3 000 &#8381;, курсовая — от 5 000 &#8381;, ВКР — от 35 000 &#8381;. Точная цена зависит от сроков и требуемой уникальности.</p>
        </details>
      </div>
      <a href="/faq" class="gallery-more">Все вопросы →</a>
    </div>
  </section>

  <!-- Floating CTA -->
  <a href="/order" class="float-cta" id="floatCta" aria-label="Заказать работу">
    Заказать работу
  </a>

  <!-- ═══════ 8. ЗАКРЫТИЕ = FOOTER ═══════ -->
  <section class="closing" id="closing">
    <div class="closing-inner">
      <h2 class="closing-title">Откройте каталог<br/>или напишите нам.</h2>
      <div class="closing-actions">
        <a href="/catalog" class="btn btn--primary">Каталог</a>
        <a href="/order" class="btn btn--ghost">Заказать работу</a>
      </div>

      <nav class="closing-links">
        <a href="/catalog">Каталог</a>
        <a href="/order">Заказать</a>
        <a href="/faq">FAQ</a>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
        <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
      </nav>

      <p class="colophon">© 2022–2026 Библиотека академического салона</p>
    </div>
  </section>

</Base>

<style>
  /* Scrollbar & selection are in design-tokens.css */

  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* CSS fallback glow — warm candle behind text */
  .hero-glow {
    position: absolute;
    width: min(1200px, 100vw);
    height: min(1000px, 85vw);
    top: 42%;
    left: 50%;
    transform: translate(-50%, -50%) scale(1);
    background:
      radial-gradient(ellipse 60% 50% at 50% 50%, rgba(200,165,40,.18) 0%, transparent 70%),
      radial-gradient(ellipse 40% 35% at 50% 45%, rgba(212,175,55,.1) 0%, transparent 55%);
    animation: glow-breathe 10s ease-in-out infinite;
    pointer-events: none;
    z-index: 0;
  }

  .hero-canvas.is-active ~ .hero-glow {
    opacity: .35;
  }

  @keyframes glow-breathe {
    0%, 100% { opacity: .7; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.12); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 960px;
    text-align: center;
    padding: 0 8px;
  }

  .hero-eyebrow {
    font: 500 clamp(10px, 1.2vw, 12px)/1 var(--fi);
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ac);
    margin-bottom: 28px;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .6s cubic-bezier(.25,0,0,1) .1s forwards;
  }

  .hero-title {
    font: 300 clamp(48px, 10vw, 100px)/.92 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    text-wrap: balance;
  }

  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(28px);
    animation: word-in .7s cubic-bezier(.25,0,0,1) forwards;
    animation-delay: calc(var(--i) * 120ms + 300ms);
  }

  @keyframes word-in {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-rule {
    width: 88px;
    height: 1px;
    margin: 36px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
    animation: rule-in .7s cubic-bezier(.25,0,0,1) .9s forwards;
  }

  @keyframes rule-in {
    to { opacity: .3; transform: scaleX(1); }
  }

  .hero-sub {
    margin-top: 28px;
    font: 400 clamp(14px, 1.8vw, 17px)/1.7 var(--fi);
    color: var(--t3);
    letter-spacing: .04em;
    max-width: 48ch;
    margin-inline: auto;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .6s cubic-bezier(.25,0,0,1) 1.1s forwards;
  }

  .hero-actions {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(16px);
    animation: fade-up .6s cubic-bezier(.25,0,0,1) 1.3s forwards;
  }

  .hero-unfold {
    width: 200px;
    height: 1px;
    margin: 0 auto;
    margin-top: 56px;
    background: linear-gradient(90deg, transparent, rgba(212,175,55,.25), transparent);
    opacity: 0;
    transform: scaleX(0);
    animation: unfold 2s cubic-bezier(.25,0,0,1) 1.5s forwards;
  }

  @keyframes unfold {
    to { opacity: 1; transform: scaleX(1); }
  }

  .hero-metrics {
    position: absolute;
    bottom: 80px;
    left: 24px;
    right: 24px;
    display: flex;
    justify-content: center;
    gap: 80px;
    flex-wrap: wrap;
    z-index: 1;
  }

  @keyframes fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══════ BUTTONS ═══════ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 18px 48px;
    border-radius: 0;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    text-decoration: none;
    color: var(--t1);
    border: .5px solid rgba(212,175,55,.2);
    cursor: pointer;
    transition:
      transform .5s cubic-bezier(.25,0,0,1),
      border-color .5s cubic-bezier(.25,0,0,1),
      box-shadow .6s cubic-bezier(.25,0,0,1);
  }

  .btn--primary {
    background: rgba(255,255,255,.03);
    border-color: rgba(212,175,55,.25);
  }

  .btn--ghost {
    background: transparent;
  }

  .btn:hover {
    transform: translateY(-2px);
    border-color: rgba(212,175,55,.4);
    box-shadow: 0 12px 40px rgba(212,175,55,.06);
  }

  .btn--primary:hover {
    box-shadow: 0 12px 40px rgba(212,175,55,.1);
  }

  /* ═══════ METRICS (inside hero) ═══════ */
  .metric {
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
  }

  .metric.is-visible {
    animation: fade-up .5s var(--ease-spring) calc(var(--i) * 120ms) forwards;
  }

  .metric-value {
    display: block;
    font: 300 clamp(42px, 8vw, 68px)/1 var(--fm);
    color: var(--ac);
    letter-spacing: -.02em;
    font-variant-numeric: tabular-nums;
  }

  .metric-label {
    display: block;
    margin-top: 12px;
    font: 400 11px/1.3 var(--fi);
    color: var(--t3);
    text-transform: uppercase;
    letter-spacing: .12em;
  }

  /* ═══════ GALLERY ═══════ */
  .gallery {
    padding: 140px 24px 128px;
    background: var(--bg);
  }

  .gallery-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .gallery-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px 40px;
    margin-bottom: 56px;
  }

  .section-title {
    font: 300 clamp(36px, 6vw, 56px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
  }

  .gallery-filters {
