  }
  .stat-val .stat-suffix {
    font-size: .55em;
    color: var(--t3);
    margin-left: 2px;
    letter-spacing: .04em;
  }
  .stat-val .stat-sep {
    color: var(--ac);
    font-style: italic;
    margin-right: 4px;
  }
  .stat-note {
    font: 400 13px/1.4 var(--fi);
    color: var(--t3);
    max-width: 22ch;
  }

  /* Risk #2 fix: explicit handling of 640–900px gap (was missing) */
  @media (max-width: 900px) {
    .stats-strip-inner {
      grid-template-columns: 1fr 1fr;
      gap: 28px 32px;
    }
    .stat-col:last-child {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--brd);
    }
    .stat-col:last-child .stat-note { max-width: none; text-align: right; }
  }
  @media (max-width: 560px) {
    .stats-strip { padding-top: 48px; padding-left: 20px; padding-right: 20px; }
    .stats-strip-inner {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .stat-col {
      padding: 18px 0;
      border-bottom: 1px solid var(--brd);
    }
    .stat-col:last-child {
      flex-direction: column;
      align-items: flex-start;
      border-bottom: none;
      border-top: none;
      padding-top: 18px;
    }
    .stat-col:last-child .stat-note { text-align: left; }
  }

  /* ----------------------------------------------------------------
     LIGHT THEME OVERRIDES
     ---------------------------------------------------------------- */
  :global([data-theme="light"]) .hero-glow {
    background:
      radial-gradient(ellipse 55% 45% at 50% 48%, rgba(180,145,30,.12) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 48% 44%, rgba(180,145,30,.08) 0%, transparent 50%),
      radial-gradient(ellipse 75% 55% at 42% 52%, rgba(160,120,15,.05) 0%, transparent 75%);
  }

  :global([data-theme="light"]) .hero-search-input {
    background: rgba(0,0,0,.03);
    border-color: rgba(0,0,0,.1);
  }

  :global([data-theme="light"]) .hero-search-input:focus {
    border-color: var(--ac-b);
    background: rgba(0,0,0,.04);
  }

  :global([data-theme="light"]) .card {
    background: #fff;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-color: var(--brd);
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }

  :global([data-theme="light"]) .card:hover {
    box-shadow: 0 12px 40px rgba(0,0,0,.1), 0 0 0 1px rgba(212,175,55,.12);
  }

  :global([data-theme="light"]) .rw-img {
    border-color: rgba(0,0,0,.08);
  }

  :global([data-theme="light"]) .rw-img:hover {
    border-color: rgba(122,95,18,.2);
  }

  /* ----------------------------------------------------------------
     REDUCED MOTION
     ---------------------------------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    .word,
    .hero-sub,
    .hero-search,
    .hero-actions {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .hero-glow {
      animation: none;
      opacity: .8;
      transform: translate(-50%, -50%);
    }

    .rw-track {
      animation: none !important;
    }

    .rv {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ----------------------------------------------------------------
     TABLET (max 900px)
     ---------------------------------------------------------------- */
  @media (max-width: 900px) {
    .catalog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ----------------------------------------------------------------
     MOBILE (max 639px)
     ---------------------------------------------------------------- */
  @media (max-width: 639px) {
    .reviews,
    .catalog {
      padding: 64px 20px;
    }

    .catalog-grid {
      grid-template-columns: 1fr;
    }

    /* Smaller review images on mobile */
    .rw-img {
      height: 160px;
    }

    .reviews-wall {
      gap: 8px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .hero-actions .btn {
      width: 100%;
      max-width: 320px;
    }

    .foot {
      padding: 48px 20px;
    }

    .reviews-head {
      margin-bottom: 32px;
    }
  }

  /* ================================================================
     PRELUDE — Dark Couture hero (step 2.1)
     New class namespace (*-2 / prelude-h / prelude-scroll-cue) to
     avoid conflicts with legacy .prelude-* rules still used by the
     Epilogue block higher in this file.
     ================================================================ */
  .prelude {
    position: relative;
    min-height: 100svh;
    padding: calc(var(--nav-h) + 48px) 0 120px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    background: var(--ink);
    color: var(--cream);
  }
  .prelude-wrap {
    max-width: var(--wrap-wide);
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
    position: relative;
    z-index: 1;
    width: 100%;
  }

  /* ── 3-column head ── */
  .prelude-head {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 4vw, 48px);
    padding: 12px 0 32px;
    border-bottom: 1px solid var(--line);
    margin-bottom: clamp(48px, 8vw, 96px);
  }
  .prelude-head .col {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .prelude-head .lbl {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .prelude-head .val {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--cream);
  }
  .prelude-head .val .it {
    font-style: italic;
    color: var(--gold);
  }
  @media (max-width: 720px) {
    .prelude-head {
      grid-template-columns: 1fr;
      gap: 20px;
      padding-bottom: 20px;
      margin-bottom: 48px;
    }
  }

  /* ── Eyebrow: decorative "Prelude" ── */
  .prelude-eyebrow-2 {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 24px;
  }
  .prelude-eyebrow-2 .rule {
    width: 28px;
    height: 1px;
    background: var(--gold);
  }
  .prelude-eyebrow-2 .word {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
  }

  /* ── Title: clamp lower bound so long words don't overflow 375px, upper bound caps 4K ── */
  .prelude-h {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(40px, 9vw, 140px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--cream);
    margin: 0 0 clamp(40px, 6vw, 72px);
    max-width: 18ch;
    text-wrap: balance;
    overflow-wrap: break-word;
    word-break: normal;
    hyphens: auto;
  }
  .prelude-h .ln {
    display: block;
  }
  .prelude-h .it {
    font-style: italic;
    color: var(--gold);
    font-feature-settings: "swsh";
    font-weight: 400;
  }

  /* ── Foot: lede + actions (two columns on desktop, stacked on mobile) ── */
  .prelude-foot {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(32px, 4vw, 56px);
    align-items: end;
    padding-top: 32px;
    border-top: 1px solid var(--line);
  }
  .prelude-lede-2 {
    max-width: 52ch;
    font-family: var(--serif);
    font-size: clamp(17px, 1.5vw, 21px);
    font-weight: 400;
    line-height: 1.5;
    color: var(--cream-2);
    margin: 0;
  }
  .prelude-lede-2 em {
    font-style: italic;
    color: var(--gold);
    font-feature-settings: "swsh";
  }
  .prelude-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .prelude-actions .btn {
    text-align: center;
  }
  @media (max-width: 900px) {
    .prelude-foot {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .prelude-actions .btn {
      flex: 1 1 auto;
    }
  }

  /* ── Scroll cue ── */
  .prelude-scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 28px;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: var(--mute);
    text-decoration: none;
    transition: color .4s var(--ease-silk);
  }
  .prelude-scroll-cue:hover { color: var(--gold); }
  .prelude-scroll-cue .lbl {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }
  .prelude-scroll-cue .line {
    width: 1px;
    height: 54px;
    background: linear-gradient(180deg, transparent, var(--gold));
  }
  @media (max-width: 720px) {
    .prelude-scroll-cue { display: none; }
  }

  /* ================================================================
     CALENDAR — decorative 12-month load timeline (step 2.3)
     No legacy .calendar-* collisions, classes ported 1-to-1 from
     bundle. Cells are inert (role=listitem, no cursor/click).
     ================================================================ */
  .calendar {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px);
    background: var(--ink);
    position: relative;
  }
  .calendar-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
  }

  .calendar-intro {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: clamp(32px, 5vw, 60px);
    align-items: end;
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--line);
  }
  .calendar-legend {
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .calendar-legend .row {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .calendar-legend .dot {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
    border-radius: 50%;
  }
  .calendar-legend .dot.free {
    background: var(--gold);
    box-shadow: 0 0 8px var(--gold-glow);
  }
  .calendar-legend .dot.tight { background: var(--cream-3); }
  .calendar-legend .dot.closed {
    background: var(--mute-2);
    border: 1px solid var(--mute);
    box-sizing: border-box;
  }

  .calendar-track {
    position: relative;
    padding: 60px 0;
  }
  .calendar-track::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-line) 8%, var(--gold-line) 92%, transparent);
  }

  .calendar-months {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 0;
    position: relative;
  }
  .month {
    position: relative;
    padding: 10px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform .6s var(--ease-silk);
    min-width: 0;
  }
  .month:hover { transform: translateY(-2px); }

  .month-name {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(14px, 1.2vw, 17px);
    color: var(--cream);
    margin-bottom: 36px;
    line-height: 1;
    transition: color .4s;
  }
  .month.closed .month-name { color: var(--mute); }
  .month:hover .month-name { color: var(--gold); }

  .month-node {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 14px;
    height: 14px;
    background: var(--ink);
    border: 1px solid var(--gold-line);
    border-radius: 50%;
    transition: transform .4s var(--ease-silk), box-shadow .4s;
    z-index: 2;
  }
  .month.free .month-node {
    background: var(--gold);
    border-color: var(--gold);
    box-shadow: 0 0 0 4px rgba(201, 162, 76, 0.15), 0 0 20px var(--gold-glow);
  }
  .month.tight .month-node {
    background: var(--cream-3);
    border-color: var(--cream-3);
    box-shadow: 0 0 0 3px rgba(200, 188, 160, 0.12);
  }
  .month.closed .month-node {
    background: var(--mute-2);
    border-color: var(--mute);
  }
  .month:hover .month-node { transform: translate(-50%, -50%) scale(1.4); }

  .month-stat {
    margin-top: 36px;
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mute);
    line-height: 1.3;
    padding: 0 4px;
  }
  .month-stat b {
    font-family: var(--fd);
    font-style: italic;
    font-size: 14px;
    color: var(--gold);
    font-weight: 400;
    display: block;
    letter-spacing: 0;
    margin-bottom: 4px;
    text-transform: none;
  }
  .month.closed .month-stat b { color: var(--mute); }

  .month-bar {
    margin-top: 8px;
    width: 70%;
    height: 2px;
    background: var(--line-2);
    position: relative;
    overflow: hidden;
  }
  .month-bar::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: var(--booked, 40%);
    background: var(--gold);
  }
  .month.closed .month-bar::before { background: var(--mute); }
  .month.tight .month-bar::before { background: var(--cream-3); }

  @media (max-width: 1000px) {
    .calendar-months { grid-template-columns: repeat(6, 1fr); gap: 40px 0; }
    .calendar-track::before { display: none; }
  }
  @media (max-width: 600px) {
    .calendar-months { grid-template-columns: repeat(3, 1fr); gap: 32px 0; }
    .month-name { margin-bottom: 28px; }
    .month-stat { margin-top: 28px; font-size: 8px; }
  }
  @media (max-width: 900px) {
    .calendar-intro { grid-template-columns: 1fr; gap: 24px; }
  }

  /* Bottom hint card */
  .calendar-hint {
    margin-top: clamp(48px, 6vw, 72px);
    padding: clamp(28px, 4vw, 40px);
    border: 1px solid var(--gold-line);
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 32px;
    align-items: center;
    background: linear-gradient(180deg, var(--gold-soft), transparent);
    position: relative;
  }
  .calendar-hint::before {
    content: "";
    position: absolute;
    top: 0;
    left: 20px;
    width: 32px;
    height: 1px;
    background: var(--gold);
  }
  .calendar-hint .roman {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(48px, 6vw, 60px);
    line-height: 0.9;
    color: var(--gold);
  }
  .calendar-hint .body h3 {
    font-family: var(--fd);
    font-weight: 500;
    font-size: clamp(20px, 2vw, 26px);
    margin-bottom: 8px;
    color: var(--cream);
    letter-spacing: -0.01em;
  }
  .calendar-hint .body p {
    font-family: var(--fd);
    font-size: 15px;
    font-style: italic;
    color: var(--cream-2);
    margin: 0;
  }
  @media (max-width: 720px) {
    .calendar-hint {
      grid-template-columns: 1fr;
      text-align: left;
      padding: 24px;
      gap: 18px;
    }
    .calendar-hint .btn { justify-self: start; }
  }

  /* ================================================================
     FORMULA — calculator scaffold (step 2.5, ported 1-to-1 from
     bundle css/05-genres-formula-archive.css). No JS wiring yet.
     ================================================================ */
  .formula {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px);
    background: var(--ink);
    position: relative;
  }
  .formula-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
  }

  .formula-stage {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 1px;
    background: var(--line-2);
    border: 1px solid var(--line-2);
    position: relative;
  }
  @media (max-width: 1100px) {
    .formula-stage { grid-template-columns: 1fr; }
  }

  .formula-left {
    background: var(--ink);
    padding: clamp(32px, 5vw, 64px);
    display: flex;
    flex-direction: column;
    gap: 44px;
  }

  .formula-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 28px;
    align-items: start;
    padding-bottom: 36px;
    border-bottom: 1px solid var(--line);
  }
  .formula-row:last-child { border-bottom: 0; padding-bottom: 0; }

  .formula-row-label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 4px;
  }
  .formula-row-label .n {
    font-family: var(--fd);
    font-style: italic;
    font-size: 32px;
    color: var(--gold);
    line-height: 1;
    font-feature-settings: "swsh";
  }
  .formula-row-label .t {
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  @media (max-width: 640px) {
    .formula-row { grid-template-columns: 1fr; gap: 14px; }
  }

  .formula-options {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .formula-opt {
    padding: 12px 18px;
    background: transparent;
    border: 1px solid var(--line-2);
    color: var(--cream-2);
    font-family: var(--fi);
    font-size: 13px;
    font-weight: 400;
    cursor: pointer;
    position: relative;
    transition: color .45s var(--ease-silk), border-color .45s;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    line-height: 1;
    overflow: hidden;
    isolation: isolate;
  }
  .formula-opt::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--gold-soft);
    transform: translateY(101%);
    transition: transform .5s var(--ease-kine);
    z-index: -1;
  }
  .formula-opt:hover { border-color: var(--gold-line); color: var(--cream); }
  .formula-opt:hover::before { transform: translateY(0); }
  .formula-opt .p {
    font-family: var(--fm);
    font-size: 10px;
    color: var(--mute);
    letter-spacing: 0.08em;
  }
  .formula-opt.is-active {
    background: var(--cream);
    border-color: var(--cream);
    color: var(--ink);
  }
  .formula-opt.is-active .p { color: var(--gold-deep); }
  .formula-opt.is-active::before { display: none; }

  /* Slider */
  .formula-slider {
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
  }
  .formula-slider .readout {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 20px;
  }
  .formula-slider .pages {
    font-family: var(--fd);
    font-size: clamp(32px, 3.5vw, 44px);
    line-height: 1;
    color: var(--cream);
    letter-spacing: -0.02em;
    font-feature-settings: "tnum";
  }
  .formula-slider .pages small {
    font-family: var(--fd);
    font-style: italic;
    color: var(--gold);
    font-size: 18px;
    margin-left: 8px;
    letter-spacing: 0;
  }
  .formula-slider .bounds {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .formula-slider input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 2px;
    background: linear-gradient(
      90deg,
      var(--gold) 0%,
      var(--gold) var(--fill, 30%),
      var(--line-2) var(--fill, 30%),
      var(--line-2) 100%
    );
    outline: none;
    cursor: pointer;
  }
  .formula-slider input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 14px;
    height: 14px;
    background: var(--gold);
    border: 3px solid var(--ink);
    box-shadow: 0 0 0 1px var(--gold), 0 0 16px var(--gold-glow);
    cursor: pointer;
    border-radius: 50%;
    transition: transform .3s;
  }
  .formula-slider input[type="range"]::-webkit-slider-thumb:hover { transform: scale(1.2); }
  .formula-slider input[type="range"]::-moz-range-thumb {
    width: 14px;
    height: 14px;
    background: var(--gold);
    border: 3px solid var(--ink);
    box-shadow: 0 0 0 1px var(--gold);
    cursor: pointer;
    border-radius: 50%;
  }

  /* Right — receipt */
  .formula-right {
    background: var(--ink-2);
    padding: clamp(32px, 5vw, 64px);
    display: flex;
    flex-direction: column;
    gap: 28px;
    position: relative;
    overflow: hidden;
  }
  .formula-right::before {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, transparent, var(--gold-line), transparent);
  }

  .formula-receipt-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 18px;
    border-bottom: 1px dashed var(--line-2);
  }
  .formula-receipt-head .t {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .formula-receipt-head .d {
    font-family: var(--fd);
    font-size: 14px;
    color: var(--cream-2);
  }
  .formula-receipt-head .it {
    font-style: italic;
    color: var(--gold);
  }

  .formula-receipt-rows {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex-grow: 1;
    font-family: var(--fd);
    min-height: 120px;
  }
  .receipt-row {
    display: grid;
