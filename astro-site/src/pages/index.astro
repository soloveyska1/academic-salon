---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';
import { qaItems } from '../data/faq';
import { genres } from '../data/genres';
import { fmtRub } from '../lib/utils';
import FAQ from '../components/home/FAQ.astro';
import Manifesto from '../components/home/Manifesto.astro';
import Genres from '../components/home/Genres.astro';
import Method from '../components/home/Method.astro';
import Epilogue from '../components/home/Epilogue.astro';
import Archive from '../components/home/Archive.astro';

const totalDocs = D.length;
const currentYear = String(new Date().getFullYear());

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const match = blob.match(/(?:19|20)\d{2}/);
  return match ? match[0] : currentYear;
}

function normalizeDoc(doc: any, index: number) {
  return {
    id: `${doc.file}-${index}`,
    slug: doc.file,
    title: doc.catalogTitle || doc.title || doc.filename || 'Студенческая работа',
    type: doc.docType || doc.category || 'Работа',
    subject: doc.subject || 'Психология',
    year: extractYear(doc),
  };
}

const preferredCategories = [
  'ВКР и дипломы',
  'Курсовые работы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
  'Методические материалы',
];

const pickedDocs: any[] = [];
for (const category of preferredCategories) {
  const nextDocs = D.filter((doc: any) => doc.category === category).slice(0, 1);
  pickedDocs.push(...nextDocs);
}
if (pickedDocs.length < 6) {
  for (const doc of D) {
    if (pickedDocs.includes(doc)) continue;
    pickedDocs.push(doc);
    if (pickedDocs.length >= 6) break;
  }
}

const cards = pickedDocs.slice(0, 6).map(normalizeDoc);

// ── Calendar of the workshop (decorative load map — step 2.3) ──
// Computed at build time from new Date(). Not a real booking system.
const monthNames = ['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];
const calendarNow = new Date();
const calendarCurMonth = calendarNow.getMonth(); // 0..11

type CalendarState = 'closed' | 'tight' | 'free';
interface CalendarCell {
  name: string;
  state: CalendarState;
  booked: number;
  title: string;
  sub: string;
}
const calendarCells: CalendarCell[] = monthNames.map((name, i): CalendarCell => {
  if (i < calendarCurMonth) {
    return { name, state: 'closed', booked: 0, title: '—', sub: 'прошёл' };
  }
  if (i === calendarCurMonth) {
    return { name, state: 'tight', booked: 90, title: '90%', sub: 'мало окон' };
  }
  if (i === calendarCurMonth + 1) {
    return { name, state: 'tight', booked: 80, title: '80%', sub: 'мало окон' };
  }
  if (i === calendarCurMonth + 2) {
    return { name, state: 'free', booked: 50, title: '50%', sub: 'открыто' };
  }
  if (i === calendarCurMonth + 3) {
    return { name, state: 'free', booked: 40, title: '40%', sub: 'открыто' };
  }
  const booked = 25 + ((i * 3) % 10); // 25..34, deterministic but varied
  return { name, state: 'free', booked, title: `${booked}%`, sub: 'лучшее время' };
});


const reviewAlts = [
  'Отзыв: Спасибо за работу',
  'Отзыв: У меня 5, работа очень хорошая',
  'Отзыв: Четвёрка твёрдая, отлично всё',
  'Отзыв: Автомат, 5 -- спасибо огромное',
  'Отзыв: Сдали с первого раза',
  'Отзыв: Сдала на 4, сказали хорошая работа',
  'Отзыв: Кайф, благодарю за быструю работу',
  'Отзыв: Всё отлично, спасибо',
  'Отзыв: Преподаватель поставил отлично',
  'Отзыв: Работа принята без замечаний',
];
---

<Base
  title="Библиотека академического салона -- студенческие работы без паники"
  description="Библиотека готовых студенческих работ: психология, социальная работа, конфликтология и другие гуманитарные дисциплины. Или закажите индивидуальную подготовку."
  currentPath="/"
  extraSchema={[
    {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Библиотека академического салона',
      alternateName: 'Академический Салон',
      url: 'https://bibliosaloon.ru/',
      inLanguage: 'ru-RU',
      description: 'Свободный архив студенческих работ и мастерская индивидуального заказа.',
    },
    {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: qaItems.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    },
  ]}
>

  <!-- Curtain intro removed — relying on natural CSS load instead of scripted overlay -->

  <!-- ============================================================
       PRELUDE — editorial hero (Dark Couture · step 2.1)
       ============================================================ -->
  <section class="prelude" id="prelude" aria-label="Вступление">
    <div class="prelude-wrap">
      <div class="prelude-head">
        <div class="col">
          <span class="lbl">Мастерская</span>
          <span class="val">с&nbsp;2020</span>
        </div>
        <div class="col">
          <span class="lbl">В&nbsp;архиве</span>
          <span class="val">{totalDocs} <i class="it">работ</i></span>
        </div>
        <div class="col">
          <span class="lbl">Сезон</span>
          <span class="val"><i class="it">MMXXVI</i></span>
        </div>
      </div>

      <div class="prelude-eyebrow-2" aria-hidden="true">
        <span class="rule"></span>
        <span class="word">Prelude</span>
      </div>

      <h1 class="prelude-h">
        <span class="ln">Написано с&nbsp;терпением,</span>
        <span class="ln">защищено с&nbsp;<em class="it">достоинством</em>.</span>
      </h1>

      <div class="prelude-foot">
        <p class="prelude-lede-2">
          Свободная библиотека из&nbsp;{totalDocs}&nbsp;студенческих работ и&nbsp;авторский заказ <em>под&nbsp;защиту</em>&nbsp;— от&nbsp;разговора до&nbsp;оценки в&nbsp;ведомости.
        </p>
        <div class="prelude-actions">
          <a href="/order" class="btn btn-gold btn-lg">Рассчитать стоимость</a>
          <a href="/catalog" class="btn btn-ghost-gold btn-lg">Открыть архив</a>
        </div>
      </div>
    </div>

    <a href="#manifesto" class="prelude-scroll-cue" aria-label="Читать дальше">
      <span class="lbl">читать дальше</span>
      <span class="line" aria-hidden="true"></span>
    </a>
  </section>

  <!-- ============================================================
       STATS — editorial column strip below the hero
       ============================================================ -->
  <section class="stats-strip rv" aria-label="О мастерской в цифрах">
    <div class="stats-strip-inner">
      <div class="stat-col">
        <span class="stat-lbl">В каталоге</span>
        <span class="stat-val">{totalDocs}<span class="stat-suffix">+</span> <i class="it">работ</i></span>
        <span class="stat-note">бесплатно, без регистрации</span>
      </div>
      <div class="stat-col">
        <span class="stat-lbl">Мастерская</span>
        <span class="stat-val"><span class="stat-sep">·</span> с 2020</span>
        <span class="stat-note">шесть лет собранной практики</span>
      </div>
      <div class="stat-col">
        <span class="stat-lbl">На связи</span>
        <span class="stat-val">15 <span class="stat-suffix">мин</span></span>
        <span class="stat-note">ответ живого человека в&nbsp;будни</span>
      </div>
    </div>
  </section>

  <Manifesto totalDocs={totalDocs} />

  <!-- ============================================================
       II · CALENDAR — decorative 12-month workshop load (step 2.3)
       ============================================================ -->
  <section
    id="calendar"
    class="calendar rv"
    aria-label="Календарь мастерской"
    data-calendar-year={calendarNow.getFullYear()}
    data-calendar-month={calendarCurMonth}
    data-calendar-today={calendarNow.getDate()}
  >
    <div class="calendar-inner">
      <header class="chapter-head" data-reveal>
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">II</span>
          <span class="chapter-label">Caput Secundum · Глава вторая</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">Календарь <em class="it">мастерской</em>.</h2>
          <p class="chapter-lede">Загрузка авторских работ по&nbsp;месяцам MMXXVI&nbsp;— чтобы вы&nbsp;видели, плотно&nbsp;ли идёт месяц, и&nbsp;могли написать заранее, если&nbsp;нужен спокойный срок.</p>
        </div>
      </header>

      <div class="calendar-intro">
        <p class="chapter-lede">
          Это не&nbsp;система бронирования, а&nbsp;честная карта загрузки. Пик приходится на&nbsp;май и&nbsp;декабрь (сессия и&nbsp;защиты); спокойнее всего&nbsp;— в&nbsp;июле, августе, феврале.
        </p>
        <div class="calendar-legend" aria-hidden="true">
          <div class="row"><span class="dot free"></span><span>окна открыты</span></div>
          <div class="row"><span class="dot tight"></span><span>плотно</span></div>
          <div class="row"><span class="dot closed"></span><span>прошёл</span></div>
        </div>
      </div>

      <div class="calendar-track">
        <div class="calendar-months" role="list" id="calendarMonths">
          {calendarCells.map((m, idx) => (
            <button
              type="button"
              class:list={['month', m.state]}
              style={`--booked: ${m.booked}%`}
              role="listitem"
              data-month-index={idx}
              data-month-name={m.name}
              data-month-state={m.state}
              aria-label={`${m.name} — ${m.sub}. Открыть дни месяца`}
            >
              <span class="month-name">{m.name}</span>
              <span class="month-node" aria-hidden="true"></span>
              <span class="month-stat">
                <b>{m.title}</b>
                {m.sub}
              </span>
              <span class="month-bar" aria-hidden="true"></span>
            </button>
          ))}
        </div>
      </div>

      <aside class="calendar-hint">
        <div class="roman" aria-hidden="true">!</div>
        <div class="body">
          <h3>Напишите заранее&nbsp;— и&nbsp;окно подберём</h3>
          <p>Чем раньше расскажете о&nbsp;задаче, тем спокойнее обоим: подберём автора под тему, а&nbsp;вы&nbsp;не&nbsp;упрётесь в&nbsp;срочность.</p>
        </div>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-gold btn-sm">Написать в&nbsp;Telegram</a>
      </aside>
    </div>

    <!-- Day grid dialog — opens when user clicks on a month -->
    <dialog class="cal-modal" id="calModal" aria-labelledby="calModalTitle">
      <div class="cal-modal-body">
        <button type="button" class="cal-close" id="calModalClose" aria-label="Закрыть">
          <svg viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.3"/></svg>
        </button>

        <header class="cal-modal-head">
          <span class="cal-modal-eyebrow" aria-hidden="true">
            <span class="rule"></span>
            <span class="word">Месяц</span>
          </span>
          <h3 class="cal-modal-title" id="calModalTitle">—</h3>
          <p class="cal-modal-sub" id="calModalSub">Декоративная карта загрузки. Точные даты&nbsp;— в&nbsp;Telegram.</p>
        </header>

        <div class="cal-modal-legend" aria-hidden="true">
          <span class="row"><span class="dot free"></span>свободно</span>
          <span class="row"><span class="dot tight"></span>плотно</span>
          <span class="row"><span class="dot busy"></span>занято</span>
          <span class="row"><span class="dot today"></span>сегодня</span>
          <span class="row"><span class="dot closed"></span>прошёл</span>
        </div>

        <div class="cal-modal-weekdays" aria-hidden="true">
          <span>пн</span><span>вт</span><span>ср</span><span>чт</span><span>пт</span><span>сб</span><span>вс</span>
        </div>
        <div class="cal-modal-grid" id="calModalGrid" role="grid" aria-label="Дни месяца"></div>

        <footer class="cal-modal-foot">
          <p class="cal-modal-note" id="calModalNote">—</p>
          <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-gold btn-sm">
            Подобрать дату в&nbsp;Telegram
          </a>
        </footer>
      </div>
    </dialog>
  </section>

  <Genres />

  <!-- ============================================================
       IV · FORMULA — calculator scaffold (step 2.5, no JS yet)
       ============================================================ -->
  <section id="formula" class="formula rv" aria-label="Формула стоимости">
    <div class="formula-inner">
      <header class="chapter-head" data-reveal>
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">IV</span>
          <span class="chapter-label">Caput Quartum · Глава четвёртая</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">Формула <em class="it">стоимости</em>.</h2>
          <p class="chapter-lede">Четыре&nbsp;шага&nbsp;— жанр, объём, темп и&nbsp;дополнения. Цифры статичные для&nbsp;ориентира; финальную сумму согласуем после разговора.</p>
        </div>
      </header>

      <div class="formula-stage">
        <!-- LEFT — selections -->
        <div class="formula-left">
          <div class="formula-row">
            <div class="formula-row-label">
              <span class="n">i</span>
              <span class="t">Жанр</span>
            </div>
            <div class="formula-options" data-group="genre">
              {genres.map((g, idx) => (
                <button
                  type="button"
                  class:list={['formula-opt', { 'is-active': idx === 0 }]}
                  data-genre={g.code}
                  aria-pressed={idx === 0 ? 'true' : 'false'}
                >
                  <span>{g.name}</span>
                  <span class="p">{fmtRub(g.priceFrom)}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="formula-row">
            <div class="formula-row-label">
              <span class="n">ii</span>
              <span class="t">Объём</span>
            </div>
            <div class="formula-slider">
              <div class="readout">
                <div class="pages"><span id="formulaPagesVal">8</span> <small>стр.</small></div>
                <div class="bounds">5 — 120 страниц</div>
              </div>
              <input
                type="range"
                min="5"
                max="120"
                value="8"
                step="1"
                id="formulaPages"
                style="--fill: 2.6%;"
                aria-label="Объём в страницах"
              />
            </div>
          </div>

          <div class="formula-row">
            <div class="formula-row-label">
              <span class="n">iii</span>
              <span class="t">Темп</span>
            </div>
            <div class="formula-options" data-group="tempo">
              <button type="button" class="formula-opt is-active" data-tempo="slow" aria-pressed="true">
                <span>Неспешно</span>
                <span class="p">× 1.0</span>
              </button>
              <button type="button" class="formula-opt" data-tempo="normal" aria-pressed="false">
                <span>Собранно</span>
                <span class="p">× 1.25</span>
              </button>
              <button type="button" class="formula-opt" data-tempo="rush" aria-pressed="false">
                <span>Срочно</span>
                <span class="p">× 1.6</span>
              </button>
            </div>
          </div>

          <div class="formula-row">
            <div class="formula-row-label">
              <span class="n">iv</span>
              <span class="t">Дополнения</span>
            </div>
            <div class="formula-options" data-group="extras">
              <button type="button" class="formula-opt" data-extra="antiplag" aria-pressed="false">
                <span>Антиплагиат ВУЗ</span>
                <span class="p">+1&nbsp;500</span>
              </button>
              <button type="button" class="formula-opt" data-extra="speech" aria-pressed="false">
                <span>Речь к&nbsp;защите</span>
                <span class="p">+2&nbsp;500</span>
              </button>
              <button type="button" class="formula-opt" data-extra="slides" aria-pressed="false">
                <span>Слайды · 15&nbsp;шт.</span>
                <span class="p">+3&nbsp;500</span>
              </button>
            </div>
          </div>
        </div>

        <!-- RIGHT — receipt -->
        <div class="formula-right">
          <div class="formula-receipt-head">
            <span class="t">Счёт · Ratio</span>
            <span class="d"><i class="it">Академический Салон</i></span>
          </div>

          <div class="formula-receipt-rows" id="formulaRows">
            <div class="receipt-row">
              <span class="k">Самостоятельная</span>
              <span class="v">2&nbsp;500&nbsp;₽</span>
            </div>
            <div class="receipt-row sub">
              <span class="k">Темп · неспешно</span>
              <span class="v">× 1.0</span>
            </div>
            <div class="receipt-row">
              <span class="k">Объём · 10&nbsp;стр.</span>
              <span class="v">—</span>
            </div>
          </div>

          <div class="formula-total">
            <span class="label">Итого</span>
            <span class="amount" id="formulaTotal">2&nbsp;500<span class="cur">&nbsp;₽</span></span>
          </div>

          <div class="formula-cta">
            <a href="/order" id="formulaCta" class="btn btn-gold btn-lg">
              Оформить заявку
              <svg viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.3"/></svg>
            </a>
            <p class="formula-whisper">Оплата по&nbsp;частям: 50% после плана, 50% после защиты</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Archive />

  <Method />

  <!-- ============================================================
       IV · TESTIMONIA — wrap existing scrolling review wall
       (Real screenshots, not fabricated copy. Runtime: see scripts/home-page-runtime.ts)
       ============================================================ -->
  <section id="testimonia" class="reviews testimonia rv" aria-label="Свидетельства">
    <header class="chapter-head testimonia-head" data-reveal>
      <div class="chapter-num">
        <span class="roman" aria-hidden="true">VII</span>
        <span class="chapter-label">Caput Septimum · Глава седьмая</span>
      </div>
      <div class="chapter-title-block">
        <h2 class="chapter-h">Свидетельства и <em class="it">гарантии</em>.</h2>
        <p class="chapter-lede">Не&nbsp;выученные «спасибо за&nbsp;работу», а&nbsp;живые скриншоты переписок. Авторы разрешили опубликовать&nbsp;— хотели поделиться. Тапните по&nbsp;любой, чтобы открыть на&nbsp;весь экран.</p>
      </div>
    </header>
    <div class="reviews-wall">
      <!-- Row 1: scrolls left -->
      <div class="rw-row rw-row--left">
        <div class="rw-track">
          <img src="/reviews/4.webp" alt={reviewAlts[3]} class="rw-img" loading="lazy" />
          <img src="/reviews/2.webp" alt={reviewAlts[1]} class="rw-img" loading="lazy" />
          <img src="/reviews/8.webp" alt={reviewAlts[7]} class="rw-img" loading="lazy" />
          <img src="/reviews/5.webp" alt={reviewAlts[4]} class="rw-img" loading="lazy" />
          <img src="/reviews/3.webp" alt={reviewAlts[2]} class="rw-img" loading="lazy" />
          <!-- Duplicate for seamless loop -->
          <img src="/reviews/4.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/2.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/8.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/5.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/3.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
        </div>
      </div>
      <!-- Row 2: scrolls right -->
      <div class="rw-row rw-row--right">
        <div class="rw-track">
          <img src="/reviews/6.webp" alt={reviewAlts[5]} class="rw-img" loading="lazy" />
          <img src="/reviews/1.webp" alt={reviewAlts[0]} class="rw-img" loading="lazy" />
          <img src="/reviews/7.webp" alt={reviewAlts[6]} class="rw-img" loading="lazy" />
          <img src="/reviews/10.webp" alt={reviewAlts[9]} class="rw-img" loading="lazy" />
          <img src="/reviews/9.webp" alt={reviewAlts[8]} class="rw-img" loading="lazy" />
          <!-- Duplicate for seamless loop -->
          <img src="/reviews/6.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/1.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/7.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/10.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/9.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
        </div>
      </div>
    </div>

    <!-- Lightbox — click to enlarge any review -->
    <div class="lightbox" id="reviewLightbox" aria-hidden="true">
      <button class="lb-close" id="lbClose" aria-label="Закрыть">&times;</button>
      <button class="lb-prev" id="lbPrev" aria-label="Назад">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <img class="lb-img" id="lbImg" alt="" width="1200" height="1600" loading="lazy" />
      <button class="lb-next" id="lbNext" aria-label="Вперёд">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
      </button>
