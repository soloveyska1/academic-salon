---
import Base from '../layouts/Base.astro';
import DocumentCard from '../components/DocumentCard.astro';
import { D } from '../data/catalog.js';

const docCount = D.length;
const categoryMap = new Map();
const subjectMap = new Map();

for (const doc of D) {
  const category = doc.category || 'Без категории';
  categoryMap.set(category, (categoryMap.get(category) || 0) + 1);

  const subject = doc.subject || 'Общее';
  subjectMap.set(subject, (subjectMap.get(subject) || 0) + 1);
}

const categoryStats = Array.from(categoryMap.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6)
  .map(([name, count]) => ({ name, count }));

const maxCategoryCount = categoryStats[0]?.count || 1;

const subjectStats = Array.from(subjectMap.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5)
  .map(([name, count]) => ({ name, count }));

const curatedOrder = ['ВКР и дипломы', 'Курсовые работы', 'Рефераты', 'Отчёты по практике', 'Контрольные работы', 'Методические материалы'];
const curatedDocs = [];

for (const category of curatedOrder) {
  const candidate = D.find((doc) => doc.category === category && !curatedDocs.includes(doc));
  if (candidate) curatedDocs.push(candidate);
}

while (curatedDocs.length < 6) {
  const candidate = D.find((doc) => !curatedDocs.includes(doc));
  if (!candidate) break;
  curatedDocs.push(candidate);
}

const heroShelves = categoryStats.slice(0, 4);
const showcaseDocs = curatedDocs.slice(0, 6);

const milestones = [
  {
    year: '2019',
    title: 'Запуск «Кладовой ГИПСР»',
    text: 'Телеграм-канал как тихая внутренняя библиотека для студентов, где собирались реальные сданные работы.',
  },
  {
    year: '2021',
    title: 'Рост коллекции',
    text: 'Сотни материалов по психологии, социальной работе и смежным дисциплинам, сортировка по форматам и темам.',
  },
  {
    year: '2024',
    title: 'Переход в веб',
    text: 'Из-за ограничений Telegram библиотека переезжает в устойчивый формат сайта с полноценным каталогом.',
  },
  {
    year: 'Сейчас',
    title: 'Два сценария на одной платформе',
    text: 'Быстрый доступ к готовым материалам и деликатный сервис индивидуальной работы, если нужен точный результат под задачу.',
  },
];

const atelierStages = [
  {
    id: 'brief',
    label: 'Бриф',
    subtitle: 'Тема и рамка',
    timing: 'День 1',
    headline: 'Фиксируем задачу и критерии, по которым преподаватель будет оценивать работу.',
    body: 'Собираем методичку, требования к объему, дедлайн и пожелания по стилю. Вы сразу видите план и риски.',
    metrics: [
      { label: 'Стартовая сессия', value: '15-20 мин' },
      { label: 'Прозрачность этапов', value: '100%' },
      { label: 'Формат оплаты', value: '50/50' },
    ],
  },
  {
    id: 'draft',
    label: 'Черновик',
    subtitle: 'Каркас и аргументы',
    timing: 'Дни 2-4',
    headline: 'Собираем академический скелет: логика глав, источники и доказательная часть.',
    body: 'Показываем промежуточную версию, чтобы согласовать ход работы до финальной сборки и избежать лишних правок.',
    metrics: [
      { label: 'Антиплагиат на этапе', value: '70%+' },
      { label: 'Контрольные точки', value: '2-3' },
      { label: 'Согласование', value: 'в чате' },
    ],
  },
  {
    id: 'final',
    label: 'Финал',
    subtitle: 'Сдача и защита',
    timing: 'До дедлайна',
    headline: 'Передаем чистовую версию с оформлением, комментариями и поддержкой до закрытия работы.',
    body: 'Если преподаватель просит доработки, корректируем бесплатно в рамках задачи до принятия результата.',
    metrics: [
      { label: 'Оформление', value: 'ГОСТ' },
      { label: 'Поддержка после сдачи', value: 'есть' },
      { label: 'Скорость ответов', value: '24/7' },
    ],
  },
];
---

<Base title="Академический Салон — библиотека «Кладовая ГИПСР»" currentPath="/">
  <section class="landing-hero" id="hero">
    <div class="hero-scan" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>

    <div class="container hero-inner">
      <div class="hero-intro">
        <p class="hero-kicker" data-reveal>Архив «Кладовая ГИПСР»</p>
        <h1 class="hero-title" data-reveal data-delay="80">
          Библиотека реальных студенческих работ.<br />
          Сервис авторских работ как второй, аккуратный слой.
        </h1>
        <p class="hero-lead" data-reveal data-delay="140">
          Сначала вы берете готовые материалы из фонда и закрываете задачу быстро.
          Если нужен индивидуальный формат под конкретные требования, подключаемся как авторская команда.
        </p>

        <div class="hero-actions" data-reveal data-delay="190">
          <a href="/catalog" class="btn btn-primary">Открыть библиотеку</a>
          <a href="/order" class="btn btn-secondary">Обсудить индивидуальную работу</a>
        </div>

        <div class="hero-micro" data-reveal data-delay="240">
          <div class="hero-micro-item">
            <span class="hero-micro-value">{docCount}+</span>
            <span class="hero-micro-label">документов в открытом фонде</span>
          </div>
          <div class="hero-micro-item">
            <span class="hero-micro-value">6+ лет</span>
            <span class="hero-micro-label">контекста СПбГИПСР и смежных программ</span>
          </div>
          <div class="hero-micro-item">
            <span class="hero-micro-value">50/50</span>
            <span class="hero-micro-label">модель оплаты для индивидуальных заказов</span>
          </div>
        </div>
      </div>

      <div class="hero-plane" id="heroPlane" data-reveal data-delay="120">
        <div class="hero-plane-head">
          <span class="hero-plane-title">Срез фонда по категориям</span>
          <span class="hero-plane-total">{docCount} документов</span>
        </div>

        <div class="hero-shelves">
          {heroShelves.map((item, index) => (
            <article class="hero-shelf" style={`--ratio:${Math.max(18, Math.round((item.count / maxCategoryCount) * 100))}%`}>
              <div class="hero-shelf-row">
                <span class="hero-shelf-name">{item.name}</span>
                <span class="hero-shelf-count">{item.count}</span>
              </div>
              <span class="hero-shelf-track" aria-hidden="true">
                <span class="hero-shelf-fill" style={`transition-delay:${index * 90}ms`}></span>
              </span>
            </article>
          ))}
        </div>

        <p class="hero-plane-note">Каталог растет из реальных работ, которые проходили через канал и частные запросы студентов.</p>
      </div>
    </div>
  </section>

  <section class="library-atlas" id="atlas">
    <div class="container">
      <p class="section-label" data-reveal>Фонд библиотеки</p>

      <div class="atlas-grid">
        <div class="atlas-copy" data-reveal>
          <h2>Навигация сделана вокруг реальной учебной рутины, а не абстрактных витрин.</h2>
          <p>
            Каталог помогает быстро найти отправную точку: посмотреть структуру,
            оформление, аргументацию и тон готовой работы до того, как тратить время на самостоятельную сборку.
          </p>
          <div class="subject-cloud">
            {subjectStats.map((subject) => (
              <span class="subject-pill">{subject.name} · {subject.count}</span>
            ))}
          </div>
        </div>

        <ol class="atlas-chart" id="atlasChart" data-reveal data-delay="90">
          {categoryStats.map((item, index) => (
            <li class="atlas-row" style={`--ratio:${Math.max(18, Math.round((item.count / maxCategoryCount) * 100))}%; --stagger:${index * 70}ms`}>
              <div class="atlas-row-head">
                <span>{item.name}</span>
                <strong>{item.count}</strong>
              </div>
              <span class="atlas-row-track" aria-hidden="true">
                <span class="atlas-row-fill"></span>
              </span>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <section class="provenance" id="provenance">
    <div class="container">
      <p class="section-label" data-reveal>Путь «Кладовой ГИПСР»</p>

      <div class="provenance-grid">
        <div class="provenance-lead" data-reveal>
          <h2>Это не витрина ради витрины, а эволюция живого студенческого архива.</h2>
          <p>
            Сайт сохраняет главный принцип канала: сначала дать студенту полезный материал,
            а уже потом мягко предложить авторское сопровождение, если нужна работа точно под требования и дедлайн.
          </p>
          <a href="/order" class="text-link">Нужен формат «под вас» — берём в работу аккуратно и без шума</a>
        </div>

        <ol class="provenance-line" data-reveal data-delay="100">
          {milestones.map((milestone, index) => (
            <li class="milestone" style={`transition-delay:${index * 80}ms`}>
              <span class="milestone-year">{milestone.year}</span>
              <h3>{milestone.title}</h3>
              <p>{milestone.text}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <section class="showcase" id="showcase">
    <div class="container">
      <div class="showcase-head">
        <p class="section-label" data-reveal>Примеры из коллекции</p>
        <p class="showcase-sub" data-reveal data-delay="70">
          Конкретные документы из разных сценариев: от коротких рефератов до объемных выпускных работ.
        </p>
      </div>

      <div class="showcase-grid">
        {showcaseDocs.map((doc, index) => (
          <div class:list={[
            'showcase-item',
            {
              'showcase-item--lead': index === 0,
            },
          ]} data-reveal data-delay={Math.min(index * 70, 280)}>
            <DocumentCard doc={doc} index={index} />
          </div>
        ))}
      </div>

      <div class="showcase-foot" data-reveal data-delay="120">
        <a href="/catalog" class="btn btn-secondary">Смотреть весь каталог</a>
        <a href="/order" class="btn btn-ghost">Если нужен новый текст под задачу, оформим заказ →</a>
      </div>
    </div>
  </section>

  <section class="atelier" id="atelier">
    <div class="container">
      <p class="section-label" data-reveal>Индивидуальная работа</p>

      <div class="atelier-grid">
        <div class="atelier-copy" data-reveal>
          <h2>Когда готового файла недостаточно, подключаем авторский режим.</h2>
          <p>
            Конверсия встроена в логику страницы без агрессивных продаж: сначала польза библиотеки,
            затем прозрачный производственный процесс для тех, кому нужна персональная работа.
          </p>

          <div class="atelier-list" id="atelierList">
            {atelierStages.map((stage, index) => (
              <button
                type="button"
                class:list={['atelier-step', { 'is-active': index === 0 }]}
                data-stage={stage.id}
              >
                <span class="atelier-step-order">{String(index + 1).padStart(2, '0')}</span>
                <span class="atelier-step-main">{stage.label}</span>
                <span class="atelier-step-sub">{stage.subtitle}</span>
              </button>
            ))}
          </div>
        </div>

        <article class="atelier-panel" id="atelierPanel" data-reveal data-delay="110">
          <div class="atelier-panel-top">
            <span class="atelier-tag" id="atelierTag">{atelierStages[0].label}</span>
            <span class="atelier-time" id="atelierTime">{atelierStages[0].timing}</span>
          </div>

          <h3 id="atelierHeadline">{atelierStages[0].headline}</h3>
          <p id="atelierBody">{atelierStages[0].body}</p>

          <div class="atelier-metrics" id="atelierMetrics">
            {atelierStages[0].metrics.map((metric) => (
              <div class="atelier-metric">
                <span>{metric.label}</span>
                <strong>{metric.value}</strong>
              </div>
            ))}
          </div>

          <a href="/order" class="btn btn-primary atelier-cta">Запустить индивидуальную работу</a>
        </article>
      </div>
    </div>
  </section>

  <section class="proof" id="proof">
    <div class="container proof-grid">
      <article class="proof-block" data-reveal>
        <p class="proof-kicker">Репутация</p>
        <h2>Сайт сохраняет аккуратный тон библиотеки, но не теряет коммерческую ясность.</h2>
        <p>
          Если запрос типовой, удобнее взять готовый документ из фонда.
          Если преподаватель требует уникальную структуру и быстрое сопровождение,
          логично перейти к заказу и закрыть задачу без суеты.
        </p>
      </article>

      <article class="proof-block" data-reveal data-delay="90">
        <p class="proof-kicker">Гарантии</p>
        <ul class="proof-list">
          <li>Бесплатные доработки до принятия работы</li>
          <li>Формализация требований до старта</li>
          <li>Конфиденциальная коммуникация в личных каналах</li>
          <li>Поддержка до финальной сдачи</li>
        </ul>
      </article>

      <article class="proof-block proof-block--cta" data-reveal data-delay="140">
        <p class="proof-kicker">Контакт</p>
        <h3>Остались вопросы по теме или дедлайну?</h3>
        <p>Напишите удобным способом, оценим задачу и предложим рабочий сценарий без навязчивости.</p>
        <div class="proof-actions">
          <a href="/order" class="btn btn-primary">Перейти к заказу</a>
          <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost">Telegram →</a>
          <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost">VK →</a>
        </div>
      </article>
    </div>
  </section>

  <script type="application/json" id="atelierData">{JSON.stringify(atelierStages)}</script>
</Base>

<style>
  .landing-hero,
  .library-atlas,
  .provenance,
  .showcase,
  .atelier,
  .proof {
    position: relative;
    z-index: 2;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(26px);
    transition: opacity .65s var(--ease), transform .65s var(--ease);
    transition-delay: var(--reveal-delay, 0ms);
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .landing-hero {
    min-height: calc(100svh - 28px);
    padding: calc(var(--nav-h) + 56px) 0 96px;
    overflow: clip;
    border-bottom: 1px solid rgba(212,175,55,.08);
  }
  .landing-hero::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 180px;
    background: linear-gradient(180deg, transparent 0%, rgba(9,8,12,.86) 100%);
    pointer-events: none;
  }

  .hero-scan,
  .hero-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero-scan {
    background:
      radial-gradient(860px 460px at 18% 18%, rgba(212,175,55,.14), transparent 72%),
      radial-gradient(960px 540px at 84% 76%, rgba(246,226,122,.08), transparent 72%),
      linear-gradient(160deg, rgba(12,11,16,.95), rgba(8,7,12,.7));
  }
  .hero-grid {
    background-image:
      linear-gradient(rgba(212,175,55,.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212,175,55,.04) 1px, transparent 1px);
    background-size: 52px 52px;
    mask-image: radial-gradient(circle at 56% 36%, rgba(0,0,0,.95) 0%, rgba(0,0,0,.24) 64%, transparent 100%);
    opacity: .3;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(0, .92fr);
    align-items: end;
    gap: clamp(30px, 5vw, 74px);
    position: relative;
    z-index: 2;
  }

  .hero-kicker {
    font-size: 12px;
    letter-spacing: 2.2px;
    text-transform: uppercase;
    color: var(--ac3);
    margin-bottom: var(--sp-5);
  }
  .hero-title {
    font-family: var(--fd);
    font-size: clamp(40px, 5.2vw, 72px);
    line-height: 1.04;
    color: var(--t1);
    text-wrap: balance;
  }
  .hero-lead {
    margin-top: var(--sp-6);
    max-width: 620px;
    color: var(--t2);
    font-size: clamp(16px, 1.6vw, 20px);
    line-height: 1.6;
  }

  .hero-actions {
    margin-top: var(--sp-8);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  .hero-micro {
    margin-top: var(--sp-8);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--sp-4);
    max-width: 760px;
  }
  .hero-micro-item {
    padding-top: 14px;
    border-top: 1px solid rgba(212,175,55,.2);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .hero-micro-value {
    font-family: var(--fm);
    font-size: 14px;
    color: var(--ac3);
    letter-spacing: .6px;
  }
  .hero-micro-label {
    color: var(--t2);
    font-size: 13px;
    line-height: 1.5;
  }

  .hero-plane {
    border: 1px solid rgba(212,175,55,.18);
    border-radius: 24px;
    padding: 28px;
    background:
      linear-gradient(160deg, rgba(18,17,25,.82), rgba(11,10,16,.6));
    box-shadow:
      0 26px 90px rgba(0,0,0,.46),
      inset 0 1px 0 rgba(255,255,255,.08);
    backdrop-filter: blur(18px) saturate(1.22);
    will-change: transform;
    transform: perspective(1200px) rotateX(0deg) rotateY(0deg);
    transition: transform .18s linear;
  }

  .hero-plane-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--sp-4);
    border-bottom: 1px solid rgba(212,175,55,.14);
    padding-bottom: var(--sp-4);
    margin-bottom: var(--sp-5);
  }
  .hero-plane-title {
    font-size: 13px;
    color: var(--t2);
    letter-spacing: .5px;
    text-transform: uppercase;
  }
  .hero-plane-total {
    font-family: var(--fm);
    color: var(--ac3);
    font-size: 13px;
  }

  .hero-shelves {
    display: grid;
    gap: 16px;
  }
  .hero-shelf-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--sp-3);
    margin-bottom: 7px;
  }
  .hero-shelf-name {
    font-size: 14px;
    color: var(--t1);
    line-height: 1.4;
  }
  .hero-shelf-count {
    font-family: var(--fm);
    font-size: 12px;
    color: var(--ac3);
  }
  .hero-shelf-track {
    display: block;
    height: 5px;
    border-radius: 999px;
    background: rgba(212,175,55,.08);
    overflow: hidden;
  }
  .hero-shelf-fill {
    display: block;
    height: 100%;
    width: var(--ratio);
    border-radius: inherit;
    background: linear-gradient(90deg, rgba(212,175,55,.55), rgba(246,226,122,.96));
    transform-origin: left center;
    transform: scaleX(0);
    animation: shelf-fill .9s var(--ease-spring) forwards;
  }
  @keyframes shelf-fill {
    to { transform: scaleX(1); }
  }

  .hero-plane-note {
    margin-top: var(--sp-5);
    color: var(--t3);
    font-size: 13px;
    line-height: 1.55;
    border-top: 1px solid rgba(212,175,55,.1);
    padding-top: var(--sp-4);
  }

  .library-atlas {
    padding: 86px 0 56px;
  }
  .atlas-grid {
    margin-top: var(--sp-8);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: clamp(26px, 4vw, 58px);
  }

  .atlas-copy h2 {
    font-family: var(--fd);
    font-size: clamp(28px, 3.1vw, 42px);
    line-height: 1.18;
    text-wrap: balance;
  }
  .atlas-copy p {
    margin-top: var(--sp-5);
    color: var(--t2);
    font-size: 16px;
    line-height: 1.65;
    max-width: 560px;
  }

  .subject-cloud {
    margin-top: var(--sp-6);
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .subject-pill {
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid rgba(212,175,55,.2);
    color: var(--t2);
    font-size: 12px;
    background: rgba(212,175,55,.04);
  }

  .atlas-chart {
    list-style: none;
    display: grid;
    gap: 15px;
  }
  .atlas-row {
    padding: 14px 16px;
    border: 1px solid rgba(212,175,55,.14);
