---
import Base from '../layouts/Base.astro';
import DocumentCard from '../components/DocumentCard.astro';
import { D } from '../data/catalog.js';

const categories = ['ВКР и дипломы', 'Курсовые работы', 'Рефераты', 'Отчёты по практике', 'Контрольные работы', 'Методические материалы'];
const featured: typeof D = [];
for (const cat of categories) {
  const doc = D.find(d => d.category === cat && !featured.includes(d));
  if (doc) featured.push(doc);
}
while (featured.length < 6) {
  const doc = D.find(d => !featured.includes(d));
  if (doc) featured.push(doc);
  else break;
}
const docCount = D.length;
---

<Base title="Академический Салон — Библиотека студенческих работ" currentPath="/">

  <!-- ═══════════ THREE.JS 3D SCENE ═══════════ -->
  <canvas id="heroScene" class="hero-3d" aria-hidden="true"></canvas>

  <!-- ═══════════ CHROMATIC ABERRATION OVERLAY ═══════════ -->
  <canvas id="chromaCanvas" class="chroma-layer" aria-hidden="true"></canvas>

  <!-- ═══════════ GOLD FLUID CANVAS ═══════════ -->
  <canvas id="goldFluid" class="gold-fluid" aria-hidden="true"></canvas>

  <!-- ═══════════ HERO — CINEMATIC ═══════════ -->
  <section class="hero" id="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-glow"></div>
    </div>

    <div class="container hero-inner">
      <p class="hero-eyebrow" data-reveal>
        <span class="hero-ew-line"></span>
        <span class="scramble-text" data-final="Библиотека студенческих работ">················</span>
        <span class="hero-ew-line"></span>
      </p>

      <!-- Particle Text Canvas replaces static h1 -->
      <canvas id="particleText" class="particle-text-canvas" width="900" height="260"></canvas>
      <h1 class="hero-h1-fallback" id="heroH1Fallback">
        <span class="hero-h1-main">Академический</span>
        <span class="hero-accent gold-shimmer">Салон</span>
      </h1>

      <div class="hero-ornament" data-reveal data-reveal-delay="400" aria-hidden="true">
        <span class="hero-orn-line"></span>
        <span class="hero-orn-diamond">&#9830;</span>
        <span class="hero-orn-line"></span>
      </div>

      <p class="hero-sub" data-reveal data-reveal-delay="500">
        <span class="typed-line" id="heroTyped"></span>
      </p>

      <!-- Dual CTA — two paths -->
      <div class="hero-dual" data-reveal data-reveal-delay="600">
        <a href="/catalog" class="hero-path hero-path--free">
          <span class="hero-path-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/></svg>
          </span>
          <span class="hero-path-label">Скачать готовую</span>
          <span class="hero-path-sub">{docCount} работ бесплатно</span>
          <span class="hero-path-arrow">&rarr;</span>
        </a>

        <div class="hero-path-divider">
          <span class="hero-path-or">или</span>
        </div>

        <a href="/order" class="hero-path hero-path--order">
          <span class="hero-path-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"/></svg>
          </span>
          <span class="hero-path-label">Заказать свою</span>
          <span class="hero-path-sub">Напишем под ключ</span>
          <span class="hero-path-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════ SECTION DIVIDER ═══════════ -->
  <div class="section-divider" aria-hidden="true">
    <svg viewBox="0 0 1200 2" preserveAspectRatio="none"><line x1="0" y1="1" x2="1200" y2="1" stroke="url(#goldLine)" stroke-width="1"/><defs><linearGradient id="goldLine"><stop offset="0%" stop-color="transparent"/><stop offset="50%" stop-color="rgba(212,175,55,.3)"/><stop offset="100%" stop-color="transparent"/></linearGradient></defs></svg>
  </div>

  <!-- ═══════════ LIVE TICKER ═══════════ -->
  <div class="ticker" id="liveTicker" aria-hidden="true">
    <div class="ticker-track" id="tickerTrack"></div>
  </div>

  <!-- ═══════════ SECTION DIVIDER ═══════════ -->
  <div class="section-divider" aria-hidden="true">
    <svg viewBox="0 0 1200 2" preserveAspectRatio="none"><line x1="0" y1="1" x2="1200" y2="1" stroke="url(#goldLine2)" stroke-width="1"/><defs><linearGradient id="goldLine2"><stop offset="0%" stop-color="transparent"/><stop offset="50%" stop-color="rgba(212,175,55,.3)"/><stop offset="100%" stop-color="transparent"/></linearGradient></defs></svg>
  </div>

  <!-- ═══════════ MORPHING BLOB ═══════════ -->
  <div class="morph-blob-wrap" aria-hidden="true">
    <svg class="morph-blob" viewBox="0 0 200 200">
      <path class="morph-path" fill="rgba(212,175,55,.04)" stroke="rgba(212,175,55,.08)" stroke-width="0.5"/>
    </svg>
  </div>

  <!-- ═══════════ SCROLL TEXT REVEAL — MANIFESTO ═══════════ -->
  <section class="manifesto" id="manifesto">
    <div class="container">
      <p class="manifesto-text" id="manifestoText">
        <span class="mw">Мы</span>
        <span class="mw">пишем</span>
        <span class="mw">работы,</span>
        <span class="mw">которые</span>
        <span class="mw mw-gold">сдаются</span>
        <span class="mw">с</span>
        <span class="mw">первого</span>
        <span class="mw">раза.</span>
        <span class="mw">Уже</span>
        <span class="mw mw-gold">шесть</span>
        <span class="mw">лет.</span>
        <span class="mw">Для</span>
        <span class="mw mw-gold">сотен</span>
        <span class="mw">студентов.</span>
        <span class="mw">Каждая</span>
        <span class="mw">работа</span>
        <span class="mw">—</span>
        <span class="mw mw-gold">индивидуальная.</span>
        <span class="mw">Как</span>
        <span class="mw">почерк.</span>
      </p>
    </div>
  </section>

  <!-- ═══════════ SCROLL PAPER CREATION ═══════════ -->
  <section class="paper-journey" id="paperJourney">
    <div class="container">
      <p class="section-label" data-reveal>Как это работает</p>
    </div>
    <div class="paper-stage" id="paperStage">
      <div class="paper-sheet" id="paperSheet">
        <div class="paper-corner"></div>
        <div class="paper-lines" id="paperLines">
          <div class="paper-line" style="--i:0">Тема: Особенности социальной адаптации...</div>
          <div class="paper-line" style="--i:1">Введение. Актуальность исследования обусловлена...</div>
          <div class="paper-line" style="--i:2">Глава 1. Теоретические основы...</div>
          <div class="paper-line" style="--i:3">1.1 Понятие и сущность социальной работы...</div>
          <div class="paper-line" style="--i:4">Глава 2. Эмпирическое исследование...</div>
          <div class="paper-line" style="--i:5">Заключение. В ходе исследования было выявлено...</div>
          <div class="paper-line" style="--i:6">Список литературы: 45 источников</div>
        </div>
        <div class="paper-stamp" id="paperStamp">
          <span>Сдано</span>
          <span class="paper-stamp-grade">на отлично</span>
        </div>
      </div>

      <div class="paper-steps">
        <div class="paper-step" data-step="0">
          <div class="paper-step-num">01</div>
          <h3>Расскажите задачу</h3>
          <p>Тема, предмет, требования — всё, что знаете. Остальное уточним сами.</p>
        </div>
        <div class="paper-step" data-step="1">
          <div class="paper-step-num">02</div>
          <h3>Мы пишем</h3>
          <p>Исследуем, структурируем, оформляем по ГОСТ. Вы видите прогресс.</p>
        </div>
        <div class="paper-step" data-step="2">
          <div class="paper-step-num">03</div>
          <h3>Сдаёте и забываете</h3>
          <p>Готовая работа + бесплатные правки до успешной сдачи.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ WHY US ═══════════ -->
  <section class="why-us">
    <div class="container">
      <p class="section-label" data-reveal>Почему мы</p>
      <div class="why-grid">
        <div class="why-card" data-reveal>
          <div class="why-card-glow"></div>
          <div class="why-icon">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="24" cy="24" r="20" stroke-dasharray="4 4"/><text x="24" y="28" text-anchor="middle" fill="currentColor" stroke="none" font-size="16" font-weight="700" font-family="var(--fd)">6+</text></svg>
          </div>
          <h3 class="why-title">Лет опыта</h3>
          <p class="why-desc">Начинали как студенческий канал в Telegram. Выросли в сервис с сотнями выполненных работ.</p>
          <div class="why-counter" data-count="427">0</div>
          <span class="why-counter-label">работ выполнено</span>
        </div>

        <div class="why-card" data-reveal data-reveal-delay="100">
          <div class="why-card-glow"></div>
          <div class="why-icon">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 38V14a4 4 0 0 1 4-4h24a4 4 0 0 1 4 4v24"/><path d="M14 22h20M14 30h12"/><circle cx="36" cy="36" r="8" fill="rgba(212,175,55,.15)" stroke="var(--ac)"/><path d="M33 36l2 2 4-4" stroke="var(--ac)"/></svg>
          </div>
          <h3 class="why-title">Знаем ГИПСР изнутри</h3>
          <p class="why-desc">Мы прошли те же пары, тех же преподавателей. Знаем требования каждого.</p>
        </div>

        <div class="why-card" data-reveal data-reveal-delay="200">
          <div class="why-card-glow"></div>
          <div class="why-icon">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M24 4C13 4 4 13 4 24s9 20 20 20 20-9 20-20S35 4 24 4z"/><path class="infinity-path" d="M16 24c0-3 2-6 5-6s5 3 5 6-2 6-5 6-5-3-5-6zm10 0c0-3 2-6 5-6s5 3 5 6-2 6-5 6-5-3-5-6z" stroke="var(--ac)" stroke-width="2"/></svg>
          </div>
          <h3 class="why-title">Бесплатные правки</h3>
          <p class="why-desc">Бесконечные корректировки до полной сдачи. Мы не бросаем после оплаты.</p>
        </div>

        <div class="why-card" data-reveal data-reveal-delay="300">
          <div class="why-card-glow"></div>
          <div class="why-icon">
            <svg viewBox="0 0 48 48" fill="none"><circle cx="18" cy="24" r="14" stroke="currentColor" stroke-width="1.5"/><circle cx="30" cy="24" r="14" stroke="var(--ac)" stroke-width="1.5"/><path d="M24 14.3a14 14 0 0 1 0 19.4" stroke="currentColor" stroke-width="1.5" opacity=".4"/></svg>
          </div>
          <h3 class="why-title">Оплата 50/50</h3>
          <p class="why-desc">Половина при заказе, половина после готовности. Никаких рисков.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ FEATURED CATALOG ═══════════ -->
  <section class="featured">
    <div class="container">
      <p class="section-label" data-reveal>Из каталога</p>
      <div class="bento" id="bentoGrid">
        {featured.map((doc, i) => (
          <div class="tilt-card" data-tilt>
            <DocumentCard doc={doc} index={i} />
            <a href="/order" class="card-micro-cta">Нужна похожая? &rarr;</a>
          </div>
        ))}
      </div>
      <div class="featured-foot" data-reveal>
        <a href="/catalog" class="btn btn-secondary">
          Все {docCount} документов
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════ SOCIAL PROOF ═══════════ -->
  <section class="proof">
    <div class="container">
      <p class="section-label" data-reveal>Нам доверяют</p>
      <div class="proof-grid">
        <div class="proof-stats" data-reveal>
          <div class="proof-stat">
            <span class="proof-stat-n" data-count="93">0</span>
            <span class="proof-stat-u">%</span>
            <span class="proof-stat-l">сдают с первого раза</span>
          </div>
          <div class="proof-stat">
            <span class="proof-stat-n proof-stat-inf">&infin;</span>
            <span class="proof-stat-l">бесплатных правок</span>
          </div>
          <div class="proof-stat">
            <span class="proof-stat-n" data-count="6">0</span>
            <span class="proof-stat-u">лет</span>
            <span class="proof-stat-l">на рынке</span>
          </div>
        </div>

        <div class="proof-reviews" data-reveal data-reveal-delay="200">
          <div class="phone-mockup">
            <div class="phone-notch"></div>
            <div class="phone-screen" id="reviewCarousel">
              <div class="review-msg review-msg--in">Здравствуйте! Курсовая по психологии нужна к пятнице, тема: «Мотивация учебной деятельности»</div>
              <div class="review-msg review-msg--out">Добрый день! Да, сделаем. 40 страниц, ГОСТ, антиплагиат от 70%. Готово будет в среду 👌</div>
              <div class="review-msg review-msg--in">Супер быстро! Спасибо огромное!</div>
              <div class="review-msg review-msg--out">Готово ✅ Отправляю файл. Если будут правки — бесплатно поправим</div>
              <div class="review-msg review-msg--in">Сдала на 5! Вы лучшие 🎉</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ HORIZONTAL SCROLL PORTFOLIO ═══════════ -->
  <section class="hscroll" id="hscrollSection">
    <div class="hscroll-sticky">
      <p class="section-label container" data-reveal>Выполненные работы</p>
      <div class="hscroll-track" id="hscrollTrack">
        <div class="hscroll-card">
          <div class="hscroll-card-type">Курсовая работа</div>
          <h3>Мотивация учебной деятельности студентов</h3>
          <div class="hscroll-card-meta">Психология &middot; 42 стр. &middot; Антиплагиат 78%</div>
          <div class="hscroll-card-result">Оценка: <strong>отлично</strong></div>
        </div>
        <div class="hscroll-card">
          <div class="hscroll-card-type">ВКР (дипломная)</div>
          <h3>Социальная адаптация детей-сирот в условиях интерната</h3>
          <div class="hscroll-card-meta">Социальная работа &middot; 68 стр. &middot; Антиплагиат 82%</div>
          <div class="hscroll-card-result">Защита: <strong>с отличием</strong></div>
        </div>
        <div class="hscroll-card">
          <div class="hscroll-card-type">Реферат</div>
          <h3>Теории массовых социальных движений</h3>
          <div class="hscroll-card-meta">Социология &middot; 24 стр. &middot; 2 дня</div>
          <div class="hscroll-card-result">Оценка: <strong>отлично</strong></div>
        </div>
        <div class="hscroll-card">
          <div class="hscroll-card-type">Курсовая работа</div>
          <h3>Психодиагностика эмоциональных состояний</h3>
          <div class="hscroll-card-meta">Психодиагностика &middot; 38 стр. &middot; Антиплагиат 75%</div>
          <div class="hscroll-card-result">Принята <strong>без правок</strong></div>
        </div>
        <div class="hscroll-card">
          <div class="hscroll-card-type">Отчёт по практике</div>
          <h3>Стажёрская практика в центре социальной помощи</h3>
          <div class="hscroll-card-meta">Социальная работа &middot; 32 стр. &middot; 1 день</div>
          <div class="hscroll-card-result">Оценка: <strong>отлично</strong></div>
        </div>
        <div class="hscroll-card">
          <div class="hscroll-card-type">Дипломная работа</div>
          <h3>Профилактика девиантного поведения подростков</h3>
          <div class="hscroll-card-meta">Психология &middot; 72 стр. &middot; Антиплагиат 85%</div>
          <div class="hscroll-card-result">Защита: <strong>на отлично</strong></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ TRUST STACK ═══════════ -->
  <section class="trust-stack">
    <div class="container">
      <div class="trust-shield-wrap" data-reveal>
        <svg class="trust-shield" viewBox="0 0 80 96" fill="none" stroke="var(--ac)" stroke-width="2">
          <path class="shield-path" d="M40 4 L72 20 V52 C72 72 56 88 40 92 C24 88 8 72 8 52 V20 Z" stroke-dasharray="300" stroke-dashoffset="300"/>
          <path class="shield-check" d="M28 48 L36 58 L54 38" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="50" stroke-dashoffset="50"/>
        </svg>
        <h2 class="trust-title">Гарантируем результат</h2>
      </div>

      <div class="trust-cards">
        <div class="trust-card" data-reveal>
          <div class="trust-card-icon">&#8734;</div>
          <h3>Бесплатные правки</h3>
          <p>Пока не будете полностью довольны результатом. Без ограничений.</p>
        </div>
        <div class="trust-card" data-reveal data-reveal-delay="100">
          <div class="trust-card-icon">&#128176;</div>
          <h3>Возврат средств</h3>
          <p>Полный возврат, если не сможем выполнить работу. Без вопросов.</p>
        </div>
        <div class="trust-card" data-reveal data-reveal-delay="200">
          <div class="trust-card-icon">&#128274;</div>
          <h3>Конфиденциальность</h3>
          <p>Ваши данные никогда не передаются третьим лицам. Анонимность гарантирована.</p>
        </div>
      </div>

      <div class="trust-badges" data-reveal>
        <span class="trust-badge">&#10003; Оплата 50/50</span>
        <span class="trust-badge">&#10003; Оформление по ГОСТ</span>
        <span class="trust-badge">&#10003; Антиплагиат от 70%</span>
        <span class="trust-badge">&#10003; Сдача в срок</span>
        <span class="trust-badge">&#10003; 6+ лет опыта</span>
      </div>
    </div>
  </section>

  <!-- ═══════════ CTA — FINAL ═══════════ -->
  <section class="cta-final">
    <div class="container">
      <div class="cta-card" data-reveal>
        <div class="cta-card-glow"></div>
        <h2 class="cta-title">
          <span class="scramble-text" data-final="Напишем вашу работу">·················</span>
        </h2>
        <p class="cta-sub">От идеи до защиты. Курсовые, дипломные, ВКР, рефераты — индивидуально, по ГОСТ, с гарантией сдачи.</p>

        <div class="cta-actions">
          <a href="/order" class="btn btn-primary btn-glow">
            Узнать стоимость
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost">Написать в ВК &rarr;</a>
          <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost">Telegram &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════ FLOATING CTA ═══════════ -->
  <div class="float-cta" id="floatCta">
    <a href="/order" class="float-cta-btn" id="floatCtaBtn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Z"/></svg>
      <span class="float-cta-text">Заказать</span>
    </a>
  </div>

  <!-- ═══════════ CURSOR TRAIL CANVAS ═══════════ -->
  <canvas id="cursorTrail" class="cursor-trail" aria-hidden="true"></canvas>

  <!-- ═══════════ TOAST NOTIFICATIONS ═══════════ -->
  <div class="toast-container" id="toastContainer"></div>

</Base>

<style>
  /* ═══════════════════════════════════════
     GOLD FLUID CANVAS
     ═══════════════════════════════════════ */
  .gold-fluid {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: .6;
  }

  /* ═══════════════════════════════════════
     HERO — CINEMATIC
     ═══════════════════════════════════════ */
  .hero {
    position: relative;
    padding: 140px 0 80px;
    text-align: center;
    overflow: visible;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero-glow {
    position: absolute;
    top: -30%; left: 50%;
    transform: translateX(-50%);
    width: 1200px; height: 800px;
    background:
      radial-gradient(ellipse 50% 40%, rgba(212,175,55,.12) 0%, transparent 60%),
      radial-gradient(ellipse 30% 25% at 30% 60%, rgba(212,175,55,.06) 0%, transparent 50%),
      radial-gradient(ellipse 25% 20% at 70% 70%, rgba(167,139,250,.03) 0%, transparent 50%);
    animation: glow-pulse 6s ease-in-out infinite alternate;
  }
  @keyframes glow-pulse {
    0% { opacity: .7; transform: translateX(-50%) scale(1) }
    100% { opacity: 1; transform: translateX(-50%) scale(1.08) }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
    text-align: center;
  }

  /* Eyebrow */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--ac);
    opacity: 0;
    margin-bottom: var(--sp-8);
  }
  .hero-ew-line {
    width: 40px; height: 1px;
    background: var(--ac);
    opacity: .5;
  }

  /* Title fallback (visible until particle canvas loads) */
  .hero-h1-fallback {
    font-family: var(--fd);
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 900;
    letter-spacing: -.04em;
    line-height: .88;
    margin-bottom: var(--sp-4);
    filter: drop-shadow(0 4px 32px rgba(212,175,55,.1));
    text-align: center;
  }
  .hero-h1-fallback.hidden { display: none; }
  .hero-h1-main {
    display: block;
    background: linear-gradient(180deg, #ffffff 0%, #e8dcc8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-accent {
    display: block;
    font-style: italic;
    letter-spacing: .01em;
    margin-top: -.05em;
  }

  /* Ornament */
  .hero-ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin: var(--sp-6) 0 var(--sp-8);
    opacity: 0;
  }
  .hero-orn-line {
    width: 60px; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212,175,55,.35), transparent);
  }
  .hero-orn-diamond {
    font-size: 8px;
    color: var(--ac);
    opacity: .4;
    animation: diamond-spin 8s linear infinite;
  }
  @keyframes diamond-spin {
    0%, 100% { transform: rotate(0deg) scale(1) }
    50% { transform: rotate(180deg) scale(1.3) }
  }

  /* Typed subtitle */
  .hero-sub {
    font-size: 16px;
    color: var(--t2);
    line-height: 1.7;
    max-width: 500px;
    margin-bottom: var(--sp-10);
    min-height: 52px;
    opacity: 0;
  }
  .typed-line::after {
    content: '|';
    color: var(--ac);
    animation: blink 1s step-end infinite;
    margin-left: 2px;
  }
  @keyframes blink {
    50% { opacity: 0 }
  }

  /* ═══════════ DUAL CTA HERO ═══════════ */
  .hero-dual {
    display: flex;
    align-items: stretch;
    gap: 0;
    width: 100%;
    max-width: 680px;
    opacity: 0;
  }

  .hero-path {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-8) var(--sp-6);
    border-radius: var(--r);
    text-decoration: none;
    transition: all .4s var(--ease);
    position: relative;
    overflow: hidden;
  }
  .hero-path::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--r);
    border: 1px solid var(--brd);
    transition: border-color .4s var(--ease);
  }
  .hero-path::after {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity .4s var(--ease);
    border-radius: var(--r);
  }

  .hero-path--free {
    background: rgba(255,255,255,.02);
  }
  .hero-path--free::after {
    background: radial-gradient(ellipse at center, rgba(167,139,250,.06), transparent 70%);
  }
  .hero-path--free:hover::after { opacity: 1 }
  .hero-path--free:hover::before { border-color: rgba(167,139,250,.2) }
  .hero-path--free:hover { transform: translateY(-4px) }

  .hero-path--order {
    background: rgba(212,175,55,.03);
  }
  .hero-path--order::after {
    background: radial-gradient(ellipse at center, rgba(212,175,55,.08), transparent 70%);
  }
  .hero-path--order:hover::after { opacity: 1 }
  .hero-path--order:hover::before { border-color: rgba(212,175,55,.25) }
  .hero-path--order:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(212,175,55,.1);
  }

  .hero-path-icon {
    width: 48px; height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: rgba(255,255,255,.04);
    border: 1px solid var(--brd);
    color: var(--t2);
    transition: all .3s var(--ease);
  }
  .hero-path-icon svg { width: 24px; height: 24px }
  .hero-path--order .hero-path-icon { color: var(--ac) }
  .hero-path:hover .hero-path-icon {
    transform: scale(1.1);
    border-color: var(--brd-h);
  }

  .hero-path-label {
    font-family: var(--fd);
    font-size: 20px;
    font-weight: 800;
    color: var(--t1);
  }
  .hero-path-sub {
    font-size: 13px;
    color: var(--t3);
  }
  .hero-path-arrow {
    font-size: 18px;
    color: var(--t3);
    transition: all .3s var(--ease);
    opacity: 0;
    transform: translateX(-8px);
  }
  .hero-path:hover .hero-path-arrow {
    opacity: 1;
    transform: translateX(0);
  }
  .hero-path--order .hero-path-arrow { color: var(--ac) }

  .hero-path-divider {
    display: flex;
    align-items: center;
    padding: 0 var(--sp-4);
  }
  .hero-path-or {
    font-size: 12px;
    color: var(--t3);
    opacity: .5;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  /* ═══════════ HERO SCROLL FADE ═══════════ */
  .hero-inner {
    will-change: opacity, transform;
  }

  /* ═══════════ REVEAL SYSTEM ═══════════ */
  [data-reveal] {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity .8s var(--ease), transform .8s var(--ease);
  }
  [data-reveal].visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ═══════════ PORTAL REVEAL ═══════════ */
  .paper-journey {
    will-change: clip-path;
  }

  /* ═══════════ MORPHING BLOB ═══════════ */
  .morph-blob-wrap {
    position: relative;
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: calc(-1 * var(--sp-12)) 0;
    pointer-events: none;
    z-index: 0;
    overflow: visible;
  }
  .morph-blob {
    width: 600px;
    height: 200px;
    opacity: .7;
    filter: blur(40px);
  }

  /* ═══════════ SECTION DIVIDERS ═══════════ */
  .section-divider {
    padding: var(--sp-2) var(--sp-8);
    opacity: .6;
  }
  .section-divider svg {
    width: 100%;
    height: 2px;
    display: block;
  }

  /* ═══════════ LIVE TICKER ═══════════ */
  .ticker {
    padding: var(--sp-4) 0;
    overflow: hidden;
    border-top: 1px solid var(--brd);
    border-bottom: 1px solid var(--brd);
    background: rgba(212,175,55,.015);
    position: relative;
    z-index: 1;
  }
  .ticker::before, .ticker::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }
  .ticker::before { left: 0; background: linear-gradient(90deg, var(--bg), transparent) }
  .ticker::after { right: 0; background: linear-gradient(270deg, var(--bg), transparent) }

  .ticker-track {
    display: flex;
    gap: var(--sp-8);
    animation: ticker-scroll 40s linear infinite;
    width: max-content;
  }
  @keyframes ticker-scroll {
    0% { transform: translateX(0) }
    100% { transform: translateX(-50%) }
  }

  .ticker-item {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    white-space: nowrap;
    font-size: 13px;
    color: var(--t2);
  }
  .ticker-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--ac);
    opacity: .6;
    animation: dot-pulse 2s ease-in-out infinite;
  }
  @keyframes dot-pulse {
    0%, 100% { opacity: .3; transform: scale(.8) }
    50% { opacity: .8; transform: scale(1.2) }
  }
  .ticker-highlight {
    color: var(--ac2);
    font-weight: 600;
  }

  /* ═══════════ PAPER JOURNEY ═══════════ */
  .paper-journey {
    padding: var(--sp-24) 0;
    position: relative;
  }
  .paper-stage {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-16);
    max-width: var(--max-w);
    margin: var(--sp-12) auto 0;
    padding: 0 var(--sp-8);
    align-items: center;
  }

  .paper-sheet {
    position: relative;
    aspect-ratio: 210/297;
    max-height: 520px;
    background: #faf8f2;
    border-radius: 4px;
    box-shadow:
      0 2px 8px rgba(0,0,0,.1),
      0 16px 48px rgba(0,0,0,.15),
      inset 0 0 0 1px rgba(0,0,0,.05);
    padding: 40px 36px;
    transform: perspective(800px) rotateY(-6deg) rotateX(2deg);
    transition: transform 1s var(--ease), box-shadow 1s var(--ease);
    overflow: hidden;
  }
  .paper-sheet.active {
    transform: perspective(800px) rotateY(0) rotateX(0);
    box-shadow:
      0 4px 16px rgba(0,0,0,.1),
      0 32px 80px rgba(0,0,0,.2),
      0 0 60px rgba(212,175,55,.08);
  }
  .paper-corner {
    position: absolute;
    top: 0; right: 0;
    width: 40px; height: 40px;
    background: linear-gradient(225deg, var(--bg) 50%, #e8e4db 50%);
    box-shadow: -2px 2px 4px rgba(0,0,0,.05);
  }

  .paper-line {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    color: #2a2520;
    line-height: 2.4;
    opacity: 0;
    transform: translateX(-10px);
    transition: opacity .6s var(--ease), transform .6s var(--ease);
    transition-delay: calc(var(--i) * 150ms);
    border-bottom: 1px solid rgba(0,0,0,.04);
  }
  .paper-sheet.lines-visible .paper-line {
    opacity: 1;
    transform: translateX(0);
  }

  .paper-stamp {
    position: absolute;
    bottom: 40px; right: 36px;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 12px 24px;
    border: 3px solid #b8342a;
    border-radius: 8px;
    color: #b8342a;
    font-family: var(--fd);
    font-weight: 900;
    font-size: 18px;
    letter-spacing: 2px;
    text-transform: uppercase;
    transform: rotate(-12deg) scale(0);
    opacity: 0;
    transition: transform .5s var(--ease-spring), opacity .3s;
  }
  .paper-stamp-grade {
    font-size: 11px;
    letter-spacing: 1px;
  }
  .paper-sheet.stamped .paper-stamp {
    transform: rotate(-12deg) scale(1);
    opacity: .85;
  }

  .paper-steps {
    display: flex;
    flex-direction: column;
    gap: var(--sp-10);
  }
  .paper-step {
    padding: var(--sp-6);
    border-radius: var(--r);
    border: 1px solid var(--brd);
    background: var(--card);
    transition: all .5s var(--ease);
    opacity: .4;
    transform: translateX(20px);
  }
  .paper-step.active {
    opacity: 1;
    transform: translateX(0);
    border-color: rgba(212,175,55,.15);
    background: rgba(212,175,55,.03);
    box-shadow: 0 8px 32px rgba(212,175,55,.06);
  }
  .paper-step-num {
    font-family: var(--fm);
    font-size: 12px;
    color: var(--ac);
    opacity: .5;
    margin-bottom: var(--sp-2);
  }
  .paper-step h3 {
    font-family: var(--fd);
    font-size: 20px;
    font-weight: 800;
    color: var(--t1);
    margin-bottom: var(--sp-2);
  }
  .paper-step p {
    font-size: 14px;
    color: var(--t2);
    line-height: 1.6;
  }

  /* ═══════════ WHY US ═══════════ */
  .why-us {
    padding: var(--sp-24) 0;
  }
  .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-5);
    margin-top: var(--sp-10);
  }
  .why-card {
    position: relative;
    padding: var(--sp-8) var(--sp-6);
    border-radius: var(--r);
    border: 1px solid var(--brd);
    background: var(--card);
    text-align: center;
    overflow: hidden;
    transition: all .4s var(--ease);
  }
  .why-card::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: calc(var(--r) + 2px);
    background: conic-gradient(from var(--card-angle, 0deg), transparent 0%, rgba(212,175,55,.4) 10%, transparent 20%);
    opacity: 0;
    transition: opacity .4s var(--ease);
    z-index: -1;
    animation: rotate-border 3s linear infinite;
  }
  @keyframes rotate-border {
    to { --card-angle: 360deg; }
  }
  @property --card-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }
  .why-card:hover::before { opacity: 1; }
  .why-card:hover {
    border-color: transparent;
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(212,175,55,.08);
  }
  .why-card-glow {
    position: absolute;
    top: -50%; left: 50%;
    transform: translateX(-50%);
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(212,175,55,.08), transparent 70%);
    opacity: 0;
    transition: opacity .4s;
    pointer-events: none;
  }
  .why-card:hover .why-card-glow { opacity: 1 }

  .why-icon {
    width: 56px; height: 56px;
    margin: 0 auto var(--sp-4);
    color: var(--t2);
  }
  .why-icon svg { width: 100%; height: 100% }
  .why-title {
    font-family: var(--fd);
    font-size: 18px;
    font-weight: 800;
    color: var(--t1);
    margin-bottom: var(--sp-2);
  }
  .why-desc {
    font-size: 13px;
    color: var(--t3);
    line-height: 1.6;
  }
  .why-counter {
    font-family: var(--fd);
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--ac);
    margin-top: var(--sp-4);
    line-height: 1;
  }
  .why-counter-label {
    font-size: 11px;
    color: var(--t3);
    margin-top: 4px;
    display: block;
  }

  /* ═══════════ FEATURED ═══════════ */
  .featured {
    padding: var(--sp-12) 0 var(--sp-20);
  }
  .bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
    margin-top: var(--sp-8);
  }

  .tilt-card {
    position: relative;
    transform-style: preserve-3d;
    transition: transform .15s ease-out;
  }
  .tilt-card:hover {
    z-index: 2;
  }

  .card-micro-cta {
    position: absolute;
    bottom: 12px; right: 12px;
    padding: 4px 12px;
    border-radius: 100px;
    background: rgba(212,175,55,.1);
    border: 1px solid rgba(212,175,55,.15);
    color: var(--ac2);
    font-size: 11px;
    font-weight: 600;
    text-decoration: none;
    opacity: 0;
    transform: translateY(6px);
    transition: all .3s var(--ease);
    z-index: 3;
  }
  .tilt-card:hover .card-micro-cta {
    opacity: 1;
    transform: translateY(0);
  }
  .card-micro-cta:hover {
    background: rgba(212,175,55,.2);
    border-color: rgba(212,175,55,.3);
  }

  .featured-foot {
    text-align: center;
    margin-top: var(--sp-8);
  }

  /* ═══════════ SOCIAL PROOF ═══════════ */
  .proof {
    padding: var(--sp-20) 0;
  }
  .proof-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-12);
    margin-top: var(--sp-10);
    align-items: center;
    min-height: 400px;
  }
  .proof-stats {
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
  }
  .proof-stat {
    display: flex;
    align-items: baseline;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .proof-stat-n {
    font-family: var(--fd);
    font-size: 4rem;
    font-weight: 900;
    background: linear-gradient(180deg, var(--ac3), var(--ac));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    display: inline-flex;
    overflow: hidden;
  }
  .slot-digit {
    display: inline-block;
    transition: transform 1.2s cubic-bezier(.22,1,.36,1);
  }
  .proof-stat-inf {
    font-size: 5rem;
  }
  .proof-stat-u {
    font-family: var(--fd);
    font-size: 2rem;
    font-weight: 800;
    color: var(--ac);
  }
  .proof-stat-l {
    width: 100%;
    font-size: 14px;
    color: var(--t3);
    margin-top: 4px;
  }

  /* Phone mockup */
  .phone-mockup {
    width: 320px;
    margin: 0 auto;
    will-change: transform;
    transition: transform .3s var(--ease);
    background: #1a1a2e;
    border-radius: 32px;
    padding: 12px;
    box-shadow:
      0 0 0 2px rgba(255,255,255,.08),
      0 24px 60px rgba(0,0,0,.4),
      0 0 80px rgba(212,175,55,.05);
    position: relative;
  }
  .phone-notch {
    width: 100px;
    height: 24px;
    background: #1a1a2e;
    border-radius: 0 0 16px 16px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  .phone-screen {
    background: #0d0d1a;
    border-radius: 24px;
    padding: var(--sp-5);
    min-height: 400px;
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    overflow: hidden;
  }

  .review-msg {
    max-width: 85%;
    padding: 10px 14px;
    border-radius: 16px;
    font-size: 13px;
    line-height: 1.5;
    opacity: 0;
    transform: translateY(12px) scale(.95);
    transition: opacity .5s var(--ease-spring), transform .5s var(--ease-spring);
  }
  .review-msg.animate-in {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .review-msg--in {
    align-self: flex-start;
    background: rgba(255,255,255,.08);
    color: #e0e0e0;
    border-bottom-left-radius: 4px;
  }
  .review-msg--out {
    align-self: flex-end;
    background: linear-gradient(135deg, rgba(212,175,55,.2), rgba(212,175,55,.1));
    color: var(--ac3);
    border-bottom-right-radius: 4px;
  }
  .review-msg:nth-child(1) { transition-delay: .2s }
  .review-msg:nth-child(2) { transition-delay: .6s }
  .review-msg:nth-child(3) { transition-delay: 1.1s }
  .review-msg:nth-child(4) { transition-delay: 1.6s }
  .review-msg:nth-child(5) { transition-delay: 2.2s }

  /* ═══════════ CTA FINAL ═══════════ */
  .cta-final {
    padding: var(--sp-12) 0 var(--sp-24);
  }
  .cta-card {
    position: relative;
    text-align: center;
    padding: var(--sp-16) var(--sp-10);
    border-radius: 24px;
    border: 1px solid var(--brd);
    background: rgba(212,175,55,.02);
    overflow: hidden;
  }
  .cta-card-glow {
    position: absolute;
    top: -100px; left: 50%;
    transform: translateX(-50%);
    width: 600px; height: 300px;
    background: radial-gradient(ellipse, rgba(212,175,55,.08), transparent 70%);
    pointer-events: none;
  }
  .cta-title {
    font-family: var(--fd);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    color: var(--t1);
    letter-spacing: -.03em;
    margin-bottom: var(--sp-4);
    position: relative;
  }
  .cta-sub {
    font-size: 16px;
    color: var(--t2);
    max-width: 50ch;
    margin: 0 auto var(--sp-8);
    line-height: 1.7;
    position: relative;
  }
  .cta-actions {
    display: flex;
    justify-content: center;
    gap: var(--sp-5);
    align-items: center;
    flex-wrap: wrap;
    position: relative;
  }

  .btn-glow {
    animation: btn-glow-pulse 3s ease-in-out infinite;
  }
  @keyframes btn-glow-pulse {
