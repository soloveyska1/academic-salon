---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const totalDocs = D.length;

const categoryAlias: Record<string, string> = {
  'ВКР и дипломы': 'ВКР',
  'Курсовые работы': 'Курсовые',
  'Курсовые': 'Курсовые',
  'Рефераты': 'Рефераты',
  'Отчёты по практике': 'Практика',
  'Самостоятельные работы': 'Самостоятельные',
  'Методические материалы': 'Методички',
};

const preferredCategories = [
  'ВКР и дипломы',
  'Курсовые работы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
  'Методические материалы',
];

const categoryCount = new Map<string, number>();
for (const doc of D) {
  const key = (doc as any).category || 'Разное';
  categoryCount.set(key, (categoryCount.get(key) || 0) + 1);
}

const uniqueCategories = categoryCount.size;

const currentYear = String(new Date().getFullYear());

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const match = blob.match(/(?:19|20)\d{2}/);
  return match ? match[0] : currentYear;
}

function normalizeDoc(doc: any, index: number) {
  return {
    id: `${doc.file}-${index}`,
    slug: doc.file,
    title: doc.catalogTitle || doc.title || doc.filename || 'Работа по психологии',
    type: doc.docType || doc.category || 'Работа',
    subject: doc.subject || 'Психология',
    year: extractYear(doc),
    group: doc.category || 'Разное',
  };
}

const pickedDocs: any[] = [];
for (const category of preferredCategories) {
  const nextDocs = D.filter((doc: any) => doc.category === category).slice(0, 2);
  pickedDocs.push(...nextDocs);
}
if (pickedDocs.length < 8) {
  for (const doc of D) {
    if (pickedDocs.includes(doc)) continue;
    pickedDocs.push(doc);
    if (pickedDocs.length >= 8) break;
  }
}

const cards = pickedDocs.slice(0, 8).map(normalizeDoc);
const filters = ['Все', ...Array.from(new Set(cards.map((c) => c.group))).slice(0, 5)].map((name) => ({
  key: name,
  label: name === 'Все' ? 'Все' : (categoryAlias[name] || name),
}));

const steps = [
  { num: '01', title: 'Тема', note: 'Фиксируем задачу и срок.' },
  { num: '02', title: 'Черновик', note: 'Сверяем логику и формат.' },
  { num: '03', title: 'Сдача', note: 'Отдаём финальную версию.' },
];

const metrics = [
  { value: totalDocs, suffix: '+', label: 'работ в каталоге' },
  { value: uniqueCategories, suffix: '', label: 'категорий' },
  { value: 0, suffix: '', label: 'ГИПСР', isText: true },
];
---

<Base
  title="Кладовая ГИПСР — психология без паники"
  description="Готовые работы по психологии и деликатный персональный формат, когда нужен текст с нуля."
  currentPath="/"
>

  <!-- ═══════ 1. HERO — «Тихий гром» ═══════ -->
  <section class="hero" id="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <h1 class="hero-title" id="heroTitle" aria-label="Психология без паники перед дедлайном.">
        <span class="word" style="--i:0">Психология</span>
        <span class="word" style="--i:1">без</span>
        <span class="word" style="--i:2">паники</span>
        <br aria-hidden="true" />
        <span class="word word--gold" style="--i:3">перед</span>
        <span class="word word--gold" style="--i:4">дедлайном.</span>
      </h1>
      <p class="hero-sub" id="heroSub">
        Открывай готовые работы или отправляй тему на персональную подготовку.
      </p>
      <div class="hero-actions" id="heroActions">
        <a href="/catalog" class="btn btn--primary">Смотреть работы</a>
        <a href="/order" class="btn btn--ghost">Заказать с нуля</a>
      </div>
    </div>
  </section>

  <!-- ═══════ 2. SOCIAL PROOF — «Тихие цифры» ═══════ -->
  <section class="proof" id="proof">
    <div class="proof-inner">
      {metrics.map((m, i) => (
        <div class="metric" style={`--i:${i}`}>
          {m.isText ? (
            <span class="metric-value" data-text="ГИПСР">ГИПСР</span>
          ) : (
            <span class="metric-value" data-target={m.value} data-suffix={m.suffix}>0{m.suffix}</span>
          )}
          <span class="metric-label">{m.isText ? 'факультет' : m.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════ 3. КАТАЛОГ — «Галерея» ═══════ -->
  <section class="gallery" id="gallery">
    <div class="gallery-inner">
      <header class="gallery-head">
        <h2 class="section-title">Подборка, где всё видно сразу</h2>
        <p class="section-sub">Тип, предмет, год и быстрый переход к файлу.</p>
      </header>

      <div class="gallery-filters" role="tablist" aria-label="Фильтр работ">
        {filters.map((f, idx) => (
          <button
            class:list={['chip', { 'chip--active': idx === 0 }]}
            type="button"
            role="tab"
            aria-selected={idx === 0 ? 'true' : 'false'}
            data-filter={f.key}
          >
            {f.label}
          </button>
        ))}
      </div>

      <div class="bento" id="bento">
        {cards.map((card, idx) => (
          <article
            class:list={['card', { 'card--lead': idx === 0 }]}
            data-group={card.group}
            style={`--i:${idx}`}
          >
            <a href={`/doc/${card.slug}`} class="card-link">
              <span class="card-type">{card.type}</span>
              <h3 class="card-title">{card.title}</h3>
              <span class="card-subject">{card.subject} · {card.year}</span>
            </a>
          </article>
        ))}
      </div>

      <a href="/catalog" class="gallery-more">Открыть полный каталог →</a>
    </div>
  </section>

  <!-- ═══════ 4. ПРОЦЕСС — «Три акта» ═══════ -->
  <section class="process" id="process">
    <div class="process-inner">
      <p class="process-kicker">Персональный формат</p>
      <h2 class="section-title">Нужна работа с нуля?</h2>

      <div class="steps">
        <div class="steps-line" id="stepsLine" aria-hidden="true"></div>
        {steps.map((s) => (
          <div class="step">
            <span class="step-num" aria-hidden="true">{s.num}</span>
            <b class="step-title">{s.title}</b>
            <p class="step-note">{s.note}</p>
          </div>
        ))}
      </div>

      <div class="process-actions">
        <a href="/order" class="btn btn--primary">Отправить тему</a>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="link-text">Telegram</a>
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener" class="link-text">VK</a>
      </div>
    </div>
  </section>

  <!-- ═══════ 5. ЗАКРЫТИЕ — «Тихий выход» ═══════ -->
  <section class="closing" id="closing">
    <div class="closing-glow" aria-hidden="true"></div>
    <div class="closing-inner">
      <h2 class="closing-title">Откройте каталог<br/>или напишите нам.</h2>
      <div class="closing-actions">
        <a href="/catalog" class="btn btn--primary">Каталог</a>
        <a href="/order" class="btn btn--ghost">Заказать работу</a>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-glow {
    position: absolute;
    width: 800px;
    height: 800px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(1);
    background: radial-gradient(circle, rgba(212,175,55,.1) 0%, rgba(212,175,55,.03) 40%, transparent 70%);
    animation: glow-breathe 8s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes glow-breathe {
    0%, 100% { opacity: .6; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.15); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 900px;
    text-align: center;
  }

  .hero-title {
    font: 900 clamp(40px, 8vw, 80px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: -.02em;
    text-wrap: balance;
  }

  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(32px);
    animation: word-in .6s var(--ease-spring) forwards;
    animation-delay: calc(var(--i) * 100ms + 200ms);
  }

  .word--gold { color: var(--ac); }

  @keyframes word-in {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-sub {
    margin-top: 28px;
    font: 400 clamp(16px, 2.5vw, 20px)/1.5 var(--fi);
    color: var(--t2);
    max-width: 52ch;
    margin-inline: auto;
    opacity: 0;
    transform: translateY(16px);
    animation: fade-up .6s var(--ease-spring) .7s forwards;
  }

  .hero-actions {
    margin-top: 40px;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(16px);
    animation: fade-up .6s var(--ease-spring) .9s forwards;
  }

  @keyframes fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══════ BUTTONS ═══════ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 32px;
    border-radius: 999px;
    font: 600 15px/1 var(--fi);
    text-decoration: none;
    color: var(--t1);
    border: 1px solid rgba(212,175,55,.25);
    transition: transform .25s var(--ease-spring), opacity .25s var(--ease);
  }

  .btn--primary {
    background: rgba(212,175,55,.14);
    border-color: rgba(212,175,55,.35);
  }

  .btn--ghost {
    background: transparent;
  }

  .btn:hover {
    transform: translateY(-2px);
  }

  /* ═══════ SOCIAL PROOF ═══════ */
  .proof {
    padding: 80px 24px;
    background: var(--bg2);
    border-top: 1px solid var(--brd);
    border-bottom: 1px solid var(--brd);
  }

  .proof-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    justify-content: center;
    gap: 80px;
    flex-wrap: wrap;
  }

  .metric {
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
  }

  .metric.is-visible {
    animation: fade-up .5s var(--ease-spring) calc(var(--i) * 120ms) forwards;
  }

  .metric-value {
    display: block;
    font: 500 clamp(40px, 7vw, 64px)/1 var(--fm);
    color: var(--ac);
    letter-spacing: -.02em;
  }

  .metric-label {
    display: block;
    margin-top: 8px;
    font: 400 14px/1.3 var(--fi);
    color: var(--t2);
    text-transform: lowercase;
  }

  /* ═══════ GALLERY ═══════ */
  .gallery {
    padding: 140px 24px 120px;
    background: linear-gradient(180deg, var(--bg2) 0%, var(--bg) 100%);
  }

  .gallery-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .section-title {
    font: 800 clamp(28px, 5vw, 48px)/1.05 var(--fd);
    color: var(--t1);
    letter-spacing: -.015em;
    text-wrap: balance;
  }

  .section-sub {
    margin-top: 12px;
    font: 400 16px/1.5 var(--fi);
    color: var(--t2);
  }

  .gallery-filters {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .chip {
    padding: 8px 16px;
    border: none;
    border-radius: 999px;
    background: transparent;
    color: var(--t2);
    font: 500 14px/1 var(--fi);
    cursor: pointer;
    position: relative;
    transition: color .2s var(--ease);
  }

  .chip--active,
  .chip:hover {
    color: var(--t1);
  }

  .chip--active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 16px;
    right: 16px;
    height: 2px;
    background: var(--ac);
    border-radius: 1px;
  }

  .bento {
    margin-top: 32px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .card {
    position: relative;
    border-radius: var(--r);
    background: var(--card);
    transition: transform .3s var(--ease-spring), box-shadow .3s var(--ease);
    opacity: 0;
    transform: translateY(24px);
  }

  .card.is-visible {
    animation: fade-up .5s var(--ease-spring) calc(var(--i) * 80ms) forwards;
  }

  /* After animation finishes, allow hover transforms */
  .card.is-visible.anim-done {
    opacity: 1;
    transform: translateY(0);
    animation: none;
  }

  .card[hidden] { display: none; }

  .card.anim-done:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(212,175,55,.06);
  }

  .card--lead {
    background: rgba(212,175,55,.05);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 24px;
    min-height: 200px;
    text-decoration: none;
    color: inherit;
  }

  .card-type {
    font: 500 11px/1 var(--fm);
    color: var(--ac);
    text-transform: uppercase;
    letter-spacing: .1em;
  }

  .card-title {
    font: 700 clamp(17px, 2.5vw, 21px)/1.3 var(--fd);
    color: var(--t1);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-subject {
    margin-top: auto;
    font: 400 13px/1.3 var(--fi);
    color: var(--t3);
  }

  .gallery-more {
    display: inline-block;
    margin-top: 40px;
    font: 500 15px/1 var(--fi);
    color: var(--ac);
    text-decoration: none;
    transition: opacity .2s;
  }

  .gallery-more:hover { opacity: .7; }

  /* ═══════ PROCESS ═══════ */
  .process {
    padding: 120px 24px;
    background: var(--bg);
  }

  .process-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .process-kicker {
    margin-bottom: 12px;
    font: 500 12px/1 var(--fm);
    color: var(--ac);
    text-transform: uppercase;
    letter-spacing: .15em;
  }

  .steps {
    margin-top: 56px;
    position: relative;
    display: grid;
    gap: 40px;
  }

  .steps-line {
    display: none;
  }

  .step {
    position: relative;
    padding-left: 80px;
  }

  .step-num {
    position: absolute;
    left: 0;
    top: -8px;
    font: 500 64px/1 var(--fm);
    color: var(--ac);
    opacity: .12;
  }

  .step-title {
    display: block;
    font: 700 clamp(20px, 3vw, 28px)/1.2 var(--fd);
    color: var(--t1);
  }

  .step-note {
    margin-top: 6px;
    font: 400 15px/1.5 var(--fi);
    color: var(--t2);
  }

  .process-actions {
    margin-top: 56px;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .link-text {
    font: 500 15px/1 var(--fi);
    color: var(--ac);
    text-decoration: none;
    transition: opacity .2s;
  }

  .link-text:hover { opacity: .7; }

  /* ═══════ CLOSING ═══════ */
  .closing {
    position: relative;
    padding: 160px 24px;
    background: var(--bg);
    text-align: center;
    overflow: hidden;
  }

  .closing-glow {
    position: absolute;
    width: 800px;
    height: 600px;
    bottom: -200px;
    left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, rgba(212,175,55,.08) 0%, transparent 70%);
    pointer-events: none;
    animation: glow-breathe 10s ease-in-out infinite;
  }

  .closing-inner {
    position: relative;
    z-index: 1;
  }

  .closing-title {
    font: 800 clamp(28px, 5vw, 48px)/1.15 var(--fd);
    color: var(--t1);
    text-wrap: balance;
  }

  .closing-actions {
    margin-top: 40px;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ═══════ TABLET ═══════ */
  @media (min-width: 640px) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .card--lead { grid-column: span 2; }
  }

  /* ═══════ DESKTOP ═══════ */
  @media (min-width: 900px) {
    .bento {
      grid-template-columns: repeat(12, 1fr);
      gap: 20px;
    }

    .card { grid-column: span 4; }
    .card--lead { grid-column: span 6; grid-row: span 2; }
    .card:nth-child(5) { grid-column: span 6; }

    .steps {
      grid-template-columns: repeat(3, 1fr);
      gap: 48px;
    }

    .steps-line {
      display: block;
      position: absolute;
      top: 28px;
      left: 80px;
      right: 80px;
      height: 1px;
      background: var(--brd-h);
      transform-origin: left;
      transform: scaleX(0);
    }

    /* Scroll-driven draw if supported */
    @supports (animation-timeline: view()) {
      .steps-line {
        animation: draw-line linear both;
        animation-timeline: view();
        animation-range: entry 20% cover 50%;
      }
    }

    /* IO fallback */
    .steps-line.is-drawn {
      animation: draw-line .8s var(--ease) forwards;
    }

    @keyframes draw-line {
      to { transform: scaleX(1); }
    }
  }

  @media (min-width: 1024px) {
    .proof-inner { gap: 120px; }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .word,
    .hero-sub,
    .hero-actions,
    .metric,
    .card {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }

    .hero-glow,
    .closing-glow {
      animation: none !important;
    }
  }
</style>

<script is:inline>
(() => {
  let cleanups = [];

  function cleanupAll() {
    cleanups.forEach((fn) => { try { fn(); } catch(_) {} });
    cleanups = [];
  }

  /* ── viewport fix ── */
  function fixViewport() {
    const meta = document.querySelector('meta[name="viewport"]');
    if (meta) meta.setAttribute('content', 'width=device-width, initial-scale=1');
  }

  /* ── intersection reveal for metrics + cards ── */
  function initReveal() {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const items = document.querySelectorAll('.metric, .card');

    if (reduced) {
      items.forEach((el) => {
        el.classList.add('is-visible');
        el.classList.add('anim-done');
      });
      return;
    }

    /* Mark cards as anim-done after their animation ends so hover works */
    items.forEach((el) => {
      const handler = () => {
        el.classList.add('anim-done');
        el.removeEventListener('animationend', handler);
      };
      el.addEventListener('animationend', handler);
      cleanups.push(() => el.removeEventListener('animationend', handler));
    });

    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        e.target.classList.add('is-visible');
        obs.unobserve(e.target);
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    items.forEach((el) => obs.observe(el));
    cleanups.push(() => obs.disconnect());
  }

  /* ── count-up for metrics ── */
  function initCountUp() {
    const els = document.querySelectorAll('[data-target]');
    if (!els.length) return;

    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        obs.unobserve(e.target);

        const target = parseInt(e.target.getAttribute('data-target') || '0', 10);
        const suffix = e.target.getAttribute('data-suffix') || '';
        const duration = 1200;
        const start = performance.now();

        function tick(now) {
          const t = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - t, 3);
          const val = Math.round(ease * target);
          e.target.textContent = val + suffix;
          if (t < 1) requestAnimationFrame(tick);
        }

        requestAnimationFrame(tick);
      });
    }, { threshold: 0.3 });

    els.forEach((el) => obs.observe(el));
    cleanups.push(() => obs.disconnect());
  }

  /* ── progress line for steps (IO fallback when scroll-driven not supported) ── */
  function initStepsLine() {
    const line = document.getElementById('stepsLine');
    if (!line) return;
    if (CSS.supports('animation-timeline: view()')) return;

    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        line.classList.add('is-drawn');
        obs.unobserve(e.target);
      });
    }, { threshold: 0.2 });

    obs.observe(line);
    cleanups.push(() => obs.disconnect());
  }

  /* ── filters ── */
  function initFilters() {
    const chips = Array.from(document.querySelectorAll('.chip'));
    const cards = Array.from(document.querySelectorAll('.card'));
    if (!chips.length || !cards.length) return;

    function apply(key) {
      cards.forEach((card) => {
        const group = card.getAttribute('data-group') || '';
        card.hidden = !(key === 'Все' || group === key);
      });
    }

    chips.forEach((chip) => {
      const onClick = () => {
        chips.forEach((c) => {
          c.classList.remove('chip--active');
          c.setAttribute('aria-selected', 'false');
        });
        chip.classList.add('chip--active');
        chip.setAttribute('aria-selected', 'true');
        apply(chip.getAttribute('data-filter') || 'Все');
      };
      chip.addEventListener('click', onClick);
      cleanups.push(() => chip.removeEventListener('click', onClick));
    });

    apply('Все');
  }

  /* ── init ── */
  function initAll() {
    cleanupAll();
    fixViewport();
    initReveal();
    initCountUp();
    initStepsLine();
    initFilters();
  }

  initAll();
  document.addEventListener('astro:page-load', initAll);
  document.addEventListener('astro:after-swap', initAll);
})();
</script>
