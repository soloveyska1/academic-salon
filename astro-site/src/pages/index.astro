---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const totalDocs = D.length;

const preferredCategories = [
  'ВКР и дипломы',
  'Курсовые работы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
];

const categoryAlias = {
  'ВКР и дипломы': 'ВКР',
  'Курсовые работы': 'Курсовые',
  'Курсовые': 'Курсовые',
  'Рефераты': 'Рефераты',
  'Отчёты по практике': 'Практика',
  'Самостоятельные работы': 'Самостоятельные',
  'Методические материалы': 'Методички',
};

const categoryCount = new Map();
for (const doc of D) {
  const key = doc.category || 'Разное';
  categoryCount.set(key, (categoryCount.get(key) || 0) + 1);
}

const topSignals = Array.from(categoryCount.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 4)
  .map(([name, count]) => ({
    name: categoryAlias[name] || name,
    count,
  }));

function extractYear(doc) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const match = blob.match(/(?:19|20)\d{2}/);
  return match ? match[0] : '2026';
}

function normalizeDoc(doc, i) {
  return {
    id: `${doc.file}-${i}`,
    slug: doc.file,
    title: doc.catalogTitle || doc.title || doc.filename || 'Работа по психологии',
    type: doc.docType || doc.category || 'Работа',
    subject: doc.subject || 'Психология',
    year: extractYear(doc),
    group: doc.category || 'Разное',
  };
}

const selectedDocs = [];
for (const group of preferredCategories) {
  const inGroup = D.filter((doc) => doc.category === group).slice(0, 2);
  selectedDocs.push(...inGroup);
}

if (selectedDocs.length < 10) {
  for (const doc of D) {
    if (selectedDocs.includes(doc)) continue;
    selectedDocs.push(doc);
    if (selectedDocs.length >= 10) break;
  }
}

const cards = selectedDocs.slice(0, 10).map(normalizeDoc);

const filterOrder = ['Все', ...Array.from(new Set(cards.map((card) => card.group))).slice(0, 5)];
const filters = filterOrder.map((name) => ({
  key: name,
  label: name === 'Все' ? 'Все' : (categoryAlias[name] || name),
}));

const serviceSteps = [
  { title: 'Тема', note: 'Фиксируем задачу и срок.' },
  { title: 'Работа', note: 'Пишем в нужной логике.' },
  { title: 'Сдача', note: 'Готовим финальную версию.' },
];
---

<Base
  title="Кладовая ГИПСР — работы по психологии"
  description="Кладовая ГИПСР: готовые работы по психологии и деликатная помощь с индивидуальными задачами."
  currentPath="/"
>
  <section class="hero" id="hero">
    <canvas class="hero-canvas" id="heroCanvas" aria-hidden="true"></canvas>
    <div class="hero-layer hero-layer-a" data-parallax-layer aria-hidden="true"></div>
    <div class="hero-layer hero-layer-b" data-parallax-layer aria-hidden="true"></div>

    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="hero-kicker" data-reveal>Кладовая ГИПСР</p>
        <h1 class="hero-title" data-reveal data-delay="80">
          Работы по психологии,
          <span>которые спасают дедлайн.</span>
        </h1>
        <p class="hero-sub" data-reveal data-delay="150">
          Берите готовый материал или отправляйте тему на спокойную индивидуальную подготовку.
        </p>

        <div class="hero-actions" data-reveal data-delay="220">
          <a href="/catalog" class="cta cta-primary">Смотреть работы</a>
          <a href="/order" class="cta cta-ghost">Заказать с нуля</a>
        </div>
      </div>

      <div class="hero-visual" id="heroVisual" data-reveal data-delay="120">
        <div class="hero-orb" id="heroOrb" aria-hidden="true">
          <span class="orb-ring orb-ring-1"></span>
          <span class="orb-ring orb-ring-2"></span>
          <span class="orb-ring orb-ring-3"></span>
          <div class="orb-core">
            <b>{totalDocs}+</b>
            <span>работ</span>
          </div>
        </div>

        <ul class="hero-signals">
          {topSignals.map((signal) => (
            <li>
              <b>{signal.name}</b>
              <span>{signal.count}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="works" id="works">
    <div class="container works-inner">
      <header class="works-head" data-reveal>
        <h2>Подберите формат за минуту.</h2>
        <p>Без лишних слов: тип, предмет и год.</p>
      </header>

      <div class="works-filters" role="tablist" aria-label="Фильтр работ" data-reveal data-delay="50">
        {filters.map((filter, idx) => (
          <button
            class:list={['filter-chip', { 'is-active': idx === 0 }]}
            type="button"
            role="tab"
            aria-selected={idx === 0 ? 'true' : 'false'}
            data-filter={filter.key}
          >
            {filter.label}
          </button>
        ))}
      </div>

      <div class="works-grid" id="worksGrid">
        {cards.map((card, idx) => (
          <article
            class:list={[
              'work-card',
              {
                'work-card-lead': idx === 0,
                'work-card-wide': idx === 3,
              },
            ]}
            data-group={card.group}
            data-tilt-card
            data-reveal
            data-delay={Math.min(idx * 45, 260)}
          >
            <a href={`/doc/${card.slug}`} class="work-link">
              <div class="work-meta-top">
                <span>{card.type}</span>
                <span>{card.year}</span>
              </div>
              <h3>{card.title}</h3>
              <div class="work-meta-bottom">
                <span>{card.subject}</span>
              </div>
            </a>
          </article>
        ))}
      </div>

      <div class="works-foot" data-reveal data-delay="100">
        <a href="/catalog" class="works-link">Открыть полный список →</a>
      </div>
    </div>
  </section>

  <section class="assist" id="assist">
    <div class="container">
      <article class="assist-card" data-reveal>
        <p class="assist-kicker">Если нужен индивидуальный формат</p>
        <h2>Подхватим задачу и доведем до финальной сдачи.</h2>

        <ol class="assist-steps">
          {serviceSteps.map((step, idx) => (
            <li class="assist-step" style={`--step:${idx + 1}`}>
              <b>{step.title}</b>
              <p>{step.note}</p>
            </li>
          ))}
        </ol>

        <div class="assist-actions">
          <a href="/order" class="cta cta-primary">Отправить тему</a>
          <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="cta cta-ghost">Telegram</a>
          <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener" class="cta cta-ghost">VK</a>
        </div>
      </article>
    </div>
  </section>
</Base>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap');

  :global(html.index-motion-ready) [data-reveal] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity .6s cubic-bezier(.2,.7,.2,1), transform .6s cubic-bezier(.2,.7,.2,1);
    transition-delay: var(--delay, 0ms);
  }

  :global(html.index-motion-ready) [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hero,
  .works,
  .assist {
    position: relative;
    z-index: 2;
  }

  .hero {
    min-height: calc(100svh - 8px);
    padding: calc(var(--nav-h) + 30px) 0 56px;
    overflow: clip;
    border-bottom: 1px solid rgba(201,165,90,.14);
    background: linear-gradient(180deg, #0a0a0f 0%, #0d0d14 100%);
  }

  .hero-canvas,
  .hero-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-canvas {
    width: 100%;
    height: 100%;
    z-index: 0;
    opacity: .88;
  }

  .hero-layer {
    z-index: 1;
    will-change: transform;
  }

  .hero-layer-a {
    background: radial-gradient(44% 58% at 18% 20%, rgba(201,165,90,.19), rgba(201,165,90,0));
  }

  .hero-layer-b {
    background: radial-gradient(38% 52% at 78% 72%, rgba(201,165,90,.14), rgba(201,165,90,0));
  }

  .hero-inner {
    position: relative;
    z-index: 3;
    display: grid;
    gap: 26px;
    align-items: center;
  }

  .hero-copy {
    max-width: 620px;
  }

  .hero-kicker {
    margin: 0 0 12px;
    font: 600 11px/1.2 'Inter', sans-serif;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: #c9a55a;
  }

  .hero-title {
    margin: 0;
    font: 700 clamp(34px, 11vw, 56px)/.95 'Space Grotesk', sans-serif;
    color: #f4f0e6;
    text-wrap: balance;
  }

  .hero-title span {
    display: block;
    color: #c9a55a;
  }

  .hero-sub {
    margin: 14px 0 0;
    font: 400 clamp(15px, 4.4vw, 18px)/1.52 'Inter', sans-serif;
    color: #b7b0a2;
    max-width: 58ch;
  }

  .hero-actions,
  .assist-actions {
    margin-top: 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 16px;
    border-radius: 999px;
    border: 1px solid rgba(201,165,90,.34);
    color: #efe8d8;
    text-decoration: none;
    font: 600 14px/1 'Inter', sans-serif;
    letter-spacing: .01em;
    transform: translate3d(0,0,0);
    transition: transform .2s ease;
    will-change: transform;
  }

  .cta:hover {
    border-color: rgba(201,165,90,.72);
  }

  .cta-primary {
    background: rgba(201,165,90,.16);
  }

  .cta-primary:hover {
    background: rgba(201,165,90,.24);
  }

  .cta-ghost {
    background: rgba(201,165,90,.05);
    color: #d8d0bf;
  }

  .hero-visual {
    justify-self: center;
    width: min(100%, 460px);
  }

  .hero-orb {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    transform: perspective(1000px) rotateX(var(--orb-x, 0deg)) rotateY(var(--orb-y, 0deg));
    transform-style: preserve-3d;
    will-change: transform;
  }

  .orb-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(201,165,90,.24);
    animation: spin 16s linear infinite;
  }

  .orb-ring-2 {
    inset: 12%;
    animation-duration: 12s;
    animation-direction: reverse;
  }

  .orb-ring-3 {
    inset: 24%;
    animation-duration: 9s;
  }

  .orb-core {
    position: absolute;
    inset: 34%;
    border-radius: 50%;
    border: 1px solid rgba(201,165,90,.42);
    background: linear-gradient(160deg, rgba(201,165,90,.22), rgba(17,17,24,.9));
    display: grid;
    place-items: center;
    align-content: center;
    color: #f4f0e6;
  }

  .orb-core b {
    display: block;
    font: 700 clamp(36px, 8vw, 56px)/1 'Space Grotesk', sans-serif;
    color: #f3e3bf;
  }

  .orb-core span {
    font: 500 11px/1.2 'Inter', sans-serif;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #c9a55a;
  }

  .hero-signals {
    margin: 14px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }

  .hero-signals li {
    border: 1px solid rgba(201,165,90,.2);
    border-radius: 12px;
    padding: 9px 10px;
    background: rgba(201,165,90,.05);
  }

  .hero-signals b {
    display: block;
    font: 600 12px/1.2 'Inter', sans-serif;
    color: #f1ecdf;
  }

  .hero-signals span {
    display: block;
    margin-top: 3px;
    font: 500 11px/1.1 'Inter', sans-serif;
    color: #c9a55a;
  }

  .works {
    padding: 54px 0 64px;
    background: linear-gradient(180deg, #0d0d14 0%, #0f0f17 100%);
  }

  .works-head h2 {
    margin: 0;
    font: 700 clamp(28px, 8vw, 44px)/1 'Space Grotesk', sans-serif;
    color: #f4f0e6;
    text-wrap: balance;
  }

  .works-head p {
    margin: 10px 0 0;
    font: 400 15px/1.45 'Inter', sans-serif;
    color: #afa797;
  }

  .works-filters {
    margin-top: 18px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .filter-chip {
    border: 1px solid rgba(201,165,90,.25);
    border-radius: 999px;
    background: rgba(201,165,90,.04);
    color: #cec6b5;
    font: 500 13px/1 'Inter', sans-serif;
    min-height: 34px;
    padding: 0 12px;
    cursor: pointer;
    transition: transform .2s ease;
  }

  .filter-chip:hover {
    border-color: rgba(201,165,90,.58);
    transform: translateY(-1px);
  }

  .filter-chip.is-active {
    background: rgba(201,165,90,.18);
    color: #f4f0e6;
    border-color: rgba(201,165,90,.75);
  }

  .works-grid {
    margin-top: 18px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .work-card {
    border: 1px solid rgba(201,165,90,.2);
    border-radius: 14px;
    background: linear-gradient(165deg, rgba(201,165,90,.08), rgba(201,165,90,.02));
    transform: perspective(900px) rotateX(0deg) rotateY(0deg) translateY(0);
    transform-style: preserve-3d;
    transition: transform .22s ease, opacity .24s ease;
    will-change: transform;
  }

  .work-card:hover {
    border-color: rgba(201,165,90,.55);
  }

  .work-card.is-muted {
    opacity: .18;
    transform: scale(.985);
    pointer-events: none;
  }

  .work-link {
    display: grid;
    gap: 12px;
    min-height: 170px;
    padding: 14px;
    color: inherit;
    text-decoration: none;
  }

  .work-meta-top,
  .work-meta-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    font: 500 12px/1.2 'Inter', sans-serif;
    color: #c9a55a;
  }

  .work-link h3 {
    margin: 0;
    font: 600 clamp(16px, 4vw, 20px)/1.24 'Inter', sans-serif;
    color: #f2eee3;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-wrap: balance;
  }

  .works-foot {
    margin-top: 16px;
  }

  .works-link {
    color: #c9a55a;
    text-decoration: none;
    border-bottom: 1px solid rgba(201,165,90,.46);
    padding-bottom: 2px;
    font: 500 14px/1.2 'Inter', sans-serif;
  }

  .works-link:hover {
    color: #f3e3bf;
    border-color: rgba(201,165,90,.8);
  }

  .assist {
    padding: 0 0 70px;
    background: linear-gradient(180deg, #0f0f17 0%, #111118 100%);
  }

  .assist-card {
    border: 1px solid rgba(201,165,90,.22);
    border-radius: 18px;
    padding: 20px;
    background: linear-gradient(160deg, rgba(201,165,90,.11), rgba(18,18,25,.9));
  }

  .assist-kicker {
    margin: 0;
    font: 600 11px/1.2 'Inter', sans-serif;
    letter-spacing: .16em;
    text-transform: uppercase;
    color: #c9a55a;
  }

  .assist-card h2 {
    margin: 12px 0 0;
    font: 700 clamp(28px, 8vw, 44px)/1.02 'Space Grotesk', sans-serif;
    color: #f4f0e6;
    text-wrap: balance;
  }

  .assist-steps {
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 8px;
  }

  .assist-step {
    border: 1px solid rgba(201,165,90,.18);
    border-radius: 12px;
    padding: 10px 12px;
    background: rgba(201,165,90,.05);
  }

  .assist-step b {
    display: block;
    font: 600 14px/1.2 'Inter', sans-serif;
    color: #f2ece0;
  }

  .assist-step p {
    margin: 4px 0 0;
    font: 400 13px/1.4 'Inter', sans-serif;
    color: #b8af9f;
  }

  @media (min-width: 860px) {
    .hero {
      padding-top: calc(var(--nav-h) + 44px);
      padding-bottom: 70px;
    }

    .hero-inner {
      grid-template-columns: minmax(0, 1fr) minmax(360px, .9fr);
      gap: 36px;
    }

    .hero-visual {
      width: min(100%, 520px);
    }

    .works-grid {
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 12px;
    }

    .work-card {
      grid-column: span 4;
    }

    .work-card-lead {
      grid-column: span 6;
      grid-row: span 2;
    }

    .work-card-wide {
      grid-column: span 6;
    }

    .work-link {
      min-height: 185px;
      padding: 16px;
    }

    .assist-card {
      padding: 28px;
    }

    .assist-steps {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .orb-ring,
    .filter-chip,
    .work-card,
    .cta {
      animation: none !important;
      transition: none !important;
      transform: none !important;
    }
  }

  @supports (animation-timeline: view()) {
    .works-head,
    .works-filters,
    .work-card,
    .assist-card {
      animation: reveal linear both;
      animation-timeline: view();
      animation-range: entry 10% cover 28%;
    }
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes reveal {
    from {
      opacity: .38;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script is:inline>
  (() => {
    let cleanups = [];

    function cleanupAll() {
      cleanups.forEach((fn) => {
        try { fn(); } catch (_) { /* noop */ }
      });
      cleanups = [];
    }

    function fixViewportMeta() {
      const meta = document.querySelector('meta[name="viewport"]');
      if (meta) meta.setAttribute('content', 'width=device-width, initial-scale=1');
    }

    function setRevealDelay() {
      const nodes = Array.from(document.querySelectorAll('[data-reveal]'));
      nodes.forEach((node) => {
        const delay = Number(node.getAttribute('data-delay') || 0);
        node.style.setProperty('--delay', `${delay}ms`);
      });
      return nodes;
    }

    function initRevealFallback() {
      const nodes = setRevealDelay();
      if (!nodes.length) return;

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const supportsTimeline = CSS.supports('animation-timeline: view()');

      if (reduced || supportsTimeline) {
        nodes.forEach((node) => node.classList.add('is-visible'));
        return;
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.18, rootMargin: '0px 0px -40px 0px' });

      nodes.forEach((node) => observer.observe(node));
      cleanups.push(() => observer.disconnect());
    }

    function initHeroParallax() {
      const hero = document.getElementById('hero');
      const layers = Array.from(document.querySelectorAll('[data-parallax-layer]'));
      const orb = document.getElementById('heroOrb');
      if (!(hero instanceof HTMLElement) || !(orb instanceof HTMLElement) || !layers.length) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      let tx = 0;
      let ty = 0;
      let cx = 0;
      let cy = 0;
      let scrollTarget = 0;
      let scrollCurrent = 0;
      let rafId = 0;
      let running = true;

      const render = () => {
        if (!running) return;

        cx += (tx - cx) * 0.08;
        cy += (ty - cy) * 0.08;
        scrollCurrent += (scrollTarget - scrollCurrent) * 0.09;

        layers.forEach((layer, idx) => {
          const depth = idx === 0 ? 10 : 16;
          const x = cx * depth;
          const y = cy * depth + scrollCurrent * (idx === 0 ? -0.08 : -0.12);
          layer.style.transform = `translate3d(${x.toFixed(2)}px, ${y.toFixed(2)}px, 0)`;
        });

        orb.style.setProperty('--orb-x', `${(cy * -6).toFixed(2)}deg`);
        orb.style.setProperty('--orb-y', `${(cx * 8).toFixed(2)}deg`);

        rafId = requestAnimationFrame(render);
      };

      const onPointerMove = (event) => {
        const rect = hero.getBoundingClientRect();
        tx = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
        ty = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
      };

      const onPointerLeave = () => {
        tx = 0;
        ty = 0;
      };

      const onScroll = () => {
        const rect = hero.getBoundingClientRect();
        scrollTarget = -rect.top;
      };

      hero.addEventListener('pointermove', onPointerMove, { passive: true });
      hero.addEventListener('pointerleave', onPointerLeave, { passive: true });
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
      rafId = requestAnimationFrame(render);

      cleanups.push(() => {
        running = false;
        if (rafId) cancelAnimationFrame(rafId);
        hero.removeEventListener('pointermove', onPointerMove);
        hero.removeEventListener('pointerleave', onPointerLeave);
        window.removeEventListener('scroll', onScroll);
        layers.forEach((layer) => { layer.style.transform = 'translate3d(0,0,0)'; });
        orb.style.setProperty('--orb-x', '0deg');
        orb.style.setProperty('--orb-y', '0deg');
      });
    }

    function initMagneticButtons() {
      if (window.matchMedia('(pointer: coarse)').matches) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const buttons = Array.from(document.querySelectorAll('.cta'));
      buttons.forEach((button) => {
        let tx = 0;
        let ty = 0;
        let cx = 0;
        let cy = 0;
        let rafId = 0;

        const render = () => {
          cx += (tx - cx) * 0.16;
          cy += (ty - cy) * 0.16;
          button.style.transform = `translate3d(${(cx * 7).toFixed(2)}px, ${(cy * 6).toFixed(2)}px, 0)`;

          if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) {
            rafId = requestAnimationFrame(render);
          } else {
            rafId = 0;
          }
        };

        const onMove = (event) => {
          const rect = button.getBoundingClientRect();
          tx = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
          ty = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
          if (!rafId) rafId = requestAnimationFrame(render);
        };

        const onLeave = () => {
          tx = 0;
          ty = 0;
          if (!rafId) rafId = requestAnimationFrame(render);
        };

        button.addEventListener('pointermove', onMove, { passive: true });
        button.addEventListener('pointerleave', onLeave, { passive: true });

        cleanups.push(() => {
          button.removeEventListener('pointermove', onMove);
          button.removeEventListener('pointerleave', onLeave);
          if (rafId) cancelAnimationFrame(rafId);
          button.style.transform = 'translate3d(0,0,0)';
        });
      });
    }

    function initTiltCards() {
      if (window.matchMedia('(pointer: coarse)').matches) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const cards = Array.from(document.querySelectorAll('[data-tilt-card]'));
      cards.forEach((card) => {
        let tx = 0;
        let ty = 0;
        let cx = 0;
        let cy = 0;
        let rafId = 0;

        const render = () => {
          cx += (tx - cx) * 0.13;
          cy += (ty - cy) * 0.13;
          const rx = (cy * -5).toFixed(2);
          const ry = (cx * 7).toFixed(2);
          card.style.transform = `perspective(900px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-1px)`;

          if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) {
            rafId = requestAnimationFrame(render);
          } else {
            rafId = 0;
          }
        };

        const onMove = (event) => {
          const rect = card.getBoundingClientRect();
          tx = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
          ty = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
          if (!rafId) rafId = requestAnimationFrame(render);
        };

        const onLeave = () => {
          tx = 0;
          ty = 0;
          if (!rafId) rafId = requestAnimationFrame(render);
        };

        card.addEventListener('pointermove', onMove, { passive: true });
        card.addEventListener('pointerleave', onLeave, { passive: true });

        cleanups.push(() => {
          card.removeEventListener('pointermove', onMove);
          card.removeEventListener('pointerleave', onLeave);
          if (rafId) cancelAnimationFrame(rafId);
          card.style.transform = 'perspective(900px) rotateX(0deg) rotateY(0deg) translateY(0)';
        });
      });
    }

    function initFilters() {
      const grid = document.getElementById('worksGrid');
      if (!(grid instanceof HTMLElement)) return;

      const chips = Array.from(document.querySelectorAll('.filter-chip'));
      const cards = Array.from(grid.querySelectorAll('.work-card'));

      const applyFilter = (key) => {
        cards.forEach((card) => {
          const group = card.getAttribute('data-group') || '';
          const isMatch = key === 'Все' || group === key;
          card.classList.toggle('is-muted', !isMatch);
        });
      };

      chips.forEach((chip) => {
        const onClick = () => {
          chips.forEach((node) => {
            node.classList.remove('is-active');
            node.setAttribute('aria-selected', 'false');
          });
          chip.classList.add('is-active');
          chip.setAttribute('aria-selected', 'true');
          applyFilter(chip.getAttribute('data-filter') || 'Все');
        };

        chip.addEventListener('click', onClick);
        cleanups.push(() => chip.removeEventListener('click', onClick));
      });

      applyFilter('Все');
    }

    function initHeroCanvas() {
      const canvas = document.getElementById('heroCanvas');
      if (!(canvas instanceof HTMLCanvasElement)) return;
      const ctx = canvas.getContext('2d', { alpha: true });
      if (!ctx) return;

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const coarse = window.matchMedia('(pointer: coarse)').matches;

      const pointsCount = reduced ? 0 : coarse ? 34 : 54;
      const points = Array.from({ length: pointsCount }, () => ({
        x: Math.random(),
        y: Math.random(),
        vx: (Math.random() - 0.5) * 0.00022,
        vy: (Math.random() - 0.5) * 0.00022,
      }));

      const pointer = { x: .5, y: .5, tx: .5, ty: .5 };
      let width = 0;
      let height = 0;
      let rafId = 0;
      let running = true;

      const resize = () => {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = canvas.clientWidth;
        height = canvas.clientHeight;
        canvas.width = Math.max(1, Math.floor(width * dpr));
        canvas.height = Math.max(1, Math.floor(height * dpr));
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      };

      const onPointerMove = (event) => {
        const rect = canvas.getBoundingClientRect();
        pointer.tx = Math.min(1, Math.max(0, (event.clientX - rect.left) / rect.width));
        pointer.ty = Math.min(1, Math.max(0, (event.clientY - rect.top) / rect.height));
      };

      const onPointerLeave = () => {
        pointer.tx = .5;
        pointer.ty = .5;
      };

      const render = (timeMs) => {
        if (!running) return;

        pointer.x += (pointer.tx - pointer.x) * 0.06;
        pointer.y += (pointer.ty - pointer.y) * 0.06;

        ctx.clearRect(0, 0, width, height);

        const bg = ctx.createLinearGradient(0, 0, 0, height);
        bg.addColorStop(0, 'rgba(10,10,15,0.95)');
        bg.addColorStop(1, 'rgba(17,17,24,0.95)');
        ctx.fillStyle = bg;
        ctx.fillRect(0, 0, width, height);

        const pulse = (Math.sin(timeMs * 0.00045) + 1) * 0.5;

        for (let i = 0; i < 3; i += 1) {
          const yBase = height * (0.26 + i * 0.2);
          ctx.beginPath();
          ctx.lineWidth = 1;
          ctx.strokeStyle = `rgba(201,165,90,${0.08 + i * 0.03})`;

          for (let x = 0; x <= width; x += 12) {
            const nx = x / width;
            const wave = Math.sin(nx * 9 + timeMs * 0.0012 + i * 0.9) * (14 + i * 6 + pulse * 6);
            const py = yBase + wave;
            if (x === 0) ctx.moveTo(x, py);
            else ctx.lineTo(x, py);
          }
          ctx.stroke();
        }

        points.forEach((p) => {
          p.x += p.vx;
          p.y += p.vy;
          if (p.x <= 0 || p.x >= 1) p.vx *= -1;
          if (p.y <= 0 || p.y >= 1) p.vy *= -1;

          const dx = p.x - pointer.x;
          const dy = p.y - pointer.y;
          const dist = Math.hypot(dx, dy) || 1;
          const force = Math.max(0, 0.12 - dist) * 0.0008;
          p.vx += (dx / dist) * force;
          p.vy += (dy / dist) * force;

          p.vx *= 0.997;
          p.vy *= 0.997;

          const px = p.x * width;
          const py = p.y * height;
          ctx.beginPath();
          ctx.fillStyle = 'rgba(201,165,90,0.42)';
          ctx.arc(px, py, 1.2, 0, Math.PI * 2);
          ctx.fill();
        });

        for (let i = 0; i < points.length; i += 1) {
          const a = points[i];
          const ax = a.x * width;
          const ay = a.y * height;

          for (let j = i + 1; j < points.length; j += 1) {
            const b = points[j];
            const bx = b.x * width;
            const by = b.y * height;
            const dist = Math.hypot(ax - bx, ay - by);
            if (dist > 120) continue;

            const alpha = (1 - dist / 120) * 0.08;
            ctx.strokeStyle = `rgba(201,165,90,${alpha})`;
            ctx.beginPath();
            ctx.moveTo(ax, ay);
            ctx.lineTo(bx, by);
            ctx.stroke();
          }
        }

        rafId = requestAnimationFrame(render);
      };

      resize();
      window.addEventListener('resize', resize, { passive: true });

      if (!reduced) {
        canvas.addEventListener('pointermove', onPointerMove, { passive: true });
        canvas.addEventListener('pointerleave', onPointerLeave, { passive: true });
        rafId = requestAnimationFrame(render);
      }

      cleanups.push(() => {
        running = false;
        if (rafId) cancelAnimationFrame(rafId);
        window.removeEventListener('resize', resize);
        canvas.removeEventListener('pointermove', onPointerMove);
        canvas.removeEventListener('pointerleave', onPointerLeave);
      });
    }

    function initAll() {
      cleanupAll();
      fixViewportMeta();
      document.documentElement.classList.add('index-motion-ready');
      initRevealFallback();
      initHeroParallax();
      initHeroCanvas();
      initMagneticButtons();
      initTiltCards();
      initFilters();
    }

    initAll();
    document.addEventListener('astro:page-load', initAll);
    document.addEventListener('astro:after-swap', initAll);
  })();
</script>
