<script is:inline>
(() => {
  let cleanups = [];

  function cleanupAll() {
    cleanups.forEach((fn) => { try { fn(); } catch(_) {} });
    cleanups = [];
  }

  /* ── viewport fix (no longer needed — Base.astro now sets device-width) ── */
  function fixViewport() {}

  /* ── intersection reveal for metrics + cards ── */
  function initReveal() {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const items = document.querySelectorAll('.metric, .card');

    if (reduced) {
      items.forEach((el) => {
        el.classList.add('is-visible');
        el.classList.add('anim-done');
      });
      return;
    }

    /* Mark cards as anim-done after their animation ends so hover works */
    items.forEach((el) => {
      const handler = () => {
        el.classList.add('anim-done');
        el.removeEventListener('animationend', handler);
      };
      el.addEventListener('animationend', handler);
      cleanups.push(() => el.removeEventListener('animationend', handler));
    });

    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        e.target.classList.add('is-visible');
        obs.unobserve(e.target);
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    items.forEach((el) => obs.observe(el));
    cleanups.push(() => obs.disconnect());
  }

  /* ── count-up for metrics ── */
  function initCountUp() {
    const els = document.querySelectorAll('[data-target]');
    if (!els.length) return;

    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        obs.unobserve(e.target);

        const target = parseInt(e.target.getAttribute('data-target') || '0', 10);
        const suffix = e.target.getAttribute('data-suffix') || '';
        const duration = 1200;
        const start = performance.now();

        function tick(now) {
          const t = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - t, 3);
          const val = Math.round(ease * target);
          e.target.textContent = val + suffix;
          if (t < 1) requestAnimationFrame(tick);
        }

        requestAnimationFrame(tick);
      });
    }, { threshold: 0.3 });

    els.forEach((el) => obs.observe(el));
    cleanups.push(() => obs.disconnect());
  }

  /* ── progress line for steps (IO fallback when scroll-driven not supported) ── */
  function initStepsLine() {
    const line = document.getElementById('stepsLine');
    if (!line) return;
    if (CSS.supports('animation-timeline: view()')) return;

    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        line.classList.add('is-drawn');
        obs.unobserve(e.target);
      });
    }, { threshold: 0.2 });

    obs.observe(line);
    cleanups.push(() => obs.disconnect());
  }

  /* ── filters ── */
  function initFilters() {
    const chips = Array.from(document.querySelectorAll('.chip'));
    const cards = Array.from(document.querySelectorAll('.card'));
    if (!chips.length || !cards.length) return;

    function apply(key) {
      cards.forEach((card) => {
        const group = card.getAttribute('data-group') || '';
        card.hidden = !(key === 'Все' || group === key);
        card.style.gridColumn = '';
      });

      /* Fill incomplete last row: stretch last visible card */
      var visible = cards.filter(function(c) { return !c.hidden; });
      var cols = 1;
      if (window.matchMedia('(min-width: 900px)').matches) cols = 3;
      else if (window.matchMedia('(min-width: 640px)').matches) cols = 2;

      if (cols > 1 && visible.length > 0) {
        var remainder = visible.length % cols;
        if (remainder !== 0) {
          var last = visible[visible.length - 1];
          last.style.gridColumn = 'span ' + (cols - remainder + 1);
        }
      }
    }

    chips.forEach((chip) => {
      const onClick = () => {
        chips.forEach((c) => {
          c.classList.remove('chip--active');
          c.setAttribute('aria-selected', 'false');
        });
        chip.classList.add('chip--active');
        chip.setAttribute('aria-selected', 'true');
        apply(chip.getAttribute('data-filter') || 'Все');
      };
      chip.addEventListener('click', onClick);
      cleanups.push(() => chip.removeEventListener('click', onClick));
    });

    apply('Все');
  }

  /* ── hero noise shader ── */
  function initHeroShader() {
    var canvas = document.getElementById('heroCanvas');
    if (!(canvas instanceof HTMLCanvasElement)) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var gl = canvas.getContext('webgl2', { alpha: true, antialias: false, powerPreference: 'low-power' });
    if (!gl) return;

    canvas.classList.add('is-active');

    var vert = '#version 300 es\nin vec2 a;out vec2 v;void main(){v=a*.5+.5;gl_Position=vec4(a,0,1);}';
    var frag = [
      '#version 300 es',
      'precision mediump float;',
      'in vec2 v;out vec4 o;',
      'uniform float u_t;',
      'uniform vec2 u_m;',

      /* simplex helpers */
      'vec3 mod289(vec3 x){return x-floor(x*(1./289.))*289.;}',
      'vec2 mod289(vec2 x){return x-floor(x*(1./289.))*289.;}',
      'vec3 pm(vec3 x){return mod289(((x*34.)+1.)*x);}',

      'float snoise(vec2 v){',
      '  const vec4 C=vec4(.211324865405187,.366025403784439,-.577350269189626,.024390243902439);',
      '  vec2 i=floor(v+dot(v,C.yy));',
      '  vec2 x0=v-i+dot(i,C.xx);',
      '  vec2 i1;i1=(x0.x>x0.y)?vec2(1,0):vec2(0,1);',
      '  vec4 x12=x0.xyxy+C.xxzz;x12.xy-=i1;',
      '  i=mod289(i);',
      '  vec3 p=pm(pm(i.y+vec3(0,i1.y,1.))+i.x+vec3(0,i1.x,1.));',
      '  vec3 m=max(.5-vec3(dot(x0,x0),dot(x12.xy,x12.xy),dot(x12.zw,x12.zw)),0.);',
      '  m=m*m;m=m*m;',
      '  vec3 x=2.*fract(p*C.www)-1.;',
      '  vec3 h=abs(x)-.5;',
      '  vec3 ox=floor(x+.5);',
      '  vec3 a0=x-ox;',
      '  m*=1.79284291400159-.85373472095314*(a0*a0+h*h);',
      '  vec3 g;',
      '  g.x=a0.x*x0.x+h.x*x0.y;',
      '  g.yz=a0.yz*x12.xz+h.yz*x12.yw;',
      '  return 130.*dot(m,g);',
      '}',

      'void main(){',
      '  float t=u_t*.00006;',
      '  vec2 uv=v;',

      /* subtle mouse influence */
      '  uv+=(.5-u_m)*.06;',

      /* multi-octave noise for organic flow */
      '  float n=0.;',
      '  n+=snoise(uv*1.8+vec2(t*.7,t*.5))*.5;',
      '  n+=snoise(uv*3.6-vec2(t*.4,t*.8))*.25;',
      '  n+=snoise(uv*7.0+vec2(t*1.1,-t*.6))*.125;',

      /* gold color palette — concentrated in center */
      '  float mask=1.-smoothstep(.0,.85,length(v-.5));',
      '  mask*=mask;',
      '  float intensity=smoothstep(-.2,.6,n)*mask;',

      /* warm gold tones */
      '  vec3 c1=vec3(.83,.69,.22);',  /* #d4af37 */
      '  vec3 c2=vec3(.93,.79,.29);',  /* brighter gold */
      '  vec3 col=mix(c1,c2,n*.5+.5);',

      '  o=vec4(col,intensity*.18);',
      '}',
    ].join('\n');

    function compile(type, src) {
      var s = gl.createShader(type);
      gl.shaderSource(s, src);
      gl.compileShader(s);
      return s;
    }

    var vs = compile(gl.VERTEX_SHADER, vert);
    var fs = compile(gl.FRAGMENT_SHADER, frag);
    var pg = gl.createProgram();
    gl.attachShader(pg, vs);
    gl.attachShader(pg, fs);
    gl.linkProgram(pg);

    if (!gl.getProgramParameter(pg, gl.LINK_STATUS)) {
      canvas.classList.remove('is-active');
      return;
    }

    gl.useProgram(pg);

    var buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);

    var aLoc = gl.getAttribLocation(pg, 'a');
    gl.enableVertexAttribArray(aLoc);
    gl.vertexAttribPointer(aLoc, 2, gl.FLOAT, false, 0, 0);

    var uT = gl.getUniformLocation(pg, 'u_t');
    var uM = gl.getUniformLocation(pg, 'u_m');

    var mx = 0.5, my = 0.5, tmx = 0.5, tmy = 0.5;
    var running = true;
    var rafId = 0;
    var w = 0, h = 0;

    function resize() {
      var dpr = Math.min(devicePixelRatio || 1, 1.5);
      w = canvas.clientWidth;
      h = canvas.clientHeight;
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      gl.viewport(0, 0, canvas.width, canvas.height);
    }

    function render(t) {
      if (!running) return;
      mx += (tmx - mx) * .04;
      my += (tmy - my) * .04;

      gl.clearColor(0, 0, 0, 0);
      gl.clear(gl.COLOR_BUFFER_BIT);
      gl.enable(gl.BLEND);
      gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);
      gl.uniform1f(uT, t);
      gl.uniform2f(uM, mx, my);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
      rafId = requestAnimationFrame(render);
    }

    var hero = document.getElementById('hero');
    var onMove = function(e) {
      var r = hero.getBoundingClientRect();
      tmx = (e.clientX - r.left) / r.width;
      tmy = (e.clientY - r.top) / r.height;
    };
    var onLeave = function() { tmx = .5; tmy = .5; };

    resize();
    window.addEventListener('resize', resize, { passive: true });
    if (hero) {
      hero.addEventListener('pointermove', onMove, { passive: true });
      hero.addEventListener('pointerleave', onLeave, { passive: true });
    }
    rafId = requestAnimationFrame(render);

    cleanups.push(function() {
      running = false;
      if (rafId) cancelAnimationFrame(rafId);
      window.removeEventListener('resize', resize);
      if (hero) {
        hero.removeEventListener('pointermove', onMove);
        hero.removeEventListener('pointerleave', onLeave);
      }
      canvas.classList.remove('is-active');
    });
  }

  /* ── carousel drag + lightbox ── */
  function initCarousel() {
    var carousel = document.getElementById('carousel');
    var track = document.getElementById('carouselTrack');
    if (!carousel || !track) return;

    var isDragging = false;
    var startX = 0;
    var scrollStart = 0;
    var didDrag = false;

    function getTranslateX() {
      var style = getComputedStyle(track);
      var matrix = new DOMMatrix(style.transform);
      return matrix.m41;
    }

    function onPointerDown(e) {
      isDragging = true;
      didDrag = false;
      startX = e.clientX || (e.touches && e.touches[0].clientX) || 0;
      scrollStart = getTranslateX();
      track.classList.add('is-dragging');
      carousel.classList.add('is-dragging');
      track.style.animation = 'none';
      track.style.transform = 'translateX(' + scrollStart + 'px)';
    }

    function onPointerMove(e) {
      if (!isDragging) return;
      var x = e.clientX || (e.touches && e.touches[0].clientX) || 0;
      var diff = x - startX;
      if (Math.abs(diff) > 5) didDrag = true;
      var half = track.scrollWidth / 2;
      var newX = scrollStart + diff;
      /* Wrap around */
      if (newX > 0) newX -= half;
      if (newX < -half) newX += half;
      track.style.transform = 'translateX(' + newX + 'px)';
    }

    function onPointerUp() {
      if (!isDragging) return;
      isDragging = false;
      track.classList.remove('is-dragging');
      carousel.classList.remove('is-dragging');
      /* Resume auto-scroll from current position */
      var currentX = getTranslateX();
      var half = track.scrollWidth / 2;
      /* Normalize to 0..-half range for animation offset */
      var pct = ((currentX % half) + half) % half;
      var offsetPct = (pct / half) * 100;
      track.style.transform = '';
      track.style.animation = '';
      track.style.animationDelay = '-' + (60 * (1 - offsetPct / 100)) + 's';
    }

    carousel.addEventListener('pointerdown', onPointerDown);
    window.addEventListener('pointermove', onPointerMove);
    window.addEventListener('pointerup', onPointerUp);
    carousel.addEventListener('touchstart', function(e) { onPointerDown(e.touches[0]); }, { passive: true });
    window.addEventListener('touchmove', function(e) { if (isDragging) onPointerMove(e.touches[0]); }, { passive: true });
    window.addEventListener('touchend', onPointerUp);

    cleanups.push(function() {
      carousel.removeEventListener('pointerdown', onPointerDown);
      window.removeEventListener('pointermove', onPointerMove);
      window.removeEventListener('pointerup', onPointerUp);
    });

    /* Lightbox */
    var lightbox = document.getElementById('lightbox');
    var lightboxImg = document.getElementById('lightboxImg');
    var lightboxClose = document.getElementById('lightboxClose');
    if (!lightbox || !lightboxImg) return;

    carousel.addEventListener('click', function(e) {
      if (didDrag) return;
      var img = e.target.closest('.review-img');
      if (!img) return;
      lightboxImg.src = img.src;
      lightbox.classList.add('is-open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    });

    function closeLightbox() {
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    lightboxClose && lightboxClose.addEventListener('click', closeLightbox);
    lightbox.addEventListener('click', function(e) {
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && lightbox.classList.contains('is-open')) closeLightbox();
    });

    cleanups.push(closeLightbox);
  }

  /* ── floating CTA ── */
  function initFloatCta() {
    var cta = document.getElementById('floatCta');
    var hero = document.getElementById('hero');
    if (!cta || !hero) return;

    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          cta.classList.remove('is-visible');
        } else {
          cta.classList.add('is-visible');
        }
      });
    }, { threshold: 0.1 });

    obs.observe(hero);
    cleanups.push(function() { obs.disconnect(); });
  }

  /* ── init ── */
  function initAll() {
    cleanupAll();
    fixViewport();
    initHeroShader();
    initReveal();
    initCountUp();
    initStepsLine();
    initFilters();
    initCarousel();
    initFloatCta();
  }

  initAll();
  document.addEventListener('astro:page-load', initAll);
  document.addEventListener('astro:after-swap', initAll);
})();
</script>
