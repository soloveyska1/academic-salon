  .guarantee p {
    font-family: var(--fd);
    font-size: 15px;
    line-height: 1.55;
    color: var(--mute);
    letter-spacing: 0.005em;
    margin: 0;
    margin-top: auto;
  }

  /* ================================================================
     Q&A — editorial dictionary-style FAQ (step 2.10)
     Ported 1-to-1 from bundle css/06-*. No legacy .qa-* collisions.
     ================================================================ */
  .qa {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px);
    background: var(--ink);
    position: relative;
  }
  .qa-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
  }

  .qa-list {
    max-width: 980px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }
  .qa-item {
    padding: 28px 0;
    border-bottom: 1px solid var(--line);
    cursor: pointer;
    position: relative;
  }
  .qa-item summary {
    list-style: none;
    display: grid;
    grid-template-columns: 60px 1fr auto;
    gap: 28px;
    align-items: baseline;
    cursor: pointer;
  }
  .qa-item summary::-webkit-details-marker { display: none; }

  .qa-no {
    font-family: var(--fd);
    font-style: italic;
    font-size: 18px;
    color: var(--gold);
    line-height: 1;
    font-feature-settings: "tnum";
    letter-spacing: 0;
  }
  .qa-q {
    font-family: var(--fd);
    font-size: clamp(20px, 2vw, 28px);
    color: var(--cream);
    line-height: 1.25;
    letter-spacing: -0.015em;
    font-weight: 400;
    transition: color .5s var(--ease-silk);
  }
  .qa-item:hover .qa-q { color: var(--gold); }

  .qa-chev {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
