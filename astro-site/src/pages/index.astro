---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const totalDocs = D.length;
const currentYear = String(new Date().getFullYear());

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const match = blob.match(/(?:19|20)\d{2}/);
  return match ? match[0] : currentYear;
}

function normalizeDoc(doc: any, index: number) {
  return {
    id: `${doc.file}-${index}`,
    slug: doc.file,
    title: doc.catalogTitle || doc.title || doc.filename || 'Студенческая работа',
    type: doc.docType || doc.category || 'Работа',
    subject: doc.subject || 'Психология',
    year: extractYear(doc),
  };
}

const preferredCategories = [
  'ВКР и дипломы',
  'Курсовые работы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
  'Методические материалы',
];

const pickedDocs: any[] = [];
for (const category of preferredCategories) {
  const nextDocs = D.filter((doc: any) => doc.category === category).slice(0, 1);
  pickedDocs.push(...nextDocs);
}
if (pickedDocs.length < 6) {
  for (const doc of D) {
    if (pickedDocs.includes(doc)) continue;
    pickedDocs.push(doc);
    if (pickedDocs.length >= 6) break;
  }
}

const cards = pickedDocs.slice(0, 6).map(normalizeDoc);

const reviewAlts = [
  'Отзыв: Спасибо за работу',
  'Отзыв: У меня 5, работа очень хорошая',
  'Отзыв: Четвёрка твёрдая, отлично всё',
  'Отзыв: Автомат, 5 -- спасибо огромное',
  'Отзыв: Сдали с первого раза',
  'Отзыв: Сдала на 4, сказали хорошая работа',
  'Отзыв: Кайф, благодарю за быструю работу',
  'Отзыв: Всё отлично, спасибо',
  'Отзыв: Преподаватель поставил отлично',
  'Отзыв: Работа принята без замечаний',
];
---

<Base
  title="Библиотека академического салона -- студенческие работы без паники"
  description="Библиотека готовых студенческих работ: психология, социальная работа, конфликтология и другие гуманитарные дисциплины. Или закажите индивидуальную подготовку."
  currentPath="/"
>

  <!-- ============================================================
       1. HERO -- Confident, atmospheric
       ============================================================ -->
  <section class="hero" id="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <h1 class="hero-title" aria-label="Без паники перед дедлайном.">
        <span class="word" style="--i:0">Без</span>
        <span class="word" style="--i:1">паники</span>
        <br aria-hidden="true" />
        <span class="word" style="--i:2">перед</span>
        <span class="word" style="--i:3">дедлайном.</span>
      </h1>
      <div class="hero-rule" aria-hidden="true"></div>
      <p class="hero-sub">{totalDocs}+ работ бесплатно &middot; или напишем под ваши требования</p>
      <form class="hero-search" action="/catalog" method="get">
        <svg class="hero-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input class="hero-search-input" type="search" name="q" placeholder="Найти работу..." autocomplete="off" enterkeyhint="search" id="heroSearchInput" />
      </form>
      <div class="hero-actions">
        <a href="/catalog" class="btn btn--primary">Смотреть каталог</a>
        <a href="/order" class="btn btn--ghost">Заказать работу</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. REVIEWS -- Carousel, one at a time, natural sizes
       ============================================================ -->
  <section class="reviews rv">
    <div class="reviews-head">
      <h2 class="section-title">Что говорят студенты</h2>
      <p class="reviews-sub">Реальные переписки — не выдуманные цитаты</p>
    </div>
    <div class="reviews-carousel">
      <div class="reviews-track">
        {Array.from({ length: 10 }, (_, i) => (
          <div class="review-slide">
            <img
              src={`/reviews/${i + 1}.webp`}
              alt={reviewAlts[i]}
              class="review-img"
              loading={i < 2 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       3. CATALOG -- Bento grid
       ============================================================ -->
  <section class="catalog rv">
    <div class="catalog-inner">
      <div class="catalog-head">
        <h2 class="section-title">Каталог</h2>
        <a href="/catalog" class="section-link">Все работы &rarr;</a>
      </div>
      <div class="catalog-grid">
        {cards.map((card) => (
          <a href={`/doc/${card.slug}`} class="card">
            <span class="card-type">{card.type}</span>
            <h3 class="card-title">{card.title}</h3>
            <span class="card-meta">{card.subject} &middot; {card.year}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. ORDER -- Conversion
       ============================================================ -->
  <section class="order rv">
    <div class="order-inner">
      <h2 class="order-title">Напишем под ваши<br/>требования.</h2>
      <div class="order-prices">
        <div class="price-item">
          <span class="price-label">Реферат</span>
          <span class="price-amount">от 3 000 &#8381;</span>
        </div>
        <span class="price-divider"></span>
        <div class="price-item">
          <span class="price-label">Курсовая</span>
          <span class="price-amount">от 5 000 &#8381;</span>
        </div>
        <span class="price-divider"></span>
        <div class="price-item">
          <span class="price-label">Дипломная</span>
          <span class="price-amount">от 30 000 &#8381;</span>
        </div>
      </div>
      <a href="/order" class="order-btn btn btn--primary">Заказать работу</a>
      <div class="order-contacts">
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
        <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       5. FOOTER -- Minimal signature
       ============================================================ -->
  <footer class="foot">
    <span class="foot-copy">&copy; 2022&ndash;2026 Библиотека академического салона</span>
  </footer>

</Base>

<style>
  /* ================================================================
     HOMEPAGE -- Editorial Luxury
     Monocle meets Linear. Gold on obsidian. Every section breathes.
     ================================================================ */

  /* Hide the global footer on this page */
  :global(.footer) { display: none; }

  /* ----------------------------------------------------------------
     SHARED
     ---------------------------------------------------------------- */
  @keyframes fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes word-in {
    to { opacity: 1; transform: translateY(0); }
  }

  .section-title {
    font: 300 clamp(36px, 6vw, 56px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
  }

  .rv {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .6s var(--ease), transform .6s var(--ease);
  }

  .rv.vis {
    opacity: 1;
    transform: translateY(0);
  }

  /* ----------------------------------------------------------------
     BUTTONS
     ---------------------------------------------------------------- */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 16px 40px;
    border-radius: 0;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    text-decoration: none;
    color: var(--t1);
    border: 1px solid var(--ac-b);
    cursor: pointer;
    transition:
      transform .3s var(--ease),
      border-color .3s var(--ease),
      box-shadow .3s var(--ease);
  }

  .btn--primary {
    background: var(--surf);
    border-color: var(--ac-b);
  }

  .btn--ghost {
    background: transparent;
    border-color: var(--ac-line);
    color: var(--t2);
  }

  .btn:hover {
    transform: translateY(-2px);
    border-color: var(--ac-b3);
    box-shadow: 0 12px 40px var(--ac-sh);
  }

  .btn--primary:hover {
    box-shadow: 0 12px 40px var(--ac-g);
  }

  .btn--ghost:hover {
    color: var(--t1);
    border-color: var(--ac-b2);
  }

  /* ----------------------------------------------------------------
     1. HERO -- dramatic multi-layer glow, 100svh
     ---------------------------------------------------------------- */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-glow {
    position: absolute;
    width: min(1100px, 95vw);
    height: min(900px, 85vw);
    top: 45%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45% at 50% 48%, rgba(212,175,55,.22) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 48% 44%, rgba(212,175,55,.14) 0%, transparent 50%),
      radial-gradient(ellipse 75% 55% at 42% 52%, rgba(180,130,20,.08) 0%, transparent 75%);
    pointer-events: none;
    z-index: 0;
    animation: glow-breathe 10s ease-in-out infinite;
  }

  @keyframes glow-breathe {
    0%, 100% { opacity: .65; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.06); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 960px;
    text-align: center;
    padding: 0 8px;
  }

  .hero-title {
    font: 300 clamp(48px, 10vw, 100px)/.88 var(--fd);
    color: var(--t1);
    letter-spacing: -.02em;
    text-wrap: balance;
    text-shadow: 0 0 120px rgba(212,175,55,.06), 0 4px 24px rgba(0,0,0,.3);
  }

  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(12px);
    animation: word-in .4s ease-out forwards;
    animation-delay: calc(var(--i) * 200ms + 300ms);
  }

  .hero-rule {
    width: 48px;
    height: 1px;
    margin: 28px auto 0;
    background: linear-gradient(90deg, transparent, var(--ac), transparent);
    opacity: .35;
  }

  .hero-sub {
    margin-top: 24px;
    font: 400 15px/1.6 var(--fi);
    color: var(--t2);
    max-width: 52ch;
    margin-inline: auto;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.2s forwards;
  }

  .hero-search {
    position: relative;
    max-width: 480px;
    margin: 36px auto 0;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.4s forwards;
  }

  .hero-search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--t3);
    pointer-events: none;
  }

  .hero-search-input {
    width: 100%;
    padding: 14px 20px 14px 42px;
    border: 1px solid var(--brd);
    border-radius: 999px;
    background: rgba(255,255,255,.04);
    color: var(--t1);
    font: 400 16px/1.4 var(--fi);
    outline: none;
    transition: border-color .3s, box-shadow .3s, background .3s;
  }

  .hero-search-input::placeholder { color: var(--t3); }

  .hero-search-input:focus {
    border-color: var(--ac-b);
    box-shadow: 0 0 0 3px rgba(212,175,55,.1);
    background: rgba(255,255,255,.06);
  }

  .hero-actions {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.6s forwards;
  }

  /* ----------------------------------------------------------------
     2. REVIEWS -- horizontal scroll gallery (the showstopper)
     ---------------------------------------------------------------- */
  .reviews {
    padding: 120px 0;
    background: var(--bg);
  }

  .reviews-head {
    text-align: center;
    padding: 0 24px;
    margin-bottom: 48px;
  }

  .reviews-sub {
    font: 400 14px/1.6 var(--fi);
    color: var(--t3);
    margin-top: 12px;
  }

  /* Carousel — horizontal scroll, one image centered, neighbors peek */
  .reviews-carousel {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
    scroll-padding: 0 calc(50% - 160px);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }

  .reviews-carousel::-webkit-scrollbar { display: none; }

  .reviews-track {
    display: flex;
    gap: 20px;
    padding: 0 calc(50vw - 170px);
  }

  .review-slide {
    flex: 0 0 320px;
    scroll-snap-align: center;
  }

  .review-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,.08);
    box-shadow: 0 8px 32px rgba(0,0,0,.25);
    transition: transform .3s var(--ease), box-shadow .3s var(--ease), border-color .3s;
  }

  .review-img:hover {
    transform: scale(1.02);
    box-shadow: 0 16px 48px rgba(0,0,0,.4);
    border-color: rgba(212,175,55,.12);
  }

  /* ----------------------------------------------------------------
     3. CATALOG -- Bento grid, glass cards
     ---------------------------------------------------------------- */
  .catalog {
    padding: 120px 24px;
    background: var(--bg);
  }

  .catalog-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .catalog-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 56px;
  }

  .section-link {
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    transition: color .3s var(--ease);
  }

  .section-link:hover { color: var(--ac); }

  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  /* Glass card */
  .card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px;
    background: rgba(255,255,255,.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,.06);
    border-radius: var(--rs);
    text-decoration: none;
    color: var(--t1);
    position: relative;
    overflow: hidden;
    transition:
      border-color .3s var(--ease),
      transform .3s var(--ease),
      box-shadow .3s var(--ease);
  }

  /* Gold shimmer top-line on hover */
  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 20%, var(--ac) 50%, transparent 80%);
    opacity: 0;
    transition: opacity .3s;
  }

  .card:hover {
    border-color: rgba(212,175,55,.15);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,.3), 0 0 0 1px rgba(212,175,55,.08);
  }

  .card:hover::before {
    opacity: .4;
  }

  .card-type {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
  }

  .card-title {
    font: 400 18px/1.35 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card:hover .card-title {
    color: var(--ac2, var(--ac));
  }

  .card-meta {
    font: 400 13px/1 var(--fi);
    color: var(--t3);
    margin-top: auto;
  }

  /* ----------------------------------------------------------------
     4. ORDER -- bold conversion section
     ---------------------------------------------------------------- */
  .order {
    padding: 120px 24px;
    background: var(--bg);
  }

  .order-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    text-align: center;
  }

  .order-title {
    font: 300 clamp(32px, 5vw, 48px)/1.1 var(--fd);
    color: var(--t1);
    margin-bottom: 64px;
  }

  .order-prices {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 48px;
    margin-bottom: 56px;
  }

  .price-item {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
  }

  .price-label {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
  }

  .price-amount {
    font: 400 28px/1 var(--fm);
    color: var(--ac);
    letter-spacing: -.01em;
  }

  .price-divider {
    width: 1px;
    height: 48px;
    background: var(--ac);
    opacity: .2;
    flex-shrink: 0;
  }

  .order-btn {
    margin-bottom: 40px;
  }

  .order-contacts {
    display: flex;
    justify-content: center;
    gap: 24px;
  }

  .order-contacts a {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    transition: color .3s var(--ease);
  }

  .order-contacts a:hover { color: var(--ac); }

  /* ----------------------------------------------------------------
     5. FOOTER -- minimal signature
     ---------------------------------------------------------------- */
  .foot {
    padding: 64px 24px;
    background: var(--bg);
    text-align: center;
  }

  .foot-copy {
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    letter-spacing: .04em;
  }

  /* ----------------------------------------------------------------
     LIGHT THEME OVERRIDES
     ---------------------------------------------------------------- */
  :global([data-theme="light"]) .hero-glow {
    background:
      radial-gradient(ellipse 55% 45% at 50% 48%, rgba(180,145,30,.12) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 48% 44%, rgba(180,145,30,.08) 0%, transparent 50%),
      radial-gradient(ellipse 75% 55% at 42% 52%, rgba(160,120,15,.05) 0%, transparent 75%);
  }

  :global([data-theme="light"]) .hero-search-input {
    background: rgba(0,0,0,.03);
    border-color: rgba(0,0,0,.1);
  }

  :global([data-theme="light"]) .hero-search-input:focus {
    border-color: var(--ac-b);
    background: rgba(0,0,0,.04);
  }

  :global([data-theme="light"]) .card {
    background: #fff;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-color: var(--brd);
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }

  :global([data-theme="light"]) .card:hover {
    box-shadow: 0 12px 40px rgba(0,0,0,.1), 0 0 0 1px rgba(212,175,55,.12);
  }

  :global([data-theme="light"]) .review-img {
    border-color: rgba(0,0,0,.1);
    box-shadow: 0 4px 20px rgba(0,0,0,.08);
  }

  :global([data-theme="light"]) .review-img:hover {
    box-shadow: 0 12px 40px rgba(0,0,0,.12);
  }

  :global([data-theme="light"]) .price-divider {
    background: var(--ac);
    opacity: .3;
  }

  /* ----------------------------------------------------------------
     REDUCED MOTION
     ---------------------------------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    .word,
    .hero-sub,
    .hero-search,
    .hero-actions {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .hero-glow {
      animation: none;
      opacity: .8;
      transform: translate(-50%, -50%);
    }

    .rv {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ----------------------------------------------------------------
     TABLET (max 900px)
     ---------------------------------------------------------------- */
  @media (max-width: 900px) {
    .catalog-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .order-prices {
      gap: 32px;
    }

    .price-amount {
      font-size: 24px;
    }

  }

  /* ----------------------------------------------------------------
     MOBILE (max 639px)
     ---------------------------------------------------------------- */
  @media (max-width: 639px) {
    .reviews,
    .catalog,
    .order {
      padding: 64px 20px;
    }

    .catalog-grid {
      grid-template-columns: 1fr;
    }

    /* Carousel: wider slides on mobile */
    .review-slide {
      flex: 0 0 85vw;
    }

    .reviews-track {
      padding: 0 calc(50vw - 42.5vw);
      gap: 12px;
    }

    .order-prices {
      flex-direction: column;
      align-items: center;
      gap: 28px;
    }

    .price-divider {
      width: 48px;
      height: 1px;
    }

    .price-amount {
      font-size: 24px;
    }

    .order-btn {
      width: 100%;
      text-align: center;
    }

    .order-contacts {
      flex-wrap: wrap;
      gap: 16px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .hero-actions .btn {
      width: 100%;
      max-width: 320px;
    }

    .foot {
      padding: 48px 20px;
    }

    .reviews-head {
      margin-bottom: 32px;
    }
  }
</style>

<script>
  import { bootHomePageRuntime } from '../scripts/home-page-runtime';
  bootHomePageRuntime();
</script>
