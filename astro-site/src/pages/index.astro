---
import Base from '../layouts/Base.astro';
import DocumentCard from '../components/DocumentCard.astro';
import { D } from '../data/catalog.js';

const categories = ['ВКР и дипломы', 'Курсовые работы', 'Рефераты', 'Отчёты по практике', 'Контрольные работы', 'Методические материалы'];
const featured: typeof D = [];
for (const cat of categories) {
  const doc = D.find(d => d.category === cat && !featured.includes(d));
  if (doc) featured.push(doc);
}
while (featured.length < 6) {
  const doc = D.find(d => !featured.includes(d));
  if (doc) featured.push(doc);
  else break;
}

const docCount = D.length;
---

<Base title="Академический Салон — Библиотека студенческих работ" currentPath="/">

  <!-- ═══════════ HERO ═══════════ -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>

    <div class="container hero-inner">
      <p class="hero-eyebrow reveal">
        <span class="hero-dot"></span>
        Библиотека студенческих работ
      </p>

      <h1 class="hero-h1 reveal">
        Академический<br/>
        <span class="hero-accent gold-shimmer">Салон</span>
      </h1>

      <p class="hero-sub reveal">
        {docCount} бесплатных работ по психологии и социальной работе.<br class="hide-m"/>
        Скачивай готовые или закажи индивидуально.
      </p>

      <div class="hero-actions reveal">
        <a href="/catalog" class="btn btn-primary hero-primary">Открыть каталог</a>
        <a href="/order" class="btn btn-ghost">Заказать работу &rarr;</a>
      </div>

      <div class="hero-search reveal">
        <svg class="hero-search-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" class="hero-search-input" id="heroSearch" placeholder="Найти по теме, предмету или ключевому слову..." />
      </div>

      <div class="hero-hints reveal">
        <a href="/catalog?q=психология" class="hint">психология</a>
        <a href="/catalog?q=курсовая" class="hint">курсовая</a>
        <a href="/catalog?q=диплом" class="hint">диплом</a>
        <a href="/catalog?q=практика" class="hint">практика</a>
      </div>
    </div>
  </section>

  <!-- ═══════════ FEATURED ═══════════ -->
  <section class="featured">
    <div class="container">
      <p class="featured-label reveal section-label">Из каталога</p>
      <div class="bento reveal">
        {featured.map((doc, i) => (
          <DocumentCard doc={doc} index={i} />
        ))}
      </div>
      <div class="featured-foot reveal">
        <a href="/catalog" class="btn btn-secondary">
          Смотреть все {docCount} документов
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════ CTA ═══════════ -->
  <section class="cta">
    <div class="container">
      <div class="cta-card reveal">
        <div class="cta-content">
          <h2 class="cta-title">Не нашли нужную работу?</h2>
          <p class="cta-desc">
            Выполним индивидуально под ваши требования —
            курсовые, дипломные, ВКР, рефераты, контрольные.
            Гарантия сдачи, бесплатные правки, оплата 50/50.
          </p>
          <div class="cta-actions">
            <a href="/order" class="btn btn-primary">Узнать стоимость &rarr;</a>
            <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost">Написать в ВК &rarr;</a>
          </div>
        </div>
        <div class="cta-stats">
          <div class="cta-stat">
            <span class="cta-stat-n">93<span class="cta-stat-u">%</span></span>
            <span class="cta-stat-l">сдают с первого раза</span>
          </div>
          <div class="cta-stat">
            <span class="cta-stat-n">&infin;</span>
            <span class="cta-stat-l">бесплатных правок</span>
          </div>
          <div class="cta-stat">
            <span class="cta-stat-n">50/50</span>
            <span class="cta-stat-l">оплата по частям</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ═══════════════════════════════════════
     HERO — full viewport, cinematic, focused
     ═══════════════════════════════════════ */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px 0 48px;
    text-align: center;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 50% 40% at 50% 30%, rgba(212,175,55,.07) 0%, transparent 70%);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 680px;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--ac);
    opacity: .7;
    margin-bottom: var(--sp-8);
  }

  .hero-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--ac);
    box-shadow: 0 0 8px rgba(212,175,55,.5);
    animation: pulse 2.5s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: .5; transform: scale(1) }
    50% { opacity: 1; transform: scale(1.5) }
  }

  .hero-h1 {
    font-family: var(--fd);
    font-size: clamp(3.2rem, 9vw, 6.5rem);
    font-weight: 900;
    letter-spacing: -.04em;
    line-height: .95;
    color: var(--t1);
    margin-bottom: var(--sp-6);
  }
  .hero-accent { font-style: italic; letter-spacing: .01em }

  .hero-sub {
    font-size: 17px;
    color: var(--t2);
    line-height: 1.7;
    max-width: 480px;
    margin-bottom: var(--sp-10);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
    margin-bottom: var(--sp-8);
  }
  .hero-primary {
    padding: 16px 36px;
    font-size: 15px;
    border-radius: 14px;
  }

  /* Search */
  .hero-search {
    position: relative;
    width: 100%;
    max-width: 560px;
  }
  .hero-search-ico {
    position: absolute;
    left: 20px; top: 50%;
    transform: translateY(-50%);
    width: 18px; height: 18px;
    color: var(--t3);
    pointer-events: none;
  }
  .hero-search-input {
    width: 100%;
    height: 56px;
    padding: 0 24px 0 52px;
    background: rgba(255,255,255,.03);
    border: 1px solid var(--brd);
    border-radius: var(--rm);
    color: var(--t1);
    font-size: 15px;
    font-family: inherit;
    outline: 0;
    transition: all .35s var(--ease);
  }
  .hero-search-input::placeholder { color: var(--t3) }
  .hero-search-input:focus {
    border-color: rgba(212,175,55,.2);
    box-shadow: 0 0 0 4px rgba(212,175,55,.04), 0 12px 40px rgba(0,0,0,.15);
    background: rgba(255,255,255,.05);
  }

  .hero-hints {
    display: flex;
    gap: var(--sp-2);
    margin-top: var(--sp-3);
    flex-wrap: wrap;
    justify-content: center;
  }
  .hint {
    padding: 4px 14px;
    border-radius: 100px;
    background: transparent;
    border: 1px solid var(--brd);
    color: var(--t3);
    font-size: 12px;
    font-weight: 500;
    text-decoration: none;
    transition: all var(--dur-fast) var(--ease);
  }
  .hint:hover {
    border-color: rgba(212,175,55,.15);
    color: var(--t2);
    background: var(--ac-g2);
  }

  .hide-m { display: inline }

  /* ═══════════════════════════════════════
     FEATURED — bento grid, product speaks
     ═══════════════════════════════════════ */
  .featured {
    padding: var(--sp-16) 0 var(--sp-24);
  }

  .featured-label { margin-bottom: var(--sp-8) }

  .bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: auto;
    gap: var(--sp-4);
  }
  .bento > :first-child {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }

  .featured-foot {
    text-align: center;
    margin-top: var(--sp-10);
  }

  /* ═══════════════════════════════════════
     CTA — one card, clear message
     ═══════════════════════════════════════ */
  .cta {
    padding: 0 0 var(--sp-24);
  }

  .cta-card {
    display: grid;
    grid-template-columns: 1.3fr .7fr;
    gap: var(--sp-12);
    align-items: center;
    padding: var(--sp-16) var(--sp-12);
    border-radius: 24px;
    background: rgba(212,175,55,.02);
    border: 1px solid var(--brd);
    position: relative;
  }
  .cta-card::before {
    content: '';
    position: absolute;
    top: 0; left: 15%; right: 15%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212,175,55,.12), transparent);
  }

  .cta-title {
    font-family: var(--fd);
    font-size: clamp(1.8rem, 3.5vw, 2.6rem);
    font-weight: 900;
    color: var(--t1);
    letter-spacing: -.03em;
    line-height: 1.1;
    margin-bottom: var(--sp-5);
  }

  .cta-desc {
    font-size: 15px;
    color: var(--t2);
    line-height: 1.75;
    max-width: 44ch;
    margin-bottom: var(--sp-8);
  }

  .cta-actions {
    display: flex;
    gap: var(--sp-4);
    align-items: center;
    flex-wrap: wrap;
  }

  .cta-stats {
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
    padding-left: var(--sp-10);
    border-left: 1px solid var(--brd);
  }

  .cta-stat-n {
    font-family: var(--fd);
    font-size: 2rem;
    font-weight: 900;
    background: linear-gradient(180deg, var(--ac3), var(--ac));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1;
  }
  .cta-stat-u { font-size: 1.4rem }
  .cta-stat-l {
    font-size: 12px;
    color: var(--t3);
    margin-top: 4px;
    display: block;
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 768px) {
    .hero { padding: var(--sp-20) 0 var(--sp-12) }
    .hero-h1 { font-size: clamp(2.6rem, 12vw, 4rem) }
    .hero-actions { flex-direction: column; width: 100% }
    .hero-primary { width: 100%; justify-content: center }
    .hide-m { display: none }

    .bento { grid-template-columns: 1fr }
    .bento > :first-child { grid-column: 1; grid-row: auto }

    .cta-card {
      grid-template-columns: 1fr;
      padding: var(--sp-10) var(--sp-6);
    }
    .cta-stats {
      flex-direction: row;
      border-left: none;
      padding-left: 0;
      border-top: 1px solid var(--brd);
      padding-top: var(--sp-6);
      gap: var(--sp-4);
    }
    .cta-stat { flex: 1 }
  }
</style>

<script>
  const input = document.getElementById('heroSearch') as HTMLInputElement;
  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && input.value.trim()) {
      window.location.href = `/catalog?q=${encodeURIComponent(input.value.trim())}`;
    }
  });
</script>
