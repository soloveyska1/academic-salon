  /* ================================================================
     TESTIMONIA — editorial wrapper additions (step 2.9)
     Reviews-wall + lightbox already live under .testimonia above;
     here we add only the VII chapter framing and 4 guarantees.
     ================================================================ */
  .testimonia-rule {
    border: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-line) 20%, var(--gold-line) 80%, transparent);
    margin: clamp(60px, 8vw, 96px) 0 0;
