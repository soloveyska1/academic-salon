      radial-gradient(860px 460px at 18% 18%, rgba(184,148,42,.14), transparent 72%),
      radial-gradient(960px 540px at 84% 76%, rgba(212,175,55,.09), transparent 72%),
      linear-gradient(160deg, rgba(250,248,242,.96), rgba(241,236,226,.74));
  }
  [data-theme='light'] .hero-grid {
    opacity: .22;
