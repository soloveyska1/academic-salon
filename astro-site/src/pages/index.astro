---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';


const totalDocs = D.length;

const categoryAlias: Record<string, string> = {
  'ВКР и дипломы': 'ВКР',
  'Курсовые работы': 'Курсовые',
  'Курсовые': 'Курсовые',
  'Рефераты': 'Рефераты',
  'Отчёты по практике': 'Практика',
  'Самостоятельные работы': 'Самостоятельные',
  'Методические материалы': 'Методички',
};

const preferredCategories = [
  'ВКР и дипломы',
  'Курсовые работы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
  'Методические материалы',
];

const categoryCount = new Map<string, number>();
for (const doc of D) {
  const key = (doc as any).category || 'Разное';
  categoryCount.set(key, (categoryCount.get(key) || 0) + 1);
}

const uniqueCategories = categoryCount.size;

const currentYear = String(new Date().getFullYear());

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const match = blob.match(/(?:19|20)\d{2}/);
  return match ? match[0] : currentYear;
}

function normalizeDoc(doc: any, index: number) {
  return {
    id: `${doc.file}-${index}`,
    slug: doc.file,
    title: doc.catalogTitle || doc.title || doc.filename || 'Студенческая работа',
    type: doc.docType || doc.category || 'Работа',
    subject: doc.subject || 'Психология',
    year: extractYear(doc),
    group: doc.category || 'Разное',
  };
}

const pickedDocs: any[] = [];
for (const category of preferredCategories) {
  const nextDocs = D.filter((doc: any) => doc.category === category).slice(0, 2);
  pickedDocs.push(...nextDocs);
}
if (pickedDocs.length < 9) {
  for (const doc of D) {
    if (pickedDocs.includes(doc)) continue;
    pickedDocs.push(doc);
    if (pickedDocs.length >= 9) break;
  }
}

const cards = pickedDocs.slice(0, 9).map(normalizeDoc);
const filters = ['Все', ...Array.from(new Set(cards.map((c) => c.group))).slice(0, 5)].map((name) => ({
  key: name,
  label: name === 'Все' ? 'Все' : (categoryAlias[name] || name),
}));

const steps = [
  { num: '01', title: 'Тема', note: 'Фиксируем задачу и срок.' },
  { num: '02', title: 'Черновик', note: 'Сверяем логику и формат.' },
  { num: '03', title: 'Сдача', note: 'Отдаём финальную версию.' },
];

const subjectCount = new Map<string, number>();
for (const doc of D) {
  const s = (doc as any).subject;
  if (s) subjectCount.set(s, (subjectCount.get(s) || 0) + 1);
}

const metrics = [
  { value: totalDocs, suffix: '+', label: 'готовых работ' },
  { value: uniqueCategories, suffix: '', label: 'категорий' },
  { value: subjectCount.size, suffix: '+', label: 'предметов' },
];
---

<Base
  title="Библиотека академического салона — студенческие работы без паники"
  description="Библиотека готовых студенческих работ: психология, социальная работа, конфликтология и другие гуманитарные дисциплины. Или закажите индивидуальную подготовку."
  currentPath="/"
>

  <!-- ═══════ 1. HERO ═══════ -->
  <section class="hero" id="hero">
    <canvas class="hero-canvas" id="heroCanvas" aria-hidden="true"></canvas>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <p class="hero-eyebrow" id="heroEyebrow">Библиотека академического салона</p>
      <h1 class="hero-title" id="heroTitle" aria-label="Без паники перед дедлайном.">
        <span class="word" style="--i:0">Без</span>
        <span class="word" style="--i:1">паники</span>
        <br aria-hidden="true" />
        <span class="word" style="--i:2">перед</span>
        <span class="word" style="--i:3">дедлайном.</span>
      </h1>
      <div class="hero-rule" aria-hidden="true"></div>
      <p class="hero-sub" id="heroSub">{totalDocs}+ готовых работ бесплатно · или напишем под ваши требования</p>
      <div class="hero-actions" id="heroActions">
        <a href="/catalog" class="btn btn--primary">Смотреть каталог</a>
        <a href="/order" class="btn btn--ghost">Заказать работу</a>
      </div>
      <div class="hero-unfold" aria-hidden="true"></div>
    </div>

    <div class="hero-metrics" id="proof">
      {metrics.map((m, i) => (
        <div class="metric" style={`--i:${i}`}>
          <span class="metric-value" data-target={m.value} data-suffix={m.suffix}>0{m.suffix}</span>
          <span class="metric-label">{m.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════ 3. КАТАЛОГ ═══════ -->
  <section class="gallery" id="gallery">
    <div class="gallery-inner">
      <header class="gallery-head">
        <h2 class="section-title">Каталог</h2>
        <nav class="gallery-filters" role="tablist" aria-label="Фильтр работ">
          {filters.map((f, idx) => (
            <button
              class:list={['chip', { 'chip--active': idx === 0 }]}
              type="button"
              role="tab"
              aria-selected={idx === 0 ? 'true' : 'false'}
              data-filter={f.key}
            >
              {f.label}
            </button>
          ))}
        </nav>
      </header>

      <div class="grid" id="bento">
        {cards.map((card, idx) => (
          <article
            class="card gradient-border"
            data-group={card.group}
            style={`--i:${idx}`}
          >
            <a href={`/doc/${card.slug}`} class="card-link">
              <span class="card-type">{card.type}</span>
              <h3 class="card-title">{card.title}</h3>
              <span class="card-subject">{card.subject} · {card.year}</span>
            </a>
          </article>
        ))}
      </div>

      <a href="/catalog" class="gallery-more reveal">Полный каталог →</a>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"><span></span><span class="diamond">&#9670;</span><span></span></div>

  <!-- ═══════ 4. ОТЗЫВЫ ═══════ -->
  <section class="reviews" id="reviews">
    <div class="reviews-inner">
      <h2 class="section-title reveal">Что говорят студенты</h2>
      <p class="reviews-lead reveal">Реальные переписки, не выдуманные цитаты</p>
    </div>
    <div class="carousel-wrap">
      <div class="carousel" id="carousel">
        <div class="carousel-track" id="carouselTrack">
          <img src="/reviews/1.webp" alt="Отзыв: Спасибо за работу — Я довольна" class="review-img" loading="lazy" />
          <img src="/reviews/2.webp" alt="Отзыв: У меня 5, работа очень хорошая" class="review-img" loading="lazy" />
          <img src="/reviews/3.webp" alt="Отзыв: Четвёрка твёрдая, отлично всё, шикарно" class="review-img" loading="lazy" />
          <img src="/reviews/4.webp" alt="Отзыв: Автомат, 5 — спасибо огромное за работу" class="review-img" loading="lazy" />
          <img src="/reviews/5.webp" alt="Отзыв: Сдали с первого раза, даже правок нет" class="review-img" loading="lazy" />
          <img src="/reviews/6.webp" alt="Отзыв: Сдала на 4, сказали очень хорошая работа" class="review-img" loading="lazy" />
          <img src="/reviews/7.webp" alt="Отзыв: Кайф, благодарю за быструю работу" class="review-img" loading="lazy" />
          <img src="/reviews/8.webp" alt="Отзыв: Вы мой кумир, как вы это делаете" class="review-img" loading="lazy" />
          <img src="/reviews/9.webp" alt="Отзыв: В шоке, не думала что на след день отправишь" class="review-img" loading="lazy" />
          <img src="/reviews/10.webp" alt="Отзыв: Оценена на 30 баллов — от души" class="review-img" loading="lazy" />
          <!-- Clones for infinite loop -->
          <img src="/reviews/1.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/2.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/3.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/4.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/5.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/6.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/7.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/8.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/9.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
          <img src="/reviews/10.webp" alt="" class="review-img" loading="lazy" aria-hidden="true" />
        </div>
      </div>
      <p class="carousel-hint">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        Нажмите на скриншот, чтобы увеличить
      </p>
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox-close" id="lightboxClose" aria-label="Закрыть">&times;</button>
    <img class="lightbox-img" id="lightboxImg" alt="" />
  </div>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"><span></span><span class="diamond">&#9670;</span><span></span></div>

  <!-- ═══════ 5. ГАРАНТИИ ═══════ -->
  <section class="guarantees reveal cv-auto" id="guarantees">
    <div class="guarantees-inner">
      <h2 class="section-title">Почему мы</h2>
      <div class="guarantees-grid">
        <div class="guarantee grainy">
          <span class="guarantee-icon" aria-hidden="true">&#8734;</span>
          <b class="guarantee-title">Работаем до результата</b>
          <p class="guarantee-note">Бесплатные правки, пока преподаватель не примет работу. Не бросаем на полпути.</p>
        </div>
        <div class="guarantee grainy">
          <span class="guarantee-icon" aria-hidden="true">&#9670;</span>
          <b class="guarantee-title">Антиплагиат</b>
          <p class="guarantee-note">Гарантируем заявленный процент уникальности. Проверка в системе Антиплагиат.</p>
        </div>
        <div class="guarantee grainy">
          <span class="guarantee-icon" aria-hidden="true">&#9201;</span>
          <b class="guarantee-title">Сроки от 1 дня</b>
          <p class="guarantee-note">Стандарт — 2 недели. Срочно — от 1 дня. Дедлайн фиксируем заранее.</p>
        </div>
        <div class="guarantee grainy">
          <span class="guarantee-icon" aria-hidden="true">0&#8381;</span>
          <b class="guarantee-title">{totalDocs}+ работ бесплатно</b>
          <p class="guarantee-note">Каталог готовых работ — без регистрации, без ограничений, без подвоха.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="section-divider" aria-hidden="true"><span></span><span class="diamond">&#9670;</span><span></span></div>

  <!-- ═══════ 6. ПРОЦЕСС ═══════ -->
  <section class="process reveal cv-auto" id="process">
    <div class="process-inner">
      <h2 class="section-title">От темы до защиты — за 3 шага</h2>

      <div class="steps">
        <div class="steps-line" id="stepsLine" aria-hidden="true"></div>
        {steps.map((s) => (
          <div class="step">
            <span class="step-num" aria-hidden="true">{s.num}</span>
            <b class="step-title">{s.title}</b>
            <p class="step-note">{s.note}</p>
          </div>
        ))}
      </div>

      <div class="process-actions">
        <a href="/order" class="btn btn--ghost">Отправить тему</a>
        <span class="process-channels">
          <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="link-text">Telegram</a>
          <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener" class="link-text">VK</a>
        </span>
      </div>
    </div>
  </section>

  <!-- ═══════ 7. FAQ-ПРЕВЬЮ ═══════ -->
  <section class="faq-preview reveal cv-auto" id="faqPreview">
    <div class="faq-preview-inner">
      <h2 class="section-title">Частые вопросы</h2>
      <div class="faq-preview-list">
        <details class="faq-item">
          <summary class="faq-q">
            <span>Это бесплатно? В чём подвох?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <p class="faq-a">Каталог полностью бесплатный — скачивайте без регистрации. Заказ индивидуальных работ — платная услуга, она поддерживает проект.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">
            <span>Какие гарантии вы даёте?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <p class="faq-a">Уникальность по Антиплагиату, выполнение в срок, соответствие методичке и бесплатные правки до тех пор, пока преподаватель не примет работу.</p>
        </details>
        <details class="faq-item">
          <summary class="faq-q">
            <span>Сколько стоит заказать работу?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <p class="faq-a">Реферат — от 3 000 &#8381;, курсовая — от 5 000 &#8381;, ВКР — от 35 000 &#8381;. Точная цена зависит от сроков и требуемой уникальности.</p>
        </details>
      </div>
      <a href="/about#faq" class="gallery-more">Все вопросы →</a>
    </div>
  </section>

  <!-- Floating CTA -->
  <a href="/order" class="float-cta" id="floatCta" aria-label="Заказать работу">
    Заказать работу
  </a>

  <!-- ═══════ 8. ЗАКРЫТИЕ = FOOTER ═══════ -->
  <section class="closing" id="closing">
    <div class="closing-inner">
      <h2 class="closing-title">Откройте каталог<br/>или напишите нам.</h2>
      <div class="closing-actions">
        <a href="/catalog" class="btn btn--primary">Каталог</a>
        <a href="/order" class="btn btn--ghost">Заказать работу</a>
      </div>

      <nav class="closing-links">
        <a href="/catalog">Каталог</a>
        <a href="/order">Заказать</a>
        <a href="/about#faq">FAQ</a>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
        <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
      </nav>

      <p class="colophon">© 2022–2026 Библиотека академического салона</p>
    </div>
  </section>

</Base>

<style>
  /* Scrollbar & selection are in design-tokens.css */

  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* CSS fallback glow — warm candle behind text */
  .hero-glow {
    position: absolute;
    width: min(1200px, 100vw);
    height: min(1000px, 85vw);
    top: 42%;
    left: 50%;
    transform: translate(-50%, -50%) scale(1);
    background:
      radial-gradient(ellipse 60% 50% at 50% 50%, rgba(200,165,40,.18) 0%, transparent 70%),
      radial-gradient(ellipse 40% 35% at 50% 45%, var(--ac-g) 0%, transparent 55%);
    animation: glow-breathe 10s ease-in-out infinite;
    pointer-events: none;
    z-index: 0;
  }

  .hero-canvas.is-active ~ .hero-glow {
    opacity: .35;
  }

  @keyframes glow-breathe {
    0%, 100% { opacity: .7; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.12); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 960px;
    text-align: center;
    padding: 0 8px;
  }

  .hero-eyebrow {
    font: 400 clamp(11px, 1.3vw, 12px)/1 var(--fi);
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--t2);
    margin-bottom: 24px;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .6s cubic-bezier(.25,0,0,1) .1s forwards;
  }

  .hero-title {
    font: 300 clamp(48px, 10vw, 100px)/.92 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    text-wrap: balance;
  }

  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(28px);
    animation: word-in .7s cubic-bezier(.25,0,0,1) forwards;
    animation-delay: calc(var(--i) * 120ms + 300ms);
  }

  @keyframes word-in {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-rule {
    width: 48px;
    height: 1px;
    margin: 32px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
    animation: rule-in .7s cubic-bezier(.25,0,0,1) .9s forwards;
  }

  @keyframes rule-in {
    to { opacity: .25; transform: scaleX(1); }
  }

  .hero-sub {
    margin-top: 28px;
    font: 400 clamp(14px, 1.8vw, 16px)/1.65 var(--fi);
    color: var(--t2);
    letter-spacing: .04em;
    max-width: 52ch;
    margin-inline: auto;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .6s cubic-bezier(.25,0,0,1) 1.1s forwards;
  }

  .hero-actions {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(16px);
    animation: fade-up .6s cubic-bezier(.25,0,0,1) 1.3s forwards;
  }

  .hero-unfold {
    width: 200px;
    height: 1px;
    margin: 0 auto;
    margin-top: 56px;
    background: linear-gradient(90deg, transparent, var(--ac-b), transparent);
    opacity: 0;
    transform: scaleX(0);
    animation: unfold 2s cubic-bezier(.25,0,0,1) 1.5s forwards;
  }

  @keyframes unfold {
    to { opacity: 1; transform: scaleX(1); }
  }

  .hero-metrics {
    position: absolute;
    bottom: 80px;
    left: 24px;
    right: 24px;
    display: flex;
    justify-content: center;
    gap: 80px;
    flex-wrap: wrap;
    z-index: 1;
  }

  @keyframes fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══════ BUTTONS ═══════ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 18px 48px;
    border-radius: 0;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    text-decoration: none;
    color: var(--t1);
    border: .5px solid var(--ac-b);
    cursor: pointer;
    transition:
      transform .5s cubic-bezier(.25,0,0,1),
      border-color .5s cubic-bezier(.25,0,0,1),
      box-shadow .6s cubic-bezier(.25,0,0,1);
  }

  .btn--primary {
    background: var(--surf);
    border-color: var(--ac-b);
  }

  .btn--ghost {
    background: transparent;
  }

  .btn:hover {
    transform: translateY(-2px);
    border-color: var(--ac-b2);
    box-shadow: 0 12px 40px var(--ac-sh);
  }

  .btn--primary:hover {
    box-shadow: 0 12px 40px var(--ac-g);
  }

  /* ═══════ METRICS (inside hero) ═══════ */
  .metric {
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
  }

  .metric.is-visible {
    animation: fade-up .5s var(--ease-spring) calc(var(--i) * 120ms) forwards;
  }

  .metric-value {
    display: block;
    font: 300 clamp(42px, 8vw, 68px)/1 var(--fm);
    color: var(--ac);
    letter-spacing: -.02em;
    font-variant-numeric: tabular-nums;
  }

  .metric-label {
    display: block;
    margin-top: 12px;
    font: 400 11px/1.3 var(--fi);
    color: var(--t3);
    text-transform: uppercase;
    letter-spacing: .12em;
  }

  /* ═══════ GALLERY ═══════ */
  .gallery {
    padding: 140px 24px 128px;
    background: var(--bg);
  }

  .gallery-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .gallery-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px 40px;
    margin-bottom: 56px;
  }

  .section-title {
    font: 300 clamp(36px, 6vw, 56px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
  }

  .gallery-filters {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .chip {
    padding: 8px 16px;
    border: none;
    background: transparent;
    color: var(--t3);
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    cursor: pointer;
    opacity: .4;
    position: relative;
    transition: opacity .4s cubic-bezier(.25,0,0,1), color .4s cubic-bezier(.25,0,0,1);
  }

  .chip::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 16px;
    right: 16px;
    height: 1px;
    background: var(--ac);
    transform: scaleX(0);
    transition: transform .4s cubic-bezier(.25,0,0,1);
  }

  .chip--active {
    opacity: 1;
    color: var(--t1);
  }

  .chip--active::after {
    transform: scaleX(1);
  }

  .chip:hover {
    opacity: .75;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .card {
    background: var(--card);
    border: 1px solid var(--brd);
    border-top: 2px solid var(--ac-b);
    border-radius: 16px;
    opacity: 0;
    transform: translateY(20px);
    transition:
      background .4s cubic-bezier(.25,0,0,1),
      border-color .4s cubic-bezier(.25,0,0,1),
      box-shadow .5s cubic-bezier(.25,0,0,1),
      transform .4s cubic-bezier(.25,0,0,1);
  }

  .card.is-visible {
    animation: fade-up .5s cubic-bezier(.25,0,0,1) calc(var(--i) * 60ms) forwards;
  }

  .card.is-visible.anim-done {
    opacity: 1;
    transform: none;
    animation: none;
  }

  .card[hidden] { display: none; }

  .card.anim-done:hover {
    background: var(--card-h);
    border-color: rgba(212,175,55,.15);
    border-top-color: var(--ac-b3);
    box-shadow: 0 8px 32px var(--ac-t), inset 0 1px 0 rgba(255,255,255,.04);
    transform: translateY(-4px);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 14px;
    padding: 28px 26px;
    min-height: 200px;
    text-decoration: none;
    color: inherit;
    position: relative;
  }

  .card-type {
    font: 400 10px/1 var(--fi);
    color: var(--t3);
    text-transform: uppercase;
    letter-spacing: .14em;
  }

  .card-title {
    font: 400 clamp(17px, 2.2vw, 20px)/1.4 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color .3s cubic-bezier(.25,0,0,1);
  }

  .card.anim-done:hover .card-title {
    color: var(--ac3);
  }

  .card-subject {
    font: 400 11px/1.3 var(--fi);
    color: var(--t3);
    letter-spacing: .03em;
    padding-top: 8px;
    border-top: 1px solid var(--brd);
  }

  .gallery-more {
    display: inline-block;
    margin-top: 56px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--t3);
    text-decoration: none;
    transition: color .5s cubic-bezier(.25,0,0,1);
  }

  .gallery-more:hover { color: var(--ac); }

  /* ═══════ SECTION DIVIDERS ═══════ */
  .section-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 0;
    background: var(--bg);
  }

  .section-divider span:first-child,
  .section-divider span:last-child {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ac-b), transparent);
  }

  .section-divider .diamond {
    color: var(--ac);
    font-size: 8px;
    opacity: .35;
  }

  /* ═══════ FLOATING CTA ═══════ */
  .float-cta {
    position: fixed;
    bottom: 32px;
    right: 32px;
    z-index: 90;
    padding: 14px 28px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    text-decoration: none;
    color: var(--t1);
    background: var(--surf-h);
    border: 1px solid var(--ac-b);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    opacity: 0;
    transform: translateY(20px);
    pointer-events: none;
    transition: all .5s cubic-bezier(.25,0,0,1);
  }

  .float-cta.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .float-cta:hover {
    background: var(--surf-h);
    border-color: var(--ac-b2);
    transform: translateY(-2px);
    box-shadow: 0 12px 40px var(--ac-g);
  }

  /* ═══════ REVIEWS CAROUSEL ═══════ */
  .reviews {
    padding: 140px 0 128px;
    background: var(--bg);
    border-top: 1px solid var(--ac-g2);
    overflow: hidden;
    position: relative;
  }

  .reviews::before {
    content: '';
    position: absolute;
    inset: -30%;
    background:
      radial-gradient(ellipse 50% 40% at 70% 40%, var(--ac-t) 0%, transparent 70%);
    animation: mesh-drift 22s ease-in-out infinite alternate-reverse;
    pointer-events: none;
  }

  .reviews-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 24px;
  }

  .reviews-lead {
    margin-top: 12px;
    font: 400 13px/1.5 var(--fi);
    color: var(--t3);
  }

  .carousel-wrap {
    margin-top: 48px;
    position: relative;
  }

  .carousel-wrap::before,
  .carousel-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }

  .carousel-wrap::before {
    left: 0;
    background: linear-gradient(90deg, var(--bg), transparent);
  }

  .carousel-wrap::after {
    right: 0;
    background: linear-gradient(270deg, var(--bg), transparent);
  }

  .carousel {
    overflow: hidden;
    cursor: grab;
  }

  .carousel.is-dragging {
    cursor: grabbing;
  }

  .carousel-track {
    display: flex;
    gap: 24px;
    animation: carousel-scroll 60s linear infinite;
    width: max-content;
  }

  .carousel-track.is-dragging {
    animation-play-state: paused;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes carousel-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .review-img {
    flex-shrink: 0;
    width: 280px;
    height: auto;
    object-fit: contain;
    border-radius: 16px;
    border: 1px solid var(--ac-g);
    opacity: .85;
    cursor: pointer;
    transition: opacity .4s cubic-bezier(.25,0,0,1), border-color .4s cubic-bezier(.25,0,0,1), transform .3s cubic-bezier(.25,0,0,1);
    user-select: none;
    -webkit-user-drag: none;
  }

  .review-img:hover {
    opacity: 1;
    border-color: var(--ac-b);
    transform: scale(1.02);
  }

  .carousel-hint {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 20px;
    text-align: center;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    opacity: .5;
  }
  .carousel-hint svg { opacity: .7; }

  /* ═══════ LIGHTBOX ═══════ */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    opacity: 0;
    pointer-events: none;
    transition: opacity .35s cubic-bezier(.25,0,0,1);
    padding: 40px;
  }

  .lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* @starting-style — native entry animation (progressive enhancement) */
  @supports (selector(:popover-open)) {
    @starting-style {
      .lightbox.is-open {
        opacity: 0;
      }
      .lightbox.is-open .lightbox-img {
        transform: scale(0.85) translateY(20px);
      }
    }
  }

  .lightbox-img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 16px;
    box-shadow: 0 32px 80px rgba(0,0,0,.5);
    transform: scale(.92);
    transition: transform .45s cubic-bezier(.22,1,.36,1), filter .35s;
    filter: blur(0);
  }

  .lightbox.is-open .lightbox-img {
    transform: scale(1);
  }

  .lightbox-close {
    position: absolute;
    top: 24px;
    right: 24px;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 50%;
    background: var(--surf-h);
    color: rgba(255,255,255,.7);
    font-size: 24px;
    cursor: pointer;
    transition: all .3s;
  }

  .lightbox-close:hover {
    background: rgba(255,255,255,.1);
    color: #fff;
    border-color: rgba(255,255,255,.3);
  }

  /* ═══════ GUARANTEES ═══════ */
  .guarantees {
    padding: 140px 24px;
    background: var(--bg);
    position: relative;
    overflow: hidden;
  }

  /* Animated mesh gradient overlay */
  .guarantees::before {
    content: '';
    position: absolute;
    inset: -50%;
    background:
      radial-gradient(ellipse 40% 35% at 20% 30%, var(--ac-t) 0%, transparent 70%),
      radial-gradient(ellipse 35% 30% at 80% 60%, rgba(167,139,250,.025) 0%, transparent 70%);
    animation: mesh-drift 18s ease-in-out infinite alternate;
    pointer-events: none;
  }

  @keyframes mesh-drift {
    0%   { transform: translate(0, 0) rotate(0deg); }
    50%  { transform: translate(30px, -20px) rotate(2deg); }
    100% { transform: translate(-20px, 15px) rotate(-1deg); }
  }

  .guarantees-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .guarantees-grid {
    margin-top: 56px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--surf);
  }

  .guarantee {
    background: var(--bg);
    padding: 40px 32px;
  }

  .guarantee-icon {
    display: block;
    font: 300 24px/1 var(--fm);
    color: var(--ac);
    opacity: .5;
    margin-bottom: 20px;
  }

  .guarantee-title {
    display: block;
    font: 400 13px/1.4 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t1);
  }

  .guarantee-note {
    margin-top: 10px;
    font: 400 14px/1.7 var(--fi);
    color: var(--t2);
    max-width: 36ch;
  }

  /* ═══════ FAQ PREVIEW ═══════ */
  .faq-preview {
    padding: 140px 24px;
    background: var(--bg);
  }

  .faq-preview-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .faq-preview-list {
    margin-top: 48px;
  }

  .faq-item {
    border-bottom: 1px solid var(--ac-sh);
  }

  .faq-q {
    padding: 20px 0;
    font: 500 15px/1.4 var(--fi);
    color: var(--t1);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    transition: color .3s cubic-bezier(.25,0,0,1);
  }

  .faq-q::-webkit-details-marker { display: none; }
  .faq-q:hover { color: var(--ac2); }

  .faq-chevron {
    flex-shrink: 0;
    color: var(--t3);
    transition: transform .3s cubic-bezier(.25,0,0,1), color .3s;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: var(--ac);
  }

  .faq-a {
    padding: 0 0 20px;
    font: 400 14px/1.8 var(--fi);
    color: var(--t2);
    max-width: 56ch;
  }

  /* ═══════ PROCESS ═══════ */
  .process {
    padding: 140px 24px;
    background: var(--bg);
    border-top: 1px solid var(--ac-g2);
  }

  .process-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .steps {
    margin-top: 64px;
    position: relative;
    display: grid;
    gap: 48px;
  }

  .steps-line {
    display: none;
  }

  .step {
    position: relative;
    padding-left: 24px;
    padding-top: 40px;
  }

  .step-num {
    position: absolute;
    left: 0;
    top: 0;
    font: 300 clamp(80px, 12vw, 104px)/1 var(--fm);
    color: var(--ac);
    opacity: .06;
    user-select: none;
  }

  .step-title {
    position: relative;
    display: block;
    font: 400 12px/1.4 var(--fi);
    color: var(--t1);
    text-transform: uppercase;
    letter-spacing: .12em;
  }

  .step-note {
    position: relative;
    margin-top: 10px;
    font: 400 15px/1.6 var(--fi);
    color: var(--t2);
  }

  .process-actions {
    margin-top: 64px;
    display: flex;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }

  .process-channels {
    display: flex;
    gap: 16px;
  }

  .link-text {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    text-decoration: none;
    transition: color .5s cubic-bezier(.25,0,0,1);
  }

  .link-text:hover { color: var(--ac); }

  /* ═══════ CLOSING (= FOOTER) ═══════ */

  /* Hide global Footer component on homepage */
  :global(.footer) {
    display: none;
  }

  .closing {
    position: relative;
    padding: 180px 24px 72px;
    background: var(--bg);
    text-align: center;
    border-top: 1px solid var(--ac-g2);
    overflow: hidden;
  }

  /* Closing mesh glow */
  .closing::before {
    content: '';
    position: absolute;
    width: 800px;
    height: 600px;
    top: 30%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse 60% 50% at 50% 50%, var(--ac-sh) 0%, transparent 70%);
    animation: closing-glow 12s ease-in-out infinite alternate;
    pointer-events: none;
  }

  @keyframes closing-glow {
    0%   { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
    100% { opacity: 1; transform: translate(-50%, -50%) scale(1.15); }
  }

  .closing-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .closing-title {
    font: 300 clamp(32px, 5.5vw, 52px)/1.15 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    text-wrap: balance;
  }

  .closing-actions {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .closing-links {
    margin-top: 96px;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
  }

  .closing-links a {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    padding: 4px 14px;
    transition: color .5s cubic-bezier(.25,0,0,1);
  }

  .closing-links a:hover {
    color: var(--t1);
  }

  .closing-links a + a {
    border-left: 1px solid var(--ac-g);
  }

  .colophon {
    margin-top: 32px;
    font: 400 10px/1 var(--fm);
    text-transform: uppercase;
    letter-spacing: .22em;
    color: var(--t3);
    opacity: .25;
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 639px) {
    .hero {
      padding-left: var(--sp-page);
      padding-right: var(--sp-page);
      min-height: 85svh; /* Peek at next section */
    }

    .hero-title {
      line-height: 1.1;
      font-size: clamp(38px, 10vw, 52px);
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
    }

    .hero-actions .btn {
      text-align: center;
      padding: 16px 32px;
      font-size: 13px;
    }

    .hero-metrics {
      position: relative;
      bottom: auto;
      left: auto;
      right: auto;
      margin-top: 48px;
      gap: 32px;
      padding: 0 16px;
    }

    .metric-value {
      font-size: clamp(32px, 10vw, 48px);
    }

    .gallery {
      padding: 56px 16px 48px;
    }

    .gallery-head {
      flex-direction: column;
      gap: 16px;
      margin-bottom: 32px;
    }

    .gallery-filters {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 4px;
      padding-bottom: 4px;
    }
    .gallery-filters::-webkit-scrollbar { display: none; }

    .chip {
      padding: 10px 16px;
      font-size: 12px;
      flex-shrink: 0;
      border-radius: 20px;
      background: rgba(255,255,255,.03);
      border: 1px solid var(--brd);
    }
    .chip--active {
      background: rgba(212,175,55,.08);
      border-color: rgba(212,175,55,.2);
    }

    .grid {
      gap: 16px;
    }

    .card {
      border-radius: 16px;
      box-shadow: 0 2px 8px rgba(0,0,0,.15), inset 0 1px 0 rgba(255,255,255,.03);
    }

    .card-link {
      padding: 20px;
      min-height: 130px;
    }

    .card-type {
      font-size: 11px;
    }

    .card-subject {
      font-size: 12px;
    }

    .reviews {
      padding: 56px 0 48px;
    }

    .reviews-inner {
      padding: 0 16px;
    }

    .review-img {
      width: 75vw;
      max-width: 300px;
      border-radius: 16px;
      scroll-snap-align: center;
      flex-shrink: 0;
    }

    /* Native scroll-snap carousel on mobile */
    .carousel {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }
    .carousel::-webkit-scrollbar { display: none; }

    .carousel-track {
      gap: 16px;
      animation: none !important;
      padding: 0 16px;
    }

    .carousel-wrap::before,
    .carousel-wrap::after {
      display: none;
    }

    .carousel-hint { display: none; }

    .guarantees {
      padding: 56px 16px;
    }

    .guarantees-grid {
      grid-template-columns: 1fr;
      gap: 12px;
      background: none;
    }

    .guarantee {
      padding: 24px 20px;
      border-radius: 16px;
      background: rgba(255,255,255,.02);
      border: 1px solid var(--brd);
    }

    .guarantee-icon {
      font-size: 28px;
      margin-bottom: 16px;
    }

    .guarantee-title {
      font-size: 14px;
    }

    .guarantee-note {
      font-size: 14px;
      line-height: 1.6;
    }

    .faq-preview {
      padding: 56px 16px;
    }

    .faq-q {
      padding: 24px 0;
      font-size: 16px;
      min-height: 56px;
    }

    .faq-a {
      font-size: 15px;
      line-height: 1.65;
    }

    .process {
      padding: 56px 16px;
    }

    .step {
      padding-left: 16px;
      padding-top: 28px;
    }

    .step-num {
      font-size: clamp(52px, 12vw, 72px);
    }

    .process-actions {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .closing {
      padding: 64px 16px 48px;
    }

    .closing-links {
      flex-direction: column;
      gap: 0;
    }

    .closing-links a {
      padding: 14px 0;
      font-size: 14px;
    }

    .closing-links a + a {
      border-left: none;
      border-top: 1px solid var(--ac-sh);
    }

    .section-divider {
      margin: 8px 0;
    }

    /* Float CTA: hide when bottom nav present */
    .float-cta {
      display: none !important;
    }
  }

  /* ═══════ SMALL PHONES ═══════ */
  @media (max-width: 375px) {
    .hero { padding-left: 16px; padding-right: 16px; }
    .gallery { padding: 48px 16px 40px; }
    .guarantees { padding: 48px 16px; }
    .faq-preview { padding: 48px 16px; }
    .process { padding: 48px 16px; }
    .closing { padding: 56px 16px 40px; }
    .hero-metrics { gap: 24px; padding: 0 8px; }
  }

  /* ═══════ TABLET ═══════ */
  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ═══════ DESKTOP ═══════ */
  @media (min-width: 900px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .steps {
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
    }

    .step {
      padding: 44px 40px 0 28px;
    }

    .steps-line {
      display: block;
      position: absolute;
      top: 44px;
      left: 40px;
      right: 40px;
      height: 0.5px;
      background: var(--surf-h);
      transform-origin: left;
      transform: scaleX(0);
    }

    /* Scroll-driven draw if supported */
    @supports (animation-timeline: view()) {
