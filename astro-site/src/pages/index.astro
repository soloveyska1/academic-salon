---
import Base from '../layouts/Base.astro';
import DocumentCard from '../components/DocumentCard.astro';
import { D } from '../data/catalog.js';

const docCount = D.length;
const categoryMap = new Map();

for (const doc of D) {
  const category = doc.category || 'Без категории';
  categoryMap.set(category, (categoryMap.get(category) || 0) + 1);
}

const categoryStats = Array.from(categoryMap.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5)
  .map(([name, count]) => ({ name, count }));

const maxCategoryCount = categoryStats[0]?.count || 1;

const curatedOrder = ['ВКР и дипломы', 'Курсовые работы', 'Рефераты', 'Отчёты по практике', 'Контрольные работы', 'Методические материалы'];
const showcaseDocs = [];

for (const category of curatedOrder) {
  const candidate = D.find((doc) => doc.category === category && !showcaseDocs.includes(doc));
  if (candidate) showcaseDocs.push(candidate);
}

while (showcaseDocs.length < 9) {
  const candidate = D.find((doc) => !showcaseDocs.includes(doc));
  if (!candidate) break;
  showcaseDocs.push(candidate);
}

const servicePoints = [
  'Бриф и требования фиксируем до старта',
  'Промежуточный черновик для согласования',
  'Правки бесплатно до принятия работы',
];
---

<Base title="Академический Салон — библиотека «Кладовая ГИПСР»" currentPath="/">
  <section class="hero" id="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>

    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="hero-kicker" data-reveal>Кладовая ГИПСР • архив работ</p>
        <h1 class="hero-title" data-reveal data-delay="80">
          Библиотека работ,
          <span>с которой закрывают дедлайны.</span>
        </h1>
        <p class="hero-sub" data-reveal data-delay="140">
          Сначала берёшь готовый материал. Если нужен текст с нуля, подключаем авторский режим.
        </p>

        <div class="hero-actions" data-reveal data-delay="190">
          <a href="/catalog" class="btn btn-primary">Открыть каталог</a>
          <a href="/order" class="btn btn-secondary">Индивидуальная работа</a>
        </div>
      </div>

      <aside class="hero-panel" id="heroPanel" data-reveal data-delay="120">
        <div class="hero-panel-head">
          <span>Фонд библиотеки</span>
          <strong>{docCount}</strong>
        </div>

        <ul class="hero-bars">
          {categoryStats.map((item, index) => (
            <li class="hero-bar" style={`--ratio:${Math.max(16, Math.round((item.count / maxCategoryCount) * 100))}%; --delay:${index * 80}ms`}>
              <div class="hero-bar-row">
                <span>{item.name}</span>
                <b>{item.count}</b>
              </div>
              <span class="hero-bar-track" aria-hidden="true">
                <span class="hero-bar-fill"></span>
              </span>
            </li>
          ))}
        </ul>

        <p class="hero-panel-note">Основа сайта — материалы из «Кладовой ГИПСР».</p>
      </aside>
    </div>
  </section>

  <section class="showcase" id="showcase">
    <div class="container">
      <div class="showcase-head">
        <p class="section-label" data-reveal>Выборка документов</p>
        <a href="/catalog" class="showcase-link" data-reveal data-delay="80">Весь каталог →</a>
      </div>

      <div class="showcase-grid">
        {showcaseDocs.map((doc, index) => (
          <div
            class:list={[
              'showcase-item',
              {
                'showcase-item--lead': index === 0,
                'showcase-item--wide': index === 1,
              },
            ]}
            data-reveal
            data-delay={Math.min(index * 55, 240)}
          >
            <DocumentCard doc={doc} index={index} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="service" id="service">
    <div class="container">
      <article class="service-card" data-reveal>
        <p class="section-label">Индивидуальная работа</p>
        <h2>Нужен новый текст под конкретного преподавателя? Сделаем спокойно и точно.</h2>

        <ul class="service-points">
          {servicePoints.map((point) => (
            <li>{point}</li>
          ))}
        </ul>

        <div class="service-actions">
          <a href="/order" class="btn btn-primary">Оставить запрос</a>
          <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost">Telegram →</a>
          <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost">VK →</a>
        </div>
      </article>
    </div>
  </section>

  <section class="contact-band" id="contactBand">
    <div class="container contact-inner" data-reveal>
      <p>Неясно, брать из каталога или заказывать? Напиши задачу, подскажем лучший путь.</p>
      <a href="/order">Уточнить по теме и сроку →</a>
    </div>
  </section>
</Base>

<style>
  .hero,
  .showcase,
  .service,
  .contact-band {
    position: relative;
    z-index: 2;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .6s var(--ease), transform .6s var(--ease);
    transition-delay: var(--reveal-delay, 0ms);
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hero {
    min-height: calc(100svh - 24px);
    padding: calc(var(--nav-h) + 56px) 0 90px;
    overflow: clip;
    border-bottom: 1px solid rgba(212,175,55,.1);
  }

  .hero-bg,
  .hero-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero-bg {
    background:
      radial-gradient(900px 520px at 18% 18%, rgba(212,175,55,.16), transparent 70%),
      radial-gradient(800px 500px at 86% 80%, rgba(246,226,122,.08), transparent 72%),
      linear-gradient(165deg, rgba(12,11,16,.95), rgba(8,7,12,.74));
  }
  .hero-grid {
    background-image:
      linear-gradient(rgba(212,175,55,.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212,175,55,.04) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(circle at 52% 34%, rgba(0,0,0,.95) 0%, rgba(0,0,0,.2) 66%, transparent 100%);
    opacity: .28;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(0, .92fr);
    gap: clamp(28px, 4.4vw, 68px);
    align-items: end;
  }

  .hero-kicker {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--ac3);
    margin-bottom: var(--sp-5);
  }
  .hero-title {
    font-family: var(--fd);
    font-size: clamp(42px, 5.4vw, 76px);
    line-height: 1.02;
    text-wrap: balance;
    max-width: 860px;
  }
  .hero-title span {
    color: var(--ac3);
  }
  .hero-sub {
    margin-top: var(--sp-6);
    max-width: 590px;
    color: var(--t2);
    font-size: clamp(16px, 1.5vw, 20px);
    line-height: 1.62;
  }

  .hero-actions {
    margin-top: var(--sp-8);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  .hero-panel {
    border: 1px solid rgba(212,175,55,.2);
    border-radius: 22px;
    padding: 24px;
    background: linear-gradient(160deg, rgba(17,16,24,.84), rgba(10,9,14,.68));
    box-shadow:
      0 22px 80px rgba(0,0,0,.44),
      inset 0 1px 0 rgba(255,255,255,.08);
    backdrop-filter: blur(18px) saturate(1.2);
    transform: perspective(1200px) rotateX(0deg) rotateY(0deg);
    transition: transform .16s linear;
    will-change: transform;
  }

  .hero-panel-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 12px;
    margin-bottom: 16px;
    border-bottom: 1px solid rgba(212,175,55,.16);
  }
  .hero-panel-head span {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--t2);
  }
  .hero-panel-head strong {
    font-family: var(--fm);
    color: var(--ac3);
    font-size: 20px;
    letter-spacing: .4px;
  }

  .hero-bars {
    list-style: none;
    display: grid;
    gap: 14px;
    padding: 0;
    margin: 0;
  }
  .hero-bar-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 7px;
  }
  .hero-bar-row span {
    font-size: 14px;
    color: var(--t1);
    line-height: 1.3;
  }
  .hero-bar-row b {
    font-family: var(--fm);
    color: var(--ac3);
    font-size: 12px;
    font-weight: 500;
  }

  .hero-bar-track {
    display: block;
    height: 5px;
    border-radius: 999px;
    background: rgba(212,175,55,.08);
    overflow: hidden;
  }
  .hero-bar-fill {
    display: block;
    width: var(--ratio);
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, rgba(212,175,55,.75), rgba(246,226,122,.98));
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform .72s var(--ease-spring);
    transition-delay: var(--delay);
  }
  .hero-bar.is-ready .hero-bar-fill {
    transform: scaleX(1);
  }

  .hero-panel-note {
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid rgba(212,175,55,.12);
    color: var(--t3);
    font-size: 13px;
    line-height: 1.5;
  }

  .showcase {
    padding: 72px 0 88px;
  }
  .showcase-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--sp-4);
    margin-bottom: var(--sp-8);
  }
  .showcase-link {
    color: var(--ac3);
    text-decoration: none;
    border-bottom: 1px solid rgba(212,175,55,.4);
    padding-bottom: 2px;
    transition: color .25s var(--ease), border-color .25s var(--ease);
  }
  .showcase-link:hover {
    color: var(--ac4);
    border-color: rgba(246,226,122,.7);
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }
  .showcase-item--lead {
    grid-column: span 2;
  }
  .showcase-item--wide {
    grid-column: span 2;
  }

  .showcase-item :global(a.doc-card) {
    height: 100%;
    border-radius: 18px;
    border-color: rgba(212,175,55,.16);
    background: linear-gradient(165deg, rgba(212,175,55,.05), rgba(212,175,55,.02));
    transition: border-color .25s var(--ease), transform .25s var(--ease);
  }
  .showcase-item :global(a.doc-card:hover) {
    border-color: rgba(246,226,122,.38);
    transform: translateY(-2px);
  }

  .service {
    padding: 0 0 82px;
  }
  .service-card {
    border: 1px solid rgba(212,175,55,.18);
    border-radius: 22px;
    padding: clamp(22px, 3vw, 34px);
    background: linear-gradient(160deg, rgba(18,17,24,.8), rgba(10,9,14,.68));
    box-shadow: 0 18px 70px rgba(0,0,0,.34);
  }
  .service-card h2 {
    margin-top: var(--sp-4);
    font-family: var(--fd);
    font-size: clamp(30px, 3.2vw, 46px);
    line-height: 1.15;
    text-wrap: balance;
    max-width: 980px;
  }

  .service-points {
    margin-top: var(--sp-6);
    list-style: none;
    display: grid;
    gap: 10px;
    max-width: 700px;
  }
  .service-points li {
    color: var(--t2);
    font-size: 15px;
    line-height: 1.52;
    padding-left: 18px;
    position: relative;
  }
  .service-points li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ac2);
    box-shadow: 0 0 0 3px rgba(212,175,55,.1);
  }

  .service-actions {
    margin-top: var(--sp-7);
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  .contact-band {
    border-top: 1px solid rgba(212,175,55,.1);
    padding: 28px 0 76px;
  }
  .contact-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--sp-4);
  }
  .contact-inner p {
    font-size: 18px;
    color: var(--t2);
    line-height: 1.5;
  }
  .contact-inner a {
    color: var(--ac3);
    text-decoration: none;
    border-bottom: 1px solid rgba(212,175,55,.4);
    padding-bottom: 2px;
    white-space: nowrap;
    transition: color .25s var(--ease), border-color .25s var(--ease);
  }
  .contact-inner a:hover {
    color: var(--ac4);
    border-color: rgba(246,226,122,.72);
  }

  @media (max-width: 1200px) {
    .hero-inner {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .hero-panel {
      max-width: 760px;
    }

    .showcase-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .showcase-item--lead,
    .showcase-item--wide {
      grid-column: span 2;
    }
  }

  @media (max-width: 860px) {
    .hero {
      min-height: auto;
      padding-top: calc(var(--nav-h) + 40px);
      padding-bottom: 74px;
    }

    .hero-title {
      font-size: clamp(36px, 9vw, 52px);
    }

    .showcase-grid {
      grid-template-columns: 1fr;
    }
    .showcase-item--lead,
    .showcase-item--wide {
      grid-column: auto;
    }

    .contact-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .contact-inner p {
      font-size: 16px;
    }
  }

  @media (max-width: 640px) {
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .hero-actions .btn {
      width: 100%;
      justify-content: center;
    }

    .showcase-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }
  }

  [data-theme='light'] .hero-bg {
    background:
      radial-gradient(900px 520px at 18% 18%, rgba(184,148,42,.16), transparent 70%),
      radial-gradient(800px 500px at 86% 80%, rgba(212,175,55,.1), transparent 72%),
      linear-gradient(165deg, rgba(250,248,242,.98), rgba(241,236,226,.78));
  }
  [data-theme='light'] .hero-grid {
    opacity: .2;
  }
  [data-theme='light'] .hero-panel,
  [data-theme='light'] .service-card {
    box-shadow: var(--shadow);
  }
</style>

<script is:inline>
  (() => {
    let cleanups = [];

    function cleanupAll() {
      cleanups.forEach((fn) => {
        try { fn(); } catch (_) { /* noop */ }
      });
      cleanups = [];
    }

    function initReveals() {
      const nodes = Array.from(document.querySelectorAll('[data-reveal]'));
      if (!nodes.length) return;

      nodes.forEach((node) => {
        const delay = Number(node.getAttribute('data-delay') || 0);
        node.style.setProperty('--reveal-delay', `${delay}ms`);
      });

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        nodes.forEach((node) => node.classList.add('is-visible'));
        return;
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.16, rootMargin: '0px 0px -40px 0px' });

      nodes.forEach((node) => observer.observe(node));
      cleanups.push(() => observer.disconnect());
    }

    function initHeroBars() {
      const items = Array.from(document.querySelectorAll('.hero-bar'));
      if (!items.length) return;

      const panel = document.getElementById('heroPanel');
      if (!panel) return;

      const observer = new IntersectionObserver((entries) => {
        const visible = entries.some((entry) => entry.isIntersecting);
        if (!visible) return;
        items.forEach((item) => item.classList.add('is-ready'));
        observer.disconnect();
      }, { threshold: 0.35 });

      observer.observe(panel);
      cleanups.push(() => observer.disconnect());
    }

    function initHeroTilt() {
      const section = document.getElementById('hero');
      const panel = document.getElementById('heroPanel');
      if (!section || !panel) return;
      if (window.matchMedia('(pointer: coarse)').matches) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      let tx = 0;
      let ty = 0;
      let cx = 0;
      let cy = 0;
      let rafId = 0;

      const render = () => {
        cx += (tx - cx) * 0.09;
        cy += (ty - cy) * 0.09;

        const rotX = cy * -6;
        const rotY = cx * 8;
        panel.style.transform = `perspective(1200px) rotateX(${rotX.toFixed(2)}deg) rotateY(${rotY.toFixed(2)}deg)`;

        if (Math.abs(tx - cx) > 0.001 || Math.abs(ty - cy) > 0.001) {
          rafId = requestAnimationFrame(render);
        } else {
          rafId = 0;
        }
      };

      const onMove = (event) => {
        const rect = section.getBoundingClientRect();
        tx = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
        ty = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
        if (!rafId) rafId = requestAnimationFrame(render);
      };

      const onLeave = () => {
        tx = 0;
        ty = 0;
        if (!rafId) rafId = requestAnimationFrame(render);
      };

      section.addEventListener('mousemove', onMove, { passive: true });
      section.addEventListener('mouseleave', onLeave);

      cleanups.push(() => {
        section.removeEventListener('mousemove', onMove);
        section.removeEventListener('mouseleave', onLeave);
        if (rafId) cancelAnimationFrame(rafId);
        panel.style.transform = 'perspective(1200px) rotateX(0deg) rotateY(0deg)';
      });
    }

    function initAll() {
      cleanupAll();
      initReveals();
      initHeroBars();
      initHeroTilt();
    }

    initAll();
    document.addEventListener('astro:page-load', initAll);
    document.addEventListener('astro:after-swap', initAll);
  })();
</script>
