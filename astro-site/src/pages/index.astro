<style>
  /* ================================================================
     HOMEPAGE -- Editorial Luxury
     Monocle meets Linear. Gold on obsidian. Every section breathes.
     ================================================================ */

  /* Hide the global footer on this page */
  :global(.footer) { display: none; }

  /* ----------------------------------------------------------------
     SHARED
     ---------------------------------------------------------------- */
  @keyframes fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes word-in {
    to { opacity: 1; transform: translateY(0); }
  }

  .section-title {
    font: 300 clamp(36px, 6vw, 56px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
  }

  .rv {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .6s var(--ease), transform .6s var(--ease);
  }

  .rv.vis {
    opacity: 1;
    transform: translateY(0);
  }

  /* ----------------------------------------------------------------
     BUTTONS
     ---------------------------------------------------------------- */
  /* Base .btn/.btn--primary/.btn--ghost live in components.css (global).
     The duplicates that used to be here were overriding .btn-gold color/bg on
     the homepage because scoped Astro selectors ([data-astro-cid-*]) had higher
     specificity. Keep this block for homepage-only tweaks, but let globals win. */
  .btn--primary {
    background: var(--surf);
  }
  .btn--ghost {
    background: transparent;
  }

  .btn--primary:hover {
    box-shadow: 0 12px 40px var(--ac-g);
  }

  .btn--ghost:hover {
    color: var(--t1);
    border-color: var(--ac-b2);
  }

  /* ----------------------------------------------------------------
     1. HERO -- dramatic multi-layer glow, 100svh
     ---------------------------------------------------------------- */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-glow {
    position: absolute;
    width: min(1100px, 95vw);
    height: min(900px, 85vw);
    top: 45%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45% at 50% 48%, rgba(212,175,55,.22) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 48% 44%, rgba(212,175,55,.14) 0%, transparent 50%),
      radial-gradient(ellipse 75% 55% at 42% 52%, rgba(180,130,20,.08) 0%, transparent 75%);
    pointer-events: none;
    z-index: 0;
    animation: glow-breathe 10s ease-in-out infinite;
  }

  @keyframes glow-breathe {
    0%, 100% { opacity: .65; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.06); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 960px;
    text-align: center;
    padding: 0 8px;
  }

  .hero-title {
    /* Risk #1 fix: cap at 140px so 4K/ultrawide doesn't overflow;
       min 38px keeps 'Студенческие' safe on 320px viewport */
    font: 300 clamp(38px, 8.5vw, 140px)/.96 var(--fd);
    color: var(--t1);
    letter-spacing: -.025em;
    text-wrap: balance;
    text-shadow: 0 0 120px rgba(212,175,55,.06), 0 4px 24px rgba(0,0,0,.3);
    max-width: 14ch;
    margin: 0 auto;
    font-feature-settings: "dlig", "liga", "kern", "ss01";
  }
  .prelude-title .ln {
    display: block;
  }
  .prelude-title .it {
    font-style: italic;
    color: var(--ac);
    font-weight: 400;
    font-feature-settings: "swsh", "dlig", "liga";
  }
  /* Eyebrow above hero title — chapter mark */
  .prelude-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: clamp(20px, 3vw, 36px);
    font: 400 11px/1 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--ac);
    opacity: 0;
    animation: fade-up .5s ease-out .1s forwards;
  }
  .prelude-eyebrow-rule {
    width: 28px;
    height: 1px;
    background: var(--ac);
    display: inline-block;
  }
  .prelude-eyebrow-num {
    font-family: var(--fd);
    font-style: italic;
    font-size: 18px;
    color: var(--ac);
    letter-spacing: 0;
    text-transform: none;
  }
  /* Lede with two audiences — split on / for visual balance */
  .prelude-lede {
    font: 400 clamp(15px, 1.7vw, 18px)/1.65 var(--fi);
    color: var(--t2);
    max-width: 56ch;
    margin: 28px auto 0;
    text-wrap: balance;
  }
  .prelude-lede .lede-aud {
    color: var(--ac);
    font-weight: 500;
    letter-spacing: .02em;
  }
  .prelude-lede .lede-sep {
    color: var(--ac);
    opacity: .4;
    margin: 0 6px;
  }
  /* Scroll cue — bottom of hero */
  .prelude-cue {
    position: absolute;
    bottom: clamp(16px, 4vh, 40px);
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    font: 400 10px/1 var(--fm);
    letter-spacing: .24em;
    text-transform: uppercase;
    color: var(--t3);
    text-decoration: none;
    opacity: 0;
    animation: fade-up .5s ease-out 1.8s forwards;
    transition: color var(--dur) var(--ease);
  }
  .prelude-cue:hover { color: var(--ac); }
  .prelude-cue-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, var(--ac), transparent);
    opacity: .55;
  }
  @media (max-width: 720px) {
    .prelude-cue { display: none; }
  }

  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(12px);
    animation: word-in .4s ease-out forwards;
    animation-delay: calc(var(--i) * 200ms + 300ms);
  }

  .hero-rule {
    width: 48px;
    height: 1px;
    margin: 28px auto 0;
    background: linear-gradient(90deg, transparent, var(--ac), transparent);
    opacity: .35;
  }

  .hero-sub {
    margin-top: 24px;
    font: 400 15px/1.6 var(--fi);
    color: var(--t2);
    max-width: 52ch;
    margin-inline: auto;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.2s forwards;
  }

  .hero-search {
    position: relative;
    max-width: 480px;
    margin: 36px auto 0;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.4s forwards;
  }

  .hero-search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--t3);
    pointer-events: none;
  }

  .hero-search-input {
    width: 100%;
    padding: 14px 20px 14px 42px;
    border: 1px solid var(--brd);
    border-radius: 999px;
    background: rgba(255,255,255,.04);
    color: var(--t1);
    font: 400 16px/1.4 var(--fi);
    outline: none;
    transition: border-color .3s, box-shadow .3s, background .3s;
  }

  .hero-search-input::placeholder { color: var(--t3); }

  .hero-search-input:focus {
    border-color: var(--ac-b);
    box-shadow: 0 0 0 3px rgba(212,175,55,.1);
    background: rgba(255,255,255,.06);
  }

  .hero-actions {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.6s forwards;
  }

  /* ----------------------------------------------------------------
     2. REVIEWS -- horizontal scroll gallery (the showstopper)
     ---------------------------------------------------------------- */
  .reviews {
    padding: 120px 0;
    background: var(--bg);
    overflow: hidden;
  }

  .reviews-head {
    text-align: center;
    padding: 0 24px;
    margin-bottom: 48px;
  }

  .reviews-sub {
    font: 400 14px/1.6 var(--fi);
    color: var(--t3);
    margin-top: 12px;
  }

  /* Auto-scrolling review wall */
  .reviews-wall {
    display: flex;
    flex-direction: column;
    gap: 12px;
    mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
  }

  .rw-row {
    overflow: hidden;
  }

  .rw-track {
    display: flex;
    gap: 12px;
    width: max-content;
  }

  .rw-row--left .rw-track {
    animation: rw-scroll-left 50s linear infinite;
  }

  .rw-row--right .rw-track {
    animation: rw-scroll-right 55s linear infinite;
  }

  @keyframes rw-scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes rw-scroll-right {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  .rw-img {
    height: 200px;
    width: auto;
    flex-shrink: 0;
    display: block;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,.06);
    object-fit: cover;
    cursor: pointer;
    transition: transform .3s var(--ease), border-color .3s;
  }

  .rw-img:hover {
    transform: scale(1.03);
    border-color: rgba(212,175,55,.15);
    box-shadow: 0 0 0 2px rgba(255,255,255,.15);
  }

  /* Pause on hover */
  .reviews-wall:hover .rw-track {
    animation-play-state: paused;
  }

  /* ----------------------------------------------------------------
     LIGHTBOX — fullscreen review viewer
     ---------------------------------------------------------------- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,.92);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    opacity: 0;
    visibility: hidden;
    transition: opacity .3s ease, visibility .3s;
    padding: 48px;
  }

  .lightbox.is-open {
    opacity: 1;
    visibility: visible;
  }

  .lb-img {
    max-width: min(90vw, 500px);
    max-height: 85vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 12px;
    box-shadow: 0 32px 80px rgba(0,0,0,.5);
    transition: transform .3s ease;
  }

  .lightbox.is-open .lb-img {
    animation: lb-enter .3s ease-out;
  }

  @keyframes lb-enter {
    from { opacity: 0; transform: scale(.92); }
    to { opacity: 1; transform: scale(1); }
  }

  .lb-close {
    position: absolute;
    top: 16px;
    right: 20px;
    width: 44px;
    height: 44px;
    border: none;
    background: none;
    color: var(--t2);
    font-size: 28px;
    cursor: pointer;
    z-index: 2;
    transition: color .2s;
  }

  .lb-close:hover { color: #fff; }

  .lb-prev,
  .lb-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 50%;
    background: rgba(255,255,255,.05);
    color: var(--t2);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: border-color .2s, color .2s, background .2s;
  }

  .lb-prev { left: 20px; }
  .lb-next { right: 20px; }

  .lb-prev:hover,
  .lb-next:hover {
    border-color: rgba(255,255,255,.3);
    color: #fff;
    background: rgba(255,255,255,.1);
  }

  .lb-counter {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font: 400 13px/1 var(--fm);
    color: var(--t3);
    letter-spacing: .1em;
  }

  @media (max-width: 639px) {
    .lightbox { padding: 20px; }
    .lb-prev, .lb-next { width: 40px; height: 40px; }
    .lb-prev { left: 8px; }
    .lb-next { right: 8px; }
    .lb-img { max-width: 92vw; }
  }

  /* ----------------------------------------------------------------
     3. CATALOG -- Bento grid, glass cards
     ---------------------------------------------------------------- */
  .catalog {
    padding: 120px 24px;
    background: var(--bg);
  }

  .catalog-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .catalog-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 56px;
  }

  .section-link {
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    transition: color .3s var(--ease);
  }

  .section-link:hover { color: var(--ac); }

  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  /* Glass card */
  .card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px;
    background: rgba(255,255,255,.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,.06);
    border-radius: var(--rs);
    text-decoration: none;
    color: var(--t1);
    position: relative;
    overflow: hidden;
    transition:
      border-color .3s var(--ease),
      transform .3s var(--ease),
      box-shadow .3s var(--ease);
  }

  /* Gold shimmer top-line on hover */
  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 20%, var(--ac) 50%, transparent 80%);
    opacity: 0;
    transition: opacity .3s;
  }

  .card:hover {
    border-color: rgba(212,175,55,.15);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,.3), 0 0 0 1px rgba(212,175,55,.08);
  }

  .card:hover::before {
    opacity: .4;
  }

  .card-type {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
  }

  .card-title {
    font: 400 18px/1.35 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card:hover .card-title {
    text-decoration: underline;
    text-decoration-color: rgba(255,255,255,.2);
    text-underline-offset: 3px;
  }

  .card-meta {
    font: 400 13px/1 var(--fi);
    color: var(--t3);
    margin-top: auto;
  }

  /* ----------------------------------------------------------------
     5. FOOTER -- minimal signature
     ---------------------------------------------------------------- */
  .foot {
    padding: 64px 24px;
    background: var(--bg);
    text-align: center;
  }

  .foot-copy {
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    letter-spacing: .04em;
  }

  /* ----------------------------------------------------------------
     CHAPTER HEAD — shared across editorial sections
     ---------------------------------------------------------------- */
  .chapter-head {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: clamp(24px, 5vw, 80px);
    align-items: start;
    margin-bottom: clamp(40px, 6vw, 80px);
  }
  .chapter-num {
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: sticky;
    top: calc(var(--nav-h) + 16px);
  }
  .chapter-num .roman {
    font: italic 400 clamp(48px, 6vw, 76px)/1 var(--fd);
    color: var(--ac);
    letter-spacing: -.02em;
    font-feature-settings: "swsh";
  }
  .chapter-num .chapter-label {
    font: 400 10px/1.4 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--t3);
  }
  .chapter-title-block { max-width: 56ch; }
  .chapter-h {
    font: 400 clamp(36px, 5vw, 76px)/.98 var(--fd);
    color: var(--t1);
    letter-spacing: -.025em;
    margin: 0 0 clamp(16px, 2vw, 28px);
    text-wrap: balance;
    font-feature-settings: "dlig", "liga", "kern";
  }
  .chapter-h .it {
    font-style: italic;
    color: var(--ac);
    font-feature-settings: "swsh", "dlig";
  }
  .chapter-lede {
    font: 400 clamp(15px, 1.6vw, 18px)/1.65 var(--fi);
    color: var(--t2);
    max-width: 52ch;
  }
  @media (max-width: 760px) {
    .chapter-head {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .chapter-num {
      position: static;
      flex-direction: row;
      align-items: baseline;
      gap: 14px;
    }
    .chapter-num .roman { font-size: 40px; }
  }

  /* ----------------------------------------------------------------
     II. MANIFESTO
     ---------------------------------------------------------------- */
  .manifesto {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px);
    background: var(--bg);
  }
  .manifesto-inner {
    max-width: 1080px;
    margin: 0 auto;
  }
  .manifesto-body {
    max-width: 56ch;
    margin: 0 auto clamp(56px, 8vw, 96px);
    padding-left: clamp(0px, 4vw, 80px);
  }
  .manifesto-text {
    font: 400 clamp(17px, 1.7vw, 20px)/1.65 var(--fd);
    color: var(--cream-2, var(--t2));
    margin-bottom: 1.4em;
    font-feature-settings: "dlig", "liga", "kern", "onum";
  }
  .manifesto-text:last-of-type { margin-bottom: 0; }
  .manifesto-text .it {
    font-style: italic;
    color: var(--ac);
    font-weight: 400;
    font-feature-settings: "swsh", "dlig";
  }
  .manifesto-drop {
    float: left;
    font: 400 clamp(64px, 7vw, 92px)/.85 var(--fd);
    font-style: italic;
    color: var(--ac);
    margin: 4px 14px 0 0;
    font-feature-settings: "swsh";
  }
  .manifesto-cta {
    display: flex;
    gap: 14px;
    margin-top: clamp(32px, 5vw, 48px);
    flex-wrap: wrap;
  }
  .manifesto-tenets {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 3vw, 40px);
    padding-top: clamp(40px, 6vw, 64px);
    border-top: 1px solid var(--brd);
  }
  .tenet {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .tenet-num {
    font: italic 400 16px/1 var(--fd);
    color: var(--ac);
    letter-spacing: 0;
    font-feature-settings: "swsh";
  }
  .tenet-h {
    font: 400 clamp(20px, 2vw, 26px)/1.15 var(--fd);
    color: var(--t1);
    letter-spacing: -.01em;
    margin: 0;
  }
  .tenet-p {
    font: 400 14px/1.55 var(--fi);
    color: var(--t2);
    margin: 0;
  }
  .tenet-p .it {
    font-style: italic;
    color: var(--ac);
    font-feature-settings: "swsh";
  }
  @media (max-width: 900px) {
    .manifesto-tenets { grid-template-columns: 1fr; gap: 28px; }
    .manifesto-body { padding-left: 0; }
  }

  /* ----------------------------------------------------------------
     V. EPILOGUE — final CTA + contact channels
     ---------------------------------------------------------------- */
  .epilogue {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px) clamp(48px, 6vw, 80px);
    background: var(--bg);
    border-top: 1px solid var(--brd);
    text-align: center;
  }
  .epilogue-inner {
    max-width: 1080px;
    margin: 0 auto;
  }
  .epilogue-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: clamp(20px, 3vw, 32px);
    font: 400 11px/1 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--ac);
  }
  .epilogue-h {
    font: 400 clamp(40px, 6vw, 96px)/.98 var(--fd);
    color: var(--t1);
    letter-spacing: -.025em;
    margin: 0 0 clamp(16px, 2vw, 24px);
    text-wrap: balance;
  }
  .epilogue-h .it {
    font-style: italic;
    color: var(--ac);
    font-feature-settings: "swsh", "dlig";
  }
  .epilogue-sub {
    font: 400 clamp(15px, 1.6vw, 18px)/1.6 var(--fi);
    color: var(--t2);
    max-width: 56ch;
    margin: 0 auto clamp(40px, 6vw, 64px);
  }
  .epilogue-channels {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--brd);
    border-bottom: 1px solid var(--brd);
    margin-bottom: clamp(40px, 6vw, 72px);
  }
  .channel {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    padding: clamp(24px, 3vw, 36px);
    border-right: 1px solid var(--brd);
    text-decoration: none;
    text-align: left;
    color: var(--t1);
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
    position: relative;
  }
  .channel:last-child { border-right: none; }
  .channel:hover {
    background: var(--ac-t);
    color: var(--ac);
  }
  .channel:focus-visible {
    outline: 2px solid var(--ac-b);
    outline-offset: -4px;
  }
  .channel-icon {
    display: inline-flex;
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ac-line);
    border-radius: 50%;
    color: var(--ac);
    transition: border-color var(--dur) var(--ease);
  }
  .channel-icon svg { width: 18px; height: 18px; }
  .channel:hover .channel-icon { border-color: var(--ac); }
  .channel-name {
    font: 400 13px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--t1);
    margin-top: 4px;
  }
  .channel:hover .channel-name { color: var(--ac); }
  .channel-handle {
    font: italic 400 17px/1.2 var(--fd);
    color: var(--t2);
    word-break: break-all;
    font-feature-settings: "dlig";
  }
  .channel-note {
    font: 400 11px/1.4 var(--fm);
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--t3);
    margin-top: auto;
  }

  .epilogue-signoff {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  .epilogue-signoff .hairline-edit {
    width: 48px;
    height: 1px;
    background: var(--ac);
    opacity: .4;
  }
  .epilogue-copy {
    font: italic 400 14px/1.4 var(--fd);
    color: var(--t2);
    letter-spacing: .04em;
    font-variant-numeric: tabular-nums;
  }
  .epilogue-whisper {
    font: 400 11px/1.5 var(--fi);
    color: var(--t3);
    opacity: .65;
    letter-spacing: .03em;
  }

  @media (max-width: 1000px) {
    .epilogue-channels { grid-template-columns: repeat(2, 1fr); }
    .channel:nth-child(2) { border-right: none; }
    .channel:nth-child(1),
    .channel:nth-child(2) { border-bottom: 1px solid var(--brd); }
  }
  @media (max-width: 560px) {
    .epilogue-channels { grid-template-columns: 1fr; }
    .channel { border-right: none; border-bottom: 1px solid var(--brd); }
    .channel:last-child { border-bottom: none; }
  }

  /* ----------------------------------------------------------------
     IV. TESTIMONIA — editorial wrapper around scrolling reviews wall
     (Reviews wall styles are kept above; this only adds chapter framing.)
     ---------------------------------------------------------------- */
  .testimonia {
    padding-top: clamp(80px, 12vw, 160px);
    padding-bottom: clamp(80px, 12vw, 160px);
    border-top: 1px solid var(--brd);
  }
  .testimonia-head {
    max-width: var(--max-w);
    margin: 0 auto clamp(40px, 6vw, 72px);
    padding: 0 clamp(20px, 4vw, 48px);
  }

  /* ----------------------------------------------------------------
     III. METHOD — 4 ordered steps
     ---------------------------------------------------------------- */
  .method {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px);
    background: var(--bg);
    border-top: 1px solid var(--brd);
  }
  .method-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }
  .method-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--brd);
  }
  .method-step {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: clamp(24px, 3vw, 40px) clamp(16px, 2.4vw, 32px);
    border-right: 1px solid var(--brd);
    counter-increment: step;
  }
  .method-step:last-child { border-right: none; }
  .method-step::before {
    content: '';
    position: absolute;
    top: -1px; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ac), transparent 80%);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .45s var(--ease-silk);
  }
  .method-step:hover::before { transform: scaleX(1); }
  .step-no {
    font: italic 400 28px/1 var(--fd);
    color: var(--ac);
    letter-spacing: 0;
    font-feature-settings: "swsh";
  }
  .step-latin {
    font: 400 10px/1 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--t3);
  }
  .step-h {
    font: 400 clamp(20px, 2vw, 26px)/1.15 var(--fd);
    color: var(--t1);
    letter-spacing: -.01em;
    margin: 0;
    text-wrap: balance;
  }
  .step-p {
    font: 400 14px/1.55 var(--fi);
    color: var(--t2);
    margin: 0;
    flex: 1;
  }
  .step-foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: 16px;
    border-top: 1px solid var(--brd);
    margin-top: auto;
  }
  .step-foot-l {
    font: 400 9px/1 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--t3);
  }
  .step-foot-v {
    font: italic 400 14px/1 var(--fd);
    color: var(--ac);
    font-feature-settings: "swsh";
  }
  @media (max-width: 1000px) {
    .method-steps { grid-template-columns: 1fr 1fr; }
    .method-step:nth-child(2) { border-right: none; }
    .method-step:nth-child(1),
    .method-step:nth-child(2) { border-bottom: 1px solid var(--brd); }
  }
  @media (max-width: 640px) {
    .method-steps { grid-template-columns: 1fr; }
    .method-step { border-right: none; border-bottom: 1px solid var(--brd); }
    .method-step:last-child { border-bottom: none; }
  }

  /* ----------------------------------------------------------------
     STATS STRIP — editorial column row below hero
     ---------------------------------------------------------------- */
  .stats-strip {
    padding: clamp(56px, 8vw, 96px) 24px 0;
    background: var(--bg);
  }
  .stats-strip-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 4vw, 56px);
    padding: clamp(28px, 4vw, 40px) 0;
    border-top: 1px solid var(--brd);
    border-bottom: 1px solid var(--brd);
    position: relative;
  }
  .stats-strip-inner::before,
  .stats-strip-inner::after {
    content: '';
    position: absolute;
    left: 20%; right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ac-line), transparent);
    pointer-events: none;
  }
  .stats-strip-inner::before { top: -1px; }
  .stats-strip-inner::after  { bottom: -1px; }

  .stat-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
  }
  .stat-lbl {
    font: 400 10px/1 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--t3);
  }
  .stat-val {
    font: 400 clamp(32px, 4.4vw, 54px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: -.01em;
    font-feature-settings: "lnum", "tnum";
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .stat-val .it {
    font-style: italic;
    color: var(--ac);
    font-weight: 400;
    font-size: .65em;
    margin-left: 6px;
    font-feature-settings: "swsh";
  }
  .stat-val .stat-suffix {
    font-size: .55em;
    color: var(--t3);
    margin-left: 2px;
    letter-spacing: .04em;
  }
  .stat-val .stat-sep {
    color: var(--ac);
    font-style: italic;
    margin-right: 4px;
  }
  .stat-note {
    font: 400 13px/1.4 var(--fi);
    color: var(--t3);
    max-width: 22ch;
  }

  /* Risk #2 fix: explicit handling of 640–900px gap (was missing) */
  @media (max-width: 900px) {
    .stats-strip-inner {
      grid-template-columns: 1fr 1fr;
      gap: 28px 32px;
    }
    .stat-col:last-child {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--brd);
    }
    .stat-col:last-child .stat-note { max-width: none; text-align: right; }
  }
  @media (max-width: 560px) {
    .stats-strip { padding-top: 48px; padding-left: 20px; padding-right: 20px; }
    .stats-strip-inner {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .stat-col {
      padding: 18px 0;
      border-bottom: 1px solid var(--brd);
    }
    .stat-col:last-child {
      flex-direction: column;
      align-items: flex-start;
      border-bottom: none;
      border-top: none;
      padding-top: 18px;
    }
    .stat-col:last-child .stat-note { text-align: left; }
  }

  /* ----------------------------------------------------------------
     LIGHT THEME OVERRIDES
     ---------------------------------------------------------------- */
  :global([data-theme="light"]) .hero-glow {
    background:
      radial-gradient(ellipse 55% 45% at 50% 48%, rgba(180,145,30,.12) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 48% 44%, rgba(180,145,30,.08) 0%, transparent 50%),
      radial-gradient(ellipse 75% 55% at 42% 52%, rgba(160,120,15,.05) 0%, transparent 75%);
  }

  :global([data-theme="light"]) .hero-search-input {
    background: rgba(0,0,0,.03);
    border-color: rgba(0,0,0,.1);
  }

  :global([data-theme="light"]) .hero-search-input:focus {
    border-color: var(--ac-b);
    background: rgba(0,0,0,.04);
  }

  :global([data-theme="light"]) .card {
    background: #fff;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-color: var(--brd);
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }

  :global([data-theme="light"]) .card:hover {
    box-shadow: 0 12px 40px rgba(0,0,0,.1), 0 0 0 1px rgba(212,175,55,.12);
  }

  :global([data-theme="light"]) .rw-img {
    border-color: rgba(0,0,0,.08);
  }

  :global([data-theme="light"]) .rw-img:hover {
    border-color: rgba(122,95,18,.2);
  }

  /* ----------------------------------------------------------------
     REDUCED MOTION
     ---------------------------------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    .word,
    .hero-sub,
    .hero-search,
    .hero-actions {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .hero-glow {
      animation: none;
      opacity: .8;
      transform: translate(-50%, -50%);
    }

    .rw-track {
      animation: none !important;
    }

    .rv {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ----------------------------------------------------------------
     TABLET (max 900px)
     ---------------------------------------------------------------- */
  @media (max-width: 900px) {
    .catalog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ----------------------------------------------------------------
     MOBILE (max 639px)
     ---------------------------------------------------------------- */
  @media (max-width: 639px) {
    .reviews,
    .catalog {
      padding: 64px 20px;
    }

    .catalog-grid {
      grid-template-columns: 1fr;
    }

    /* Smaller review images on mobile */
    .rw-img {
      height: 160px;
    }

    .reviews-wall {
      gap: 8px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .hero-actions .btn {
      width: 100%;
      max-width: 320px;
    }

    .foot {
      padding: 48px 20px;
    }

    .reviews-head {
      margin-bottom: 32px;
    }
  }

  /* ================================================================
     PRELUDE — Dark Couture hero (step 2.1)
     New class namespace (*-2 / prelude-h / prelude-scroll-cue) to
     avoid conflicts with legacy .prelude-* rules still used by the
     Epilogue block higher in this file.
     ================================================================ */
  .prelude {
    position: relative;
    min-height: 100svh;
    padding: calc(var(--nav-h) + 48px) 0 120px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    background: var(--ink);
    color: var(--cream);
  }
  .prelude-wrap {
    max-width: var(--wrap-wide);
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
    position: relative;
    z-index: 1;
    width: 100%;
  }

  /* ── 3-column head ── */
  .prelude-head {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 4vw, 48px);
    padding: 12px 0 32px;
    border-bottom: 1px solid var(--line);
    margin-bottom: clamp(48px, 8vw, 96px);
  }
  .prelude-head .col {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .prelude-head .lbl {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .prelude-head .val {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--cream);
  }
  .prelude-head .val .it {
    font-style: italic;
    color: var(--gold);
  }
  @media (max-width: 720px) {
    .prelude-head {
      grid-template-columns: 1fr;
      gap: 20px;
      padding-bottom: 20px;
      margin-bottom: 48px;
    }
  }

  /* ── Eyebrow: decorative "Prelude" ── */
  .prelude-eyebrow-2 {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 24px;
  }
  .prelude-eyebrow-2 .rule {
    width: 28px;
    height: 1px;
    background: var(--gold);
  }
  .prelude-eyebrow-2 .word {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
  }

  /* ── Title: clamp lower bound so long words don't overflow 375px, upper bound caps 4K ── */
  .prelude-h {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(40px, 9vw, 140px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: var(--cream);
    margin: 0 0 clamp(40px, 6vw, 72px);
    max-width: 18ch;
    text-wrap: balance;
    overflow-wrap: break-word;
    word-break: normal;
    hyphens: auto;
  }
  .prelude-h .ln {
    display: block;
  }
  .prelude-h .it {
    font-style: italic;
    color: var(--gold);
    font-feature-settings: "swsh";
    font-weight: 400;
  }

  /* ── Foot: lede + actions (two columns on desktop, stacked on mobile) ── */
  .prelude-foot {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(32px, 4vw, 56px);
    align-items: end;
    padding-top: 32px;
    border-top: 1px solid var(--line);
  }
  .prelude-lede-2 {
    max-width: 52ch;
    font-family: var(--serif);
    font-size: clamp(17px, 1.5vw, 21px);
    font-weight: 400;
    line-height: 1.5;
    color: var(--cream-2);
    margin: 0;
  }
  .prelude-lede-2 em {
    font-style: italic;
    color: var(--gold);
    font-feature-settings: "swsh";
  }
  .prelude-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .prelude-actions .btn {
    text-align: center;
  }
  @media (max-width: 900px) {
    .prelude-foot {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .prelude-actions .btn {
      flex: 1 1 auto;
    }
  }

  /* ── Scroll cue ── */
  .prelude-scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 28px;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: var(--mute);
    text-decoration: none;
    transition: color .4s var(--ease-silk);
  }
  .prelude-scroll-cue:hover { color: var(--gold); }
  .prelude-scroll-cue .lbl {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }
  .prelude-scroll-cue .line {
    width: 1px;
    height: 54px;
    background: linear-gradient(180deg, transparent, var(--gold));
  }
  @media (max-width: 720px) {
    .prelude-scroll-cue { display: none; }
  }

  /* ================================================================
     MANIFESTO — Dark Couture editorial (step 2.2)
     Overrides earlier .manifesto-* rules above (same specificity,
     later rules win). Left-aligned body becomes centered editorial
     column with gold hairlines above/below and bigger Cormorant.
     ================================================================ */
  .manifesto-body {
    max-width: 940px;
    margin: 0 auto;
    padding: 80px clamp(20px, 4vw, 40px);
    position: relative;
    text-align: center;
  }
  .manifesto-body::before,
  .manifesto-body::after {
    content: "";
    position: absolute;
    left: 50%;
    width: 1px;
    height: 48px;
    background: linear-gradient(var(--gold), transparent);
    transform: translateX(-50%);
  }
  .manifesto-body::before { top: 0; }
  .manifesto-body::after {
    bottom: 0;
    background: linear-gradient(transparent, var(--gold));
  }

  .manifesto-text {
    font-family: var(--fd);
    font-weight: 300;
    font-size: clamp(20px, 1.9vw, 28px);
    line-height: 1.45;
    color: var(--cream-2);
    text-align: center;
    letter-spacing: -0.005em;
    margin: 0;
  }
  .manifesto-text + .manifesto-text { margin-top: 28px; }
  .manifesto-text .it {
    font-style: italic;
    color: var(--gold);
    font-feature-settings: "swsh";
  }

  .manifesto-drop {
    font-family: var(--fd);
    font-style: italic;
    font-weight: 500;
    font-size: 4.2em;
    line-height: 0.85;
    float: left;
    margin: 0.05em 0.08em 0 0;
    color: var(--gold);
    font-feature-settings: "swsh";
  }

  .manifesto-signature {
    margin-top: 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .manifesto-signature .sig {
    font-family: var(--fd);
    font-style: italic;
    font-weight: 500;
    font-size: 48px;
    color: var(--gold);
    line-height: 1;
    letter-spacing: 0.02em;
    font-feature-settings: "swsh";
    transform: rotate(-4deg);
  }
  .manifesto-signature .under {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--mute);
  }

  /* Tenets — flat grid with hairline separators, hover-bar */
  .manifesto-tenets {
    margin-top: clamp(80px, 10vw, 120px);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    padding: 0;
    background: var(--line);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .tenet {
    background: var(--ink);
    padding: clamp(36px, 4vw, 56px) clamp(24px, 3vw, 40px);
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    transition: background .6s var(--ease-silk);
  }
  .tenet:hover { background: var(--ink-2); }
  .tenet::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold);
    transition: width .8s var(--ease-silk);
  }
  .tenet:hover::before { width: 100%; }
  .tenet-num {
    font: italic 400 14px/1 var(--fd);
    color: var(--gold);
    letter-spacing: 0.02em;
    font-feature-settings: "swsh";
  }
  .tenet-h {
    font-family: var(--fd);
    font-size: clamp(22px, 2vw, 28px);
    font-weight: 500;
    color: var(--cream);
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0;
  }
  .tenet-p {
    font-family: var(--fd);
    font-size: 17px;
    line-height: 1.55;
    color: var(--mute);
    font-weight: 400;
    letter-spacing: 0.005em;
    font-style: italic;
    margin: 0;
  }
  .tenet-p .it {
    font-style: italic;
    color: var(--gold);
    font-feature-settings: "swsh";
  }

  @media (max-width: 900px) {
    .manifesto-tenets { grid-template-columns: 1fr; }
    .manifesto-body { padding: 56px 0; }
  }

  /* ================================================================
     CALENDAR — decorative 12-month load timeline (step 2.3)
     No legacy .calendar-* collisions, classes ported 1-to-1 from
     bundle. Cells are inert (role=listitem, no cursor/click).
     ================================================================ */
  .calendar {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px);
    background: var(--ink);
    position: relative;
  }
  .calendar-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
  }

  .calendar-intro {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: clamp(32px, 5vw, 60px);
    align-items: end;
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--line);
  }
  .calendar-legend {
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .calendar-legend .row {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .calendar-legend .dot {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
    border-radius: 50%;
  }
  .calendar-legend .dot.free {
    background: var(--gold);
    box-shadow: 0 0 8px var(--gold-glow);
  }
  .calendar-legend .dot.tight { background: var(--cream-3); }
  .calendar-legend .dot.closed {
    background: var(--mute-2);
    border: 1px solid var(--mute);
    box-sizing: border-box;
  }

  .calendar-track {
    position: relative;
    padding: 60px 0;
  }
  .calendar-track::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-line) 8%, var(--gold-line) 92%, transparent);
  }

  .calendar-months {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 0;
    position: relative;
  }
  .month {
    position: relative;
    padding: 10px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform .6s var(--ease-silk);
    min-width: 0;
  }
  .month:hover { transform: translateY(-2px); }

  .month-name {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(14px, 1.2vw, 17px);
    color: var(--cream);
    margin-bottom: 36px;
    line-height: 1;
    transition: color .4s;
  }
  .month.closed .month-name { color: var(--mute); }
  .month:hover .month-name { color: var(--gold); }

  .month-node {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 14px;
    height: 14px;
    background: var(--ink);
    border: 1px solid var(--gold-line);
    border-radius: 50%;
    transition: transform .4s var(--ease-silk), box-shadow .4s;
    z-index: 2;
  }
  .month.free .month-node {
    background: var(--gold);
    border-color: var(--gold);
    box-shadow: 0 0 0 4px rgba(201, 162, 76, 0.15), 0 0 20px var(--gold-glow);
  }
  .month.tight .month-node {
    background: var(--cream-3);
    border-color: var(--cream-3);
    box-shadow: 0 0 0 3px rgba(200, 188, 160, 0.12);
  }
  .month.closed .month-node {
    background: var(--mute-2);
    border-color: var(--mute);
  }
  .month:hover .month-node { transform: translate(-50%, -50%) scale(1.4); }

  .month-stat {
    margin-top: 36px;
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mute);
    line-height: 1.3;
    padding: 0 4px;
  }
  .month-stat b {
    font-family: var(--fd);
    font-style: italic;
    font-size: 14px;
    color: var(--gold);
    font-weight: 400;
    display: block;
    letter-spacing: 0;
    margin-bottom: 4px;
    text-transform: none;
  }
  .month.closed .month-stat b { color: var(--mute); }

  .month-bar {
    margin-top: 8px;
    width: 70%;
    height: 2px;
    background: var(--line-2);
    position: relative;
    overflow: hidden;
  }
  .month-bar::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: var(--booked, 40%);
    background: var(--gold);
  }
  .month.closed .month-bar::before { background: var(--mute); }
  .month.tight .month-bar::before { background: var(--cream-3); }

  @media (max-width: 1000px) {
    .calendar-months { grid-template-columns: repeat(6, 1fr); gap: 40px 0; }
    .calendar-track::before { display: none; }
  }
  @media (max-width: 600px) {
    .calendar-months { grid-template-columns: repeat(3, 1fr); gap: 32px 0; }
    .month-name { margin-bottom: 28px; }
    .month-stat { margin-top: 28px; font-size: 8px; }
  }
  @media (max-width: 900px) {
    .calendar-intro { grid-template-columns: 1fr; gap: 24px; }
  }

  /* Bottom hint card */
  .calendar-hint {
    margin-top: clamp(48px, 6vw, 72px);
    padding: clamp(28px, 4vw, 40px);
    border: 1px solid var(--gold-line);
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 32px;
    align-items: center;
    background: linear-gradient(180deg, var(--gold-soft), transparent);
    position: relative;
  }
  .calendar-hint::before {
    content: "";
    position: absolute;
    top: 0;
    left: 20px;
    width: 32px;
    height: 1px;
    background: var(--gold);
  }
  .calendar-hint .roman {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(48px, 6vw, 60px);
    line-height: 0.9;
    color: var(--gold);
  }
  .calendar-hint .body h3 {
    font-family: var(--fd);
    font-weight: 500;
    font-size: clamp(20px, 2vw, 26px);
    margin-bottom: 8px;
    color: var(--cream);
    letter-spacing: -0.01em;
  }
  .calendar-hint .body p {
    font-family: var(--fd);
    font-size: 15px;
    font-style: italic;
    color: var(--cream-2);
    margin: 0;
  }
  @media (max-width: 720px) {
    .calendar-hint {
      grid-template-columns: 1fr;
      text-align: left;
      padding: 24px;
      gap: 18px;
    }
    .calendar-hint .btn { justify-self: start; }
  }

  /* ================================================================
     GENRES — editorial 8-row list with real pricing (step 2.4)
     No legacy .genres-* collisions. Ported 1-to-1 from bundle.
     ================================================================ */
  .genres {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px);
    background: var(--ink);
    position: relative;
  }
  .genres-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
  }

  .genres-index {
    display: grid;
    grid-template-columns: 56px 1.3fr 2fr 1fr auto;
    gap: 32px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
    align-items: baseline;
  }
  .genres-index .t-right { text-align: right; }

  .genres-list {
    display: flex;
    flex-direction: column;
  }

  .genre {
    display: grid;
    grid-template-columns: 56px 1.3fr 2fr 1fr auto;
    gap: 32px;
    padding: 32px 0;
    border-bottom: 1px solid var(--line);
    align-items: center;
    position: relative;
    text-decoration: none;
    color: inherit;
  }
  .genre::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent, var(--gold-soft) 50%, transparent);
    opacity: 0;
    transition: opacity .6s var(--ease-silk);
    pointer-events: none;
  }
  .genre:hover .genre-no { transform: translateX(8px); color: var(--gold); opacity: 1; }
  .genre:hover::before { opacity: 1; }
  .genre:hover .genre-name { color: var(--gold); }
  .genre:hover .genre-arrow {
    transform: translateX(8px);
    color: var(--gold);
    border-color: var(--gold-line);
  }

  .genre-no {
    font-family: var(--fd);
    font-style: italic;
    font-size: 22px;
    color: var(--gold);
    line-height: 1;
    font-feature-settings: "swsh";
    opacity: 0.75;
    transition: transform .5s var(--ease-silk), opacity .4s, color .4s;
  }
  .genre-meta { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
  .genre-latin {
    font-family: var(--fd);
    font-style: italic;
    font-size: 13px;
    color: var(--mute);
    line-height: 1;
  }
  .genre-name {
    font-family: var(--fd);
    font-size: clamp(24px, 2.4vw, 38px);
    font-weight: 400;
    color: var(--cream);
    line-height: 1.05;
    letter-spacing: -0.02em;
    transition: color .5s var(--ease-silk);
  }
  .genre-desc {
    font-family: var(--fd);
    font-size: 16px;
    line-height: 1.5;
    color: var(--cream-2);
    letter-spacing: 0.005em;
    max-width: 52ch;
  }
  .genre-pricing {
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-align: right;
    font-feature-settings: "tnum";
  }
  .genre-pricing .pre {
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .genre-pricing .val {
    font-family: var(--fd);
    font-size: clamp(22px, 2.2vw, 28px);
    color: var(--cream);
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .genre-pricing .cur {
    font-style: italic;
    color: var(--gold);
    font-size: 0.75em;
  }
  .genre-arrow {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line-2);
    border-radius: 50%;
    transition: transform .5s var(--ease-silk), color .5s, border-color .5s;
    color: var(--cream);
    flex-shrink: 0;
  }
  .genre-arrow svg { width: 14px; height: 14px; }

  @media (max-width: 960px) {
    .genres-index { display: none; }
    .genre {
      grid-template-columns: 36px 1fr auto;
      grid-template-areas:
        "no name price"
        ".  desc desc";
      gap: 10px 20px;
      padding: 24px 0;
    }
    .genre-no   { grid-area: no; font-size: 18px; }
    .genre-meta { grid-area: name; }
    .genre-desc { grid-area: desc; font-size: 14px; line-height: 1.5; }
    .genre-pricing { grid-area: price; }
    .genre-arrow   { display: none; }
  }

  /* genres-note card */
  .genres-note {
    margin-top: clamp(48px, 6vw, 72px);
    padding: clamp(28px, 4vw, 44px);
    border: 1px solid var(--line);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 32px;
    align-items: center;
  }
  .genres-note-text {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(17px, 1.6vw, 20px);
    line-height: 1.5;
    color: var(--cream-2);
    max-width: 60ch;
  }
  .genres-note-text .it { color: var(--gold); font-style: italic; }
  .genres-note .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .genres-note .btn svg { width: 12px; height: 12px; }

  @media (max-width: 720px) {
    .genres-note { grid-template-columns: 1fr; padding: 24px; }
    .genres-note .btn { justify-self: start; }
  }

  /* ================================================================
     FORMULA — calculator scaffold (step 2.5, ported 1-to-1 from
     bundle css/05-genres-formula-archive.css). No JS wiring yet.
     ================================================================ */
  .formula {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px);
    background: var(--ink);
    position: relative;
  }
  .formula-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
  }

  .formula-stage {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 1px;
    background: var(--line-2);
    border: 1px solid var(--line-2);
    position: relative;
  }
  @media (max-width: 1100px) {
    .formula-stage { grid-template-columns: 1fr; }
  }

  .formula-left {
    background: var(--ink);
    padding: clamp(32px, 5vw, 64px);
    display: flex;
    flex-direction: column;
    gap: 44px;
  }

  .formula-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 28px;
    align-items: start;
    padding-bottom: 36px;
    border-bottom: 1px solid var(--line);
  }
  .formula-row:last-child { border-bottom: 0; padding-bottom: 0; }

  .formula-row-label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 4px;
  }
  .formula-row-label .n {
    font-family: var(--fd);
    font-style: italic;
    font-size: 32px;
    color: var(--gold);
    line-height: 1;
    font-feature-settings: "swsh";
  }
  .formula-row-label .t {
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  @media (max-width: 640px) {
    .formula-row { grid-template-columns: 1fr; gap: 14px; }
  }

  .formula-options {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .formula-opt {
    padding: 12px 18px;
    background: transparent;
    border: 1px solid var(--line-2);
    color: var(--cream-2);
    font-family: var(--fi);
    font-size: 13px;
    font-weight: 400;
    cursor: pointer;
    position: relative;
    transition: color .45s var(--ease-silk), border-color .45s;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    line-height: 1;
    overflow: hidden;
    isolation: isolate;
  }
  .formula-opt::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--gold-soft);
    transform: translateY(101%);
    transition: transform .5s var(--ease-kine);
    z-index: -1;
  }
  .formula-opt:hover { border-color: var(--gold-line); color: var(--cream); }
  .formula-opt:hover::before { transform: translateY(0); }
  .formula-opt .p {
    font-family: var(--fm);
    font-size: 10px;
    color: var(--mute);
    letter-spacing: 0.08em;
  }
  .formula-opt.is-active {
    background: var(--cream);
    border-color: var(--cream);
    color: var(--ink);
  }
  .formula-opt.is-active .p { color: var(--gold-deep); }
  .formula-opt.is-active::before { display: none; }

  /* Slider */
  .formula-slider {
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
  }
  .formula-slider .readout {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 20px;
  }
  .formula-slider .pages {
    font-family: var(--fd);
    font-size: clamp(32px, 3.5vw, 44px);
    line-height: 1;
    color: var(--cream);
    letter-spacing: -0.02em;
    font-feature-settings: "tnum";
  }
  .formula-slider .pages small {
    font-family: var(--fd);
    font-style: italic;
    color: var(--gold);
    font-size: 18px;
    margin-left: 8px;
    letter-spacing: 0;
  }
  .formula-slider .bounds {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .formula-slider input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 2px;
    background: linear-gradient(
      90deg,
      var(--gold) 0%,
      var(--gold) var(--fill, 30%),
      var(--line-2) var(--fill, 30%),
      var(--line-2) 100%
    );
    outline: none;
    cursor: pointer;
  }
  .formula-slider input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 14px;
    height: 14px;
    background: var(--gold);
    border: 3px solid var(--ink);
    box-shadow: 0 0 0 1px var(--gold), 0 0 16px var(--gold-glow);
    cursor: pointer;
    border-radius: 50%;
    transition: transform .3s;
  }
  .formula-slider input[type="range"]::-webkit-slider-thumb:hover { transform: scale(1.2); }
  .formula-slider input[type="range"]::-moz-range-thumb {
    width: 14px;
    height: 14px;
    background: var(--gold);
    border: 3px solid var(--ink);
    box-shadow: 0 0 0 1px var(--gold);
    cursor: pointer;
    border-radius: 50%;
  }

  /* Right — receipt */
  .formula-right {
    background: var(--ink-2);
    padding: clamp(32px, 5vw, 64px);
    display: flex;
    flex-direction: column;
    gap: 28px;
    position: relative;
    overflow: hidden;
  }
  .formula-right::before {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, transparent, var(--gold-line), transparent);
  }

  .formula-receipt-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 18px;
    border-bottom: 1px dashed var(--line-2);
  }
  .formula-receipt-head .t {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .formula-receipt-head .d {
    font-family: var(--fd);
    font-size: 14px;
    color: var(--cream-2);
  }
  .formula-receipt-head .it {
    font-style: italic;
    color: var(--gold);
  }

  .formula-receipt-rows {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex-grow: 1;
    font-family: var(--fd);
    min-height: 120px;
  }
  .receipt-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 18px;
    align-items: baseline;
    font-size: 15px;
    color: var(--cream-2);
    padding: 4px 0;
    position: relative;
  }
  .receipt-row .k {
    font-style: italic;
    display: flex;
    align-items: baseline;
    gap: 10px;
    min-width: 0;
  }
  .receipt-row .k::after {
    content: "";
    flex-grow: 1;
    border-bottom: 1px dotted var(--line-2);
    transform: translateY(-4px);
    margin: 0 4px;
  }
  .receipt-row .v {
    color: var(--cream);
    font-feature-settings: "tnum";
    font-size: 15px;
    white-space: nowrap;
  }
  .receipt-row.sub .v {
    color: var(--gold);
    font-style: italic;
  }

  .formula-total {
    padding-top: 24px;
    border-top: 1px solid var(--gold-line);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .formula-total .label {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .formula-total .amount {
    font-family: var(--fd);
    font-size: clamp(40px, 5vw, 64px);
    color: var(--cream);
    line-height: 1;
    letter-spacing: -0.02em;
    font-feature-settings: "tnum", "onum";
    font-weight: 400;
  }
  .formula-total .amount .cur {
    font-style: italic;
    color: var(--gold);
    font-size: 0.5em;
  }

  .formula-cta {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .formula-cta .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  .formula-cta .btn svg { width: 14px; height: 14px; }
  .formula-whisper {
    font-family: var(--fd);
    font-style: italic;
    font-size: 14px;
    color: var(--mute);
    line-height: 1.45;
    text-align: center;
    margin: 0;
  }
  .formula-whisper::before { content: "⁓ "; color: var(--gold); }
  .formula-whisper::after  { content: " ⁓"; color: var(--gold); }

  /* ================================================================
     ARCHIVE — editorial list with 10-category filter (step 2.7)
     Ported 1-to-1 from bundle. No legacy .archive-row/* collisions.
     ================================================================ */
  .archive {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px);
    background: var(--ink);
    position: relative;
  }
  .archive-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
  }
  .chapter-lede .archive-total {
    color: var(--gold);
    font-family: var(--fi);
    font-style: normal;
    font-weight: 500;
    font-feature-settings: "tnum";
  }

  /* Filters + counter */
  .archive-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
    gap: 24px;
    flex-wrap: wrap;
  }
  .archive-filters {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    max-width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .archive-filters::-webkit-scrollbar { display: none; }
  .archive-filter {
    padding: 10px 14px;
    background: transparent;
    border: 1px solid transparent;
    color: var(--mute);
    font-family: var(--fi);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color .4s var(--ease-silk), border-color .4s;
    line-height: 1;
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    white-space: nowrap;
  }
  .archive-filter:hover { color: var(--cream); }
  .archive-filter.is-active {
    color: var(--gold);
    border-color: var(--gold-line);
  }
  .archive-filter .ft-n {
    font-family: var(--fd);
    font-style: italic;
    font-size: 12px;
    color: var(--mute);
    letter-spacing: 0;
    text-transform: none;
    font-feature-settings: "tnum";
  }
  .archive-filter.is-active .ft-n { color: var(--gold); }
  .archive-count {
    font-family: var(--fd);
    font-style: italic;
    font-size: 15px;
    color: var(--mute);
    white-space: nowrap;
  }
  .archive-count b {
    color: var(--gold);
    font-style: normal;
    font-family: var(--fi);
    font-feature-settings: "tnum";
    font-weight: 500;
    font-size: 13px;
    padding: 0 2px;
  }

  /* Header index row + list */
  .archive-index {
    display: grid;
    grid-template-columns: 72px 2fr 1fr 1fr 80px;
    gap: 20px;
    padding: 12px 20px;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
    border-bottom: 1px solid var(--line);
  }
  .archive-index .t-right { text-align: right; }
  @media (max-width: 900px) {
    .archive-index { display: none; }
  }

  .archive-list {
    display: flex;
    flex-direction: column;
  }
  .archive-row {
    display: grid;
    grid-template-columns: 72px 2fr 1fr 1fr 80px;
    gap: 20px;
    padding: 20px;
    border-bottom: 1px solid var(--line);
    align-items: center;
    transition: background .4s var(--ease-silk);
    position: relative;
    text-decoration: none;
    color: inherit;
  }
  .archive-row::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--gold);
    transform: scaleY(0);
    transition: transform .5s var(--ease-silk);
  }
  .archive-row:hover::before { transform: scaleY(1); }
  .archive-row:hover { background: var(--gold-soft); }
  .archive-row:hover .archive-title { color: var(--gold); transform: translateX(6px); }
  .archive-title { transition: color .4s var(--ease-silk), transform .4s var(--ease-silk); }

  .archive-no {
    font-family: var(--fd);
    font-style: italic;
    font-size: 15px;
    color: var(--mute);
    font-feature-settings: "tnum";
    line-height: 1;
  }
  .archive-title {
    font-family: var(--fd);
    font-size: clamp(16px, 1.3vw, 19px);
    color: var(--cream);
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: -0.005em;
    transition: color .4s;
  }
  .archive-type {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .archive-field {
    font-family: var(--fd);
    font-style: italic;
    font-size: 14px;
    color: var(--cream-2);
  }
  .archive-year {
    font-family: var(--fd);
    font-style: italic;
    font-size: 14px;
    color: var(--mute);
    text-align: right;
    font-feature-settings: "onum";
    white-space: nowrap;
  }
  .archive-year .star {
    color: var(--gold);
    margin-right: 4px;
    font-style: normal;
  }

  @media (max-width: 900px) {
    .archive-row {
      grid-template-columns: auto 1fr auto;
      grid-template-areas:
        "no title year"
        ".  meta  meta";
      gap: 6px 12px;
      padding: 16px 0;
    }
    .archive-no { grid-area: no; }
    .archive-title { grid-area: title; font-size: 15px; }
    .archive-year { grid-area: year; }
    .archive-type, .archive-field { grid-area: meta; display: inline; }
    .archive-type { margin-right: 10px; }
  }

  .archive-empty {
    padding: 48px 20px;
    text-align: center;
    font-family: var(--fd);
    font-style: italic;
    font-size: 17px;
    color: var(--cream-2);
    border-bottom: 1px solid var(--line);
  }
  .archive-empty a {
    color: var(--gold);
    border-bottom: 1px solid var(--gold-line);
  }

  .archive-foot {
    margin-top: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
  }
  .archive-foot-line {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(16px, 1.6vw, 18px);
    color: var(--cream-2);
  }
  .archive-foot-line b {
    color: var(--gold);
    font-weight: 400;
    font-style: normal;
    font-family: var(--fi);
    font-feature-settings: "tnum";
    font-size: 15px;
    padding: 0 2px;
  }
  .archive-foot .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .archive-foot .btn svg { width: 12px; height: 12px; }

  /* ================================================================
     METHOD — 5-step editorial tabs (step 2.8)
     Ported from bundle css/06-method-*. All 5 panels are rendered
     for SEO; JS only toggles .is-active + hidden.
     ================================================================ */
  .method {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px);
    background: var(--ink);
    position: relative;
  }
  .method-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
  }

  .method-stage {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    margin-top: 32px;
  }
  @media (max-width: 900px) {
    .method-stage { grid-template-columns: 1fr; }
  }

  .method-nav {
    background: var(--ink);
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .method-tab {
    padding: clamp(24px, 3vw, 36px) clamp(24px, 3vw, 40px);
    border: 0;
    border-bottom: 1px solid var(--line);
    cursor: pointer;
    transition: background .5s var(--ease-silk);
    display: grid;
    grid-template-columns: 56px 1fr auto;
    gap: 20px;
    align-items: center;
    position: relative;
    background: transparent;
    color: inherit;
    font: inherit;
    text-align: left;
    width: 100%;
  }
  .method-tab:last-child { border-bottom: 0; }
  .method-tab::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--gold);
    transform: scaleY(0);
    transition: transform .5s var(--ease-silk);
  }
  .method-tab:hover { background: var(--ink-2); }
  .method-tab:hover .method-tab-no { transform: translateX(6px); opacity: 1; }
  .method-tab.is-active::before { transform: scaleY(1); }
  .method-tab.is-active { background: var(--ink-2); }
  .method-tab.is-active .method-tab-title { color: var(--gold); }

  .method-tab-no {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(28px, 3vw, 36px);
    color: var(--gold);
    line-height: 1;
    opacity: 0.5;
    transition: opacity .5s, transform .5s var(--ease-silk);
  }
  .method-tab.is-active .method-tab-no { opacity: 1; }

  .method-tab-title {
    font-family: var(--fd);
    font-size: clamp(20px, 2vw, 26px);
    color: var(--cream);
    line-height: 1.1;
    letter-spacing: -0.015em;
    transition: color .5s;
  }
  .method-tab-dur {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--mute);
    text-align: right;
    white-space: nowrap;
  }

  .method-pane {
    background: var(--ink-2);
    position: relative;
    display: grid;
  }
  .method-panel {
    grid-column: 1;
    grid-row: 1;
    padding: clamp(28px, 4vw, 56px);
    display: flex;
    flex-direction: column;
    gap: 24px;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity .5s, transform .5s var(--ease-silk);
    pointer-events: none;
  }
  .method-panel.is-active {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
  /* Inactive panels stay in the grid stack (so pane keeps max-height),
     but are visually hidden and not tab-focusable. Hidden attribute from
     JS is ignored here — we drive visibility purely via .is-active. */
  .method-panel[hidden] {
