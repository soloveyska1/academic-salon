---
import Base from '../layouts/Base.astro';
import DocumentCard from '../components/DocumentCard.astro';
import { D } from '../data/catalog.js';

const docCount = D.length;
const categoryMap = new Map();

for (const doc of D) {
  const category = doc.category || 'Без категории';
  categoryMap.set(category, (categoryMap.get(category) || 0) + 1);
}

const categoryStats = Array.from(categoryMap.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6)
  .map(([name, count]) => ({ name, count }));

const maxCategoryCount = categoryStats[0]?.count || 1;

const curatedOrder = [
  'ВКР и дипломы',
  'Курсовые работы',
  'Рефераты',
  'Отчёты по практике',
  'Контрольные работы',
  'Методические материалы',
];

const showcaseDocs = [];
for (const category of curatedOrder) {
  const candidate = D.find((doc) => doc.category === category && !showcaseDocs.includes(doc));
  if (candidate) showcaseDocs.push(candidate);
}
while (showcaseDocs.length < 9) {
  const candidate = D.find((doc) => !showcaseDocs.includes(doc));
  if (!candidate) break;
  showcaseDocs.push(candidate);
}

const collectionDescriptions = {
  'ВКР и дипломы': 'Объемные работы для финальной защиты.',
  'Курсовые работы': 'Быстрый ориентир по структуре и аргументации.',
  'Рефераты': 'Короткие форматы для точечных дедлайнов.',
  'Отчёты по практике': 'Шаблоны и реальные примеры прохождения практики.',
  'Контрольные работы': 'Ответы и разборы под учебные задания.',
  'Методические материалы': 'Нормативка, инструкции и рабочие шаблоны.',
};

const collectionCards = categoryStats.slice(0, 5).map((item, index) => ({
  ...item,
  index,
  ratio: Math.max(18, Math.round((item.count / maxCategoryCount) * 100)),
  description: collectionDescriptions[item.name] || 'Коллекция документов по учебным сценариям.',
}));

const serviceSteps = [
  { title: 'Бриф', note: 'фиксируем тему, дедлайн и критерии' },
  { title: 'Черновик', note: 'согласовываем логику и структуру' },
  { title: 'Финал', note: 'доводим до принятия преподавателем' },
];
---

<Base title="Академический Салон — библиотека «Кладовая ГИПСР»" currentPath="/">
  <section class="hero" id="hero">
    <canvas id="vaultCanvas" class="vault-canvas" aria-hidden="true"></canvas>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>

    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="hero-kicker" data-reveal>Кладовая ГИПСР • цифровой архив</p>
        <h1 class="hero-title" data-reveal data-delay="80">
          Библиотека работ,
          <span>которая выглядит как вау.</span>
        </h1>
        <p class="hero-sub" data-reveal data-delay="140">
          Берёшь готовое из фонда. Если нужен текст под конкретного преподавателя, включаем авторский режим.
        </p>

        <div class="hero-actions" data-reveal data-delay="200">
          <a href="/catalog" class="btn btn-primary">Открыть библиотеку</a>
          <a href="/order" class="btn btn-secondary">Индивидуальная работа</a>
        </div>

        <div class="hero-facts" data-reveal data-delay="250">
          <div class="hero-fact">
            <span class="hero-fact-v">{docCount}+</span>
            <span class="hero-fact-l">документов</span>
          </div>
          <div class="hero-fact">
            <span class="hero-fact-v">6+ лет</span>
            <span class="hero-fact-l">истории Кладовой</span>
          </div>
          <div class="hero-fact">
            <span class="hero-fact-v">50/50</span>
            <span class="hero-fact-l">модель оплаты заказа</span>
          </div>
        </div>
      </div>

      <aside class="hero-meter" id="heroMeter" data-reveal data-delay="120">
        <div class="hero-meter-head">
          <span>Структура фонда</span>
          <strong>{docCount}</strong>
        </div>

        <ol class="hero-meter-list">
          {categoryStats.map((item, index) => (
            <li class="hero-meter-item" style={`--ratio:${Math.max(16, Math.round((item.count / maxCategoryCount) * 100))}%; --delay:${index * 70}ms`}>
              <div class="hero-meter-row">
                <span>{item.name}</span>
                <b>{item.count}</b>
              </div>
              <span class="hero-meter-track" aria-hidden="true">
                <span class="hero-meter-fill"></span>
              </span>
            </li>
          ))}
        </ol>

        <p class="hero-meter-note">Фокус сайта: библиотека в первом экране, услуги — деликатно ниже.</p>
      </aside>
    </div>
  </section>

  <section class="collections" id="collections">
    <div class="container collections-head">
      <p class="section-label" data-reveal>Коллекции</p>
      <a href="/catalog" class="collections-link" data-reveal data-delay="80">Весь каталог →</a>
    </div>

    <div class="collections-scroll" data-reveal data-delay="120">
      <div class="collections-track">
        {collectionCards.map((card) => (
          <article class="collection-card" data-collection-card>
            <div class="collection-top">
              <span class="collection-index">{String(card.index + 1).padStart(2, '0')}</span>
              <span class="collection-count">{card.count} документов</span>
            </div>
            <h3>{card.name}</h3>
            <p>{card.description}</p>
            <span class="collection-line" aria-hidden="true">
              <span style={`width:${card.ratio}%`}></span>
            </span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="showcase" id="showcase">
    <div class="container">
      <div class="showcase-head">
        <p class="section-label" data-reveal>Примеры из архива</p>
        <a href="/catalog" class="showcase-link" data-reveal data-delay="80">Смотреть всё →</a>
      </div>

      <div class="showcase-grid">
        {showcaseDocs.map((doc, index) => (
          <div
            class:list={[
              'showcase-item',
              {
                'showcase-item--lead': index === 0,
                'showcase-item--wide': index === 1,
              },
            ]}
            data-reveal
            data-delay={Math.min(index * 55, 260)}
          >
            <DocumentCard doc={doc} index={index} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="service" id="service">
    <div class="container">
      <article class="service-card" data-reveal>
        <div class="service-top">
          <p class="section-label">Индивидуальная работа</p>
          <span class="service-badge">бережная продажа</span>
        </div>

        <h2>Если в библиотеке нет нужного формата — пишем под вашу задачу и ведём до принятия.</h2>

        <div class="service-steps">
          {serviceSteps.map((step, index) => (
            <div class="service-step" style={`--i:${index}`}>
              <span class="service-step-n">{String(index + 1).padStart(2, '0')}</span>
              <div>
                <strong>{step.title}</strong>
                <p>{step.note}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="service-actions">
          <a href="/order" class="btn btn-primary">Отправить запрос</a>
          <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost">Telegram →</a>
          <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost">VK →</a>
        </div>
      </article>
    </div>
  </section>

  <section class="final-band" id="finalBand">
    <div class="container final-band-inner" data-reveal>
      <p>Неясно, что выбрать: архив или заказ с нуля? Напиши тему и дедлайн, сориентируем по оптимальному сценарию.</p>
      <a href="/order">Уточнить сейчас →</a>
    </div>
  </section>
</Base>

<style>
  :global(html.index-motion-ready) [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .6s var(--ease), transform .6s var(--ease);
    transition-delay: var(--reveal-delay, 0ms);
  }
  :global(html.index-motion-ready) [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hero,
  .collections,
  .showcase,
  .service,
  .final-band {
    position: relative;
    z-index: 2;
  }

  .hero {
    min-height: calc(100svh - 18px);
    padding: calc(var(--nav-h) + 48px) 0 92px;
    border-bottom: 1px solid rgba(212,175,55,.11);
    overflow: clip;
  }

  .vault-canvas,
  .hero-glow,
  .hero-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .vault-canvas {
    width: 100%;
    height: 100%;
    z-index: 0;
  }
  .hero-glow {
    background:
      radial-gradient(780px 430px at 16% 16%, rgba(212,175,55,.2), transparent 72%),
      radial-gradient(920px 540px at 80% 84%, rgba(246,226,122,.09), transparent 72%);
    z-index: 1;
    mix-blend-mode: screen;
  }
  .hero-grid {
    background-image:
      linear-gradient(rgba(212,175,55,.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212,175,55,.04) 1px, transparent 1px);
    background-size: 58px 58px;
    mask-image: radial-gradient(circle at 52% 35%, rgba(0,0,0,.95) 0%, rgba(0,0,0,.2) 68%, transparent 100%);
    opacity: .32;
    z-index: 1;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(0, .92fr);
    gap: clamp(28px, 4.5vw, 70px);
    align-items: end;
  }

  .hero-kicker {
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--ac3);
    margin-bottom: var(--sp-5);
  }
  .hero-title {
    font-family: var(--fd);
    font-size: clamp(44px, 5.6vw, 82px);
    line-height: 1.02;
    text-wrap: balance;
    max-width: 900px;
  }
  .hero-title span {
    color: var(--ac3);
    text-shadow: 0 0 22px rgba(212,175,55,.25);
  }
  .hero-sub {
    margin-top: var(--sp-6);
    max-width: 620px;
    color: var(--t2);
    font-size: clamp(16px, 1.55vw, 20px);
    line-height: 1.65;
  }

  .hero-actions {
    margin-top: var(--sp-8);
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  .hero-facts {
    margin-top: var(--sp-8);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--sp-4);
    max-width: 760px;
  }
  .hero-fact {
    border-top: 1px solid rgba(212,175,55,.2);
    padding-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .hero-fact-v {
    font-family: var(--fm);
    color: var(--ac3);
    letter-spacing: .4px;
    font-size: 13px;
  }
  .hero-fact-l {
    color: var(--t2);
    font-size: 13px;
  }

  .hero-meter {
    border: 1px solid rgba(212,175,55,.2);
    border-radius: 24px;
    padding: 24px;
    background: linear-gradient(160deg, rgba(17,16,24,.86), rgba(9,8,13,.68));
    backdrop-filter: blur(18px) saturate(1.18);
    box-shadow:
      0 24px 84px rgba(0,0,0,.45),
      inset 0 1px 0 rgba(255,255,255,.08);
    transform: perspective(1200px) rotateX(0deg) rotateY(0deg);
    transition: transform .18s linear;
    will-change: transform;
  }
  .hero-meter-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 12px;
    margin-bottom: 16px;
    border-bottom: 1px solid rgba(212,175,55,.16);
  }
  .hero-meter-head span {
    color: var(--t2);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .hero-meter-head strong {
    color: var(--ac3);
    font-family: var(--fm);
    font-size: 20px;
    letter-spacing: .4px;
  }

  .hero-meter-list {
    list-style: none;
    display: grid;
    gap: 13px;
    padding: 0;
    margin: 0;
  }
  .hero-meter-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 6px;
  }
  .hero-meter-row span {
    color: var(--t1);
    font-size: 14px;
    line-height: 1.3;
  }
  .hero-meter-row b {
    color: var(--ac3);
    font-size: 12px;
    font-family: var(--fm);
    font-weight: 500;
  }

  .hero-meter-track {
    display: block;
    height: 5px;
    border-radius: 999px;
    background: rgba(212,175,55,.08);
    overflow: hidden;
  }
  .hero-meter-fill {
    display: block;
    width: var(--ratio);
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, rgba(212,175,55,.76), rgba(246,226,122,.98));
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform .75s var(--ease-spring);
    transition-delay: var(--delay);
  }
  .hero-meter-item.is-ready .hero-meter-fill {
    transform: scaleX(1);
  }

  .hero-meter-note {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid rgba(212,175,55,.12);
    color: var(--t3);
    font-size: 13px;
    line-height: 1.5;
  }

  .collections {
    padding: 72px 0 42px;
  }
  .collections-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
  }
  .collections-link {
    color: var(--ac3);
    text-decoration: none;
    border-bottom: 1px solid rgba(212,175,55,.4);
    padding-bottom: 2px;
    transition: color .25s var(--ease), border-color .25s var(--ease);
  }
  .collections-link:hover {
    color: var(--ac4);
    border-color: rgba(246,226,122,.7);
  }

  .collections-scroll {
    overflow-x: auto;
    padding: 4px 0 8px;
    scrollbar-width: thin;
    scrollbar-color: rgba(212,175,55,.38) transparent;
  }
  .collections-track {
    padding: 0 var(--sp-8);
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(280px, 26vw);
    gap: 12px;
  }

  .collection-card {
    border: 1px solid rgba(212,175,55,.18);
    border-radius: 18px;
    padding: 20px;
    background: linear-gradient(165deg, rgba(212,175,55,.06), rgba(212,175,55,.02));
    box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
    min-height: 210px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    scroll-snap-align: start;
  }
  .collection-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
  }
  .collection-index {
    font-family: var(--fm);
    font-size: 12px;
    color: var(--ac3);
    letter-spacing: .3px;
  }
  .collection-count {
    font-size: 12px;
    color: var(--t3);
  }
  .collection-card h3 {
    font-family: var(--fd);
    font-size: 28px;
    line-height: 1.05;
    text-wrap: balance;
    min-height: 60px;
  }
  .collection-card p {
    color: var(--t2);
    font-size: 14px;
    line-height: 1.55;
    margin-bottom: auto;
  }

  .collection-line {
    display: block;
    height: 4px;
    border-radius: 999px;
    background: rgba(212,175,55,.08);
    overflow: hidden;
  }
  .collection-line span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, rgba(212,175,55,.76), rgba(246,226,122,.98));
  }

  .showcase {
    padding: 54px 0 88px;
  }
  .showcase-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--sp-4);
    margin-bottom: var(--sp-8);
  }
  .showcase-link {
    color: var(--ac3);
    text-decoration: none;
    border-bottom: 1px solid rgba(212,175,55,.4);
    padding-bottom: 2px;
    transition: color .25s var(--ease), border-color .25s var(--ease);
  }
  .showcase-link:hover {
    color: var(--ac4);
    border-color: rgba(246,226,122,.72);
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }
  .showcase-item--lead,
  .showcase-item--wide {
    grid-column: span 2;
  }

  .showcase-item :global(a.doc-card) {
    height: 100%;
    border-radius: 18px;
    border-color: rgba(212,175,55,.16);
    background: linear-gradient(165deg, rgba(212,175,55,.05), rgba(212,175,55,.02));
    transition: border-color .25s var(--ease), transform .25s var(--ease);
  }
  .showcase-item :global(a.doc-card:hover) {
    border-color: rgba(246,226,122,.4);
    transform: translateY(-2px);
  }

  .service {
    padding: 0 0 82px;
  }
  .service-card {
    border: 1px solid rgba(212,175,55,.2);
    border-radius: 24px;
    padding: clamp(22px, 3vw, 34px);
    background: linear-gradient(160deg, rgba(18,17,24,.84), rgba(10,9,14,.7));
    box-shadow: 0 20px 76px rgba(0,0,0,.35);
  }
  .service-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
  }
  .service-badge {
    display: inline-flex;
    align-items: center;
    padding: 5px 10px;
    border-radius: 999px;
    border: 1px solid rgba(212,175,55,.3);
    color: var(--ac3);
    font-size: 11px;
    letter-spacing: .8px;
    text-transform: uppercase;
  }

  .service-card h2 {
    margin-top: var(--sp-4);
    font-family: var(--fd);
    font-size: clamp(30px, 3.2vw, 48px);
    line-height: 1.14;
    text-wrap: balance;
    max-width: 980px;
  }

  .service-steps {
    margin-top: var(--sp-6);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }
  .service-step {
    border: 1px solid rgba(212,175,55,.14);
    border-radius: 14px;
    padding: 12px;
    background: rgba(212,175,55,.04);
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }
  .service-step-n {
    color: var(--ac3);
    font-family: var(--fm);
    font-size: 12px;
    margin-top: 2px;
  }
  .service-step strong {
    display: block;
    font-size: 15px;
    line-height: 1.2;
    margin-bottom: 4px;
  }
  .service-step p {
    color: var(--t2);
    font-size: 13px;
    line-height: 1.45;
  }

  .service-actions {
    margin-top: var(--sp-7);
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }

  .final-band {
    border-top: 1px solid rgba(212,175,55,.1);
    padding: 28px 0 76px;
  }
  .final-band-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--sp-4);
  }
  .final-band-inner p {
    color: var(--t2);
    font-size: 18px;
    line-height: 1.54;
  }
  .final-band-inner a {
    color: var(--ac3);
    text-decoration: none;
    border-bottom: 1px solid rgba(212,175,55,.4);
    padding-bottom: 2px;
    white-space: nowrap;
    transition: color .25s var(--ease), border-color .25s var(--ease);
  }
  .final-band-inner a:hover {
    color: var(--ac4);
    border-color: rgba(246,226,122,.72);
  }

  @keyframes sd-reveal {
    from {
      opacity: .4;
      transform: translateY(22px) scale(.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @supports (animation-timeline: view()) {
    .collection-card {
      animation: sd-reveal both linear;
      animation-timeline: view();
      animation-range: entry 8% cover 34%;
    }
  }

  @media (max-width: 1200px) {
    .hero-inner {
      grid-template-columns: 1fr;
      align-items: start;
    }
    .hero-meter {
      max-width: 760px;
    }
    .showcase-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .showcase-item--lead,
    .showcase-item--wide {
      grid-column: span 2;
    }
    .service-steps {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 860px) {
    .hero {
      min-height: auto;
      padding-top: calc(var(--nav-h) + 38px);
      padding-bottom: 74px;
    }
    .hero-title {
      font-size: clamp(36px, 9vw, 56px);
    }
    .hero-facts {
      grid-template-columns: 1fr;
      max-width: 100%;
    }

    .collections-track {
      padding: 0 var(--sp-4);
      grid-auto-columns: minmax(260px, 78vw);
    }

    .showcase-grid {
      grid-template-columns: 1fr;
    }
    .showcase-item--lead,
    .showcase-item--wide {
      grid-column: auto;
    }

    .final-band-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .final-band-inner p {
      font-size: 16px;
    }
  }

  @media (max-width: 640px) {
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .hero-actions .btn {
      width: 100%;
      justify-content: center;
    }
    .collections-head,
    .showcase-head,
    .service-top {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  [data-theme='light'] .hero-glow {
    background:
      radial-gradient(760px 430px at 16% 16%, rgba(184,148,42,.2), transparent 72%),
      radial-gradient(880px 500px at 80% 84%, rgba(212,175,55,.1), transparent 72%);
    mix-blend-mode: multiply;
  }
  [data-theme='light'] .hero-grid {
    opacity: .2;
  }
  [data-theme='light'] .hero-meter,
  [data-theme='light'] .service-card {
    box-shadow: var(--shadow);
  }
</style>

<script is:inline>
  (() => {
    let cleanups = [];

    function cleanupAll() {
      cleanups.forEach((fn) => {
        try { fn(); } catch (_) { /* no-op */ }
      });
      cleanups = [];
    }

    function setRevealDelay() {
      const revealNodes = Array.from(document.querySelectorAll('[data-reveal]'));
      revealNodes.forEach((node) => {
        const delay = Number(node.getAttribute('data-delay') || 0);
        node.style.setProperty('--reveal-delay', `${delay}ms`);
      });
      return revealNodes;
    }

    function initRevealFallback() {
      const revealNodes = setRevealDelay();
      if (!revealNodes.length) return;

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const scrollTimelineSupported = CSS.supports('animation-timeline: view()');

      if (reduced || scrollTimelineSupported) {
        revealNodes.forEach((node) => node.classList.add('is-visible'));
        return;
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.16, rootMargin: '0px 0px -40px 0px' });

      revealNodes.forEach((node) => observer.observe(node));
      cleanups.push(() => observer.disconnect());
    }

    function initMeterBars() {
      const meter = document.getElementById('heroMeter');
      if (!meter) return;

      const items = Array.from(meter.querySelectorAll('.hero-meter-item'));
      if (!items.length) return;

      const observer = new IntersectionObserver((entries) => {
        const isVisible = entries.some((entry) => entry.isIntersecting);
        if (!isVisible) return;
        items.forEach((item) => item.classList.add('is-ready'));
        observer.disconnect();
      }, { threshold: 0.36 });

      observer.observe(meter);
      cleanups.push(() => observer.disconnect());
    }

    function initHeroTilt() {
      const hero = document.getElementById('hero');
      const meter = document.getElementById('heroMeter');
      if (!hero || !meter) return;
      if (window.matchMedia('(pointer: coarse)').matches) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      let targetX = 0;
      let targetY = 0;
      let currentX = 0;
      let currentY = 0;
      let rafId = 0;

      const render = () => {
        currentX += (targetX - currentX) * 0.09;
        currentY += (targetY - currentY) * 0.09;

        const rotX = currentY * -6;
        const rotY = currentX * 8;
        meter.style.transform = `perspective(1200px) rotateX(${rotX.toFixed(2)}deg) rotateY(${rotY.toFixed(2)}deg)`;

        if (Math.abs(targetX - currentX) > 0.001 || Math.abs(targetY - currentY) > 0.001) {
          rafId = requestAnimationFrame(render);
        } else {
          rafId = 0;
        }
      };

      const onMove = (event) => {
        const rect = hero.getBoundingClientRect();
        targetX = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
        targetY = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
        if (!rafId) rafId = requestAnimationFrame(render);
      };

      const onLeave = () => {
        targetX = 0;
        targetY = 0;
        if (!rafId) rafId = requestAnimationFrame(render);
      };

      hero.addEventListener('mousemove', onMove, { passive: true });
      hero.addEventListener('mouseleave', onLeave);

      cleanups.push(() => {
        hero.removeEventListener('mousemove', onMove);
        hero.removeEventListener('mouseleave', onLeave);
        if (rafId) cancelAnimationFrame(rafId);
        meter.style.transform = 'perspective(1200px) rotateX(0deg) rotateY(0deg)';
      });
    }

    function initVaultCanvas() {
      const canvas = document.getElementById('vaultCanvas');
      if (!(canvas instanceof HTMLCanvasElement)) return;

      const ctx = canvas.getContext('2d', { alpha: true });
      if (!ctx) return;

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const isMobile = window.matchMedia('(max-width: 860px)').matches;
      const lowPointer = window.matchMedia('(pointer: coarse)').matches;

      const nodeCount = reduced ? 0 : lowPointer ? 34 : isMobile ? 52 : 92;
      const nodes = Array.from({ length: nodeCount }, () => ({
        x: Math.random(),
        y: Math.random(),
        vx: (Math.random() - 0.5) * (lowPointer ? 0.00015 : 0.00026),
        vy: (Math.random() - 0.5) * (lowPointer ? 0.00015 : 0.00026),
        r: Math.random() * 1.8 + 0.8,
        a: Math.random() * 0.55 + 0.2,
      }));

      const pointer = { x: 0.5, y: 0.5, active: false };

      let rafId = 0;
      let width = 0;
      let height = 0;
      let dpr = 1;
      let running = true;

      const resize = () => {
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = canvas.clientWidth;
        height = canvas.clientHeight;
        canvas.width = Math.max(1, Math.floor(width * dpr));
        canvas.height = Math.max(1, Math.floor(height * dpr));
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      };

      const drawBackground = () => {
        const grad = ctx.createRadialGradient(width * 0.25, height * 0.18, 0, width * 0.25, height * 0.18, width * 0.7);
        grad.addColorStop(0, 'rgba(212,175,55,0.16)');
        grad.addColorStop(0.5, 'rgba(212,175,55,0.04)');
        grad.addColorStop(1, 'rgba(212,175,55,0)');
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, width, height);
      };

      const step = () => {
        if (!running) return;

        ctx.clearRect(0, 0, width, height);
        drawBackground();

        for (let i = 0; i < nodes.length; i += 1) {
          const n = nodes[i];

          n.x += n.vx;
          n.y += n.vy;

          if (n.x <= 0 || n.x >= 1) n.vx *= -1;
          if (n.y <= 0 || n.y >= 1) n.vy *= -1;

          if (pointer.active) {
            const px = n.x - pointer.x;
            const py = n.y - pointer.y;
            const dist = Math.sqrt(px * px + py * py) || 1;
            const force = Math.max(0, 0.1 - dist) * 0.0012;
            n.vx += (px / dist) * force;
            n.vy += (py / dist) * force;
          }

          n.vx *= 0.996;
          n.vy *= 0.996;

          const x = n.x * width;
          const y = n.y * height;

          ctx.beginPath();
          ctx.fillStyle = `rgba(246,226,122,${n.a})`;
          ctx.arc(x, y, n.r, 0, Math.PI * 2);
          ctx.fill();
        }

        for (let i = 0; i < nodes.length; i += 1) {
          const a = nodes[i];
          const ax = a.x * width;
          const ay = a.y * height;

          for (let j = i + 1; j < nodes.length; j += 1) {
            const b = nodes[j];
            const bx = b.x * width;
            const by = b.y * height;

            const dx = ax - bx;
            const dy = ay - by;
            const dist = Math.hypot(dx, dy);
            if (dist > 120) continue;

            const alpha = (1 - dist / 120) * 0.18;
            ctx.strokeStyle = `rgba(212,175,55,${alpha})`;
            ctx.lineWidth = 0.7;
            ctx.beginPath();
            ctx.moveTo(ax, ay);
            ctx.lineTo(bx, by);
            ctx.stroke();
          }
        }

        rafId = requestAnimationFrame(step);
      };

      const onPointerMove = (event) => {
        const rect = canvas.getBoundingClientRect();
        pointer.x = Math.min(1, Math.max(0, (event.clientX - rect.left) / rect.width));
        pointer.y = Math.min(1, Math.max(0, (event.clientY - rect.top) / rect.height));
        pointer.active = true;
      };

      const onPointerLeave = () => {
        pointer.active = false;
      };

      const onResize = () => resize();

      resize();

      if (!reduced) {
        canvas.addEventListener('pointermove', onPointerMove, { passive: true });
        canvas.addEventListener('pointerleave', onPointerLeave, { passive: true });
        window.addEventListener('resize', onResize, { passive: true });
        rafId = requestAnimationFrame(step);
      } else {
        ctx.clearRect(0, 0, width, height);
        drawBackground();
      }

      cleanups.push(() => {
        running = false;
        if (rafId) cancelAnimationFrame(rafId);
        canvas.removeEventListener('pointermove', onPointerMove);
        canvas.removeEventListener('pointerleave', onPointerLeave);
        window.removeEventListener('resize', onResize);
      });
    }

    function initAll() {
      cleanupAll();
      document.documentElement.classList.add('index-motion-ready');
      initRevealFallback();
      initMeterBars();
      initHeroTilt();
      initVaultCanvas();
    }

    initAll();
    document.addEventListener('astro:page-load', initAll);
    document.addEventListener('astro:after-swap', initAll);
  })();
</script>
