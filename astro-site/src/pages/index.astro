---
import Base from '../layouts/Base.astro';
import DocumentCard from '../components/DocumentCard.astro';
import { D } from '../data/catalog.js';

const categories = ['ВКР и дипломы', 'Курсовые работы', 'Рефераты', 'Отчёты по практике', 'Контрольные работы', 'Методические материалы'];
const featured: typeof D = [];
for (const cat of categories) {
  const doc = D.find(d => d.category === cat && !featured.includes(d));
  if (doc) featured.push(doc);
}
while (featured.length < 6) {
  const doc = D.find(d => !featured.includes(d));
  if (doc) featured.push(doc);
  else break;
}

const docCount = D.length;
---

<Base title="Академический Салон — Библиотека студенческих работ" currentPath="/">

  <!-- ═══════════ HERO ═══════════ -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-glow"></div>
      <div class="hero-noise"></div>
    </div>

    <div class="container hero-inner">
      <p class="hero-eyebrow reveal">Библиотека студенческих работ</p>

      <h1 class="hero-h1 reveal">
        Академический<br/><span class="hero-accent gold-shimmer">Салон</span>
      </h1>

      <p class="hero-sub reveal">
        {docCount} бесплатных работ по психологии и социальной работе.
        Скачивай&nbsp;готовые или&nbsp;закажи&nbsp;индивидуально.
      </p>

      <div class="hero-bar reveal">
        <svg class="hero-bar-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" class="hero-bar-input" id="heroSearch" placeholder="Найти работу..." />
        <a href="/catalog" class="hero-bar-btn">Каталог</a>
      </div>

      <div class="hero-hints reveal">
        <a href="/catalog?q=психология" class="hint">психология</a>
        <a href="/catalog?q=курсовая" class="hint">курсовая</a>
        <a href="/catalog?q=диплом" class="hint">диплом</a>
        <a href="/catalog?q=практика" class="hint">практика</a>
        <span class="hint-sep">или</span>
        <a href="/order" class="hint hint-order">заказать работу &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ═══════════ FEATURED ═══════════ -->
  <section class="featured">
    <div class="container">
      <p class="featured-label reveal section-label">Из каталога</p>
      <div class="bento reveal">
        {featured.map((doc, i) => (
          <DocumentCard doc={doc} index={i} />
        ))}
      </div>
      <div class="featured-foot reveal">
        <a href="/catalog" class="btn btn-secondary">
          Все {docCount} документов
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════ CTA ═══════════ -->
  <section class="cta">
    <div class="container">
      <div class="cta-card reveal">
        <div class="cta-content">
          <h2 class="cta-title">Не нашли нужную работу?</h2>
          <p class="cta-desc">
            Выполним индивидуально — курсовые, дипломные, ВКР, рефераты.
            Гарантия сдачи, бесплатные правки, оплата&nbsp;50/50.
          </p>
          <div class="cta-actions">
            <a href="/order" class="btn btn-primary">Узнать стоимость &rarr;</a>
            <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost">Написать в ВК &rarr;</a>
          </div>
        </div>
        <div class="cta-stats">
          <div class="cta-stat">
            <span class="cta-stat-n">93<span class="cta-stat-u">%</span></span>
            <span class="cta-stat-l">сдают с первого раза</span>
          </div>
          <div class="cta-stat">
            <span class="cta-stat-n">&infin;</span>
            <span class="cta-stat-l">бесплатных правок</span>
          </div>
          <div class="cta-stat">
            <span class="cta-stat-n">50/50</span>
            <span class="cta-stat-l">оплата по частям</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ═══════════════════════════════════════
     HERO — compact, dense, search-first
     ═══════════════════════════════════════ */
  .hero {
    position: relative;
    padding: 120px 0 64px;
    text-align: center;
    overflow: hidden;
  }

  /* Background: glow + subtle noise texture */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .hero-glow {
    position: absolute;
    top: -30%; left: 50%;
    transform: translateX(-50%);
    width: 800px; height: 500px;
    background: radial-gradient(ellipse, rgba(212,175,55,.09) 0%, transparent 65%);
    filter: blur(40px);
  }
  .hero-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.015'/%3E%3C/svg%3E");
    background-size: 128px;
    opacity: .5;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--ac);
    opacity: .5;
    margin-bottom: var(--sp-6);
  }

  .hero-h1 {
    font-family: var(--fd);
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 900;
    letter-spacing: -.04em;
    line-height: .95;
    color: var(--t1);
    margin-bottom: var(--sp-5);
  }
  .hero-accent {
    font-style: italic;
    letter-spacing: .01em;
  }

  .hero-sub {
    font-size: 16px;
    color: var(--t2);
    line-height: 1.65;
    max-width: 440px;
    margin-bottom: var(--sp-8);
  }

  /* Search bar — integrated with CTA button */
  .hero-bar {
    position: relative;
    width: 100%;
    max-width: 520px;
    display: flex;
    align-items: center;
    background: rgba(255,255,255,.04);
    border: 1px solid var(--brd);
    border-radius: 16px;
    padding: 6px;
    transition: all .3s var(--ease);
  }
  .hero-bar:focus-within {
    border-color: rgba(212,175,55,.18);
    box-shadow: 0 0 0 3px rgba(212,175,55,.04), 0 8px 32px rgba(0,0,0,.12);
    background: rgba(255,255,255,.06);
  }
  .hero-bar-ico {
    position: absolute;
    left: 18px;
    width: 16px; height: 16px;
    color: var(--t3);
    pointer-events: none;
  }
  .hero-bar-input {
    flex: 1;
    height: 44px;
    padding: 0 12px 0 40px;
    background: transparent;
    border: none;
    color: var(--t1);
    font-size: 14px;
    font-family: inherit;
    outline: 0;
  }
  .hero-bar-input::placeholder { color: var(--t3) }
  .hero-bar-btn {
    flex-shrink: 0;
    padding: 10px 24px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--ac), var(--ac2));
    color: #1a1410;
    font-size: 13px;
    font-weight: 700;
    font-family: inherit;
    text-decoration: none;
    transition: all .2s var(--ease);
  }
  .hero-bar-btn:hover {
    box-shadow: 0 4px 16px rgba(212,175,55,.25);
    transform: translateY(-1px);
  }

  /* Hints — inline with "or order" link */
  .hero-hints {
    display: flex;
    gap: 6px;
    margin-top: var(--sp-3);
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
  }
  .hint {
    padding: 3px 12px;
    border-radius: 100px;
    background: transparent;
    border: 1px solid var(--brd);
    color: var(--t3);
    font-size: 11px;
    font-weight: 500;
    text-decoration: none;
    transition: all var(--dur-fast) var(--ease);
  }
  .hint:hover {
    border-color: rgba(212,175,55,.12);
    color: var(--t2);
  }
  .hint-sep {
    font-size: 11px;
    color: var(--t3);
    opacity: .4;
    margin: 0 2px;
  }
  .hint-order {
    color: var(--ac);
    border-color: rgba(212,175,55,.12);
    opacity: .7;
  }
  .hint-order:hover {
    opacity: 1;
    border-color: rgba(212,175,55,.2);
    color: var(--ac2);
  }

  /* ═══════════════════════════════════════
     FEATURED — bento grid
     ═══════════════════════════════════════ */
  .featured {
    padding: var(--sp-12) 0 var(--sp-20);
  }

  .featured-label { margin-bottom: var(--sp-6) }

  .bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: auto;
    gap: var(--sp-4);
  }
  .bento > :first-child {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }

  .featured-foot {
    text-align: center;
    margin-top: var(--sp-8);
  }

  /* ═══════════════════════════════════════
     CTA — one card, clear message
     ═══════════════════════════════════════ */
  .cta {
    padding: 0 0 var(--sp-20);
  }

  .cta-card {
    display: grid;
    grid-template-columns: 1.3fr .7fr;
    gap: var(--sp-10);
    align-items: center;
    padding: var(--sp-12) var(--sp-10);
    border-radius: 20px;
    background: rgba(212,175,55,.02);
    border: 1px solid var(--brd);
    position: relative;
  }
  .cta-card::before {
    content: '';
    position: absolute;
    top: 0; left: 15%; right: 15%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212,175,55,.1), transparent);
  }

  .cta-title {
    font-family: var(--fd);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 900;
    color: var(--t1);
    letter-spacing: -.02em;
    line-height: 1.15;
    margin-bottom: var(--sp-4);
  }

  .cta-desc {
    font-size: 14px;
    color: var(--t2);
    line-height: 1.7;
    max-width: 44ch;
    margin-bottom: var(--sp-6);
  }

  .cta-actions {
    display: flex;
    gap: var(--sp-4);
    align-items: center;
    flex-wrap: wrap;
  }

  .cta-stats {
    display: flex;
    flex-direction: column;
    gap: var(--sp-6);
    padding-left: var(--sp-8);
    border-left: 1px solid var(--brd);
  }

  .cta-stat-n {
    font-family: var(--fd);
    font-size: 1.8rem;
    font-weight: 900;
    background: linear-gradient(180deg, var(--ac3), var(--ac));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1;
  }
  .cta-stat-u { font-size: 1.2rem }
  .cta-stat-l {
    font-size: 11px;
    color: var(--t3);
    margin-top: 3px;
    display: block;
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 768px) {
    .hero { padding: 100px 0 48px }
    .hero-h1 { font-size: clamp(2.4rem, 11vw, 3.5rem) }
    .hero-bar { flex-direction: column; padding: 4px }
    .hero-bar-input { width: 100%; padding-left: 40px }
    .hero-bar-btn { width: 100%; text-align: center; padding: 12px }

    .bento { grid-template-columns: 1fr }
    .bento > :first-child { grid-column: 1; grid-row: auto }

    .cta-card {
      grid-template-columns: 1fr;
      padding: var(--sp-8) var(--sp-6);
    }
    .cta-stats {
      flex-direction: row;
      border-left: none;
      padding-left: 0;
      border-top: 1px solid var(--brd);
      padding-top: var(--sp-5);
      gap: var(--sp-3);
    }
    .cta-stat { flex: 1 }
  }
</style>

<script>
  const input = document.getElementById('heroSearch') as HTMLInputElement;
  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && input.value.trim()) {
      window.location.href = `/catalog?q=${encodeURIComponent(input.value.trim())}`;
    }
  });
</script>
