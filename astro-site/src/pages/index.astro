<script>
  // Phase 3.1 — scroll-progress + reveal observer. Only loaded on "/"
  // because this page file only renders at "/". The module bootstraps
  // itself on load + astro:page-load.
  import '../scripts/couture';
</script>

<script>
  // ════════════════════════════════════════════════════════════════
  // FORMULA — calculator interactions (step 2.6)
  // Decorative pricing: base × tempo + extras. Pages are NOT priced
  // (our genre prices are "from", final is agreed individually).
  // ════════════════════════════════════════════════════════════════
  type GenreCode =
    | 'ess' | 'ref' | 'article' | 'pres'
    | 'practice' | 'kurs' | 'diplom' | 'magist';
  type TempoCode = 'slow' | 'normal' | 'rush';
  type ExtraCode = 'antiplag' | 'speech' | 'slides';

  // `basePages` — объём, который уже включён в базовую цену.
  // `perPage`   — наценка за каждую страницу сверх base, до коэффициента темпа.
  // Коридор страниц slider — 5..120 общий; здесь уточняем, откуда считать наценку.
  interface GenreSpec {
    base: number;
    basePages: number;
    perPage: number;
    label: string;
    query: string;
  }
  interface TempoSpec { mult: number; label: string; }
  interface ExtraSpec { price: number; label: string; }

  const GENRES: Record<GenreCode, GenreSpec> = {
    ess:      { base: 2500,  basePages: 8,   perPage: 180, label: 'Самостоятельная',    query: 'topic=' + encodeURIComponent('Самостоятельная работа') },
    ref:      { base: 3500,  basePages: 15,  perPage: 200, label: 'Реферат',            query: 'type=ref' },
    article:  { base: 6000,  basePages: 10,  perPage: 350, label: 'Научная статья',     query: 'topic=' + encodeURIComponent('Научная статья') },
    pres:     { base: 7500,  basePages: 15,  perPage: 250, label: 'Презентация и речь', query: 'topic=' + encodeURIComponent('Презентация и речь к защите') },
    practice: { base: 8000,  basePages: 25,  perPage: 250, label: 'Отчёт по практике',  query: 'type=practice' },
    kurs:     { base: 14000, basePages: 30,  perPage: 300, label: 'Курсовая',           query: 'type=kurs_t' },
    diplom:   { base: 40000, basePages: 60,  perPage: 500, label: 'ВКР · дипломная',    query: 'type=diplom' },
    magist:   { base: 60000, basePages: 80,  perPage: 600, label: 'Магистерская',       query: 'type=magist' },
  };
  const TEMPOS: Record<TempoCode, TempoSpec> = {
    slow:   { mult: 1.0,  label: 'неспешно' },
    normal: { mult: 1.25, label: 'собранно' },
    rush:   { mult: 1.6,  label: 'срочно' },
  };
  const EXTRAS: Record<ExtraCode, ExtraSpec> = {
    antiplag: { price: 1500, label: 'Антиплагиат ВУЗ' },
    speech:   { price: 2500, label: 'Речь к защите' },
    slides:   { price: 3500, label: 'Слайды презентации' },
  };

  // narrow no-break space between thousand groups
  const NARROW_NBSP = '\u202F';
  const money = (n: number) => Math.round(n).toLocaleString('ru-RU').replace(/,/g, NARROW_NBSP);
  const escapeHtml = (s: string) =>
    s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));

  function initFormula() {
    const section = document.getElementById('formula');
    if (!section) return;

    const rowsEl = section.querySelector<HTMLElement>('#formulaRows');
    const totalEl = section.querySelector<HTMLElement>('#formulaTotal');
    const ctaEl = section.querySelector<HTMLAnchorElement>('#formulaCta');
    const pagesInput = section.querySelector<HTMLInputElement>('#formulaPages');
    const pagesValEl = section.querySelector<HTMLElement>('#formulaPagesVal');
    if (!rowsEl || !totalEl || !ctaEl || !pagesInput || !pagesValEl) return;

    const state = {
      genre: 'ess' as GenreCode,
      tempo: 'slow' as TempoCode,
      extras: new Set<ExtraCode>(),
      pages: GENRES.ess.basePages,
    };

    function setActive(group: 'genre' | 'tempo', value: string) {
      const attr = 'data-' + group;
      section!.querySelectorAll<HTMLButtonElement>(`[${attr}]`).forEach((btn) => {
        const on = btn.getAttribute(attr) === value;
        btn.classList.toggle('is-active', on);
        btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
    }

    function setExtra(code: ExtraCode, on: boolean) {
      const btn = section!.querySelector<HTMLButtonElement>(`[data-extra="${code}"]`);
      if (!btn) return;
      btn.classList.toggle('is-active', on);
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
    }

    function update() {
      const g = GENRES[state.genre];
      const t = TEMPOS[state.tempo];

      const volumeDelta = Math.max(0, state.pages - g.basePages) * g.perPage;
      const subtotal = g.base + volumeDelta;
      const afterTempo = subtotal * t.mult;
      const tempoDelta = afterTempo - subtotal;
      const extrasSum = [...state.extras].reduce((s, k) => s + EXTRAS[k].price, 0);
      const total = afterTempo + extrasSum;

      const rows: string[] = [];
      rows.push(`<div class="receipt-row"><span class="k">${escapeHtml(g.label)} · база (${g.basePages}${NARROW_NBSP}стр.)</span><span class="v">${money(g.base)}${NARROW_NBSP}₽</span></div>`);

      if (volumeDelta > 0) {
        const extraPages = state.pages - g.basePages;
        rows.push(`<div class="receipt-row sub"><span class="k">Объём · +${extraPages}${NARROW_NBSP}стр. × ${money(g.perPage)}${NARROW_NBSP}₽</span><span class="v">+${NARROW_NBSP}${money(volumeDelta)}${NARROW_NBSP}₽</span></div>`);
      } else {
        rows.push(`<div class="receipt-row"><span class="k">Объём · ${state.pages}${NARROW_NBSP}стр. (в\u00a0базе)</span><span class="v">—</span></div>`);
      }

      const tempoVal = tempoDelta > 0
        ? `+${NARROW_NBSP}${money(tempoDelta)}${NARROW_NBSP}₽`
        : `×${NARROW_NBSP}1.0`;
      rows.push(`<div class="receipt-row sub"><span class="k">Темп · ${escapeHtml(t.label)}</span><span class="v">${tempoVal}</span></div>`);

      state.extras.forEach((k) => {
        const e = EXTRAS[k];
        rows.push(`<div class="receipt-row sub"><span class="k">${escapeHtml(e.label)}</span><span class="v">+${NARROW_NBSP}${money(e.price)}${NARROW_NBSP}₽</span></div>`);
      });

      rowsEl!.innerHTML = rows.join('');
      totalEl!.innerHTML = `${money(total)}<span class="cur">${NARROW_NBSP}₽</span>`;
      ctaEl!.setAttribute('href', `/order?${g.query}`);
    }

    // ── Event delegation on groups ──
    section.querySelectorAll<HTMLElement>('[data-group]').forEach((group) => {
      const kind = group.getAttribute('data-group');
      group.addEventListener('click', (ev) => {
        const target = (ev.target as HTMLElement).closest('button');
        if (!target || !group.contains(target)) return;
        if (kind === 'genre') {
          const v = target.getAttribute('data-genre') as GenreCode | null;
          if (!v || !(v in GENRES)) return;
          state.genre = v;
          // Reset slider to the default volume for this genre, so the
          // user doesn't end up pricing 120 pages of an essay.
          state.pages = GENRES[v].basePages;
          pagesInput.value = String(state.pages);
          pagesValEl.textContent = String(state.pages);
          const min = Number(pagesInput.min) || 5;
          const max = Number(pagesInput.max) || 120;
          const fill = ((state.pages - min) / Math.max(1, max - min)) * 100;
          pagesInput.style.setProperty('--fill', fill.toFixed(1) + '%');
          setActive('genre', v);
          update();
        } else if (kind === 'tempo') {
          const v = target.getAttribute('data-tempo') as TempoCode | null;
          if (!v || !(v in TEMPOS)) return;
          state.tempo = v;
          setActive('tempo', v);
          update();
        } else if (kind === 'extras') {
          const v = target.getAttribute('data-extra') as ExtraCode | null;
          if (!v || !(v in EXTRAS)) return;
          if (state.extras.has(v)) state.extras.delete(v); else state.extras.add(v);
          setExtra(v, state.extras.has(v));
          update();
        }
      });
    });

    // ── Slider (decorative, updates pages label + fill, not price) ──
    const syncPages = () => {
      state.pages = Number(pagesInput!.value) || 10;
      pagesValEl!.textContent = String(state.pages);
      const min = Number(pagesInput!.min) || 5;
      const max = Number(pagesInput!.max) || 120;
      const fill = ((state.pages - min) / Math.max(1, max - min)) * 100;
      pagesInput!.style.setProperty('--fill', fill.toFixed(1) + '%');
      update();
    };
    pagesInput.addEventListener('input', syncPages);
    syncPages();
  }

  initFormula();
  // Re-init after Astro view-transition swaps in a fresh DOM.
  document.addEventListener('astro:page-load', initFormula);
</script>


<script>
  // ════════════════════════════════════════════════════════════════
  // CALENDAR — click-to-open day grid dialog
  // Decorative load map: past → closed, today → gold, next 3 days →
  // tight, rest → free. Exact bookings are agreed in Telegram; this
  // dialog is not a booking system. Future-proofed for a per-day
  // override from /calendar.json (not required yet).
  // ════════════════════════════════════════════════════════════════
  type DayState = 'empty' | 'closed' | 'today' | 'busy' | 'tight' | 'free';
  interface DayCell { day: number | null; state: DayState; }

  const MONTH_NAMES_NOM = [
    'Январь','Февраль','Март','Апрель','Май','Июнь',
    'Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь',
  ];
  const MONTH_NAMES_GEN = [
    'января','февраля','марта','апреля','мая','июня',
    'июля','августа','сентября','октября','ноября','декабря',
  ];

  /* Admin-saved state: { "2026-07-15": "tight" | "busy" | "free" | "closed" }.
     Falls back to decorative pattern (loaded feel) when a day isn't set. */
  /* Pull server-side overrides once per page-load; merge into the same cache so
     buildDays() reads a single source. Quietly fails if backend is down. */
  (function syncServerCalendar() {
    fetch('/api/calendar', { cache: 'no-store' })
      .then((r) => (r.ok ? r.json() : null))
      .then((data) => {
        if (!data || !data.ok || !Array.isArray(data.items)) return;
        const map: Record<string, string> = {};
        data.items.forEach((it: any) => { if (it && it.date && it.state) map[it.date] = it.state; });
        try { localStorage.setItem('academic-salon:calendar', JSON.stringify(map)); } catch (_) {}
      })
      .catch(() => {});
  })();

  function readCalOverrides(): Record<string, DayState> {
    try {
      const raw = localStorage.getItem('academic-salon:calendar');
      if (!raw) return {};
      const parsed = JSON.parse(raw);
      return (parsed && typeof parsed === 'object') ? parsed : {};
    } catch (_) { return {}; }
  }

  function ymd(year: number, monthIdx: number, day: number): string {
    return year + '-' + String(monthIdx + 1).padStart(2, '0') + '-' + String(day).padStart(2, '0');
  }

  function buildDays(year: number, monthIdx: number, todayYear: number, todayMonth: number, todayDay: number): DayCell[] {
    const first = new Date(year, monthIdx, 1);
    const last = new Date(year, monthIdx + 1, 0);
    const daysInMonth = last.getDate();
    const firstDow = (first.getDay() + 6) % 7;

    const overrides = readCalOverrides();
    const cells: DayCell[] = [];
    for (let i = 0; i < firstDow; i++) cells.push({ day: null, state: 'empty' });

    for (let d = 1; d <= daysInMonth; d++) {
      const key = ymd(year, monthIdx, d);
      const isPastMonth =
        year < todayYear || (year === todayYear && monthIdx < todayMonth);
      const isFutureMonth =
        year > todayYear || (year === todayYear && monthIdx > todayMonth);

      let state: DayState;
      /* 1. Admin override wins */
      if (overrides[key]) {
        state = overrides[key] as DayState;
      } else if (isPastMonth) {
        state = 'closed';
      } else if (isFutureMonth) {
        /* Loaded default — first two weeks mostly busy, rest a mix of tight/free */
        if (d <= 7) state = 'busy' as DayState;
        else if (d <= 18) state = 'tight';
        else state = (d % 3 === 0) ? 'tight' : 'free';
      } else {
        /* Current month */
        if (d < todayDay) state = 'closed';
        else if (d === todayDay) state = 'today';
        else if (d - todayDay <= 5) state = 'busy' as DayState;
        else if (d - todayDay <= 12) state = 'tight';
        else state = (d % 3 === 0) ? 'tight' : 'free';
      }
      cells.push({ day: d, state });
    }
    while (cells.length % 7 !== 0) cells.push({ day: null, state: 'empty' });
    return cells;
  }

  function initCalendarModal() {
    const section = document.getElementById('calendar');
    const modal = document.getElementById('calModal') as HTMLDialogElement | null;
    if (!section || !modal) return;
    if (typeof modal.showModal !== 'function') {
      // Very old browser fallback: leave months as-is, skip wiring.
      return;
    }

    const year = Number(section.getAttribute('data-calendar-year')) || new Date().getFullYear();
    const todayMonth = Number(section.getAttribute('data-calendar-month'));
    const todayDay = Number(section.getAttribute('data-calendar-today'));

    const grid = modal.querySelector<HTMLElement>('#calModalGrid');
    const title = modal.querySelector<HTMLElement>('#calModalTitle');
    const note = modal.querySelector<HTMLElement>('#calModalNote');
    const closeBtn = modal.querySelector<HTMLButtonElement>('#calModalClose');

    function open(monthIdx: number, stateLabel: string) {
      if (!grid || !title || !note) return;
      // Month name points to the calendar year (not the shifting cursor year).
      // Since our 12 cells start at the current month, monthIdx here is the
      // absolute calendar month (0..11). The section stores today's month
      // so we compute the year this month belongs to:
      const monthYear = (monthIdx < todayMonth) ? year + 1 : year;
      title.innerHTML = `${MONTH_NAMES_NOM[monthIdx]} · <em>${monthYear}</em>`;

      const cells = buildDays(monthYear, monthIdx, year, todayMonth, todayDay);
      grid.innerHTML = cells.map((c) => {
        if (c.state === 'empty') return '<span class="cal-day empty" aria-hidden="true"></span>';
        const aria = `${c.day} ${MONTH_NAMES_GEN[monthIdx]}`;
        return `<span class="cal-day ${c.state}" role="gridcell" aria-label="${aria}">${c.day}</span>`;
      }).join('');

      const noteText =
        stateLabel === 'closed' ? `${MONTH_NAMES_NOM[monthIdx]} уже прошёл. Ближайшие окна — в следующих месяцах.`
        : stateLabel === 'tight' ? `${MONTH_NAMES_NOM[monthIdx]} идёт плотно. Напишите — подберём конкретные даты.`
        : `${MONTH_NAMES_NOM[monthIdx]} — окна открыты. Точные даты обсудим в Telegram.`;
      note.textContent = noteText;

      modal!.showModal();
      document.body.style.overflow = 'hidden';
    }

    function close() {
      modal!.close();
      document.body.style.overflow = '';
    }

    section.querySelectorAll<HTMLButtonElement>('.month').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idxStr = btn.getAttribute('data-month-index');
        const stateLabel = btn.getAttribute('data-month-state') || 'free';
        if (idxStr === null) return;
        const relative = Number(idxStr);
        // `calendarCells` was built starting from the current month, so the
        // absolute month is todayMonth + relative (mod 12).
        const absoluteMonth = (todayMonth + relative) % 12;
        open(absoluteMonth, stateLabel);
      });
    });

    closeBtn?.addEventListener('click', close);
    modal.addEventListener('click', (e) => {
      // Close when user clicks on the backdrop (outside the .cal-modal-body).
      const body = modal!.querySelector<HTMLElement>('.cal-modal-body');
      if (!body) return;
      const r = body.getBoundingClientRect();
      const clickedInside =
        e.clientX >= r.left && e.clientX <= r.right &&
        e.clientY >= r.top && e.clientY <= r.bottom;
      if (!clickedInside) close();
    });
    modal.addEventListener('cancel', () => {
      // ESC closes — restore overflow.
      document.body.style.overflow = '';
    });
  }

  initCalendarModal();
  document.addEventListener('astro:page-load', initCalendarModal);
</script>
