---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const totalDocs = D.length;
const currentYear = String(new Date().getFullYear());

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const match = blob.match(/(?:19|20)\d{2}/);
  return match ? match[0] : currentYear;
}

function normalizeDoc(doc: any, index: number) {
  return {
    id: `${doc.file}-${index}`,
    slug: doc.file,
    title: doc.catalogTitle || doc.title || doc.filename || 'Студенческая работа',
    type: doc.docType || doc.category || 'Работа',
    subject: doc.subject || 'Психология',
    year: extractYear(doc),
  };
}

const preferredCategories = [
  'ВКР и дипломы',
  'Курсовые работы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
  'Методические материалы',
];

const pickedDocs: any[] = [];
for (const category of preferredCategories) {
  const nextDocs = D.filter((doc: any) => doc.category === category).slice(0, 1);
  pickedDocs.push(...nextDocs);
}
if (pickedDocs.length < 6) {
  for (const doc of D) {
    if (pickedDocs.includes(doc)) continue;
    pickedDocs.push(doc);
    if (pickedDocs.length >= 6) break;
  }
}

const cards = pickedDocs.slice(0, 6).map(normalizeDoc);

// ── Calendar of the workshop (decorative load map — step 2.3) ──
// Computed at build time from new Date(). Not a real booking system.
const monthNames = ['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];
const calendarNow = new Date();
const calendarCurMonth = calendarNow.getMonth(); // 0..11

type CalendarState = 'closed' | 'tight' | 'free';
interface CalendarCell {
  name: string;
  state: CalendarState;
  booked: number;
  title: string;
  sub: string;
}
const calendarCells: CalendarCell[] = monthNames.map((name, i): CalendarCell => {
  if (i < calendarCurMonth) {
    return { name, state: 'closed', booked: 0, title: '—', sub: 'прошёл' };
  }
  if (i === calendarCurMonth) {
    return { name, state: 'tight', booked: 90, title: '90%', sub: 'мало окон' };
  }
  if (i === calendarCurMonth + 1) {
    return { name, state: 'tight', booked: 80, title: '80%', sub: 'мало окон' };
  }
  if (i === calendarCurMonth + 2) {
    return { name, state: 'free', booked: 50, title: '50%', sub: 'открыто' };
  }
  if (i === calendarCurMonth + 3) {
    return { name, state: 'free', booked: 40, title: '40%', sub: 'открыто' };
  }
  const booked = 25 + ((i * 3) % 10); // 25..34, deterministic but varied
  return { name, state: 'free', booked, title: `${booked}%`, sub: 'лучшее время' };
});

// ── Genres of work (step 2.4) ──
// Prices are locked to REAL_DATA.md §4. Order from cheap to expensive.
// Hrefs use order.astro's existing ?type=<calcCode> contract when a
// matching calculator pill exists (see src/pages/order.astro:128-135);
// otherwise we fall back to ?topic=<name> which prefills the topic field.
interface GenreRow {
  no: string;
  latin: string;
  name: string;
  desc: string;
  priceFrom: number;
  href: string;
}
const genres: GenreRow[] = [
  { no: 'I',    latin: 'Exercitium',   name: 'Самостоятельная',    desc: 'Короткий ответ по\u00a0вопросу или\u00a0теме.',            priceFrom: 2500,  href: '/order?topic=' + encodeURIComponent('Самостоятельная работа') },
  { no: 'II',   latin: 'Epitome',      name: 'Реферат',            desc: 'Обзор источников по\u00a0ГОСТ.',                           priceFrom: 3500,  href: '/order?type=ref' },
  { no: 'III',  latin: 'Articulus',    name: 'Научная статья',     desc: 'ВАК, РИНЦ, студенческие сборники.',                        priceFrom: 6000,  href: '/order?topic=' + encodeURIComponent('Научная статья') },
  { no: 'IV',   latin: 'Oratio',       name: 'Презентация и\u00a0речь', desc: '15\u00a0слайдов и\u00a07–10\u00a0минут речи к\u00a0защите.', priceFrom: 7500, href: '/order?topic=' + encodeURIComponent('Презентация и речь к защите') },
  { no: 'V',    latin: 'Relatio',      name: 'Отчёт по\u00a0практике', desc: 'Дневник, характеристика, приложения.',                 priceFrom: 8000,  href: '/order?type=practice' },
  { no: 'VI',   latin: 'Commentarium', name: 'Курсовая',           desc: 'Теория плюс практика, с\u00a0защитой.',                    priceFrom: 8500,  href: '/order?type=kurs_t' },
  { no: 'VII',  latin: 'Opus magnum',  name: 'ВКР · дипломная',    desc: 'Эмпирика под\u00a0защиту, сопровождение до\u00a0оценки.',  priceFrom: 40000, href: '/order?type=diplom' },
  { no: 'VIII', latin: 'Dissertatio',  name: 'Магистерская',       desc: 'С\u00a0апробацией, публикациями, эмпирикой.',              priceFrom: 60000, href: '/order?type=magist' },
];
const fmtRub = (n: number) => n.toLocaleString('ru-RU').replace(/,/g, '\u202F');

const reviewAlts = [
  'Отзыв: Спасибо за работу',
  'Отзыв: У меня 5, работа очень хорошая',
  'Отзыв: Четвёрка твёрдая, отлично всё',
  'Отзыв: Автомат, 5 -- спасибо огромное',
  'Отзыв: Сдали с первого раза',
  'Отзыв: Сдала на 4, сказали хорошая работа',
  'Отзыв: Кайф, благодарю за быструю работу',
  'Отзыв: Всё отлично, спасибо',
  'Отзыв: Преподаватель поставил отлично',
  'Отзыв: Работа принята без замечаний',
];
---

<Base
  title="Библиотека академического салона -- студенческие работы без паники"
  description="Библиотека готовых студенческих работ: психология, социальная работа, конфликтология и другие гуманитарные дисциплины. Или закажите индивидуальную подготовку."
  currentPath="/"
>

  <!-- ============================================================
       PRELUDE — editorial hero (Dark Couture · step 2.1)
       ============================================================ -->
  <section class="prelude" id="prelude" aria-label="Вступление">
    <div class="prelude-wrap">
      <div class="prelude-head">
        <div class="col">
          <span class="lbl">Мастерская</span>
          <span class="val">с&nbsp;2020</span>
        </div>
        <div class="col">
          <span class="lbl">В&nbsp;архиве</span>
          <span class="val">{totalDocs} <i class="it">работ</i></span>
        </div>
        <div class="col">
          <span class="lbl">Сезон</span>
          <span class="val"><i class="it">MMXXVI</i></span>
        </div>
      </div>

      <div class="prelude-eyebrow-2" aria-hidden="true">
        <span class="rule"></span>
        <span class="word">Prelude</span>
      </div>

      <h1 class="prelude-h">
        <span class="ln">Написано с&nbsp;терпением,</span>
        <span class="ln">защищено с&nbsp;<em class="it">достоинством</em>.</span>
      </h1>

      <div class="prelude-foot">
        <p class="prelude-lede-2">
          Свободная библиотека из&nbsp;{totalDocs}&nbsp;студенческих работ и&nbsp;авторский заказ <em>под&nbsp;защиту</em>&nbsp;— от&nbsp;разговора до&nbsp;оценки в&nbsp;ведомости.
        </p>
        <div class="prelude-actions">
          <a href="/order" class="btn btn-gold btn-lg">Рассчитать стоимость</a>
          <a href="/catalog" class="btn btn-ghost-gold btn-lg">Открыть архив</a>
        </div>
      </div>
    </div>

    <a href="#manifesto" class="prelude-scroll-cue" aria-label="Читать дальше">
      <span class="lbl">читать дальше</span>
      <span class="line" aria-hidden="true"></span>
    </a>
  </section>

  <!-- ============================================================
       STATS — editorial column strip below the hero
       ============================================================ -->
  <section class="stats-strip rv" aria-label="О мастерской в цифрах">
    <div class="stats-strip-inner">
      <div class="stat-col">
        <span class="stat-lbl">В каталоге</span>
        <span class="stat-val">{totalDocs}<span class="stat-suffix">+</span> <i class="it">работ</i></span>
        <span class="stat-note">бесплатно, без регистрации</span>
      </div>
      <div class="stat-col">
        <span class="stat-lbl">Мастерская</span>
        <span class="stat-val"><span class="stat-sep">·</span> с 2020</span>
        <span class="stat-note">шесть лет тихой практики</span>
      </div>
      <div class="stat-col">
        <span class="stat-lbl">На связи</span>
        <span class="stat-val">15 <span class="stat-suffix">мин</span></span>
        <span class="stat-note">ответ живого человека в&nbsp;будни</span>
      </div>
    </div>
  </section>

  <!-- ============================================================
       I · MANIFESTO — editorial chapter (Dark Couture · step 2.2)
       ============================================================ -->
  <section id="manifesto" class="manifesto rv" aria-label="Манифест">
    <div class="manifesto-inner">
      <header class="chapter-head">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">I</span>
          <span class="chapter-label">Caput Primum · Глава первая</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">О&nbsp;чём этот <em class="it">салон</em>.</h2>
          <p class="chapter-lede">Короткая правда о&nbsp;том, чем занимаемся: бесплатной библиотекой студенческих работ и&nbsp;авторскими заказами под защиту. Без&nbsp;коллцентра, без&nbsp;шаблонов, без&nbsp;ИИ-шлака.</p>
        </div>
      </header>

      <div class="manifesto-body">
        <p class="manifesto-text">
          <span class="manifesto-drop">М</span>ы&nbsp;собирали этот архив с&nbsp;2020&nbsp;года&nbsp;— из&nbsp;работ студентов, которые делились ими сами. {totalDocs}&nbsp;текстов по&nbsp;психологии, социальной работе, конфликтологии, педагогике. Берите целиком как образец, забирайте куски, ищите формулировки. <em class="it">Бесплатно</em> и&nbsp;без&nbsp;регистрации.
        </p>
        <p class="manifesto-text">
          Если в&nbsp;архиве нет вашей темы&nbsp;— напишем под вас. Не&nbsp;шаблон с&nbsp;биржи, а&nbsp;разговор тридцать минут, план, главу за&nbsp;главой с&nbsp;правками после каждой проверки руководителем. Ведём до&nbsp;оценки в&nbsp;ведомости, а&nbsp;не&nbsp;до&nbsp;«высылаю файл».
        </p>
        <p class="manifesto-text">
          За&nbsp;шесть&nbsp;лет тихой работы научились двум вещам: говорить «нет», когда тема не&nbsp;наша, и&nbsp;не&nbsp;браться за&nbsp;то, что не&nbsp;успеем сделать как следует. Это не&nbsp;кокетство&nbsp;— это причина, почему работа отсюда <em class="it">не&nbsp;подводит</em> на&nbsp;защите.
        </p>

        <div class="manifesto-signature" aria-hidden="true">
          <span class="sig">АС</span>
          <span class="under">— Академический Салон · MMXX—MMXXVI —</span>
        </div>
      </div>

      <div class="manifesto-tenets">
        <article class="tenet">
          <span class="tenet-num">Principium I</span>
          <h4 class="tenet-h">Свободный архив,<br/>а&nbsp;не&nbsp;витрина</h4>
          <p class="tenet-p">{totalDocs}+ работ скачиваются <em class="it">без&nbsp;оплаты</em> и&nbsp;без&nbsp;регистрации. Если работа спасла студента&nbsp;— она наша и&nbsp;общая.</p>
        </article>
        <article class="tenet">
          <span class="tenet-num">Principium II</span>
          <h4 class="tenet-h">Авторский текст,<br/>а&nbsp;не&nbsp;компиляция</h4>
          <p class="tenet-p">Заказы пишет конкретный автор с&nbsp;профильным образованием. <em class="it">Никакого ИИ</em>, никаких переклеенных абзацев.</p>
        </article>
        <article class="tenet">
          <span class="tenet-num">Principium III</span>
          <h4 class="tenet-h">Сопровождение<br/>до&nbsp;оценки</h4>
          <p class="tenet-p">Правки после каждой проверки руководителем, репетиция защиты, речь, слайды&nbsp;— <em class="it">в&nbsp;цене</em>.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       II · CALENDAR — decorative 12-month workshop load (step 2.3)
       ============================================================ -->
  <section id="calendar" class="calendar rv" aria-label="Календарь мастерской">
    <div class="calendar-inner">
      <header class="chapter-head">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">II</span>
          <span class="chapter-label">Caput Secundum · Глава вторая</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">Календарь <em class="it">мастерской</em>.</h2>
          <p class="chapter-lede">Загрузка авторских работ по&nbsp;месяцам MMXXVI&nbsp;— чтобы вы&nbsp;видели, плотно&nbsp;ли идёт месяц, и&nbsp;могли написать заранее, если&nbsp;нужен спокойный срок.</p>
        </div>
      </header>

      <div class="calendar-intro">
        <p class="chapter-lede">
          Это не&nbsp;система бронирования, а&nbsp;честная карта загрузки. Пик приходится на&nbsp;май и&nbsp;декабрь (сессия и&nbsp;защиты); спокойнее всего&nbsp;— в&nbsp;июле, августе, феврале.
        </p>
        <div class="calendar-legend" aria-hidden="true">
          <div class="row"><span class="dot free"></span><span>окна открыты</span></div>
          <div class="row"><span class="dot tight"></span><span>плотно</span></div>
          <div class="row"><span class="dot closed"></span><span>прошёл</span></div>
        </div>
      </div>

      <div class="calendar-track">
        <div class="calendar-months" role="list">
          {calendarCells.map((m) => (
            <div
              class:list={['month', m.state]}
              style={`--booked: ${m.booked}%`}
              role="listitem"
              aria-label={`${m.name} — ${m.sub}`}
            >
              <div class="month-name">{m.name}</div>
              <div class="month-node" aria-hidden="true"></div>
              <div class="month-stat">
                <b>{m.title}</b>
                {m.sub}
              </div>
              <div class="month-bar" aria-hidden="true"></div>
            </div>
          ))}
        </div>
      </div>

      <aside class="calendar-hint">
        <div class="roman" aria-hidden="true">!</div>
        <div class="body">
          <h4>Напишите заранее&nbsp;— и&nbsp;окно подберём</h4>
          <p>Чем раньше расскажете о&nbsp;задаче, тем спокойнее обоим: подберём автора под тему, а&nbsp;вы&nbsp;не&nbsp;упрётесь в&nbsp;срочность.</p>
        </div>
        <a href="/order" class="btn btn-gold btn-sm">Написать о&nbsp;задаче</a>
      </aside>
    </div>
  </section>

  <!-- ============================================================
       III · GENRES — 8 formats with real pricing (step 2.4)
       ============================================================ -->
  <section id="genres" class="genres rv" aria-label="Жанры работ">
    <div class="genres-inner">
      <header class="chapter-head">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">III</span>
          <span class="chapter-label">Caput Tertium · Глава третья</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">Жанры <em class="it">работ</em>.</h2>
          <p class="chapter-lede">Что&nbsp;мы&nbsp;делаем для&nbsp;архива и&nbsp;под&nbsp;защиту&nbsp;— восемь форматов, с&nbsp;честной стартовой ценой. Финальная зависит от&nbsp;темы и&nbsp;срока.</p>
        </div>
      </header>

      <div class="genres-index" aria-hidden="true">
        <div>№</div>
        <div>Жанр</div>
        <div>Описание</div>
        <div class="t-right">От</div>
        <div></div>
      </div>

      <div class="genres-list">
        {genres.map((g) => (
          <a class="genre" href={g.href} aria-label={`${g.name} — от ${fmtRub(g.priceFrom)} ₽`}>
            <div class="genre-no">{g.no}.</div>
            <div class="genre-meta">
              <div class="genre-latin">{g.latin}</div>
              <div class="genre-name">{g.name}</div>
            </div>
            <div class="genre-desc">{g.desc}</div>
            <div class="genre-pricing">
              <span class="pre">От</span>
              <span class="val">{fmtRub(g.priceFrom)}<span class="cur">&nbsp;₽</span></span>
            </div>
            <div class="genre-arrow" aria-hidden="true">
              <svg viewBox="0 0 14 14" fill="none"><path d="M2 7h10m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.3"/></svg>
            </div>
          </a>
        ))}
      </div>

      <aside class="genres-note">
        <div class="genres-note-text">
          Не&nbsp;нашли свой формат? Пишем рецензии, доклады, отзывы научрука, переводы академических текстов&nbsp;— <em class="it">напишите напрямую</em>, обсудим.
        </div>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost-gold btn-sm">
          Написать в&nbsp;Telegram
          <svg viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.2"/></svg>
        </a>
      </aside>
    </div>
  </section>

  <!-- ============================================================
       IV · FORMULA — calculator scaffold (step 2.5, no JS yet)
       ============================================================ -->
  <section id="formula" class="formula rv" aria-label="Формула стоимости">
    <div class="formula-inner">
      <header class="chapter-head">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">IV</span>
          <span class="chapter-label">Caput Quartum · Глава четвёртая</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">Формула <em class="it">стоимости</em>.</h2>
          <p class="chapter-lede">Четыре&nbsp;шага&nbsp;— жанр, объём, темп и&nbsp;дополнения. Цифры статичные для&nbsp;ориентира; финальную сумму согласуем после разговора.</p>
        </div>
      </header>

      <div class="formula-stage">
        <!-- LEFT — selections -->
        <div class="formula-left">
          <div class="formula-row">
            <div class="formula-row-label">
              <span class="n">i</span>
              <span class="t">Жанр</span>
            </div>
            <div class="formula-options">
              {genres.map((g, idx) => (
                <button type="button" class:list={['formula-opt', { 'is-active': idx === 0 }]}>
                  <span>{g.name}</span>
                  <span class="p">{fmtRub(g.priceFrom)}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="formula-row">
            <div class="formula-row-label">
              <span class="n">ii</span>
              <span class="t">Объём</span>
            </div>
            <div class="formula-slider">
              <div class="readout">
                <div class="pages">10 <small>стр.</small></div>
                <div class="bounds">5 — 120 страниц</div>
              </div>
              <input type="range" min="5" max="120" value="10" step="1" style="--fill: 4.3%;" aria-label="Объём в страницах" />
            </div>
          </div>

          <div class="formula-row">
            <div class="formula-row-label">
              <span class="n">iii</span>
              <span class="t">Темп</span>
            </div>
            <div class="formula-options">
              <button type="button" class="formula-opt is-active">
                <span>Неспешно</span>
                <span class="p">× 1.0</span>
              </button>
              <button type="button" class="formula-opt">
                <span>Собранно</span>
                <span class="p">× 1.25</span>
              </button>
              <button type="button" class="formula-opt">
                <span>Срочно</span>
                <span class="p">× 1.6</span>
              </button>
            </div>
          </div>

          <div class="formula-row">
            <div class="formula-row-label">
              <span class="n">iv</span>
              <span class="t">Дополнения</span>
            </div>
            <div class="formula-options">
              <button type="button" class="formula-opt" aria-pressed="false">
                <span>Антиплагиат ВУЗ</span>
                <span class="p">+1&nbsp;500</span>
              </button>
              <button type="button" class="formula-opt" aria-pressed="false">
                <span>Речь к&nbsp;защите</span>
                <span class="p">+2&nbsp;500</span>
              </button>
              <button type="button" class="formula-opt" aria-pressed="false">
                <span>Слайды · 15&nbsp;шт.</span>
                <span class="p">+3&nbsp;500</span>
              </button>
            </div>
          </div>
        </div>

        <!-- RIGHT — receipt -->
        <div class="formula-right">
          <div class="formula-receipt-head">
            <span class="t">Счёт · Ratio</span>
            <span class="d"><i class="it">Академический Салон</i></span>
          </div>

          <div class="formula-receipt-rows">
            <div class="receipt-row">
