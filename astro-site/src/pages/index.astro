---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const totalDocs = D.length;
const currentYear = String(new Date().getFullYear());

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const match = blob.match(/(?:19|20)\d{2}/);
  return match ? match[0] : currentYear;
}

function normalizeDoc(doc: any, index: number) {
  return {
    id: `${doc.file}-${index}`,
    slug: doc.file,
    title: doc.catalogTitle || doc.title || doc.filename || 'Студенческая работа',
    type: doc.docType || doc.category || 'Работа',
    subject: doc.subject || 'Психология',
    year: extractYear(doc),
  };
}

const preferredCategories = [
  'ВКР и дипломы',
  'Курсовые работы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
  'Методические материалы',
];

const pickedDocs: any[] = [];
for (const category of preferredCategories) {
  const nextDocs = D.filter((doc: any) => doc.category === category).slice(0, 1);
  pickedDocs.push(...nextDocs);
}
if (pickedDocs.length < 6) {
  for (const doc of D) {
    if (pickedDocs.includes(doc)) continue;
    pickedDocs.push(doc);
    if (pickedDocs.length >= 6) break;
  }
}

const cards = pickedDocs.slice(0, 6).map(normalizeDoc);

// ── Calendar of the workshop (decorative load map — step 2.3) ──
// Computed at build time from new Date(). Not a real booking system.
const monthNames = ['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];
const calendarNow = new Date();
const calendarCurMonth = calendarNow.getMonth(); // 0..11

type CalendarState = 'closed' | 'tight' | 'free';
interface CalendarCell {
  name: string;
  state: CalendarState;
  booked: number;
  title: string;
  sub: string;
}
const calendarCells: CalendarCell[] = monthNames.map((name, i): CalendarCell => {
  if (i < calendarCurMonth) {
    return { name, state: 'closed', booked: 0, title: '—', sub: 'прошёл' };
  }
  if (i === calendarCurMonth) {
    return { name, state: 'tight', booked: 90, title: '90%', sub: 'мало окон' };
  }
  if (i === calendarCurMonth + 1) {
    return { name, state: 'tight', booked: 80, title: '80%', sub: 'мало окон' };
  }
  if (i === calendarCurMonth + 2) {
    return { name, state: 'free', booked: 50, title: '50%', sub: 'открыто' };
  }
  if (i === calendarCurMonth + 3) {
    return { name, state: 'free', booked: 40, title: '40%', sub: 'открыто' };
  }
  const booked = 25 + ((i * 3) % 10); // 25..34, deterministic but varied
  return { name, state: 'free', booked, title: `${booked}%`, sub: 'лучшее время' };
});

// ── Genres of work (step 2.4) ──
// Prices are locked to REAL_DATA.md §4. Order from cheap to expensive.
// Hrefs use order.astro's existing ?type=<calcCode> contract when a
// matching calculator pill exists (see src/pages/order.astro:128-135);
// otherwise we fall back to ?topic=<name> which prefills the topic field.
interface GenreRow {
  no: string;
  code: string;   // used by Formula calculator (step 2.6)
  latin: string;
  name: string;
  desc: string;
  priceFrom: number;
  href: string;
}
const genres: GenreRow[] = [
  { no: 'I',    code: 'ess',      latin: 'Exercitium',   name: 'Самостоятельная',    desc: 'Короткий ответ по\u00a0вопросу или\u00a0теме.',            priceFrom: 2500,  href: '/order?topic=' + encodeURIComponent('Самостоятельная работа') },
  { no: 'II',   code: 'ref',      latin: 'Epitome',      name: 'Реферат',            desc: 'Обзор источников по\u00a0ГОСТ.',                           priceFrom: 3500,  href: '/order?type=ref' },
  { no: 'III',  code: 'article',  latin: 'Articulus',    name: 'Научная статья',     desc: 'ВАК, РИНЦ, студенческие сборники.',                        priceFrom: 6000,  href: '/order?topic=' + encodeURIComponent('Научная статья') },
  { no: 'IV',   code: 'pres',     latin: 'Oratio',       name: 'Презентация и\u00a0речь', desc: '15\u00a0слайдов и\u00a07–10\u00a0минут речи к\u00a0защите.', priceFrom: 7500, href: '/order?topic=' + encodeURIComponent('Презентация и речь к защите') },
  { no: 'V',    code: 'practice', latin: 'Relatio',      name: 'Отчёт по\u00a0практике', desc: 'Дневник, характеристика, приложения.',                 priceFrom: 8000,  href: '/order?type=practice' },
  { no: 'VI',   code: 'kurs',     latin: 'Commentarium', name: 'Курсовая',           desc: 'Теория\u00a0— от\u00a014\u202F000\u00a0₽. С\u00a0эмпирикой и\u00a0сопровождением к\u00a0защите\u00a0— от\u00a020\u202F000\u00a0₽.', priceFrom: 14000, href: '/order?type=kurs_t' },
  { no: 'VII',  code: 'diplom',   latin: 'Opus magnum',  name: 'ВКР · дипломная',    desc: 'Эмпирика под\u00a0защиту, сопровождение до\u00a0оценки.',  priceFrom: 40000, href: '/order?type=diplom' },
  { no: 'VIII', code: 'magist',   latin: 'Dissertatio',  name: 'Магистерская',       desc: 'С\u00a0апробацией, публикациями, эмпирикой.',              priceFrom: 60000, href: '/order?type=magist' },
];
const fmtRub = (n: number) => n.toLocaleString('ru-RU').replace(/,/g, '\u202F');

// ── Archive V (step 2.7) ──
// Shows the last 25 works from D with 10-category filter pills.
// Counts are derived from catalog.js at build time (not hard-coded).
const ARCHIVE_CATEGORIES: readonly string[] = [
  'ВКР и дипломы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
  'Эссе',
  'Конспекты лекций',
  'Методические материалы',
  'НПР',
  'Другое',
];
const archiveCounts: Record<string, number> = Object.fromEntries(
  ARCHIVE_CATEGORIES.map((c) => [c, D.filter((d: any) => d.category === c).length])
);
const archiveTotal: number = D.length;

const archiveShortType: Record<string, string> = {
  'ВКР и дипломы': 'ВКР',
  'Курсовые': 'Курс.',
  'Рефераты': 'Реф.',
  'Отчёты по практике': 'Практика',
  'Самостоятельные работы': 'Самост.',
  'Эссе': 'Эссе',
  'Конспекты лекций': 'Конспект',
  'Методические материалы': 'Методич.',
  'НПР': 'НПР',
  'Другое': 'Другое',
};

interface ArchiveRow {
  no: number;
  title: string;
  category: string;
  shortType: string;
  subject: string;
  year: string;
  href: string;
}
const yearRe = /(?:19|20)\d{2}/;
function extractYearStr(doc: any): string {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text]
    .filter(Boolean)
    .join(' ');
  const m = blob.match(yearRe);
  return m ? m[0] : '';
}

// Last 25 in D order (catalog.json's natural sort). Newest-first on the page.
const archiveSlice = D.slice(Math.max(0, D.length - 25));
const archiveRows: ArchiveRow[] = archiveSlice
  .map((doc: any, i: number): ArchiveRow => ({
    no: D.length - (archiveSlice.length - 1 - i),
    title: doc.catalogTitle || doc.title || doc.filename || 'Работа',
    category: doc.category || 'Другое',
    shortType: archiveShortType[doc.category] || doc.category || 'Другое',
    subject: doc.subject || '',
    year: extractYearStr(doc),
    href: '/doc/' + doc.file,
  }))
  .reverse(); // newest at the top visually

// ── Q&A items (step 2.10). Texts are copied verbatim from the task. ──
interface QaItem { no: string; q: string; a: string; }
const qaItems: QaItem[] = [
  {
    no: '01',
    q: 'Как вы\u00a0используете ИИ?',
    a: 'Открыто: ИИ\u00a0— часть нашего процесса. Он\u00a0ускоряет поиск источников, фактчек, редактуру. Но\u00a0всё, что попадает в\u00a0финальный текст, проходит через несколько этапов нашей проверки\u00a0— руками. Мы\u00a0не\u00a0отстаём от\u00a0технологий: умеем пользоваться так, чтобы работа <em>защищалась</em>, а\u00a0не\u00a0заваливалась на\u00a0антиплагиате.',
  },
  {
    no: '02',
    q: 'Почему цены начинаются от\u00a02\u202F500\u00a0₽, а\u00a0не\u00a0дешевле?',
    a: 'Дешевле\u00a0— это копипаст или конвейер. Мы\u00a0работаем точечно, поэтому порог входа такой. Короткие форматы всё\u00a0равно самые доступные.',
  },
  {
    no: '03',
    q: 'Сколько времени занимает работа?',
    a: 'Спокойный режим\u00a0— от\u00a0недели для курсовой, от\u00a0трёх для\u00a0диплома. Собранный (×1.25)\u00a0— короче вдвое. Срочный (×1.6)\u00a0— можем сделать курсовую за\u00a0двое суток, диплом за\u00a0неделю. Даже за\u00a0сутки\u00a0— бывает, но\u00a0с\u00a0наценкой ×1.6 и\u00a0только если автор свободен. Берите время заранее\u00a0— выходит дешевле и\u00a0спокойнее.',
  },
  {
    no: '04',
    q: 'Какая уникальность на\u00a0антиплагиате?',
    a: 'Рабочий коридор 75–90% по\u00a0Антиплагиат.ВУЗ, зависит от\u00a0темы и\u00a0требований. Отчёт можно заказать отдельно в\u00a0калькуляторе.',
  },
  {
    no: '05',
    q: 'А\u00a0если работу вернут с\u00a0замечаниями?',
    a: 'Бесплатные правки по\u00a0замечаниям научрука в\u00a0рамках согласованного ТЗ. Переписывать главу с\u00a0нуля по\u00a0новому требованию\u00a0— отдельный разговор.',
  },
  {
    no: '06',
    q: 'Как устроена оплата?',
    a: '50% после согласования плана, 50% после защиты. Карты, СБП. Работаем как самозанятые\u00a0— чек после оплаты по\u00a0желанию.',
  },
  {
    no: '07',
    q: 'Можно пообщаться с\u00a0автором до\u00a0оплаты?',
    a: 'Да. Брифуем в\u00a0Telegram, VK или MAX\u00a0— выберите удобный канал. До\u00a0предоплаты разбираем задачу, формат, сроки.',
  },
  {
    no: '08',
    q: 'Что с\u00a0конфиденциальностью?',
    a: 'Заказанная работа не\u00a0публикуется в\u00a0архиве, данные не\u00a0передаются третьим лицам. В\u00a0архиве\u00a0— только то, что авторы сами согласились сделать публичным.',
  },
  {
    no: '09',
    q: 'Берётесь ли за\u00a0любые темы?',
    a: 'Берёмся почти за\u00a0любые темы\u00a0— психология, социальная работа, педагогика, гуманитарные, экономика, право. Исключение\u00a0— инженерка, программирование, медицина: туда не\u00a0идём, ответим честным «нет».',
  },
  {
    no: '10',
    q: 'А\u00a0если я\u00a0хочу сначала посмотреть готовую работу?',
    a: 'Для этого и\u00a0есть бесплатный архив\u00a0— 235+ работ: часть собрана студентами, которые поделились своими, часть\u00a0— наши собственные работы, опубликованные с\u00a0их\u00a0согласия. Читайте как ориентир, берите как пример формата.',
  },
];

const reviewAlts = [
  'Отзыв: Спасибо за работу',
  'Отзыв: У меня 5, работа очень хорошая',
  'Отзыв: Четвёрка твёрдая, отлично всё',
  'Отзыв: Автомат, 5 -- спасибо огромное',
  'Отзыв: Сдали с первого раза',
  'Отзыв: Сдала на 4, сказали хорошая работа',
  'Отзыв: Кайф, благодарю за быструю работу',
  'Отзыв: Всё отлично, спасибо',
  'Отзыв: Преподаватель поставил отлично',
  'Отзыв: Работа принята без замечаний',
];
---

<Base
  title="Библиотека академического салона -- студенческие работы без паники"
  description="Библиотека готовых студенческих работ: психология, социальная работа, конфликтология и другие гуманитарные дисциплины. Или закажите индивидуальную подготовку."
  currentPath="/"
  extraSchema={[
    {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Библиотека академического салона',
      alternateName: 'Академический Салон',
      url: 'https://bibliosaloon.ru/',
      inLanguage: 'ru-RU',
      description: 'Свободный архив студенческих работ и мастерская индивидуального заказа.',
    },
    {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: qaItems.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    },
  ]}
>

  <!-- Curtain intro removed — relying on natural CSS load instead of scripted overlay -->

  <!-- ============================================================
       PRELUDE — editorial hero (Dark Couture · step 2.1)
       ============================================================ -->
  <section class="prelude" id="prelude" aria-label="Вступление">
    <div class="prelude-wrap">
      <div class="prelude-head">
        <div class="col">
          <span class="lbl">Мастерская</span>
          <span class="val">с&nbsp;2020</span>
        </div>
        <div class="col">
          <span class="lbl">В&nbsp;архиве</span>
          <span class="val">{totalDocs} <i class="it">работ</i></span>
        </div>
        <div class="col">
          <span class="lbl">Сезон</span>
          <span class="val"><i class="it">MMXXVI</i></span>
        </div>
      </div>

      <div class="prelude-eyebrow-2" aria-hidden="true">
        <span class="rule"></span>
        <span class="word">Prelude</span>
      </div>

      <h1 class="prelude-h">
        <span class="ln">Написано с&nbsp;терпением,</span>
        <span class="ln">защищено с&nbsp;<em class="it">достоинством</em>.</span>
      </h1>

      <div class="prelude-foot">
        <p class="prelude-lede-2">
          Свободная библиотека из&nbsp;{totalDocs}&nbsp;студенческих работ и&nbsp;авторский заказ <em>под&nbsp;защиту</em>&nbsp;— от&nbsp;разговора до&nbsp;оценки в&nbsp;ведомости.
        </p>
        <div class="prelude-actions">
          <a href="/order" class="btn btn-gold btn-lg">Рассчитать стоимость</a>
          <a href="/catalog" class="btn btn-ghost-gold btn-lg">Открыть архив</a>
        </div>
      </div>
    </div>

    <a href="#manifesto" class="prelude-scroll-cue" aria-label="Читать дальше">
      <span class="lbl">читать дальше</span>
      <span class="line" aria-hidden="true"></span>
    </a>
  </section>

  <!-- ============================================================
       STATS — editorial column strip below the hero
       ============================================================ -->
  <section class="stats-strip rv" aria-label="О мастерской в цифрах">
    <div class="stats-strip-inner">
      <div class="stat-col">
        <span class="stat-lbl">В каталоге</span>
        <span class="stat-val">{totalDocs}<span class="stat-suffix">+</span> <i class="it">работ</i></span>
        <span class="stat-note">бесплатно, без регистрации</span>
      </div>
      <div class="stat-col">
        <span class="stat-lbl">Мастерская</span>
        <span class="stat-val"><span class="stat-sep">·</span> с 2020</span>
        <span class="stat-note">шесть лет собранной практики</span>
      </div>
      <div class="stat-col">
        <span class="stat-lbl">На связи</span>
        <span class="stat-val">15 <span class="stat-suffix">мин</span></span>
        <span class="stat-note">ответ живого человека в&nbsp;будни</span>
      </div>
    </div>
  </section>

  <!-- ============================================================
       I · MANIFESTO — editorial chapter (Dark Couture · step 2.2)
       ============================================================ -->
  <section id="manifesto" class="manifesto rv" aria-label="Манифест">
    <div class="manifesto-inner">
      <header class="chapter-head" data-reveal>
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">I</span>
          <span class="chapter-label">Caput Primum · Глава первая</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">О&nbsp;чём этот <em class="it">салон</em>.</h2>
          <p class="chapter-lede">Короткая правда о&nbsp;том, чем занимаемся: бесплатной библиотекой студенческих работ и&nbsp;авторскими заказами под защиту. Без&nbsp;коллцентра, без&nbsp;шаблонов, без&nbsp;конвейера.</p>
        </div>
      </header>

      <div class="manifesto-body" data-reveal data-reveal-delay="1">
        <p class="manifesto-text">
          <span class="manifesto-drop">М</span>ы&nbsp;собирали этот архив с&nbsp;2020&nbsp;года&nbsp;— из&nbsp;работ студентов, которые делились ими сами. {totalDocs}&nbsp;текстов по&nbsp;психологии, социальной работе, конфликтологии, педагогике. Берите целиком как образец, забирайте куски, ищите формулировки. <em class="it">Бесплатно</em> и&nbsp;без&nbsp;регистрации.
        </p>
        <p class="manifesto-text">
          Если в&nbsp;архиве нет вашей темы&nbsp;— напишем под вас. Не&nbsp;шаблон с&nbsp;биржи, а&nbsp;разговор, план, главу за&nbsp;главой с&nbsp;правками после каждой проверки руководителем. Под каждого научного руководителя мы&nbsp;собираем <em class="it">профиль</em>&nbsp;— знаем, что он&nbsp;любит и&nbsp;на&nbsp;чём срезает. Ведём до&nbsp;оценки в&nbsp;ведомости, а&nbsp;не&nbsp;до&nbsp;«высылаю файл».
        </p>
        <p class="manifesto-text">
          За&nbsp;шесть&nbsp;лет работы научились трём вещам: говорить «нет», когда тема не&nbsp;наша; не&nbsp;браться за&nbsp;то, что не&nbsp;успеем сделать как следует; и&nbsp;умело пользоваться <em class="it">ИИ</em>&nbsp;— не&nbsp;как заменой автору, а&nbsp;как инструментом на&nbsp;этапах поиска, проверки и&nbsp;редактуры. Работа отсюда не&nbsp;подводит на&nbsp;защите.
        </p>

        <div class="manifesto-signature" aria-hidden="true">
          <span class="sig">АС</span>
          <span class="under">— Академический Салон · MMXX—MMXXVI —</span>
        </div>
      </div>

      <div class="manifesto-tenets">
        <article class="tenet">
          <span class="tenet-num">Principium I</span>
          <h3 class="tenet-h">Свободный архив,<br/>а&nbsp;не&nbsp;витрина</h3>
          <p class="tenet-p">{totalDocs}+ работ скачиваются <em class="it">без&nbsp;оплаты</em> и&nbsp;без&nbsp;регистрации. Если работа спасла студента&nbsp;— она наша и&nbsp;общая.</p>
        </article>
        <article class="tenet">
          <span class="tenet-num">Principium II</span>
          <h3 class="tenet-h">Автор и&nbsp;ИИ&nbsp;—<br/>в&nbsp;правильных ролях</h3>
          <p class="tenet-p">Пишет конкретный автор с&nbsp;профильным образованием. ИИ используем как инструмент на&nbsp;этапах поиска, фактчека и&nbsp;редактуры. Финал <em class="it">всегда</em> через наши руки.</p>
        </article>
        <article class="tenet">
          <span class="tenet-num">Principium III</span>
          <h3 class="tenet-h">Сопровождение<br/>до&nbsp;оценки</h3>
          <p class="tenet-p">Правки после каждой проверки руководителем, репетиция защиты, речь, слайды&nbsp;— <em class="it">в&nbsp;цене</em>.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       II · CALENDAR — decorative 12-month workshop load (step 2.3)
       ============================================================ -->
  <section
    id="calendar"
    class="calendar rv"
    aria-label="Календарь мастерской"
    data-calendar-year={calendarNow.getFullYear()}
    data-calendar-month={calendarCurMonth}
    data-calendar-today={calendarNow.getDate()}
  >
    <div class="calendar-inner">
      <header class="chapter-head" data-reveal>
        <div class="chapter-num">
