<script>
  // ═══════════ TEXT SCRAMBLE EFFECT ═══════════
  class TextScramble {
    private el: HTMLElement;
    private chars = '!<>-_\\/[]{}—=+*^?#абвгдеёжзиклмнопрстуфхцчшщэюя';
    private frame = 0;
    private queue: Array<{from: string; to: string; start: number; end: number; char?: string}> = [];
    private resolve!: () => void;

    constructor(el: HTMLElement) {
      this.el = el;
    }

    setText(newText: string): Promise<void> {
      const oldText = this.el.innerText;
      const length = Math.max(oldText.length, newText.length);
      this.queue = [];
      for (let i = 0; i < length; i++) {
        const from = oldText[i] || '';
        const to = newText[i] || '';
        const start = Math.floor(Math.random() * 30);
        const end = start + Math.floor(Math.random() * 30);
        this.queue.push({ from, to, start, end });
      }
      cancelAnimationFrame(this.frame);
      return new Promise(resolve => {
        this.resolve = resolve;
        this.update();
      });
    }

    private update() {
      let output = '';
      let complete = 0;
      for (let i = 0; i < this.queue.length; i++) {
        let { from, to, start, end, char } = this.queue[i];
        if (this.frame >= end) {
          complete++;
          output += to;
        } else if (this.frame >= start) {
          if (!char || Math.random() < 0.28) {
            char = this.chars[Math.floor(Math.random() * this.chars.length)];
            this.queue[i].char = char;
          }
          output += `<span class="scramble-char">${char}</span>`;
        } else {
          output += from;
        }
      }
      this.el.innerHTML = output;
      if (complete === this.queue.length) {
        this.resolve();
      } else {
        this.frame++;
        this.frame = requestAnimationFrame(() => this.update());
      }
    }
  }

  // ═══════════ INIT SCRAMBLE TEXTS ═══════════
  function initScramble() {
    document.querySelectorAll('.scramble-text').forEach((el) => {
      const htmlEl = el as HTMLElement;
      const finalText = htmlEl.dataset.final;
      if (!finalText) return;
      const scramble = new TextScramble(htmlEl);
      const delay = parseInt(htmlEl.closest('[data-reveal-delay]')?.getAttribute('data-reveal-delay') || '0');
      setTimeout(() => scramble.setText(finalText), 600 + delay);
    });
  }

  // ═══════════ TYPEWRITER EFFECT ═══════════
  function initTypewriter() {
    const el = document.getElementById('heroTyped');
    if (!el) return;
    const phrases = [
      'Бесплатная библиотека работ по психологии и социальной работе.',
      'Курсовые, ВКР, рефераты — скачивай или закажи.',
      '235+ документов. 6 лет опыта. Гарантия сдачи.',
      'Индивидуально, по ГОСТ, с антиплагиатом.',
    ];
    let phraseIdx = 0;
    let charIdx = 0;
    let deleting = false;

    function type() {
      const phrase = phrases[phraseIdx];
      if (!deleting) {
        el.textContent = phrase.slice(0, charIdx++);
        if (charIdx > phrase.length) {
          deleting = true;
          setTimeout(type, 2500);
          return;
        }
        setTimeout(type, 35 + Math.random() * 25);
      } else {
        el.textContent = phrase.slice(0, charIdx--);
        if (charIdx < 0) {
          deleting = false;
          charIdx = 0;
          phraseIdx = (phraseIdx + 1) % phrases.length;
          setTimeout(type, 400);
          return;
        }
        setTimeout(type, 18);
      }
    }
    setTimeout(type, 1200);
  }

  // ═══════════ REVEAL SYSTEM ═══════════
  function initReveals() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const delay = parseInt((e.target as HTMLElement).dataset.revealDelay || '0');
          setTimeout(() => e.target.classList.add('visible'), delay);
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));

    // Hero elements auto-reveal
    document.querySelectorAll('.hero [data-reveal]').forEach(el => {
      const delay = parseInt((el as HTMLElement).dataset.revealDelay || '0');
      setTimeout(() => el.classList.add('visible'), 200 + delay);
    });
  }

  // ═══════════ LIVE TICKER ═══════════
  function initTicker() {
    const track = document.getElementById('tickerTrack');
    if (!track) return;

    const items = [
      { text: 'Курсовая по психологии', status: 'сдана на 5' },
      { text: 'ВКР по социальной работе', status: 'защита на отлично' },
      { text: 'Реферат «Мотивация»', status: 'выполнен за 2 дня' },
      { text: 'Отчёт по практике ГИПСР', status: 'сдан преподавателю' },
      { text: 'Контрольная по психодиагностике', status: 'оценка: отлично' },
      { text: 'Дипломная работа', status: 'защита с отличием' },
      { text: 'Курсовая по соцработе', status: 'принята без правок' },
      { text: 'Эссе по философии', status: 'сдано в срок' },
    ];

    const html = items.map(it =>
      `<div class="ticker-item"><span class="ticker-dot"></span>${it.text} — <span class="ticker-highlight">${it.status}</span></div>`
    ).join('');

    track.innerHTML = html + html; // duplicate for seamless loop
  }

  // ═══════════ SCROLL-DRIVEN PAPER ═══════════
  function initPaperJourney() {
    const sheet = document.getElementById('paperSheet');
    const steps = document.querySelectorAll('.paper-step');
    if (!sheet || !steps.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const ratio = e.intersectionRatio;

        if (ratio > 0.1) {
          sheet.classList.add('active');
          steps[0]?.classList.add('active');
        }
        if (ratio > 0.3) {
          sheet.classList.add('lines-visible');
          steps[1]?.classList.add('active');
        }
        if (ratio > 0.6) {
          sheet.classList.add('stamped');
          steps[2]?.classList.add('active');
        }
      });
    }, { threshold: [0, 0.1, 0.3, 0.6, 1] });

    observer.observe(sheet);
  }

  // ═══════════ 3D TILT CARDS ═══════════
  function initTiltCards() {
    document.querySelectorAll('[data-tilt]').forEach(card => {
      const el = card as HTMLElement;

      el.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = el.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;

        el.style.transform = `perspective(600px) rotateY(${x * 8}deg) rotateX(${-y * 8}deg) scale(1.02)`;

        // Light refraction effect
        const inner = el.querySelector('.card') as HTMLElement;
        if (inner) {
          inner.style.background = `
            radial-gradient(circle at ${(x + 0.5) * 100}% ${(y + 0.5) * 100}%,
              rgba(212,175,55,.06) 0%, transparent 50%),
            var(--card)
          `;
        }
      });

      el.addEventListener('mouseleave', () => {
        el.style.transform = '';
        const inner = el.querySelector('.card') as HTMLElement;
        if (inner) inner.style.background = '';
      });
    });
  }

  // ═══════════ COUNTER ANIMATION ═══════════
  function initCounters() {
    const counters = document.querySelectorAll('[data-count]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const el = e.target as HTMLElement;
        const target = parseInt(el.dataset.count || '0');
        const duration = 2000;
        const start = performance.now();

        function update(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          // Ease out cubic
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.floor(target * eased).toString();
          if (progress < 1) requestAnimationFrame(update);
        }
        requestAnimationFrame(update);
        observer.unobserve(el);
      });
    }, { threshold: 0.5 });

    counters.forEach(c => observer.observe(c));
  }

  // ═══════════ FLOATING CTA ═══════════
  function initFloatCta() {
    const floatEl = document.getElementById('floatCta');
    if (!floatEl) return;

    window.addEventListener('scroll', () => {
      if (window.scrollY > window.innerHeight * 0.6) {
        floatEl.classList.add('visible');
      } else {
        floatEl.classList.remove('visible');
      }
    }, { passive: true });
  }

  // ═══════════ TOAST NOTIFICATIONS ═══════════
  function initToasts() {
    const container = document.getElementById('toastContainer');
    if (!container) return;

    const toasts = [
      'Курсовая по психологии — сдана на 5',
      'Новый заказ: ВКР по социальной работе',
      'Реферат «Мотивация» — скачан 3 мин. назад',
      'Дипломная работа — защита на отлично',
      'Отчёт по практике — выполнен за 1 день',
      'Контрольная по психодиагностике — готова',
    ];
    let idx = 0;

    function showToast() {
      const toast = document.createElement('div');
      toast.className = 'toast';
      toast.innerHTML = `<span class="toast-icon"></span>${toasts[idx % toasts.length]}`;
      container.appendChild(toast);
      idx++;
      setTimeout(() => toast.remove(), 6000);
    }

    // First toast after 8s, then every 15s
    setTimeout(() => {
      showToast();
      setInterval(showToast, 15000);
    }, 8000);
  }

  // ═══════════ GOLD FLUID SIMULATION ═══════════
  function initGoldFluid() {
    const canvas = document.getElementById('goldFluid') as HTMLCanvasElement;
    if (!canvas) return;

    const gl = canvas.getContext('webgl', { alpha: true, premultipliedAlpha: false });
    if (!gl) return;

    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    const vertSrc = `
      attribute vec2 a_position;
      void main() { gl_Position = vec4(a_position, 0, 1); }
    `;

    const fragSrc = `
      precision mediump float;
      uniform vec2 u_resolution;
      uniform float u_time;
      uniform vec2 u_mouse;
      uniform float u_scroll;

      float hash(vec2 p) {
        return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
      }

      float noise(vec2 p) {
        vec2 i = floor(p);
        vec2 f = fract(p);
        f = f * f * (3.0 - 2.0 * f);
        float a = hash(i);
        float b = hash(i + vec2(1, 0));
        float c = hash(i + vec2(0, 1));
        float d = hash(i + vec2(1, 1));
        return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
      }

      float fbm(vec2 p) {
        float v = 0.0;
        float a = 0.5;
        for (int i = 0; i < 4; i++) {
          v += a * noise(p);
          p *= 2.0;
          a *= 0.5;
        }
        return v;
      }

      void main() {
        vec2 uv = gl_FragCoord.xy / u_resolution;
        vec2 mouse = u_mouse / u_resolution;

        float t = u_time * 0.15;

        // Flowing gold noise
        float n1 = fbm(uv * 3.0 + vec2(t, t * 0.7));
        float n2 = fbm(uv * 2.0 - vec2(t * 0.5, t * 0.3) + n1 * 0.5);

        // Mouse interaction — ripple
        float dist = length(uv - mouse);
        float ripple = smoothstep(0.3, 0.0, dist) * 0.15;

        // Scroll color shift
        float scrollShift = u_scroll * 0.001;

        // Gold color with purple shift on scroll
        vec3 gold = vec3(0.83, 0.69, 0.22);
        vec3 purple = vec3(0.65, 0.48, 0.98);
        vec3 col = mix(gold, purple, scrollShift * 0.3 + n2 * 0.15);

        float alpha = (n2 * 0.04 + ripple) * smoothstep(0.0, 0.3, uv.y);
        alpha *= 0.7; // overall subtlety

        gl_FragColor = vec4(col * alpha, alpha);
      }
    `;

    function createShader(type: number, source: string) {
      const shader = gl!.createShader(type)!;
      gl!.shaderSource(shader, source);
      gl!.compileShader(shader);
      return shader;
    }

    const vert = createShader(gl.VERTEX_SHADER, vertSrc);
    const frag = createShader(gl.FRAGMENT_SHADER, fragSrc);
    const program = gl.createProgram()!;
    gl.attachShader(program, vert);
    gl.attachShader(program, frag);
    gl.linkProgram(program);
    gl.useProgram(program);

    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);

    const posLoc = gl.getAttribLocation(program, 'a_position');
    gl.enableVertexAttribArray(posLoc);
    gl.vertexAttribPointer(posLoc, 2, gl.FLOAT, false, 0, 0);

    const uRes = gl.getUniformLocation(program, 'u_resolution');
    const uTime = gl.getUniformLocation(program, 'u_time');
    const uMouse = gl.getUniformLocation(program, 'u_mouse');
    const uScroll = gl.getUniformLocation(program, 'u_scroll');

    let mouseX = canvas.width / 2;
    let mouseY = canvas.height / 2;

    document.addEventListener('mousemove', e => {
      mouseX = e.clientX;
      mouseY = canvas.height - e.clientY;
    });

    gl.enable(gl.BLEND);
    gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);

    function render(time: number) {
      if (!gl) return;
      gl.viewport(0, 0, canvas.width, canvas.height);
      gl.clear(gl.COLOR_BUFFER_BIT);
      gl.uniform2f(uRes, canvas.width, canvas.height);
      gl.uniform1f(uTime, time * 0.001);
      gl.uniform2f(uMouse, mouseX, mouseY);
      gl.uniform1f(uScroll, window.scrollY);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
      requestAnimationFrame(render);
    }
    requestAnimationFrame(render);

    window.addEventListener('resize', () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    });
  }

  // ═══════════ HERO PARTICLE RAIN ═══════════
  function initParticles() {
    const container = document.getElementById('heroParticles');
    if (!container) return;

    for (let i = 0; i < 30; i++) {
      const p = document.createElement('div');
      p.style.cssText = `
        position: absolute;
        width: ${1 + Math.random() * 2}px;
        height: ${1 + Math.random() * 2}px;
        background: rgba(212,175,55,${0.15 + Math.random() * 0.25});
        border-radius: 50%;
        left: ${Math.random() * 100}%;
        top: ${Math.random() * 100}%;
        animation: particle-float ${8 + Math.random() * 12}s linear infinite;
        animation-delay: ${-Math.random() * 10}s;
      `;
      container.appendChild(p);
    }
  }

  // ═══════════ SCRAMBLE CHAR STYLE ═══════════
  const scrambleStyle = document.createElement('style');
  scrambleStyle.textContent = `
    .scramble-char { color: var(--ac); opacity: .6 }
    @keyframes particle-float {
      0% { transform: translateY(0) translateX(0); opacity: 0 }
      10% { opacity: 1 }
      90% { opacity: 1 }
      100% { transform: translateY(-100vh) translateX(${Math.random() > 0.5 ? '' : '-'}30px); opacity: 0 }
    }
  `;
  document.head.appendChild(scrambleStyle);

  // ═══════════ SCROLL-DRIVEN MANIFESTO ═══════════
  function initManifesto() {
    const words = document.querySelectorAll('.mw');
    if (!words.length) return;

    const section = document.getElementById('manifesto');
    if (!section) return;

    function updateWords() {
      const rect = section.getBoundingClientRect();
      const vh = window.innerHeight;

      // Section progress: 0 when top enters, 1 when bottom leaves
      const sectionTop = rect.top;
      const sectionHeight = rect.height;
      const progress = Math.max(0, Math.min(1, (vh - sectionTop) / (vh + sectionHeight)));

      // Map progress to word reveals
      const totalWords = words.length;
      words.forEach((w, i) => {
        const wordThreshold = (i / totalWords) * 0.8 + 0.1; // spread across 10%-90% of progress
        if (progress >= wordThreshold) {
          w.classList.add('lit');
        } else {
          w.classList.remove('lit');
        }
      });
    }

    window.addEventListener('scroll', updateWords, { passive: true });
    updateWords();
  }

  // ═══════════ INIT ALL ═══════════
  initReveals();
  initScramble();
  initTypewriter();
  initTicker();
  initPaperJourney();
  initTiltCards();
  initCounters();
  initFloatCta();
  initToasts();
  initGoldFluid();
  initParticles();
  initManifesto();

  // Re-init after Astro view transitions
  document.addEventListener('astro:after-swap', () => {
    initReveals();
    initScramble();
    initTypewriter();
    initTicker();
    initPaperJourney();
    initTiltCards();
    initCounters();
    initFloatCta();
    initToasts();
    initGoldFluid();
    initParticles();
    initManifesto();
  });
</script>
