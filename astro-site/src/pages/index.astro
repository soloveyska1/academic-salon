---
import Base from '../layouts/Base.astro';
import DocumentCard from '../components/DocumentCard.astro';
import { D } from '../data/catalog.js';

// Pick featured documents (different categories)
const categories = ['ВКР и дипломы', 'Курсовые работы', 'Рефераты', 'Отчёты по практике', 'Контрольные работы', 'Методические материалы'];
const featured: typeof D = [];
for (const cat of categories) {
  const doc = D.find(d => d.category === cat && !featured.includes(d));
  if (doc) featured.push(doc);
}
// Fill to 6 if needed
while (featured.length < 6) {
  const doc = D.find(d => !featured.includes(d));
  if (doc) featured.push(doc);
  else break;
}

const stats = {
  docs: D.length,
  subjects: [...new Set(D.map(d => d.subject).filter(Boolean))].length,
  categories: [...new Set(D.map(d => d.category).filter(Boolean))].length,
};
---

<Base title="Академический Салон — Библиотека студенческих работ" currentPath="/">

  <!-- SECTION 1: HERO -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-glow-gold"></div>
      <div class="hero-glow-purple"></div>
      <div class="hero-dots"></div>
    </div>
    <div class="container hero-container">
      <div class="hero-content">

        <div class="hero-eyebrow reveal">
          <span class="pulse-dot"></span>
          <span class="hero-eyebrow-text">Библиотека студенческих работ</span>
        </div>

        <h1 class="hero-h1 reveal">
          Академический<br/>
          <em class="gold-shimmer">Салон</em>
        </h1>

        <p class="hero-tagline reveal">
          Крупнейшая коллекция проверенных студенческих работ
          по психологии и социальной работе.
          <strong>Бесплатно.</strong>
        </p>

        <div class="hero-actions reveal">
          <a href="/catalog" class="btn btn-primary btn-lg">
            Открыть каталог
            <span class="hero-btn-badge">{stats.docs}</span>
          </a>
          <a href="/order" class="btn btn-ghost btn-lg">Заказать работу &rarr;</a>
        </div>

        <div class="hero-search reveal">
          <div class="hero-search-inner">
            <svg class="hero-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input
              type="text"
              class="hero-search-input"
              placeholder="Найти работу по теме, предмету или ключевому слову..."
              id="heroSearch"
            />
            <kbd class="hero-search-kbd">Enter</kbd>
          </div>
          <div class="hero-hints">
            Популярное:
            <a href="/catalog?q=психология" class="hero-hint">психология</a>
            <a href="/catalog?q=курсовая" class="hero-hint">курсовая</a>
            <a href="/catalog?q=диплом" class="hero-hint">диплом</a>
            <a href="/catalog?q=практика" class="hero-hint">практика</a>
          </div>
        </div>

        <div class="hero-metrics reveal">
          <div class="hero-metric">
            <span class="hero-metric-n gold-shimmer" data-count={stats.docs}>{stats.docs}+</span>
            <span class="hero-metric-l">документов</span>
          </div>
          <span class="hero-metric-div" aria-hidden="true"></span>
          <div class="hero-metric">
            <span class="hero-metric-n gold-shimmer" data-count={stats.subjects}>{stats.subjects}</span>
            <span class="hero-metric-l">предметов</span>
          </div>
          <span class="hero-metric-div" aria-hidden="true"></span>
          <div class="hero-metric">
            <span class="hero-metric-n gold-shimmer" data-count="93">93%</span>
            <span class="hero-metric-l">сдача</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SECTION 2: TRUST STRIP -->
  <section class="trust-strip reveal">
    <div class="container">
      <span class="trust-label section-label">Работы по направлениям</span>
      <div class="trust-row">
        <span class="trust-item">Психология</span>
        <span class="trust-slash" aria-hidden="true">/</span>
        <span class="trust-item">Социальная работа</span>
        <span class="trust-slash" aria-hidden="true">/</span>
        <span class="trust-item">Педагогика</span>
        <span class="trust-slash" aria-hidden="true">/</span>
        <span class="trust-item">Конфликтология</span>
        <span class="trust-slash" aria-hidden="true">/</span>
        <span class="trust-item">Социология</span>
      </div>
    </div>
  </section>

  <!-- SECTION 3: FEATURED DOCUMENTS -->
  <section class="featured">
    <div class="container">
      <div class="featured-header reveal">
        <div>
          <h2 class="featured-title">Из каталога</h2>
          <p class="featured-sub">Бесплатные работы, проверенные и готовые к скачиванию</p>
        </div>
      </div>
      <div class="doc-grid-bento reveal">
        {featured.map((doc, i) => (
          <DocumentCard doc={doc} index={i} />
        ))}
      </div>
      <div class="featured-cta reveal">
        <a href="/catalog" class="btn btn-secondary">
          Смотреть все {stats.docs} документов &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- SECTION 4: HOW IT WORKS -->
  <section class="how-section">
    <div class="container">
      <div class="how-header reveal">
        <h2 class="featured-title">Как это работает</h2>
      </div>
      <div class="how-grid">
        <div class="how-card reveal">
          <span class="how-num">01</span>
          <h3 class="how-card-title">Найдите в каталоге</h3>
          <p class="how-card-desc">Более {stats.docs} готовых работ по психологии и социальной работе. Скачайте бесплатно за пару кликов.</p>
          <a href="/catalog" class="how-link">Открыть каталог &rarr;</a>
        </div>
        <div class="how-card reveal">
          <span class="how-num">02</span>
          <h3 class="how-card-title">Или закажите</h3>
          <p class="how-card-desc">Не нашли нужную тему? Закажите индивидуальную работу с гарантией сдачи и бесплатными правками.</p>
          <a href="/order" class="how-link">Узнать стоимость &rarr;</a>
        </div>
        <div class="how-card reveal">
          <span class="how-num">03</span>
          <h3 class="how-card-title">Сдайте на отлично</h3>
          <p class="how-card-desc">93% наших работ принимают с первого раза. Мы сопровождаем до полной сдачи преподавателю.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 5: TESTIMONIALS -->
  <section class="testimonials">
    <div class="container">
      <div class="testimonials-header reveal">
        <h2 class="featured-title">Отзывы студентов</h2>
      </div>
      <div class="testimonials-grid">
        <div class="testimonial-card reveal">
          <span class="testimonial-quote" aria-hidden="true">&ldquo;</span>
          <p class="testimonial-text">Заказывала курсовую по психологии — сделали за неделю, уникальность 82%. Преподаватель приняла с первого раза.</p>
          <div class="testimonial-author">
            <span class="testimonial-avatar">А</span>
            <div>
              <span class="testimonial-name">Анастасия К.</span>
              <span class="testimonial-role">4 курс, психология</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card reveal">
          <span class="testimonial-quote" aria-hidden="true">&ldquo;</span>
          <p class="testimonial-text">Дипломную писали с нуля под мою тему. Научрук одобрил без правок.</p>
          <div class="testimonial-author">
            <span class="testimonial-avatar">В</span>
            <div>
              <span class="testimonial-name">Выпускник 2025</span>
              <span class="testimonial-role">социальная работа</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card reveal">
          <span class="testimonial-quote" aria-hidden="true">&ldquo;</span>
          <p class="testimonial-text">Срочная контрольная за 1 день — думал невозможно, но ребята сделали. Оценка 5.</p>
          <div class="testimonial-author">
            <span class="testimonial-avatar">М</span>
            <div>
              <span class="testimonial-name">Максим Д.</span>
              <span class="testimonial-role">2 курс, психология</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION 6: CTA -->
  <section class="home-cta">
    <div class="container">
      <div class="home-cta-card reveal">
        <div class="home-cta-glow" aria-hidden="true"></div>
        <div class="home-cta-content">
          <span class="home-cta-badge">
            <span class="home-cta-badge-line"></span>
            Индивидуально на заказ
          </span>
          <h2 class="home-cta-title">
            Нужна работа<br/>
            <em class="gold-shimmer">под ваши требования?</em>
          </h2>
          <p class="home-cta-desc">
            Делаем любые студенческие работы с гарантией сдачи.
            93% работ принимают с первого раза.
          </p>
          <div class="home-cta-actions">
            <a href="/order" class="btn btn-primary">Узнать стоимость &rarr;</a>
            <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost">Написать в ВК &rarr;</a>
          </div>
        </div>
        <div class="home-cta-stats">
          <div class="home-cta-stat">
            <span class="home-cta-stat-n">93%</span>
            <span class="home-cta-stat-l">сдают с первого раза</span>
          </div>
          <div class="home-cta-stat">
            <span class="home-cta-stat-n">&infin;</span>
            <span class="home-cta-stat-l">бесплатных правок</span>
          </div>
          <div class="home-cta-stat">
            <span class="home-cta-stat-n">50/50</span>
            <span class="home-cta-stat-l">оплата по частям</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ═══════════════════════════════════════
     SECTION 1: HERO
     ═══════════════════════════════════════ */
  .hero {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    padding: var(--sp-24) 0 var(--sp-12);
  }

  /* Background effects */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .hero-glow-gold {
    position: absolute;
    top: 50%; left: 50%;
    width: 900px; height: 900px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(212,175,55,.08) 0%, transparent 70%);
    border-radius: 50%;
  }
  .hero-glow-purple {
    position: absolute;
    bottom: -20%; right: -10%;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(167,139,250,.04) 0%, transparent 70%);
    border-radius: 50%;
  }
  .hero-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(212,175,55,.06) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black 30%, transparent 80%);
  }

  .hero-container {
    position: relative;
    z-index: 1;
  }
  .hero-content {
    max-width: 720px;
    margin: 0 auto;
  }

  /* Eyebrow */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-3);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--ac);
    opacity: .7;
    margin-bottom: var(--sp-8);
  }
  .hero-eyebrow-text {
    font-family: var(--fi);
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: .4; transform: scale(.7); }
  }
  .pulse-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--ac);
    display: inline-block;
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  /* H1 */
  .hero-h1 {
    font-family: var(--fd);
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 900;
    letter-spacing: -.04em;
    line-height: .95;
    color: var(--t1);
    margin-bottom: var(--sp-6);
  }
  .hero-h1 em {
    font-style: italic;
    letter-spacing: -.02em;
  }

  /* Tagline */
  .hero-tagline {
    font-size: 17px;
    color: var(--t2);
    max-width: 500px;
    margin: 0 auto var(--sp-8);
    line-height: 1.75;
  }
  .hero-tagline strong {
    color: var(--ac2);
    font-weight: 700;
  }

  /* CTA buttons */
  .hero-actions {
    display: flex;
    gap: var(--sp-4);
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: var(--sp-8);
  }
  .btn-lg {
    padding: 14px 32px;
    font-size: 15px;
  }
  .hero-btn-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 28px;
    height: 22px;
    padding: 0 6px;
    border-radius: 100px;
    background: rgba(255,255,255,.15);
    font-size: 11px;
    font-weight: 700;
    margin-left: 8px;
    letter-spacing: 0;
  }

  /* Search */
  .hero-search {
    max-width: 580px;
    margin: 0 auto var(--sp-8);
  }
  .hero-search-inner {
    position: relative;
  }
  .hero-search-icon {
    position: absolute;
    left: 20px; top: 50%;
    transform: translateY(-50%);
    width: 20px; height: 20px;
    color: var(--t3);
    pointer-events: none;
    transition: color .3s;
  }
  .hero-search-input {
    width: 100%;
    height: 60px;
    padding: 0 80px 0 54px;
    background: var(--glass);
    backdrop-filter: var(--glass-b);
    -webkit-backdrop-filter: var(--glass-b);
    border: 1px solid var(--brd);
    border-radius: var(--r);
    color: var(--t1);
    font-size: 15px;
    font-family: inherit;
    outline: 0;
    transition: all .35s var(--ease);
  }
  .hero-search-input::placeholder { color: var(--t3) }
  .hero-search-input:focus {
    border-color: rgba(212,175,55,.25);
    box-shadow: 0 0 0 4px rgba(212,175,55,.06), 0 16px 48px rgba(0,0,0,.2);
    background: var(--bg);
  }
  .hero-search-kbd {
    position: absolute;
    right: 16px; top: 50%;
    transform: translateY(-50%);
    padding: 4px 10px;
    border-radius: var(--rx);
    background: var(--bg3);
    border: 1px solid var(--brd);
    font-size: 11px;
    font-family: var(--fm);
    color: var(--t3);
    opacity: 0;
    transition: opacity .25s var(--ease);
    pointer-events: none;
  }
  .hero-search-input:focus ~ .hero-search-kbd {
    opacity: 1;
  }

  .hero-hints {
    margin-top: var(--sp-3);
    font-size: 12px;
    color: var(--t3);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    flex-wrap: wrap;
  }
  .hero-hint {
    padding: 4px 12px;
    border-radius: 100px;
    background: var(--ac-g2);
    border: 1px solid var(--brd);
    color: var(--t2);
    font-size: 12px;
    font-weight: 500;
    text-decoration: none;
    transition: all var(--dur-fast) var(--ease);
  }
  .hero-hint:hover {
    border-color: var(--ac);
    color: var(--ac2);
    background: var(--ac-g);
  }

  /* Metrics bar */
  .hero-metrics {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0;
    padding: var(--sp-6) var(--sp-8);
    background: var(--glass);
    backdrop-filter: var(--glass-b);
    -webkit-backdrop-filter: var(--glass-b);
    border: 1px solid var(--brd);
    border-radius: var(--r);
  }
  .hero-metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    flex: 1;
  }
  .hero-metric-n {
    font-family: var(--fd);
    font-size: 32px;
    font-weight: 900;
    line-height: 1;
  }
  .hero-metric-l {
    font-size: 11px;
    color: var(--t3);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 500;
  }
  .hero-metric-div {
    width: 1px;
    height: 40px;
    background: var(--brd);
    flex-shrink: 0;
  }

  /* ═══════════════════════════════════════
     SECTION 2: TRUST STRIP
     ═══════════════════════════════════════ */
  .trust-strip {
    border-top: 1px solid var(--brd);
    border-bottom: 1px solid var(--brd);
    padding: var(--sp-8) 0;
    text-align: center;
  }
  .trust-label {
    display: block;
    margin-bottom: var(--sp-4);
  }
  .trust-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-4);
    flex-wrap: wrap;
  }
  .trust-item {
    font-family: var(--fd);
    font-size: 18px;
    font-weight: 600;
    color: var(--t1);
    opacity: .5;
    transition: opacity var(--dur) var(--ease);
    cursor: default;
  }
  .trust-item:hover {
    opacity: .8;
  }
  .trust-slash {
    color: var(--ac);
    opacity: .35;
    font-size: 20px;
    font-weight: 300;
  }

  /* ═══════════════════════════════════════
     SECTION 3: FEATURED
     ═══════════════════════════════════════ */
  .featured {
    padding: var(--sp-16) 0 var(--sp-12);
  }
  .featured-header {
    margin-bottom: var(--sp-8);
  }
  .featured-title {
    font-family: var(--fd);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 900;
    color: var(--t1);
    letter-spacing: -.02em;
    line-height: 1.1;
    margin-bottom: var(--sp-2);
  }
  .featured-sub {
    font-size: 15px;
    color: var(--t3);
    line-height: 1.6;
  }
  .doc-grid-bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: auto;
    gap: var(--sp-4);
  }
  .doc-grid-bento > :first-child {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }
  .featured-cta {
    text-align: center;
    margin-top: var(--sp-8);
  }

  /* ═══════════════════════════════════════
     SECTION 4: HOW IT WORKS
     ═══════════════════════════════════════ */
  .how-section {
    background: var(--bg2);
    border-top: 1px solid var(--brd);
    border-bottom: 1px solid var(--brd);
    padding: var(--sp-16) 0;
  }
  .how-header {
    margin-bottom: var(--sp-8);
  }
  .how-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }
  .how-card {
    padding: var(--sp-8);
    border: 1px solid var(--brd);
    border-radius: var(--r);
    background: var(--card);
    transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .how-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-gold);
    border-color: var(--brd-h);
  }
  .how-num {
    font-family: var(--fm);
    font-size: 13px;
    font-weight: 700;
    color: var(--ac);
    opacity: .6;
    margin-bottom: var(--sp-4);
    display: block;
  }
  .how-card-title {
    font-family: var(--fd);
    font-size: 20px;
    font-weight: 800;
    color: var(--t1);
    margin-bottom: var(--sp-3);
    letter-spacing: -.01em;
  }
  .how-card-desc {
    font-size: 14px;
    color: var(--t2);
    line-height: 1.7;
    margin-bottom: var(--sp-4);
  }
  .how-link {
    font-size: 13px;
    font-weight: 600;
    color: var(--ac);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }
  .how-link:hover {
    color: var(--ac2);
  }

  /* ═══════════════════════════════════════
     SECTION 5: TESTIMONIALS
     ═══════════════════════════════════════ */
  .testimonials {
    padding: var(--sp-16) 0;
  }
  .testimonials-header {
    margin-bottom: var(--sp-8);
  }
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-4);
  }
  .testimonial-card {
    padding: var(--sp-8);
    border: 1px solid var(--brd);
    border-radius: var(--r);
    background: var(--card);
    position: relative;
    transition: border-color var(--dur) var(--ease), box-shadow var(--dur) var(--ease);
  }
  .testimonial-card:hover {
    border-color: var(--brd-h);
    box-shadow: var(--shadow-gold);
  }
  .testimonial-quote {
    font-family: var(--fd);
    font-size: 48px;
    font-weight: 900;
    line-height: 1;
    color: var(--ac);
    opacity: .2;
    display: block;
    margin-bottom: var(--sp-2);
  }
