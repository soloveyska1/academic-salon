  /* ================================================================
     CALENDAR — month buttons + day-grid dialog (post-launch upgrade)
     Month cells become <button> so they're focusable; a native <dialog>
     opens a 7-column day grid with decorative load states. Real dates
     agreed in Telegram — the site doesn't pretend to be a booking system.
     ================================================================ */
  .month {
    background: transparent;
    border: 0;
    font: inherit;
    color: inherit;
    cursor: pointer;
    width: 100%;
  }
  .month:focus-visible {
    outline: 1px solid var(--gold);
    outline-offset: 4px;
  }

  .cal-modal {
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--cream);
    max-width: min(640px, 92vw);
    width: 100%;
    max-height: 90vh;
    margin: auto;
    overflow: visible;
  }
  .cal-modal::backdrop {
    background: rgba(10, 9, 8, 0.82);
    backdrop-filter: blur(16px) saturate(140%);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
  }
  .cal-modal:not([open]) { display: none; }
  .cal-modal-body {
    background: var(--ink-2);
    border: 1px solid var(--gold-line);
    padding: clamp(24px, 4vw, 40px);
    position: relative;
    max-height: 90vh;
    overflow-y: auto;
