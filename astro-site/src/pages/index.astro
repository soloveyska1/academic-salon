---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';
import { qaItems } from '../data/faq';
import FAQ from '../components/home/FAQ.astro';
import Manifesto from '../components/home/Manifesto.astro';
import Genres from '../components/home/Genres.astro';
import Method from '../components/home/Method.astro';
import Epilogue from '../components/home/Epilogue.astro';
import Archive from '../components/home/Archive.astro';
import Formula from '../components/home/Formula.astro';
import Calendar from '../components/home/Calendar.astro';
import Testimonia from '../components/home/Testimonia.astro';

const totalDocs = D.length;
const currentYear = String(new Date().getFullYear());

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const match = blob.match(/(?:19|20)\d{2}/);
  return match ? match[0] : currentYear;
}

function normalizeDoc(doc: any, index: number) {
  return {
    id: `${doc.file}-${index}`,
    slug: doc.file,
    title: doc.catalogTitle || doc.title || doc.filename || 'Студенческая работа',
    type: doc.docType || doc.category || 'Работа',
    subject: doc.subject || 'Психология',
    year: extractYear(doc),
  };
}

const preferredCategories = [
  'ВКР и дипломы',
  'Курсовые работы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
  'Методические материалы',
];

const pickedDocs: any[] = [];
for (const category of preferredCategories) {
  const nextDocs = D.filter((doc: any) => doc.category === category).slice(0, 1);
  pickedDocs.push(...nextDocs);
}
if (pickedDocs.length < 6) {
  for (const doc of D) {
    if (pickedDocs.includes(doc)) continue;
    pickedDocs.push(doc);
    if (pickedDocs.length >= 6) break;
  }
}

const cards = pickedDocs.slice(0, 6).map(normalizeDoc);



---

<Base
  title="Библиотека академического салона -- студенческие работы без паники"
  description="Библиотека готовых студенческих работ: психология, социальная работа, конфликтология и другие гуманитарные дисциплины. Или закажите индивидуальную подготовку."
  currentPath="/"
  extraSchema={[
    {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Библиотека академического салона',
      alternateName: 'Академический Салон',
      url: 'https://bibliosaloon.ru/',
      inLanguage: 'ru-RU',
      description: 'Свободный архив студенческих работ и мастерская индивидуального заказа.',
    },
    {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: qaItems.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    },
  ]}
>

  <!-- Curtain intro removed — relying on natural CSS load instead of scripted overlay -->

  <!-- ============================================================
       PRELUDE — editorial hero (Dark Couture · step 2.1)
       ============================================================ -->
  <section class="prelude" id="prelude" aria-label="Вступление">
    <div class="prelude-wrap">
      <div class="prelude-head">
        <div class="col">
          <span class="lbl">Мастерская</span>
          <span class="val">с&nbsp;2020</span>
        </div>
        <div class="col">
          <span class="lbl">В&nbsp;архиве</span>
          <span class="val">{totalDocs} <i class="it">работ</i></span>
        </div>
        <div class="col">
          <span class="lbl">Сезон</span>
          <span class="val"><i class="it">MMXXVI</i></span>
        </div>
      </div>

      <div class="prelude-eyebrow-2" aria-hidden="true">
        <span class="rule"></span>
        <span class="word">Prelude</span>
      </div>

      <h1 class="prelude-h">
        <span class="ln">Написано с&nbsp;терпением,</span>
        <span class="ln">защищено с&nbsp;<em class="it">достоинством</em>.</span>
      </h1>

      <div class="prelude-foot">
        <p class="prelude-lede-2">
          Свободная библиотека из&nbsp;{totalDocs}&nbsp;студенческих работ и&nbsp;авторский заказ <em>под&nbsp;защиту</em>&nbsp;— от&nbsp;разговора до&nbsp;оценки в&nbsp;ведомости.
        </p>
        <div class="prelude-actions">
          <a href="/order" class="btn btn-gold btn-lg">Рассчитать стоимость</a>
          <a href="/catalog" class="btn btn-ghost-gold btn-lg">Открыть архив</a>
        </div>
      </div>
    </div>

    <a href="#manifesto" class="prelude-scroll-cue" aria-label="Читать дальше">
      <span class="lbl">читать дальше</span>
      <span class="line" aria-hidden="true"></span>
    </a>
  </section>

  <!-- ============================================================
       STATS — editorial column strip below the hero
       ============================================================ -->
  <section class="stats-strip rv" aria-label="О мастерской в цифрах">
    <div class="stats-strip-inner">
      <div class="stat-col">
        <span class="stat-lbl">В каталоге</span>
        <span class="stat-val">{totalDocs}<span class="stat-suffix">+</span> <i class="it">работ</i></span>
        <span class="stat-note">бесплатно, без регистрации</span>
      </div>
      <div class="stat-col">
        <span class="stat-lbl">Мастерская</span>
        <span class="stat-val"><span class="stat-sep">·</span> с 2020</span>
        <span class="stat-note">шесть лет собранной практики</span>
      </div>
      <div class="stat-col">
        <span class="stat-lbl">На связи</span>
        <span class="stat-val">15 <span class="stat-suffix">мин</span></span>
        <span class="stat-note">ответ живого человека в&nbsp;будни</span>
      </div>
    </div>
  </section>

  <Manifesto totalDocs={totalDocs} />

  <Calendar />

  <Genres />

  <Formula />
  <Archive />

  <Method />

  <Testimonia />

  <FAQ />

  <!-- ============================================================
       3. CATALOG -- Bento grid
       ============================================================ -->
  <section class="catalog rv">
    <div class="catalog-inner">
      <div class="catalog-head">
        <h2 class="section-title">Каталог</h2>
        <a href="/catalog" class="section-link">Все работы &rarr;</a>
      </div>
      <div class="catalog-grid">
        {cards.map((card) => (
          <a href={`/doc/${card.slug}`} class="card">
            <span class="card-type">{card.type}</span>
            <h3 class="card-title">{card.title}</h3>
            <span class="card-meta">{card.subject} &middot; {card.year}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Epilogue />

  <!-- ============================================================
       FOOTER — editorial (step 2.11C)
       ============================================================ -->
  <footer class="salon-footer" aria-label="Подвал сайта">
    <div class="salon-footer-inner">
      <div class="sf-grid">
        <div class="sf-brand">
          <span class="sf-mark" aria-hidden="true">АС</span>
          <p class="sf-tagline">
            Академический Салон&nbsp;— мастерская студенческих работ с&nbsp;2020&nbsp;года. Библиотека из&nbsp;{totalDocs}&nbsp;работ и&nbsp;авторский заказ под&nbsp;защиту.
          </p>
        </div>

        <div class="sf-col">
          <h3 class="sf-h">Салон</h3>
          <ul>
            <li><a href="/catalog">Архив работ</a></li>
            <li><a href="/order">Оформить заказ</a></li>
            <li><a href="/about">О&nbsp;нас</a></li>
          </ul>
        </div>

        <div class="sf-col">
          <h3 class="sf-h">Форматы</h3>
          <ul>
            <li><a href="/order?type=ref">Реферат</a></li>
            <li><a href="/order?type=kurs_t">Курсовая</a></li>
            <li><a href="/order?type=practice">Отчёт по&nbsp;практике</a></li>
            <li><a href="/order?type=diplom">ВКР · дипломная</a></li>
            <li><a href="/order?type=magist">Магистерская</a></li>
          </ul>
        </div>

        <div class="sf-col">
          <h3 class="sf-h">Контакты</h3>
          <ul>
            <li><a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram · @academicsaloon</a></li>
            <li><a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">ВКонтакте · /academicsaloon</a></li>
            <li><a href="https://max.ru/join/lvaRhM9GTze3JfqgW9GsTisLfz-o_IOdVK-ev-_AsH0" target="_blank" rel="noopener">MAX · присоединиться</a></li>
            <li><a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a></li>
          </ul>
        </div>
      </div>

      <div class="sf-bottom">
        <span class="sf-copy" id="sfCopy">&copy;&nbsp;MMXX&mdash;MMXXVI · Академический&nbsp;Салон</span>
        <span class="sf-whisper">Пишем собранно, для&nbsp;тех, кому важен текст.</span>
      </div>
    </div>
  </footer>

</Base>

<style>
  /* ================================================================
     HOMEPAGE -- Editorial Luxury
     Monocle meets Linear. Gold on obsidian. Every section breathes.
     ================================================================ */

  /* Hide the global footer on this page */
  :global(.footer) { display: none; }

  /* ----------------------------------------------------------------
     SHARED
     ---------------------------------------------------------------- */
  @keyframes fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes word-in {
    to { opacity: 1; transform: translateY(0); }
  }

  .section-title {
    font: 300 clamp(36px, 6vw, 56px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
  }

  .rv {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .6s var(--ease), transform .6s var(--ease);
  }

  .rv.vis {
    opacity: 1;
    transform: translateY(0);
  }

  /* ----------------------------------------------------------------
     BUTTONS
     ---------------------------------------------------------------- */
  /* Base .btn/.btn--primary/.btn--ghost live in components.css (global).
     The duplicates that used to be here were overriding .btn-gold color/bg on
     the homepage because scoped Astro selectors ([data-astro-cid-*]) had higher
     specificity. Keep this block for homepage-only tweaks, but let globals win. */
  .btn--primary {
    background: var(--surf);
  }
  .btn--ghost {
    background: transparent;
  }

  .btn--primary:hover {
    box-shadow: 0 12px 40px var(--ac-g);
  }

  .btn--ghost:hover {
    color: var(--t1);
    border-color: var(--ac-b2);
  }

  /* ----------------------------------------------------------------
     1. HERO -- dramatic multi-layer glow, 100svh
     ---------------------------------------------------------------- */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-glow {
    position: absolute;
    width: min(1100px, 95vw);
    height: min(900px, 85vw);
    top: 45%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45% at 50% 48%, rgba(212,175,55,.22) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 48% 44%, rgba(212,175,55,.14) 0%, transparent 50%),
      radial-gradient(ellipse 75% 55% at 42% 52%, rgba(180,130,20,.08) 0%, transparent 75%);
    pointer-events: none;
    z-index: 0;
    animation: glow-breathe 10s ease-in-out infinite;
  }

  @keyframes glow-breathe {
    0%, 100% { opacity: .65; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.06); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 960px;
    text-align: center;
    padding: 0 8px;
  }

  .hero-title {
    /* Risk #1 fix: cap at 140px so 4K/ultrawide doesn't overflow;
       min 38px keeps 'Студенческие' safe on 320px viewport */
    font: 300 clamp(38px, 8.5vw, 140px)/.96 var(--fd);
    color: var(--t1);
    letter-spacing: -.025em;
    text-wrap: balance;
    text-shadow: 0 0 120px rgba(212,175,55,.06), 0 4px 24px rgba(0,0,0,.3);
    max-width: 14ch;
    margin: 0 auto;
    font-feature-settings: "dlig", "liga", "kern", "ss01";
  }
  .prelude-title .ln {
    display: block;
  }
  .prelude-title .it {
    font-style: italic;
    color: var(--ac);
    font-weight: 400;
    font-feature-settings: "swsh", "dlig", "liga";
  }
  /* Eyebrow above hero title — chapter mark */
  .prelude-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: clamp(20px, 3vw, 36px);
    font: 400 11px/1 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--ac);
    opacity: 0;
    animation: fade-up .5s ease-out .1s forwards;
  }
  .prelude-eyebrow-rule {
    width: 28px;
    height: 1px;
    background: var(--ac);
    display: inline-block;
  }
  .prelude-eyebrow-num {
    font-family: var(--fd);
    font-style: italic;
    font-size: 18px;
    color: var(--ac);
    letter-spacing: 0;
    text-transform: none;
  }
  /* Lede with two audiences — split on / for visual balance */
  .prelude-lede {
    font: 400 clamp(15px, 1.7vw, 18px)/1.65 var(--fi);
    color: var(--t2);
    max-width: 56ch;
    margin: 28px auto 0;
    text-wrap: balance;
  }
  .prelude-lede .lede-aud {
    color: var(--ac);
    font-weight: 500;
    letter-spacing: .02em;
  }
  .prelude-lede .lede-sep {
    color: var(--ac);
    opacity: .4;
    margin: 0 6px;
  }
  /* Scroll cue — bottom of hero */
  .prelude-cue {
    position: absolute;
    bottom: clamp(16px, 4vh, 40px);
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    font: 400 10px/1 var(--fm);
    letter-spacing: .24em;
    text-transform: uppercase;
    color: var(--t3);
    text-decoration: none;
    opacity: 0;
    animation: fade-up .5s ease-out 1.8s forwards;
    transition: color var(--dur) var(--ease);
  }
  .prelude-cue:hover { color: var(--ac); }
  .prelude-cue-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, var(--ac), transparent);
    opacity: .55;
  }
  @media (max-width: 720px) {
    .prelude-cue { display: none; }
  }

  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(12px);
    animation: word-in .4s ease-out forwards;
    animation-delay: calc(var(--i) * 200ms + 300ms);
  }

  .hero-rule {
    width: 48px;
    height: 1px;
    margin: 28px auto 0;
    background: linear-gradient(90deg, transparent, var(--ac), transparent);
    opacity: .35;
  }

  .hero-sub {
    margin-top: 24px;
    font: 400 15px/1.6 var(--fi);
    color: var(--t2);
    max-width: 52ch;
    margin-inline: auto;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.2s forwards;
  }

  .hero-search {
    position: relative;
    max-width: 480px;
    margin: 36px auto 0;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.4s forwards;
  }

  .hero-search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--t3);
    pointer-events: none;
  }

  .hero-search-input {
    width: 100%;
    padding: 14px 20px 14px 42px;
    border: 1px solid var(--brd);
    border-radius: 999px;
    background: rgba(255,255,255,.04);
    color: var(--t1);
    font: 400 16px/1.4 var(--fi);
    outline: none;
    transition: border-color .3s, box-shadow .3s, background .3s;
  }

  .hero-search-input::placeholder { color: var(--t3); }

  .hero-search-input:focus {
    border-color: var(--ac-b);
    box-shadow: 0 0 0 3px rgba(212,175,55,.1);
    background: rgba(255,255,255,.06);
  }

  .hero-actions {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.6s forwards;
  }


  /* ----------------------------------------------------------------
     3. CATALOG -- Bento grid, glass cards
     ---------------------------------------------------------------- */
  .catalog {
    padding: 120px 24px;
    background: var(--bg);
  }

  .catalog-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .catalog-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 56px;
  }

  .section-link {
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    transition: color .3s var(--ease);
  }

  .section-link:hover { color: var(--ac); }

  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  /* Glass card */
  .card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px;
    background: rgba(255,255,255,.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,.06);
    border-radius: var(--rs);
    text-decoration: none;
    color: var(--t1);
    position: relative;
    overflow: hidden;
    transition:
      border-color .3s var(--ease),
      transform .3s var(--ease),
      box-shadow .3s var(--ease);
  }

  /* Gold shimmer top-line on hover */
  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 20%, var(--ac) 50%, transparent 80%);
    opacity: 0;
    transition: opacity .3s;
  }

  .card:hover {
    border-color: rgba(212,175,55,.15);
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0,0,0,.3), 0 0 0 1px rgba(212,175,55,.08);
  }

  .card:hover::before {
    opacity: .4;
  }

  .card-type {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
  }

  .card-title {
    font: 400 18px/1.35 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card:hover .card-title {
    text-decoration: underline;
    text-decoration-color: rgba(255,255,255,.2);
    text-underline-offset: 3px;
  }

  .card-meta {
    font: 400 13px/1 var(--fi);
    color: var(--t3);
    margin-top: auto;
  }

  /* ----------------------------------------------------------------
     5. FOOTER -- minimal signature
     ---------------------------------------------------------------- */
  .foot {
    padding: 64px 24px;
    background: var(--bg);
    text-align: center;
  }

  .foot-copy {
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    letter-spacing: .04em;
  }



  /* ----------------------------------------------------------------
     STATS STRIP — editorial column row below hero
     ---------------------------------------------------------------- */
  .stats-strip {
    padding: clamp(56px, 8vw, 96px) 24px 0;
    background: var(--bg);
  }
  .stats-strip-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 4vw, 56px);
    padding: clamp(28px, 4vw, 40px) 0;
    border-top: 1px solid var(--brd);
    border-bottom: 1px solid var(--brd);
    position: relative;
  }
  .stats-strip-inner::before,
  .stats-strip-inner::after {
    content: '';
    position: absolute;
    left: 20%; right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ac-line), transparent);
    pointer-events: none;
  }
  .stats-strip-inner::before { top: -1px; }
  .stats-strip-inner::after  { bottom: -1px; }

  .stat-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
  }
  .stat-lbl {
    font: 400 10px/1 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--t3);
  }
  .stat-val {
    font: 400 clamp(32px, 4.4vw, 54px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: -.01em;
    font-feature-settings: "lnum", "tnum";
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .stat-val .it {
    font-style: italic;
    color: var(--ac);
    font-weight: 400;
    font-size: .65em;
    margin-left: 6px;
    font-feature-settings: "swsh";
  }
  .stat-val .stat-suffix {
    font-size: .55em;
    color: var(--t3);
    margin-left: 2px;
    letter-spacing: .04em;
  }
  .stat-val .stat-sep {
    color: var(--ac);
    font-style: italic;
    margin-right: 4px;
  }
  .stat-note {
    font: 400 13px/1.4 var(--fi);
    color: var(--t3);
    max-width: 22ch;
  }

  /* Risk #2 fix: explicit handling of 640–900px gap (was missing) */
  @media (max-width: 900px) {
    .stats-strip-inner {
      grid-template-columns: 1fr 1fr;
      gap: 28px 32px;
    }
    .stat-col:last-child {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
      padding-top: 16px;
      border-top: 1px solid var(--brd);
    }
