  }
  .qa-a-body a {
    color: var(--gold);
    border-bottom: 1px solid var(--gold-line);
    padding-bottom: 1px;
  }

  @media (max-width: 720px) {
    .qa-item summary { grid-template-columns: auto 1fr auto; gap: 14px; }
    .qa-a { grid-template-columns: 1fr; gap: 0; }
