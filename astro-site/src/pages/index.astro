---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const totalDocs = D.length;
const currentYear = String(new Date().getFullYear());

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const match = blob.match(/(?:19|20)\d{2}/);
  return match ? match[0] : currentYear;
}

function normalizeDoc(doc: any, index: number) {
  return {
    id: `${doc.file}-${index}`,
    slug: doc.file,
    title: doc.catalogTitle || doc.title || doc.filename || 'Студенческая работа',
    type: doc.docType || doc.category || 'Работа',
    subject: doc.subject || 'Психология',
    year: extractYear(doc),
  };
}

const preferredCategories = [
  'ВКР и дипломы',
  'Курсовые работы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
  'Методические материалы',
];

const pickedDocs: any[] = [];
for (const category of preferredCategories) {
  const nextDocs = D.filter((doc: any) => doc.category === category).slice(0, 1);
  pickedDocs.push(...nextDocs);
}
if (pickedDocs.length < 6) {
  for (const doc of D) {
    if (pickedDocs.includes(doc)) continue;
    pickedDocs.push(doc);
    if (pickedDocs.length >= 6) break;
  }
}

const cards = pickedDocs.slice(0, 6).map(normalizeDoc);
---

<Base
  title="Библиотека академического салона -- студенческие работы без паники"
  description="Библиотека готовых студенческих работ: психология, социальная работа, конфликтология и другие гуманитарные дисциплины. Или закажите индивидуальную подготовку."
  currentPath="/"
>

  <!-- 1. HERO -->
  <section class="hero" id="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <h1 class="hero-title" aria-label="Без паники перед дедлайном.">
        <span class="word" style="--i:0">Без</span>
        <span class="word" style="--i:1">паники</span>
        <br aria-hidden="true" />
        <span class="word" style="--i:2">перед</span>
        <span class="word" style="--i:3">дедлайном.</span>
      </h1>
      <div class="hero-rule" aria-hidden="true"></div>
      <p class="hero-sub">{totalDocs}+ работ бесплатно &middot; или напишем под ваши требования</p>
      <form class="hero-search" action="/catalog" method="get">
        <svg class="hero-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input class="hero-search-input" type="search" name="q" placeholder="Найти работу..." autocomplete="off" enterkeyhint="search" id="heroSearchInput" />
      </form>
      <div class="hero-actions">
        <a href="/catalog" class="btn btn--primary">Смотреть каталог</a>
        <a href="/order" class="btn btn--ghost">Заказать работу</a>
      </div>
    </div>
  </section>

  <!-- 2. CATALOG -->
  <section class="catalog rv">
    <div class="catalog-inner">
      <div class="catalog-head">
        <h2 class="section-title">Каталог</h2>
        <a href="/catalog" class="section-link">Все работы &rarr;</a>
      </div>
      <div class="catalog-grid">
        {cards.map((card) => (
          <a href={`/doc/${card.slug}`} class="card rv">
            <span class="card-type">{card.type}</span>
            <h3 class="card-title">{card.title}</h3>
            <span class="card-meta">{card.subject} &middot; {card.year}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. TRUST -->
  <section class="trust rv">
    <div class="trust-inner">
      <h2 class="section-title">Отзывы</h2>
      <div class="trust-screenshots">
        <img src="/reviews/1.webp" alt="Отзыв: Спасибо за работу" class="trust-img" loading="lazy" />
        <img src="/reviews/4.webp" alt="Отзыв: Автомат, 5 -- спасибо огромное" class="trust-img" loading="lazy" />
        <img src="/reviews/7.webp" alt="Отзыв: Кайф, благодарю за быструю работу" class="trust-img" loading="lazy" />
      </div>
      <div class="trust-guarantees">
        <div class="trust-item">
          <span class="trust-icon" aria-hidden="true">&#8734;</span>
          <span class="trust-text">Правки до защиты</span>
        </div>
        <div class="trust-item">
          <span class="trust-icon" aria-hidden="true">&#9670;</span>
          <span class="trust-text">Антиплагиат</span>
        </div>
        <div class="trust-item">
          <span class="trust-icon" aria-hidden="true">&#9201;</span>
          <span class="trust-text">Сроки от 1 дня</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. ORDER -->
  <section class="order rv">
    <div class="order-inner">
      <h2 class="order-title">Напишем под ваши требования.</h2>
      <div class="order-prices">
        <div class="price">
          <span class="price-type">Реферат</span>
          <span class="price-value">от 3 000 &#8381;</span>
        </div>
        <div class="price">
          <span class="price-type">Курсовая</span>
          <span class="price-value">от 5 000 &#8381;</span>
        </div>
        <div class="price">
          <span class="price-type">Дипломная</span>
          <span class="price-value">от 30 000 &#8381;</span>
        </div>
      </div>
      <a href="/order" class="order-cta btn btn--primary">Заказать работу</a>
      <div class="order-channels">
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
        <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
      </div>
    </div>
  </section>

  <!-- 5. CLOSING -->
  <footer class="closing">
    <div class="closing-inner">
      <span class="closing-copy">&copy; 2022&ndash;2026 Библиотека академического салона</span>
    </div>
  </footer>

</Base>

<style>
  /* ================================================================
     HOMEPAGE — Luxury minimalism. 5 sections. Every element earns its place.
     ================================================================ */

  /* Hide the global footer on this page — closing section replaces it */
  :global(.footer) { display: none; }

  /* ----------------------------------------------------------------
     SHARED
     ---------------------------------------------------------------- */
  @keyframes fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes word-in {
    to { opacity: 1; transform: translateY(0); }
  }

  .section-title {
    font: 300 clamp(36px, 6vw, 56px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
  }

  /* Reveal animation — elements with .rv get .vis from IntersectionObserver */
  .rv {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .6s var(--ease), transform .6s var(--ease);
  }

  .rv.vis {
    opacity: 1;
    transform: translateY(0);
  }

  /* ----------------------------------------------------------------
     BUTTONS
     ---------------------------------------------------------------- */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 16px 40px;
    border-radius: 0;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    text-decoration: none;
    color: var(--t1);
    border: 1px solid var(--ac-b);
    cursor: pointer;
    transition:
      transform var(--dur-slow) var(--ease),
      border-color var(--dur-slow) var(--ease),
      box-shadow var(--dur-slow) var(--ease);
  }

  .btn--primary {
    background: var(--surf);
    border-color: var(--ac-b);
  }

  .btn--ghost {
    background: transparent;
    border-color: var(--ac-line);
    color: var(--t2);
  }

  .btn:hover {
    transform: translateY(-2px);
    border-color: var(--ac-b3);
    box-shadow: 0 12px 40px var(--ac-sh);
  }

  .btn--primary:hover {
    box-shadow: 0 12px 40px var(--ac-g);
  }

  .btn--ghost:hover {
    color: var(--t1);
    border-color: var(--ac-b2);
  }

  /* ----------------------------------------------------------------
     1. HERO
     ---------------------------------------------------------------- */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-glow {
    position: absolute;
    width: min(900px, 80vw);
    height: min(700px, 70vw);
    top: 45%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(ellipse 55% 45% at 50% 50%, rgba(212,175,55,.12) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 960px;
    text-align: center;
    padding: 0 8px;
  }

  .hero-title {
    font: 300 clamp(48px, 10vw, 100px)/.88 var(--fd);
    color: var(--t1);
    letter-spacing: -.02em;
    text-wrap: balance;
  }

  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(12px);
    animation: word-in .4s ease-out forwards;
    animation-delay: calc(var(--i) * 200ms + 300ms);
  }

  .hero-rule {
    width: 48px;
    height: 1px;
    margin: 32px auto 0;
    background: var(--ac);
    opacity: .2;
  }

  .hero-sub {
    margin-top: 28px;
    font: 400 15px/1.6 var(--fi);
    color: var(--t2);
    max-width: 52ch;
    margin-inline: auto;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.2s forwards;
  }

  .hero-search {
    position: relative;
    max-width: 480px;
    margin: 36px auto 0;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.4s forwards;
  }

  .hero-search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--t3);
    pointer-events: none;
  }

  .hero-search-input {
    width: 100%;
    padding: 14px 20px 14px 42px;
    border: 1px solid var(--brd);
    border-radius: 999px;
    background: rgba(255,255,255,.04);
    color: var(--t1);
    font: 400 16px/1.4 var(--fi);
    outline: none;
    transition: border-color .3s, box-shadow .3s, background .3s;
  }

  .hero-search-input::placeholder { color: var(--t3); }

  .hero-search-input:focus {
    border-color: var(--ac-b);
    box-shadow: 0 0 0 3px rgba(212,175,55,.1);
    background: rgba(255,255,255,.06);
  }

  .hero-actions {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.6s forwards;
  }

  /* ----------------------------------------------------------------
     2. CATALOG
     ---------------------------------------------------------------- */
  .catalog {
    padding: 160px 24px;
    background: var(--bg);
  }

  .catalog-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .catalog-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 56px;
  }

  .section-link {
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    transition: color var(--dur) var(--ease);
  }

  .section-link:hover { color: var(--ac); }

  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px;
    background: var(--card);
    border: 1px solid var(--brd);
    border-radius: var(--rs);
    text-decoration: none;
    color: var(--t1);
    transition:
      border-color var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }

  .card:hover {
    border-color: var(--ac-b);
    transform: translateY(-2px);
  }

  .card-type {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
  }

  .card-title {
    font: 400 16px/1.35 var(--fi);
    color: var(--t1);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    font: 400 13px/1 var(--fi);
    color: var(--t3);
    margin-top: auto;
  }

  /* ----------------------------------------------------------------
     3. TRUST
     ---------------------------------------------------------------- */
  .trust {
    padding: 160px 24px;
    background: var(--bg);
  }

  .trust-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .trust-inner .section-title {
    margin-bottom: 56px;
  }

  .trust-screenshots {
    display: flex;
    gap: 20px;
    justify-content: center;
    margin-bottom: 64px;
  }

  .trust-img {
    width: 220px;
    height: auto;
    border-radius: var(--rs);
    border: 1px solid var(--brd);
    object-fit: cover;
  }

  .trust-guarantees {
    display: flex;
    justify-content: center;
    gap: 48px;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .trust-icon {
    font-size: 20px;
    color: var(--ac);
    line-height: 1;
  }

  .trust-text {
    font: 400 14px/1.3 var(--fi);
    color: var(--t2);
  }

  /* ----------------------------------------------------------------
     4. ORDER
     ---------------------------------------------------------------- */
  .order {
    padding: 160px 24px;
    background: var(--bg);
  }

  .order-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    text-align: center;
  }

  .order-title {
    font: 300 clamp(32px, 5vw, 48px)/1.1 var(--fd);
    color: var(--t1);
    margin-bottom: 64px;
  }

  .order-prices {
    display: flex;
    justify-content: center;
    gap: 64px;
    margin-bottom: 56px;
  }

  .price {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
  }

  .price-type {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
  }

  .price-value {
    font: 400 24px/1 var(--fm);
    color: var(--ac);
    letter-spacing: -.01em;
  }

  .order-cta {
    margin-bottom: 40px;
  }

  .order-channels {
    display: flex;
    justify-content: center;
    gap: 24px;
  }

  .order-channels a {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    transition: color var(--dur) var(--ease);
  }

  .order-channels a:hover { color: var(--ac); }

  /* ----------------------------------------------------------------
     5. CLOSING
     ---------------------------------------------------------------- */
  .closing {
    padding: 80px 24px;
    background: var(--bg);
  }

  .closing-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    text-align: center;
  }

  .closing-copy {
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    letter-spacing: .04em;
  }

  /* ----------------------------------------------------------------
     LIGHT THEME OVERRIDES
     ---------------------------------------------------------------- */
  :global([data-theme="light"]) .hero-glow {
    background: radial-gradient(ellipse 55% 45% at 50% 50%, rgba(180,145,30,.08) 0%, transparent 70%);
  }

  :global([data-theme="light"]) .hero-search-input {
    background: rgba(0,0,0,.03);
    border-color: rgba(0,0,0,.1);
  }

  :global([data-theme="light"]) .hero-search-input:focus {
    border-color: var(--ac-b);
    background: rgba(0,0,0,.04);
  }

  :global([data-theme="light"]) .card {
    background: var(--card);
    border-color: var(--brd);
  }

  :global([data-theme="light"]) .trust-img {
    border-color: var(--brd);
  }

  /* ----------------------------------------------------------------
     REDUCED MOTION
     ---------------------------------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    .word,
    .hero-sub,
    .hero-search,
    .hero-actions {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .rv {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ----------------------------------------------------------------
     TABLET (max 900px)
     ---------------------------------------------------------------- */
  @media (max-width: 900px) {
    .catalog-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .order-prices {
      gap: 40px;
    }

    .trust-guarantees {
      gap: 32px;
    }
  }

  /* ----------------------------------------------------------------
     MOBILE (max 639px)
     ---------------------------------------------------------------- */
  @media (max-width: 639px) {
    .catalog,
    .trust,
    .order {
      padding: 80px 20px;
    }

    .catalog-grid {
      grid-template-columns: 1fr;
    }

    .trust-screenshots {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      justify-content: flex-start;
      padding-bottom: 8px;
      -webkit-overflow-scrolling: touch;
    }

    .trust-img {
      flex: 0 0 220px;
      scroll-snap-align: start;
    }

    .trust-guarantees {
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }

    .order-prices {
      flex-direction: column;
      align-items: center;
      gap: 32px;
    }

    .order-cta {
      width: 100%;
      text-align: center;
    }

    .order-channels {
      flex-wrap: wrap;
      gap: 16px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .hero-actions .btn {
      width: 100%;
      max-width: 320px;
    }

    .closing {
      padding: 48px 20px;
    }
  }
</style>

<script>
  import { bootHomePageRuntime } from '../scripts/home-page-runtime';
  bootHomePageRuntime();
</script>
