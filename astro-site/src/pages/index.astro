</style>

<script>
  // ═══════════ LIFECYCLE CLEANUP SYSTEM ═══════════
  // Prevents rAF/interval/listener leaks on Astro view transitions
  const _cleanups: Array<() => void> = [];
  function onCleanup(fn: () => void) { _cleanups.push(fn); }
  function runCleanups() {
    _cleanups.forEach(fn => { try { fn(); } catch(_) {} });
    _cleanups.length = 0;
  }

  function managedRAF(callback: (time: number) => void): () => void {
    let running = true;
    let id = 0;
    function loop(time: number) {
      if (!running) return;
      callback(time);
      id = requestAnimationFrame(loop);
    }
    id = requestAnimationFrame(loop);
    const stop = () => { running = false; cancelAnimationFrame(id); };
    onCleanup(stop);
    return stop;
  }

  function managedInterval(fn: () => void, ms: number): () => void {
    const id = setInterval(fn, ms);
    const stop = () => clearInterval(id);
    onCleanup(stop);
    return stop;
  }

  function managedTimeout(fn: () => void, ms: number): () => void {
    const id = setTimeout(fn, ms);
    const stop = () => clearTimeout(id);
    onCleanup(stop);
    return stop;
  }

  function managedListener<K extends keyof WindowEventMap>(
    target: EventTarget, event: string, handler: EventListener, opts?: AddEventListenerOptions
  ): () => void {
    target.addEventListener(event, handler, opts);
    const remove = () => target.removeEventListener(event, handler, opts);
    onCleanup(remove);
    return remove;
  }

  // ═══════════ TEXT SCRAMBLE EFFECT ═══════════
  class TextScramble {
    private el: HTMLElement;
    private chars = '!<>-_\\/[]{}—=+*^?#абвгдеёжзиклмнопрстуфхцчшщэюя';
    private rafId = 0;
    private frameCount = 0;
    private queue: Array<{from: string; to: string; start: number; end: number; char?: string}> = [];
    private resolve!: () => void;

    constructor(el: HTMLElement) {
      this.el = el;
    }

    setText(newText: string): Promise<void> {
      const oldText = this.el.innerText;
      const length = Math.max(oldText.length, newText.length);
      this.queue = [];
      this.frameCount = 0;
      for (let i = 0; i < length; i++) {
        const from = oldText[i] || '';
        const to = newText[i] || '';
        const start = Math.floor(Math.random() * 30);
        const end = start + Math.floor(Math.random() * 30);
        this.queue.push({ from, to, start, end });
      }
      cancelAnimationFrame(this.rafId);
      return new Promise(resolve => {
        this.resolve = resolve;
        this.update();
      });
    }

    private update() {
      let output = '';
      let complete = 0;
      for (let i = 0; i < this.queue.length; i++) {
        let { from, to, start, end, char } = this.queue[i];
        if (this.frameCount >= end) {
          complete++;
          output += to;
        } else if (this.frameCount >= start) {
          if (!char || Math.random() < 0.28) {
            char = this.chars[Math.floor(Math.random() * this.chars.length)];
            this.queue[i].char = char;
          }
          output += `<span class="scramble-char">${char}</span>`;
        } else {
          output += from;
        }
      }
      this.el.innerHTML = output;
      if (complete === this.queue.length) {
        this.resolve();
      } else {
        this.frameCount++;
        this.rafId = requestAnimationFrame(() => this.update());
      }
    }
  }

  // ═══════════ INIT SCRAMBLE TEXTS ═══════════
  function initScramble() {
    document.querySelectorAll('.scramble-text').forEach((el) => {
      const htmlEl = el as HTMLElement;
      const finalText = htmlEl.dataset.final;
      if (!finalText) return;
      const scramble = new TextScramble(htmlEl);
      const delay = parseInt(htmlEl.closest('[data-reveal-delay]')?.getAttribute('data-reveal-delay') || '0');
      setTimeout(() => scramble.setText(finalText), 600 + delay);
    });
  }

  // ═══════════ TYPEWRITER EFFECT ═══════════
  function initTypewriter() {
    const el = document.getElementById('heroTyped');
    if (!el) return;
    const phrases = [
      'Бесплатная библиотека работ по психологии и социальной работе.',
      'Курсовые, ВКР, рефераты — скачивай или закажи.',
      '235+ документов. 6 лет опыта. Гарантия сдачи.',
      'Индивидуально, по ГОСТ, с антиплагиатом.',
    ];
    let phraseIdx = 0;
    let charIdx = 0;
    let deleting = false;

    function type() {
      if (!document.body.contains(el)) return; // stop if element removed
      const phrase = phrases[phraseIdx];
      if (!deleting) {
        el.textContent = phrase.slice(0, charIdx++);
        if (charIdx > phrase.length) {
          deleting = true;
          managedTimeout(type, 2500);
          return;
        }
        managedTimeout(type, 35 + Math.random() * 25);
      } else {
        el.textContent = phrase.slice(0, charIdx--);
        if (charIdx < 0) {
          deleting = false;
          charIdx = 0;
          phraseIdx = (phraseIdx + 1) % phrases.length;
          managedTimeout(type, 400);
          return;
        }
        managedTimeout(type, 18);
      }
    }
    managedTimeout(type, 1200);
  }

  // ═══════════ REVEAL SYSTEM ═══════════
  function initReveals() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const delay = parseInt((e.target as HTMLElement).dataset.revealDelay || '0');
          setTimeout(() => e.target.classList.add('visible'), delay);
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));

    // Hero elements auto-reveal
    document.querySelectorAll('.hero [data-reveal]').forEach(el => {
      const delay = parseInt((el as HTMLElement).dataset.revealDelay || '0');
      setTimeout(() => el.classList.add('visible'), 200 + delay);
    });
  }

  // ═══════════ LIVE TICKER ═══════════
  function initTicker() {
    const track = document.getElementById('tickerTrack');
    if (!track) return;

    const items = [
      { text: 'Курсовая по психологии', status: 'сдана на 5' },
      { text: 'ВКР по социальной работе', status: 'защита на отлично' },
      { text: 'Реферат «Мотивация»', status: 'выполнен за 2 дня' },
      { text: 'Отчёт по практике ГИПСР', status: 'сдан преподавателю' },
      { text: 'Контрольная по психодиагностике', status: 'оценка: отлично' },
      { text: 'Дипломная работа', status: 'защита с отличием' },
      { text: 'Курсовая по соцработе', status: 'принята без правок' },
      { text: 'Эссе по философии', status: 'сдано в срок' },
    ];

    const html = items.map(it =>
      `<div class="ticker-item"><span class="ticker-dot"></span>${it.text} — <span class="ticker-highlight">${it.status}</span></div>`
    ).join('');

    track.innerHTML = html + html; // duplicate for seamless loop
  }

  // ═══════════ SCROLL-DRIVEN PAPER ═══════════
  function initPaperJourney() {
    const sheet = document.getElementById('paperSheet');
    const steps = document.querySelectorAll('.paper-step');
    if (!sheet || !steps.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const ratio = e.intersectionRatio;

        if (ratio > 0.1) {
          sheet.classList.add('active');
          steps[0]?.classList.add('active');
        }
        if (ratio > 0.3) {
          sheet.classList.add('lines-visible');
          steps[1]?.classList.add('active');
        }
        if (ratio > 0.6) {
          sheet.classList.add('stamped');
          steps[2]?.classList.add('active');
        }
      });
    }, { threshold: [0, 0.1, 0.3, 0.6, 1] });

    observer.observe(sheet);
  }

  // ═══════════ 3D TILT CARDS ═══════════
  function initTiltCards() {
    document.querySelectorAll('[data-tilt]').forEach(card => {
      const el = card as HTMLElement;

      el.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = el.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;

        el.style.transform = `perspective(600px) rotateY(${x * 8}deg) rotateX(${-y * 8}deg) scale(1.02)`;

        // Light refraction effect
        const inner = el.querySelector('.card') as HTMLElement;
        if (inner) {
          inner.style.background = `
            radial-gradient(circle at ${(x + 0.5) * 100}% ${(y + 0.5) * 100}%,
              rgba(212,175,55,.06) 0%, transparent 50%),
            var(--card)
          `;
        }
      });

      el.addEventListener('mouseleave', () => {
        el.style.transform = '';
        const inner = el.querySelector('.card') as HTMLElement;
        if (inner) inner.style.background = '';
      });
    });
  }

  // ═══════════ SLOT MACHINE DIGIT COUNTER ═══════════
  function initCounters() {
    const counters = document.querySelectorAll('[data-count]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const el = e.target as HTMLElement;
        const target = parseInt(el.dataset.count || '0');
        const digits = target.toString().split('');

        // Remove background-clip:text from parent (breaks on child elements)
        // Use explicit gold color on digits instead
        el.style.background = 'none';
        el.style.webkitTextFillColor = 'unset';
        el.style.color = '#d4af37';
        el.innerHTML = '';
        el.style.display = 'inline-flex';
        el.style.overflow = 'hidden';
        el.style.gap = '0';

        digits.forEach((digit, i) => {
          const col = document.createElement('span');
          col.style.cssText = 'display:inline-block;height:1.1em;overflow:hidden;position:relative;line-height:1.1;';

          const strip = document.createElement('span');
          strip.style.cssText = 'display:flex;flex-direction:column;position:relative;transition:transform 1.5s cubic-bezier(.22,1,.36,1);transition-delay:' + (i * 0.12) + 's;color:inherit;';

          for (let d = 0; d <= 9; d++) {
            const span = document.createElement('span');
            span.textContent = d.toString();
            span.style.cssText = 'height:1.1em;display:flex;align-items:center;justify-content:center;';
            strip.appendChild(span);
          }

          strip.style.transform = 'translateY(0)';
          col.appendChild(strip);
          el.appendChild(col);

          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              const targetDigit = parseInt(digit);
              strip.style.transform = 'translateY(' + (-targetDigit * 1.1) + 'em)';
            });
          });
        });

        observer.unobserve(el);
      });
    }, { threshold: 0.5 });

    counters.forEach(c => observer.observe(c));
  }

