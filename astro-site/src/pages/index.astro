---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';
import { qaItems } from '../data/faq';
import FAQ from '../components/home/FAQ.astro';
import Manifesto from '../components/home/Manifesto.astro';
import Genres from '../components/home/Genres.astro';
import Method from '../components/home/Method.astro';
import Epilogue from '../components/home/Epilogue.astro';
import Archive from '../components/home/Archive.astro';
import Formula from '../components/home/Formula.astro';
import Calendar from '../components/home/Calendar.astro';
import Testimonia from '../components/home/Testimonia.astro';
import Hero from '../components/home/Hero.astro';
import Stats from '../components/home/Stats.astro';
import CatalogBento from '../components/home/CatalogBento.astro';
import HomeFooter from '../components/home/HomeFooter.astro';

const totalDocs = D.length;
const currentYear = String(new Date().getFullYear());

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const match = blob.match(/(?:19|20)\d{2}/);
  return match ? match[0] : currentYear;
}

function normalizeDoc(doc: any, index: number) {
  return {
    id: `${doc.file}-${index}`,
    slug: doc.file,
    title: doc.catalogTitle || doc.title || doc.filename || 'Студенческая работа',
    type: doc.docType || doc.category || 'Работа',
    subject: doc.subject || 'Психология',
    year: extractYear(doc),
  };
}

const preferredCategories = [
  'ВКР и дипломы',
  'Курсовые работы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
  'Методические материалы',
];

const pickedDocs: any[] = [];
for (const category of preferredCategories) {
  const nextDocs = D.filter((doc: any) => doc.category === category).slice(0, 1);
  pickedDocs.push(...nextDocs);
}
if (pickedDocs.length < 6) {
  for (const doc of D) {
    if (pickedDocs.includes(doc)) continue;
    pickedDocs.push(doc);
    if (pickedDocs.length >= 6) break;
  }
}

const cards = pickedDocs.slice(0, 6).map(normalizeDoc);



---

<Base
  title="Библиотека академического салона -- студенческие работы без паники"
  description="Библиотека готовых студенческих работ: психология, социальная работа, конфликтология и другие гуманитарные дисциплины. Или закажите индивидуальную подготовку."
  currentPath="/"
  extraSchema={[
    {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Библиотека академического салона',
      alternateName: 'Академический Салон',
      url: 'https://bibliosaloon.ru/',
      inLanguage: 'ru-RU',
      description: 'Свободный архив студенческих работ и мастерская индивидуального заказа.',
    },
    {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: qaItems.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    },
  ]}
>

  <!-- Curtain intro removed — relying on natural CSS load instead of scripted overlay -->

  <Hero totalDocs={totalDocs} />
  <Stats totalDocs={totalDocs} />

  <Manifesto totalDocs={totalDocs} />

  <Calendar />

  <Genres />

  <Formula />
  <Archive />

  <Method />

  <Testimonia />

  <FAQ />

  <CatalogBento />

  <Epilogue />

  <HomeFooter totalDocs={totalDocs} />

</Base>

<style>
  /* ================================================================
     HOMEPAGE -- Editorial Luxury
     Monocle meets Linear. Gold on obsidian. Every section breathes.
     ================================================================ */

  /* ----------------------------------------------------------------
     SHARED
     ---------------------------------------------------------------- */
  @keyframes fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes word-in {
    to { opacity: 1; transform: translateY(0); }
  }


  .rv {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity .6s var(--ease), transform .6s var(--ease);
  }

  .rv.vis {
    opacity: 1;
    transform: translateY(0);
  }

  /* ----------------------------------------------------------------
     BUTTONS
     ---------------------------------------------------------------- */
  /* Base .btn/.btn--primary/.btn--ghost live in components.css (global).
     The duplicates that used to be here were overriding .btn-gold color/bg on
     the homepage because scoped Astro selectors ([data-astro-cid-*]) had higher
     specificity. Keep this block for homepage-only tweaks, but let globals win. */
  .btn--primary {
    background: var(--surf);
  }
  .btn--ghost {
    background: transparent;
  }

  .btn--primary:hover {
    box-shadow: 0 12px 40px var(--ac-g);
  }

  .btn--ghost:hover {
    color: var(--t1);
    border-color: var(--ac-b2);
  }

  /* ----------------------------------------------------------------
     1. HERO -- dramatic multi-layer glow, 100svh
     ---------------------------------------------------------------- */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-glow {
    position: absolute;
    width: min(1100px, 95vw);
    height: min(900px, 85vw);
    top: 45%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45% at 50% 48%, rgba(212,175,55,.22) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 48% 44%, rgba(212,175,55,.14) 0%, transparent 50%),
      radial-gradient(ellipse 75% 55% at 42% 52%, rgba(180,130,20,.08) 0%, transparent 75%);
    pointer-events: none;
    z-index: 0;
    animation: glow-breathe 10s ease-in-out infinite;
  }

  @keyframes glow-breathe {
    0%, 100% { opacity: .65; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.06); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 960px;
    text-align: center;
    padding: 0 8px;
  }

  .hero-title {
    /* Risk #1 fix: cap at 140px so 4K/ultrawide doesn't overflow;
       min 38px keeps 'Студенческие' safe on 320px viewport */
    font: 300 clamp(38px, 8.5vw, 140px)/.96 var(--fd);
    color: var(--t1);
    letter-spacing: -.025em;
    text-wrap: balance;
    text-shadow: 0 0 120px rgba(212,175,55,.06), 0 4px 24px rgba(0,0,0,.3);
    max-width: 14ch;
    margin: 0 auto;
    font-feature-settings: "dlig", "liga", "kern", "ss01";
  }
  .prelude-title .ln {
    display: block;
  }
  .prelude-title .it {
    font-style: italic;
    color: var(--ac);
    font-weight: 400;
    font-feature-settings: "swsh", "dlig", "liga";
  }
  /* Eyebrow above hero title — chapter mark */
  .prelude-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: clamp(20px, 3vw, 36px);
    font: 400 11px/1 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--ac);
    opacity: 0;
    animation: fade-up .5s ease-out .1s forwards;
  }
  .prelude-eyebrow-rule {
    width: 28px;
    height: 1px;
    background: var(--ac);
    display: inline-block;
  }
  .prelude-eyebrow-num {
    font-family: var(--fd);
    font-style: italic;
    font-size: 18px;
    color: var(--ac);
    letter-spacing: 0;
    text-transform: none;
  }
  /* Lede with two audiences — split on / for visual balance */
  .prelude-lede {
    font: 400 clamp(15px, 1.7vw, 18px)/1.65 var(--fi);
    color: var(--t2);
    max-width: 56ch;
    margin: 28px auto 0;
    text-wrap: balance;
  }
  .prelude-lede .lede-aud {
    color: var(--ac);
    font-weight: 500;
    letter-spacing: .02em;
  }
  .prelude-lede .lede-sep {
    color: var(--ac);
    opacity: .4;
    margin: 0 6px;
  }
  /* Scroll cue — bottom of hero */
  .prelude-cue {
    position: absolute;
    bottom: clamp(16px, 4vh, 40px);
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    font: 400 10px/1 var(--fm);
    letter-spacing: .24em;
    text-transform: uppercase;
    color: var(--t3);
    text-decoration: none;
    opacity: 0;
    animation: fade-up .5s ease-out 1.8s forwards;
    transition: color var(--dur) var(--ease);
  }
  .prelude-cue:hover { color: var(--ac); }
  .prelude-cue-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, var(--ac), transparent);
    opacity: .55;
  }
  @media (max-width: 720px) {
    .prelude-cue { display: none; }
  }

  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(12px);
    animation: word-in .4s ease-out forwards;
    animation-delay: calc(var(--i) * 200ms + 300ms);
  }

  .hero-rule {
    width: 48px;
    height: 1px;
    margin: 28px auto 0;
    background: linear-gradient(90deg, transparent, var(--ac), transparent);
    opacity: .35;
  }

  .hero-sub {
    margin-top: 24px;
    font: 400 15px/1.6 var(--fi);
    color: var(--t2);
    max-width: 52ch;
    margin-inline: auto;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.2s forwards;
  }

  .hero-search {
    position: relative;
    max-width: 480px;
    margin: 36px auto 0;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.4s forwards;
  }

  .hero-search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--t3);
    pointer-events: none;
  }

  .hero-search-input {
    width: 100%;
    padding: 14px 20px 14px 42px;
    border: 1px solid var(--brd);
    border-radius: 999px;
    background: rgba(255,255,255,.04);
    color: var(--t1);
    font: 400 16px/1.4 var(--fi);
    outline: none;
    transition: border-color .3s, box-shadow .3s, background .3s;
  }

  .hero-search-input::placeholder { color: var(--t3); }

  .hero-search-input:focus {
    border-color: var(--ac-b);
    box-shadow: 0 0 0 3px rgba(212,175,55,.1);
    background: rgba(255,255,255,.06);
  }

  .hero-actions {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .5s ease-out 1.6s forwards;
  }



  /* ----------------------------------------------------------------
     5. FOOTER -- minimal signature
     ---------------------------------------------------------------- */
  .foot {
    padding: 64px 24px;
    background: var(--bg);
    text-align: center;
  }

  .foot-copy {
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    letter-spacing: .04em;
  }



  /* ----------------------------------------------------------------
     LIGHT THEME OVERRIDES
     ---------------------------------------------------------------- */
  :global([data-theme="light"]) .hero-glow {
    background:
      radial-gradient(ellipse 55% 45% at 50% 48%, rgba(180,145,30,.12) 0%, transparent 65%),
      radial-gradient(ellipse 35% 30% at 48% 44%, rgba(180,145,30,.08) 0%, transparent 50%),
      radial-gradient(ellipse 75% 55% at 42% 52%, rgba(160,120,15,.05) 0%, transparent 75%);
  }

  :global([data-theme="light"]) .hero-search-input {
    background: rgba(0,0,0,.03);
    border-color: rgba(0,0,0,.1);
  }

  :global([data-theme="light"]) .hero-search-input:focus {
    border-color: var(--ac-b);
    background: rgba(0,0,0,.04);
  }

  :global([data-theme="light"]) .card {
    background: #fff;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-color: var(--brd);
    box-shadow: 0 2px 12px rgba(0,0,0,.06);
  }

  :global([data-theme="light"]) .card:hover {
    box-shadow: 0 12px 40px rgba(0,0,0,.1), 0 0 0 1px rgba(212,175,55,.12);
  }

  :global([data-theme="light"]) .rw-img {
    border-color: rgba(0,0,0,.08);
  }

  :global([data-theme="light"]) .rw-img:hover {
    border-color: rgba(122,95,18,.2);
  }

  /* ----------------------------------------------------------------
     REDUCED MOTION
     ---------------------------------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    .word,
    .hero-sub,
    .hero-search,
    .hero-actions {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .hero-glow {
      animation: none;
      opacity: .8;
      transform: translate(-50%, -50%);
    }

    .rw-track {
      animation: none !important;
    }

    .rv {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ----------------------------------------------------------------
     TABLET (max 900px)
     ---------------------------------------------------------------- */
  @media (max-width: 900px) {
    .catalog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ----------------------------------------------------------------
     MOBILE (max 639px)
     ---------------------------------------------------------------- */
  @media (max-width: 639px) {
    .reviews,
    .catalog {
      padding: 64px 20px;
    }

    .catalog-grid {
      grid-template-columns: 1fr;
    }

    /* Smaller review images on mobile */
    .rw-img {
      height: 160px;
    }

    .reviews-wall {
      gap: 8px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .hero-actions .btn {
      width: 100%;
      max-width: 320px;
    }

    .foot {
      padding: 48px 20px;
    }

    .reviews-head {
      margin-bottom: 32px;
    }
  }



  /* ================================================================
     Curtain intro — element and rules removed.
     ================================================================ */

</style>


<script>
  import { bootHomePageRuntime } from '../scripts/home-page-runtime';
  bootHomePageRuntime();
</script>

<script>
  // Phase 3.1 — scroll-progress + reveal observer. Only loaded on "/"
  // because this page file only renders at "/". The module bootstraps
  // itself on load + astro:page-load.
  import '../scripts/couture';
</script>



