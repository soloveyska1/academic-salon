---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const totalDocs = D.length;

const categoryAlias: Record<string, string> = {
  'ВКР и дипломы': 'ВКР',
  'Курсовые работы': 'Курсовые',
  'Курсовые': 'Курсовые',
  'Рефераты': 'Рефераты',
  'Отчёты по практике': 'Практика',
  'Самостоятельные работы': 'Самостоятельные',
  'Методические материалы': 'Методички',
};

const preferredCategories = [
  'ВКР и дипломы',
  'Курсовые работы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
  'Методические материалы',
];

const categoryCount = new Map<string, number>();
for (const doc of D) {
  const key = (doc as any).category || 'Разное';
  categoryCount.set(key, (categoryCount.get(key) || 0) + 1);
}

const uniqueCategories = categoryCount.size;

const currentYear = String(new Date().getFullYear());

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const match = blob.match(/(?:19|20)\d{2}/);
  return match ? match[0] : currentYear;
}

function normalizeDoc(doc: any, index: number) {
  return {
    id: `${doc.file}-${index}`,
    slug: doc.file,
    title: doc.catalogTitle || doc.title || doc.filename || 'Студенческая работа',
    type: doc.docType || doc.category || 'Работа',
    subject: doc.subject || 'Психология',
    year: extractYear(doc),
    group: doc.category || 'Разное',
  };
}

const pickedDocs: any[] = [];
for (const category of preferredCategories) {
  const nextDocs = D.filter((doc: any) => doc.category === category).slice(0, 2);
  pickedDocs.push(...nextDocs);
}
if (pickedDocs.length < 9) {
  for (const doc of D) {
    if (pickedDocs.includes(doc)) continue;
    pickedDocs.push(doc);
    if (pickedDocs.length >= 9) break;
  }
}

const cards = pickedDocs.slice(0, 9).map(normalizeDoc);
const filters = ['Все', ...Array.from(new Set(cards.map((c) => c.group))).slice(0, 5)].map((name) => ({
  key: name,
  label: name === 'Все' ? 'Все' : (categoryAlias[name] || name),
}));

const steps = [
  { num: '01', title: 'Тема', note: 'Фиксируем задачу и срок.' },
  { num: '02', title: 'Черновик', note: 'Сверяем логику и формат.' },
  { num: '03', title: 'Сдача', note: 'Отдаём финальную версию.' },
];

const subjectCount = new Map<string, number>();
for (const doc of D) {
  const s = (doc as any).subject;
  if (s) subjectCount.set(s, (subjectCount.get(s) || 0) + 1);
}

const metrics = [
  { value: totalDocs, suffix: '+', label: 'готовых работ' },
  { value: uniqueCategories, suffix: '', label: 'категорий' },
  { value: subjectCount.size, suffix: '+', label: 'предметов' },
];
---

<Base
  title="Академический Салон — студенческие работы без паники"
  description="Библиотека готовых студенческих работ: психология, социальная работа, конфликтология и другие гуманитарные дисциплины. Или закажите индивидуальную подготовку."
  currentPath="/"
>

  <!-- ═══════ 1. HERO ═══════ -->
  <section class="hero" id="hero">
    <canvas class="hero-canvas" id="heroCanvas" aria-hidden="true"></canvas>
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <h1 class="hero-title" id="heroTitle" aria-label="Без паники перед дедлайном.">
        <span class="word" style="--i:0">Без</span>
        <span class="word" style="--i:1">паники</span>
        <br aria-hidden="true" />
        <span class="word" style="--i:2">перед</span>
        <span class="word" style="--i:3">дедлайном.</span>
      </h1>
      <div class="hero-rule" aria-hidden="true"></div>
      <p class="hero-sub" id="heroSub">Готовые работы · Индивидуальные заказы</p>
      <div class="hero-actions" id="heroActions">
        <a href="/catalog" class="btn btn--primary">Смотреть каталог</a>
        <a href="/order" class="btn btn--ghost">Заказать работу</a>
      </div>
      <div class="hero-unfold" aria-hidden="true"></div>
    </div>

    <div class="hero-metrics" id="proof">
      {metrics.map((m, i) => (
        <div class="metric" style={`--i:${i}`}>
          <span class="metric-value" data-target={m.value} data-suffix={m.suffix}>0{m.suffix}</span>
          <span class="metric-label">{m.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════ 3. КАТАЛОГ ═══════ -->
  <section class="gallery" id="gallery">
    <div class="gallery-inner">
      <header class="gallery-head">
        <h2 class="section-title">Каталог</h2>
        <nav class="gallery-filters" role="tablist" aria-label="Фильтр работ">
          {filters.map((f, idx) => (
            <button
              class:list={['chip', { 'chip--active': idx === 0 }]}
              type="button"
              role="tab"
              aria-selected={idx === 0 ? 'true' : 'false'}
              data-filter={f.key}
            >
              {f.label}
            </button>
          ))}
        </nav>
      </header>

      <div class="grid" id="bento">
        {cards.map((card, idx) => (
          <article
            class="card"
            data-group={card.group}
            style={`--i:${idx}`}
          >
            <a href={`/doc/${card.slug}`} class="card-link">
              <span class="card-type">{card.type}</span>
              <h3 class="card-title">{card.title}</h3>
              <span class="card-subject">{card.subject} · {card.year}</span>
            </a>
          </article>
        ))}
      </div>

      <a href="/catalog" class="gallery-more">Полный каталог →</a>
    </div>
  </section>

  <!-- ═══════ 4. ПРОЦЕСС ═══════ -->
  <section class="process" id="process">
    <div class="process-inner">
      <h2 class="section-title">Индивидуальная работа</h2>

      <div class="steps">
        <div class="steps-line" id="stepsLine" aria-hidden="true"></div>
        {steps.map((s) => (
          <div class="step">
            <span class="step-num" aria-hidden="true">{s.num}</span>
            <b class="step-title">{s.title}</b>
            <p class="step-note">{s.note}</p>
          </div>
        ))}
      </div>

      <div class="process-actions">
        <a href="/order" class="btn btn--ghost">Отправить тему</a>
        <span class="process-channels">
          <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="link-text">Telegram</a>
          <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener" class="link-text">VK</a>
        </span>
      </div>
    </div>
  </section>

  <!-- ═══════ 5. ЗАКРЫТИЕ = FOOTER ═══════ -->
  <section class="closing" id="closing">
    <div class="closing-inner">
      <h2 class="closing-title">Откройте каталог<br/>или напишите нам.</h2>
      <div class="closing-actions">
        <a href="/catalog" class="btn btn--primary">Каталог</a>
        <a href="/order" class="btn btn--ghost">Заказать работу</a>
      </div>

      <nav class="closing-links">
        <a href="/catalog">Каталог</a>
        <a href="/order">Заказать</a>
        <a href="/faq">FAQ</a>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
        <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
      </nav>

      <p class="colophon">© 2022–2026 Академический Салон</p>
    </div>
  </section>

</Base>

<style>
  /* ═══════ MICRO-DETAILS ═══════ */
  :global(::selection) {
    background: rgba(212,175,55,.25);
    color: var(--t1);
  }

  :global(::-webkit-scrollbar) {
    width: 6px;
  }

  :global(::-webkit-scrollbar-track) {
    background: transparent;
  }

  :global(::-webkit-scrollbar-thumb) {
    background: rgba(212,175,55,.18);
    border-radius: 3px;
  }

  :global(::-webkit-scrollbar-thumb:hover) {
    background: rgba(212,175,55,.32);
  }

  :global(html) {
    scroll-behavior: smooth;
    scrollbar-color: rgba(212,175,55,.18) transparent;
    scrollbar-width: thin;
  }

  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* CSS fallback glow — warm candle behind text */
  .hero-glow {
    position: absolute;
    width: min(1200px, 100vw);
    height: min(1000px, 85vw);
    top: 42%;
    left: 50%;
    transform: translate(-50%, -50%) scale(1);
    background:
      radial-gradient(ellipse 60% 50% at 50% 50%, rgba(200,165,40,.18) 0%, transparent 70%),
      radial-gradient(ellipse 40% 35% at 50% 45%, rgba(212,175,55,.1) 0%, transparent 55%);
    animation: glow-breathe 10s ease-in-out infinite;
    pointer-events: none;
    z-index: 0;
  }

  .hero-canvas.is-active ~ .hero-glow {
    opacity: .35;
  }

  @keyframes glow-breathe {
    0%, 100% { opacity: .7; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.12); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 960px;
    text-align: center;
    padding: 0 8px;
  }

  .hero-title {
    font: 300 clamp(48px, 10vw, 100px)/.92 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    text-wrap: balance;
  }

  .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(28px);
    animation: word-in .7s cubic-bezier(.25,0,0,1) forwards;
    animation-delay: calc(var(--i) * 120ms + 300ms);
  }

  @keyframes word-in {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-rule {
    width: 88px;
    height: 1px;
    margin: 36px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
    animation: rule-in .7s cubic-bezier(.25,0,0,1) .9s forwards;
  }

  @keyframes rule-in {
    to { opacity: .3; transform: scaleX(1); }
  }

  .hero-sub {
    margin-top: 24px;
    font: 400 clamp(12px, 1.6vw, 14px)/1.6 var(--fi);
    color: var(--t2);
    text-transform: uppercase;
    letter-spacing: .15em;
    max-width: 52ch;
    margin-inline: auto;
    opacity: 0;
    transform: translateY(12px);
    animation: fade-up .6s cubic-bezier(.25,0,0,1) 1.1s forwards;
  }

  .hero-actions {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(16px);
    animation: fade-up .6s cubic-bezier(.25,0,0,1) 1.3s forwards;
  }

  .hero-unfold {
    width: 200px;
    height: 1px;
    margin: 0 auto;
    margin-top: 56px;
    background: linear-gradient(90deg, transparent, rgba(212,175,55,.25), transparent);
    opacity: 0;
    transform: scaleX(0);
    animation: unfold 2s cubic-bezier(.25,0,0,1) 1.5s forwards;
  }

  @keyframes unfold {
    to { opacity: 1; transform: scaleX(1); }
  }

  .hero-metrics {
    position: absolute;
    bottom: 80px;
    left: 24px;
    right: 24px;
    display: flex;
    justify-content: center;
    gap: 80px;
    flex-wrap: wrap;
    z-index: 1;
  }

  @keyframes fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══════ BUTTONS ═══════ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 18px 48px;
    border-radius: 0;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    text-decoration: none;
    color: var(--t1);
    border: .5px solid rgba(212,175,55,.2);
    cursor: pointer;
    transition:
      transform .5s cubic-bezier(.25,0,0,1),
      border-color .5s cubic-bezier(.25,0,0,1),
      box-shadow .6s cubic-bezier(.25,0,0,1);
  }

  .btn--primary {
    background: rgba(212,175,55,.08);
    border-color: rgba(212,175,55,.25);
  }

  .btn--ghost {
    background: transparent;
  }

  .btn:hover {
    transform: translateY(-2px);
    border-color: rgba(212,175,55,.4);
    box-shadow: 0 12px 40px rgba(212,175,55,.06);
  }

  .btn--primary:hover {
    box-shadow: 0 12px 40px rgba(212,175,55,.1);
  }

  /* ═══════ METRICS (inside hero) ═══════ */
  .metric {
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
  }

  .metric.is-visible {
    animation: fade-up .5s var(--ease-spring) calc(var(--i) * 120ms) forwards;
  }

  .metric-value {
    display: block;
    font: 300 clamp(42px, 8vw, 68px)/1 var(--fm);
    color: var(--ac);
    letter-spacing: -.02em;
    font-variant-numeric: tabular-nums;
  }

  .metric-label {
    display: block;
    margin-top: 12px;
    font: 400 11px/1.3 var(--fi);
    color: var(--t3);
    text-transform: uppercase;
    letter-spacing: .12em;
  }

  /* ═══════ GALLERY ═══════ */
  .gallery {
    padding: 140px 24px 128px;
    background: #08080e;
    border-top: 1px solid rgba(212,175,55,.05);
  }

  .gallery-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .gallery-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px 40px;
    margin-bottom: 48px;
  }

  .section-title {
    font: 300 clamp(36px, 6vw, 56px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
  }

  .gallery-filters {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .chip {
    padding: 6px 14px;
    border: none;
    background: transparent;
    color: var(--t3);
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    cursor: pointer;
    opacity: .35;
    transition: opacity .5s cubic-bezier(.25,0,0,1);
  }

  .chip--active {
    opacity: 1;
    color: var(--t1);
  }

  .chip:hover {
    opacity: .7;
  }

  .chip + .chip {
    border-left: 1px solid rgba(212,175,55,.1);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: rgba(212,175,55,.06);
  }

  .card {
    background: #08080e;
    opacity: 0;
    transform: translateY(20px);
    transition: background .5s cubic-bezier(.25,0,0,1);
  }

  .card.is-visible {
    animation: fade-up .5s cubic-bezier(.25,0,0,1) calc(var(--i) * 60ms) forwards;
  }

  .card.is-visible.anim-done {
    opacity: 1;
    transform: none;
    animation: none;
  }

  .card[hidden] { display: none; }

  .card.anim-done:hover {
    background: rgba(255,255,255,.025);
  }

  .card-link {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 10px;
    padding: 32px 28px;
    min-height: 240px;
    text-decoration: none;
    color: inherit;
  }

  .card-type {
    font: 400 10px/1 var(--fm);
    color: var(--ac);
    text-transform: uppercase;
    letter-spacing: .14em;
    opacity: .7;
  }

  .card-title {
    font: 400 clamp(18px, 2.5vw, 22px)/1.3 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-subject {
    font: 400 11px/1.3 var(--fi);
    color: var(--t3);
    letter-spacing: .03em;
  }

  .gallery-more {
    display: inline-block;
    margin-top: 56px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--t3);
    text-decoration: none;
    transition: color .5s cubic-bezier(.25,0,0,1);
  }

  .gallery-more:hover { color: var(--ac); }

  /* ═══════ PROCESS ═══════ */
  .process {
    padding: 140px 24px;
    background: #0b0a06;
    border-top: 1px solid rgba(212,175,55,.05);
  }

  .process-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .steps {
    margin-top: 64px;
    position: relative;
    display: grid;
    gap: 48px;
  }

  .steps-line {
    display: none;
  }

  .step {
    position: relative;
    padding-left: 24px;
    padding-top: 40px;
  }

  .step-num {
    position: absolute;
    left: 0;
    top: 0;
    font: 300 clamp(80px, 12vw, 104px)/1 var(--fm);
    color: var(--ac);
    opacity: .06;
    user-select: none;
  }

  .step-title {
    position: relative;
    display: block;
    font: 400 12px/1.4 var(--fi);
    color: var(--t1);
    text-transform: uppercase;
    letter-spacing: .12em;
  }

  .step-note {
    position: relative;
    margin-top: 10px;
    font: 400 15px/1.6 var(--fi);
    color: var(--t2);
  }

  .process-actions {
    margin-top: 64px;
    display: flex;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }

  .process-channels {
    display: flex;
    gap: 16px;
  }

  .link-text {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    text-decoration: none;
    transition: color .5s cubic-bezier(.25,0,0,1);
  }

  .link-text:hover { color: var(--ac); }

  /* ═══════ CLOSING (= FOOTER) ═══════ */

  /* Hide global Footer component on homepage */
  :global(.footer) {
    display: none;
  }

  .closing {
    position: relative;
    padding: 180px 24px 72px;
    background: var(--bg);
    text-align: center;
    border-top: 1px solid rgba(212,175,55,.05);
  }

  .closing-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .closing-title {
    font: 300 clamp(32px, 5.5vw, 52px)/1.15 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    text-wrap: balance;
  }

  .closing-actions {
    margin-top: 48px;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .closing-links {
    margin-top: 96px;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
  }

  .closing-links a {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    padding: 4px 14px;
    transition: color .5s cubic-bezier(.25,0,0,1);
  }

  .closing-links a:hover {
    color: var(--t1);
  }

  .closing-links a + a {
    border-left: 1px solid rgba(212,175,55,.08);
  }

  .colophon {
    margin-top: 32px;
    font: 400 10px/1 var(--fm);
    text-transform: uppercase;
    letter-spacing: .22em;
    color: var(--t3);
    opacity: .25;
  }

  /* ═══════ TABLET ═══════ */
  @media (min-width: 640px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ═══════ DESKTOP ═══════ */
  @media (min-width: 900px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .steps {
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
    }

    .step {
      padding: 44px 40px 0 28px;
    }

    .steps-line {
      display: block;
      position: absolute;
      top: 44px;
      left: 40px;
      right: 40px;
      height: 0.5px;
      background: rgba(212,175,55,.1);
      transform-origin: left;
      transform: scaleX(0);
    }

    /* Scroll-driven draw if supported */
    @supports (animation-timeline: view()) {
      .steps-line {
        animation: draw-line linear both;
        animation-timeline: view();
        animation-range: entry 20% cover 50%;
      }
    }

    /* IO fallback */
    .steps-line.is-drawn {
      animation: draw-line .8s var(--ease) forwards;
    }

    @keyframes draw-line {
      to { transform: scaleX(1); }
    }
  }

  @media (min-width: 1024px) {
    .hero-metrics { gap: 120px; }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .word,
    .hero-rule,
    .hero-unfold,
    .hero-sub,
    .hero-actions,
    .metric,
    .card {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }

    .hero-rule {
      opacity: .3 !important;
    }

    .hero-unfold {
      opacity: 1 !important;
    }

    .hero-canvas {
      display: none !important;
    }

    .hero-glow {
      animation: none !important;
    }
  }
</style>

<script is:inline>
(() => {
  let cleanups = [];

  function cleanupAll() {
    cleanups.forEach((fn) => { try { fn(); } catch(_) {} });
    cleanups = [];
  }

  /* ── viewport fix ── */
  function fixViewport() {
    const meta = document.querySelector('meta[name="viewport"]');
    if (meta) meta.setAttribute('content', 'width=device-width, initial-scale=1');
  }

  /* ── intersection reveal for metrics + cards ── */
  function initReveal() {
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const items = document.querySelectorAll('.metric, .card');

    if (reduced) {
      items.forEach((el) => {
        el.classList.add('is-visible');
        el.classList.add('anim-done');
      });
      return;
    }

    /* Mark cards as anim-done after their animation ends so hover works */
    items.forEach((el) => {
      const handler = () => {
        el.classList.add('anim-done');
        el.removeEventListener('animationend', handler);
      };
      el.addEventListener('animationend', handler);
      cleanups.push(() => el.removeEventListener('animationend', handler));
    });

    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        e.target.classList.add('is-visible');
        obs.unobserve(e.target);
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    items.forEach((el) => obs.observe(el));
    cleanups.push(() => obs.disconnect());
  }

  /* ── count-up for metrics ── */
  function initCountUp() {
    const els = document.querySelectorAll('[data-target]');
    if (!els.length) return;

    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        obs.unobserve(e.target);

        const target = parseInt(e.target.getAttribute('data-target') || '0', 10);
        const suffix = e.target.getAttribute('data-suffix') || '';
        const duration = 1200;
        const start = performance.now();

        function tick(now) {
          const t = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - t, 3);
          const val = Math.round(ease * target);
          e.target.textContent = val + suffix;
          if (t < 1) requestAnimationFrame(tick);
        }

        requestAnimationFrame(tick);
      });
    }, { threshold: 0.3 });

    els.forEach((el) => obs.observe(el));
    cleanups.push(() => obs.disconnect());
  }

  /* ── progress line for steps (IO fallback when scroll-driven not supported) ── */
  function initStepsLine() {
    const line = document.getElementById('stepsLine');
    if (!line) return;
    if (CSS.supports('animation-timeline: view()')) return;

    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        line.classList.add('is-drawn');
        obs.unobserve(e.target);
      });
    }, { threshold: 0.2 });

    obs.observe(line);
    cleanups.push(() => obs.disconnect());
  }

  /* ── filters ── */
  function initFilters() {
    const chips = Array.from(document.querySelectorAll('.chip'));
    const cards = Array.from(document.querySelectorAll('.card'));
    if (!chips.length || !cards.length) return;

    function apply(key) {
      cards.forEach((card) => {
        const group = card.getAttribute('data-group') || '';
        card.hidden = !(key === 'Все' || group === key);
        card.style.gridColumn = '';
      });

      /* Fill incomplete last row: stretch last visible card */
      var visible = cards.filter(function(c) { return !c.hidden; });
      var cols = 1;
      if (window.matchMedia('(min-width: 900px)').matches) cols = 3;
      else if (window.matchMedia('(min-width: 640px)').matches) cols = 2;

      if (cols > 1 && visible.length > 0) {
        var remainder = visible.length % cols;
        if (remainder !== 0) {
          var last = visible[visible.length - 1];
          last.style.gridColumn = 'span ' + (cols - remainder + 1);
        }
      }
    }

    chips.forEach((chip) => {
      const onClick = () => {
        chips.forEach((c) => {
          c.classList.remove('chip--active');
          c.setAttribute('aria-selected', 'false');
        });
        chip.classList.add('chip--active');
        chip.setAttribute('aria-selected', 'true');
        apply(chip.getAttribute('data-filter') || 'Все');
      };
      chip.addEventListener('click', onClick);
      cleanups.push(() => chip.removeEventListener('click', onClick));
    });

    apply('Все');
  }

  /* ── hero noise shader ── */
  function initHeroShader() {
    var canvas = document.getElementById('heroCanvas');
    if (!(canvas instanceof HTMLCanvasElement)) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var gl = canvas.getContext('webgl2', { alpha: true, antialias: false, powerPreference: 'low-power' });
    if (!gl) return;

    canvas.classList.add('is-active');

    var vert = '#version 300 es\nin vec2 a;out vec2 v;void main(){v=a*.5+.5;gl_Position=vec4(a,0,1);}';
    var frag = [
      '#version 300 es',
      'precision mediump float;',
      'in vec2 v;out vec4 o;',
      'uniform float u_t;',
      'uniform vec2 u_m;',

      /* simplex helpers */
      'vec3 mod289(vec3 x){return x-floor(x*(1./289.))*289.;}',
      'vec2 mod289(vec2 x){return x-floor(x*(1./289.))*289.;}',
      'vec3 pm(vec3 x){return mod289(((x*34.)+1.)*x);}',

      'float snoise(vec2 v){',
      '  const vec4 C=vec4(.211324865405187,.366025403784439,-.577350269189626,.024390243902439);',
      '  vec2 i=floor(v+dot(v,C.yy));',
      '  vec2 x0=v-i+dot(i,C.xx);',
      '  vec2 i1;i1=(x0.x>x0.y)?vec2(1,0):vec2(0,1);',
      '  vec4 x12=x0.xyxy+C.xxzz;x12.xy-=i1;',
      '  i=mod289(i);',
      '  vec3 p=pm(pm(i.y+vec3(0,i1.y,1.))+i.x+vec3(0,i1.x,1.));',
      '  vec3 m=max(.5-vec3(dot(x0,x0),dot(x12.xy,x12.xy),dot(x12.zw,x12.zw)),0.);',
      '  m=m*m;m=m*m;',
      '  vec3 x=2.*fract(p*C.www)-1.;',
      '  vec3 h=abs(x)-.5;',
      '  vec3 ox=floor(x+.5);',
      '  vec3 a0=x-ox;',
      '  m*=1.79284291400159-.85373472095314*(a0*a0+h*h);',
      '  vec3 g;',
      '  g.x=a0.x*x0.x+h.x*x0.y;',
      '  g.yz=a0.yz*x12.xz+h.yz*x12.yw;',
      '  return 130.*dot(m,g);',
      '}',

      'void main(){',
      '  float t=u_t*.00006;',
      '  vec2 uv=v;',

      /* subtle mouse influence */
      '  uv+=(.5-u_m)*.06;',

      /* multi-octave noise for organic flow */
      '  float n=0.;',
      '  n+=snoise(uv*1.8+vec2(t*.7,t*.5))*.5;',
      '  n+=snoise(uv*3.6-vec2(t*.4,t*.8))*.25;',
      '  n+=snoise(uv*7.0+vec2(t*1.1,-t*.6))*.125;',

      /* gold color palette — concentrated in center */
      '  float mask=1.-smoothstep(.0,.85,length(v-.5));',
      '  mask*=mask;',
      '  float intensity=smoothstep(-.2,.6,n)*mask;',

      /* warm gold tones */
      '  vec3 c1=vec3(.83,.69,.22);',  /* #d4af37 */
      '  vec3 c2=vec3(.93,.79,.29);',  /* brighter gold */
      '  vec3 col=mix(c1,c2,n*.5+.5);',

      '  o=vec4(col,intensity*.18);',
      '}',
    ].join('\n');

    function compile(type, src) {
      var s = gl.createShader(type);
      gl.shaderSource(s, src);
      gl.compileShader(s);
      return s;
    }

    var vs = compile(gl.VERTEX_SHADER, vert);
    var fs = compile(gl.FRAGMENT_SHADER, frag);
    var pg = gl.createProgram();
    gl.attachShader(pg, vs);
    gl.attachShader(pg, fs);
    gl.linkProgram(pg);

    if (!gl.getProgramParameter(pg, gl.LINK_STATUS)) {
      canvas.classList.remove('is-active');
      return;
    }

    gl.useProgram(pg);

    var buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);

    var aLoc = gl.getAttribLocation(pg, 'a');
    gl.enableVertexAttribArray(aLoc);
    gl.vertexAttribPointer(aLoc, 2, gl.FLOAT, false, 0, 0);

    var uT = gl.getUniformLocation(pg, 'u_t');
    var uM = gl.getUniformLocation(pg, 'u_m');

    var mx = 0.5, my = 0.5, tmx = 0.5, tmy = 0.5;
    var running = true;
    var rafId = 0;
    var w = 0, h = 0;

    function resize() {
      var dpr = Math.min(devicePixelRatio || 1, 1.5);
      w = canvas.clientWidth;
      h = canvas.clientHeight;
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      gl.viewport(0, 0, canvas.width, canvas.height);
    }

    function render(t) {
      if (!running) return;
      mx += (tmx - mx) * .04;
      my += (tmy - my) * .04;

      gl.clearColor(0, 0, 0, 0);
      gl.clear(gl.COLOR_BUFFER_BIT);
      gl.enable(gl.BLEND);
      gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);
      gl.uniform1f(uT, t);
      gl.uniform2f(uM, mx, my);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
      rafId = requestAnimationFrame(render);
    }

    var hero = document.getElementById('hero');
    var onMove = function(e) {
      var r = hero.getBoundingClientRect();
      tmx = (e.clientX - r.left) / r.width;
      tmy = (e.clientY - r.top) / r.height;
    };
    var onLeave = function() { tmx = .5; tmy = .5; };

    resize();
    window.addEventListener('resize', resize, { passive: true });
    if (hero) {
      hero.addEventListener('pointermove', onMove, { passive: true });
      hero.addEventListener('pointerleave', onLeave, { passive: true });
    }
    rafId = requestAnimationFrame(render);

    cleanups.push(function() {
      running = false;
      if (rafId) cancelAnimationFrame(rafId);
      window.removeEventListener('resize', resize);
      if (hero) {
        hero.removeEventListener('pointermove', onMove);
        hero.removeEventListener('pointerleave', onLeave);
      }
      canvas.classList.remove('is-active');
    });
  }

  /* ── init ── */
  function initAll() {
    cleanupAll();
    fixViewport();
    initHeroShader();
    initReveal();
    initCountUp();
    initStepsLine();
    initFilters();
  }

  initAll();
  document.addEventListener('astro:page-load', initAll);
  document.addEventListener('astro:after-swap', initAll);
})();
</script>
