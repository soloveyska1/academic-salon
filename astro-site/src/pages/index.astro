---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const totalDocs = D.length;
const currentYear = String(new Date().getFullYear());

function extractYear(doc: any) {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text].filter(Boolean).join(' ');
  const match = blob.match(/(?:19|20)\d{2}/);
  return match ? match[0] : currentYear;
}

function normalizeDoc(doc: any, index: number) {
  return {
    id: `${doc.file}-${index}`,
    slug: doc.file,
    title: doc.catalogTitle || doc.title || doc.filename || 'Студенческая работа',
    type: doc.docType || doc.category || 'Работа',
    subject: doc.subject || 'Психология',
    year: extractYear(doc),
  };
}

const preferredCategories = [
  'ВКР и дипломы',
  'Курсовые работы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
  'Методические материалы',
];

const pickedDocs: any[] = [];
for (const category of preferredCategories) {
  const nextDocs = D.filter((doc: any) => doc.category === category).slice(0, 1);
  pickedDocs.push(...nextDocs);
}
if (pickedDocs.length < 6) {
  for (const doc of D) {
    if (pickedDocs.includes(doc)) continue;
    pickedDocs.push(doc);
    if (pickedDocs.length >= 6) break;
  }
}

const cards = pickedDocs.slice(0, 6).map(normalizeDoc);

const reviewAlts = [
  'Отзыв: Спасибо за работу',
  'Отзыв: У меня 5, работа очень хорошая',
  'Отзыв: Четвёрка твёрдая, отлично всё',
  'Отзыв: Автомат, 5 -- спасибо огромное',
  'Отзыв: Сдали с первого раза',
  'Отзыв: Сдала на 4, сказали хорошая работа',
  'Отзыв: Кайф, благодарю за быструю работу',
  'Отзыв: Всё отлично, спасибо',
  'Отзыв: Преподаватель поставил отлично',
  'Отзыв: Работа принята без замечаний',
];
---

<Base
  title="Библиотека академического салона -- студенческие работы без паники"
  description="Библиотека готовых студенческих работ: психология, социальная работа, конфликтология и другие гуманитарные дисциплины. Или закажите индивидуальную подготовку."
  currentPath="/"
>

  <!-- ============================================================
       I · PRELUDE — Editorial hero
       ============================================================ -->
  <section class="hero prelude" id="hero" aria-label="Вступление">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <span class="prelude-eyebrow">
        <span class="prelude-eyebrow-rule" aria-hidden="true"></span>
        <span class="prelude-eyebrow-num">I</span>
        Prooemium · Начало разговора
      </span>

      <h1 class="hero-title prelude-title" aria-label="Студенческие работы — готовые или написанные под вас.">
        <span class="ln"><span class="word" style="--i:0">Студенческие</span> <span class="word" style="--i:1">работы&nbsp;—</span></span>
        <span class="ln"><span class="word" style="--i:2">готовые</span> <span class="word" style="--i:3">или</span></span>
        <span class="ln"><em class="it"><span class="word" style="--i:4">написанные</span> <span class="word" style="--i:5">под</span> <span class="word" style="--i:6">вас</span></em>.</span>
      </h1>

      <div class="hero-rule" aria-hidden="true"></div>

      <p class="hero-sub prelude-lede">
        <span class="lede-aud">Свободный архив&nbsp;— </span>{totalDocs}+ работ по&nbsp;психологии, социальной работе и&nbsp;конфликтологии. <span class="lede-sep" aria-hidden="true">·</span>
        <span class="lede-aud">Под защиту&nbsp;— </span>авторский текст с&nbsp;разговором, планом и&nbsp;сопровождением до&nbsp;оценки.
      </p>

      <form class="hero-search" action="/catalog" method="get" role="search" aria-label="Поиск по каталогу">
        <svg class="hero-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input class="hero-search-input" type="search" name="q" placeholder="Найти работу… (нажмите /)" autocomplete="off" enterkeyhint="search" id="heroSearchInput" aria-label="Поиск работы" />
      </form>

      <div class="hero-actions">
        <a href="/catalog" class="btn btn--primary">Открыть архив</a>
        <a href="/order" class="btn btn--ghost">Заказать работу</a>
      </div>
    </div>

    <a href="#manifesto" class="prelude-cue" aria-label="Прочесть дальше">
      <span>прочесть дальше</span>
      <span class="prelude-cue-line" aria-hidden="true"></span>
    </a>
  </section>

  <!-- ============================================================
       STATS — editorial column strip below the hero
       ============================================================ -->
  <section class="stats-strip rv" aria-label="О мастерской в цифрах">
    <div class="stats-strip-inner">
      <div class="stat-col">
        <span class="stat-lbl">В каталоге</span>
        <span class="stat-val">{totalDocs}<span class="stat-suffix">+</span> <i class="it">работ</i></span>
        <span class="stat-note">бесплатно, без регистрации</span>
      </div>
      <div class="stat-col">
        <span class="stat-lbl">Мастерская</span>
        <span class="stat-val"><span class="stat-sep">·</span> с 2020</span>
        <span class="stat-note">шесть лет тихой практики</span>
      </div>
      <div class="stat-col">
        <span class="stat-lbl">На связи</span>
        <span class="stat-val">15 <span class="stat-suffix">мин</span></span>
        <span class="stat-note">ответ живого человека в&nbsp;будни</span>
      </div>
    </div>
  </section>

  <!-- ============================================================
       II · MANIFESTO — what this salon is
       ============================================================ -->
  <section id="manifesto" class="manifesto rv" aria-label="Манифест">
    <div class="manifesto-inner">
      <header class="chapter-head">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">II</span>
          <span class="chapter-label">Caput Primum · Глава первая</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">О чём этот <em class="it">салон</em>.</h2>
          <p class="chapter-lede">Короткая правда о&nbsp;том, чем занимаемся: бесплатной библиотекой студенческих работ и&nbsp;авторскими заказами под защиту. Без&nbsp;коллцентра, без&nbsp;шаблонов, без&nbsp;ИИ-шлака.</p>
        </div>
      </header>

      <div class="manifesto-body">
        <p class="manifesto-text">
          <span class="manifesto-drop">М</span>ы&nbsp;собирали этот архив с&nbsp;2020&nbsp;года&nbsp;— из&nbsp;работ студентов, которые делились ими сами. {totalDocs}&nbsp;текстов по&nbsp;психологии, социальной работе, конфликтологии, педагогике. Берите целиком как образец, забирайте куски, ищите формулировки. <em class="it">Бесплатно</em> и&nbsp;без&nbsp;регистрации.
        </p>
        <p class="manifesto-text">
          Если в&nbsp;архиве нет вашей темы&nbsp;— напишем под вас. Не&nbsp;шаблон с&nbsp;биржи, а&nbsp;разговор тридцать минут, план, главу за&nbsp;главой с&nbsp;правками после каждой проверки руководителем. Ведём до&nbsp;оценки в&nbsp;ведомости, а&nbsp;не&nbsp;до&nbsp;«высылаю файл».
        </p>
        <p class="manifesto-text">
          За&nbsp;шесть&nbsp;лет тихой работы научились двум вещам: говорить «нет», когда тема не&nbsp;наша, и&nbsp;не&nbsp;браться за&nbsp;то, что не&nbsp;успеем сделать как следует. Это не&nbsp;кокетство&nbsp;— это причина, почему ни&nbsp;одна работа отсюда не&nbsp;возвращалась с&nbsp;плагиатом.
        </p>

        <div class="manifesto-cta">
          <a href="/catalog" class="btn btn--primary">Открыть архив</a>
          <a href="/order" class="btn btn--ghost">Заказать работу</a>
        </div>
      </div>

      <div class="manifesto-tenets">
        <article class="tenet">
          <span class="tenet-num">Principium I</span>
          <h3 class="tenet-h">Свободный архив,<br/>а&nbsp;не&nbsp;витрина</h3>
          <p class="tenet-p">{totalDocs}+ работ скачиваются <em class="it">без&nbsp;оплаты</em> и&nbsp;без&nbsp;регистрации. Если работа спасла студента&nbsp;— она наша и&nbsp;общая.</p>
        </article>
        <article class="tenet">
          <span class="tenet-num">Principium II</span>
          <h3 class="tenet-h">Авторский текст,<br/>а&nbsp;не&nbsp;компиляция</h3>
          <p class="tenet-p">Заказы пишет конкретный автор с&nbsp;профильным образованием. <em class="it">Никакого ИИ</em>, никаких переклеенных абзацев.</p>
        </article>
        <article class="tenet">
          <span class="tenet-num">Principium III</span>
          <h3 class="tenet-h">Сопровождение<br/>до&nbsp;оценки</h3>
          <p class="tenet-p">Правки после каждой проверки руководителем, репетиция защиты, речь, слайды&nbsp;— <em class="it">в&nbsp;цене</em>.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       III · METHOD — how the salon actually works
       ============================================================ -->
  <section id="method" class="method rv" aria-label="Метод">
    <div class="method-inner">
      <header class="chapter-head">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">III</span>
          <span class="chapter-label">Caput Secundum · Глава вторая</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">Как работает <em class="it">салон</em>.</h2>
          <p class="chapter-lede">Два&nbsp;входа в&nbsp;мастерскую: бесплатный архив для&nbsp;тех, кто ищет образец, и&nbsp;авторский заказ для&nbsp;тех, кому нужно под&nbsp;их&nbsp;руководителя. Ниже&nbsp;— как идёт каждый сценарий.</p>
        </div>
      </header>

      <ol class="method-steps">
        <li class="method-step">
          <span class="step-no">I</span>
          <span class="step-latin">Conspectus</span>
          <h3 class="step-h">Поиск в&nbsp;архиве</h3>
          <p class="step-p">Открываете каталог, смотрите по&nbsp;теме, по&nbsp;дисциплине, по&nbsp;типу работы. Скачиваете без&nbsp;регистрации&nbsp;— берёте целиком как образец или собираете куски.</p>
          <span class="step-foot"><span class="step-foot-l">Время</span><span class="step-foot-v">5 минут</span></span>
        </li>

        <li class="method-step">
          <span class="step-no">II</span>
          <span class="step-latin">Colloquium</span>
          <h3 class="step-h">Разговор и&nbsp;план</h3>
          <p class="step-p">Если в&nbsp;архиве вашего нет&nbsp;— пишете в&nbsp;любой мессенджер. Тридцать минут разговора: тема, руководитель, кафедра, методичка, дедлайн. Получаете план с&nbsp;главами и&nbsp;сроками.</p>
          <span class="step-foot"><span class="step-foot-l">Время</span><span class="step-foot-v">1–2 дня</span></span>
        </li>

        <li class="method-step">
          <span class="step-no">III</span>
          <span class="step-latin">Elocutio</span>
          <h3 class="step-h">Работа над&nbsp;рукописью</h3>
          <p class="step-p">Автор пишет главу за&nbsp;главой, высылает по&nbsp;мере готовности. Правки после каждой проверки руководителем&nbsp;— бесплатно. Антиплагиат ВУЗ до&nbsp;90% оригинальности.</p>
          <span class="step-foot"><span class="step-foot-l">Время</span><span class="step-foot-v">основной этап</span></span>
        </li>

        <li class="method-step">
          <span class="step-no">IV</span>
          <span class="step-latin">Actio</span>
          <h3 class="step-h">Сопровождение до&nbsp;защиты</h3>
          <p class="step-p">Презентация в&nbsp;стиле вашего ВУЗа, речь на&nbsp;7–10&nbsp;минут, репетиция по&nbsp;видео. Правим до&nbsp;оценки в&nbsp;ведомости, а&nbsp;не&nbsp;до&nbsp;«сдал и&nbsp;ушёл».</p>
          <span class="step-foot"><span class="step-foot-l">Гарантия</span><span class="step-foot-v">до оценки</span></span>
        </li>
      </ol>
    </div>
  </section>

  <!-- ============================================================
       IV · TESTIMONIA — wrap existing scrolling review wall
       (Real screenshots, not fabricated copy. Runtime: see scripts/home-page-runtime.ts)
       ============================================================ -->
  <section id="testimonia" class="reviews testimonia rv" aria-label="Свидетельства">
    <header class="chapter-head testimonia-head">
      <div class="chapter-num">
        <span class="roman" aria-hidden="true">IV</span>
        <span class="chapter-label">Caput Tertium · Глава третья</span>
      </div>
      <div class="chapter-title-block">
        <h2 class="chapter-h">Что говорят <em class="it">студенты</em>.</h2>
        <p class="chapter-lede">Не&nbsp;вычитанные «спасибо за&nbsp;работу», а&nbsp;реальные скриншоты переписок&nbsp;— то, что писали после защиты, не&nbsp;зная, что мы&nbsp;их&nbsp;покажем. Тапните по&nbsp;любой, чтобы открыть на&nbsp;весь экран.</p>
      </div>
    </header>
    <div class="reviews-wall">
      <!-- Row 1: scrolls left -->
      <div class="rw-row rw-row--left">
        <div class="rw-track">
          <img src="/reviews/4.webp" alt={reviewAlts[3]} class="rw-img" loading="lazy" />
          <img src="/reviews/2.webp" alt={reviewAlts[1]} class="rw-img" loading="lazy" />
          <img src="/reviews/8.webp" alt={reviewAlts[7]} class="rw-img" loading="lazy" />
          <img src="/reviews/5.webp" alt={reviewAlts[4]} class="rw-img" loading="lazy" />
          <img src="/reviews/3.webp" alt={reviewAlts[2]} class="rw-img" loading="lazy" />
          <!-- Duplicate for seamless loop -->
          <img src="/reviews/4.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/2.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/8.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/5.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/3.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
        </div>
      </div>
      <!-- Row 2: scrolls right -->
      <div class="rw-row rw-row--right">
        <div class="rw-track">
          <img src="/reviews/6.webp" alt={reviewAlts[5]} class="rw-img" loading="lazy" />
          <img src="/reviews/1.webp" alt={reviewAlts[0]} class="rw-img" loading="lazy" />
          <img src="/reviews/7.webp" alt={reviewAlts[6]} class="rw-img" loading="lazy" />
          <img src="/reviews/10.webp" alt={reviewAlts[9]} class="rw-img" loading="lazy" />
          <img src="/reviews/9.webp" alt={reviewAlts[8]} class="rw-img" loading="lazy" />
          <!-- Duplicate for seamless loop -->
          <img src="/reviews/6.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/1.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/7.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/10.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
          <img src="/reviews/9.webp" alt="" class="rw-img" aria-hidden="true" loading="lazy" />
        </div>
      </div>
    </div>

    <!-- Lightbox — click to enlarge any review -->
    <div class="lightbox" id="reviewLightbox" aria-hidden="true">
      <button class="lb-close" id="lbClose" aria-label="Закрыть">&times;</button>
      <button class="lb-prev" id="lbPrev" aria-label="Назад">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <img class="lb-img" id="lbImg" alt="" />
      <button class="lb-next" id="lbNext" aria-label="Вперёд">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
      </button>
      <span class="lb-counter" id="lbCounter"></span>
    </div>
  </section>

  <!-- ============================================================
       3. CATALOG -- Bento grid
       ============================================================ -->
  <section class="catalog rv">
    <div class="catalog-inner">
      <div class="catalog-head">
        <h2 class="section-title">Каталог</h2>
        <a href="/catalog" class="section-link">Все работы &rarr;</a>
      </div>
      <div class="catalog-grid">
        {cards.map((card) => (
          <a href={`/doc/${card.slug}`} class="card">
            <span class="card-type">{card.type}</span>
            <h3 class="card-title">{card.title}</h3>
            <span class="card-meta">{card.subject} &middot; {card.year}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       4. ORDER -- Conversion
       ============================================================ -->
  <section class="order rv">
    <div class="order-inner">
      <h2 class="order-title">Напишем под ваши<br/>требования.</h2>
      <div class="order-prices">
        <div class="price-item">
          <span class="price-label">Реферат</span>
          <span class="price-amount">от 3 000 &#8381;</span>
        </div>
        <span class="price-divider"></span>
        <div class="price-item">
          <span class="price-label">Курсовая</span>
          <span class="price-amount">от 5 000 &#8381;</span>
        </div>
        <span class="price-divider"></span>
        <div class="price-item">
          <span class="price-label">Дипломная</span>
          <span class="price-amount">от 30 000 &#8381;</span>
        </div>
      </div>
      <a href="/order" class="order-btn btn btn--primary">Заказать работу</a>
      <div class="order-contacts">
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.5 2.5L2 10l7 3 3 7 9.5-18z"/><line x1="9" y1="13" x2="13.5" y2="8.5"/></svg>
          Telegram
        </a>
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M12.5 16.5c-3.5 0-5.5-2.5-5.6-5h2c.1 1.8 1.3 2.5 2.3 2.7V11.5c-1.5-.2-3-1-3-3.5 0-1.7 1.2-2.9 3-3v3"/></svg>
          VK
        </a>
        <a href="mailto:academsaloon@mail.ru">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
          academsaloon@mail.ru
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       V · EPILOGUE — final CTA + signature
       ============================================================ -->
  <section id="contact" class="epilogue rv" aria-label="Контакты">
    <div class="epilogue-inner">
      <span class="epilogue-eyebrow">
        <span class="prelude-eyebrow-rule" aria-hidden="true"></span>
        <span class="prelude-eyebrow-num">V</span>
        Epilogus · Послесловие
      </span>

      <h2 class="epilogue-h">Напишите. <em class="it">Мы&nbsp;на&nbsp;связи</em>.</h2>
      <p class="epilogue-sub">Ответ&nbsp;— в&nbsp;течение 15&nbsp;минут в&nbsp;рабочее время. Отвечает живой человек, не&nbsp;бот. Разговор ни&nbsp;к&nbsp;чему не&nbsp;обязывает.</p>

      <div class="epilogue-channels" role="list">
        <a class="channel" href="https://t.me/academicsaloon" target="_blank" rel="noopener" role="listitem" aria-label="Написать в Telegram — самый быстрый ответ">
          <span class="channel-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3l15.97-6.16c.73-.33 1.43.18 1.15 1.3l-2.72 12.81c-.19.91-.74 1.13-1.5.71L12.6 16.3l-1.99 1.93c-.23.23-.42.42-.83.42z"/></svg>
          </span>
          <span class="channel-name">Telegram</span>
          <span class="channel-handle">@academicsaloon</span>
