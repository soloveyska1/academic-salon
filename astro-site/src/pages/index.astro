</style>

<script is:inline>
  (() => {
    let cleanups = [];

    function cleanupAll() {
      cleanups.forEach((fn) => {
        try { fn(); } catch (e) { /* no-op */ }
      });
      cleanups = [];
    }

    function initReveals() {
      const nodes = Array.from(document.querySelectorAll('[data-reveal]'));
      if (!nodes.length) return;

      nodes.forEach((node) => {
        const delay = Number(node.getAttribute('data-delay') || 0);
        node.style.setProperty('--reveal-delay', `${delay}ms`);
      });

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        nodes.forEach((node) => node.classList.add('is-visible'));
        return;
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.18, rootMargin: '0px 0px -40px 0px' });

      nodes.forEach((node) => observer.observe(node));
      cleanups.push(() => observer.disconnect());
    }

    function initHeroPlane() {
      const section = document.getElementById('hero');
      const plane = document.getElementById('heroPlane');
      if (!section || !plane) return;
      if (window.matchMedia('(pointer: coarse)').matches) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      let targetX = 0;
      let targetY = 0;
      let currentX = 0;
      let currentY = 0;
      let rafId = 0;

      const render = () => {
        currentX += (targetX - currentX) * 0.08;
        currentY += (targetY - currentY) * 0.08;

        const rotX = currentY * -6;
        const rotY = currentX * 7;
        plane.style.transform = `perspective(1200px) rotateX(${rotX.toFixed(2)}deg) rotateY(${rotY.toFixed(2)}deg)`;

        if (Math.abs(targetX - currentX) > 0.001 || Math.abs(targetY - currentY) > 0.001) {
          rafId = requestAnimationFrame(render);
        } else {
          rafId = 0;
        }
      };

      const onMove = (event) => {
        const rect = section.getBoundingClientRect();
        targetX = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
        targetY = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
        if (!rafId) rafId = requestAnimationFrame(render);
      };

      const onLeave = () => {
        targetX = 0;
        targetY = 0;
        if (!rafId) rafId = requestAnimationFrame(render);
      };

      section.addEventListener('mousemove', onMove, { passive: true });
      section.addEventListener('mouseleave', onLeave);

      cleanups.push(() => {
        section.removeEventListener('mousemove', onMove);
        section.removeEventListener('mouseleave', onLeave);
        if (rafId) cancelAnimationFrame(rafId);
        plane.style.transform = 'perspective(1200px) rotateX(0deg) rotateY(0deg)';
      });
    }

    function initAtlasBars() {
      const chart = document.getElementById('atlasChart');
      if (!chart) return;

      const rows = Array.from(chart.querySelectorAll('.atlas-row'));
      if (!rows.length) return;

      const observer = new IntersectionObserver((entries) => {
        const visible = entries.some((entry) => entry.isIntersecting);
        if (!visible) return;
        rows.forEach((row) => row.classList.add('is-ready'));
        observer.disconnect();
      }, { threshold: 0.35 });

      observer.observe(chart);
      cleanups.push(() => observer.disconnect());
    }

    function initAtelierDirector() {
      const dataNode = document.getElementById('atelierData');
      const listNode = document.getElementById('atelierList');
      if (!dataNode || !listNode) return;

      let stages = [];
      try {
        const parsed = JSON.parse(dataNode.textContent || '[]');
        if (Array.isArray(parsed)) stages = parsed;
      } catch (_) {
        return;
      }
      if (!stages.length) return;

      const controls = Array.from(listNode.querySelectorAll('.atelier-step'));
      const tag = document.getElementById('atelierTag');
      const time = document.getElementById('atelierTime');
      const headline = document.getElementById('atelierHeadline');
      const body = document.getElementById('atelierBody');
      const metrics = document.getElementById('atelierMetrics');
      const section = document.getElementById('atelier');

      if (!tag || !time || !headline || !body || !metrics || !section) return;

      let activeIndex = 0;
      let timer = null;

      const renderMetrics = (items) => {
        metrics.innerHTML = '';
        items.forEach((item) => {
          const box = document.createElement('div');
          box.className = 'atelier-metric';

          const label = document.createElement('span');
          label.textContent = item.label;

          const value = document.createElement('strong');
          value.textContent = item.value;

          box.appendChild(label);
          box.appendChild(value);
          metrics.appendChild(box);
        });
      };

      const activate = (index) => {
        const stage = stages[index];
        if (!stage) return;

        activeIndex = index;
        controls.forEach((btn, btnIndex) => btn.classList.toggle('is-active', btnIndex === index));

        tag.textContent = stage.label;
        time.textContent = stage.timing;
        headline.textContent = stage.headline;
        body.textContent = stage.body;
        renderMetrics(stage.metrics || []);
      };

      const stopTimer = () => {
        if (!timer) return;
        clearInterval(timer);
        timer = null;
      };

      const startTimer = () => {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        stopTimer();
        timer = window.setInterval(() => {
          if (document.hidden) return;
          const next = (activeIndex + 1) % stages.length;
          activate(next);
        }, 5200);
      };

      controls.forEach((button, index) => {
        const onClick = () => {
          activate(index);
          startTimer();
        };
        button.addEventListener('click', onClick);
        cleanups.push(() => button.removeEventListener('click', onClick));
      });

      const visibilityObserver = new IntersectionObserver((entries) => {
        const isVisible = entries.some((entry) => entry.isIntersecting);
        if (isVisible) startTimer();
        else stopTimer();
      }, { threshold: 0.3 });

      visibilityObserver.observe(section);
      cleanups.push(() => visibilityObserver.disconnect());

      const onVisibilityChange = () => {
        if (document.hidden) stopTimer();
        else startTimer();
      };

      document.addEventListener('visibilitychange', onVisibilityChange);
      cleanups.push(() => {
        stopTimer();
        document.removeEventListener('visibilitychange', onVisibilityChange);
      });

      activate(0);
    }

    function initAll() {
      cleanupAll();
      initReveals();
      initHeroPlane();
      initAtlasBars();
      initAtelierDirector();
    }

    initAll();
    document.addEventListener('astro:page-load', initAll);
    document.addEventListener('astro:after-swap', initAll);
  })();
</script>
