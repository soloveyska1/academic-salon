---
import Base from '../layouts/Base.astro';
import { breadcrumb } from '../lib/schema';
import {
  ANTI_AI_TIERS,
  ANTI_AI_URGENCIES,
  getAntiAiPrice,
  getAntiAiEntryHint,
} from '../lib/order-price-hint.js';

const entryHint = getAntiAiEntryHint();
const entryNumber = entryHint.replace('от ', '').replace(' ₽', '').trim();

const tierEntries = Object.entries(ANTI_AI_TIERS) as [string, typeof ANTI_AI_TIERS[keyof typeof ANTI_AI_TIERS]][];
const urgencyEntries = Object.entries(ANTI_AI_URGENCIES) as [string, typeof ANTI_AI_URGENCIES[keyof typeof ANTI_AI_URGENCIES]][];

const faqItems = [
  {
    q: 'Если переписать самой — пройдёт?',
    a: 'Можно. Но переписать так, чтобы убрать ритм, штампы и пунктуационные привычки ИИ, — это уже не пара часов, а несколько дней с регулярными прогонами через детектор. И чаще всего после очередной правки уникальность снова падает. Мы делаем это за один день и фиксируем результат отчётом «до / после».',
  },
  {
    q: 'Не упадёт ли уникальность по обычному антиплагиату?',
    a: 'Нет. Мы меняем стилистические маркеры — длинное тире, штампы, ритм фраз — но не текст по смыслу. Для классического антиплагиата по совпадениям этот текст идентичен исходному; уникальность остаётся такой же, как была.',
  },
  {
    q: 'Что значит «отчёт до / после»?',
    a: 'PDF на 2–3 страницы: подсвеченные места, которые палили работу как ИИ, и наши правки рядом. Чтобы могла защитить логику изменений перед научником и видела, что мы действительно что-то делали — а не просто прогнали через ChatGPT в обратную сторону.',
  },
  {
    q: 'Можно согласовать стиль с научным руководителем?',
    a: 'Да. Если научник любит академический штамп и кафедра без оборотов не принимает (юриспруденция, философия, философия права), — оставляем там, где штамп критичен для дисциплины. В психологии, педагогике, социальной работе чистим аккуратно. Скажи в заявке, в чём ограничения, — учтём.',
  },
  {
    q: 'Какие гарантии? Что если всё равно красное?',
    a: 'Если после нашей чистки Антиплагиат 2.0 даёт больше 30% ИИ — дорабатываем бесплатно, пока не выйдем под порог. Если результат не достижим в принципе (бывает — кафедра требует определённый формальный стиль), — возвращаем 100% оплаты.',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Очистка академической работы от ИИ-маркеров',
  name: 'Чистка под Антиплагиат 2.0 — Академический Салон',
  description: 'Уберём из текста привычки ИИ — длинное тире, академические штампы, ритм фраз. Антиплагиат 2.0 (пилот апреля 2026 в 50 вузах) перестанет красить работу как написанную ChatGPT. Смысл сохраняем, отчёт «до/после» в подарок.',
  provider: {
    '@type': 'Organization',
    name: 'Академический Салон',
    url: 'https://bibliosaloon.ru/',
  },
  areaServed: { '@type': 'Country', name: 'Россия' },
  availableChannel: {
    '@type': 'ServiceChannel',
    serviceUrl: 'https://bibliosaloon.ru/order/?service=anti-ai',
    serviceName: 'Калькулятор и заявка',
  },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'RUB',
    price: '2500',
    description: 'Базовая ставка для эссе и рефератов до 15 страниц. Большие работы и срочность — по тарифной матрице.',
  },
};
---

<Base
  title="Чистка под Антиплагиат 2.0 — уберём следы ChatGPT | Академический Салон"
  description="Антиплагиат 2.0 видит привычки, не смысл. Длинное тире, академические штампы, ритм фраз — палят за тебя, даже если писала сама. За день почистим без потери смысла. От 2 500 ₽ + отчёт «до/после»."
  currentPath="/anti-ai"
  extraSchema={[
    breadcrumb([{ name: 'Чистка от ИИ', url: '/anti-ai/' }]),
    serviceLd,
    faqLd,
  ]}
>

  <article class="aai">

    <!-- ═══════ HERO ═══════ -->
    <section class="aai-hero" aria-labelledby="aai-hero-h">

      <div class="aai-eyebrow" aria-hidden="false">
        <span class="rule"></span>
        <span class="text">Антиплагиат 2.0 · апрель 2026 · пилот в 50 вузах</span>
      </div>

      <header class="aai-head">
        <div class="col">
          <span class="lbl">Срок</span>
          <span class="val">1 <i class="it">день</i></span>
        </div>
        <div class="col">
          <span class="lbl">Цена</span>
          <span class="val">{entryNumber} <i class="it">₽+</i></span>
        </div>
        <div class="col">
          <span class="lbl">Бонус</span>
          <span class="val">отчёт <i class="it">до / после</i></span>
        </div>
      </header>

      <h1 id="aai-hero-h" class="aai-h">
        <span class="ln">Уберём <em class="it">следы ChatGPT</em> —</span>
        <span class="ln-2">текст пройдёт <em class="it">даже Антиплагиат 2.0</em></span>
      </h1>

      <p class="aai-lede">
        С апреля 2026 Антиплагиат смотрит уже не на смысл, а на привычки —
        длинное тире, академические штампы, ритм фраз. Писала сама,
        не GPT? Всё равно красит. За день почистим без потери смысла.
      </p>

      <div class="aai-actions">
        <a href="/order?service=anti-ai" class="btn btn-gold btn-lg">
          Рассчитать — {entryHint}
        </a>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost-gold btn-lg">
          Сначала спросить
        </a>
      </div>

      <a href="#aai-pain" class="aai-scroll-cue" aria-label="Читать дальше">
        <span class="lbl">почему так палит</span>
        <span class="line" aria-hidden="true"></span>
      </a>

    </section>

    <!-- ═══════ I — БОЛЬ ═══════ -->
    <section class="aai-section aai-pain" id="aai-pain" aria-labelledby="aai-pain-h">
      <header class="aai-chapter-head">
        <span class="aai-chapter-num" aria-hidden="true">I</span>
        <div class="aai-chapter-body">
          <span class="aai-chapter-eyebrow">Боль · цикл переписывания</span>
          <h2 id="aai-pain-h" class="aai-chapter-h">
            Сидишь над ВКР <em class="it">третий месяц</em>.
          </h2>
        </div>
      </header>

      <div class="aai-pain-quotes">
        <figure class="aai-quote">
          <blockquote>Антиплагиат кидает: ИИ — 60%+. Переписала, стало 45%. Опять красная.</blockquote>
          <figcaption>Студентка четвёртого курса · 14 апреля 2026</figcaption>
        </figure>
        <figure class="aai-quote">
          <blockquote>Защита через две недели. А я уже две недели делаю одно и то же.</blockquote>
          <figcaption>Магистрант психологии · апрель 2026</figcaption>
        </figure>
        <figure class="aai-quote">
          <blockquote>Писала сама. Не GPT. А Антиплагиат не верит.</blockquote>
          <figcaption>Из переписки в Telegram · вчера</figcaption>
        </figure>
      </div>

      <p class="aai-pain-note"><em class="it">Знакомо?</em> Видим такое каждый день.</p>
    </section>

    <!-- ═══════ II — ПОЧЕМУ ТАК ═══════ -->
    <section class="aai-section aai-why" id="aai-why" aria-labelledby="aai-why-h">
      <header class="aai-chapter-head">
        <span class="aai-chapter-num" aria-hidden="true">II</span>
        <div class="aai-chapter-body">
          <span class="aai-chapter-eyebrow">Почему так · детектор привычек</span>
          <h2 id="aai-why-h" class="aai-chapter-h">
            Антиплагиат 2.0 смотрит уже не на смысл, <em class="it">а на привычки</em>.
          </h2>
        </div>
      </header>

      <div class="aai-why-cols">
        <article class="aai-why-col">
          <span class="aai-why-mark" aria-hidden="true">α</span>
          <h3>Ритм фраз</h3>
          <p>
            Длина предложений, чередование запятых, паттерн придаточных.
            ChatGPT любит средне-длинное с двумя зависимыми — и это палит
            детектор. Доля работ с признаками ИИ за год выросла с 16% до 23%.
          </p>
          <p class="aai-why-src">
            <a href="https://www.interfax.ru/russia/1052546" target="_blank" rel="noopener">Интерфакс →</a>
            <a href="https://antiplagiat.ru/news/antiplagiat2/" target="_blank" rel="noopener">Антиплагиат →</a>
          </p>
        </article>

        <article class="aai-why-col">
          <span class="aai-why-mark" aria-hidden="true">β</span>
          <h3>Академические штампы</h3>
          <p>
            «Важно отметить», «в современном мире», «не просто X — а Y».
            Курс академического письма сам в тебя их и вставлял — за пятёрки.
            Теперь по тем же оборотам ловит детектор. Двенадцать групп штампов.
          </p>
          <p class="aai-why-src">
            <a href="https://habr.com/ru/articles/1022906/" target="_blank" rel="noopener">Хабр · 12 групп штампов →</a>
          </p>
        </article>

        <article class="aai-why-col">
          <span class="aai-why-mark" aria-hidden="true">γ</span>
          <h3>Пунктуация и форма</h3>
          <p>
            Длинное тире, «ёлочки», буква «ё» везде. То, за что научник раньше
            ставил пятёрку. С ноября 2025 в ChatGPT отдельная настройка
            «убрать длинное тире» — потому что палит.
          </p>
          <p class="aai-why-src">
            <a href="https://techcrunch.com/2025/11/14/openai-says-its-fixed-chatgpts-em-dash-problem/" target="_blank" rel="noopener">TechCrunch · OpenAI →</a>
            <a href="https://www.cnews.ru/news/line/2025-10-14_v_rossii_poyavilsya_pervyj" target="_blank" rel="noopener">CNews · Word + Google Docs →</a>
          </p>
        </article>
      </div>
    </section>

    <!-- ═══════ III — ЧТО ДЕЛАЕМ ═══════ -->
    <section class="aai-section aai-process" id="aai-process" aria-labelledby="aai-process-h">
      <header class="aai-chapter-head">
        <span class="aai-chapter-num" aria-hidden="true">III</span>
        <div class="aai-chapter-body">
          <span class="aai-chapter-eyebrow">Что делаем · день работы</span>
          <h2 id="aai-process-h" class="aai-chapter-h">
            За день — <em class="it">без потери смысла</em>.
          </h2>
        </div>
      </header>

      <ol class="aai-steps">
        <li class="aai-step">
          <span class="aai-step-n" aria-hidden="true">I</span>
          <div class="aai-step-body">
            <h3>Получаем работу</h3>
            <p>DOC, DOCX, PDF. До 6 файлов, до 45 МБ. Можно с методичкой и требованиями кафедры — будем держать в голове.</p>
          </div>
        </li>
        <li class="aai-step">
          <span class="aai-step-n" aria-hidden="true">II</span>
          <div class="aai-step-body">
            <h3>Анализируем маркеры</h3>
            <p>Прогоняем через симулятор детектора, фиксируем места риска: длинное тире, штампы, шаблонный ритм. Получается тепловая карта по абзацам.</p>
          </div>
        </li>
        <li class="aai-step">
          <span class="aai-step-n" aria-hidden="true">III</span>
          <div class="aai-step-body">
            <h3>Чистим, сохраняя смысл</h3>
            <p>Ручная редактура: замена штампов на нейтральные обороты, разнос ритма, правка пунктуации. Терминология и структура — нетронуты.</p>
          </div>
        </li>
        <li class="aai-step">
          <span class="aai-step-n" aria-hidden="true">IV</span>
          <div class="aai-step-body">
            <h3>Отдаём + отчёт «до / после»</h3>
            <p>Итоговый файл и PDF-отчёт: что было, что стало, какие маркеры убраны. Чтобы видела результат и могла защитить логику изменений на защите.</p>
          </div>
        </li>
      </ol>
    </section>

    <!-- ═══════ IV — ЦЕНА ═══════ -->
    <section class="aai-section aai-pricing" id="aai-pricing" aria-labelledby="aai-pricing-h">
      <header class="aai-chapter-head">
        <span class="aai-chapter-num" aria-hidden="true">IV</span>
        <div class="aai-chapter-body">
          <span class="aai-chapter-eyebrow">Сколько стоит · ясно и без скидок-обманок</span>
          <h2 id="aai-pricing-h" class="aai-chapter-h">
            Цена — <em class="it">прозрачная матрица</em>.
          </h2>
        </div>
      </header>

      <div class="aai-pricing-table-wrap">
        <table class="aai-pricing-table" aria-label="Прайс «Чистка под Антиплагиат 2.0»">
          <thead>
            <tr>
              <th class="aai-pricing-corner" aria-hidden="true"></th>
              {urgencyEntries.map(([key, u]) => (
                <th scope="col">
                  <span class="th-l">{u.label}</span>
                  <span class="th-s">{u.desc}{u.multiplier !== 1 ? ` · ×${u.multiplier}` : ''}</span>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {tierEntries.map(([tierKey, t]) => (
              <tr>
                <th scope="row" class="aai-pricing-row-h">
                  <span class="rh-l">{t.label}</span>
                  <span class="rh-s">{t.pages}</span>
                </th>
                {urgencyEntries.map(([urgKey, u]) => {
                  const price = getAntiAiPrice(tierKey, urgKey);
                  if (price == null) {
                    return (
                      <td class="aai-pricing-na" aria-label="Недоступно">—</td>
                    );
                  }
                  return (
                    <td>
                      <a
                        class="aai-pricing-cell"
                        href={`/order?service=anti-ai&tier=${tierKey}&urgency=${urgKey}`}
                      >
                        {price.toLocaleString('ru-RU')} ₽
                      </a>
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="aai-pricing-note">
        Цены финальные, отчёт «до / после» включён. Оплата — после согласования объёма
        и темпа. Прочерки — комбинации, в которые мы не лезем: 80 страниц за три часа
        без потери смысла не сделать. <em class="it">Лучше честно.</em>
      </p>
    </section>

    <!-- ═══════ V — FAQ ═══════ -->
    <section class="aai-section aai-faq" id="aai-faq" aria-labelledby="aai-faq-h">
      <header class="aai-chapter-head">
        <span class="aai-chapter-num" aria-hidden="true">V</span>
        <div class="aai-chapter-body">
          <span class="aai-chapter-eyebrow">Часто спрашивают · перед заказом</span>
          <h2 id="aai-faq-h" class="aai-chapter-h">
            Самое частое — <em class="it">в одном месте</em>.
          </h2>
        </div>
      </header>

      <ul class="aai-faq-list" role="list">
        {faqItems.map((item, i) => (
          <li class="aai-faq-item">
            <details>
              <summary>
                <span class="aai-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="aai-faq-q">{item.q}</span>
                <span class="aai-faq-chev" aria-hidden="true">+</span>
              </summary>
              <div class="aai-faq-a">
                <p>{item.a}</p>
              </div>
            </details>
          </li>
        ))}
      </ul>
    </section>

    <!-- ═══════ ФИНАЛЬНЫЙ CTA ═══════ -->
    <section class="aai-section aai-finale" id="aai-finale" aria-labelledby="aai-finale-h">
      <span class="aai-finale-glyph" aria-hidden="true">⁘</span>
      <h2 id="aai-finale-h" class="aai-finale-h">
        Если устала переписывать <em class="it">по&nbsp;кругу</em>
      </h2>
      <p class="aai-finale-lede">
        Напиши в личку. Разберём твою работу за день: что палит, и как лечится без
        потери смысла. <em class="it">Всё решаемо.</em>
      </p>
      <div class="aai-finale-actions">
        <a href="/order?service=anti-ai" class="btn btn-gold btn-lg">
          Рассчитать — {entryHint}
        </a>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost-gold btn-lg">
          Telegram-личка
        </a>
      </div>
      <p class="aai-finale-tag">Академический Салон · апрель 2026</p>
    </section>

  </article>

</Base>

<style is:global>
  /* ════════════════════════════════════════════════════════════════
     /anti-ai — Editorial dark landing.
     Все цвета / шрифты / интервалы — токены из design-tokens.css.
     Префикс .aai-* чтобы не конфликтовать с другими страницами.
     ════════════════════════════════════════════════════════════════ */
  .aai {
    color: var(--cream);
    overflow-x: hidden;
  }

  /* ───────── HERO ───────── */
  .aai .aai-hero {
    position: relative;
    max-width: var(--wrap-narrow);
    margin: 0 auto;
    padding: clamp(64px, 10vw, 140px) clamp(20px, 4vw, 48px) clamp(80px, 12vw, 160px);
    display: flex;
    flex-direction: column;
    gap: clamp(24px, 3vw, 40px);
  }

  /* Eyebrow — gold rule + label */
  .aai .aai-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 0;
  }
  .aai .aai-eyebrow .rule {
    width: 28px;
    height: 1px;
    background: var(--gold-ref);
    display: inline-block;
    flex-shrink: 0;
  }
  .aai .aai-eyebrow .text {
    font-family: var(--fm);
    font-size: 11px;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--gold-ref);
  }

  /* 3-column header — ритм фактов под eyebrow */
  .aai .aai-head {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 4vw, 56px);
    border-top: 1px solid var(--line-ref);
    border-bottom: 1px solid var(--line-ref);
    padding: clamp(16px, 2vw, 22px) 0;
  }
  .aai .aai-head .col {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .aai .aai-head .lbl {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .aai .aai-head .val {
    font-family: var(--fd);
    font-weight: 400;
    font-size: clamp(20px, 2.4vw, 28px);
    line-height: 1.1;
    color: var(--cream);
    letter-spacing: -.005em;
    font-feature-settings: "tnum";
  }
  .aai .aai-head .val .it {
    font-style: italic;
    color: var(--gold-ref);
    font-feature-settings: "swsh", "dlig";
  }

  /* H1 — большой Cormorant с italic-em золотом */
  .aai .aai-h {
    font-family: var(--fd);
    font-weight: 400;
    font-size: clamp(40px, 6.5vw, 96px);
    line-height: 1;
    letter-spacing: -.025em;
    color: var(--cream);
    margin: 0;
    text-wrap: balance;
  }
  .aai .aai-h .ln,
  .aai .aai-h .ln-2 {
    display: block;
  }
  .aai .aai-h .ln-2 {
    margin-top: clamp(4px, .6vw, 10px);
  }
  .aai .aai-h em.it,
  .aai .aai-h .it {
    font-style: italic;
    color: var(--gold-ref);
    font-feature-settings: "swsh", "dlig", "liga";
    font-weight: 400;
  }

  /* Lede — italic Cormorant, узкая колонка */
  .aai .aai-lede {
    font-family: var(--fd);
