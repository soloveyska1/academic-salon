---
import Base from '../layouts/Base.astro';
import { breadcrumb } from '../lib/schema';
import {
  ANTI_AI_TIERS,
  ANTI_AI_URGENCIES,
  getAntiAiPrice,
  getAntiAiEntryHint,
} from '../lib/order-price-hint.js';

const entryHint = getAntiAiEntryHint();
const entryNumber = entryHint.replace('от ', '').replace(' ₽', '').trim();

const tierEntries = Object.entries(ANTI_AI_TIERS) as [string, typeof ANTI_AI_TIERS[keyof typeof ANTI_AI_TIERS]][];
const urgencyEntries = Object.entries(ANTI_AI_URGENCIES) as [string, typeof ANTI_AI_URGENCIES[keyof typeof ANTI_AI_URGENCIES]][];

const faqItems = [
  {
    q: 'Можно переписать самой?',
    a: 'Технически — да. Но обычно это занимает несколько дней с десятком прогонов через детектор: правишь — смотришь — правишь снова. Мы делаем тот же объём за один рабочий день и прикладываем отчёт «до / после», чтобы было видно, что именно поменяли.',
  },
  {
    q: 'А обычная уникальность не упадёт?',
    a: 'Нет. Меняем только стилистические маркеры — длинное тире, штампы, ритм. Совпадений с источниками не добавляется и не убавляется; уникальность по «Антиплагиат.ВУЗ» остаётся такой же, как была до правки.',
  },
  {
    q: 'Что входит в отчёт «до / после»?',
    a: 'PDF на 2–3 страницы: фрагменты исходного текста, рядом — что и почему мы поменяли. Покажешь научнику — увидит, что правки точечные, не рерайт чужими руками.',
  },
  {
    q: 'Можно учесть требования кафедры по стилю?',
    a: 'Да. На юриспруденции, философии и некоторых других направлениях формальные обороты — часть требований; там штампы оставим. Опиши ограничения в заявке или комментарии — учтём при редактуре.',
  },
  {
    q: 'А если не сработает — что делать?',
    a: 'Если после нашей правки «Антиплагиат 2.0» показывает больше 30% ИИ — дорабатываем бесплатно, пока не выйдем под порог. Если кафедра требует строго формальный стиль и маркеры детектора объективно не убрать — возвращаем 100% оплаты.',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Очистка академической работы от ИИ-маркеров',
  name: 'Чистка под Антиплагиат 2.0 — Академический Салон',
  description: 'Чистка академической работы под детектор «Антиплагиат 2.0»: убираем стилистические маркеры — длинное тире, типовые обороты, шаблонный синтаксис. Срок — один рабочий день, отчёт «до / после» включён в стоимость. От 2 500 ₽.',
  provider: {
    '@type': 'Organization',
    name: 'Академический Салон',
    url: 'https://bibliosaloon.ru/',
  },
  areaServed: { '@type': 'Country', name: 'Россия' },
  availableChannel: {
    '@type': 'ServiceChannel',
    serviceUrl: 'https://bibliosaloon.ru/order/?service=anti-ai',
    serviceName: 'Калькулятор и заявка',
  },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'RUB',
    price: '2500',
    description: 'Базовая ставка для эссе и рефератов до 15 страниц. Большие работы и срочность — по тарифной матрице.',
  },
};
---

<Base
  title="Чистка под Антиплагиат 2.0 — уберём следы ChatGPT | Академический Салон"
  description="«Антиплагиат 2.0» с апреля 2026 ловит работы по привычкам — длинному тире, штампам, ритму фраз. Свои тексты тоже краснеют. Уберём маркеры за день, смысл и термины не тронем. От 2 500 ₽, отчёт «до / после» в подарок."
  currentPath="/anti-ai"
  extraSchema={[
    breadcrumb([{ name: 'Чистка от ИИ', url: '/anti-ai/' }]),
    serviceLd,
    faqLd,
  ]}
>

  <article class="aai">

    <!-- ═══════ HERO ═══════ -->
    <section class="aai-hero" aria-labelledby="aai-hero-h">

      <div class="aai-eyebrow" aria-hidden="false">
        <span class="rule"></span>
        <span class="text">Антиплагиат 2.0 · апрель 2026 · пилот в 50 вузах</span>
      </div>

      <header class="aai-head">
        <div class="col">
          <span class="lbl">Срок</span>
          <span class="val">1 <i class="it">день</i></span>
        </div>
        <div class="col">
          <span class="lbl">Цена</span>
          <span class="val">{entryNumber} <i class="it">₽+</i></span>
        </div>
        <div class="col">
          <span class="lbl">Бонус</span>
          <span class="val">отчёт <i class="it">до / после</i></span>
        </div>
      </header>

      <h1 id="aai-hero-h" class="aai-h">
        <span class="ln">Уберём <em class="it">следы ChatGPT</em> —</span>
        <span class="ln-2"><em class="it">текст пройдёт защиту</em></span>
      </h1>

      <p class="aai-lede">
        «Антиплагиат 2.0» теперь читает не смысл, а <em class="it">привычки</em>:
        длинное тире, академические штампы, ритм фраз. Свои тексты тоже
        краснеют. За день уберём маркеры — смысл и термины не тронем.
        Отчёт «до / после» в подарок.
      </p>

      <div class="aai-actions">
        <a href="/order?service=anti-ai" class="btn btn-gold btn-lg">
          Рассчитать стоимость · {entryHint}
        </a>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost-gold btn-lg">
          Спросить в Telegram
        </a>
      </div>

      <a href="#aai-pain" class="aai-scroll-cue" aria-label="Читать дальше">
        <span class="lbl">как работает детектор</span>
        <span class="line" aria-hidden="true"></span>
      </a>

    </section>

    <!-- ═══════ I — НАБЛЮДЕНИЯ ═══════ -->
    <section class="aai-section aai-pain" id="aai-pain" aria-labelledby="aai-pain-h">
      <header class="aai-chapter-head">
        <span class="aai-chapter-num" aria-hidden="true">I</span>
        <div class="aai-chapter-body">
          <span class="aai-chapter-eyebrow">Что мы видим в апреле 2026</span>
          <h2 id="aai-pain-h" class="aai-chapter-h">
            Три истории <em class="it">с одной причиной</em>.
          </h2>
        </div>
      </header>

      <div class="aai-pain-quotes">
        <figure class="aai-quote">
          <blockquote>Антиплагиат 2.0 — 60% ИИ. Переписала, стало 45%. Снова красная. Так уже месяц.</blockquote>
          <figcaption>ВКР · психология · 14 апреля 2026</figcaption>
        </figure>
        <figure class="aai-quote">
          <blockquote>Защита через две недели. А я всё ещё правлю одну и ту же главу. Цвет не меняется.</blockquote>
          <figcaption>Магистратура · апрель 2026</figcaption>
        </figure>
        <figure class="aai-quote">
          <blockquote>Писала всё сама, без ChatGPT. Антиплагиат не верит.</blockquote>
          <figcaption>Из переписки в Telegram · вчера</figcaption>
        </figure>
      </div>

      <p class="aai-pain-note">
        <em class="it">Знакомая картина?</em> С апреля видим её каждый день. Причина — общая. Лечится за один день работы.
      </p>
    </section>

    <!-- ═══════ II — ЛОГИКА ДЕТЕКТОРА ═══════ -->
    <section class="aai-section aai-why" id="aai-why" aria-labelledby="aai-why-h">
      <header class="aai-chapter-head">
        <span class="aai-chapter-num" aria-hidden="true">II</span>
        <div class="aai-chapter-body">
          <span class="aai-chapter-eyebrow">Что фиксирует детектор</span>
          <h2 id="aai-why-h" class="aai-chapter-h">
            Смотрит на <em class="it">привычки</em>, не на смысл.
          </h2>
        </div>
      </header>

      <div class="aai-why-cols">
        <article class="aai-why-col">
          <span class="aai-why-mark" aria-hidden="true">I</span>
          <h3>Ритм фраз</h3>
          <p>
            GPT любит средние предложения с двумя придаточными — синтаксический
            ритм становится узнаваемым. Не зависит от темы, не зависит от
            факта генерации. По данным «Антиплагиата» — доля «ИИ-работ» за
            год выросла с&nbsp;16%&nbsp;до&nbsp;23%.
          </p>
          <p class="aai-why-src">
            <a href="https://antiplagiat.ru/news/antiplagiat2/" target="_blank" rel="noopener">Антиплагиат →</a>
            <a href="https://www.interfax.ru/russia/1052546" target="_blank" rel="noopener">Интерфакс →</a>
          </p>
        </article>

        <article class="aai-why-col">
          <span class="aai-why-mark" aria-hidden="true">II</span>
          <h3>Академические штампы</h3>
          <p>
            «Важно отметить», «в современном мире», «не просто X — а Y» — те
            же обороты, за которые научник раньше ставил пятёрку. Курс
            академического письма сам в них и натаскивал. Теперь по ним же
            ловит детектор. Двенадцать групп штампов.
          </p>
          <p class="aai-why-src">
            <a href="https://habr.com/ru/articles/1022906/" target="_blank" rel="noopener">Хабр · разбор маркеров →</a>
          </p>
        </article>

        <article class="aai-why-col">
          <span class="aai-why-mark" aria-hidden="true">III</span>
          <h3>Пунктуация и форма</h3>
          <p>
            Длинное тире, «ёлочки», буква «ё» везде. С ноября 2025 в ChatGPT
            появилась отдельная настройка — отключить длинное тире. OpenAI
            публично признал: пунктуация палит. То, за что научник раньше
            ставил пятёрку.
          </p>
          <p class="aai-why-src">
            <a href="https://techcrunch.com/2025/11/14/openai-says-its-fixed-chatgpts-em-dash-problem/" target="_blank" rel="noopener">TechCrunch · OpenAI →</a>
            <a href="https://www.cnews.ru/news/line/2025-10-14_v_rossii_poyavilsya_pervyj" target="_blank" rel="noopener">CNews · Word + Google Docs →</a>
          </p>
        </article>
      </div>
    </section>

    <!-- ═══════ III — ПРОЦЕСС ═══════ -->
    <section class="aai-section aai-process" id="aai-process" aria-labelledby="aai-process-h">
      <header class="aai-chapter-head">
        <span class="aai-chapter-num" aria-hidden="true">III</span>
        <div class="aai-chapter-body">
          <span class="aai-chapter-eyebrow">От заявки до отчёта · один день</span>
          <h2 id="aai-process-h" class="aai-chapter-h">
            Четыре шага. <em class="it">Смысл и термины не трогаем.</em>
          </h2>
        </div>
      </header>

      <ol class="aai-steps">
        <li class="aai-step">
          <span class="aai-step-n" aria-hidden="true">I</span>
          <div class="aai-step-body">
            <h3>Принимаем работу</h3>
            <p>DOC, DOCX, PDF — до 6 файлов, до 45 МБ. Прикладываешь методичку и любые рамки кафедры по стилю — учтём при редактуре.</p>
          </div>
        </li>
        <li class="aai-step">
          <span class="aai-step-n" aria-hidden="true">II</span>
          <div class="aai-step-body">
            <h3>Прогоняем через детектор</h3>
            <p>Симулятор «Антиплагиата 2.0» отмечает абзацы риска: длинное тире, штампы, шаблонный ритм. Получаем карту по разделам — где нужна точечная работа, где можно не трогать.</p>
          </div>
        </li>
        <li class="aai-step">
          <span class="aai-step-n" aria-hidden="true">III</span>
          <div class="aai-step-body">
            <h3>Чистим — руками, не GPT</h3>
            <p>Заменяем маркеры на нейтральные обороты, разнообразим ритм, чистим пунктуацию. Терминология, факты и структура — твои. Скрытого рерайта нет.</p>
          </div>
        </li>
        <li class="aai-step">
          <span class="aai-step-n" aria-hidden="true">IV</span>
          <div class="aai-step-body">
            <h3>Возвращаем + отчёт «до / после»</h3>
            <p>Готовый файл и PDF-отчёт: что было, что стало, почему. Можно показывать научнику — сразу видно, что правки точечные, не «переписали через ChatGPT в обратную сторону».</p>
          </div>
        </li>
      </ol>
    </section>

    <!-- ═══════ IV — ЦЕНА ═══════ -->
    <section class="aai-section aai-pricing" id="aai-pricing" aria-labelledby="aai-pricing-h">
      <header class="aai-chapter-head">
        <span class="aai-chapter-num" aria-hidden="true">IV</span>
        <div class="aai-chapter-body">
          <span class="aai-chapter-eyebrow">Сколько стоит · без скидок-обманок</span>
          <h2 id="aai-pricing-h" class="aai-chapter-h">
            Цена — <em class="it">по объёму и сроку</em>, без сюрпризов.
          </h2>
        </div>
      </header>

      <div class="aai-pricing-table-wrap">
        <table class="aai-pricing-table" aria-label="Прайс «Чистка под Антиплагиат 2.0»">
          <thead>
            <tr>
              <th class="aai-pricing-corner" aria-hidden="true"></th>
              {urgencyEntries.map(([key, u]) => (
                <th scope="col">
                  <span class="th-l">{u.label}</span>
                  <span class="th-s">{u.desc}{u.multiplier !== 1 ? ` · ×${u.multiplier}` : ''}</span>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {tierEntries.map(([tierKey, t]) => (
              <tr>
                <th scope="row" class="aai-pricing-row-h">
                  <span class="rh-l">{t.label}</span>
                  <span class="rh-s">{t.pages}</span>
                </th>
                {urgencyEntries.map(([urgKey, u]) => {
                  const price = getAntiAiPrice(tierKey, urgKey);
                  if (price == null) {
                    return (
                      <td class="aai-pricing-na" aria-label="Недоступно">—</td>
                    );
                  }
                  return (
                    <td>
                      <a
                        class="aai-pricing-cell"
                        href={`/order?service=anti-ai&tier=${tierKey}&urgency=${urgKey}`}
                      >
                        {price.toLocaleString('ru-RU')} ₽
                      </a>
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="aai-pricing-note">
        Цены финальные, отчёт «до / после» включён, оплата — после согласования объёма.
        Для сравнения: переписать ВКР с нуля — <em class="it">от 25 000 ₽</em>; здесь только
        чистка под детектор. Срочные тарифы ×2 и ×3 — параллельная работа двух редакторов,
        подтверждаем по текущей загрузке мастерской.
      </p>
    </section>

    <!-- ═══════ V — FAQ ═══════ -->
    <section class="aai-section aai-faq" id="aai-faq" aria-labelledby="aai-faq-h">
      <header class="aai-chapter-head">
        <span class="aai-chapter-num" aria-hidden="true">V</span>
        <div class="aai-chapter-body">
          <span class="aai-chapter-eyebrow">Перед заказом · что обычно спрашивают</span>
          <h2 id="aai-faq-h" class="aai-chapter-h">
            Пять вопросов <em class="it">по делу</em>.
          </h2>
        </div>
      </header>

      <ul class="aai-faq-list" role="list">
        {faqItems.map((item, i) => (
          <li class="aai-faq-item">
            <details>
              <summary>
                <span class="aai-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="aai-faq-q">{item.q}</span>
                <span class="aai-faq-chev" aria-hidden="true">+</span>
              </summary>
              <div class="aai-faq-a">
                <p>{item.a}</p>
              </div>
            </details>
          </li>
        ))}
      </ul>
    </section>

    <!-- ═══════ ФИНАЛЬНЫЙ CTA ═══════ -->
    <section class="aai-section aai-finale" id="aai-finale" aria-labelledby="aai-finale-h">
      <span class="aai-finale-glyph" aria-hidden="true">⁘</span>
      <h2 id="aai-finale-h" class="aai-finale-h">
        Защита через две недели? <em class="it">Успеем.</em>
      </h2>
      <p class="aai-finale-lede">
        Пересдача — это полгода и +30 000 ₽ на круг. Чистка — день и
        от 2 500. Посчитай в калькуляторе или напиши в Telegram —
        предметно разберём <em class="it">твою работу</em>, согласуем объём и срок.
      </p>
      <div class="aai-finale-actions">
        <a href="/order?service=anti-ai" class="btn btn-gold btn-lg">
          Рассчитать стоимость · {entryHint}
        </a>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost-gold btn-lg">
          Написать в Telegram
        </a>
      </div>
      <p class="aai-finale-tag">Академический Салон · мастерская с 2020</p>
    </section>

  </article>

</Base>

<style is:global>
  /* ════════════════════════════════════════════════════════════════
     /anti-ai — Editorial dark landing.
     Все цвета / шрифты / интервалы — токены из design-tokens.css.
     Префикс .aai-* чтобы не конфликтовать с другими страницами.
     ════════════════════════════════════════════════════════════════ */
  .aai {
    color: var(--cream);
    overflow-x: hidden;
  }

  /* ───────── HERO ───────── */
  .aai .aai-hero {
    position: relative;
    max-width: var(--wrap-narrow);
    margin: 0 auto;
    padding: clamp(64px, 10vw, 140px) clamp(20px, 4vw, 48px) clamp(80px, 12vw, 160px);
    display: flex;
    flex-direction: column;
    gap: clamp(24px, 3vw, 40px);
  }

  /* Eyebrow — gold rule + label */
  .aai .aai-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 0;
  }
  .aai .aai-eyebrow .rule {
    width: 28px;
    height: 1px;
    background: var(--gold-ref);
    display: inline-block;
    flex-shrink: 0;
  }
  .aai .aai-eyebrow .text {
    font-family: var(--fm);
    font-size: 11px;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--gold-ref);
  }

  /* 3-column header — ритм фактов под eyebrow */
  .aai .aai-head {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(20px, 4vw, 56px);
    border-top: 1px solid var(--line-ref);
    border-bottom: 1px solid var(--line-ref);
    padding: clamp(16px, 2vw, 22px) 0;
  }
  .aai .aai-head .col {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .aai .aai-head .lbl {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .aai .aai-head .val {
    font-family: var(--fd);
    font-weight: 400;
    font-size: clamp(20px, 2.4vw, 28px);
    line-height: 1.1;
    color: var(--cream);
    letter-spacing: -.005em;
    font-feature-settings: "tnum";
  }
  .aai .aai-head .val .it {
    font-style: italic;
    color: var(--gold-ref);
    font-feature-settings: "swsh", "dlig";
  }

  /* H1 — Cormorant с italic-em золотом, в ритме главной (.prelude-h) */
  .aai .aai-h {
    font-family: var(--fd);
    font-weight: 400;
    font-size: clamp(36px, 5.2vw, 76px);
    line-height: 1.05;
    letter-spacing: -.022em;
    color: var(--cream);
    margin: 0;
    text-wrap: balance;
  }
  .aai .aai-h .ln,
  .aai .aai-h .ln-2 {
    display: block;
  }
