---
/**
 * /compare — сравнение 2-4 работ side-by-side.
 *
 * Чтение URL ?files=a,b,c (URL-encoded), резолв против catalog.js,
 * рендер таблицы с метриками. Stats-цифры (downloads/views) тянутся
 * client-side через /api/doc-stats/batch — ничего не блокирует SSG.
 *
 * Stage 57.
 */
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

// Slim index for client-side picker; full doc lookup happens server-side
// from query string at build time would be impossible (SSG), so the
// hydration script reads location.search itself and renders.
const bySlug: Record<string, any> = {};
for (const d of D as any[]) {
  if (!d || !d.file) continue;
  bySlug[d.file] = {
    file: d.file,
    title: d.catalogTitle || d.title || d.filename || d.file,
    subject: d.subject || '',
    category: d.category || '',
    docType: d.docType || '',
    size: d.size || '',
    description: d.catalogDescription || d.description || '',
    text: d.text || '',
    filename: d.filename || '',
  };
}
---

<Base
  title="Сравнить работы — Академический Салон"
  description="Сопоставление студенческих работ из архива: тип, предмет, размер, описание — рядом, чтобы выбрать подходящую."
  currentPath="/compare"
  noindex
>

  <article class="cmp-folio">

    <nav class="cmp-crumb" aria-label="Навигация">
      <a href="/">Салон</a>
      <span class="sep" aria-hidden="true">›</span>
      <a href="/catalog">Каталог</a>
      <span class="sep" aria-hidden="true">›</span>
      <span class="current">Сравнение</span>
    </nav>

    <p class="cmp-eyebrow">
      <span class="roman" aria-hidden="true">⫶</span>
      <span>Сопоставление работ</span>
    </p>

    <h1 class="cmp-title">Сравнить <em class="it">рядом</em>.</h1>

    <p class="cmp-lede" id="cmpLede">
      Выберите 2–4 работы — мы покажем их характеристики в одной строке. Чтобы добавить работы, откройте <a href="/catalog">каталог</a> или <a href="/me">кабинет</a> и нажмите ⫶ на карточке.
    </p>

    <hr class="cmp-hairline" aria-hidden="true" />

    <!-- Picker — empty by default, runtime-populated. -->
    <div class="cmp-empty" id="cmpEmpty" hidden>
      <p class="cmp-empty-title">Пока не выбрано ни одной работы.</p>
      <p class="cmp-empty-hint">Откройте каталог, выберите интересные работы, отметьте их кнопкой ⫶ — и вернитесь сюда.</p>
      <a href="/catalog" class="btn btn-gold btn-sm">Открыть каталог</a>
    </div>

    <!-- Table — runtime-populated from URL ?files=… -->
    <div class="cmp-table-wrap" id="cmpTableWrap" hidden>
      <table class="cmp-table" id="cmpTable" aria-label="Сравнение характеристик">
        <thead></thead>
        <tbody></tbody>
      </table>

      <div class="cmp-actions">
        <button type="button" class="cmp-clear" id="cmpClear">Сбросить выбор</button>
        <a href="/catalog" class="cmp-add-more">+ добавить ещё</a>
      </div>
    </div>

  </article>

  <script is:inline define:vars={{ bySlug }}>
    window.__compareIndex = bySlug;
  </script>
  <script src="/scripts/compare-runtime.js" defer></script>

</Base>

<style is:global>
  .cmp-folio {
    max-width: 1200px;
    margin: 0 auto;
    padding: clamp(48px, 6vw, 96px) clamp(20px, 4vw, 40px) clamp(64px, 8vw, 96px);
    color: var(--t1);
  }
  .cmp-folio .cmp-crumb {
    font: 400 11px/1 var(--fm);
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--t3);
    display: flex; gap: 10px; align-items: center;
    margin-bottom: 32px;
  }
  .cmp-folio .cmp-crumb a { color: var(--t3); text-decoration: none; }
  .cmp-folio .cmp-crumb a:hover { color: var(--ac); }
  .cmp-folio .cmp-crumb .sep { color: var(--ac); opacity: .6; }
  .cmp-folio .cmp-crumb .current { color: var(--t1); }
  .cmp-folio .cmp-eyebrow {
    display: inline-flex; align-items: center; gap: 12px;
    font: 600 11px/1 var(--fm);
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ac);
    margin: 0 0 14px;
  }
  .cmp-folio .cmp-eyebrow .roman { color: var(--ac); opacity: .6; font-size: 18px; line-height: 0.7; }
  .cmp-folio .cmp-title {
    font: 400 clamp(36px, 5vw, 64px)/1.05 var(--fh);
    color: var(--t1);
    letter-spacing: -.02em;
    margin: 0 0 18px;
  }
  .cmp-folio .cmp-title em, .cmp-folio .cmp-title .it {
    font-style: italic; color: var(--ac);
  }
  .cmp-folio .cmp-lede {
    font: 400 16px/1.6 var(--fi);
    color: var(--t2);
    margin: 0 0 32px;
    max-width: 70ch;
  }
  .cmp-folio .cmp-lede a {
    color: var(--ac);
    text-decoration: underline;
    text-decoration-color: var(--ac-line);
    text-underline-offset: 4px;
  }
  .cmp-folio .cmp-hairline {
    border: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--ac-line) 20%, var(--ac-line) 80%, transparent);
    margin: 0 0 32px;
  }

  /* Empty state */
  .cmp-folio .cmp-empty {
    text-align: center;
    padding: clamp(48px, 8vw, 96px) 0;
    border: 1px dashed var(--brd);
    border-radius: 12px;
  }
  .cmp-folio .cmp-empty-title {
    font: 400 20px/1.4 var(--fd);
    color: var(--t1);
    margin: 0 0 8px;
  }
  .cmp-folio .cmp-empty-hint {
    font: 400 14px/1.5 var(--fi);
    color: var(--t3);
    max-width: 50ch;
    margin: 0 auto 24px;
  }

  /* Table */
  .cmp-folio .cmp-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .cmp-folio .cmp-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 640px;
  }
  .cmp-folio .cmp-table thead th {
    text-align: left;
    padding: 16px 18px;
    font: 400 14px/1.4 var(--fd);
    color: var(--t1);
    border-bottom: 1px solid var(--brd);
    vertical-align: top;
    width: calc(100% / var(--cols, 3));
    min-width: 180px;
  }
  .cmp-folio .cmp-table thead th.cmp-th-label {
    width: 140px;
    min-width: 140px;
    color: var(--t3);
    font: 500 11px/1.2 var(--fm);
    letter-spacing: .14em;
    text-transform: uppercase;
  }
  .cmp-folio .cmp-th-title {
    font: 400 16px/1.35 var(--fd);
    color: var(--t1);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 6px;
  }
  .cmp-folio .cmp-th-title a {
    color: var(--t1);
    text-decoration: none;
    transition: color .25s var(--ease-ios);
  }
  .cmp-folio .cmp-th-title a:hover { color: var(--ac); }
  .cmp-folio .cmp-th-rm {
    font: 400 11px/1 var(--fm);
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--t3);
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 4px 0;
    transition: color .25s var(--ease-ios);
  }
  .cmp-folio .cmp-th-rm:hover { color: var(--red, #f87171); }

  .cmp-folio .cmp-table tbody td {
    padding: 14px 18px;
    border-bottom: 1px solid var(--brd);
    font: 400 14px/1.5 var(--fi);
    color: var(--t2);
    vertical-align: top;
  }
  .cmp-folio .cmp-table tbody td.cmp-td-label {
    color: var(--t3);
    font: 500 11px/1.4 var(--fm);
    letter-spacing: .14em;
    text-transform: uppercase;
    background: rgba(212,175,55,.02);
  }
  .cmp-folio .cmp-table tbody td.cmp-td-desc {
    font: italic 400 14px/1.6 var(--fi);
    max-width: 32ch;
  }
  .cmp-folio .cmp-table tbody td .cmp-stat {
    color: var(--ac);
    font-feature-settings: "tnum";
    font-style: italic;
  }
  .cmp-folio .cmp-table tbody td .cmp-empty-cell {
    color: var(--t3);
    font-style: italic;
    opacity: .6;
  }

  .cmp-folio .cmp-actions {
    margin-top: 24px;
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }
  .cmp-folio .cmp-clear {
    font: 500 12px/1 var(--fm);
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--t3);
    background: transparent;
    border: 1px solid var(--brd);
    padding: 10px 16px;
    border-radius: 8px;
    cursor: pointer;
    transition: all .25s var(--ease-ios);
  }
  .cmp-folio .cmp-clear:hover { color: var(--ac); border-color: var(--ac-b); }
  .cmp-folio .cmp-add-more {
    font: 400 13px/1 var(--fi);
    color: var(--ac);
    text-decoration: none;
    border-bottom: 1px solid var(--ac-line);
  }
  .cmp-folio .cmp-add-more:hover { border-bottom-color: var(--ac); }

  @media (max-width: 720px) {
    .cmp-folio .cmp-table thead th { min-width: 200px; padding: 12px 14px; }
    .cmp-folio .cmp-table tbody td { padding: 12px 14px; }
  }
</style>
