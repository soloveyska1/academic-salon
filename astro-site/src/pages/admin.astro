---
import '../styles/design-tokens.css';
import '../styles/admin-console.css';

const title = 'Пульт библиотеки';
const description = 'Закрытая админка библиотеки академического салона.';
---

<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Библиотека академического салона</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow,noarchive" />
    <meta name="theme-color" content="#0c0b0d" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icon-192.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="admin-body">
    <div class="admin-app" id="adminApp">
      <aside class="admin-sidebar">
        <div class="admin-brand">
          <span class="admin-kicker">Закрытый доступ</span>
          <h1>Пульт библиотеки</h1>
          <p>Спокойный рабочий контур без терминала и ручных правок.</p>
        </div>

        <div class="admin-quicklinks">
          <a class="admin-link" href="/" target="_blank" rel="noopener" aria-label="Открыть сайт в новой вкладке">↗ сайт</a>
        </div>

        <nav class="admin-nav" aria-label="Разделы админки">
          <button class="admin-nav-btn is-active" type="button" data-tab="overview">
            <span>Обзор</span>
            <span class="nav-count" id="navCountOverview" hidden>•</span>
          </button>
          <button class="admin-nav-btn" type="button" data-tab="orders">
            <span>Заявки</span>
            <span class="nav-count" id="navCountOrders">0</span>
          </button>
          <button class="admin-nav-btn" type="button" data-tab="submissions">
            <span>Входящие</span>
            <span class="nav-count" id="navCountSubmissions">0</span>
          </button>
          <button class="admin-nav-btn" type="button" data-tab="catalog">
            <span>Каталог</span>
            <span class="nav-count" id="navCountCatalog">0</span>
          </button>
          <button class="admin-nav-btn" type="button" data-tab="upload">
            <span>Загрузить</span>
          </button>
          <button class="admin-nav-btn" type="button" data-tab="calendar">
            <span>Календарь</span>
            <span class="nav-count" id="navCountCalendar" hidden>—</span>
          </button>
        </nav>

      </aside>

      <section class="admin-shell">
        <header class="admin-header">
          <div class="admin-header-meta">
            <span class="section-kicker" id="workspaceEyebrow">Обзор</span>
            <h2 id="workspaceTitle">Пульт библиотеки</h2>
            <p id="workspaceLead">После входа откроются загрузка, модерация, каталог, заявки и системные действия.</p>
          </div>

          <div class="admin-header-actions">
            <span class="session-pill" id="adminSessionState">Не авторизованы</span>
            <span class="admin-sync" id="adminLastSync">Ещё не обновляли</span>
            <button class="ghost-btn" id="adminRefreshBtn" type="button" hidden>Обновить</button>
            <button class="ghost-btn" id="adminLogoutBtn" type="button" hidden>Выйти</button>
          </div>
        </header>

        <section class="auth-card" id="adminAuthCard">
          <div class="surface-head">
            <div>
              <span class="auth-kicker">Вход</span>
              <h3>Открыть пульт</h3>
              <p>Один пароль, дальше вся работа идёт внутри понятных экранов.</p>
            </div>
          </div>

          <form id="adminLoginForm" class="panel-stack">
            <label class="field field--full">
              <span>Пароль администратора</span>
              <input id="adminPassword" type="password" autocomplete="current-password" placeholder="Введите пароль" />
            </label>

            <div class="button-row">
              <button class="primary-btn" id="adminLoginBtn" type="submit">Войти</button>
            </div>
            <p class="helper-text" id="adminLoginError"></p>
          </form>
        </section>

        <section id="adminWorkspace" hidden>
          <div class="panel-stack">
            <!-- Compact quick-search bar (only when typing or explicitly focused) -->
            <section class="quick-search" aria-label="Поиск">
              <input
                id="commandSearch"
                type="search"
                autocomplete="off"
                placeholder="Поиск по заявкам, документам, темам…"
              />
              <div class="command-results" id="commandResults" hidden></div>
            </section>

            <section class="panel" data-panel="overview">
              <!-- 4 big numbers — readable at arm's length -->
              <div class="hero-tiles" id="overviewHeroTiles"></div>

              <!-- 3 primary actions — one click = one task -->
              <div class="action-cards">
                <button class="action-card" type="button" data-open-tab="orders">
                  <span class="action-card-kicker">Заявки</span>
                  <strong id="actionCardOrders">—</strong>
                  <span class="action-card-hint">Ответить клиентам</span>
                </button>
                <button class="action-card" type="button" data-open-tab="submissions">
                  <span class="action-card-kicker">Входящие работы</span>
                  <strong id="actionCardSubmissions">—</strong>
                  <span class="action-card-hint">Опубликовать или отклонить</span>
                </button>
                <button class="action-card" type="button" data-open-tab="upload">
                  <span class="action-card-kicker">Каталог</span>
                  <strong>Добавить</strong>
                  <span class="action-card-hint">Новый документ вручную</span>
                </button>
              </div>

              <!-- Two columns: what needs attention | recent activity -->
              <div class="overview-split">
                <article class="overview-col">
                  <header class="overview-col-head">
                    <h3>Требует внимания</h3>
                    <span class="overview-col-note" id="overviewAttentionCount">—</span>
                  </header>
                  <div class="overview-list" id="overviewAttention"></div>
                </article>

                <article class="overview-col">
                  <header class="overview-col-head">
                    <h3>Свежие заявки</h3>
                    <a class="overview-col-link" href="#" data-open-tab="orders">все заявки →</a>
                  </header>
                  <div class="overview-list" id="overviewRecentOrders"></div>
                </article>
              </div>
            </section>

            <section class="panel" data-panel="upload" hidden>
              <div class="panel-grid panel-grid--main">
                <article class="surface">
                  <div class="surface-head">
                    <div>
                      <span class="surface-kicker">Новая работа</span>
                      <h3>Добавить документ в каталог</h3>
                    </div>
                  </div>

                  <form id="adminUploadForm" class="panel-stack">
                    <label class="dropzone" id="adminDropzone">
                      <input id="adminUploadFile" type="file" />
                      <span class="dropzone-title">Перетащите файл сюда или выберите вручную</span>
                      <span class="dropzone-note">Поддерживаются DOCX, PDF, DOC, PPTX, XLSX, ODT, TXT. Размер до 50 МБ.</span>
                    </label>

                    <div class="file-pill" id="adminUploadFileInfo">Файл ещё не выбран</div>

                    <div class="field-grid">
                      <label class="field field--full">
                        <span>Название карточки</span>
                        <input id="uploadTitle" type="text" placeholder="Как документ будет называться в каталоге" />
                      </label>

                      <label class="field field--full">
                        <span>Описание</span>
                        <textarea id="uploadDescription" rows="4" placeholder="Коротко: что это за работа и кому пригодится"></textarea>
                      </label>

                      <label class="field">
                        <span>Категория</span>
                        <input id="uploadCategory" type="text" list="categoryOptions" placeholder="Например, Курсовые" />
                      </label>

                      <label class="field">
                        <span>Предмет</span>
                        <input id="uploadSubject" type="text" list="subjectOptions" placeholder="Например, Социальная работа" />
                      </label>

                      <label class="field">
                        <span>Курс</span>
                        <input id="uploadCourse" type="text" list="courseOptions" placeholder="Например, 3 курс" />
                      </label>

                      <label class="field">
                        <span>Тип документа</span>
                        <input id="uploadDocType" type="text" list="docTypeOptions" placeholder="Например, Реферат" />
                      </label>

                      <label class="field field--full">
                        <span>Теги через запятую</span>
                        <input id="uploadTags" type="text" placeholder="Психология, семья, конфликтология" />
                      </label>
                    </div>

                    <div class="button-row">
                      <button class="primary-btn" id="uploadSubmitBtn" type="submit">Загрузить в каталог</button>
                      <div class="progress-bar" id="uploadProgress" hidden><span id="uploadProgressFill"></span></div>
                    </div>
                    <p class="helper-text" id="uploadStatus">После загрузки документ сразу попадёт в живой каталог.</p>
                  </form>
                </article>

                <article class="surface surface--compact">
                  <div class="surface-head">
                    <div>
                      <span class="surface-kicker">Предпросмотр</span>
                      <h3>Как работа появится в каталоге</h3>
                    </div>
                  </div>
                  <div class="preview-card" id="uploadSmartPreview">
                    <strong>Выберите файл, и здесь появится живая карточка.</strong>
                    <p>Название, категория и тип можно сразу поправить до загрузки.</p>
                  </div>

                  <div class="panel-stack">
                    <div class="quick-picks">
                      <div>
                        <span class="field-heading">Частые категории</span>
                        <div class="chip-actions" id="uploadCategoryPicks"></div>
                      </div>
                    </div>

                    <div class="quick-picks">
                      <div>
                        <span class="field-heading">Частые предметы</span>
                        <div class="chip-actions" id="uploadSubjectPicks"></div>
                      </div>
                    </div>

                    <div class="quick-picks">
                      <div>
                        <span class="field-heading">Частые типы</span>
                        <div class="chip-actions" id="uploadDocTypePicks"></div>
                      </div>
                    </div>
                  </div>
                </article>
              </div>
            </section>

            <section class="panel" data-panel="submissions" hidden>
              <div class="panel-grid panel-grid--main">
                <article class="surface list-panel">
                  <div class="surface-head">
                    <div>
                      <span class="surface-kicker">Очередь</span>
                      <h3>Входящие работы</h3>
                    </div>
                  </div>
                  <div class="list-toolbar">
                    <input id="submissionSearch" type="search" placeholder="Поиск по названию, контакту, предмету" />
                    <select id="submissionStatusFilter">
                      <option value="all">Все статусы</option>
                      <option value="new">Новые</option>
                      <option value="priority">Приоритет</option>
                      <option value="approved">Опубликованы</option>
                      <option value="rejected">Отклонены</option>
                      <option value="archived">Архив</option>
                    </select>
                  </div>
                  <div class="queue-strip" id="submissionQueueBar"></div>
                  <div class="stack-list" id="submissionList"></div>
                </article>

                <article class="surface detail-panel">
                  <div class="surface-head">
                    <div>
                      <span class="surface-kicker">Карточка</span>
                      <h3>Разбор работы</h3>
                    </div>
                  </div>
                  <div class="empty-state" id="submissionEmpty">Выберите работу слева. Здесь появятся файлы, заметка и публикация в каталог.</div>
                  <div id="submissionDetail" hidden></div>
                </article>
              </div>
            </section>

            <section class="panel" data-panel="catalog" hidden>
              <div class="panel-grid panel-grid--main">
                <article class="surface list-panel">
                  <div class="surface-head">
                    <div>
                      <span class="surface-kicker">Каталог</span>
                      <h3>Опубликованные документы</h3>
                    </div>
                  </div>
                  <div class="list-toolbar">
                    <input id="catalogSearch" type="search" placeholder="Поиск по названию, предмету, категории" />
                    <select id="catalogQuickFilter">
                      <option value="all">Все документы</option>
                      <option value="popular">Популярные</option>
                      <option value="recent">Недавно добавленные</option>
                    </select>
                  </div>
                  <div class="queue-strip" id="catalogQueueBar"></div>
                  <div class="stack-list" id="catalogList"></div>
                </article>

                <article class="surface detail-panel">
                  <div class="surface-head">
                    <div>
                      <span class="surface-kicker">Редактор</span>
                      <h3>Карточка документа</h3>
                    </div>
                    <div class="surface-head-actions">
                      <a class="ghost-btn" id="catalogOpenBtn" href="/catalog" target="_blank" rel="noopener">Открыть публично</a>
                    </div>
                  </div>
                  <div class="empty-state" id="catalogEmpty">Выберите документ слева, чтобы изменить карточку или удалить его из каталога.</div>
                  <form id="catalogEditor" hidden class="panel-stack">
                    <div class="field-grid">
                      <label class="field field--full">
                        <span>Название</span>
                        <input id="catalogTitle" type="text" />
                      </label>

                      <label class="field field--full">
                        <span>Описание</span>
                        <textarea id="catalogDescription" rows="5"></textarea>
                      </label>

                      <label class="field">
                        <span>Категория</span>
                        <input id="catalogCategory" type="text" list="categoryOptions" />
                      </label>

                      <label class="field">
                        <span>Предмет</span>
                        <input id="catalogSubject" type="text" list="subjectOptions" />
                      </label>

                      <label class="field">
                        <span>Курс</span>
                        <input id="catalogCourse" type="text" list="courseOptions" />
                      </label>

                      <label class="field">
                        <span>Тип документа</span>
                        <input id="catalogDocType" type="text" list="docTypeOptions" />
                      </label>

                      <label class="field field--full">
                        <span>Теги через запятую</span>
                        <input id="catalogTags" type="text" />
                      </label>
                    </div>

                    <div class="editor-meta" id="catalogMeta"></div>

                    <div class="button-row">
                      <button class="primary-btn" id="catalogSaveBtn" type="submit">Сохранить</button>
                      <button class="ghost-btn ghost-btn--danger" id="catalogDeleteBtn" type="button">Удалить</button>
                    </div>
                    <p class="helper-text" id="catalogStatus"></p>
                  </form>
                </article>
              </div>
            </section>

            <section class="panel" data-panel="orders" hidden>
              <div class="panel-grid panel-grid--main">
                <article class="surface list-panel orders-list-panel">
                  <div class="list-toolbar">
                    <input id="orderSearch" type="search" placeholder="Поиск: контакт, тема, предмет" />
                  </div>
                  <div class="status-pills" id="orderStatusPills" role="tablist" aria-label="Фильтр по статусу"></div>
                  <select id="orderStatusFilter" hidden>
                    <option value="all">Все статусы</option>
                    <option value="open">Открытые</option>
                    <option value="new">Новые</option>
                    <option value="priority">Приоритет</option>
                    <option value="in_work">В работе</option>
                    <option value="waiting_client">Ждём клиента</option>
                    <option value="done">Завершены</option>
                    <option value="archived">Архив</option>
                  </select>
                  <div class="queue-strip" id="orderQueueBar" hidden></div>
                  <div class="stack-list" id="orderList"></div>
                </article>

                <article class="surface detail-panel orders-detail-panel">
                  <div class="empty-state" id="orderEmpty">Выберите заявку слева — увидите кто написал, откуда пришёл и что просит.</div>
                  <form id="orderEditor" hidden class="panel-stack orders-detail-form">
                    <div class="detail-top" id="orderSummary"></div>

                    <div class="client-history" id="orderClientHistory" hidden></div>

                    <div class="order-context" id="orderContext" hidden></div>

                    <section class="order-actions" aria-label="Действия по заявке">
                      <div class="status-pills" id="orderStatusPillsDetail" role="tablist" aria-label="Статус заявки"></div>

                      <details class="order-note-block" id="orderNoteBlock">
                        <summary>
                          <span>Внутренняя заметка</span>
                          <span class="order-note-hint" id="orderNoteHint">пусто</span>
                        </summary>
                        <label class="field field--full">
                          <textarea id="orderNote" rows="3" placeholder="Например: ждёт вечером, нужен созвон"></textarea>
                        </label>
                        <div class="button-row">
                          <button class="ghost-btn" id="orderSaveBtn" type="submit">Сохранить заметку</button>
                        </div>
                        <p class="helper-text" id="orderStatusNote"></p>
                      </details>

                      <details class="order-response-block" id="orderResponseBlock">
                        <summary>
                          <span>Ответ клиенту</span>
                          <span class="order-response-hint" id="orderResponseHint">не отправлялся</span>
                        </summary>
                        <p class="detail-section-note">Уйдёт в канал заявки. Внутренняя заметка НЕ отправляется.</p>
                        <label class="field field--full">
                          <textarea id="orderResponse" rows="4" placeholder="Напишите что узнали. Например: «Разбираем, завтра пришлём оценку»"></textarea>
                        </label>
                        <div class="field-grid">
                          <label class="field">
                            <span>Канал</span>
                            <select id="orderResponseChannel">
                              <option value="auto">Тот, через который пришёл</option>
                              <option value="telegram">Telegram</option>
                              <option value="vk">ВКонтакте</option>
                              <option value="email">Email</option>
                            </select>
                          </label>
                        </div>
                        <div class="button-row">
                          <button class="primary-btn" id="orderSendBtn" type="button" disabled>Отправить</button>
                          <button class="ghost-btn" id="orderCopyResponseBtn" type="button">Скопировать текст</button>
                        </div>
                        <p class="helper-text" id="orderResponseNote"></p>
                      </details>

                      <div class="order-status-select" hidden>
                        <label class="field">
                          <span>Статус</span>
                          <select id="orderStatus"></select>
                        </label>
                      </div>
                    </section>

                    <details class="order-files-block" id="orderFilesBlock" hidden>
                      <summary>
                        <span>Файлы клиента</span>
                        <span class="order-files-hint" id="orderFilesHint">—</span>
                      </summary>
                      <div class="attachment-list" id="orderAttachments"></div>
                    </details>
                  </form>
                </article>
              </div>
            </section>

            <section class="panel" data-panel="calendar" hidden>
              <div class="metric-strip" id="calendarMetrics"></div>

              <article class="surface">
                <div class="surface-head">
                  <div>
                    <span class="surface-kicker">Публичный календарь</span>
                    <h3>Загрузка на главной</h3>
                    <p>Клик по дню переключает состояние: <b>свободно → плотно → занято → прошёл → свободно</b>. Изменения сразу видны на <a href="/#calendar">главной</a>.</p>
                  </div>
                  <div class="surface-head-actions">
                    <button class="ghost-btn" type="button" id="adminCalPrev">←</button>
                    <span id="adminCalMonthLabel" style="min-width: 140px; text-align: center; font-weight: 500;">—</span>
                    <button class="ghost-btn" type="button" id="adminCalNext">→</button>
                    <button class="ghost-btn" type="button" id="adminCalReset" title="Сбросить всё на декоративный дефолт">Сбросить</button>
                  </div>
                </div>

                <div class="admin-cal-legend">
                  <span><span class="dot free"></span>свободно</span>
                  <span><span class="dot tight"></span>плотно</span>
                  <span><span class="dot busy"></span>занято</span>
                  <span><span class="dot closed"></span>прошёл</span>
                </div>

                <div class="admin-cal-weekdays">
                  <span>пн</span><span>вт</span><span>ср</span><span>чт</span><span>пт</span><span>сб</span><span>вс</span>
                </div>
                <div class="admin-cal-grid" id="adminCalGrid" role="grid"></div>

                <div class="admin-cal-foot">
                  <span id="adminCalSavedCount">Сохранено 0 дней</span>
                  <span id="adminCalSyncState">Черновик на этом устройстве · сервер пока без поддержки</span>
                </div>
              </article>
            </section>

          </div>
        </section>
      </section>

      <datalist id="categoryOptions"></datalist>
      <datalist id="subjectOptions"></datalist>
      <datalist id="courseOptions"></datalist>
      <datalist id="docTypeOptions"></datalist>
    </div>

    <div class="toast-stack" id="adminToasts"></div>
    <script type="module" src="/admin-app.js"></script>
  </body>
</html>
