<script is:inline define:vars={{ bySlug }}>
(function() {
  var app = window.academicSalon || {};
  var showToast = app.showToast || function() {};
  var track = app.track || function() {};

  /* ══════ 0. SESSION BOOTSTRAP ══════ */
  var authSection = document.getElementById('meAuthSection');
  var cabinet = document.getElementById('meCabinet');
  var contactBadge = document.getElementById('meCabinetContact');
  var ordersList = document.getElementById('meOrders');
  var ordersEmpty = document.getElementById('meOrdersEmpty');
  var ordersLoading = document.getElementById('meOrdersLoading');
  var logoutBtn = document.getElementById('meLogoutBtn');

  function showCabinet(profile) {
    if (cabinet) cabinet.hidden = false;
    if (authSection) authSection.hidden = true;
    var intro = document.getElementById('meIntro');
    if (intro) intro.hidden = true;
    if (contactBadge) contactBadge.textContent = profile.contact || '—';

    // Populate settings block
    var acctContact = document.getElementById('meAcctContact');
    var acctChannel = document.getElementById('meAcctChannel');
    if (acctContact) acctContact.textContent = profile.contact || '—';
    if (acctChannel) {
      var ch = profile.channel || 'email';
      var label = { telegram: 'Telegram', email: 'Email', vk: 'ВКонтакте' }[ch] || ch;
      acctChannel.textContent = label;
    }

    // Show the mobile FAB (CSS handles visibility per breakpoint)
    var fab = document.getElementById('meFab');
    if (fab) fab.hidden = false;

    // Hide the localStorage-only "Сохранённые работы" panel — server-side
    // favourites in the cabinet supersede it for signed-in users.
    var localFavsSection = document.querySelector('section[aria-label="Сохранённые работы"]');
    if (localFavsSection) localFavsSection.hidden = true;
    var hr1 = localFavsSection && localFavsSection.previousElementSibling;
    if (hr1 && hr1.classList && hr1.classList.contains('me-hairline')) hr1.hidden = true;

    loadOrders();
    syncFavoritesWithServer();
  }

  function setStat(id, value) {
    var el = document.getElementById(id);
    if (el) el.textContent = String(value);
  }
  function formatSinceDate(epoch) {
    if (!epoch) return 'сегодня';
    var d = new Date(epoch * 1000);
    var now = Date.now();
    var diffDays = Math.floor((now - d.getTime()) / 86400000);
    if (diffDays < 1) return 'сегодня';
    if (diffDays < 30) return diffDays + ' дн.';
    return d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short', year: '2-digit' });
  }

  /* On first sign-in we push whatever's in localStorage 'favorites' to
     the server (idempotent merge), then refresh the cabinet list from
     the server's view. Subsequent visits are just a fetch. */
  function syncFavoritesWithServer() {
    var local = [];
    try { local = JSON.parse(localStorage.getItem('favorites') || '[]') || []; } catch (_) {}
    if (Array.isArray(local) && local.length) {
      fetch('/api/me/favorites', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ files: local }),
      })
        .catch(function() {})
        .finally(loadFavs);
    } else {
      loadFavs();
    }
  }

  function loadFavs() {
    var listEl = document.getElementById('meFavs');
    var emptyEl = document.getElementById('meFavsEmpty');
    var loadingEl = document.getElementById('meFavsLoading');
    if (!listEl || !emptyEl || !loadingEl) return;
    loadingEl.hidden = false;
    listEl.hidden = true;
    emptyEl.hidden = true;

    fetch('/api/me/favorites', { credentials: 'same-origin', cache: 'no-store' })
      .then(function(r) { return r.ok ? r.json() : { ok: false, favorites: [] }; })
      .then(function(data) {
        loadingEl.hidden = true;
        var items = (data && data.favorites) || [];
        setStat('meStatFavs', items.length);
        if (!items.length) { emptyEl.hidden = false; return; }

        // Mirror the server list back into localStorage so the catalog
        // page can immediately reflect cross-device changes too.
        try {
          var asArr = items.map(function(it) { return it.file; });
          localStorage.setItem('favorites', JSON.stringify(asArr));
        } catch (_) {}

        listEl.innerHTML = items.map(function(it) {
          var meta = bySlug && bySlug[it.file];
          var title = (meta && (meta.catalogTitle || meta.title || meta.filename)) || it.file;
          var docType = meta && meta.docType ? escHtml(meta.docType) : '';
          var subject = meta && meta.subject ? escHtml(meta.subject) : '';
          var size = meta && meta.size ? escHtml(meta.size) : '';
          var added = it.added_at
            ? new Date(it.added_at * 1000).toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' })
            : '';
          var metaLine = [docType, subject].filter(Boolean).join(' · ');
          var docHref = '/doc/' + encodeURI(it.file);
          return '<li class="me-fav-card">' +
                 '<a class="me-fav-card-link" href="' + docHref + '">' +
                   '<h4 class="me-fav-card-title">' + escHtml(title) + '</h4>' +
                   (metaLine ? '<p class="me-fav-card-meta">' + metaLine + '</p>' : '') +
                 '</a>' +
                 '<div class="me-fav-card-foot">' +
                   '<span class="me-fav-card-when">' + (size ? size + ' · ' : '') + (added ? 'добавлено ' + added : '') + '</span>' +
                   '<button type="button" class="me-fav-rm" data-file="' + encodeURIComponent(it.file) + '" aria-label="Убрать из сохранённых">✕</button>' +
                 '</div>' +
                 '</li>';
        }).join('');
        listEl.hidden = false;
      })
      .catch(function() { loadingEl.hidden = true; });
  }

  // Delegated remove handler for the cabinet favourites list.
  document.addEventListener('click', function(e) {
    var btn = e.target && e.target.closest && e.target.closest('.me-fav-rm');
    if (!btn) return;
    var file = decodeURIComponent(btn.getAttribute('data-file') || '');
    if (!file) return;
    fetch('/api/me/favorites', {
      method: 'DELETE',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ file: file }),
    })
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function() {
        // Also drop from localStorage so other tabs / catalog pick it up.
        try {
          var local = JSON.parse(localStorage.getItem('favorites') || '[]') || [];
          local = local.filter(function(f) { return f !== file; });
          localStorage.setItem('favorites', JSON.stringify(local));
        } catch (_) {}
        loadFavs();
      });
  });

  function bootVkButton() {
    var btn = document.getElementById('meVkBtn');
    if (!btn) return;
    fetch('/api/me/vk-config', { credentials: 'same-origin', cache: 'no-store' })
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(cfg) {
        if (cfg && cfg.enabled) {
          btn.hidden = false;
          var wrap = document.getElementById('meTgWrap');
          if (wrap) wrap.hidden = false;
        }
      })
      .catch(function() {});
  }

  function showAuth() {
    if (cabinet) cabinet.hidden = true;
    if (authSection) authSection.hidden = false;
    bootTelegramWidget();
    bootVkButton();
  }

  /* Telegram Login Widget — fetched lazily, only when the auth screen
     is shown (i.e. user isn't already signed in). The widget itself is
     a third-party iframe; we expose `onTelegramAuth` on window so the
     widget's data-onauth callback can find it. */
  var tgWidgetBooted = false;
  function bootTelegramWidget() {
    if (tgWidgetBooted) return;
    tgWidgetBooted = true;
    fetch('/api/me/telegram-config', { credentials: 'same-origin', cache: 'no-store' })
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(cfg) {
        if (!cfg || !cfg.enabled || !cfg.botUsername) return;
        var wrap = document.getElementById('meTgWrap');
        var slot = document.getElementById('meTgWidget');
        if (!wrap || !slot) return;
        var script = document.createElement('script');
        script.async = true;
        script.src = 'https://telegram.org/js/telegram-widget.js?22';
        script.setAttribute('data-telegram-login', cfg.botUsername);
        script.setAttribute('data-size', 'large');
        script.setAttribute('data-radius', '12');
        script.setAttribute('data-userpic', 'false');
        script.setAttribute('data-request-access', 'write');
        script.setAttribute('data-onauth', 'onTelegramAuth(user)');
        slot.appendChild(script);
        wrap.hidden = false;
        // If Telegram doesn't manage to mount its iframe within 5s
        // (most often: domain not yet registered via /setdomain in
        // BotFather), surface a soft fallback so the empty box doesn't
        // look broken.
        window.setTimeout(function() {
          var iframe = slot.querySelector('iframe');
          if (iframe) return;
          var fallback = document.getElementById('meTgFallback');
          if (fallback) fallback.hidden = false;
        }, 5000);
      })
      .catch(function() {});
  }

  // Global handler the Telegram widget calls back into.
  window.onTelegramAuth = function(user) {
    fetch('/api/me/telegram-login', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(user),
    })
      .then(function(r) { return r.ok ? r.json() : { ok: false }; })
      .then(function(data) {
        if (data && data.ok) {
          showToast('Вы вошли через Telegram.', 'success', 3000);
          // Reload so the cabinet renders with the fresh whoami.
          window.location.replace('/me?ok=1');
        } else {
          showToast('Не удалось войти через Telegram. Попробуйте по почте.', 'error', 4500);
        }
      })
      .catch(function() {
        showToast('Связь с сервером прервалась. Попробуйте ещё раз.', 'error', 4500);
      });
  };

  // Map raw status → human label + timeline step (0/1/2).
  // Step 0 = «Принята», 1 = «В работе», 2 = «Готова».
  var STATUS_META = {
    'new':         { lbl: 'Принята',   step: 0, active: true  },
    'in_work':     { lbl: 'В работе',  step: 1, active: true  },
    'in_progress': { lbl: 'В работе',  step: 1, active: true  },
    'done':        { lbl: 'Готова',    step: 2, active: false },
    'completed':   { lbl: 'Готова',    step: 2, active: false },
    'cancelled':   { lbl: 'Отменена',  step: -1, active: false },
    'rejected':    { lbl: 'Отклонена', step: -1, active: false },
  };

  function escHtml(s) { return String(s == null ? '' : s).replace(/[<>&"]/g, function(c) {
    return ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'})[c]; }); }

  function renderActiveOrderCard(o) {
    var meta = STATUS_META[o.status] || STATUS_META['new'];
    var step = meta.step >= 0 ? meta.step : 0;
    var when = new Date((o.created_at || 0) * 1000)
      .toLocaleDateString('ru-RU', { day: 'numeric', month: 'short', year: 'numeric' });
    var topic = escHtml(o.topic || o.work_type || 'Заявка');
    var workType = escHtml(o.work_type || '');
    var subject = escHtml(o.subject || '');
    var deadline = o.deadline ? escHtml(o.deadline) : '';

    var tlSteps = ['Принята', 'В работе', 'Готова'].map(function(label, i) {
      var cls = i < step ? 'me-tl-step me-tl-done'
              : i === step ? 'me-tl-step me-tl-current'
              : 'me-tl-step';
      return '<div class="' + cls + '">' +
             '<span class="me-tl-dot" aria-hidden="true"></span>' +
             '<span class="me-tl-lbl">' + label + '</span>' +
             '</div>';
    }).join('<div class="me-tl-bar" aria-hidden="true"></div>');

    var tgText = encodeURIComponent(
      'Здравствуйте! У меня вопрос по заявке № ' + (o.id || '?') +
      ' от ' + when + ' (' + topic + '): '
    );
    var tgHref = 'https://t.me/academicsaloon?text=' + tgText;

    var repeatQs = [
      o.work_type ? 'type=' + encodeURIComponent(o.work_type) : '',
      o.subject   ? 'subject=' + encodeURIComponent(o.subject) : '',
      o.topic     ? 'topic=' + encodeURIComponent(o.topic) : '',
    ].filter(Boolean).join('&');
    var repeatHref = '/order' + (repeatQs ? '?' + repeatQs : '');

    var metaLine = [
      o.id ? 'Заявка №' + escHtml(o.id) : '',
      'от ' + when,
      workType,
      subject,
      deadline ? 'дедлайн ' + deadline : '',
    ].filter(Boolean).join(' · ');

    return '<article class="me-active">' +
      '<header class="me-active-head">' +
        '<span class="me-active-eyebrow">' + meta.lbl + '</span>' +
        '<h3 class="me-active-topic">' + topic + '</h3>' +
        '<p class="me-active-meta">' + metaLine + '</p>' +
      '</header>' +
      '<div class="me-active-timeline" aria-label="Статус заявки">' + tlSteps + '</div>' +
      '<div class="me-active-foot">' +
        '<a href="' + tgHref + '" class="btn btn-gold btn-sm" target="_blank" rel="noopener">Написать по&nbsp;заказу</a>' +
        '<a href="' + repeatHref + '" class="me-link-btn">Повторить заказ</a>' +
      '</div>' +
    '</article>';
  }

  function renderHistoryRow(o) {
    var when = new Date((o.created_at || 0) * 1000)
      .toLocaleDateString('ru-RU', { day: 'numeric', month: 'short', year: 'numeric' });
    var topic = escHtml(o.topic || o.work_type || 'Заявка');
    var meta = STATUS_META[o.status] || { lbl: o.status || 'new', step: -1 };
    var statusClass = (o.status || 'new').replace(/[^a-z_]/g, '');

    var repeatQs = [
      o.work_type ? 'type=' + encodeURIComponent(o.work_type) : '',
      o.subject   ? 'subject=' + encodeURIComponent(o.subject) : '',
      o.topic     ? 'topic=' + encodeURIComponent(o.topic) : '',
    ].filter(Boolean).join('&');
    var repeatHref = '/order' + (repeatQs ? '?' + repeatQs : '');

    return '<li class="me-order">' +
           '<span class="me-order-when">' + when + '</span>' +
           '<span class="me-order-topic">' + topic + '</span>' +
           '<span class="me-order-status me-order-status--' + statusClass + '">' + escHtml(meta.lbl) + '</span>' +
           '<a class="me-order-repeat" href="' + repeatHref + '" aria-label="Повторить заказ">↻</a>' +
           '</li>';
  }

  function loadOrders() {
    if (!ordersList || !ordersEmpty || !ordersLoading) return;
    ordersLoading.hidden = false;
    ordersList.hidden = true;
    ordersEmpty.hidden = true;
    var activeBox = document.getElementById('meActiveOrders');
    if (activeBox) { activeBox.hidden = true; activeBox.innerHTML = ''; }

    fetch('/api/me/orders', { credentials: 'same-origin' })
      .then(function(r) { return r.ok ? r.json() : { ok: false, orders: [] }; })
      .then(function(data) {
        ordersLoading.hidden = true;
        var items = (data && data.orders) || [];
        setStat('meStatOrders', items.length);

        // Earliest order date → "with us since".
        var earliest = items.reduce(function(m, o) {
          var t = o && o.created_at;
          return (t && (!m || t < m)) ? t : m;
        }, 0);
        setStat('meStatSince', formatSinceDate(earliest));

        // Split active vs everything else.
        var active = [];
        var history = [];
        items.forEach(function(o) {
          var meta = STATUS_META[o.status] || STATUS_META['new'];
          (meta.active ? active : history).push(o);
        });

        // Active orders rise to the top as hero cards (most recent first).
        if (active.length && activeBox) {
          activeBox.innerHTML = active
            .slice()
            .sort(function(a, b) { return (b.created_at || 0) - (a.created_at || 0); })
            .map(renderActiveOrderCard)
            .join('');
          activeBox.hidden = false;
        }

        // History: compact rows. If there's no history but there ARE
        // active orders, suppress the empty state — it would feel
        // contradictory next to a giant active card above.
        if (!history.length) {
          if (!active.length) ordersEmpty.hidden = false;
          return;
        }
        ordersList.innerHTML = history.map(renderHistoryRow).join('');
        ordersList.hidden = false;
      })
      .catch(function() {
        ordersLoading.hidden = true;
      });
  }

  /* Surface ?err= or ?ok= flags from /api/me/verify redirects. */
  (function flashUrlMessages() {
    var params = new URLSearchParams(window.location.search);
    var err = params.get('err');
    var ok = params.get('ok');
    if (err) {
      var copy = {
        token:        'Ссылка повреждена. Запросите новую.',
        unknown:      'Эта ссылка не найдена. Возможно, она уже устарела.',
        used:         'Эта ссылка уже использована. Запросите новую.',
        expired:      'Срок действия ссылки истёк. Запросите новую.',
        vk_state:     'Сессия входа через ВКонтакте устарела. Попробуйте ещё раз.',
        vk_token:     'ВКонтакте не вернул токен. Попробуйте ещё раз.',
        vk_config:    'Вход через ВКонтакте временно недоступен.',
        vk_session:   'Не удалось создать сессию. Попробуйте ещё раз.',
      }[err] || 'Не удалось войти. Попробуйте ещё раз.';
      showToast(copy, 'error', 4500);
    } else if (ok === '1') {
      showToast('Вы вошли в кабинет.', 'success', 3000);
    }
    if (err || ok) {
      var clean = window.location.pathname + window.location.hash;
      window.history.replaceState({}, '', clean);
    }
  })();

  /* Initial whoami check — hides the form if already signed in. */
  fetch('/api/me/whoami', { credentials: 'same-origin', cache: 'no-store' })
    .then(function(r) { return r.ok ? r.json() : { loggedIn: false }; })
    .then(function(data) {
      if (data && data.loggedIn) showCabinet(data);
      else showAuth();
    })
    .catch(function() { showAuth(); });

  if (logoutBtn) {
    logoutBtn.addEventListener('click', function() {
      fetch('/api/me/logout', { method: 'POST', credentials: 'same-origin' })
        .finally(function() { window.location.reload(); });
    });
  }

  /* ══════ 1. MAGIC-LINK FORM ══════ */
  var form = document.getElementById('meForm');
  var input = document.getElementById('meContact');
  var submit = document.getElementById('meSubmit');
  var status = document.getElementById('meStatus');

  function setStatus(msg, kind) {
    status.textContent = msg;
    status.className = 'me-form-status ' + (kind ? 'is-' + kind : '');
    status.hidden = !msg;
  }

  function detectChannel(value) {
    var v = (value || '').trim();
    if (!v) return null;
    if (/^@?[a-zA-Z0-9_]{4,32}$/.test(v)) return 'telegram';
    if (/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) return 'email';
    return null;
  }

  if (form && input && submit) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var contact = input.value.trim();
      var channel = detectChannel(contact);
      if (!channel) {
        setStatus('Укажите Telegram (через @) или email.', 'error');
        input.focus();
        return;
      }
      submit.setAttribute('aria-busy', 'true');
      setStatus('Отправляем ссылку…');
      track('me_link_request', { channel: channel });

      fetch('/api/me/request-link', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ contact: contact }),
      })
        .then(function(r) {
          return r.json().catch(function() {
            return { ok: false, status: r.status };
          }).then(function(data) {
            return { data: data, status: r.status };
          });
        })
        .then(function(res) {
          submit.removeAttribute('aria-busy');
          var data = res.data || {};
          if (data.ok) {
            if (data.auto) {
              setStatus(
                'Ссылка отправлена на ' + contact +
                '. Откройте письмо — оно действует 30 минут.',
                'success'
              );
            } else {
              var where = channel === 'telegram' ? 'в Telegram' : 'на email';
              setStatus(
                'Заявка принята — куратор пришлёт вход ' + where +
                ' в течение часа в рабочее время.',
                'success'
              );
            }
            input.value = '';
            return;
          }
          if (res.status === 429) {
            setStatus('Слишком много заявок с этого устройства. Попробуйте через час.', 'error');
            return;
          }
          var msg = (data.detail && data.detail.error) ||
                    'Не удалось отправить заявку. Напишите в Telegram — @academicsaloon.';
          setStatus(msg, 'error');
        })
        .catch(function() {
          submit.removeAttribute('aria-busy');
          setStatus('Связь с сервером прервалась. Напишите в Telegram — @academicsaloon.', 'error');
        });
    });
  }

  /* ══════ 2. SAVED (favorites) ══════ */
  function renderList(listEl, emptyEl, items, buildRow) {
    if (!items.length) {
      emptyEl.hidden = false;
      listEl.hidden = true;
      listEl.innerHTML = '';
      return;
    }
    emptyEl.hidden = true;
    listEl.hidden = false;
    listEl.innerHTML = items.map(buildRow).join('');
  }

  function typeLabel(docType) {
    var map = {
      'Выпускная квалификационная работа': 'ВКР',
      'Курсовая работа': 'Курсовая',
      'Самостоятельная работа': 'Самостоят.',
      'Контрольная работа': 'Контрольная',
      'Отчет по практике': 'Отчёт',
      'Методические материалы': 'Методичка',
      'Экзаменационные материалы': 'Экзамен',
      'Отчет о научно-практической работе': 'НПР',
    };
    return map[docType] || docType || 'Документ';
  }

  function esc(s) {
    return String(s || '').replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c];
    });
  }

  var favsList = document.getElementById('meFavsList');
  var favsEmpty = document.getElementById('meFavsEmpty');

  function renderFavs() {
    var raw = [];
    try { raw = JSON.parse(localStorage.getItem('favorites') || '[]'); } catch (_) {}
    var items = raw.map(function(file, i) {
      var d = bySlug[file];
      if (!d) return null;
      var title = d.catalogTitle || d.title || d.filename || 'Документ';
      return { file: file, title: title, subject: d.subject || '', type: typeLabel(d.docType), i: i };
    }).filter(Boolean);
    renderList(favsList, favsEmpty, items, function(item) {
      return (
        '<a href="/doc/' + encodeURI(item.file) + '" class="me-list-row">' +
          '<span class="rr-no">№&nbsp;' + String(item.i + 1).padStart(2, '0') + '</span>' +
          '<span class="rr-title">' + esc(item.title) + '</span>' +
          '<span class="rr-meta">' + esc(item.type) + '</span>' +
          '<button type="button" class="rr-rm" data-file="' + esc(item.file) + '" aria-label="Убрать">×</button>' +
        '</a>'
      );
    });
    /* Remove listeners */
    favsList.querySelectorAll('.rr-rm').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault(); e.stopPropagation();
        var file = btn.dataset.file;
        var favs = [];
        try { favs = JSON.parse(localStorage.getItem('favorites') || '[]'); } catch (_) {}
        favs = favs.filter(function(f) { return f !== file; });
        localStorage.setItem('favorites', JSON.stringify(favs));
        track('me_favorite_remove', { file: file });
        renderFavs();
      });
    });
  }
  renderFavs();

  /* ══════ 3. HISTORY ══════ */
  var histList = document.getElementById('meHistList');
  var histEmpty = document.getElementById('meHistEmpty');

  function renderHist() {
    var raw = [];
    try { raw = JSON.parse(localStorage.getItem('viewHistory') || '[]'); } catch (_) {}
    var items = raw.slice(0, 15).map(function(h, i) {
      var file = (h && h.file || '').replace(/^\/doc\//, '').replace(/\/$/, '');
      var d = bySlug[file];
      var title = (d && (d.catalogTitle || d.title || d.filename)) || h.title || 'Документ';
      var subject = d && d.subject ? d.subject : '';
      return { file: file, title: title, subject: subject, type: d ? typeLabel(d.docType) : '', i: i, path: h.file };
    });
    renderList(histList, histEmpty, items, function(item) {
      return (
        '<a href="' + (item.path || '/doc/' + encodeURI(item.file)) + '" class="me-list-row">' +
          '<span class="rr-no">№&nbsp;' + String(item.i + 1).padStart(2, '0') + '</span>' +
          '<span class="rr-title">' + esc(item.title) + '</span>' +
          '<span class="rr-meta">' + esc(item.type) + '</span>' +
          '<span class="rr-rm" aria-hidden="true">→</span>' +
        '</a>'
      );
    });
  }
  renderHist();

  /* ══════ 4. DRAFT ORDER ══════ */
  var draftEmpty = document.getElementById('meDraftEmpty');
  var draftCard = document.getElementById('meDraftCard');
  var draftType = document.getElementById('meDraftType');
  var draftDate = document.getElementById('meDraftDate');
  var draftTopic = document.getElementById('meDraftTopic');
  var draftClear = document.getElementById('meDraftClear');

  function renderDraft() {
    var raw = null;
    try { raw = JSON.parse(localStorage.getItem('academic-salon:draft:order') || 'null'); } catch (_) {}
    if (!raw || !raw.values) {
      draftEmpty.hidden = false;
      draftCard.hidden = true;
      return;
    }
    var v = raw.values || {};
    var topic = v.topic || v.fTopic || v.Тема || 'Черновик без темы';
    var type = v.type || v.workType || '—';
    var typeMap = { kurs_t: 'Курсовая', diplom: 'ВКР', kont: 'Контрольная', ref: 'Реферат' };
    draftType.textContent = typeMap[type] || type;
    draftDate.textContent = raw.savedAt ? new Date(raw.savedAt).toLocaleDateString('ru-RU') : '';
    draftTopic.textContent = topic;
    draftEmpty.hidden = true;
    draftCard.hidden = false;
  }
  renderDraft();

  if (draftClear) {
    draftClear.addEventListener('click', function() {
      localStorage.removeItem('academic-salon:draft:order');
      track('me_draft_clear');
      renderDraft();
    });
  }
})();
</script>

