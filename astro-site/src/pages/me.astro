  .me-folio .me-orders-block {
    padding: 20px 22px;
    border: 1px solid var(--brd);
    border-radius: 12px;
    background: rgba(255,255,255,.015);
  }
  .me-folio .me-h3 {
    font: 400 18px/1.3 var(--fd);
    color: var(--t1);
    margin: 0 0 14px;
  }
  .me-folio .me-orders {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .me-folio .me-order {
    display: grid;
    grid-template-columns: 110px 1fr auto auto;
    gap: 12px;
    align-items: baseline;
    padding: 10px 0;
    border-bottom: 1px solid var(--brd);
    font: 400 14px/1.4 var(--fi);
  }
  .me-folio .me-order:last-child { border-bottom: 0; }
  .me-folio .me-order-when { color: var(--t3); font-variant-numeric: tabular-nums; }
  .me-folio .me-order-topic { color: var(--t1); }
  .me-folio .me-dl-link {
    color: var(--t1);
    text-decoration: none;
    transition: color .25s var(--ease-ios);
  }
  .me-folio .me-dl-link:hover { color: var(--ac); }
  .me-folio .me-dl-subj {
    color: var(--t3);
    font: 400 13px/1.5 var(--fi);
    margin-left: 6px;
  }
  .me-folio .me-order-status {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .12em;
    padding: 3px 8px;
    border-radius: 999px;
    border: 1px solid var(--brd);
    color: var(--t2);
    white-space: nowrap;
  }
  .me-folio .me-order-status--new       { color: var(--ac); border-color: var(--ac-b); }
  .me-folio .me-order-status--in_work,
  .me-folio .me-order-status--in_progress { color: #f6e27a; border-color: rgba(246,226,122,.4); }
  .me-folio .me-order-status--done,
  .me-folio .me-order-status--completed   { color: #8de2a8; border-color: rgba(141,226,168,.35); }
  .me-folio .me-order-status--cancelled,
  .me-folio .me-order-status--rejected    { color: #c8a8a8; border-color: rgba(200,168,168,.35); }
  .me-folio .me-order-repeat {
    font: 500 14px/1 var(--fm);
    color: var(--t3);
    text-decoration: none;
    padding: 4px 8px;
    border-radius: 6px;
    transition: all .25s var(--ease-ios);
  }
  .me-folio .me-order-repeat:hover { color: var(--ac); background: rgba(212,175,55,.06); }
  .me-folio .me-orders-empty,
  .me-folio .me-orders-loading {
    margin: 0;
    color: var(--t3);
    font: 400 14px/1.5 var(--fi);
  }
  .me-folio .me-orders-empty a { color: var(--ac-link, var(--ac)); }

  /* ── Stage 53 — skeletons вместо «Загружаем…». Серый-золотой
       shimmer создаёт ощущение «уже грузится», даже если фетч
       занимает 800ms+ на медленном соединении. Прячется через
       JS hidden=true когда данные пришли (или пустой блок). ── */
  .me-folio .me-skel {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .me-folio .me-skel--cards { gap: 14px; }
  .me-folio .me-skel-row {
    display: flex;
    gap: 14px;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px dashed var(--brd);
  }
  .me-folio .me-skel-row:last-child { border-bottom: 0; }
  .me-folio .me-skel-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 14px 16px;
    border: 1px solid var(--brd);
    border-radius: 10px;
    background: rgba(255,255,255,.012);
  }
  .me-folio .me-skel-bar {
    display: block;
    height: 12px;
    border-radius: 6px;
    background: linear-gradient(90deg,
      rgba(212,175,55,.04) 0%,
      rgba(212,175,55,.13) 50%,
      rgba(212,175,55,.04) 100%);
    background-size: 200% 100%;
    animation: me-skel-shimmer 1.4s ease-in-out infinite;
  }
  .me-folio .me-skel-bar--xs { width: 70px; flex-shrink: 0; }
  .me-folio .me-skel-bar--sm { width: 35%; }
  .me-folio .me-skel-bar--md { width: 60%; flex: 1; }
  .me-folio .me-skel-bar--lg { width: 85%; flex: 1; }
  @keyframes me-skel-shimmer {
    0%, 100% { background-position: 200% 0; }
    50%      { background-position: -200% 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .me-folio .me-skel-bar { animation: none; opacity: .6; }
  }

  /* ── Active orders (hero cards above stats) ── */
  .me-folio .me-active-orders {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 24px;
  }
  .me-folio .me-active {
    padding: 22px 24px;
    border: 1px solid var(--ac-b, rgba(212,175,55,.25));
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(212,175,55,.05), rgba(212,175,55,.015));
    position: relative;
  }
  .me-folio .me-active::before {
    content: "";
    position: absolute; left: 0; top: 18px; bottom: 18px;
    width: 3px; border-radius: 2px;
    background: var(--ac);
  }
  .me-folio .me-active-head { margin-bottom: 18px; }
  .me-folio .me-active-eyebrow {
    display: inline-block;
    font: 600 10px/1 var(--fm);
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ac);
    padding: 4px 10px;
    border: 1px solid var(--ac-b);
    border-radius: 999px;
    margin-bottom: 10px;
  }
  .me-folio .me-active-topic {
    font: 400 clamp(18px, 2vw, 22px)/1.3 var(--fh);
    color: var(--t1);
    margin: 0 0 6px;
    letter-spacing: -.005em;
  }
  .me-folio .me-active-meta {
    margin: 0;
    font: 400 13px/1.5 var(--fi);
    color: var(--t3);
  }
  /* Timeline */
  .me-folio .me-active-timeline {
    display: grid;
    grid-template-columns: auto 1fr auto 1fr auto;
    align-items: center;
    gap: 8px;
    margin: 16px 0 20px;
  }
  .me-folio .me-tl-step {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    color: var(--t3);
  }
  .me-folio .me-tl-dot {
    display: block;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: transparent;
    border: 1.5px solid var(--brd);
    transition: all .3s var(--ease-ios);
  }
  .me-folio .me-tl-lbl {
    font: 500 11px/1 var(--fm);
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .me-folio .me-tl-bar {
    height: 1.5px;
    background: var(--brd);
    transition: background .3s var(--ease-ios);
  }
  .me-folio .me-tl-done .me-tl-dot,
  .me-folio .me-tl-current .me-tl-dot {
    background: var(--ac); border-color: var(--ac);
  }
  .me-folio .me-tl-current .me-tl-dot {
    box-shadow: 0 0 0 4px rgba(212,175,55,.18);
  }
  .me-folio .me-tl-done .me-tl-lbl,
  .me-folio .me-tl-current .me-tl-lbl { color: var(--t1); }
  .me-folio .me-tl-current .me-tl-lbl { color: var(--ac); }
  .me-folio .me-tl-step.me-tl-done + .me-tl-bar,
  .me-folio .me-tl-step.me-tl-current + .me-tl-bar { background: var(--ac); }
  /* Foot (actions) */
  /* Stage 59 — chat thread per order. */
  .me-folio .me-msgs {
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px dashed var(--brd);
  }
  .me-folio .me-msgs[hidden] { display: none; }
  .me-folio .me-msgs-summary {
    list-style: none;
    cursor: pointer;
    font: 500 12px/1 var(--fm);
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--ac);
    padding: 8px 0;
  }
  .me-folio .me-msgs-summary::-webkit-details-marker { display: none; }
  .me-folio .me-msgs-list {
    list-style: none;
    margin: 12px 0 14px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-height: 360px;
    overflow-y: auto;
  }
  .me-folio .me-msgs-empty {
    font: 400 13px/1.5 var(--fi);
    color: var(--t3);
    padding: 8px 0;
  }
  .me-folio .me-msg {
    padding: 10px 14px;
    border-radius: 10px;
    font: 400 14px/1.5 var(--fi);
    max-width: 86%;
  }
  .me-folio .me-msg-head {
    display: flex; gap: 8px;
    font: 500 10px/1 var(--fm);
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--t3);
    margin-bottom: 4px;
  }
  .me-folio .me-msg-sender { color: var(--ac); }
  .me-folio .me-msg-body { color: var(--t1); white-space: pre-wrap; word-wrap: break-word; }
  .me-folio .me-msg--client {
    align-self: flex-end;
    background: rgba(212,175,55,.08);
    border: 1px solid var(--gold-line);
  }
  .me-folio .me-msg--manager {
    align-self: flex-start;
    background: rgba(255,255,255,.025);
    border: 1px solid var(--brd);
  }
  .me-folio .me-msgs-form {
    display: flex;
    gap: 8px;
    align-items: flex-end;
  }
  .me-folio .me-msgs-input {
    flex: 1;
    padding: 10px 12px;
    border: 1px solid var(--brd);
    background: var(--bg);
    color: var(--t1);
    font: 400 14px/1.4 var(--fi);
    border-radius: 8px;
    resize: vertical;
    min-height: 56px;
  }
  .me-folio .me-msgs-input:focus { outline: none; border-color: var(--ac-b2); }
  .me-folio .me-msgs-send {
    padding: 10px 16px;
    background: var(--ac);
    color: var(--ink);
    border: 0;
    border-radius: 8px;
    font: 500 13px/1 var(--fd);
    cursor: pointer;
    transition: background .25s var(--ease, ease);
  }
  .me-folio .me-msgs-send:hover:not(:disabled) { background: var(--ac2, var(--ac)); }
  .me-folio .me-msgs-send:disabled { opacity: .6; cursor: not-allowed; }

  .me-folio .me-active-foot {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .me-folio .me-active-foot .btn-sm {
    padding: 8px 16px;
    font: 500 13px/1 var(--fd);
  }
  @media (max-width: 720px) {
    .me-folio .me-active { padding: 18px 18px; }
    .me-folio .me-active-timeline {
      grid-template-columns: auto 1fr auto 1fr auto;
      gap: 4px;
    }
    .me-folio .me-tl-lbl { font-size: 10px; letter-spacing: .04em; }
    .me-folio .me-order { grid-template-columns: 1fr auto; }
    .me-folio .me-order-when { grid-column: 1 / -1; font-size: 12px; }
    .me-folio .me-order-repeat { grid-column: 2; }
  }

  /* ── Telegram Login Widget surface ── */
  .me-folio .me-auth-tg {
    margin: 24px 0 32px;
    padding: 20px 24px;
    border: 1px solid var(--ac-b, rgba(212,175,55,.2));
    border-radius: 12px;
    background: rgba(212,175,55,.04);
    text-align: center;
  }
  .me-folio .me-auth-tg-lbl {
    margin: 0 0 14px;
    font: 400 14px/1.5 var(--fi);
    color: var(--t1);
  }
  .me-folio .me-auth-row {
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: stretch;
    margin-bottom: 12px;
  }
  .me-folio .me-tg-widget {
    display: flex;
    justify-content: center;
    min-height: 44px;
  }
  .me-folio .me-vk-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 10px 18px;
    border-radius: 8px;
    background: #0077FF;
    color: #fff;
    text-decoration: none;
    font: 500 14px/1 var(--fd);
    letter-spacing: -.005em;
    min-height: 40px;
    transition: background .25s var(--ease-ios), transform .15s var(--ease-ios);
  }
  .me-folio .me-vk-btn:hover { background: #0067e0; }
  .me-folio .me-vk-btn:active { transform: scale(.98); }
  .me-folio .me-vk-logo { width: 22px; height: 22px; }
  .me-folio .me-auth-tg-hint {
    margin: 0;
    font: 400 12px/1.5 var(--fi);
    color: var(--t3);
  }
  .me-folio .me-auth-tg-fallback {
    margin: 0 0 8px;
    padding: 10px 14px;
    border-radius: 10px;
    background: rgba(212, 175, 55, .07);
    border: 1px solid var(--ac-g);
    font: 400 13px/1.5 var(--fi);
    color: var(--t2);
  }

  /* ════════════════════════════════════════════════════════════
     AUTH REDESIGN — 3 method tiles + flow blocks
     Telegram / VK / Email — пользователь выбирает канал, остальное
     открывается под ним. Конкретно, без editorial-стихов.
     ════════════════════════════════════════════════════════════ */

  .me-folio .me-auth { display: flex; flex-direction: column; gap: 24px; }

  /* Method tiles — три равные плитки в ряд */
  .me-folio .me-auth-methods {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  .me-folio .me-auth-method {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    padding: 18px 18px 16px;
    border: 1px solid var(--brd);
    border-radius: 12px;
    background: rgba(255,255,255,.015);
    color: var(--t1);
    cursor: pointer;
    text-align: left;
    font: inherit;
    transition: border-color .2s, background .2s, transform .15s;
  }
  .me-folio .me-auth-method:not([disabled]):hover {
    border-color: var(--ac-b, rgba(212,175,55,.25));
    background: var(--ac-t, rgba(212,175,55,.04));
    transform: translateY(-1px);
  }
  .me-folio .me-auth-method.is-active {
    border-color: var(--ac);
    background: var(--ac-t, rgba(212,175,55,.05));
    box-shadow: 0 0 0 1px var(--ac-b, rgba(212,175,55,.2));
  }
  .me-folio .me-auth-method[disabled] {
    cursor: not-allowed;
    opacity: .42;
    filter: grayscale(.7);
  }
  .me-folio .me-auth-method[disabled]:hover {
    background: rgba(255,255,255,.015);
    transform: none;
  }
  .me-folio .me-auth-method-glyph {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(212,175,55,.08);
    border: 1px solid var(--ac-b, rgba(212,175,55,.2));
    color: var(--ac);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .me-folio .me-auth-method-glyph svg { width: 18px; height: 18px; }
  .me-folio .me-auth-method-body {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .me-folio .me-auth-method-name {
    font: 500 15px/1.2 var(--fd);
    color: var(--t1);
    letter-spacing: -.005em;
  }
  .me-folio .me-auth-method-sub {
    font: italic 400 12px/1.4 var(--fi);
    color: var(--t3);
  }
  .me-folio .me-auth-method-status {
    position: absolute;
    top: 10px;
    right: 12px;
    font: 400 9px/1 var(--fm);
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--t3);
    opacity: .7;
  }
  .me-folio .me-auth-method-status[data-status="ready"] {
    color: var(--ac);
    opacity: 1;
  }
  .me-folio .me-auth-method-status[data-status="off"] {
    color: var(--t3);
  }
  /* Email tile is always usable — no status badge */
  .me-folio .me-auth-method--email .me-auth-method-status { display: none; }

  @media (max-width: 640px) {
    .me-folio .me-auth-methods {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }

  /* Flow block — открывается под выбранной плиткой */
  .me-folio .me-auth-flow {
    padding: 22px 24px;
    border: 1px solid var(--brd);
    border-radius: 12px;
    background: rgba(255,255,255,.015);
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .me-folio .me-auth-flow[hidden] { display: none; }
  .me-folio .me-auth-flow-head {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .me-folio .me-auth-flow-h {
    margin: 0;
    font: 400 clamp(18px, 2vw, 22px)/1.2 var(--fh);
    color: var(--t1);
    letter-spacing: -.01em;
  }
  .me-folio .me-auth-flow-lede {
    margin: 0;
    font: italic 400 13px/1.55 var(--fi);
    color: var(--t2);
    max-width: 56ch;
  }
  .me-folio .me-auth-flow-note {
    margin: 0;
    padding: 10px 14px;
    border-radius: 8px;
    background: rgba(212,175,55,.06);
    border: 1px solid var(--ac-b, rgba(212,175,55,.18));
    font: 400 12px/1.5 var(--fi);
    color: var(--t2);
  }
  .me-folio .me-link-btn {
    background: none;
    border: 0;
    padding: 0;
    color: var(--ac);
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
    cursor: pointer;
    font: inherit;
  }

  /* Stepper — три шага email-flow, для ясности */
  .me-folio .me-auth-stepper {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
  }
  .me-folio .me-auth-stepper li {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border: 1px solid var(--brd);
    border-radius: 8px;
    background: rgba(255,255,255,.015);
  }
  .me-folio .me-step-n {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--ac-t, rgba(212,175,55,.08));
    border: 1px solid var(--ac-b, rgba(212,175,55,.25));
    color: var(--ac);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font: 500 11px/1 var(--fm);
    font-feature-settings: "tnum";
  }
  .me-folio .me-step-t {
    font: 400 12px/1.4 var(--fi);
    color: var(--t2);
  }
  @media (max-width: 640px) {
    .me-folio .me-auth-stepper { grid-template-columns: 1fr; }
  }

  /* TG widget centered */
  .me-folio .me-tg-widget-wrap {
    display: flex;
    justify-content: center;
    min-height: 48px;
  }

  /* VK button — gold gold (наша кнопка) вместо синего */
  .me-folio .me-vk-go {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  /* Trust footer — почему без пароля */
  .me-folio .me-auth-trust {
    margin: 0;
    padding: 14px 18px;
    border-radius: 10px;
    background: rgba(255,255,255,.015);
    display: grid;
    grid-template-columns: 22px 1fr;
    gap: 12px;
    align-items: start;
    font: italic 400 12px/1.55 var(--fi);
    color: var(--t3);
  }
  .me-folio .me-auth-trust-glyph {
    font: 400 16px/1 var(--fh);
    color: var(--ac);
    opacity: .7;
  }

  /* ── Cabinet favourites — grid of cards ── */
  .me-folio .me-favs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }
  .me-folio .me-fav-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--brd);
    border-radius: 12px;
    background: rgba(255,255,255,.02);
    padding: 14px 16px;
    transition: all .25s var(--ease-ios);
    position: relative;
    min-height: 110px;
  }
  .me-folio .me-fav-card:hover {
    border-color: var(--ac-g);
    background: rgba(212,175,55,.04);
    transform: translateY(-1px);
  }
  .me-folio .me-fav-card-link {
    flex: 1;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .me-folio .me-fav-card-title {
    margin: 0 0 6px;
    font: 400 14px/1.35 var(--fd);
    color: var(--t1);
    letter-spacing: -.005em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .me-folio .me-fav-card-meta {
    margin: 0;
    font: 400 11px/1.4 var(--fm);
    letter-spacing: .04em;
    color: var(--t3);
    text-transform: uppercase;
  }
  .me-folio .me-fav-card-foot {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 12px; padding-top: 10px;
    border-top: 1px solid var(--brd);
    gap: 8px;
  }
  .me-folio .me-fav-card-when {
    font: 400 11px/1.3 var(--fi);
    color: var(--t3);
    font-variant-numeric: tabular-nums;
    flex: 1;
    min-width: 0;
  }
  .me-folio .me-fav-rm {
    background: transparent;
    border: 1px solid var(--brd);
    border-radius: 999px;
    width: 26px;
    height: 26px;
    color: var(--t3);
    font-size: 12px;
    line-height: 1;
    cursor: pointer;
    flex-shrink: 0;
