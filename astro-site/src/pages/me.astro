<!-- Saved searches widget bootstrap — script tag for /scripts/saved-searches.js
     lives inside <Base> above; this is just the inline mount logic. -->
<script is:inline>
  (function () {
    function escapeHtml(s) {
      return String(s || '')
        .replace(/&/g, '&amp;').replace(/</g, '&lt;')
        .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }
    function renderSaved() {
      const block = document.getElementById('meSavedSearchesBlock');
      const list = document.getElementById('meSavedList');
      const empty = document.getElementById('meSavedEmpty');
      if (!block || !list) return;
      const api = window.salonSavedSearches;
      if (!api) { setTimeout(renderSaved, 120); return; }
      const items = api.list();
      const countEl = document.getElementById('meTabCountSearches');
      if (countEl) {
        countEl.textContent = String(items.length);
        countEl.hidden = items.length === 0;
      }
      if (items.length === 0) {
        block.hidden = true;
        if (empty) empty.hidden = false;
        return;
      }
      block.hidden = false;
      if (empty) empty.hidden = true;
      list.innerHTML = items.map((s) => `
        <li class="me-saved-row" data-id="${escapeHtml(s.id)}">
          <a href="${escapeHtml(api.buildUrl(s))}" class="me-saved-link">
            <span class="me-saved-glyph" aria-hidden="true">⁘</span>
            <span>${escapeHtml(s.label)}</span>
          </a>
          <button type="button" class="me-saved-remove" data-remove="${escapeHtml(s.id)}" aria-label="Удалить">убрать</button>
        </li>
      `).join('');
      list.querySelectorAll('[data-remove]').forEach((btn) => {
        btn.addEventListener('click', () => {
          api.remove(btn.getAttribute('data-remove') || '');
          renderSaved();
          if (typeof window.buildActivityTimeline === 'function') {
            window.buildActivityTimeline();
          }
        });
      });
    }
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      renderSaved();
    } else {
      window.addEventListener('DOMContentLoaded', renderSaved, { once: true });
    }
    document.addEventListener('astro:page-load', renderSaved);
  })();
</script>

<!-- Recently-viewed widget bootstrap — script tag for /scripts/recent-viewed.js
     lives inside <Base> above; this is just the inline mount logic. -->
<script is:inline>
  (function () {
    function mountRecent() {
      const target = document.getElementById('meRecentBlock');
      if (!target) return;
      if (typeof window.mountRecentView === 'function') {
        const ok = window.mountRecentView(target, { variant: 'cabinet', min: 1, limit: 8 });
        // Если истории нет — скрываем сам контейнер, чтобы не оставлять
        // пустую дыру между downloads и referral.
        if (!ok) target.hidden = true;
      } else {
        setTimeout(mountRecent, 120);
      }
    }
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      mountRecent();
    } else {
      window.addEventListener('DOMContentLoaded', mountRecent, { once: true });
    }
    document.addEventListener('astro:page-load', mountRecent);
  })();
</script>

<script is:inline define:vars={{ bySlug }} data-astro-rerun>
(function() {
  var app = window.academicSalon || {};
  var showToast = app.showToast || function() {};
  var track = app.track || function() {};

  /* ══════ 0. SESSION BOOTSTRAP ══════ */
  var authSection = document.getElementById('meAuthSection');
  var cabinet = document.getElementById('meCabinet');
  var contactBadge = document.getElementById('meCabinetContact');
  var ordersList = document.getElementById('meOrders');
  var ordersEmpty = document.getElementById('meOrdersEmpty');
  var ordersLoading = document.getElementById('meOrdersLoading');
  var logoutBtn = document.getElementById('meLogoutBtn');

  function showCabinet(profile) {
    if (cabinet) cabinet.hidden = false;
    if (authSection) authSection.hidden = true;
    try { sessionStorage.setItem('me:signed-in', '1'); } catch (_) {}
    var navProfile = document.getElementById('navProfile');
    if (navProfile) navProfile.setAttribute('data-signed-in', 'true');
    var intro = document.getElementById('meIntro');
    if (intro) intro.hidden = true;
    if (contactBadge) contactBadge.textContent = profile.contact || '—';

    // Hero avatar — initials gradient
    paintAvatar(profile.contact || '');
    paintHeroSince(profile.created_at || profile.createdAt || profile.since);

    // Populate settings block
    var acctContact = document.getElementById('meAcctContact');
    var acctChannel = document.getElementById('meAcctChannel');
    if (acctContact) acctContact.textContent = profile.contact || '—';
    if (acctChannel) {
      var ch = profile.channel || 'email';
      var label = { telegram: 'Telegram', email: 'Email', vk: 'ВКонтакте' }[ch] || ch;
      acctChannel.textContent = label;
    }

    // Show the mobile FAB (CSS handles visibility per breakpoint)
    var fab = document.getElementById('meFab');
    if (fab) fab.hidden = false;

    // Hide the localStorage-only "Сохранённые работы" panel — server-side
    // favourites в Архиве cabinet supersede it for signed-in users.
    var localFavsSection = document.querySelector('section[aria-label="Сохранённые работы"]');
    if (localFavsSection) localFavsSection.hidden = true;
    var hr1 = localFavsSection && localFavsSection.previousElementSibling;
    if (hr1 && hr1.classList && hr1.classList.contains('me-hairline')) hr1.hidden = true;

    setupCabinetTabs();

    loadOrders();
    syncFavoritesWithServer();
    loadDownloads();
    loadReferral();
    bindOrderChats();
  }

  /* ─── Initials avatar (deterministic gradient by contact hash) ─── */
  function paintAvatar(contact) {
    var initialsEl = document.getElementById('meAvatarInitials');
    var avatarEl = document.getElementById('meAvatar');
    if (!initialsEl || !avatarEl) return;
    var raw = String(contact || '').trim();
    var letters = '—';
    if (raw) {
      // Strip protocols, "@" etc — берем человеческую часть
      var cleaned = raw.replace(/^.*?[\\\/@:]+/, '').replace(/^[+\d\s()-]+$/, raw);
      var parts = cleaned.split(/[\s._@-]+/).filter(Boolean);
      if (parts.length >= 2) letters = (parts[0][0] + parts[1][0]).toUpperCase();
      else if (parts.length === 1) letters = parts[0].slice(0, 2).toUpperCase();
    }
    initialsEl.textContent = letters;

    // Hash → hue rotation for subtle differentiation per contact
    var h = 0;
    for (var i = 0; i < raw.length; i++) h = (h * 31 + raw.charCodeAt(i)) | 0;
    var hueShift = ((h % 36) - 18); // ±18° от золота
    avatarEl.style.filter = 'hue-rotate(' + hueShift + 'deg)';
  }

  function paintHeroSince(epochOrIso) {
    var since = document.getElementById('meHeroSince');
    if (!since || !epochOrIso) return;
    var d;
    if (typeof epochOrIso === 'number') {
      d = new Date(epochOrIso < 1e12 ? epochOrIso * 1000 : epochOrIso);
    } else {
      d = new Date(epochOrIso);
    }
    if (isNaN(d.getTime())) return;
    var months = d.toLocaleString('ru-RU', { month: 'long', year: 'numeric' });
    since.textContent = 'с нами с ' + months;
    since.hidden = false;
  }

  /* ─── Cabinet tabs (top-level + library sub-tabs) ─── */
  function setupCabinetTabs() {
    if (!cabinet || cabinet.getAttribute('data-me-tabs-bound') === 'true') return;
    cabinet.setAttribute('data-me-tabs-bound', 'true');

    var topButtons = Array.prototype.slice.call(
      document.querySelectorAll('.me-cabinet [data-me-tab]')
    );
    var topPanels = Array.prototype.slice.call(
      document.querySelectorAll('.me-cabinet [data-me-panel]')
    );

    function activateTop(tabId, opts) {
      opts = opts || {};
      var found = false;
      topButtons.forEach(function (btn) {
        var on = btn.dataset.meTab === tabId;
        btn.classList.toggle('is-active', on);
        if (on) {
          btn.setAttribute('aria-current', 'page');
          found = true;
        } else {
          btn.removeAttribute('aria-current');
        }
      });
      topPanels.forEach(function (panel) {
        panel.hidden = panel.dataset.mePanel !== tabId;
      });
      if (!found) return false;
      if (!opts.silent) {
        try { sessionStorage.setItem('me-active-tab', tabId); } catch (_) {}
        if (location.hash !== '#' + tabId) {
          history.replaceState(null, '', '#' + tabId);
        }
      }
      // Lazy: build timeline only when overview is shown the first time.
      if (tabId === 'overview') buildActivityTimeline();
      return true;
    }

    topButtons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        activateTop(btn.dataset.meTab);
      });
    });

    // Quick action that jumps to another tab (e.g. "Поделиться" → profile)
    document.querySelectorAll('[data-me-go-tab]').forEach(function (el) {
      el.addEventListener('click', function (e) {
        e.preventDefault();
        activateTop(el.getAttribute('data-me-go-tab'));
        var section = document.querySelector('.me-cabinet');
        if (section) section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    // Library sub-tabs
    var libButtons = Array.prototype.slice.call(
      document.querySelectorAll('[data-me-lib]')
    );
    var libPanels = Array.prototype.slice.call(
      document.querySelectorAll('[data-me-lib-panel]')
    );
    function activateLib(libId) {
      libButtons.forEach(function (btn) {
        btn.classList.toggle('is-active', btn.dataset.meLib === libId);
      });
      libPanels.forEach(function (panel) {
        panel.hidden = panel.dataset.meLibPanel !== libId;
      });
    }
    libButtons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        activateLib(btn.dataset.meLib);
      });
    });

    // Initial tab — URL hash → sessionStorage → 'overview'
    var initial = (location.hash || '').replace(/^#/, '');
    var saved = '';
    try { saved = sessionStorage.getItem('me-active-tab') || ''; } catch (_) {}
    var pick = initial && document.querySelector('[data-me-panel="' + initial + '"]')
      ? initial
      : (saved && document.querySelector('[data-me-panel="' + saved + '"]') ? saved : 'overview');
    activateTop(pick, { silent: true });

    window.addEventListener('hashchange', function () {
      var h = (location.hash || '').replace(/^#/, '');
      if (h && document.querySelector('[data-me-panel="' + h + '"]')) {
        activateTop(h, { silent: true });
      }
    });
  }

  /* ─── Activity timeline — единая лента из orders + downloads + recent + saved ─── */
  window.buildActivityTimeline = buildActivityTimeline;
  function buildActivityTimeline() {
    var box = document.getElementById('meTimeline');
    var list = document.getElementById('meTimelineList');
    if (!box || !list) return;

    var events = [];

    // Server-side: orders
    if (Array.isArray(window.__meOrders)) {
      window.__meOrders.forEach(function (o) {
        var t = o.updated_at || o.created_at || o.createdAt;
        if (!t) return;
        events.push({
          t: typeof t === 'number' ? (t < 1e12 ? t * 1000 : t) : Date.parse(t),
          glyph: '⊕',
          text: 'Заявка <a href="#orders">' + escapeHtml(o.topic || ('№' + (o.id || ''))) + '</a> · '
            + statusLabel(o.status),
        });
      });
    }
    // Server-side: downloads
    if (Array.isArray(window.__meDownloads)) {
      window.__meDownloads.forEach(function (d) {
        var t = d.last_at || d.at || d.created_at;
        if (!t) return;
        events.push({
          t: typeof t === 'number' ? (t < 1e12 ? t * 1000 : t) : Date.parse(t),
          glyph: '↓',
          text: 'Скачана работа <a href="/doc/' + encodeURI(d.file || '') + '">' + escapeHtml(d.title || d.file || '') + '</a>',
        });
      });
    }
    // Client-side: recent-viewed (от recent-viewed.js)
    try {
      var raw = localStorage.getItem('salon:viewed');
      if (raw) {
        JSON.parse(raw).forEach(function (v) {
          if (!v || !v.t) return;
          events.push({
            t: v.t,
            glyph: '⟶',
            text: 'Открыта работа <a href="/doc/' + encodeURI(v.file || '') + '">' + escapeHtml(v.title || v.file) + '</a>',
          });
        });
      }
    } catch (_) {}
    // Client-side: saved-searches
    try {
      var sraw = localStorage.getItem('salon:saved-searches');
      if (sraw) {
        JSON.parse(sraw).forEach(function (s) {
          if (!s || !s.t) return;
          events.push({
            t: s.t,
            glyph: '⁘',
            text: 'Сохранён поиск «' + escapeHtml(s.label || s.q || '—') + '»',
          });
        });
      }
    } catch (_) {}

    if (events.length === 0) {
      box.hidden = true;
      return;
    }

    events.sort(function (a, b) { return b.t - a.t; });
    var top = events.slice(0, 12);

    var now = Date.now();
    list.innerHTML = top.map(function (ev) {
      return '<li class="me-tl-row">'
        + '<span class="me-tl-glyph" aria-hidden="true">' + ev.glyph + '</span>'
        + '<span class="me-tl-when">' + relativeTime(now - ev.t) + '</span>'
        + '<span class="me-tl-text">' + ev.text + '</span>'
      + '</li>';
    }).join('');
    box.hidden = false;
  }

  function escapeHtml(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
  function statusLabel(s) {
    var map = {
      new: 'новая', in_work: 'в работе', in_progress: 'в работе',
      done: 'готова', completed: 'готова',
      cancelled: 'отменена', rejected: 'отклонена',
    };
    return map[s] || (s || '—');
  }
  function relativeTime(ms) {
    if (!ms || ms < 0) return '—';
    var s = Math.floor(ms / 1000);
    if (s < 60) return 'только что';
    var m = Math.floor(s / 60);
    if (m < 60) return m + ' мин назад';
    var h = Math.floor(m / 60);
    if (h < 24) return h + ' ч назад';
    var d = Math.floor(h / 24);
    if (d < 7) return d + ' дн назад';
    var w = Math.floor(d / 7);
    if (w < 5) return w + ' нед назад';
    var mo = Math.floor(d / 30);
    if (mo < 12) return mo + ' мес назад';
    return Math.floor(d / 365) + ' г назад';
  }

  // Stage 59 — chat thread per active order. Delegated handlers because
  // active-order cards are rendered after async loadOrders() resolves.
  // No polling for MVP — fetch on toggle-open + on send.
  function bindOrderChats() {
    if (window.__meChatsBound) return;
    window.__meChatsBound = true;

    document.addEventListener('click', function (e) {
      var target = e.target;
      if (!target || !target.closest) return;

      var toggle = target.closest('[data-msgs-toggle]');
      if (toggle) {
        e.preventDefault();
        var oid = toggle.getAttribute('data-msgs-toggle');
        var details = document.querySelector('[data-msgs="' + oid + '"]');
        if (!details) return;
        details.hidden = !details.hidden;
        if (!details.hidden) {
          details.open = true;
          loadChat(oid, details);
        }
        return;
      }
    });

    document.addEventListener('submit', function (e) {
      var form = e.target;
      if (!form || !form.matches || !form.matches('[data-msgs-form]')) return;
      e.preventDefault();
      var details = form.closest('[data-msgs]');
      if (!details) return;
      var oid = details.getAttribute('data-msgs');
      var input = form.querySelector('[data-msgs-input]');
      var btn = form.querySelector('.me-msgs-send');
      var body = (input && input.value || '').trim();
      if (!body) return;
      if (btn) { btn.disabled = true; btn.textContent = '…'; }
      fetch('/api/me/orders/' + encodeURIComponent(oid) + '/messages', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ body: body }),
      })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (data) {
          if (data && data.ok) {
            if (input) input.value = '';
            loadChat(oid, details);
          } else {
            showToast('Не получилось отправить — попробуйте ещё раз', 'error');
          }
        })
        .catch(function () {
          showToast('Сеть недоступна — попробуйте позже', 'error');
        })
        .finally(function () {
          if (btn) { btn.disabled = false; btn.textContent = 'Отправить'; }
        });
    });
  }

  function loadChat(orderId, details) {
    var listEl = details.querySelector('[data-msgs-list]');
    if (!listEl) return;
    fetch('/api/me/orders/' + encodeURIComponent(orderId) + '/messages', {
      credentials: 'same-origin', cache: 'no-store',
    })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (data) {
        if (!data || !data.ok) return;
        var items = data.messages || [];
        if (!items.length) {
          listEl.innerHTML = '<li class="me-msgs-empty">Пока сообщений нет. Напишите первым — куратор ответит в течение часа в рабочее время.</li>';
          return;
        }
        listEl.innerHTML = items.map(function (m) {
          var when = new Date((m.created_at || 0) * 1000)
            .toLocaleString('ru-RU', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
          var cls = m.author === 'manager' ? 'me-msg me-msg--manager' : 'me-msg me-msg--client';
          var sender = m.author === 'manager' ? 'Куратор' : 'Вы';
          return '<li class="' + cls + '">' +
                   '<div class="me-msg-head"><span class="me-msg-sender">' + sender + '</span><span class="me-msg-when">' + escHtml(when) + '</span></div>' +
                   '<div class="me-msg-body">' + escHtml(m.body) + '</div>' +
                 '</li>';
        }).join('');
        // Scroll to bottom
        listEl.scrollTop = listEl.scrollHeight;
      })
      .catch(function () { /* silent */ });
  }

  // Stage 58 — referral block. Fetch /api/me/referral, populate code +
  // attribution count, bind copy-link button.
  function loadReferral() {
    var section = document.getElementById('meReferral');
    if (!section) return;
    fetch('/api/me/referral', { credentials: 'same-origin', cache: 'no-store' })
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (data) {
        if (!data || !data.ok || !data.code) return;
        var codeEl = document.getElementById('meReferralCode');
        var attrEl = document.getElementById('meReferralAttr');
        var copyBtn = document.getElementById('meReferralCopy');
        if (codeEl) codeEl.textContent = data.code;
        if (attrEl && data.attributedCount > 0) {
          attrEl.textContent = 'По вашему коду уже пришло ' + data.attributedCount +
            ' ' + (function(n){var m10=n%10,m100=n%100; if (m100>=11&&m100<=19) return 'заявок'; if (m10===1) return 'заявка'; if (m10>=2&&m10<=4) return 'заявки'; return 'заявок';})(data.attributedCount) + '.';
          attrEl.hidden = false;
        }
        if (copyBtn) {
          copyBtn.addEventListener('click', function () {
            var url = data.shareUrl || ('https://bibliosaloon.ru/?ref=' + data.code);
            (navigator.clipboard && window.isSecureContext
              ? navigator.clipboard.writeText(url)
              : Promise.reject()
            ).then(function () {
              showToast('Ссылка скопирована: ' + url, 'success', 3000);
            }).catch(function () {
              // fallback
              var t = document.createElement('textarea'); t.value = url;
              t.style.position='fixed'; t.style.opacity='0';
              document.body.appendChild(t); t.select();
              try { document.execCommand('copy'); showToast('Ссылка скопирована', 'success'); } catch(_) {}
              t.remove();
            });
          });
        }
        section.hidden = false;
      })
      .catch(function () { /* silent */ });
  }

  function setStat(id, value) {
    var el = document.getElementById(id);
    if (el) el.textContent = String(value);
  }
  function formatSinceDate(epoch) {
    if (!epoch) return 'сегодня';
    var d = new Date(epoch * 1000);
    var now = Date.now();
    var diffDays = Math.floor((now - d.getTime()) / 86400000);
    if (diffDays < 1) return 'сегодня';
    if (diffDays < 30) return diffDays + ' дн.';
    return d.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short', year: '2-digit' });
  }

  /* On first sign-in we push whatever's in localStorage 'favorites' to
     the server (idempotent merge), then refresh the cabinet list from
     the server's view. Subsequent visits are just a fetch. */
  function syncFavoritesWithServer() {
    var local = [];
    try { local = JSON.parse(localStorage.getItem('favorites') || '[]') || []; } catch (_) {}
    if (Array.isArray(local) && local.length) {
      fetch('/api/me/favorites', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ files: local }),
      })
        .catch(function() {})
        .finally(loadFavs);
    } else {
      loadFavs();
    }
  }

  function loadFavs() {
    var listEl = document.getElementById('meFavs');
    var emptyEl = document.getElementById('meFavsEmpty');
    var loadingEl = document.getElementById('meFavsLoading');
    if (!listEl || !emptyEl || !loadingEl) return;
    loadingEl.hidden = false;
    listEl.hidden = true;
    emptyEl.hidden = true;

    fetch('/api/me/favorites', { credentials: 'same-origin', cache: 'no-store' })
      .then(function(r) { return r.ok ? r.json() : { ok: false, favorites: [] }; })
      .then(function(data) {
        loadingEl.hidden = true;
        var items = (data && data.favorites) || [];
        setStat('meStatFavs', items.length);
        if (typeof updateLibraryCount === 'function') updateLibraryCount();
        if (!items.length) { emptyEl.hidden = false; return; }

        // Mirror the server list back into localStorage so the catalog
        // page can immediately reflect cross-device changes too.
        try {
          var asArr = items.map(function(it) { return it.file; });
          localStorage.setItem('favorites', JSON.stringify(asArr));
        } catch (_) {}

        listEl.innerHTML = items.map(function(it) {
          var meta = bySlug && bySlug[it.file];
          var title = (meta && (meta.catalogTitle || meta.title || meta.filename)) || it.file;
          var docType = meta && meta.docType ? escHtml(meta.docType) : '';
          var subject = meta && meta.subject ? escHtml(meta.subject) : '';
          var size = meta && meta.size ? escHtml(meta.size) : '';
          var added = it.added_at
            ? new Date(it.added_at * 1000).toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' })
            : '';
          var metaLine = [docType, subject].filter(Boolean).join(' · ');
          var docHref = '/doc/' + encodeURI(it.file);
          return '<li class="me-fav-card">' +
                 '<a class="me-fav-card-link" href="' + docHref + '">' +
                   '<h4 class="me-fav-card-title">' + escHtml(title) + '</h4>' +
                   (metaLine ? '<p class="me-fav-card-meta">' + metaLine + '</p>' : '') +
                 '</a>' +
                 '<div class="me-fav-card-foot">' +
                   '<span class="me-fav-card-when">' + (size ? size + ' · ' : '') + (added ? 'добавлено ' + added : '') + '</span>' +
                   '<button type="button" class="me-fav-rm" data-file="' + encodeURIComponent(it.file) + '" aria-label="Убрать из сохранённых">✕</button>' +
                 '</div>' +
                 '</li>';
        }).join('');
        listEl.hidden = false;
      })
      .catch(function() { loadingEl.hidden = true; });
  }

  // Stage 47 — render «Недавно скачано» from /api/me/downloads.
  // Compact rows: «5 мин назад» / «3 дня назад» · title · subject.
  function loadDownloads() {
    var listEl = document.getElementById('meDownloads');
    var emptyEl = document.getElementById('meDownloadsEmpty');
    var loadingEl = document.getElementById('meDownloadsLoading');
    if (!listEl || !emptyEl || !loadingEl) return;
    loadingEl.hidden = false;
    listEl.hidden = true;
    emptyEl.hidden = true;

    fetch('/api/me/downloads', { credentials: 'same-origin', cache: 'no-store' })
      .then(function(r) { return r.ok ? r.json() : { ok: false, downloads: [] }; })
      .then(function(data) {
        loadingEl.hidden = true;
        var items = (data && data.downloads) || [];
        // Augment with title for the timeline before storing.
        window.__meDownloads = items.map(function(it) {
          var meta = bySlug && bySlug[it.file];
          return Object.assign({}, it, {
            title: (meta && (meta.catalogTitle || meta.title || meta.filename)) || it.file,
            last_at: it.downloaded_at,
          });
        });
        updateLibraryCount();
        if (typeof buildActivityTimeline === 'function') buildActivityTimeline();
        if (!items.length) { emptyEl.hidden = false; return; }

        listEl.innerHTML = items.map(function(it) {
          var meta = bySlug && bySlug[it.file];
          var title = (meta && (meta.catalogTitle || meta.title || meta.filename)) || it.file;
          var subject = meta && meta.subject ? escHtml(meta.subject) : '';
          var when = it.downloaded_at ? formatRelativeWhen(it.downloaded_at) : '';
          var docHref = '/doc/' + encodeURI(it.file);
          return '<li class="me-order">' +
                 '<span class="me-order-when">' + escHtml(when) + '</span>' +
                 '<span class="me-order-topic">' +
                   '<a href="' + docHref + '" class="me-dl-link">' + escHtml(title) + '</a>' +
                   (subject ? ' <span class="me-dl-subj">· ' + subject + '</span>' : '') +
                 '</span>' +
                 '</li>';
        }).join('');
        listEl.hidden = false;
      })
      .catch(function() { loadingEl.hidden = true; });
  }

  /* ─── Tab counters: orders, library (favs+downloads+viewed), searches ─── */
  function updateTabCount(elId, n) {
    var el = document.getElementById(elId);
    if (!el) return;
    el.textContent = String(n || 0);
    el.hidden = !n;
  }
  function updateLibraryCount() {
    var favs = Number((document.getElementById('meStatFavs') || {}).textContent || 0);
    var dl = Array.isArray(window.__meDownloads) ? window.__meDownloads.length : 0;
    var viewed = 0;
    try {
      var raw = localStorage.getItem('salon:viewed');
      if (raw) viewed = (JSON.parse(raw) || []).length;
    } catch (_) {}
    updateTabCount('meTabCountLibrary', favs + dl + viewed);
    updateTabCount('meLibCountFavs', isNaN(favs) ? 0 : favs);
    updateTabCount('meLibCountDl', dl);
    updateTabCount('meLibCountView', viewed);
  }

  // «5 мин назад» / «3 дня назад» / «25 апр» — relative when recent,
  // absolute when older than a week.
  function formatRelativeWhen(epoch) {
    var now = Math.floor(Date.now() / 1000);
    var diff = Math.max(0, now - epoch);
    if (diff < 60) return 'только что';
    if (diff < 3600) return Math.floor(diff / 60) + ' мин назад';
    if (diff < 86400) return Math.floor(diff / 3600) + ' ч назад';
    if (diff < 7 * 86400) {
      var d = Math.floor(diff / 86400);
      return d + ' ' + (d === 1 ? 'день' : d < 5 ? 'дня' : 'дней') + ' назад';
    }
    return new Date(epoch * 1000)
      .toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' });
  }

  // Delegated remove handler for the cabinet favourites list.
  document.addEventListener('click', function(e) {
    var btn = e.target && e.target.closest && e.target.closest('.me-fav-rm');
    if (!btn) return;
    var file = decodeURIComponent(btn.getAttribute('data-file') || '');
    if (!file) return;
    fetch('/api/me/favorites', {
      method: 'DELETE',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ file: file }),
    })
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function() {
        // Also drop from localStorage so other tabs / catalog pick it up.
        try {
          var local = JSON.parse(localStorage.getItem('favorites') || '[]') || [];
          local = local.filter(function(f) { return f !== file; });
          localStorage.setItem('favorites', JSON.stringify(local));
        } catch (_) {}
        loadFavs();
      });
  });

  function bootVkButton() {
    var tile = document.querySelector('.me-auth-method[data-me-auth="vk"]');
    var status = tile && tile.querySelector('.me-auth-method-status');
    fetch('/api/me/vk-config', { credentials: 'same-origin', cache: 'no-store' })
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(cfg) {
        if (!tile) return;
        if (cfg && cfg.enabled) {
          tile.removeAttribute('disabled');
          if (status) {
            status.textContent = 'готово';
            status.setAttribute('data-status', 'ready');
          }
        } else {
          markMethodOff(tile, 'недоступно');
        }
      })
      .catch(function() { if (tile) markMethodOff(tile, 'недоступно'); });
  }

  function showAuth() {
    if (cabinet) cabinet.hidden = true;
    if (authSection) authSection.hidden = false;
    try { sessionStorage.removeItem('me:signed-in'); } catch (_) {}
    var navProfile = document.getElementById('navProfile');
    if (navProfile) navProfile.removeAttribute('data-signed-in');
    setupAuthMethodTiles();
    bootTelegramWidget();
    bootVkButton();
  }

  function markMethodOff(tile, label) {
    var status = tile.querySelector('.me-auth-method-status');
    tile.setAttribute('disabled', '');
    if (status) {
      status.textContent = label || 'недоступно';
      status.setAttribute('data-status', 'off');
    }
  }

  /* ─── Auth method tile switching ─── */
  function setupAuthMethodTiles() {
    if (!authSection || authSection.getAttribute('data-me-auth-bound') === 'true') return;
    authSection.setAttribute('data-me-auth-bound', 'true');

    var tiles = Array.prototype.slice.call(
      document.querySelectorAll('.me-auth-method[data-me-auth]')
    );
    var flows = Array.prototype.slice.call(
      document.querySelectorAll('.me-auth-flow[data-me-auth-flow]')
    );

    function activate(method) {
      tiles.forEach(function (t) {
        var on = t.dataset.meAuth === method;
        t.classList.toggle('is-active', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
      });
      flows.forEach(function (f) {
        f.hidden = f.dataset.meAuthFlow !== method;
      });
    }

    tiles.forEach(function (tile) {
      tile.addEventListener('click', function () {
        if (tile.hasAttribute('disabled')) return;
        activate(tile.dataset.meAuth);
      });
    });

    // "Войти по почте" link inside TG fallback note
    document.querySelectorAll('.me-link-btn[data-me-auth]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        activate(btn.getAttribute('data-me-auth'));
      });
    });
  }

  /* Telegram Login Widget — fetched lazily, only when the auth screen
     is shown (i.e. user isn't already signed in). The widget itself is
     a third-party iframe; we expose `onTelegramAuth` on window so the
     widget's data-onauth callback can find it. */
  var tgWidgetBooted = false;
  function bootTelegramWidget() {
    if (tgWidgetBooted) return;
    tgWidgetBooted = true;
    var tile = document.querySelector('.me-auth-method[data-me-auth="telegram"]');
    var status = tile && tile.querySelector('.me-auth-method-status');

    fetch('/api/me/telegram-config', { credentials: 'same-origin', cache: 'no-store' })
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(cfg) {
        if (!cfg || !cfg.enabled || !cfg.botUsername) {
          if (tile) markMethodOff(tile, 'недоступно');
          return;
        }
        var slot = document.getElementById('meTgWidget');
        if (!slot) return;
        var script = document.createElement('script');
        script.async = true;
        script.src = 'https://telegram.org/js/telegram-widget.js?22';
        script.setAttribute('data-telegram-login', cfg.botUsername);
        script.setAttribute('data-size', 'large');
        script.setAttribute('data-radius', '12');
        script.setAttribute('data-userpic', 'false');
        script.setAttribute('data-onauth', 'onTelegramAuth(user)');
        slot.appendChild(script);

        if (tile) {
          tile.removeAttribute('disabled');
          if (status) {
            status.textContent = 'готово';
            status.setAttribute('data-status', 'ready');
          }
        }

        // If Telegram doesn't manage to mount its iframe within 5s
        // (most often: domain not yet registered via /setdomain in
        // BotFather), surface a soft fallback so the empty box doesn't
        // look broken.
        window.setTimeout(function() {
          var iframe = slot.querySelector('iframe');
          if (iframe) return;
          var fallback = document.getElementById('meTgFallback');
          if (fallback) fallback.hidden = false;
        }, 5000);
      })
      .catch(function() {
        if (tile) markMethodOff(tile, 'недоступно');
      });
  }

  // Global handler the Telegram widget calls back into.
  window.onTelegramAuth = function(user) {
    fetch('/api/me/telegram-login', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(user),
    })
      .then(function(r) {
        return r.json().catch(function() { return {}; }).then(function(data) {
          data = data || {};
          data.__status = r.status;
          data.__requestId = r.headers.get('x-request-id') || data.requestId || '';
          if (!r.ok) data.ok = false;
          return data;
        });
      })
      .then(function(data) {
        if (data && data.ok) {
          showToast('Вы вошли через Telegram.', 'success', 3000);
          // Reload so the cabinet renders with the fresh whoami.
          window.location.replace('/me?ok=1');
        } else {
          var detail = data && data.detail;
          var msg = (data && data.error) ||
            (detail && (detail.error || detail.message)) ||
            (data && data.message) ||
            (data && data.__status === 429 ? 'Слишком много попыток входа. Попробуйте немного позже.' : '') ||
            'Не удалось войти через Telegram. Попробуйте по почте.';
          var reqId = data && (data.requestId || data.__requestId);
          showToast(reqId ? msg + ' Код: ' + reqId : msg, 'error', 6500);
        }
      })
      .catch(function() {
        showToast('Связь с сервером прервалась. Попробуйте ещё раз.', 'error', 4500);
      });
  };

  // Map raw status → human label + timeline step (0/1/2).
  // Step 0 = «Принята», 1 = «В работе», 2 = «Готова».
  var STATUS_META = {
    'new':         { lbl: 'Принята',   step: 0, active: true  },
    'in_work':     { lbl: 'В работе',  step: 1, active: true  },
    'in_progress': { lbl: 'В работе',  step: 1, active: true  },
    'done':        { lbl: 'Готова',    step: 2, active: false },
    'completed':   { lbl: 'Готова',    step: 2, active: false },
    'cancelled':   { lbl: 'Отменена',  step: -1, active: false },
    'rejected':    { lbl: 'Отклонена', step: -1, active: false },
  };

  function escHtml(s) { return String(s == null ? '' : s).replace(/[<>&"]/g, function(c) {
    return ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;'})[c]; }); }

  function renderActiveOrderCard(o) {
    var meta = STATUS_META[o.status] || STATUS_META['new'];
    var step = meta.step >= 0 ? meta.step : 0;
    var when = new Date((o.created_at || 0) * 1000)
      .toLocaleDateString('ru-RU', { day: 'numeric', month: 'short', year: 'numeric' });
    var topic = escHtml(o.topic || o.work_type || 'Заявка');
    var workType = escHtml(o.work_type || '');
    var subject = escHtml(o.subject || '');
    var deadline = o.deadline ? escHtml(o.deadline) : '';

    var tlSteps = ['Принята', 'В работе', 'Готова'].map(function(label, i) {
      var cls = i < step ? 'me-tl-step me-tl-done'
              : i === step ? 'me-tl-step me-tl-current'
              : 'me-tl-step';
      return '<div class="' + cls + '">' +
             '<span class="me-tl-dot" aria-hidden="true"></span>' +
             '<span class="me-tl-lbl">' + label + '</span>' +
             '</div>';
    }).join('<div class="me-tl-bar" aria-hidden="true"></div>');

    var tgText = encodeURIComponent(
      'Здравствуйте! У меня вопрос по заявке № ' + (o.id || '?') +
      ' от ' + when + ' (' + topic + '): '
    );
    var tgHref = 'https://t.me/academicsaloon?text=' + tgText;

    var repeatQs = [
      o.work_type ? 'type=' + encodeURIComponent(o.work_type) : '',
      o.subject   ? 'subject=' + encodeURIComponent(o.subject) : '',
      o.topic     ? 'topic=' + encodeURIComponent(o.topic) : '',
    ].filter(Boolean).join('&');
    var repeatHref = '/order' + (repeatQs ? '?' + repeatQs : '');

    var metaLine = [
      o.id ? 'Заявка №' + escHtml(o.id) : '',
      'от ' + when,
      workType,
      subject,
      deadline ? 'дедлайн ' + deadline : '',
    ].filter(Boolean).join(' · ');

    return '<article class="me-active" data-order-id="' + (o.id || '') + '">' +
      '<header class="me-active-head">' +
        '<span class="me-active-eyebrow">' + meta.lbl + '</span>' +
        '<h3 class="me-active-topic">' + topic + '</h3>' +
        '<p class="me-active-meta">' + metaLine + '</p>' +
      '</header>' +
      '<div class="me-active-timeline" aria-label="Статус заявки">' + tlSteps + '</div>' +
      '<div class="me-active-foot">' +
        '<a href="' + tgHref + '" class="btn btn-gold btn-sm" target="_blank" rel="noopener">Написать по&nbsp;заказу</a>' +
        '<a href="' + repeatHref + '" class="me-link-btn">Повторить заказ</a>' +
        '<button type="button" class="me-link-btn me-msgs-toggle" data-msgs-toggle="' + (o.id || '') + '">Сообщения</button>' +
      '</div>' +
      '<details class="me-msgs" data-msgs="' + (o.id || '') + '" hidden>' +
        '<summary class="me-msgs-summary">Чат по заявке №' + (o.id || '') + '</summary>' +
        '<ol class="me-msgs-list" data-msgs-list></ol>' +
        '<form class="me-msgs-form" data-msgs-form>' +
          '<textarea class="me-msgs-input" data-msgs-input rows="2" placeholder="Напишите вопрос куратору…" maxlength="4000"></textarea>' +
          '<button type="submit" class="me-msgs-send">Отправить</button>' +
        '</form>' +
      '</details>' +
    '</article>';
  }

  function renderHistoryRow(o) {
    var when = new Date((o.created_at || 0) * 1000)
      .toLocaleDateString('ru-RU', { day: 'numeric', month: 'short', year: 'numeric' });
    var topic = escHtml(o.topic || o.work_type || 'Заявка');
    var meta = STATUS_META[o.status] || { lbl: o.status || 'new', step: -1 };
    var statusClass = (o.status || 'new').replace(/[^a-z_]/g, '');

    var repeatQs = [
      o.work_type ? 'type=' + encodeURIComponent(o.work_type) : '',
      o.subject   ? 'subject=' + encodeURIComponent(o.subject) : '',
      o.topic     ? 'topic=' + encodeURIComponent(o.topic) : '',
    ].filter(Boolean).join('&');
    var repeatHref = '/order' + (repeatQs ? '?' + repeatQs : '');

    return '<li class="me-order">' +
           '<span class="me-order-when">' + when + '</span>' +
           '<span class="me-order-topic">' + topic + '</span>' +
           '<span class="me-order-status me-order-status--' + statusClass + '">' + escHtml(meta.lbl) + '</span>' +
           '<a class="me-order-repeat" href="' + repeatHref + '" aria-label="Повторить заказ">↻</a>' +
           '</li>';
  }

  function loadOrders() {
    if (!ordersList || !ordersEmpty || !ordersLoading) return;
    ordersLoading.hidden = false;
    ordersList.hidden = true;
    ordersEmpty.hidden = true;
    var activeBox = document.getElementById('meActiveOrders');
    if (activeBox) { activeBox.hidden = true; activeBox.innerHTML = ''; }

    fetch('/api/me/orders', { credentials: 'same-origin' })
      .then(function(r) { return r.ok ? r.json() : { ok: false, orders: [] }; })
      .then(function(data) {
        ordersLoading.hidden = true;
        var items = (data && data.orders) || [];
        window.__meOrders = items;
        setStat('meStatOrders', items.length);
        updateTabCount('meTabCountOrders', items.length);
        if (typeof buildActivityTimeline === 'function') buildActivityTimeline();

        // Earliest order date → "with us since".
        var earliest = items.reduce(function(m, o) {
          var t = o && o.created_at;
          return (t && (!m || t < m)) ? t : m;
        }, 0);
        setStat('meStatSince', formatSinceDate(earliest));

        // Split active vs everything else.
        var active = [];
        var history = [];
        items.forEach(function(o) {
          var meta = STATUS_META[o.status] || STATUS_META['new'];
          (meta.active ? active : history).push(o);
        });

        // Active orders rise to the top as hero cards (most recent first).
        if (active.length && activeBox) {
          activeBox.innerHTML = active
            .slice()
            .sort(function(a, b) { return (b.created_at || 0) - (a.created_at || 0); })
            .map(renderActiveOrderCard)
            .join('');
          activeBox.hidden = false;
        }

        // History: compact rows. If there's no history but there ARE
        // active orders, suppress the empty state — it would feel
        // contradictory next to a giant active card above.
        if (!history.length) {
          if (!active.length) ordersEmpty.hidden = false;
          return;
        }
        ordersList.innerHTML = history.map(renderHistoryRow).join('');
        ordersList.hidden = false;
      })
      .catch(function() {
        ordersLoading.hidden = true;
      });
  }

  /* Surface ?err= or ?ok= flags from /api/me/verify redirects. */
  (function flashUrlMessages() {
    var params = new URLSearchParams(window.location.search);
    var err = params.get('err');
    var ok = params.get('ok');
    if (err) {
      var copy = {
        token:        'Ссылка повреждена. Запросите новую.',
        unknown:      'Эта ссылка не найдена. Возможно, она уже устарела.',
        used:         'Эта ссылка уже использована. Запросите новую.',
        expired:      'Срок действия ссылки истёк. Запросите новую.',
        vk_state:     'Сессия входа через ВКонтакте устарела. Попробуйте ещё раз.',
        vk_token:     'ВКонтакте не вернул токен. Попробуйте ещё раз.',
        vk_config:    'Вход через ВКонтакте временно недоступен.',
        vk_session:   'Не удалось создать сессию. Попробуйте ещё раз.',
      }[err] || 'Не удалось войти. Попробуйте ещё раз.';
      showToast(copy, 'error', 4500);
    } else if (ok === '1') {
      showToast('Вы вошли в кабинет.', 'success', 3000);
    }
    if (err || ok) {
      var clean = window.location.pathname + window.location.hash;
      window.history.replaceState({}, '', clean);
    }
  })();

  /* Initial whoami check — hides the form if already signed in. */
  fetch('/api/me/whoami', { credentials: 'same-origin', cache: 'no-store' })
    .then(function(r) { return r.ok ? r.json() : { loggedIn: false }; })
    .then(function(data) {
      if (data && data.loggedIn) showCabinet(data);
      else showAuth();
    })
    .catch(function() { showAuth(); });

  if (logoutBtn) {
    logoutBtn.addEventListener('click', function() {
      fetch('/api/me/logout', { method: 'POST', credentials: 'same-origin' })
        .finally(function() { window.location.reload(); });
    });
  }

  /* ══════ 1. MAGIC-LINK FORM ══════ */
  var form = document.getElementById('meForm');
  var input = document.getElementById('meContact');
  var submit = document.getElementById('meSubmit');
  var status = document.getElementById('meStatus');

  function setStatus(msg, kind) {
    status.textContent = msg;
    status.className = 'me-form-status ' + (kind ? 'is-' + kind : '');
    status.hidden = !msg;
  }

  function detectChannel(value) {
    var v = (value || '').trim();
    if (!v) return null;
    if (/^@?[a-zA-Z0-9_]{4,32}$/.test(v)) return 'telegram';
    if (/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) return 'email';
    return null;
  }

  if (form && input && submit) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var contact = input.value.trim();
      var channel = detectChannel(contact);
      if (!channel) {
        setStatus('Укажите Telegram (через @) или email.', 'error');
        input.focus();
        return;
      }
      var consentEl = document.getElementById('meConsentPd');
      if (consentEl && !consentEl.checked) {
        setStatus('Подтвердите согласие на обработку персональных данных.', 'error');
        consentEl.focus();
        return;
      }
      submit.setAttribute('aria-busy', 'true');
      setStatus('Отправляем ссылку…');
      track('me_link_request', { channel: channel });

      fetch('/api/me/request-link', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contact: contact,
          consent_pd: !!(consentEl && consentEl.checked),
        }),
      })
        .then(function(r) {
          return r.json().catch(function() {
            return { ok: false, status: r.status };
          }).then(function(data) {
            return { data: data, status: r.status };
          });
        })
        .then(function(res) {
          submit.removeAttribute('aria-busy');
          var data = res.data || {};
          if (data.ok) {
            if (data.auto || data.session || data.loggedIn) {
              setStatus('Входим в кабинет…', 'success');
              window.location.replace('/me?ok=1');
              return;
            }
            var where = channel === 'telegram' ? 'в Telegram' : 'на email';
            setStatus(
              'Заявка принята — куратор пришлёт вход ' + where +
              ' в течение часа в рабочее время.',
              'success'
            );
            input.value = '';
            return;
          }
          if (res.status === 429) {
            setStatus('Слишком много заявок с этого устройства. Попробуйте через час.', 'error');
            return;
          }
          var msg = (data.detail && data.detail.error) ||
                    'Не удалось отправить заявку. Напишите в Telegram — @academicsaloon.';
          setStatus(msg, 'error');
        })
        .catch(function() {
          submit.removeAttribute('aria-busy');
          setStatus('Связь с сервером прервалась. Напишите в Telegram — @academicsaloon.', 'error');
        });
    });
  }

  /* ══════ 2. SAVED (favorites) ══════ */
  function renderList(listEl, emptyEl, items, buildRow) {
    if (!items.length) {
      emptyEl.hidden = false;
      listEl.hidden = true;
      listEl.innerHTML = '';
      return;
    }
    emptyEl.hidden = true;
    listEl.hidden = false;
    listEl.innerHTML = items.map(buildRow).join('');
  }

  function typeLabel(docType) {
    var map = {
      'Выпускная квалификационная работа': 'ВКР',
      'Курсовая работа': 'Курсовая',
      'Самостоятельная работа': 'Самостоят.',
      'Контрольная работа': 'Контрольная',
      'Отчет по практике': 'Отчёт',
      'Методические материалы': 'Методичка',
      'Экзаменационные материалы': 'Экзамен',
      'Отчет о научно-практической работе': 'НПР',
    };
    return map[docType] || docType || 'Документ';
  }

  function esc(s) {
    return String(s || '').replace(/[&<>"']/g, function(c) {
      return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c];
    });
  }

  var favsList = document.getElementById('meFavsList');
  var favsEmpty = document.getElementById('meFavsEmpty');

  function renderFavs() {
    var raw = [];
    try { raw = JSON.parse(localStorage.getItem('favorites') || '[]'); } catch (_) {}
    var items = raw.map(function(file, i) {
      var d = bySlug[file];
      if (!d) return null;
      var title = d.catalogTitle || d.title || d.filename || 'Документ';
      return { file: file, title: title, subject: d.subject || '', type: typeLabel(d.docType), i: i };
    }).filter(Boolean);
    renderList(favsList, favsEmpty, items, function(item) {
      return (
        '<a href="/doc/' + encodeURI(item.file) + '" class="me-list-row">' +
          '<span class="rr-no">№&nbsp;' + String(item.i + 1).padStart(2, '0') + '</span>' +
          '<span class="rr-title">' + esc(item.title) + '</span>' +
          '<span class="rr-meta">' + esc(item.type) + '</span>' +
          '<button type="button" class="rr-rm" data-file="' + esc(item.file) + '" aria-label="Убрать">×</button>' +
        '</a>'
      );
    });
    /* Remove listeners */
    favsList.querySelectorAll('.rr-rm').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault(); e.stopPropagation();
        var file = btn.dataset.file;
        var favs = [];
        try { favs = JSON.parse(localStorage.getItem('favorites') || '[]'); } catch (_) {}
        favs = favs.filter(function(f) { return f !== file; });
        localStorage.setItem('favorites', JSON.stringify(favs));
        track('me_favorite_remove', { file: file });
        renderFavs();
      });
    });
  }
  renderFavs();

  /* ══════ 3. HISTORY ══════ */
  var histList = document.getElementById('meHistList');
  var histEmpty = document.getElementById('meHistEmpty');

  function renderHist() {
    var raw = [];
    try { raw = JSON.parse(localStorage.getItem('viewHistory') || '[]'); } catch (_) {}
    var items = raw.slice(0, 15).map(function(h, i) {
      var file = (h && h.file || '').replace(/^\/doc\//, '').replace(/\/$/, '');
      var d = bySlug[file];
      var title = (d && (d.catalogTitle || d.title || d.filename)) || h.title || 'Документ';
      var subject = d && d.subject ? d.subject : '';
      return { file: file, title: title, subject: subject, type: d ? typeLabel(d.docType) : '', i: i, path: h.file };
    });
    renderList(histList, histEmpty, items, function(item) {
      return (
        '<a href="' + (item.path || '/doc/' + encodeURI(item.file)) + '" class="me-list-row">' +
          '<span class="rr-no">№&nbsp;' + String(item.i + 1).padStart(2, '0') + '</span>' +
          '<span class="rr-title">' + esc(item.title) + '</span>' +
          '<span class="rr-meta">' + esc(item.type) + '</span>' +
          '<span class="rr-rm" aria-hidden="true">→</span>' +
        '</a>'
      );
    });
  }
  renderHist();

  /* ══════ 4. DRAFT ORDER ══════ */
  var draftEmpty = document.getElementById('meDraftEmpty');
  var draftCard = document.getElementById('meDraftCard');
  var draftType = document.getElementById('meDraftType');
  var draftDate = document.getElementById('meDraftDate');
  var draftTopic = document.getElementById('meDraftTopic');
  var draftClear = document.getElementById('meDraftClear');

  function renderDraft() {
    var raw = null;
    try { raw = JSON.parse(localStorage.getItem('academic-salon:draft:order') || 'null'); } catch (_) {}
    if (!raw || !raw.values) {
      draftEmpty.hidden = false;
      draftCard.hidden = true;
      return;
    }
    var v = raw.values || {};
    var topic = v.topic || v.fTopic || v.Тема || 'Черновик без темы';
    var type = v.type || v.workType || '—';
    var typeMap = { kurs_t: 'Курсовая', diplom: 'ВКР', kont: 'Контрольная', ref: 'Реферат' };
    draftType.textContent = typeMap[type] || type;
    draftDate.textContent = raw.savedAt ? new Date(raw.savedAt).toLocaleDateString('ru-RU') : '';
    draftTopic.textContent = topic;
    draftEmpty.hidden = true;
    draftCard.hidden = false;
  }
  renderDraft();

  if (draftClear) {
    draftClear.addEventListener('click', function() {
      localStorage.removeItem('academic-salon:draft:order');
      track('me_draft_clear');
      renderDraft();
    });
  }
})();
</script>
