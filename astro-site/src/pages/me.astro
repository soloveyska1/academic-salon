---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';
import { buildDocHref } from '../utils/doc-links.ts';

// Compact index: only fields needed to render cabinet rows.
// file is the stable key matching localStorage['favorites'] entries.
const DOC_INDEX = (D as any[]).map((d: any) => ({
  f: d.file,
  t: d.catalogTitle || d.title || d.filename || d.file,
  s: d.subject || '',
  dt: d.docType || '',
  c: d.category || '',
}));
---

<Base
  title="Кабинет · Академический Салон"
  description="Личный кабинет без регистрации — сохранённые работы, история просмотров."
  currentPath="/me"
>
  <section class="me-page" aria-label="Кабинет">
    <div class="me-wrap">
      <!-- ═══════ MASTHEAD ═══════ -->
      <header class="me-mast">
        <span class="me-numeral" aria-hidden="true">V</span>
        <span class="me-eyebrow">Кабинет · без регистрации</span>
        <h1 class="me-title">Ваш<br /><em>золотой ряд</em></h1>
        <p class="me-sub">
          Всё, что вы отметили звездой и что недавно открывали — только в этом браузере.
          Позже — войдите через VK или Telegram, и кабинет привяжется к аккаунту.
        </p>
        <div class="me-rule" aria-hidden="true"></div>
      </header>

      <!-- ═══════ FAVORITES ═══════ -->
      <section class="me-section" data-section="favs" aria-labelledby="favs-h">
        <header class="me-sec-head">
          <div class="me-sec-title">
            <span class="me-sec-icon" aria-hidden="true">★</span>
            <h2 id="favs-h">Сохранённое</h2>
            <span class="me-sec-count" id="favsCount" aria-live="polite">—</span>
          </div>
          <button type="button" class="me-sec-clear" id="favsClear" hidden>
            Очистить
          </button>
        </header>

        <div class="me-list" id="favsList" role="list" aria-busy="true">
          <div class="me-empty" data-state="loading">
            <span class="dots" aria-hidden="true">· · ·</span>
          </div>
        </div>

        <template id="favsEmptyTpl">
          <div class="me-empty" data-state="empty">
            <p class="me-empty-line">Здесь появится ваш <em>золотой ряд</em>.</p>
            <p class="me-empty-sub">Нажмите <span class="me-kbd">★ сохранить</span> на странице любой работы — и она осядет тут.</p>
            <a href="/catalog" class="me-empty-link">К каталогу →</a>
          </div>
        </template>
      </section>

      <!-- ═══════ HISTORY ═══════ -->
      <section class="me-section" data-section="hist" aria-labelledby="hist-h">
        <header class="me-sec-head">
          <div class="me-sec-title">
            <span class="me-sec-icon me-sec-icon--clock" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>
            </span>
            <h2 id="hist-h">Недавно открытые</h2>
            <span class="me-sec-count" id="histCount" aria-live="polite">—</span>
          </div>
          <button type="button" class="me-sec-clear" id="histClear" hidden>
            Очистить
          </button>
        </header>

        <div class="me-list" id="histList" role="list" aria-busy="true">
          <div class="me-empty" data-state="loading"><span class="dots" aria-hidden="true">· · ·</span></div>
        </div>

        <template id="histEmptyTpl">
          <div class="me-empty" data-state="empty">
            <p class="me-empty-line">Пока тихо.</p>
            <p class="me-empty-sub">Откройте любую работу — она появится здесь.</p>
            <a href="/catalog" class="me-empty-link">К каталогу →</a>
          </div>
        </template>
      </section>

      <!-- ═══════ ORDERS SECTION — bound users only ═══════ -->
      <section class="me-section me-orders" aria-labelledby="orders-h" id="ordersSection" hidden>
        <header class="me-sec-head">
          <div class="me-sec-title">
            <span class="me-sec-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            </span>
            <h2 id="orders-h">Заказы</h2>
            <span class="me-sec-count" id="ordersCount">—</span>
          </div>
        </header>
        <div class="me-list" id="ordersList"></div>
        <template id="ordersEmptyTpl">
          <div class="me-empty" data-state="empty">
            <p class="me-empty-line">Заказов пока нет.</p>
            <p class="me-empty-sub">Первый заказ появится тут сразу после отправки.</p>
            <a href="/order" class="me-empty-link">Оформить заказ →</a>
          </div>
        </template>
      </section>

      <!-- ═══════ BIND SECTION — VK ID / Telegram Login ═══════ -->
      <section class="me-section me-bind" aria-labelledby="bind-h" id="bindSection">
        <header class="me-sec-head">
          <div class="me-sec-title">
            <span class="me-sec-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 11V7a5 5 0 0 1 10 0v4"/><rect x="3" y="11" width="18" height="11" rx="2"/></svg>
            </span>
            <h2 id="bind-h">Привязка</h2>
            <span class="me-sec-count" id="bindStatus">—</span>
          </div>
          <button type="button" class="me-sec-clear" id="logoutBtn" hidden>Выйти</button>
        </header>

        <!-- Loading / unbound / bound — JS swaps these -->
        <div class="me-bind-body" id="bindBody">
          <div class="me-empty" data-state="loading"><span class="dots" aria-hidden="true">· · ·</span></div>
        </div>

        <template id="bindUnboundTpl">
          <p class="me-bind-lead">
            Нажмите — и ваш <em>золотой ряд</em> будет с вами с любого устройства.
            Без паролей и писем.
          </p>
          <div class="me-bind-buttons">
            <button type="button" class="me-bind-btn me-bind-btn--vk" id="vkLoginBtn" disabled>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.785 16.241s.288-.032.435-.194c.135-.149.131-.428.131-.428s-.018-1.284.572-1.472c.582-.185 1.329 1.235 2.121 1.781.599.413 1.054.322 1.054.322l2.117-.03s1.107-.069.582-.943c-.043-.072-.306-.648-1.576-1.829-1.329-1.234-1.151-1.034.45-3.18.976-1.306 1.366-2.103 1.244-2.444-.116-.325-.838-.239-.838-.239l-2.383.015s-.177-.024-.308.054c-.128.077-.211.255-.211.255s-.378 1.01-.882 1.868c-1.063 1.812-1.488 1.908-1.662 1.795-.405-.263-.304-1.054-.304-1.615 0-1.754.266-2.486-.515-2.675-.259-.063-.45-.104-1.113-.111-.85-.009-1.57.003-1.977.202-.272.134-.482.432-.354.449.158.02.515.096.704.354.244.333.236 1.081.236 1.081s.14 2.053-.328 2.309c-.321.175-.762-.183-1.708-1.828-.485-.843-.851-1.774-.851-1.774s-.071-.173-.196-.265c-.152-.112-.365-.147-.365-.147l-2.265.015s-.34.009-.465.157c-.111.132-.009.405-.009.405s1.775 4.152 3.786 6.243c1.845 1.919 3.941 1.793 3.941 1.793h.945z"/></svg>
              <span>Войти через VK</span>
            </button>

            <div class="me-bind-btn-wrap" id="tgLoginWrap">
              <button type="button" class="me-bind-btn me-bind-btn--tg" id="tgLoginBtn" disabled>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21.5 2.5L2 10l7 3 3 7 9.5-18zm-2.3 2.3l-7.9 14.8-2.2-5.1 10.1-9.7zm-8.9 8.1L4 10.9l14.3-5.5L10.3 12.9z"/></svg>
                <span>Войти через Telegram</span>
              </button>
              <!-- TG widget script injected here when enabled -->
            </div>
          </div>

          <p class="me-bind-foot" id="bindFoot">
            Ни один пароль не передаётся. <strong>VK</strong> и <strong>Telegram</strong> сами подтверждают, что это вы.
          </p>
        </template>

        <template id="bindBoundTpl">
          <div class="me-bound">
            <div class="me-bound-avatar" id="boundAvatar" aria-hidden="true">АС</div>
            <div class="me-bound-meta">
              <span class="me-bound-prov" id="boundProvider">—</span>
              <span class="me-bound-handle" id="boundHandle">—</span>
            </div>
            <div class="me-bound-extra" id="boundExtra"></div>
          </div>
        </template>
      </section>

      <!-- ═══════ FOOTER / DEVICE ID ═══════ -->
      <footer class="me-foot">
        <div class="me-foot-row">
          <span class="me-foot-k">Кабинет</span>
          <span class="me-foot-v" id="deviceIdVal">—</span>
        </div>
        <p class="me-foot-note">
          Пока без регистрации — всё хранится в этом браузере.
          Привязка выше подтянет кабинет на других устройствах.
        </p>
      </footer>
    </div>
  </section>
</Base>

<script>
  import {
    getDeviceId,
    listFavorites, removeFavorite, clearFavorites,
    listHistory, removeHistory, clearHistory,
    onChange,
  } from '../scripts/account.ts';

  // Catalog lookup — built at compile time, embedded once per page.
  // We attach it to window so the script chunk stays small and the data
  // blob lives in a single inline <script type="application/json"> block.
  const lookup: Record<string, { t: string; s: string; dt: string; c: string }> = {};

  function hydrateLookup() {
    const el = document.getElementById('me-doc-index');
    if (!el || !el.textContent) return;
    try {
      const arr = JSON.parse(el.textContent) as Array<{ f: string; t: string; s: string; dt: string; c: string }>;
      for (const row of arr) lookup[row.f] = { t: row.t, s: row.s, dt: row.dt, c: row.c };
    } catch {}
  }

  function buildDocHref(filePath: string): string {
    const n = String(filePath || '').trim();
    if (!n) return '/catalog';
    return `/doc?file=${encodeURIComponent(n)}`;
  }

  function escape(str: string): string {
    return String(str).replace(/[&<>"']/g, s => (
      { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[s] || s
    ));
  }

  function formatRelative(ts: number): string {
    const diff = Date.now() - ts;
    const mins = Math.round(diff / 60000);
    if (mins < 1) return 'только что';
    if (mins < 60) return mins + ' мин назад';
    const hours = Math.round(mins / 60);
    if (hours < 24) return hours + ' ч назад';
    const days = Math.round(hours / 24);
    if (days === 1) return 'вчера';
    if (days < 7) return days + ' дн назад';
    const d = new Date(ts);
    return d.toLocaleDateString('ru-RU', { day: '2-digit', month: 'short' });
  }

  function renderFavs() {
    const listEl = document.getElementById('favsList');
    const countEl = document.getElementById('favsCount');
    const clearBtn = document.getElementById('favsClear') as HTMLButtonElement | null;
    if (!listEl || !countEl) return;

    const favs = listFavorites();
    countEl.textContent = favs.length ? String(favs.length).padStart(2, '0') : '00';
    listEl.setAttribute('aria-busy', 'false');

    if (!favs.length) {
      const tpl = document.getElementById('favsEmptyTpl') as HTMLTemplateElement | null;
      listEl.innerHTML = '';
      if (tpl) listEl.appendChild(tpl.content.cloneNode(true));
      if (clearBtn) clearBtn.hidden = true;
      return;
    }

    if (clearBtn) clearBtn.hidden = false;
    listEl.innerHTML = favs.map((file, i) => {
      const info = lookup[file];
      const title = info?.t || file.replace(/^files\//, '').replace(/\.[a-z0-9]+$/i, '');
      const meta = [info?.s, info?.dt].filter(Boolean).join(' · ');
      const num = String(i + 1).padStart(2, '0');
      return `
        <article class="me-row" role="listitem" data-file="${escape(file)}">
          <span class="me-row-n" aria-hidden="true">${num}</span>
          <a class="me-row-main" href="${escape(buildDocHref(file))}">
            <span class="me-row-title">${escape(title)}</span>
            ${meta ? `<span class="me-row-meta">${escape(meta)}</span>` : ''}
          </a>
          <button type="button" class="me-row-x" data-action="unfav" data-file="${escape(file)}" aria-label="Убрать из сохранённого">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
        </article>
      `;
    }).join('');
  }

  function renderHist() {
    const listEl = document.getElementById('histList');
    const countEl = document.getElementById('histCount');
    const clearBtn = document.getElementById('histClear') as HTMLButtonElement | null;
    if (!listEl || !countEl) return;

    const hist = listHistory();
    countEl.textContent = hist.length ? String(hist.length).padStart(2, '0') : '00';
    listEl.setAttribute('aria-busy', 'false');

    if (!hist.length) {
      const tpl = document.getElementById('histEmptyTpl') as HTMLTemplateElement | null;
      listEl.innerHTML = '';
      if (tpl) listEl.appendChild(tpl.content.cloneNode(true));
      if (clearBtn) clearBtn.hidden = true;
      return;
    }

    if (clearBtn) clearBtn.hidden = false;
    listEl.innerHTML = hist.map((h, i) => {
      const num = String(i + 1).padStart(2, '0');
      const title = h.title || h.file;
      const rel = formatRelative(h.time);
      return `
        <article class="me-row me-row--hist" role="listitem" data-file="${escape(h.file)}">
          <span class="me-row-n" aria-hidden="true">${num}</span>
          <a class="me-row-main" href="${escape(h.file)}">
            <span class="me-row-title">${escape(title)}</span>
            <span class="me-row-meta me-row-meta--time">${escape(rel)}</span>
          </a>
          <button type="button" class="me-row-x" data-action="unhist" data-file="${escape(h.file)}" aria-label="Убрать из истории">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
        </article>
      `;
    }).join('');
  }

  let unsubAccount: (() => void) | null = null;

  function wire() {
    hydrateLookup();

    // Device ID footer
    const devEl = document.getElementById('deviceIdVal');
    if (devEl) {
      const id = getDeviceId();
      devEl.textContent = '#' + id.slice(0, 8).toUpperCase();
      devEl.title = id;
    }

    renderFavs();
    renderHist();

    // Event delegation for remove buttons
    const page = document.querySelector('.me-page');
    if (page && !(page as any).__bound) {
      (page as any).__bound = true;
      page.addEventListener('click', (ev) => {
        const t = ev.target as HTMLElement;
        const btn = t.closest('button[data-action]') as HTMLButtonElement | null;
        if (!btn) return;
        const action = btn.dataset.action;
        const file = btn.dataset.file || '';
        if (action === 'unfav' && file) {
          ev.preventDefault();
          removeFavorite(file);
          renderFavs();
        } else if (action === 'unhist' && file) {
          ev.preventDefault();
          removeHistory(file);
          renderHist();
        }
      });
    }

    const favsClear = document.getElementById('favsClear');
    favsClear?.addEventListener('click', () => {
      if (confirm('Убрать все сохранённые работы?')) {
        clearFavorites();
        renderFavs();
      }
    });
    const histClear = document.getElementById('histClear');
    histClear?.addEventListener('click', () => {
      if (confirm('Очистить историю просмотров?')) {
        clearHistory();
        renderHist();
      }
    });

    // Cross-tab / cross-page reactivity
    if (unsubAccount) unsubAccount();
    unsubAccount = onChange((ch) => {
      if (ch === 'favorites') renderFavs();
      if (ch === 'history') renderHist();
    });

    // Auth section (VK + TG)
    wireBindSection();
  }

  // ═══════ AUTH / BIND SECTION ═══════
  interface AuthConfig {
    tg: { enabled: boolean; botName: string | null };
    vk: { enabled: boolean; appId: string | null };
  }
  interface AuthMe {
    authenticated: boolean;
    user?: {
      id: number;
      deviceId: string | null;
      vk: { id: string; handle: string | null; name: string | null; avatar: string | null } | null;
      tg: { id: string; handle: string | null; name: string | null; avatar: string | null } | null;
    };
  }

  let authCfg: AuthConfig | null = null;

  async function wireBindSection() {
    try {
      // If we came back from VK OAuth with ?code=... handle it first
      await maybeHandleVkCallback();

      // Fetch config + current session in parallel
      const [cfgRes, meRes] = await Promise.all([
        fetch('/api/auth/config', { credentials: 'same-origin' }).then(r => r.json()).catch(() => null),
        fetch('/api/auth/me', { credentials: 'same-origin' }).then(r => r.json()).catch(() => null),
      ]);
      authCfg = (cfgRes && cfgRes.ok) ? (cfgRes as AuthConfig) : { tg: { enabled: false, botName: null }, vk: { enabled: false, appId: null } };
      const me: AuthMe = (meRes && meRes.ok) ? (meRes as AuthMe) : { authenticated: false };

      renderBindSection(me);
    } catch (err) {
      renderBindSection({ authenticated: false });
    }
  }

  function renderBindSection(me: AuthMe) {
    const body = document.getElementById('bindBody');
    const status = document.getElementById('bindStatus');
    const logoutBtn = document.getElementById('logoutBtn') as HTMLButtonElement | null;
    if (!body || !status) return;

    if (me.authenticated && me.user) {
      const tpl = document.getElementById('bindBoundTpl') as HTMLTemplateElement | null;
      body.innerHTML = '';
      if (tpl) body.appendChild(tpl.content.cloneNode(true));

      const provider = me.user.vk ? 'vk' : (me.user.tg ? 'tg' : null);
      const info = provider === 'vk' ? me.user.vk : me.user.tg;
      const providerLabel = provider === 'vk' ? 'VK' : 'Telegram';
      const handle = info?.handle ? '@' + info.handle : (info?.name || '—');
      const avatar = document.getElementById('boundAvatar');
      const provEl = document.getElementById('boundProvider');
      const handleEl = document.getElementById('boundHandle');
      if (provEl) provEl.textContent = providerLabel;
      if (handleEl) handleEl.textContent = handle;
      if (avatar && info?.avatar) {
        avatar.innerHTML = '';
        const img = document.createElement('img');
        img.src = info.avatar;
        img.alt = '';
        img.loading = 'lazy';
        avatar.appendChild(img);
      }

      // If both providers are bound, mention it
      const extra = document.getElementById('boundExtra');
      if (extra && me.user.vk && me.user.tg) {
        extra.textContent = '+ Привязаны оба канала';
      }

      status.textContent = 'Привязано';
      if (logoutBtn) {
        logoutBtn.hidden = false;
        logoutBtn.onclick = onLogoutClick;
      }
      renderOrders(true);
      return;
    }

    renderOrders(false);
    // Not authenticated → show buttons
    const tpl = document.getElementById('bindUnboundTpl') as HTMLTemplateElement | null;
    body.innerHTML = '';
    if (tpl) body.appendChild(tpl.content.cloneNode(true));
    status.textContent = 'не привязано';
    if (logoutBtn) logoutBtn.hidden = true;

    const foot = document.getElementById('bindFoot');

    // Wire VK button
    const vkBtn = document.getElementById('vkLoginBtn') as HTMLButtonElement | null;
    if (vkBtn) {
      if (authCfg?.vk.enabled && authCfg.vk.appId) {
        vkBtn.disabled = false;
        vkBtn.onclick = () => startVkOAuth(authCfg!.vk.appId!);
      } else {
        vkBtn.disabled = true;
        vkBtn.title = 'VK-вход ещё не настроен на сервере';
      }
    }

    // Wire TG widget
    const tgWrap = document.getElementById('tgLoginWrap');
    const tgBtn = document.getElementById('tgLoginBtn') as HTMLButtonElement | null;
    if (tgWrap && authCfg?.tg.enabled && authCfg.tg.botName) {
      // Replace our placeholder button with the official widget iframe
      if (tgBtn) tgBtn.remove();
      injectTelegramWidget(tgWrap, authCfg.tg.botName);
      (window as any).onTelegramAuth = handleTelegramAuth;
    } else if (tgBtn) {
      tgBtn.disabled = true;
      tgBtn.title = 'Telegram-вход ещё не настроен на сервере';
    }

    // If neither provider is enabled, show a gentler note
    if (!authCfg?.vk.enabled && !authCfg?.tg.enabled && foot) {
      foot.innerHTML = 'Входы ещё не подключены на сервере. Кабинет пока живёт локально в браузере.';
    }
  }

  function injectTelegramWidget(wrap: HTMLElement, botName: string) {
    // Remove any previous widget (during re-render)
    Array.from(wrap.querySelectorAll('script[data-tg-widget]')).forEach(s => s.remove());
    const s = document.createElement('script');
    s.async = true;
    s.src = 'https://telegram.org/js/telegram-widget.js?22';
    s.setAttribute('data-telegram-login', botName);
    s.setAttribute('data-size', 'large');
    s.setAttribute('data-radius', '8');
    s.setAttribute('data-onauth', 'onTelegramAuth(user)');
    s.setAttribute('data-request-access', 'write');
    s.setAttribute('data-tg-widget', '1');
    wrap.appendChild(s);
  }

  function startVkOAuth(appId: string) {
    const redirectUri = window.location.origin + '/me';
    const state = Math.random().toString(36).slice(2, 12);
    try { sessionStorage.setItem('vk-oauth-state', state); } catch {}
    const params = new URLSearchParams({
      client_id: appId,
      redirect_uri: redirectUri,
      display: 'page',
      scope: 'email',
      response_type: 'code',
      v: '5.131',
      state,
    });
    window.location.href = 'https://oauth.vk.com/authorize?' + params.toString();
  }

  async function maybeHandleVkCallback() {
    const url = new URL(window.location.href);
    const code = url.searchParams.get('code');
    const state = url.searchParams.get('state');
    if (!code) return;

    // Verify state
    try {
      const saved = sessionStorage.getItem('vk-oauth-state');
      if (saved && state && saved !== state) return;
      sessionStorage.removeItem('vk-oauth-state');
    } catch {}

    // Clean URL early so reloads don't re-trigger
    url.searchParams.delete('code');
    url.searchParams.delete('state');
    window.history.replaceState({}, '', url.pathname + (url.search ? '?' + url.searchParams.toString() : ''));

    try {
      const res = await fetch('/api/auth/vk', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          code,
          redirect_uri: window.location.origin + '/me',
          device_id: getDeviceId(),
        }),
      });
      if (!res.ok) throw new Error(String(res.status));
      toast('Привязано через VK', 'success');
    } catch (err) {
      toast('Не получилось войти через VK', 'error');
    }
  }

  async function handleTelegramAuth(user: any) {
    if (!user || !user.id) return;
    try {
      const payload = { ...user, device_id: getDeviceId() };
      const res = await fetch('/api/auth/tg', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error(String(res.status));
      toast('Привязано через Telegram', 'success');
      // Re-render bound state
      const meRes = await fetch('/api/auth/me', { credentials: 'same-origin' }).then(r => r.json()).catch(() => null);
      renderBindSection((meRes && meRes.ok) ? meRes as AuthMe : { authenticated: false });
    } catch (err) {
      toast('Не получилось войти через Telegram', 'error');
    }
  }

  async function onLogoutClick() {
    try {
      await fetch('/api/auth/logout', { method: 'POST', credentials: 'same-origin' });
    } catch {}
    renderBindSection({ authenticated: false });
    toast('Привязка снята', 'info');
  }

  function toast(msg: string, kind: 'success' | 'error' | 'info' = 'info') {
    const fn = (window as any).showToast;
    if (typeof fn === 'function') fn(msg, kind, 2800);
  }

  // ═══════ ORDERS SECTION ═══════
  interface OrderRow { id: number; topic: string | null; work_type: string | null; deadline: string | null; status: string | null; created_at: number; }

  const STATUS_LABELS: Record<string, string> = {
    new: 'Принята',
    in_progress: 'В работе',
    ready: 'Готова',
    done: 'Закрыта',
    cancelled: 'Отменена',
  };

  async function renderOrders(authenticated: boolean) {
    const section = document.getElementById('ordersSection');
    const listEl = document.getElementById('ordersList');
    const countEl = document.getElementById('ordersCount');
    if (!section || !listEl || !countEl) return;

    if (!authenticated) {
      section.hidden = true;
      return;
    }
    section.hidden = false;

    listEl.setAttribute('aria-busy', 'true');
    listEl.innerHTML = '<div class="me-empty" data-state="loading"><span class="dots" aria-hidden="true">· · ·</span></div>';

    let orders: OrderRow[] = [];
    try {
      const res = await fetch('/api/auth/me/orders', { credentials: 'same-origin' });
      const data = await res.json();
      if (data && data.ok && Array.isArray(data.orders)) orders = data.orders;
    } catch (_) {}

    countEl.textContent = orders.length ? String(orders.length).padStart(2, '0') : '00';
    listEl.setAttribute('aria-busy', 'false');

    if (!orders.length) {
      const tpl = document.getElementById('ordersEmptyTpl') as HTMLTemplateElement | null;
      listEl.innerHTML = '';
      if (tpl) listEl.appendChild(tpl.content.cloneNode(true));
      return;
    }

    listEl.innerHTML = orders.map((o, i) => {
      const num = String(i + 1).padStart(2, '0');
      const title = (o.topic || o.work_type || 'Без темы').trim();
      const statusKey = (o.status || 'new').toLowerCase();
      const statusLabel = STATUS_LABELS[statusKey] || statusKey;
      const dateStr = o.created_at ? new Date(o.created_at * 1000).toLocaleDateString('ru-RU', { day: '2-digit', month: 'short' }) : '';
      const meta = [dateStr, o.deadline].filter(Boolean).join(' · ');
      return `
        <article class="me-row me-row--order" role="listitem" data-status="${escape(statusKey)}">
          <span class="me-row-n" aria-hidden="true">${num}</span>
          <div class="me-row-main">
            <span class="me-row-title">${escape(title)}</span>
            ${meta ? `<span class="me-row-meta">${escape(meta)}</span>` : ''}
          </div>
          <span class="me-order-status" data-status="${escape(statusKey)}">${escape(statusLabel)}</span>
        </article>
      `;
    }).join('');
  }

  wire();
  document.addEventListener('astro:before-swap', () => {
    if (unsubAccount) { unsubAccount(); unsubAccount = null; }
  });
  document.addEventListener('astro:after-swap', () => {
    // Re-init when navigated via view transitions
    if (window.location.pathname === '/me' || window.location.pathname === '/me/') wire();
  });
</script>

