---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

/* Для рендера сохранённых работ нам нужны мета-данные по слагам — строим мапу. */
const bySlug: Record<string, any> = {};
for (const d of D as any[]) {
  if (d && d.file) bySlug[d.file] = d;
}
---

<Base
  title="Кабинет — Академический Салон"
  description="Личный кабинет: магическая ссылка в Telegram или на email, сохранённые работы и история."
  currentPath="/me"
  noindex
>

  <article class="me-folio">

    <nav class="me-crumb" aria-label="Навигация">
      <a href="/">Салон</a>
      <span class="sep" aria-hidden="true">›</span>
      <span class="current">Кабинет</span>
    </nav>

    <div class="me-intro" id="meIntro">
      <p class="me-eyebrow">
        <span class="roman" aria-hidden="true">§</span>
        <span>Один тап — и&nbsp;вы&nbsp;в&nbsp;кабинете</span>
      </p>

      <h1 class="me-title">Войти — <em class="it">в&nbsp;один&nbsp;тап</em></h1>

      <p class="me-lede">
        Без&nbsp;паролей и&nbsp;долгих анкет. Войдите через Telegram&nbsp;— и&nbsp;увидите свои заявки, статусы работ и&nbsp;избранное. Мы&nbsp;запоминаем только ваш контакт, чтобы вернуть вас в&nbsp;тот&nbsp;же кабинет на&nbsp;любом устройстве.
      </p>

      <hr class="me-hairline" aria-hidden="true" />
    </div>

    <!-- ══════ Signed-in cabinet (hidden until /api/me/whoami says yes) ══════ -->
    <section class="me-section me-cabinet" id="meCabinet" hidden aria-label="Личный кабинет">
      <div class="me-cab-greet">
        <div class="me-cab-greet-text">
          <span class="eyebrow">Кабинет</span>
          <h2>Здравствуйте,&nbsp;<span id="meCabinetContact" class="me-cab-contact">—</span></h2>
        </div>
        <a href="/order" class="me-cab-cta" aria-label="Новый заказ">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          <span>Новый&nbsp;заказ</span>
        </a>
      </div>

      <!-- Active orders rise to the top as hero cards. Renders only
           when the cabinet has at least one order with status
           new / in_work. -->
      <div class="me-active-orders" id="meActiveOrders" hidden></div>

      <div class="me-cab-stats" role="group" aria-label="Сводка кабинета">
        <div class="me-stat">
          <span class="me-stat-n" id="meStatOrders">·</span>
          <span class="me-stat-l">заявок</span>
        </div>
        <div class="me-stat">
          <span class="me-stat-n" id="meStatFavs">·</span>
          <span class="me-stat-l">в&nbsp;избранном</span>
        </div>
        <div class="me-stat">
          <span class="me-stat-n" id="meStatSince">·</span>
          <span class="me-stat-l">с&nbsp;нами</span>
        </div>
      </div>

      <div class="me-orders-block">
        <h3 class="me-h3">История заявок</h3>
        <ol class="me-orders" id="meOrders" hidden></ol>
        <p class="me-orders-empty" id="meOrdersEmpty" hidden>Заявок пока нет — <a href="/order">оставьте первую</a>.</p>
        <p class="me-orders-loading" id="meOrdersLoading">Загружаем…</p>
      </div>

      <div class="me-orders-block">
        <h3 class="me-h3">Избранное</h3>
        <ol class="me-favs" id="meFavs" hidden></ol>
        <p class="me-orders-empty" id="meFavsEmpty" hidden>Ничего не сохранено — <a href="/catalog">откройте архив</a> и нажмите&nbsp;★ на работе.</p>
        <p class="me-orders-loading" id="meFavsLoading">Загружаем…</p>
      </div>

      <!-- Settings block — учётная запись + выход. Внизу, потому что
           это редко-используемое: один раз посмотреть и забыть. -->
      <div class="me-account">
        <h3 class="me-h3">Учётная запись</h3>
        <dl class="me-account-list">
          <div class="me-account-row">
            <dt>Контакт</dt>
            <dd id="meAcctContact">—</dd>
          </div>
          <div class="me-account-row">
            <dt>Канал входа</dt>
            <dd id="meAcctChannel">—</dd>
          </div>
        </dl>
        <button type="button" class="me-cab-logout" id="meLogoutBtn" aria-label="Выйти из кабинета">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          <span>Выйти</span>
        </button>
      </div>
    </section>

    <!-- Sticky FAB for new order on mobile only — visible on /me when
         signed in (because that's where you'd want to start a new
         order quickly). Hidden on desktop where the greet-row already
         has a CTA. -->
    <a href="/order" class="me-fab" id="meFab" aria-label="Новый заказ" hidden>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </a>

    <!-- ══════ 1. AUTH ══════ -->
    <section class="me-section" aria-label="Войти" id="meAuthSection">
      <header class="me-section-head">
        <span class="idx" aria-hidden="true">I</span>
        <div>
          <span class="eyebrow">Войти в кабинет</span>
          <h2>Через Telegram, VK или почту</h2>
        </div>
      </header>

      <!-- Telegram Login Widget — лучший канал для российского пользователя.
           Виджет инжектируется JS, как только /api/me/telegram-config
           подтвердит, что бот настроен (botUsername + setdomain в @BotFather). -->
      <div class="me-auth-tg" id="meTgWrap" hidden>
        <p class="me-auth-tg-lbl">Самый быстрый вход — один тап:</p>
        <div class="me-auth-row">
          <div id="meTgWidget" class="me-tg-widget"></div>
          <a id="meVkBtn" class="me-vk-btn" href="/api/me/vk-start" hidden>
            <svg class="me-vk-logo" viewBox="0 0 32 32" aria-hidden="true">
              <path fill="currentColor" d="M16.51 22.5h1.32s.4-.04.6-.27c.19-.2.18-.59.18-.59s-.02-1.81.81-2.07c.82-.26 1.87 1.74 2.99 2.51.85.58 1.49.46 1.49.46l3-.04s1.57-.1.83-1.34c-.06-.1-.43-.92-2.21-2.59-1.87-1.74-1.62-1.46.62-4.45 1.36-1.81 1.91-2.92 1.74-3.39-.16-.45-1.16-.33-1.16-.33l-3.36.02s-.25-.03-.43.08c-.18.11-.3.36-.3.36s-.53 1.41-1.24 2.61c-1.5 2.53-2.1 2.66-2.34 2.5-.57-.36-.43-1.47-.43-2.26 0-2.46.37-3.49-.73-3.75-.36-.09-.63-.14-1.56-.15-1.19-.01-2.19.01-2.76.29-.38.18-.68.6-.5.62.22.03.71.13.97.49.34.46.33 1.49.33 1.49s.19 2.85-.46 3.21c-.45.24-1.06-.25-2.4-2.55-.69-1.18-1.21-2.49-1.21-2.49s-.1-.24-.28-.37c-.21-.16-.51-.21-.51-.21l-3.19.02s-.48.01-.66.22c-.16.18-.01.57-.01.57s2.5 5.83 5.32 8.78c2.59 2.7 5.53 2.52 5.53 2.52z"/>
            </svg>
            <span class="me-vk-lbl">Войти через ВКонтакте</span>
          </a>
        </div>
        <p class="me-auth-tg-fallback" id="meTgFallback" hidden>
          Кнопка Telegram не загрузилась — войдите по&nbsp;почте ниже.
        </p>
        <p class="me-auth-tg-hint">Или по&nbsp;почте — ниже.</p>
      </div>

      <form class="me-form" id="meForm" novalidate>
        <label class="me-field">
          <span class="me-field-lbl">Telegram или email</span>
          <input
            type="text"
            name="contact"
            id="meContact"
            placeholder="@username или you@mail.ru"
            autocomplete="off"
            required
          />
          <span class="me-field-hint">Только чтобы отправить ссылку. Не спамим, не продаём, не храним пароли.</span>
        </label>

        <div class="me-form-actions">
          <button type="submit" class="btn btn-gold me-submit" id="meSubmit">
            <span class="me-submit-lbl">Прислать ссылку</span>
            <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 7h10m-3-3l3 3-3 3"/></svg>
          </button>
        </div>

        <div class="me-form-status" id="meStatus" hidden></div>
      </form>
    </section>

    <hr class="me-hairline" aria-hidden="true" />

    <!-- ══════ 2. SAVED DOCS (localStorage) ══════ -->
    <section class="me-section" aria-label="Сохранённые работы">
      <header class="me-section-head">
        <span class="idx" aria-hidden="true">II</span>
        <div>
          <span class="eyebrow">На этом устройстве</span>
          <h2>Сохранённые <em class="it">работы</em></h2>
        </div>
      </header>

      <div id="meFavsEmpty" class="me-empty">
        Пока пусто. На любой карточке в&nbsp;каталоге нажмите&nbsp;★ — работа осядет здесь.
      </div>

      <ol id="meFavsList" class="me-list" hidden></ol>
    </section>

    <hr class="me-hairline" aria-hidden="true" />

    <!-- ══════ 3. RECENT VIEWS ══════ -->
    <section class="me-section" aria-label="Недавно смотрели">
      <header class="me-section-head">
        <span class="idx" aria-hidden="true">III</span>
        <div>
          <span class="eyebrow">Ваш путь по архиву</span>
          <h2>Недавно <em class="it">смотрели</em></h2>
        </div>
      </header>

      <div id="meHistEmpty" class="me-empty">
        История чиста. Откройте что-нибудь из&nbsp;<a href="/catalog">каталога</a>.
      </div>

      <ol id="meHistList" class="me-list" hidden></ol>
    </section>

    <hr class="me-hairline" aria-hidden="true" />

    <!-- ══════ 4. DRAFT ORDER ══════ -->
    <section class="me-section" aria-label="Черновик заказа">
      <header class="me-section-head">
        <span class="idx" aria-hidden="true">IV</span>
        <div>
          <span class="eyebrow">Не отправленный</span>
          <h2>Черновик <em class="it">заказа</em></h2>
        </div>
      </header>

      <div id="meDraftEmpty" class="me-empty">
        Черновика нет. Если начнёте заполнять <a href="/order">заказ</a>, он сохранится здесь.
      </div>

      <div id="meDraftCard" class="me-draft" hidden>
        <div class="me-draft-head">
          <span class="me-draft-type" id="meDraftType">—</span>
          <span class="me-draft-date" id="meDraftDate">—</span>
        </div>
        <p class="me-draft-topic" id="meDraftTopic">—</p>
        <div class="me-draft-actions">
          <a href="/order" class="btn btn-gold btn-sm">Продолжить</a>
          <button type="button" class="me-link-btn" id="meDraftClear">Стереть черновик</button>
        </div>
      </div>
    </section>

    <hr class="me-hairline" aria-hidden="true" />

    <!-- ══════ 5. DIRECT-TG FALLBACK ══════ -->
    <aside class="me-cta">
      <span class="me-cta-glyph" aria-hidden="true">⁘</span>
      <div class="me-cta-body">
        <h3>Не хотите ждать ссылку?</h3>
        <p>Напишите нам&nbsp;в&nbsp;Telegram или ВКонтакте — разберёмся с&nbsp;вашим заказом в&nbsp;любой форме, без&nbsp;кабинета и&nbsp;паролей.</p>
      </div>
      <div class="me-cta-links">
        <a href="https://t.me/academicsaloon" class="me-link" target="_blank" rel="noopener">Telegram</a>
        <a href="https://vk.com/academicsaloon" class="me-link" target="_blank" rel="noopener">ВКонтакте</a>
      </div>
    </aside>

  </article>

</Base>

<style is:global>
  .me-folio {
    max-width: 820px;
    margin: 0 auto;
    padding: clamp(24px, 4vw, 48px) clamp(20px, 4vw, 32px) clamp(64px, 8vw, 96px);
    color: var(--t1);
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 2vw, 22px);
  }

  .me-folio .me-crumb {
    display: flex; align-items: center; gap: 10px;
    font-family: var(--fm); font-size: 10px;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--t3);
    margin: 0 0 clamp(16px, 2.5vw, 28px);
  }
  .me-folio .me-crumb a { color: var(--t3); text-decoration: none; transition: color .3s var(--ease-ios); }
  .me-folio .me-crumb a:hover { color: var(--ac); }
  .me-folio .me-crumb .sep { color: var(--ac); opacity: .6; }
  .me-folio .me-crumb .current { color: var(--t1); }

  .me-folio .me-eyebrow {
    margin: 0;
    font-family: var(--fm);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ac);
    display: inline-flex; align-items: center; gap: 12px;
  }
  .me-folio .me-eyebrow .roman { color: var(--ac); opacity: .6; font-size: 14px; }

  .me-folio .me-title {
    font-family: var(--fd);
    font-weight: 400;
    font-size: clamp(32px, 4.8vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0;
  }
  .me-folio .me-title em, .me-folio .me-title .it { font-style: italic; color: var(--ac); }

  .me-folio .me-lede {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.55;
    color: var(--t2);
    margin: 0;
    max-width: 62ch;
  }

  .me-folio .me-hairline {
    border: 0; height: 1px;
    background: linear-gradient(90deg, transparent, var(--ac-line, rgba(212,175,55,.22)) 20%, var(--ac-line, rgba(212,175,55,.22)) 80%, transparent);
    margin: clamp(8px, 1.5vw, 16px) 0;
  }

  /* Section */
  .me-folio .me-section {
    display: flex; flex-direction: column;
    gap: clamp(14px, 2vw, 20px);
  }
  /* CSS display rules above override the browser's default [hidden]
     style — re-assert it explicitly so JS-controlled visibility works. */
  .me-folio .me-section[hidden] { display: none; }
  .me-folio .me-section-head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 18px;
    align-items: end;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--brd);
    position: relative;
  }
  .me-folio .me-section-head::after {
    content: "";
    position: absolute;
    left: 0; bottom: -1px;
    width: 40px; height: 1px;
    background: var(--ac);
  }
  .me-folio .me-section-head .idx {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(32px, 4vw, 56px);
    line-height: .8;
    color: var(--ac);
  }
  .me-folio .me-section-head .eyebrow {
    display: block;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--t3);
    margin-bottom: 4px;
  }
  .me-folio .me-section-head h2 {
    font-family: var(--fd);
    font-weight: 400;
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--t1);
    margin: 0;
  }
  .me-folio .me-section-head h2 em,
  .me-folio .me-section-head h2 .it { font-style: italic; color: var(--ac); }

  /* Form */
  .me-folio .me-form { display: flex; flex-direction: column; gap: 16px; max-width: 520px; }
  .me-folio .me-field { display: flex; flex-direction: column; gap: 6px; }
  .me-folio .me-field-lbl {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--t3);
  }
  .me-folio .me-field input {
    font-family: var(--fd);
    font-size: 18px;
    padding: 12px 0;
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--brd);
    color: var(--t1);
    outline: none;
    transition: border-color .3s var(--ease-ios);
  }
  .me-folio .me-field input:focus { border-bottom-color: var(--ac); }
  .me-folio .me-field-hint {
    font-family: var(--fd);
    font-style: italic;
    font-size: 13px;
    color: var(--t3);
    line-height: 1.5;
  }
  .me-folio .me-form-actions { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  .me-folio .me-submit { display: inline-flex; align-items: center; gap: 10px; padding: 14px 24px; }
  .me-folio .me-submit svg { width: 13px; height: 13px; }
  .me-folio .me-submit[aria-busy="true"] { opacity: .7; pointer-events: none; }
  .me-folio .me-form-status {
    font-family: var(--fd);
    font-size: 15px;
    line-height: 1.5;
    color: var(--t2);
    padding: 12px 0;
  }
  .me-folio .me-form-status.is-success { color: var(--ac); }
  .me-folio .me-form-status.is-error { color: #e8a7a7; }

  /* Empty state */
  .me-folio .me-empty {
    font-family: var(--fd);
    font-style: italic;
    font-size: 15px;
    color: var(--t3);
    line-height: 1.6;
    max-width: 58ch;
  }
  .me-folio .me-empty a { color: var(--ac); text-decoration: none; border-bottom: 1px solid var(--ac-line, rgba(212,175,55,.22)); }
  .me-folio .me-empty a:hover { color: var(--ac2); border-bottom-color: var(--ac); }

  /* List — editorial rows */
  .me-folio .me-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .me-folio .me-list-row {
    display: grid;
    grid-template-columns: 56px 1fr auto auto;
    gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--brd);
    text-decoration: none;
    align-items: baseline;
    position: relative;
    transition: background .35s var(--ease-ios);
  }
  .me-folio .me-list-row::before {
    content: "";
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    background: var(--ac);
    transform: scaleY(0);
    transition: transform .4s var(--ease-ios);
  }
  .me-folio .me-list-row:hover::before { transform: scaleY(1); }
  .me-folio .me-list-row:hover .rr-title { color: var(--ac); transform: translateX(4px); }
  .me-folio .me-list-row .rr-no {
    font-family: var(--fm); font-size: 10px;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--t3); font-feature-settings: "tnum";
  }
  .me-folio .me-list-row .rr-title {
    font-family: var(--fd);
    font-size: clamp(15px, 1.3vw, 17px);
    color: var(--t1);
    line-height: 1.35;
    transition: color .35s, transform .35s var(--ease-ios);
  }
  .me-folio .me-list-row .rr-meta {
    font-family: var(--fm); font-size: 10px;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ac);
  }
  .me-folio .me-list-row .rr-rm {
    font-family: var(--fm); font-size: 10px;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--t3);
    background: transparent; border: 0;
    padding: 4px 6px;
    cursor: pointer;
    transition: color .25s var(--ease-ios);
  }
  .me-folio .me-list-row .rr-rm:hover { color: var(--ac); }

  /* Draft card */
  .me-folio .me-draft {
    padding: 20px 22px;
    border-left: 1px solid var(--ac);
    background: var(--bg2);
    display: flex; flex-direction: column; gap: 12px;
  }
  .me-folio .me-draft-head {
    display: flex; justify-content: space-between; align-items: baseline;
    font-family: var(--fm); font-size: 10px;
    letter-spacing: 0.2em; text-transform: uppercase;
  }
  .me-folio .me-draft-head .me-draft-type { color: var(--ac); }
  .me-folio .me-draft-head .me-draft-date { color: var(--t3); }
  .me-folio .me-draft-topic {
    font-family: var(--fd);
    font-size: 17px;
    line-height: 1.45;
    color: var(--t1);
    margin: 0;
  }
  .me-folio .me-draft-actions { display: flex; gap: 20px; align-items: center; flex-wrap: wrap; }
  .me-folio .me-link-btn {
    background: transparent; border: 0; cursor: pointer;
    font-family: var(--fm); font-size: 10px;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--t3);
    padding: 6px 0;
    border-bottom: 1px solid transparent;
    transition: color .25s, border-color .25s;
  }
  .me-folio .me-link-btn:hover { color: var(--ac); border-bottom-color: var(--ac); }

  /* Direct-TG fallback */
