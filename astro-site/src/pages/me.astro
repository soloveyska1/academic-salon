---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

/* Для рендера сохранённых работ нам нужны мета-данные по слагам — строим мапу. */
const bySlug: Record<string, any> = {};
for (const d of D as any[]) {
  if (d && d.file) bySlug[d.file] = d;
}
---

<Base
  title="Кабинет — Академический Салон"
  description="Личный кабинет: магическая ссылка в Telegram или на email, сохранённые работы и история."
  currentPath="/me"
  noindex
>

  <article class="me-folio">

    <nav class="me-crumb" aria-label="Навигация">
      <a href="/">Салон</a>
      <span class="sep" aria-hidden="true">›</span>
      <span class="current">Кабинет</span>
    </nav>

    <div class="me-intro" id="meIntro">
      <p class="me-eyebrow">
        <span class="roman" aria-hidden="true">§</span>
        <span>Вход в&nbsp;кабинет</span>
      </p>

      <h1 class="me-title">Войти — <em class="it">без&nbsp;пароля</em></h1>

      <p class="me-lede">
        Один клик через Telegram или ВКонтакте, либо ссылка на&nbsp;email. Без анкет и&nbsp;паролей — мы&nbsp;запоминаем только контакт, чтобы вернуть вас в&nbsp;кабинет на&nbsp;любом устройстве.
      </p>

      <hr class="me-hairline" aria-hidden="true" />
    </div>

    <!-- ══════ Signed-in cabinet (hidden until /api/me/whoami says yes) ══════ -->
    <section class="me-section me-cabinet" id="meCabinet" hidden aria-label="Личный кабинет">

      <!-- ── Hero: avatar (initials gradient) + контакт + действия ── -->
      <header class="me-hero">
        <div class="me-hero-id">
          <div class="me-avatar" id="meAvatar" aria-hidden="true">
            <span class="me-avatar-initials" id="meAvatarInitials">—</span>
          </div>
          <div class="me-hero-meta">
            <span class="eyebrow">Личный кабинет</span>
            <h1 class="me-hero-name">
              <span id="meCabinetContact" class="me-cab-contact">—</span>
            </h1>
            <p class="me-hero-since" id="meHeroSince" hidden></p>
          </div>
        </div>
        <div class="me-hero-actions">
          <a href="/order" class="me-cab-cta" aria-label="Новый заказ">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            <span>Новый&nbsp;заказ</span>
          </a>
          <button type="button" class="me-cab-logout" id="meLogoutBtn" aria-label="Выйти из кабинета">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            <span>Выйти</span>
          </button>
        </div>
      </header>

      <!-- ── Tab nav: Обзор / Заявки / Архив / Поиски / Профиль ── -->
      <nav class="me-tabs" id="meTabs" aria-label="Разделы кабинета">
        <button type="button" class="me-tab-btn is-active" data-me-tab="overview" aria-current="page">
          <span class="me-tab-name">Обзор</span>
        </button>
        <button type="button" class="me-tab-btn" data-me-tab="orders">
          <span class="me-tab-name">Заявки</span>
          <span class="me-tab-count" id="meTabCountOrders" hidden>0</span>
        </button>
        <button type="button" class="me-tab-btn" data-me-tab="library">
          <span class="me-tab-name">Архив</span>
          <span class="me-tab-count" id="meTabCountLibrary" hidden>0</span>
        </button>
        <button type="button" class="me-tab-btn" data-me-tab="searches">
          <span class="me-tab-name">Поиски</span>
          <span class="me-tab-count" id="meTabCountSearches" hidden>0</span>
        </button>
        <button type="button" class="me-tab-btn" data-me-tab="profile">
          <span class="me-tab-name">Профиль</span>
        </button>
      </nav>

      <!-- ═════ OVERVIEW ═════ -->
      <section class="me-tab-panel" data-me-panel="overview">
        <!-- Stats первый ряд: заявки / избранное / срок -->
        <div class="me-cab-stats" role="group" aria-label="Сводка кабинета">
          <div class="me-stat">
            <span class="me-stat-n" id="meStatOrders">·</span>
            <span class="me-stat-l">заявок</span>
          </div>
          <div class="me-stat">
            <span class="me-stat-n" id="meStatFavs">·</span>
            <span class="me-stat-l">в&nbsp;избранном</span>
          </div>
          <div class="me-stat">
            <span class="me-stat-n" id="meStatSince">·</span>
            <span class="me-stat-l">с&nbsp;нами</span>
          </div>
        </div>

        <!-- Активные заявки (статусы new / in_work) — наверх, как hero-карточка -->
        <div class="me-active-orders" id="meActiveOrders" hidden></div>

        <!-- Quick actions: 3 крупные плитки -->
        <div class="me-quick" aria-label="Быстрые действия">
          <a href="/order" class="me-quick-card">
            <span class="me-quick-glyph" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            </span>
            <span class="me-quick-body">
              <span class="me-quick-title">Новая заявка</span>
              <span class="me-quick-sub">Без звонков, цифры в калькуляторе</span>
            </span>
          </a>
          <a href="/catalog" class="me-quick-card">
            <span class="me-quick-glyph" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </span>
            <span class="me-quick-body">
              <span class="me-quick-title">Найти работу</span>
              <span class="me-quick-sub">235+ работ, фильтры по предметам</span>
            </span>
          </a>
          <button type="button" class="me-quick-card" data-me-go-tab="profile">
            <span class="me-quick-glyph" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            </span>
            <span class="me-quick-body">
              <span class="me-quick-title">Поделиться</span>
              <span class="me-quick-sub">Друг получит вашу метку</span>
            </span>
          </button>
        </div>

        <!-- Activity timeline — единая лента из orders + downloads + favs + views -->
        <article class="me-timeline" id="meTimeline" hidden>
          <header class="me-panel-head">
            <h2 class="me-panel-h">Лента <em class="it">активности</em></h2>
          </header>
          <ol class="me-timeline-list" id="meTimelineList"></ol>
        </article>
      </section>

      <!-- ═════ ORDERS ═════ -->
      <section class="me-tab-panel" data-me-panel="orders" hidden>
        <header class="me-panel-head">
          <h2 class="me-panel-h">Все <em class="it">заявки</em></h2>
          <a href="/order" class="me-panel-cta">Новая заявка <span aria-hidden="true">→</span></a>
        </header>
        <div class="me-orders-block">
          <ol class="me-orders" id="meOrders" hidden></ol>
          <p class="me-orders-empty" id="meOrdersEmpty" hidden>Заявок пока нет — <a href="/order">оставьте первую</a>.</p>
          <div class="me-skel" id="meOrdersLoading" aria-hidden="true">
            <div class="me-skel-row"><span class="me-skel-bar me-skel-bar--xs"></span><span class="me-skel-bar me-skel-bar--md"></span><span class="me-skel-bar me-skel-bar--xs"></span></div>
            <div class="me-skel-row"><span class="me-skel-bar me-skel-bar--xs"></span><span class="me-skel-bar me-skel-bar--lg"></span><span class="me-skel-bar me-skel-bar--xs"></span></div>
          </div>
        </div>
      </section>

      <!-- ═════ LIBRARY (избранное / скачанные / просмотренные) ═════ -->
      <section class="me-tab-panel" data-me-panel="library" hidden>
        <header class="me-panel-head">
          <h2 class="me-panel-h">Моя <em class="it">библиотека</em></h2>
        </header>
        <nav class="me-sub-tabs" id="meLibTabs" aria-label="Подразделы архива">
          <button type="button" class="me-sub-tab is-active" data-me-lib="favs">
            Избранное <span class="me-sub-tab-count" id="meLibCountFavs" hidden>0</span>
          </button>
          <button type="button" class="me-sub-tab" data-me-lib="downloads">
            Скачанные <span class="me-sub-tab-count" id="meLibCountDl" hidden>0</span>
          </button>
          <button type="button" class="me-sub-tab" data-me-lib="viewed">
            Просмотренные <span class="me-sub-tab-count" id="meLibCountView" hidden>0</span>
          </button>
        </nav>

        <section class="me-lib-section" data-me-lib-panel="favs">
          <ol class="me-favs" id="meFavs" hidden></ol>
          <p class="me-orders-empty" id="meFavsEmpty" hidden>Ничего не сохранено — <a href="/catalog">откройте архив</a> и нажмите&nbsp;★ на работе.</p>
          <div class="me-skel me-skel--cards" id="meFavsLoading" aria-hidden="true">
            <div class="me-skel-card"><span class="me-skel-bar me-skel-bar--md"></span><span class="me-skel-bar me-skel-bar--sm"></span></div>
            <div class="me-skel-card"><span class="me-skel-bar me-skel-bar--lg"></span><span class="me-skel-bar me-skel-bar--sm"></span></div>
          </div>
        </section>

        <section class="me-lib-section" data-me-lib-panel="downloads" hidden>
          <ol class="me-orders" id="meDownloads" hidden></ol>
          <p class="me-orders-empty" id="meDownloadsEmpty" hidden>Пока ничего не скачивали — <a href="/catalog">откройте архив</a>, скачайте работу, и она появится здесь.</p>
          <div class="me-skel" id="meDownloadsLoading" aria-hidden="true" hidden>
            <div class="me-skel-row"><span class="me-skel-bar me-skel-bar--xs"></span><span class="me-skel-bar me-skel-bar--md"></span></div>
            <div class="me-skel-row"><span class="me-skel-bar me-skel-bar--xs"></span><span class="me-skel-bar me-skel-bar--lg"></span></div>
          </div>
        </section>

        <section class="me-lib-section" data-me-lib-panel="viewed" hidden>
          <div id="meRecentBlock"></div>
        </section>
      </section>

      <!-- ═════ SEARCHES ═════ -->
      <section class="me-tab-panel" data-me-panel="searches" hidden>
        <header class="me-panel-head">
          <h2 class="me-panel-h">Сохранённые <em class="it">поиски</em></h2>
        </header>
        <div class="me-orders-block" id="meSavedSearchesBlock" hidden>
          <ul class="me-saved-list" id="meSavedList" role="list"></ul>
        </div>
        <p class="me-orders-empty" id="meSavedEmpty">
          Откройте <a href="/catalog">каталог</a>, добавьте фильтры и нажмите «Сохранить» — поиск появится здесь.
        </p>
      </section>

      <!-- ═════ PROFILE ═════ -->
      <section class="me-tab-panel" data-me-panel="profile" hidden>
        <header class="me-panel-head">
          <h2 class="me-panel-h">Учётная <em class="it">запись</em></h2>
        </header>

        <article class="me-profile-card">
          <dl class="me-account-list">
            <div class="me-account-row">
              <dt>Контакт</dt>
              <dd id="meAcctContact">—</dd>
            </div>
            <div class="me-account-row">
              <dt>Канал входа</dt>
              <dd id="meAcctChannel">—</dd>
            </div>
          </dl>
        </article>

        <!-- Stage 58 — referral block. Поднят сюда из подвала. -->
        <article class="me-referral" id="meReferral" hidden>
          <h3 class="me-h3">Поделиться с друзьями</h3>
          <p class="me-referral-lede">
            Расскажите однокурснику — мы&nbsp;узнаем, что он пришёл по&nbsp;вашей рекомендации, и&nbsp;запомним. Бонусы — по&nbsp;договорённости.
          </p>
          <div class="me-referral-row">
            <span class="me-referral-code" id="meReferralCode">——————</span>
            <button type="button" class="me-referral-copy" id="meReferralCopy">Скопировать ссылку</button>
          </div>
          <p class="me-referral-attr" id="meReferralAttr" hidden></p>
        </article>
      </section>
    </section>

    <!-- Sticky FAB for new order on mobile only — visible on /me when
         signed in (because that's where you'd want to start a new
         order quickly). Hidden on desktop where the greet-row already
         has a CTA. -->
    <a href="/order" class="me-fab" id="meFab" aria-label="Новый заказ" hidden>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </a>

    <!-- ══════ 1. AUTH — три способа: Telegram / VK / Email ══════ -->
    <section class="me-section me-auth" aria-label="Войти" id="meAuthSection">

      <!-- Method tiles — выбор канала входа. Telegram и ВКонтакте
           становятся active только если backend подтвердил что они
           настроены (см. bootTelegramWidget / bootVkButton ниже). -->
      <div class="me-auth-methods" role="tablist" aria-label="Способ входа">
        <button
          type="button"
          class="me-auth-method me-auth-method--tg"
          data-me-auth="telegram"
          role="tab"
          aria-selected="false"
          disabled
        >
          <span class="me-auth-method-glyph" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2.5L2 10l7 3 3 7 9.5-18z"/><line x1="9" y1="13" x2="13.5" y2="8.5"/></svg>
          </span>
          <span class="me-auth-method-body">
            <span class="me-auth-method-name">Telegram</span>
            <span class="me-auth-method-sub">Один клик</span>
          </span>
          <span class="me-auth-method-status" data-status="pending" aria-hidden="true">проверяем…</span>
        </button>

        <button
          type="button"
          class="me-auth-method me-auth-method--vk"
          data-me-auth="vk"
          role="tab"
          aria-selected="false"
          disabled
        >
          <span class="me-auth-method-glyph" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="currentColor"><path d="M16.51 22.5h1.32s.4-.04.6-.27c.19-.2.18-.59.18-.59s-.02-1.81.81-2.07c.82-.26 1.87 1.74 2.99 2.51.85.58 1.49.46 1.49.46l3-.04s1.57-.1.83-1.34c-.06-.1-.43-.92-2.21-2.59-1.87-1.74-1.62-1.46.62-4.45 1.36-1.81 1.91-2.92 1.74-3.39-.16-.45-1.16-.33-1.16-.33l-3.36.02s-.25-.03-.43.08c-.18.11-.3.36-.3.36s-.53 1.41-1.24 2.61c-1.5 2.53-2.1 2.66-2.34 2.5-.57-.36-.43-1.47-.43-2.26 0-2.46.37-3.49-.73-3.75-.36-.09-.63-.14-1.56-.15-1.19-.01-2.19.01-2.76.29-.38.18-.68.6-.5.62.22.03.71.13.97.49.34.46.33 1.49.33 1.49s.19 2.85-.46 3.21c-.45.24-1.06-.25-2.4-2.55-.69-1.18-1.21-2.49-1.21-2.49s-.1-.24-.28-.37c-.21-.16-.51-.21-.51-.21l-3.19.02s-.48.01-.66.22c-.16.18-.01.57-.01.57s2.5 5.83 5.32 8.78c2.59 2.7 5.53 2.52 5.53 2.52z"/></svg>
          </span>
          <span class="me-auth-method-body">
            <span class="me-auth-method-name">ВКонтакте</span>
            <span class="me-auth-method-sub">Один клик через VK&nbsp;ID</span>
          </span>
          <span class="me-auth-method-status" data-status="pending" aria-hidden="true">проверяем…</span>
        </button>

        <button
          type="button"
          class="me-auth-method me-auth-method--email is-active"
          data-me-auth="email"
          role="tab"
          aria-selected="true"
        >
          <span class="me-auth-method-glyph" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><polyline points="22 6 12 13 2 6"/></svg>
          </span>
          <span class="me-auth-method-body">
            <span class="me-auth-method-name">Почта</span>
            <span class="me-auth-method-sub">Ссылка в&nbsp;email</span>
          </span>
        </button>
      </div>

      <!-- ── Telegram flow ── -->
      <div class="me-auth-flow" data-me-auth-flow="telegram" hidden>
        <div class="me-auth-flow-head">
          <h3 class="me-auth-flow-h">Войти через Telegram</h3>
          <p class="me-auth-flow-lede">
            Нажмите кнопку ниже — Telegram попросит подтверждение, и&nbsp;вы&nbsp;уже в&nbsp;кабинете. Без&nbsp;пароля, без&nbsp;письма.
          </p>
        </div>
        <div class="me-tg-widget-wrap">
          <div id="meTgWidget" class="me-tg-widget"></div>
        </div>
        <p class="me-auth-flow-note" id="meTgFallback" hidden>
          Кнопка не&nbsp;загрузилась — попробуйте <button type="button" class="me-link-btn" data-me-auth="email">войти по&nbsp;почте</button>.
        </p>
      </div>

      <!-- ── VK flow ── -->
      <div class="me-auth-flow" data-me-auth-flow="vk" hidden>
        <div class="me-auth-flow-head">
          <h3 class="me-auth-flow-h">Войти через ВКонтакте</h3>
          <p class="me-auth-flow-lede">
            Откроется страница VK&nbsp;ID — подтвердите доступ, и&nbsp;вернётесь сюда уже залогиненным.
          </p>
        </div>
        <a class="btn btn-gold me-vk-go" href="/api/me/vk-start" id="meVkBtn">
          <span>Перейти в&nbsp;VK&nbsp;ID</span>
          <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 7h10m-3-3l3 3-3 3"/></svg>
        </a>
      </div>

      <!-- ── Email flow (default) ── -->
      <div class="me-auth-flow" data-me-auth-flow="email">
        <div class="me-auth-flow-head">
          <h3 class="me-auth-flow-h">Войти по&nbsp;email</h3>
          <p class="me-auth-flow-lede">
            Пришлём ссылку на&nbsp;вашу почту. Она работает 10&nbsp;минут и&nbsp;только в&nbsp;этом браузере.
          </p>
        </div>

        <ol class="me-auth-stepper" aria-label="Шаги входа по email">
          <li><span class="me-step-n">1</span><span class="me-step-t">Введите email</span></li>
          <li><span class="me-step-n">2</span><span class="me-step-t">Откройте письмо от&nbsp;нас</span></li>
          <li><span class="me-step-n">3</span><span class="me-step-t">Кликните «Войти» — готово</span></li>
        </ol>

        <form class="me-form" id="meForm" novalidate>
          <label class="me-field">
            <span class="me-field-lbl">Email</span>
            <input
              type="email"
              name="contact"
              id="meContact"
              placeholder="you@mail.ru"
              autocomplete="email"
              inputmode="email"
              required
            />
            <span class="me-field-hint">Можно и&nbsp;@telegram-username — пришлём ссылку туда. Спама нет.</span>
          </label>

          <label class="me-consent">
            <input type="checkbox" id="meConsentPd" name="consent_pd" class="me-consent-input" required />
            <span class="me-consent-box" aria-hidden="true">
              <svg viewBox="0 0 12 10" width="12" height="10"><path d="M1 5l3 3 7-7" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span class="me-consent-text">
              Согласен с&nbsp;<a href="/privacy" target="_blank" rel="noopener">обработкой персональных данных</a> для отправки ссылки (152-ФЗ, ст.&nbsp;9).
            </span>
          </label>

          <div class="me-form-actions">
            <button type="submit" class="btn btn-gold me-submit" id="meSubmit">
              <span class="me-submit-lbl">Войти</span>
              <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 7h10m-3-3l3 3-3 3"/></svg>
            </button>
          </div>

          <div class="me-form-status" id="meStatus" hidden></div>
        </form>
      </div>

