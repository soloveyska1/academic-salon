    function formatBytes(size) {
      if (size < 1024) return size + ' B';
      if (size < 1024 * 1024) return (size / 1024).toFixed(1) + ' KB';
      return (size / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function setSubmitStatus(node, message) {
      if (!node) return;
      node.textContent = message || '';
      node.classList.toggle('is-active', Boolean(message));
    }

    function setSubmitMeter(node, percent) {
      if (!node) return;
      var fill = node.querySelector('.submit-meter-fill');
      if (typeof percent !== 'number' || !isFinite(percent)) {
        node.classList.remove('is-active');
        if (fill) fill.style.transform = 'scaleX(0)';
        return;
      }
      var normalized = Math.max(0, Math.min(100, percent));
      node.classList.add('is-active');
      if (fill) fill.style.transform = 'scaleX(' + (normalized / 100) + ')';
    }

    function setSubmitButtonState(button, text, disabled) {
      if (!button) return;
      button.disabled = Boolean(disabled);
      button.classList.toggle('is-loading', Boolean(disabled));
      var label = button.querySelector('.submit-text');
      if (label) label.textContent = text;
    }

    function parseJsonText(text, status) {
      try {
        return JSON.parse(text);
      } catch (err) {
        throw new Error(text || ('HTTP ' + status));
      }
    }

    function postJson(url, payload) {
      return fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload || {}),
      }).then(function(res) {
        return res.text().then(function(text) {
          var data = parseJsonText(text, res.status);
          if (!res.ok || !data || data.ok === false) {
            throw new Error((data && data.error) || text || ('HTTP ' + res.status));
          }
          return data;
        });
      });
    }

    function uploadChunkRequest(url, body, onProgress) {
      return new Promise(function(resolve, reject) {
        var xhr = new XMLHttpRequest();
        xhr.open('POST', url, true);
        xhr.setRequestHeader('Content-Type', 'application/octet-stream');

        xhr.upload.addEventListener('progress', function(event) {
          if (!event.lengthComputable || !onProgress) return;
          onProgress(event.loaded, event.total);
        });

        xhr.onerror = function() {
          reject(new Error('network-error'));
        };

        xhr.onabort = function() {
          reject(new Error('request-aborted'));
        };

        xhr.onload = function() {
          var text = xhr.responseText || '';
          try {
            var data = parseJsonText(text, xhr.status);
            if (xhr.status >= 200 && xhr.status < 300 && data && data.ok !== false) {
              resolve(data);
              return;
            }
            reject(new Error((data && data.error) || text || ('HTTP ' + xhr.status)));
          } catch (err) {
            reject(new Error(text || ('HTTP ' + xhr.status)));
          }
        };

        xhr.send(body);
      });
    }

    function formDataToPayload(formData) {
      var payload = {};
      formData.forEach(function(value, key) {
        if (typeof File !== 'undefined' && value instanceof File) return;
        payload[key] = String(value == null ? '' : value);
      });
      return payload;
    }

    function filesSignature(files) {
      return files.map(function(file) {
