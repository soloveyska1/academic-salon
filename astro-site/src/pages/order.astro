---
import Base from '../layouts/Base.astro';
---

<Base title="Заказать работу — Академический Салон" currentPath="/order">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <h1 class="hero-t">
        <span class="w" style="--i:0">Сделаем</span>
        <span class="w" style="--i:1">работу</span>
        <span class="w" style="--i:2">за</span>
        <span class="w" style="--i:3">вас.</span>
      </h1>
      <p class="hero-sub">Курсовые, дипломные, рефераты — индивидуально, в срок, с гарантией</p>
      <div class="hero-rule" aria-hidden="true"></div>
      <a href="#form" class="hero-cta">Обсудить работу</a>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="proc">
    <div class="proc-inner">
      <div class="proc-line" aria-hidden="true"></div>
      <div class="step">
        <span class="step-n" aria-hidden="true">01</span>
        <b class="step-t">Тема</b>
        <p class="step-d">Вы описываете задачу и сроки</p>
      </div>
      <div class="step">
        <span class="step-n" aria-hidden="true">02</span>
        <b class="step-t">Работа</b>
        <p class="step-d">Мы пишем и проверяем</p>
      </div>
      <div class="step">
        <span class="step-n" aria-hidden="true">03</span>
        <b class="step-t">Сдача</b>
        <p class="step-d">Вы получаете готовый файл</p>
      </div>
    </div>
  </section>

  <!-- FORM -->
  <section class="form-section" id="form">
    <div class="form-layout">

      <div class="form-col">
        <h2 class="form-heading">Оставить заявку</h2>

        <form class="frm" id="orderForm" action="https://formsubmit.co/academsaloon@mail.ru" method="POST">
          <input type="hidden" name="_subject" value="Новая заявка — Академический Салон" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://bibliosaloon.ru/order" />
          <input type="text" name="_honey" style="display:none" />

          <div class="field">
            <label for="fType">Тип работы</label>
            <select id="fType" name="type" required>
              <option value="" disabled selected>Выберите тип</option>
              <option value="Курсовая">Курсовая</option>
              <option value="ВКР">ВКР / Дипломная</option>
              <option value="Реферат">Реферат</option>
              <option value="Контрольная">Контрольная</option>
              <option value="Другое">Другое</option>
            </select>
          </div>

          <div class="field">
            <label for="fSubj">Предмет</label>
            <input type="text" id="fSubj" name="subject" placeholder="Например, психология" />
          </div>

          <div class="field">
            <label for="fDeadline">Срок сдачи</label>
            <input type="text" id="fDeadline" name="deadline" placeholder="Когда нужна работа?" />
          </div>

          <div class="field">
            <label for="fComment">Комментарий</label>
            <textarea id="fComment" name="comment" rows="3" placeholder="Тема, требования, пожелания..."></textarea>
          </div>

          <button type="submit" class="frm-btn">Отправить заявку</button>
          <p class="frm-note">Ответим в течение часа в Telegram или VK</p>
        </form>

        <div class="frm-done" id="formDone" style="display:none">
          <p class="frm-done-t">Заявка отправлена</p>
          <p class="frm-done-d">Ответим в течение часа.</p>
        </div>

        <div class="frm-alt">
          <p>Или напишите напрямую:</p>
          <div class="frm-links">
            <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
            <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
            <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
          </div>
        </div>
      </div>

      <aside class="proof-col">
        <div class="voice">
          <p class="voice-text">«Все сдала, по содержанию нареканий нет. Спасибо и за поддержку, и за работу.»</p>
        </div>
        <div class="voice">
          <p class="voice-text">«У меня 5 без защиты, потому что времени не хватило. Работа сказал очень хорошая. Спасибо тебе ещё раз!»</p>
        </div>
        <div class="voice">
          <p class="voice-text">«Четвёрка моя твёрдая. Отлично всё, шикарно. Хорошо, что мы успели всё сделать.»</p>
        </div>
        <div class="voice">
          <p class="voice-text">«40 баллов — ты невероятен.»</p>
        </div>
      </aside>

    </div>
  </section>

  <!-- CLOSING -->
  <section class="closing">
    <p class="closing-t">Ваша работа — учиться.<br/>Остальное — наша.</p>
    <nav class="closing-links">
      <a href="/catalog">Каталог</a>
      <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
      <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
    </nav>
    <p class="closing-copy">© 2022–2026 Академический Салон</p>
  </section>

</Base>

<style>
  :global(.footer) { display: none; }

  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    padding-bottom: 12svh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    width: min(1000px, 90vw);
    height: min(800px, 80vw);
    top: 42%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45%, rgba(200,165,40,.12) 0%, transparent 70%),
      radial-gradient(ellipse 35% 30%, rgba(212,175,55,.06) 0%, transparent 50%);
    animation: glow 10s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes glow {
    0%, 100% { opacity: .5; transform: translate(-50%,-50%) scale(1); }
    50% { opacity: .9; transform: translate(-50%,-50%) scale(1.1); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .hero-t {
    font: 300 clamp(40px, 8vw, 64px)/.95 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    text-wrap: balance;
  }

  .w {
    display: inline-block;
    opacity: 0;
    transform: translateY(24px);
    animation: win .65s cubic-bezier(.25,0,0,1) forwards;
    animation-delay: calc(var(--i) * 110ms + 200ms);
  }

  @keyframes win {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-sub {
    margin-top: 28px;
    font: 400 clamp(13px, 2vw, 15px)/1.6 var(--fi);
    color: rgba(255,255,255,.5);
    opacity: 0;
    transform: translateY(12px);
    animation: fin .5s cubic-bezier(.25,0,0,1) .75s forwards;
  }

  .hero-rule {
    width: 60px;
    height: 1px;
    margin: 24px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
    animation: rin .6s cubic-bezier(.25,0,0,1) 1s forwards;
  }

  @keyframes rin { to { opacity: .2; transform: scaleX(1); } }

  .hero-cta {
    display: inline-block;
    margin-top: 32px;
    padding: 18px 56px;
    border: 1px solid rgba(201,165,90,.2);
    font: 300 italic 15px/1 var(--fd);
    color: rgba(255,255,255,.7);
    text-decoration: none;
    opacity: 0;
    transform: translateY(12px);
    animation: fin .5s cubic-bezier(.25,0,0,1) 1.2s forwards;
    transition:
      background .5s cubic-bezier(.25,0,0,1),
      border-color .5s cubic-bezier(.25,0,0,1),
      color .5s cubic-bezier(.25,0,0,1);
  }

  .hero-cta:hover {
    background: rgba(201,165,90,.06);
    border-color: rgba(201,165,90,.3);
    color: var(--t1);
  }

  @keyframes fin { to { opacity: 1; transform: translateY(0); } }

  /* ═══════ PROCESS ═══════ */
  .proc {
    padding: 120px 48px;
  }

  .proc-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    position: relative;
  }

  .proc-line {
    position: absolute;
    top: 32px;
    left: 60px;
    right: 60px;
    height: 1px;
    background: rgba(255,255,255,.04);
  }

  .step {
    position: relative;
    padding-top: 48px;
    padding-left: 16px;
  }

  .step-n {
    position: absolute;
    top: 0;
    left: 0;
    font: 300 72px/1 var(--fm);
    color: var(--ac);
    opacity: .06;
    user-select: none;
  }

  .step-t {
    display: block;
    font: 500 14px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t1);
  }

  .step-d {
    margin-top: 8px;
    font: 400 14px/1.5 var(--fi);
    color: rgba(255,255,255,.4);
  }

  /* ═══════ FORM SECTION ═══════ */
  .form-section {
    padding: 0 48px 120px;
  }

  .form-layout {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 560px 1fr;
    gap: 80px;
    align-items: start;
    border-top: 1px solid rgba(255,255,255,.04);
    padding-top: 80px;
  }

  .form-heading {
    font: 300 28px/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    margin-bottom: 40px;
  }

  /* Fields */
  .field {
    margin-bottom: 28px;
  }

  .field label {
    display: block;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: rgba(255,255,255,.3);
    margin-bottom: 8px;
  }

  .field input,
  .field select,
  .field textarea {
    width: 100%;
    padding: 12px 0;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,.08);
    background: transparent;
    color: var(--t1);
    font: 400 15px/1.4 var(--fi);
    outline: none;
    transition: border-color .4s cubic-bezier(.25,0,0,1);
    appearance: none;
    -webkit-appearance: none;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: rgba(255,255,255,.2);
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-bottom-color: rgba(201,165,90,.25);
  }

  .field select {
    cursor: pointer;
    color: rgba(255,255,255,.5);
  }

  .field select option {
    background: var(--bg);
    color: var(--t1);
  }

  .field textarea {
    resize: vertical;
    min-height: 72px;
  }

  .frm-btn {
    margin-top: 8px;
    padding: 16px 48px;
    border: 1px solid rgba(201,165,90,.2);
    background: none;
    font: 300 italic 15px/1 var(--fd);
    color: rgba(255,255,255,.7);
    cursor: pointer;
    transition:
      background .5s cubic-bezier(.25,0,0,1),
      border-color .5s cubic-bezier(.25,0,0,1),
      color .5s cubic-bezier(.25,0,0,1);
  }

  .frm-btn:hover {
    background: rgba(201,165,90,.06);
    border-color: rgba(201,165,90,.3);
    color: var(--t1);
  }

  .frm-note {
    margin-top: 12px;
    font: 400 12px/1.4 var(--fi);
    color: rgba(255,255,255,.25);
  }

  /* Success */
  .frm-done-t {
    font: 300 24px/1.2 var(--fd);
    color: var(--t1);
  }

  .frm-done-d {
    margin-top: 8px;
    font: 400 14px/1.4 var(--fi);
    color: rgba(255,255,255,.4);
  }

  /* Alternative contact */
  .frm-alt {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid rgba(255,255,255,.04);
  }

  .frm-alt p {
    font: 400 12px/1 var(--fi);
    color: rgba(255,255,255,.25);
    margin-bottom: 12px;
  }

  .frm-links {
    display: flex;
    gap: 20px;
  }

  .frm-links a {
    font: 400 13px/1 var(--fi);
    color: rgba(255,255,255,.4);
    text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .frm-links a:hover { color: rgba(255,255,255,.8); }

  /* Social proof sidebar */
  .proof-col {
    padding-top: 80px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .voice {
    padding-bottom: 32px;
    border-bottom: 1px solid rgba(255,255,255,.04);
  }

  .voice:last-child { border-bottom: none; padding-bottom: 0; }

  .voice-text {
    font: 400 italic 14px/1.6 var(--fi);
    color: rgba(255,255,255,.45);
  }

  .voice-who {
    display: block;
    margin-top: 10px;
    font: 400 12px/1 var(--fi);
    color: rgba(255,255,255,.2);
  }

  /* ═══════ CLOSING ═══════ */
  .closing {
    text-align: center;
    padding: 120px 24px 64px;
    border-top: 1px solid rgba(255,255,255,.04);
  }

  .closing-t {
    font: 300 clamp(22px, 4vw, 28px)/1.4 var(--fd);
    color: rgba(255,255,255,.6);
  }

  .closing-links {
    margin-top: 40px;
    display: flex;
    justify-content: center;
    gap: 24px;
  }

  .closing-links a {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: rgba(255,255,255,.2);
    text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .closing-links a:hover { color: rgba(255,255,255,.6); }

  .closing-copy {
    margin-top: 24px;
    font: 400 10px/1 var(--fm);
    color: rgba(255,255,255,.15);
    letter-spacing: .1em;
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 860px) {
    .proc { padding: 80px 24px; }

    .proc-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .proc-line { display: none; }

    .form-section { padding: 0 24px 80px; }

    .form-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .proof-col { padding-top: 0; }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .w, .hero-sub, .hero-rule, .hero-cta {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }

    .hero-rule { opacity: .2 !important; }
    .hero-glow { animation: none !important; }

    .frm-btn, .hero-cta, .frm-links a, .closing-links a {
      transition: none !important;
    }
  }
</style>

<script>
  function initOrder() {
    var form = document.getElementById('orderForm');
    var done = document.getElementById('formDone');

    if (form && done) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var data = new FormData(form);

        fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { 'Accept': 'application/json' }
        }).then(function(res) {
          if (res.ok) {
            form.style.display = 'none';
            done.style.display = 'block';
          }
        }).catch(function() {
          /* Fallback: mailto */
          var subj = data.get('type') || '';
          var body = 'Предмет: ' + (data.get('subject') || '') +
            '\nСрок: ' + (data.get('deadline') || '') +
            '\n\n' + (data.get('comment') || '');
          window.location.href = 'mailto:academsaloon@mail.ru?subject=' +
            encodeURIComponent('Заявка: ' + subj) +
            '&body=' + encodeURIComponent(body);
        });
      });
    }

    /* Smooth scroll to form */
    var cta = document.querySelector('.hero-cta');
    if (cta) {
      cta.addEventListener('click', function(e) {
        e.preventDefault();
        var target = document.getElementById('form');
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    }
  }

  initOrder();
  document.addEventListener('astro:after-swap', initOrder);
</script>
