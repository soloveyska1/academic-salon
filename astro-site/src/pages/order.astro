      var activeLoads = Object.create(null);

      function emitProgress() {
        if (!hooks.onProgress) return;
        var loaded = uploadedBytes;
        Object.keys(activeLoads).forEach(function(key) {
          loaded += activeLoads[key] || 0;
        });
        loaded = Math.max(0, Math.min(totalBytes, loaded));
        var percent = totalBytes ? Math.max(1, Math.min(100, Math.round((loaded / totalBytes) * 100))) : 100;
        hooks.onProgress(percent, loaded, totalBytes);
      }

      if (hooks.onPrepare) hooks.onPrepare();

      return postJson('/api/uploads/init', {
        kind: kind,
        files: createUploadDescriptors(files),
      }).then(function(data) {
        var upload = data.upload || {};
        var uploadId = upload.id || '';
        var chunkSize = Math.max(262144, Number(upload.chunkSize) || (1024 * 1024));
        if (!uploadId) throw new Error('Не удалось подготовить сессию загрузки.');

        var jobs = [];
        files.forEach(function(file, fileIndex) {
          var chunkIndex = 0;
          for (var start = 0; start < file.size; start += chunkSize) {
            var end = Math.min(file.size, start + chunkSize);
            jobs.push({
              fileIndex: fileIndex,
              chunkIndex: chunkIndex,
              chunk: file.slice(start, end),
              size: end - start,
            });
            chunkIndex += 1;
          }
        });

        var concurrency = Math.max(1, Math.min(3, jobs.length));
        var nextJobIndex = 0;
        var activeCount = 0;
        var failed = false;

        function uploadAllChunks() {
          return new Promise(function(resolve, reject) {
            function pump() {
              if (failed) return;
              if (nextJobIndex >= jobs.length && activeCount === 0) {
                resolve();
                return;
              }
              while (!failed && activeCount < concurrency && nextJobIndex < jobs.length) {
                (function(job) {
                  activeCount += 1;
                  var key = job.fileIndex + ':' + job.chunkIndex;
                  activeLoads[key] = 0;
                  var url = '/api/uploads/chunk?uploadId=' + encodeURIComponent(uploadId) +
                    '&fileIndex=' + job.fileIndex + '&chunkIndex=' + job.chunkIndex;
                  uploadChunkRequest(url, job.chunk, function(loaded) {
                    activeLoads[key] = loaded;
                    emitProgress();
                  }).then(function() {
                    delete activeLoads[key];
                    uploadedBytes += job.size;
                    activeCount -= 1;
                    emitProgress();
                    pump();
                  }).catch(function(error) {
                    delete activeLoads[key];
                    activeCount -= 1;
                    failed = true;
                    emitProgress();
                    reject(error);
                  });
                })(jobs[nextJobIndex++]);
              }
            }

            emitProgress();
            pump();
          });
        }

        return uploadAllChunks().then(function() {
          if (hooks.onFinalize) hooks.onFinalize();
          return postJson('/api/uploads/complete', { uploadId: uploadId }).then(function() {
            return uploadId;
          });
        });
      });
    }

    function resetUploadCache(cache) {
      cache.signature = '';
      cache.uploadId = '';
      cache.promise = null;
      cache.token = (cache.token || 0) + 1;
    }

    function startCachedUpload(cache, kind, files, hooks) {
      var signature = filesSignature(files);
      cache.token = (cache.token || 0) + 1;
      var token = cache.token;
      cache.signature = signature;
      cache.uploadId = '';

      cache.promise = stagedUpload(kind, files, {
        onPrepare: function() {
          if (cache.token !== token || !hooks || !hooks.onPrepare) return;
          hooks.onPrepare();
        },
        onProgress: function(percent, loaded, total) {
          if (cache.token !== token || !hooks || !hooks.onProgress) return;
          hooks.onProgress(percent, loaded, total);
        },
        onFinalize: function() {
          if (cache.token !== token || !hooks || !hooks.onFinalize) return;
          hooks.onFinalize();
        },
      }).then(function(uploadId) {
        if (cache.token !== token || cache.signature !== signature) return '';
        cache.uploadId = uploadId;
        cache.promise = Promise.resolve(uploadId);
        if (hooks && hooks.onReady) hooks.onReady(uploadId);
        return uploadId;
      }).catch(function(error) {
        if (cache.token === token) {
          cache.uploadId = '';
          cache.promise = null;
          if (hooks && hooks.onError) hooks.onError(error);
        }
        throw error;
      });

      return cache.promise;
    }

    function selectedFiles() {
      return Array.prototype.slice.call((fileInput && fileInput.files) || []);
    }

    function validateFiles(files) {
      if (files.length > maxFiles) {
        return 'Можно прикрепить не больше 6 файлов.';
      }
      var totalSize = files.reduce(function(sum, file) { return sum + (file.size || 0); }, 0);
      if (totalSize > maxTotalFileSize) {
        return 'Суммарный размер файлов не должен превышать 45 МБ.';
      }
      return '';
    }

    function selectedLibraryFiles() {
      return Array.prototype.slice.call((libraryFilesInput && libraryFilesInput.files) || []);
    }

    function validateLibraryFiles(files) {
      if (!files.length) {
        return 'Прикрепите хотя бы один файл для библиотеки.';
      }
      if (files.length > maxLibraryFiles) {
        return 'Для библиотеки можно прикрепить не больше 5 файлов.';
      }
      var totalSize = files.reduce(function(sum, file) { return sum + (file.size || 0); }, 0);
      if (totalSize > maxLibraryTotalFileSize) {
        return 'Суммарный размер файлов для библиотеки не должен превышать 45 МБ.';
      }
      return '';
    }

    function renderFiles() {
      if (!fileList) return;
      var files = selectedFiles();
      fileList.innerHTML = '';
      if (!files.length) {
        var empty = document.createElement('span');
        empty.className = 'upload-empty';
        empty.textContent = 'Файлы не выбраны';
        fileList.appendChild(empty);
        return;
      }
      files.forEach(function(file) {
        var item = document.createElement('span');
        item.className = 'upload-item';
        var title = document.createElement('strong');
        title.textContent = file.name;
        var meta = document.createElement('span');
        meta.textContent = formatBytes(file.size || 0);
        item.appendChild(title);
        item.appendChild(meta);
        fileList.appendChild(item);
      });
      var summary = document.createElement('span');
      summary.className = 'upload-summary';
      summary.textContent = files.length + ' файл(ов), ' + formatBytes(files.reduce(function(sum, file) {
        return sum + (file.size || 0);
      }, 0));
      fileList.appendChild(summary);
    }

    function renderLibraryFiles() {
      if (!libraryFileList) return;
      var files = selectedLibraryFiles();
      libraryFileList.innerHTML = '';
      if (!files.length) {
        var empty = document.createElement('span');
        empty.className = 'upload-empty';
        empty.textContent = 'Файлы для библиотеки не выбраны';
        libraryFileList.appendChild(empty);
        return;
      }
      files.forEach(function(file) {
        var item = document.createElement('span');
        item.className = 'upload-item';
        var title = document.createElement('strong');
        title.textContent = file.name;
        var meta = document.createElement('span');
        meta.textContent = formatBytes(file.size || 0);
        item.appendChild(title);
        item.appendChild(meta);
        libraryFileList.appendChild(item);
      });
      var summary = document.createElement('span');
      summary.className = 'upload-summary';
      summary.textContent = files.length + ' файл(ов), ' + formatBytes(files.reduce(function(sum, file) {
        return sum + (file.size || 0);
      }, 0));
      libraryFileList.appendChild(summary);
    }

    function update() {
      var p = prices[type] || prices.ref;
      var raw = p.base * (p[speed] || 1) * (uniqMult[uniq] || 1);
      var val = Math.ceil(raw / 500) * 500;
      priceText = 'от ' + val.toLocaleString('ru-RU') + ' \u20BD';

      if (priceEl) {
        priceEl.textContent = priceText;
        priceEl.classList.add('is-bumped');
        setTimeout(function() { priceEl.classList.remove('is-bumped'); }, 250);
      }
      if (submitPrice) submitPrice.textContent = priceText;
      if (typeInput) typeInput.value = typeName;
      if (deadlineInput) deadlineInput.value = speedName;
    }

    document.querySelectorAll('.calc-pills').forEach(function(group) {
      group.addEventListener('click', function(e) {
        var btn = e.target.closest('.pill');
        if (!btn) return;
        group.querySelectorAll('.pill').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        var id = group.id;
        if (id === 'calcType') { type = btn.dataset.val; typeName = btn.dataset.name; }
        else if (id === 'calcSpeed') { speed = btn.dataset.val; speedName = btn.dataset.name; }
        else if (id === 'calcUniq') { uniq = btn.dataset.val; uniqName = btn.dataset.name; }
        update();
      });
    });

    if (fileInput) {
      fileInput.addEventListener('change', function() {
        var files = selectedFiles();
        var fileError = validateFiles(files);
        if (fileError) {
          fileInput.value = '';
          renderFiles();
          resetUploadCache(orderUploadCache);
          setSubmitStatus(orderSubmitStatus, '');
          setSubmitMeter(orderSubmitMeter, NaN);
          alert(fileError);
          return;
        }
        resetUploadCache(orderUploadCache);
        setSubmitStatus(orderSubmitStatus, '');
        setSubmitMeter(orderSubmitMeter, NaN);
        renderFiles();
        if (!files.length) return;
        startCachedUpload(orderUploadCache, 'order', files, {
          onPrepare: function() {
            setSubmitMeter(orderSubmitMeter, 0);
            setSubmitStatus(orderSubmitStatus, 'Начинаем защищённую загрузку файлов...');
          },
          onProgress: function(percent) {
            setSubmitMeter(orderSubmitMeter, percent);
            setSubmitStatus(orderSubmitStatus, 'Файлы загружаются в фоне: ' + percent + '%');
          },
          onFinalize: function() {
            setSubmitMeter(orderSubmitMeter, 100);
            setSubmitStatus(orderSubmitStatus, 'Файлы загружены. Подтверждаем загрузку...');
          },
          onReady: function() {
            setSubmitMeter(orderSubmitMeter, 100);
            setSubmitStatus(orderSubmitStatus, 'Файлы уже загружены. Можно отправлять заявку.');
          },
          onError: function() {
            setSubmitMeter(orderSubmitMeter, NaN);
            setSubmitStatus(orderSubmitStatus, 'Не удалось загрузить файлы заранее. Повторим при отправке заявки.');
          },
        }).catch(function() {});
      });
    }

    if (libraryFilesInput) {
      libraryFilesInput.addEventListener('change', function() {
        var files = selectedLibraryFiles();
        var fileError = validateLibraryFiles(files);
        if (fileError && files.length) {
          libraryFilesInput.value = '';
          renderLibraryFiles();
          resetUploadCache(libraryUploadCache);
          setSubmitStatus(librarySubmitStatus, '');
          setSubmitMeter(librarySubmitMeter, NaN);
          alert(fileError);
          return;
        }
        resetUploadCache(libraryUploadCache);
        setSubmitStatus(librarySubmitStatus, '');
        setSubmitMeter(librarySubmitMeter, NaN);
        renderLibraryFiles();
        if (!files.length) return;
        startCachedUpload(libraryUploadCache, 'library', files, {
          onPrepare: function() {
            setSubmitMeter(librarySubmitMeter, 0);
            setSubmitStatus(librarySubmitStatus, 'Начинаем защищённую загрузку файлов...');
          },
          onProgress: function(percent) {
            setSubmitMeter(librarySubmitMeter, percent);
            setSubmitStatus(librarySubmitStatus, 'Файлы загружаются в фоне: ' + percent + '%');
          },
          onFinalize: function() {
            setSubmitMeter(librarySubmitMeter, 100);
            setSubmitStatus(librarySubmitStatus, 'Файлы загружены. Подтверждаем загрузку...');
          },
          onReady: function() {
            setSubmitMeter(librarySubmitMeter, 100);
            setSubmitStatus(librarySubmitStatus, 'Файлы уже загружены. Можно отправлять работу.');
          },
          onError: function() {
            setSubmitMeter(librarySubmitMeter, NaN);
            setSubmitStatus(librarySubmitStatus, 'Не удалось загрузить файлы заранее. Повторим при отправке.');
          },
        }).catch(function() {});
      });
    }

    if (libraryReveal && librarySection) {
      libraryReveal.addEventListener('click', function() {
        librarySection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        setTimeout(function() {
          var firstField = document.getElementById('libraryTitle');
          if (firstField) firstField.focus();
        }, 450);
      });
    }

    /* Form submission */
    var done = document.getElementById('formDone');

    if (form && done) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var files = selectedFiles();
        var fileError = validateFiles(files);
        if (fileError) {
          alert(fileError);
          return;
        }

        var formData = new FormData(form);
        var payload = formDataToPayload(formData);
        payload.workType = typeName + ' (' + uniqName + ', ' + priceText + ')';
        payload.deadline = speedName;
        payload.source = 'site_calculator';
        payload.sourceLabel = 'Сайт · калькулятор стоимости';
        payload.sourcePath = window.location.pathname;
        payload.entryUrl = window.location.href;
        payload.referrer = document.referrer || '';
        payload.pageTitle = document.title;
        payload.estimatedPrice = String(parseInt(priceText.replace(/[^\d]/g, ''), 10) || '');
        payload.originality = uniqName;

        if (!String(payload.contact || '').trim()) {
          document.getElementById('fContact').focus();
          return;
        }

        var btn = document.getElementById('submitBtn');
        var signature = filesSignature(files);
        setSubmitButtonState(btn, files.length ? 'Подготавливаем загрузку...' : 'Отправляем заявку...', true);
        setSubmitMeter(orderSubmitMeter, files.length ? 0 : NaN);
        setSubmitStatus(
          orderSubmitStatus,
          files.length ? 'Подготавливаем защищённую загрузку...' : 'Заявка отправляется. Обычно это занимает пару секунд.'
        );

        var uploadPromise;
        if (!files.length) {
          uploadPromise = Promise.resolve('');
        } else if (orderUploadCache.uploadId && orderUploadCache.signature === signature) {
          setSubmitMeter(orderSubmitMeter, 100);
          setSubmitStatus(orderSubmitStatus, 'Файлы уже загружены. Отправляем заявку...');
          uploadPromise = Promise.resolve(orderUploadCache.uploadId);
        } else if (orderUploadCache.promise && orderUploadCache.signature === signature) {
          setSubmitButtonState(btn, 'Завершаем загрузку...', true);
          setSubmitStatus(orderSubmitStatus, 'Дожидаемся завершения загрузки файлов...');
          uploadPromise = orderUploadCache.promise;
        } else {
          uploadPromise = startCachedUpload(orderUploadCache, 'order', files, {
            onPrepare: function() {
              setSubmitButtonState(btn, 'Загружаем файлы...', true);
              setSubmitMeter(orderSubmitMeter, 0);
              setSubmitStatus(orderSubmitStatus, 'Подготавливаем защищённую загрузку...');
            },
            onProgress: function(percent) {
              setSubmitMeter(orderSubmitMeter, percent);
              setSubmitStatus(orderSubmitStatus, 'Загружаем файлы: ' + percent + '%');
            },
            onFinalize: function() {
              setSubmitMeter(orderSubmitMeter, 100);
              setSubmitStatus(orderSubmitStatus, 'Файлы загружены. Подтверждаем загрузку...');
            },
          });
        }

        uploadPromise.then(function(uploadId) {
          if (uploadId) payload.uploadSessionId = uploadId;
          setSubmitButtonState(btn, 'Отправляем заявку...', true);
          if (files.length) {
            setSubmitMeter(orderSubmitMeter, 100);
            setSubmitStatus(orderSubmitStatus, 'Файлы приняты. Отправляем заявку...');
          }
          return postJson('/api/order', payload);
        }).then(function(data) {
          if (data.ok) {
            resetUploadCache(orderUploadCache);
            setSubmitStatus(orderSubmitStatus, '');
            setSubmitMeter(orderSubmitMeter, NaN);
            form.style.display = 'none';
            done.style.display = 'block';
          } else {
            setSubmitButtonState(btn, 'Отправить заявку', false);
            setSubmitStatus(orderSubmitStatus, '');
            setSubmitMeter(orderSubmitMeter, NaN);
            alert(data.error || 'Ошибка при отправке');
          }
        }).catch(function() {
          /* Fallback: open VK with pre-filled message */
          setSubmitButtonState(btn, 'Отправить заявку', false);
          setSubmitStatus(orderSubmitStatus, '');
          setSubmitMeter(orderSubmitMeter, NaN);
          var msg = encodeURIComponent(
            'Здравствуйте! Хочу заказать: ' + typeName +
            '\nПредмет: ' + String(payload.subject || '') +
            '\nСрок: ' + speedName +
            '\nТема: ' + String(payload.topic || '')
          );
          window.open('https://vk.me/academicsaloon', '_blank');
          alert(
            files.length
              ? 'Сервер временно недоступен. Откроем чат VK — отправьте туда сообщение и приложите файлы.'
              : 'Сервер временно недоступен. Откроем чат VK — опишите задачу там.'
          );
        });
      });
    }

    if (libraryForm && libraryDone) {
      libraryForm.addEventListener('submit', function(e) {
        e.preventDefault();

        var files = selectedLibraryFiles();
        var fileError = validateLibraryFiles(files);
        if (fileError) {
          alert(fileError);
          return;
        }

        var formData = new FormData(libraryForm);
        var payload = formDataToPayload(formData);
        payload.source = 'Сайт · order page library submission';
        payload.sourcePath = window.location.pathname;
        payload.entryUrl = window.location.href;
        payload.referrer = document.referrer || '';

        if (!String(payload.title || '').trim()) {
          var titleField = document.getElementById('libraryTitle');
          if (titleField) titleField.focus();
          return;
        }

        if (!String(payload.contact || '').trim()) {
          var contactField = document.getElementById('libraryContact');
          if (contactField) contactField.focus();
          return;
        }

        var btn = document.getElementById('librarySubmitBtn');
        var signature = filesSignature(files);
        setSubmitButtonState(btn, 'Подготавливаем загрузку...', true);
        setSubmitMeter(librarySubmitMeter, 0);
        setSubmitStatus(librarySubmitStatus, 'Подготавливаем защищённую загрузку...');

        var uploadPromise;
        if (libraryUploadCache.uploadId && libraryUploadCache.signature === signature) {
          setSubmitMeter(librarySubmitMeter, 100);
          setSubmitStatus(librarySubmitStatus, 'Файлы уже загружены. Отправляем работу...');
          uploadPromise = Promise.resolve(libraryUploadCache.uploadId);
        } else if (libraryUploadCache.promise && libraryUploadCache.signature === signature) {
          setSubmitButtonState(btn, 'Завершаем загрузку...', true);
          setSubmitStatus(librarySubmitStatus, 'Дожидаемся завершения загрузки файлов...');
          uploadPromise = libraryUploadCache.promise;
        } else {
          uploadPromise = startCachedUpload(libraryUploadCache, 'library', files, {
            onPrepare: function() {
              setSubmitButtonState(btn, 'Загружаем файлы...', true);
              setSubmitMeter(librarySubmitMeter, 0);
              setSubmitStatus(librarySubmitStatus, 'Подготавливаем защищённую загрузку...');
            },
            onProgress: function(percent) {
              setSubmitMeter(librarySubmitMeter, percent);
              setSubmitStatus(librarySubmitStatus, 'Загружаем файлы: ' + percent + '%');
            },
            onFinalize: function() {
              setSubmitMeter(librarySubmitMeter, 100);
              setSubmitStatus(librarySubmitStatus, 'Файлы загружены. Подтверждаем загрузку...');
            },
          });
        }

        uploadPromise.then(function(uploadId) {
          payload.uploadSessionId = uploadId;
          setSubmitButtonState(btn, 'Отправляем в библиотеку...', true);
          setSubmitMeter(librarySubmitMeter, 100);
          setSubmitStatus(librarySubmitStatus, 'Файлы приняты. Отправляем работу...');
          return postJson('/api/library-submit', payload);
        }).then(function(data) {
          if (data.ok) {
            resetUploadCache(libraryUploadCache);
            setSubmitStatus(librarySubmitStatus, '');
            setSubmitMeter(librarySubmitMeter, NaN);
            libraryForm.style.display = 'none';
            libraryDone.style.display = 'block';
          } else {
            setSubmitButtonState(btn, 'Отправить в библиотеку', false);
            setSubmitStatus(librarySubmitStatus, '');
            setSubmitMeter(librarySubmitMeter, NaN);
            alert(data.error || 'Не удалось отправить работу');
          }
        }).catch(function() {
          setSubmitButtonState(btn, 'Отправить в библиотеку', false);
          setSubmitStatus(librarySubmitStatus, '');
          setSubmitMeter(librarySubmitMeter, NaN);
          window.open('https://t.me/academicsaloon', '_blank');
          alert('Сервер временно недоступен. Откроем Telegram, чтобы вы могли отправить работу вручную.');
        });
      });
    }

    /* Hero scroll CTA */
    var scrollBtn = document.getElementById('heroScroll');
    if (scrollBtn) {
      scrollBtn.addEventListener('click', function(e) {
        e.preventDefault();
        var target = document.getElementById('form');
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    }

    update();
    renderFiles();
    renderLibraryFiles();
  }

  /* ═══════ PROOF SLIDER ═══════ */
  function initProofSlider() {
    var slider = document.getElementById('proofSlider');
    var prev = document.getElementById('proofPrev');
    var next = document.getElementById('proofNext');
    var counter = document.getElementById('proofCur');
    if (!slider) return;
    if (slider.dataset.bound === '1') return;
    slider.dataset.bound = '1';

    var imgs = Array.from(slider.querySelectorAll('.proof-img'));
    var current = 0;

    function show(idx) {
      imgs.forEach(function(img, i) {
        img.classList.toggle('is-active', i === idx);
      });
      current = idx;
      if (counter) counter.textContent = String(idx + 1);
    }

    show(0);

    if (prev) prev.addEventListener('click', function() {
      show(current > 0 ? current - 1 : imgs.length - 1);
    });

    if (next) next.addEventListener('click', function() {
      show(current < imgs.length - 1 ? current + 1 : 0);
    });

    /* Auto-advance every 5s */
    var autoTimer = setInterval(function() {
      show(current < imgs.length - 1 ? current + 1 : 0);
    }, 5000);

    /* Pause on hover */
    slider.addEventListener('mouseenter', function() { clearInterval(autoTimer); });
    slider.addEventListener('mouseleave', function() {
      autoTimer = setInterval(function() {
        show(current < imgs.length - 1 ? current + 1 : 0);
      }, 5000);
    });
  }

  initOrderPage();
  initProofSlider();
  document.addEventListener('astro:after-swap', function() {
    initOrderPage();
    initProofSlider();
  });
</script>
