</style>

<script>
  function showToast(msg, type) {
    var el = document.getElementById('formToast');
    if (!el) return;
    el.textContent = msg;
    el.className = 'form-toast form-toast--' + (type || 'info') + ' form-toast--visible';
    clearTimeout(el._tid);
    el._tid = setTimeout(function() { el.classList.remove('form-toast--visible'); }, 6000);
  }

  function initOrderPage() {
    var app = window.academicSalon || {};
    var track = app.track || function() {};
    var draftHandle = null;
    var prices = {
      ref:    { base: 2500,  today: 2.2, rush: 1.7, fast: 1.35, normal: 1 },
      kont:   { base: 2500,  today: 2.2, rush: 1.7, fast: 1.35, normal: 1 },
      doklad:   { base: 2500,  today: 2.2, rush: 1.7, fast: 1.35, normal: 1 },
      practice: { base: 14000, today: 1.8, rush: 1.5, fast: 1.35, normal: 1 },
      kurs_t:   { base: 14000, today: 1.8, rush: 1.5, fast: 1.35, normal: 1 },
      kurs_e: { base: 20000, today: 1.8, rush: 1.5, fast: 1.35, normal: 1 },
      diplom: { base: 45000, today: 1.5, rush: 1.3, fast: 1.2,  normal: 1 },
      magist: { base: 60000, today: 1.5, rush: 1.3, fast: 1.2,  normal: 1 },
    };
    var uniqMult = { '70': 1, '80': 1.1, '90': 1.2 };

    var type = 'ref', typeName = 'Реферат';
    var speed = 'normal', speedName = '2–3 недели';
    var uniq = '70', uniqName = '70%';
    var extras = []; // [{val, name, price}]
    var priceText = 'от 2 500 ₽';

    var priceEl = document.getElementById('calcPrice');
    var submitPrice = document.getElementById('submitPrice');
    var hidType = document.getElementById('hidType');
    var hidDeadline = document.getElementById('hidDeadline');
    var hidExtras = document.getElementById('hidExtras');
    var receiptRowsEl = document.getElementById('formulaReceiptRows');
    var totalAmountEl = document.getElementById('formulaTotalAmount');

    function fmtMoney(n) {
      return Math.round(n).toLocaleString('ru-RU').replace(/,/g, '\u2009');
    }

    function syncHiddenFields() {
      if (hidType) hidType.value = typeName;
      if (hidDeadline) hidDeadline.value = speedName;
      if (hidExtras) hidExtras.value = extras.map(function(x) { return x.name; }).join('; ');
    }

    function renderReceipt(baseVal, speedMult, uniqMult, extrasSum, totalVal) {
      if (!receiptRowsEl) return;
      var rows = '';
      rows += '<li class="receipt-row"><span class="rr-l">' + typeName + '</span>'
            + '<span class="rr-d" aria-hidden="true"></span>'
            + '<span class="rr-r">' + fmtMoney(baseVal) + '\u00A0\u20BD</span></li>';
      rows += '<li class="receipt-row"><span class="rr-l">Темп · ' + speedName + '</span>'
            + '<span class="rr-d" aria-hidden="true"></span>'
            + '<span class="rr-r">' + (speedMult === 1 ? 'без наценки' : '× ' + speedMult.toFixed(2).replace(/\.?0+$/, '')) + '</span></li>';
      rows += '<li class="receipt-row"><span class="rr-l">Уникальность · ' + uniqName + '</span>'
            + '<span class="rr-d" aria-hidden="true"></span>'
            + '<span class="rr-r">' + (uniqMult === 1 ? 'базовая' : '× ' + uniqMult.toFixed(2).replace(/\.?0+$/, '')) + '</span></li>';
      extras.forEach(function(x) {
        rows += '<li class="receipt-row receipt-row--add"><span class="rr-l">' + x.name + '</span>'
              + '<span class="rr-d" aria-hidden="true"></span>'
              + '<span class="rr-r">+ ' + fmtMoney(x.price) + '\u00A0\u20BD</span></li>';
      });
      receiptRowsEl.innerHTML = rows;
      if (totalAmountEl) {
        totalAmountEl.innerHTML = fmtMoney(totalVal) + '<span class="cur">\u00A0\u20BD</span>';
      }
    }

    function update() {
      var p = prices[type] || prices.ref;
      var sMult = p[speed] || 1;
      var uMult = uniqMult[uniq] || 1;
      var raw = p.base * sMult * uMult;
      var extrasSum = extras.reduce(function(acc, x) { return acc + (x.price || 0); }, 0);
      var val = Math.ceil((raw + extrasSum) / 500) * 500;
      priceText = 'от ' + val.toLocaleString('ru-RU') + ' \u20BD';

      if (priceEl) {
        priceEl.textContent = priceText;
        priceEl.classList.add('is-bumped');
        setTimeout(function() { priceEl.classList.remove('is-bumped'); }, 250);
      }
      if (submitPrice) submitPrice.textContent = priceText;
      renderReceipt(p.base, sMult, uMult, extrasSum, val);
      syncHiddenFields();
    }

    function setCalcState(groupId, value) {
      var group = document.getElementById(groupId);
      if (!group) return;
      var btn = group.querySelector('.pill[data-val="' + value + '"]');
      if (!btn) return;
      group.querySelectorAll('.pill').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      if (groupId === 'calcType') { type = btn.dataset.val; typeName = btn.dataset.name; }
      else if (groupId === 'calcSpeed') { speed = btn.dataset.val; speedName = btn.dataset.name; }
      else if (groupId === 'calcUniq') { uniq = btn.dataset.val; uniqName = btn.dataset.name; }
    }

    function toggleExtra(btn) {
      var val = btn.dataset.val;
      var idx = extras.findIndex(function(x) { return x.val === val; });
      if (idx >= 0) {
        extras.splice(idx, 1);
        btn.classList.remove('active');
        btn.setAttribute('aria-pressed', 'false');
      } else {
        extras.push({ val: val, name: btn.dataset.name, price: parseInt(btn.dataset.price, 10) || 0 });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
      }
    }

    document.querySelectorAll('.calc-pills').forEach(function(group) {
      if (group.dataset.bound === 'true') return;
      group.dataset.bound = 'true';
      group.addEventListener('click', function(e) {
        var btn = e.target.closest('.pill');
        if (!btn) return;
        // Multi-select group (Дополнения)
        if (btn.dataset.multi === 'true') {
          toggleExtra(btn);
        } else {
          setCalcState(group.id, btn.dataset.val);
        }
        update();
        if (draftHandle) draftHandle.save();
      });
    });

    // Initial paint of the receipt
    update();

    /* ═══════ URL PARAMS PRE-FILL ("Заказать похожую") ═══════ */
    (function prefillFromUrl() {
      var params = new URLSearchParams(window.location.search);
      var urlType = params.get('type');
      var urlSubject = params.get('subject');
      var urlTopic = params.get('topic');

      if (urlType) {
        setCalcState('calcType', urlType);
        update();
      }
      if (urlSubject) {
        var subj = document.getElementById('fSubj');
        if (subj) subj.value = urlSubject;
      }
      if (urlTopic) {
        var topic = document.getElementById('fTopic');
        if (topic) topic.value = urlTopic;
      }
      /* Scroll to form if params present */
      if (urlType || urlSubject || urlTopic) {
        var form = document.getElementById('form');
        if (form) setTimeout(function() { form.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 400);
      }
    })();

    /* ═══════ FILE ATTACHMENTS ═══════ */
    var MAX_FILES = 6;
    var MAX_TOTAL_BYTES = 45 * 1024 * 1024;
    var attachedFiles = [];
    var fileInput = document.getElementById('fFiles');
    var chipsContainer = document.getElementById('attachChips');

    function formatSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' КБ';
      return (bytes / (1024 * 1024)).toFixed(1) + ' МБ';
    }

    function getExt(name) {
      var parts = name.split('.');
      return parts.length > 1 ? parts.pop().toUpperCase() : '';
    }

    function attachTotalSize() {
      return attachedFiles.reduce(function(sum, f) { return sum + f.size; }, 0);
    }

    function renderChips() {
      if (!chipsContainer) return;
      chipsContainer.innerHTML = '';
      attachedFiles.forEach(function(f, idx) {
        var chip = document.createElement('div');
        chip.className = 'attach-chip';
        var safeName = f.name.replace(/</g, '&lt;').replace(/>/g, '&gt;');
        chip.innerHTML =
          '<span class="attach-chip-ext">' + getExt(f.name) + '</span>' +
          '<span class="attach-chip-name">' + safeName + '</span>' +
          '<span class="attach-chip-size">' + formatSize(f.size) + '</span>' +
          '<button type="button" class="attach-chip-rm" data-idx="' + idx + '" aria-label="Удалить">&times;</button>';
        chipsContainer.appendChild(chip);
      });
    }

    if (fileInput) {
      if (fileInput.dataset.bound !== 'true') {
        fileInput.dataset.bound = 'true';
        fileInput.addEventListener('change', function() {
          var newFiles = Array.from(fileInput.files || []);
          var prevErr = document.querySelector('.attach-error');
          if (prevErr) prevErr.remove();

          var error = '';
          newFiles.forEach(function(f) {
            if (attachedFiles.length >= MAX_FILES) { error = 'Максимум ' + MAX_FILES + ' файлов'; return; }
            if (attachTotalSize() + f.size > MAX_TOTAL_BYTES) { error = 'Превышен лимит 45 МБ'; return; }
            var isDup = attachedFiles.some(function(af) { return af.name === f.name && af.size === f.size; });
            if (!isDup) attachedFiles.push(f);
          });

          renderChips();
          fileInput.value = '';

          if (error) {
            var errEl = document.createElement('div');
            errEl.className = 'attach-error';
            errEl.textContent = error;
            chipsContainer.parentNode.appendChild(errEl);
            setTimeout(function() { if (errEl.parentNode) errEl.remove(); }, 4000);
          }
        });
      }
    }

    if (chipsContainer) {
      if (chipsContainer.dataset.bound !== 'true') {
        chipsContainer.dataset.bound = 'true';
        chipsContainer.addEventListener('click', function(e) {
          var rmBtn = e.target.closest('.attach-chip-rm');
          if (!rmBtn) return;
          attachedFiles.splice(parseInt(rmBtn.dataset.idx, 10), 1);
          renderChips();
          if (draftHandle) draftHandle.save();
        });
      }
    }

    /* ═══════ FORM SUBMISSION ═══════ */
    var form = document.getElementById('orderForm');
    var done = document.getElementById('formDone');

    if (form && app.bindDraft && form.dataset.draftBound !== 'true') {
      form.dataset.draftBound = 'true';
      draftHandle = app.bindDraft(form, {
        key: 'order-request',
        getState: function() {
          return { type: type, speed: speed, uniq: uniq };
        },
        setState: function(extra) {
          if (!extra) return;
          if (extra.type) setCalcState('calcType', extra.type);
          if (extra.speed) setCalcState('calcSpeed', extra.speed);
          if (extra.uniq) setCalcState('calcUniq', extra.uniq);
          update();
        }
      });
      draftHandle.restore();
    }

    if (form && done && form.dataset.bound !== 'true') {
      form.dataset.bound = 'true';
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        /* Double-submit guard — ignore clicks while a request is in flight */
        if (form.dataset.submitting === 'true') return;

        var payload = {
          workType: typeName + ' (' + uniqName + ', ' + priceText + ')'
                  + (extras.length ? ' + ' + extras.map(function(x){return x.name;}).join('; ') : ''),
          topic: (document.getElementById('fTopic') || {}).value || '',
          subject: (document.getElementById('fSubj') || {}).value || '',
          deadline: speedName,
          contact: (document.getElementById('fContact') || {}).value || '',
          comment: (document.getElementById('fComment') || {}).value || '',
        };

        var contact = payload.contact.trim();
        if (!contact) {
          showToast('Укажите контакт для связи', 'error');
          var contactEl = document.getElementById('fContact');
          if (contactEl) contactEl.focus();
          return;
        }
        /* Basic contact validation: must look like a VK/TG link, @username, email, or phone */
        var contactOk = /^(https?:\/\/)/.test(contact) ||
          /^@/.test(contact) ||
          /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(contact) ||
          /[\d\-\+\(\)]{7,}/.test(contact);
        if (!contactOk) {
          showToast('Введите ссылку на VK/Telegram, email или телефон', 'error');
          var contactEl = document.getElementById('fContact');
          if (contactEl) contactEl.focus();
          return;
        }

        var btn = document.getElementById('submitBtn');
        function setSubmitState(label, eyebrow, busy) {
          if (!btn) return;
          btn.disabled = Boolean(busy);
          btn.classList.toggle('is-busy', Boolean(busy));
          btn.setAttribute('aria-busy', busy ? 'true' : 'false');
          var textEl = btn.querySelector('.submit-text');
          if (textEl && label) textEl.textContent = label;
        }
        setSubmitState('Передаём заявку', '', true);
        form.dataset.submitting = 'true';

        if (!navigator.onLine) {
          form.dataset.submitting = '';
          setSubmitState('Отправить заявку', 'Запрос в салон', false);
          showToast('Нет соединения. Черновик сохранён, попробуйте ещё раз при подключении.', 'error');
          track('order_submit_error', { reason: 'offline' });
          return;
        }

        var hasFiles = attachedFiles.length > 0;
        var fetchOpts;

        if (hasFiles) {
          var fd = new FormData();
          fd.append('workType', payload.workType);
          fd.append('topic', payload.topic);
          fd.append('subject', payload.subject);
          fd.append('deadline', payload.deadline);
          fd.append('contact', payload.contact);
          fd.append('comment', payload.comment);
          attachedFiles.forEach(function(f) { fd.append('files', f); });
          fetchOpts = { method: 'POST', body: fd };
        } else {
          fetchOpts = {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          };
        }

        fetch('/api/order/', fetchOpts).then(function(res) {
          if (!res.ok) throw new Error('order ' + res.status);
          return res.json();
        }).then(function(data) {
          if (data && data.ok) {
            if (draftHandle) draftHandle.clear();
            track('order_submit_success', { work_type: type, with_files: hasFiles ? 1 : 0 });
            form.style.display = 'none';
            done.style.display = 'block';
            form.dataset.submitting = '';
          } else {
            setSubmitState('Отправить заявку', 'Запрос в салон', false);
            form.dataset.submitting = '';
            track('order_submit_error', { reason: 'api' });
            showToast((data && data.error) || 'Ошибка при отправке', 'error');
          }
        }).catch(function() {
          setSubmitState('Отправить заявку', 'Запрос в салон', false);
          form.dataset.submitting = '';
          track('order_submit_error', { reason: 'network' });
          showToast('Сервер временно недоступен. Попробуйте написать нам в VK.', 'error');
          window.open('https://vk.me/academicsaloon', '_blank');
        });
      });
    }

    /* Hero scroll CTA */
    var scrollBtn = document.getElementById('heroScroll');
    if (scrollBtn && scrollBtn.dataset.bound !== 'true') {
      scrollBtn.dataset.bound = 'true';
      scrollBtn.addEventListener('click', function(e) {
        e.preventDefault();
        var target = document.getElementById('form');
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    }

    /* ═══════ INLINE FIELD VALIDATION ═══════ */
    var contactField = document.getElementById('fContact');
    var subjectField = document.getElementById('fSubj');
    var topicField   = document.getElementById('fTopic');

    function validateField(input, rule) {
      if (!input || input.dataset.valBound === 'true') return;
      input.dataset.valBound = 'true';
      var field   = input.closest('.field');
      if (!field) return;
      var errorEl = field.querySelector('.field-error');

      input.addEventListener('blur', function() {
        var val = input.value.trim();
        if (!val) {
          field.classList.remove('is-valid', 'is-error');
          if (errorEl) errorEl.textContent = '';
          return;
        }
        var result = rule(val);
        if (result === true) {
          field.classList.add('is-valid');
          field.classList.remove('is-error');
          if (errorEl) errorEl.textContent = '';
        } else {
          field.classList.add('is-error');
          field.classList.remove('is-valid');
          if (errorEl) errorEl.textContent = result;
        }
      });

      input.addEventListener('input', function() {
        field.classList.remove('is-error');
        if (errorEl) errorEl.textContent = '';
      });
    }

    validateField(contactField, function(val) {
      if (val.length < 3) return 'Слишком короткий контакт';
      if (!/[@\w.\-]{3,}/.test(val)) return 'Введите ссылку на VK, Telegram или номер';
      return true;
    });

    validateField(subjectField, function(val) {
      return true; /* Always valid if non-empty */
    });

    validateField(topicField, function(val) {
      return true; /* Always valid if non-empty */
    });

    update();
  }

  initOrderPage();
  document.addEventListener('astro:after-swap', initOrderPage);


  /* ═══════ PROGRESS TRACKING ═══════ */
  (function initProgress() {
    if (window.innerWidth > 768) return;
    var steps = document.querySelectorAll('.order-step');
    var progressSteps = document.querySelectorAll('.progress-step');
    if (steps.length < 2 || progressSteps.length < 2) return;

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (!e.isIntersecting) return;
        var idx = Array.from(steps).indexOf(e.target);
        progressSteps.forEach(function(p, i) {
          p.classList.toggle('active', i === idx);
          p.classList.toggle('done', i < idx);
        });
      });
    }, { threshold: 0.3 });

    steps.forEach(function(s) { observer.observe(s); });
  })();
</script>

<!-- ═══════ GSAP Order Animations ═══════ -->
<script>
  var orderGsapModules;

  function loadOrderGsap() {
    if (!orderGsapModules) {
      orderGsapModules = Promise.all([
        import('gsap'),
        import('gsap/ScrollTrigger'),
        import('gsap/SplitText')
      ]).then(function(mods) {
        var gsap = mods[0].gsap;
        var ScrollTrigger = mods[1].ScrollTrigger;
        var SplitText = mods[2].SplitText;
        gsap.registerPlugin(ScrollTrigger, SplitText);
        return { gsap: gsap, ScrollTrigger: ScrollTrigger, SplitText: SplitText };
      });
    }
    return orderGsapModules;
  }

  async function initOrderGSAP() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    // Skip GSAP on mobile — gsap.from() sets inline opacity:0 which hides content
    if (window.innerWidth <= 768) return;
    var mods = await loadOrderGsap();
    var gsap = mods.gsap;
    var ScrollTrigger = mods.ScrollTrigger;
    var SplitText = mods.SplitText;
    ScrollTrigger.getAll().forEach(st => st.kill());

    // Hero title — kinetic chars
    const heroT = document.querySelector('.hero-t');
    if (heroT) {
      heroT.querySelectorAll('.w').forEach(w => {
        (w as HTMLElement).style.opacity = '1';
        (w as HTMLElement).style.transform = 'none';
        (w as HTMLElement).style.animation = 'none';
      });
      const split = new SplitText(heroT, { type: 'chars', charsClass: 'gsap-char' });
      gsap.from(split.chars, {
        opacity: 0, y: 35, rotateX: -50,
        stagger: 0.02, duration: 0.8, ease: 'power3.out', delay: 0.3,
      });
    }

    // Process steps — stagger
    const steps = document.querySelectorAll('.proc .step');
    if (steps.length) {
      gsap.from(steps, {
        opacity: 0, y: 20, stagger: 0.12,
        duration: 0.6, ease: 'power3.out',
        scrollTrigger: { trigger: '.proc', start: 'top 80%', once: true },
      });
    }

    // Order form steps — reveal on scroll
    document.querySelectorAll('.order-step').forEach((step, i) => {
      gsap.from(step, {
        opacity: 0, y: 24, duration: 0.6,
        delay: i * 0.1, ease: 'power3.out',
        scrollTrigger: { trigger: step, start: 'top 85%', once: true },
      });
    });

    ScrollTrigger.refresh();
  }

  document.addEventListener('astro:page-load', initOrderGSAP);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initOrderGSAP);
  } else {
    initOrderGSAP();
  }
</script>

<!--
  is:global styles — targeted at JS-rendered elements that Astro's
  scoped compiler cannot reach. JS does `innerHTML = '<li class="receipt-row">...'`
  and those nodes do NOT receive the [data-astro-cid-...] attribute,
  so scoped `.receipt-row` selectors silently fail. We guard these
  rules with `.order-flow ...` so they only affect this page.
-->
<style is:global>
  /* Receipt rows — 3-column grid: label · dotted leader · value */
  .order-flow .formula-receipt-rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-height: 0;
  }
  .order-flow .receipt-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 12px;
    align-items: baseline;
    font-family: var(--fd);
    font-size: 15px;
    line-height: 1.45;
    color: var(--cream-2);
    padding: 4px 0;
  }
  .order-flow .receipt-row .rr-l {
    font-family: var(--fd);
    font-style: italic;
    font-size: 15px;
    color: var(--cream-2);
    min-width: 0;
  }
  .order-flow .receipt-row .rr-d {
    border-bottom: 1px dotted var(--line-2-ref);
    height: 0;
    transform: translateY(-5px);
    min-width: 32px;
  }
  .order-flow .receipt-row .rr-r {
    font-family: var(--fd);
    font-size: 15px;
    color: var(--cream);
    font-feature-settings: "tnum";
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    text-align: right;
  }
  .order-flow .receipt-row--add .rr-l {
    font-style: italic;
    color: var(--gold-ref);
  }
  .order-flow .receipt-row--add .rr-r {
    color: var(--gold-ref);
    font-style: italic;
  }

  /* Total line — label + big price in one row, compact */
  .order-flow .formula-total {
    padding-top: 20px;
    border-top: 1px solid var(--gold-line);
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
  }
  .order-flow .formula-total-label {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--mute);
    white-space: nowrap;
    opacity: 1;
  }
  .order-flow .formula-total-amount {
    font-family: var(--fd);
    font-size: clamp(32px, 3.6vw, 48px);
    line-height: 1;
    color: var(--cream);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    text-align: right;
  }
  .order-flow .formula-total-amount .cur {
    font-style: italic;
    color: var(--gold-ref);
    font-size: 0.55em;
    margin-left: 4px;
  }

  /* Receipt head — inline "СЧЁТ · RATIO" + "Академический Салон" */
  .order-flow .formula-receipt-head {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: baseline;
    gap: 20px;
    padding-bottom: 18px;
    margin-bottom: 24px;
    border-bottom: 1px dashed var(--line-2-ref);
  }
  .order-flow .receipt-title {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .order-flow .receipt-title .it {
    color: var(--gold-ref);
    font-style: italic;
    font-family: var(--fm);
    letter-spacing: 0.24em;
  }
  .order-flow .receipt-brand {
    font-family: var(--fd);
    font-style: italic;
    font-size: 14px;
    color: var(--cream-2);
  }
  .order-flow .receipt-brand .it {
    font-style: italic;
    color: var(--gold-ref);
  }

  /* Whisper */
  .order-flow .formula-whisper {
    font-family: var(--fd);
    font-style: italic;
    font-size: 14px;
    line-height: 1.45;
    color: var(--mute);
    text-align: center;
    margin: 16px 0 0;
  }
  .order-flow .formula-whisper em,
  .order-flow .formula-whisper .it {
