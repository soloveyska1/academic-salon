---
import Base from '../layouts/Base.astro';
---

<Base title="Формула стоимости — Академический Салон" description="Рассчитайте стоимость авторской работы: курсовая, дипломная, реферат, магистерская. Прозрачная формула, тариф закрепляется в договоре, оплата после плана." currentPath="/order">

  <!-- ============================================================
       PRELUDE — editorial chapter-head (visual rework, logic kept)
       ============================================================ -->
  <section class="hero prelude" aria-label="Вступление">
    <div class="hero-inner ord-prelude-inner">
      <header class="chapter-head ord-chapter-head">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">I</span>
          <span class="chapter-label">Caput · Prima · Заказать работу</span>
        </div>
        <div class="chapter-title-block">
          <h1 class="chapter-h ord-prelude-h">Заказать <em class="it">работу</em>.</h1>
          <p class="chapter-lede ord-prelude-lede">
            Без&nbsp;звонков менеджеру и&nbsp;скрытых наценок. Считаем по&nbsp;формуле: <em class="it">жанр × темп × уникальность × дополнения</em>. Тариф закрепляется в&nbsp;договоре; оплата&nbsp;— только после плана и&nbsp;разговора с&nbsp;автором.
          </p>
        </div>
      </header>

      <div class="ord-prelude-actions">
        <a href="#form" class="btn btn-gold btn-lg" id="heroScroll">К&nbsp;калькулятору</a>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-ghost-gold btn-lg">Сначала спросить</a>
      </div>
    </div>

    <a href="#form" class="prelude-cue ord-prelude-cue" aria-label="К калькулятору">
      <span class="lbl">посчитать</span>
      <span class="prelude-cue-line" aria-hidden="true"></span>
    </a>
  </section>

  <!-- ============================================================
       II · METHOD — how the price is built
       ============================================================ -->
  <section class="proc method-mini" aria-label="Как считаем стоимость">
    <div class="proc-inner">
      <header class="chapter-head method-mini-head">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">II</span>
          <span class="chapter-label">Caput Secundum · Как считаем</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">Как <em class="it">считаем</em>.</h2>
          <p class="chapter-lede">Базовый тариф зависит от&nbsp;жанра, темп и&nbsp;уникальность дают коэффициент, дополнения добавляются строкой. Никаких «потом досчитаем»&nbsp;— сумма из&nbsp;калькулятора попадает в&nbsp;договор.</p>
        </div>
      </header>

      <div class="proc-line" aria-hidden="true"></div>
      <ol class="method-mini-steps">
        <li class="method-mini-step">
          <span class="step-no-r">I</span>
          <span class="step-latin">Genus</span>
          <b class="step-t">Жанр</b>
          <p class="step-d">Базовый тариф: от&nbsp;2&nbsp;500&nbsp;₽ за&nbsp;реферат до&nbsp;60&nbsp;000&nbsp;₽ за&nbsp;магистерскую.</p>
        </li>
        <li class="method-mini-step">
          <span class="step-no-r">II</span>
          <span class="step-latin">Tempus</span>
          <b class="step-t">Темп</b>
          <p class="step-d">«К&nbsp;утру» дороже «Неспешно» в&nbsp;1.5–2.2&nbsp;раза. Раньше&nbsp;— дешевле и&nbsp;спокойнее.</p>
        </li>
        <li class="method-mini-step">
          <span class="step-no-r">III</span>
          <span class="step-latin">Probitas</span>
          <b class="step-t">Уникальность</b>
          <p class="step-d">70%&nbsp;— базовая ВУЗ-ная, 90%&nbsp;— для строгой кафедры. Множитель ×1, ×1.1, ×1.2.</p>
        </li>
        <li class="method-mini-step">
          <span class="step-no-r">IV</span>
          <span class="step-latin">Additio</span>
          <b class="step-t">Дополнения</b>
          <p class="step-d">Антиплагиат-отчёт, презентация, речь к&nbsp;защите&nbsp;— по&nbsp;желанию, отдельной строкой.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- PROOF section removed: testimonia live on the homepage (Caput III) -->

  <!-- UNIFIED ORDER FLOW -->
  <section class="order-flow" id="form">
    <div class="order-inner">

      <div class="order-main">
        <!-- Mobile progress indicator -->
        <div class="form-progress" id="formProgress">
          <div class="progress-step active" data-step="1">
            <span class="progress-num">1</span>
            <span class="progress-label">Параметры</span>
          </div>
          <div class="progress-line"></div>
          <div class="progress-step" data-step="2">
            <span class="progress-num">2</span>
            <span class="progress-label">Детали</span>
          </div>
        </div>

        <form class="frm" id="orderForm">
          <input type="hidden" name="workType" id="hidType" value="Реферат" />
          <input type="hidden" name="deadline" id="hidDeadline" value="2–3 недели" />

          <!-- Step 1: Calculator (editorial — pill IDs/data-vals preserved for JS) -->
          <div class="order-step formula-stage">
            <div class="step-head formula-stage-head">
              <span class="step-badge">i — iv</span>
              <h2 class="step-heading">Параметры работы</h2>
              <span class="calc-price formula-headline-price" id="calcPrice">от 2 500 ₽</span>
            </div>

            <div class="calc-row formula-row">
              <div class="formula-row-label">
                <span class="formula-row-n">i</span>
                <span class="formula-row-t">Жанр</span>
                <span class="formula-row-latin">Genus</span>
              </div>
              <div class="calc-pills formula-options" id="calcType">
                <button class="pill active" data-val="ref" data-name="Реферат" type="button">Реферат</button>
                <button class="pill" data-val="kont" data-name="Контрольная" type="button">Контрольная</button>
                <button class="pill" data-val="doklad" data-name="Доклад" type="button">Доклад</button>
                <button class="pill" data-val="practice" data-name="Отчёт по практике" type="button">Отчёт по практике</button>
                <button class="pill" data-val="kurs_t" data-name="Курсовая (теория)" type="button">Курсовая</button>
                <button class="pill" data-val="kurs_e" data-name="Курсовая + эмпирика" type="button">Курсовая + эмпирика</button>
                <button class="pill" data-val="diplom" data-name="Дипломная" type="button">Дипломная</button>
                <button class="pill" data-val="magist" data-name="Магистерская" type="button">Магистерская</button>
              </div>
            </div>

            <div class="calc-row formula-row">
              <div class="formula-row-label">
                <span class="formula-row-n">ii</span>
                <span class="formula-row-t">Темп</span>
                <span class="formula-row-latin">Tempus</span>
              </div>
              <div class="calc-pills formula-options" id="calcSpeed">
                <button class="pill" data-val="today" data-name="Сегодня" type="button">Сегодня</button>
                <button class="pill" data-val="rush" data-name="1–3 дня" type="button">1–3 дня</button>
                <button class="pill" data-val="fast" data-name="1 неделя" type="button">1 неделя</button>
                <button class="pill active" data-val="normal" data-name="2–3 недели" type="button">2–3 недели</button>
              </div>
            </div>

            <div class="calc-row formula-row">
              <div class="formula-row-label">
                <span class="formula-row-n">iii</span>
                <span class="formula-row-t">Уникальность</span>
                <span class="formula-row-latin">Probitas</span>
              </div>
              <div class="calc-pills formula-options" id="calcUniq">
                <button class="pill active" data-val="70" data-name="70%" type="button">70%</button>
                <button class="pill" data-val="80" data-name="80%" type="button">80%</button>
                <button class="pill" data-val="90" data-name="90%" type="button">90%</button>
              </div>
            </div>

            <div class="calc-row formula-row">
              <div class="formula-row-label">
                <span class="formula-row-n">iv</span>
                <span class="formula-row-t">Дополнения</span>
                <span class="formula-row-latin">Additio</span>
              </div>
              <div class="calc-pills formula-options formula-extras" id="calcExtras" role="group" aria-label="Дополнительные опции">
                <button class="pill" data-val="antiplag" data-name="Антиплагиат-отчёт" data-price="1500" data-multi="true" type="button" aria-pressed="false">
                  <span class="pill-l">Антиплагиат-отчёт</span>
                  <span class="pill-p">+ 1 500&nbsp;₽</span>
                </button>
                <button class="pill" data-val="speech" data-name="Речь к защите" data-price="2500" data-multi="true" type="button" aria-pressed="false">
                  <span class="pill-l">Речь к&nbsp;защите</span>
                  <span class="pill-p">+ 2 500&nbsp;₽</span>
                </button>
                <button class="pill" data-val="slides" data-name="Презентация · 15 слайдов" data-price="3500" data-multi="true" type="button" aria-pressed="false">
                  <span class="pill-l">Презентация · 15&nbsp;слайдов</span>
                  <span class="pill-p">+ 3 500&nbsp;₽</span>
                </button>
              </div>
            </div>
            <input type="hidden" name="extras" id="hidExtras" value="" />
          </div>

          <!-- Step 2: Details -->
          <div class="order-step">
            <div class="step-head">
              <span class="step-badge">02</span>
              <h2 class="step-heading">Опишите задачу</h2>
            </div>

            <div class="fields-row">
              <div class="field">
                <label for="fSubj">Предмет</label>
                <input type="text" id="fSubj" name="subject" placeholder="Например, психология" autocapitalize="words" autocomplete="off" spellcheck="false" enterkeyhint="next" />
                <div class="field-error"></div>
              </div>
              <div class="field">
                <label for="fTopic">Тема работы</label>
                <input type="text" id="fTopic" name="topic" placeholder="Тема или краткое описание" autocapitalize="sentences" autocomplete="off" enterkeyhint="next" />
                <div class="field-error"></div>
              </div>
            </div>

            <div class="field">
              <label for="fContact">Куда ответить <span class="required">*</span></label>
              <input type="text" id="fContact" name="contact" placeholder="VK, Telegram или телефон" required autocapitalize="none" autocorrect="off" spellcheck="false" enterkeyhint="next" />
              <div class="field-error"></div>
            </div>

            <div class="field">
              <label for="fComment">Дополнительно</label>
              <textarea id="fComment" name="comment" rows="2" placeholder="Методичка, требования, пожелания..." autocomplete="off" autocapitalize="sentences" enterkeyhint="done"></textarea>
              <div class="field-error"></div>
            </div>

            <!-- File attach — inline, minimal -->
            <div class="attach-row" id="attachRow">
              <label class="attach-trigger" for="fFiles">
                <svg class="attach-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>
                <span class="attach-label">Прикрепить файлы</span>
                <span class="attach-hint">до 6 файлов, 45 МБ</span>
                <input type="file" id="fFiles" multiple accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.rtf,.odt,.jpg,.jpeg,.png,.webp,.zip,.rar" class="attach-input" />
              </label>
              <div class="attach-chips" id="attachChips"></div>
            </div>
          </div>

          <!-- Submit with trust signals -->
          <div class="order-submit">
            <div class="form-toast" id="formToast" role="alert" aria-live="polite"></div>

            <!-- Trust signals — visible near submit button -->
            <div class="trust-row">
              <span class="trust-chip"><span class="trust-check" aria-hidden="true">✓</span> Ответ за час</span>
              <span class="trust-chip"><span class="trust-check" aria-hidden="true">✓</span> Оплата после согласования</span>
              <span class="trust-chip"><span class="trust-check" aria-hidden="true">✓</span> Бесплатные доработки</span>
            </div>

            <button type="submit" class="submit-btn" id="submitBtn">
              <span class="submit-text">Отправить заявку</span>
              <span class="submit-price" id="submitPrice">от 2 500 ₽</span>
            </button>

            <!-- Quick contact -->
            <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="quick-contact">
              Есть вопросы? Напишите в Telegram →
            </a>
          </div>
        </form>

        <div class="frm-done premium-success" id="formDone" style="display:none">
          <div class="premium-success__crest">
            <span class="premium-success__seal" aria-hidden="true">АС</span>
            <div class="premium-success__folio">
              <span class="premium-success__code">ORD-01</span>
              <span class="premium-success__deck">Заказ принят</span>
            </div>
          </div>
          <span class="premium-success__eyebrow">Куратор увидит заявку в течение часа</span>
          <p class="done-title">Заявка отправлена</p>
          <p class="done-desc">Мы получили вашу заявку и ответим в течение часа.</p>

          <div class="done-contact">
            <p class="done-contact-text">Хотите уточнить детали или обсудить лично?</p>
            <div class="done-links">
              <a href="https://vk.me/academicsaloon" target="_blank" rel="noopener" class="done-link done-link--vk" id="doneVk">Написать в VK</a>
              <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="done-link" id="doneTg">Telegram</a>
              <a href="mailto:academsaloon@mail.ru" class="done-link">Почта</a>
            </div>
          </div>
        </div>

      </div>

      <!-- ============================================================
           RATIO — sticky receipt panel mirroring calculator state
           ============================================================ -->
      <aside class="formula-receipt" id="formulaReceipt" aria-label="Счёт — Ratio" aria-live="polite">
        <div class="formula-receipt-head">
          <span class="receipt-title">Счёт <span class="receipt-sep">·</span> <i class="it">Ratio</i></span>
          <span class="receipt-brand"><i class="it">Академический Салон</i></span>
        </div>

        <ul class="formula-receipt-rows" id="formulaReceiptRows">
          <!-- Populated by JS — see initRatioReceipt() -->
        </ul>

        <div class="formula-total">
          <span class="formula-total-label">Итого, от</span>
          <span class="formula-total-amount" id="formulaTotalAmount">2 500<span class="cur"> ₽</span></span>
        </div>

        <p class="formula-whisper">
          Тариф закрепляется в&nbsp;договоре. Оплата по&nbsp;частям: <em class="it">50%</em> после плана, <em class="it">50%</em> после защиты.
        </p>
      </aside>

    </div>
  </section>

  <!-- CLOSING removed: contacts live in the global editorial footer (Phase 2) -->

</Base>

<style>
  /* Global editorial footer (Phase 2) is intentionally visible on /order */

  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    padding-bottom: 12svh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    width: min(1000px, 90vw);
    height: min(800px, 80vw);
    top: 42%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45%, var(--ac-line) 0%, transparent 70%),
      radial-gradient(ellipse 35% 30%, var(--ac-sh) 0%, transparent 50%);
    animation: glow 10s cubic-bezier(.4,0,.2,1) infinite;
    pointer-events: none;
  }

  @keyframes glow {
    0%, 100% { opacity: .5; transform: translate(-50%,-50%) scale(1); }
    50% { opacity: .9; transform: translate(-50%,-50%) scale(1.1); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .hero-t {
    font: 300 clamp(36px, 7vw, 64px)/.92 var(--fd);
    color: var(--t1);
    letter-spacing: -.02em;
    text-wrap: balance;
    text-shadow: 0 0 80px rgba(212,175,55,.08), 0 0 40px rgba(212,175,55,.04);
  }

  .w {
    display: inline-block;
    opacity: 0;
    transform: translateY(24px);
    animation: win 400ms cubic-bezier(.4,0,.2,1) forwards;
    animation-delay: calc(var(--i) * 110ms + 200ms);
  }

  @keyframes win {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-sub {
    margin-top: 28px;
    font: 400 clamp(13px, 2vw, 15px)/1.6 var(--fi);
    color: var(--t2);
    opacity: 0;
    transform: translateY(12px);
    animation: fin 400ms cubic-bezier(.4,0,.2,1) .75s forwards;
  }

  .hero-rule {
    width: 60px;
    height: 1px;
    margin: 24px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
    animation: rin 400ms cubic-bezier(.4,0,.2,1) 1s forwards;
  }

  @keyframes rin { to { opacity: .2; transform: scaleX(1); } }

  .hero-btns {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 32px;
    opacity: 0;
    transform: translateY(12px);
    animation: fin 400ms cubic-bezier(.4,0,.2,1) 1.2s forwards;
  }

  .hero-cta {
    padding: 18px 44px;
    border: 1px solid var(--ac-b);
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t1);
    text-decoration: none;
    transition:
      background var(--dur-slow) var(--ease),
      border-color var(--dur-slow) var(--ease),
      transform var(--dur-slow) var(--ease),
      box-shadow var(--dur-slow) var(--ease);
  }

  .hero-cta--primary {
    background: var(--surf);
    border-color: var(--ac-b);
  }

  .hero-cta--primary:hover {
    background: var(--surf-h);
    border-color: var(--ac-b3);
    box-shadow: 0 0 0 1px var(--ac-line), 0 14px 40px rgba(0,0,0,.25);
    transform: translateY(-1px);
  }

  .hero-cta--ghost {
    background: transparent;
    color: var(--t2);
  }

  .hero-cta--ghost:hover {
    border-color: var(--ac-b2);
    color: var(--t1);
    transform: translateY(-1px);
  }

  @keyframes fin { to { opacity: 1; transform: translateY(0); } }

  /* ═══════ PROCESS ═══════ */
  .proc {
    padding: 120px 48px;
  }

  .proc-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    position: relative;
  }

  .proc-line {
    position: absolute;
    top: 32px;
    left: 60px;
    right: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--ac-b) 20%, var(--ac) 50%, var(--ac-b) 80%, transparent 100%);
    opacity: .4;
  }

  .step {
    position: relative;
    padding-top: 48px;
    padding-left: 16px;
  }

  .step-n {
    position: absolute;
    top: 0;
    left: 0;
    font: 300 72px/1 var(--fm);
    color: var(--ac);
    opacity: .2;
    user-select: none;
    text-shadow: 0 0 40px rgba(212,175,55,.2);
  }

  .step-t {
    display: block;
    font: 500 14px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t1);
  }

  .step-d {
    margin-top: 8px;
    font: 400 14px/1.5 var(--fi);
    color: var(--t3);
  }

  /* ═══════ TRUST / PROOF ═══════ */
  .proof {
    padding: 0 48px 64px;
  }
  .proof-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .proof-card {
    padding: 28px 24px;
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    background: var(--card, rgba(255,255,255,.02));
  }
  .proof-quote {
    font: 400 14px/1.6 var(--fi);
    color: var(--t2);
    font-style: italic;
  }
  .proof-author {
    display: block;
    margin-top: 12px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--t3);
  }
  @media (max-width: 860px) {
    .proof { padding: 0 16px 40px; }
    .proof-inner { grid-template-columns: 1fr; gap: 12px; }
  }

  /* ═══════ UNIFIED ORDER FLOW ═══════ */
  .order-flow {
    padding: 0 48px 80px;
  }

  .order-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    max-width: 720px;
    gap: 56px;
    align-items: start;
    border-top: 1px solid var(--brd);
    padding-top: 56px;
  }

  .order-main { min-width: 0; }

  .order-step {
    margin-bottom: 36px;
  }

  .step-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
  }

  .step-badge {
    font: 300 clamp(24px, 4vw, 32px)/1 var(--fm);
    color: var(--ac);
    opacity: .25;
  }

  .step-heading {
    font: 300 clamp(18px, 3vw, 22px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  .calc-price {
    margin-left: auto;
    font: 400 clamp(22px, 3.5vw, 28px)/1 var(--fm);
    color: var(--ac);
    font-variant-numeric: tabular-nums;
    letter-spacing: -.02em;
    text-shadow: 0 0 24px rgba(212,175,55,.15);
    transition: transform var(--dur) var(--ease-spring), text-shadow 300ms ease;
  }

  .calc-price.is-bumped { transform: scale(1.05); }

  /* Calculator rows */
  .calc-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 0;
    border-top: 1px solid var(--brd);
  }

  .calc-label {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    width: 100px;
    flex-shrink: 0;
  }

  .calc-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .pill {
    padding: 10px 20px;
    border: 1px solid var(--brd);
    border-radius: 0;
    background: transparent;
    font: 400 13px/1 var(--fi);
    color: var(--t2);
    cursor: pointer;
    position: relative;
    white-space: nowrap;
    transition: all 250ms cubic-bezier(.4,0,.2,1);
  }

  .pill:hover {
    border-color: var(--ac-b);
    color: var(--t1);
  }

  .pill.active {
    border-color: var(--ac-b2);
    color: var(--ac);
    background: var(--ac-g);
  }

  .pill.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--ac);
    border-radius: 1px;
  }

  /* Form fields */
  .fields-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .field {
    margin-bottom: 24px;
    position: relative;
  }
  .field::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ac), var(--ac3), var(--ac));
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 400ms cubic-bezier(.4,0,.2,1);
    pointer-events: none;
  }
  .field:focus-within::after {
    transform: scaleX(1);
  }

  .field label {
    display: block;
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    margin-bottom: 8px;
  }

  .field input, .field textarea {
    width: 100%;
    padding: 12px 0;
    border: none;
    border-bottom: 1px solid var(--brd);
    border-radius: 0;
    background: transparent;
    color: var(--t1);
    font: 400 15px/1.5 var(--fi);
    outline: none;
    transition: border-color var(--dur) var(--ease-out),
                box-shadow var(--dur) var(--ease-out);
  }

  .field input::placeholder, .field textarea::placeholder { color: var(--t3); opacity: .6; }
  .required { color: var(--ac); opacity: .5; }
  .field input:focus, .field textarea:focus {
    border-bottom-color: rgba(255,255,255,.15);
    box-shadow: 0 1px 0 0 rgba(255,255,255,.08);
  }
  .field textarea { resize: vertical; min-height: 64px; padding: 14px 0; }

  [data-theme="light"] .field input,
  [data-theme="light"] .field textarea {
    border-bottom-color: rgba(0,0,0,.12);
    background: transparent;
  }
  [data-theme="light"] .field input:focus,
  [data-theme="light"] .field textarea:focus {
    border-bottom-color: rgba(0,0,0,.15);
    box-shadow: 0 1px 0 0 rgba(0,0,0,.08);
  }

  /* ═══════ FILE ATTACH ═══════ */
  .attach-row { margin-top: 4px; margin-bottom: 8px; }

  .attach-trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
    cursor: pointer;
    transition: color var(--dur) var(--ease);
  }

  .attach-icon {
    color: var(--t3);
    flex-shrink: 0;
    transition: color var(--dur) var(--ease);
  }

  .attach-trigger:hover .attach-icon,
  .attach-trigger:focus-visible .attach-icon { color: var(--ac); }

  .attach-label {
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    transition: color var(--dur) var(--ease);
  }

  .attach-trigger:hover .attach-label { color: var(--t2); }

  .attach-hint {
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    opacity: .4;
    letter-spacing: .02em;
  }

  .attach-input {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    border: 0;
  }

  .attach-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 0;
    transition: margin var(--dur) var(--ease);
  }

  .attach-chips:not(:empty) { margin-top: 8px; }

  .attach-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--surf);
    border: 1px solid var(--brd);
    border-radius: var(--rx);
    font: 400 11px/1 var(--fi);
    color: var(--t2);
    animation: chip-in 250ms cubic-bezier(.22,1,.36,1);
  }

  @keyframes chip-in {
    from { opacity: 0; transform: scale(.9); }
    to { opacity: 1; transform: scale(1); }
  }

  .attach-chip-ext {
    font: 500 9px/1 var(--fm);
    color: var(--ac);
    text-transform: uppercase;
    letter-spacing: .04em;
    opacity: .7;
  }

  .attach-chip-name {
    max-width: 140px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .attach-chip-size {
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    opacity: .5;
  }

  .attach-chip-rm {
    min-width: 36px; min-height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    color: var(--t3);
    font-size: 12px;
    cursor: pointer;
    opacity: .4;
    transition: opacity .2s, color .2s;
    padding: 0;
    line-height: 1;
  }

  .attach-chip-rm:hover { opacity: 1; color: var(--red); }

  .attach-error {
    font: 400 11px/1.4 var(--fi);
    color: var(--red);
    opacity: .8;
    margin-top: 6px;
    animation: chip-in 250ms cubic-bezier(.22,1,.36,1);
  }

  /* Submit button */
  .order-submit { padding-top: 8px; }

  .submit-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 18px 22px;
    background: var(--surf);
    border: 1px solid var(--ac-b);
    border-top: 2px solid var(--ac-b2);
    border-radius: 0;
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t1);
    cursor: pointer;
    transition: all var(--dur-slow) var(--ease);
  }

  .submit-price {
    font: 400 14px/1 var(--fm);
    color: var(--ac);
    opacity: .7;
  }

  .submit-btn:hover {
    background: var(--surf-h);
    border-color: var(--ac-b3);
    box-shadow: 0 12px 40px var(--ac-g);
    transform: translateY(-2px);
  }

  .submit-note {
    margin-top: 12px;
    font: 400 11px/1.4 var(--fi);
    color: var(--t3);
    opacity: .5;
    text-align: center;
  }

  /* Success state */
  .frm-done {
    text-align: center;
    padding: 48px 28px 40px;
    border: 1px solid var(--ac-line);
    background: linear-gradient(180deg, var(--ac-g2), transparent 60%);
    animation: success-in 600ms var(--ease) both;
  }

  @keyframes success-in {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .done-title {
    margin-top: 20px;
    font: 300 32px/1.12 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
  }

  .done-desc {
    max-width: 36ch;
    margin: 12px auto 0;
    font: 400 14px/1.65 var(--fi);
    color: var(--t2);
  }

  .done-contact {
    margin-top: 36px;
    padding: 24px 18px 0;
    border-radius: 0;
    border-top: 1px solid var(--brd);
  }

  .done-contact-text {
    font: 400 13px/1.5 var(--fi);
    color: var(--t3);
    margin-bottom: 20px;
  }

  .done-links {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .done-link {
    padding: 16px 36px;
    border: 1px solid var(--ac-b);
    border-radius: 0;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t2);
    text-decoration: none;
    background: var(--card);
    transition: all var(--dur) var(--ease);
  }

  .done-link:hover {
    border-color: var(--ac-b2);
    color: var(--t1);
    transform: translateY(-2px);
  }

  .done-link--vk {
    border-color: var(--ac-b2);
    background: var(--ac-g);
    color: var(--t1);
  }

  .done-link--vk:hover {
    border-color: var(--ac-b3);
  }


  @media (max-width: 860px) {
    .order-flow { padding: 0 16px 48px; }
    .closing { padding: 48px 16px 32px; }
    .order-inner { grid-template-columns: 1fr; gap: 40px; }
    .calc-row { flex-direction: column; gap: 8px; align-items: flex-start; }
    .calc-label { width: auto; }
    .calc-pills { gap: 6px; }
    .fields-row { grid-template-columns: 1fr; gap: 0; }
    .step-head { flex-wrap: wrap; }
    .calc-price { margin-left: 0; }
  }

  /* old calc/form CSS removed — merged into unified order flow above */
  /* ═══════ CLOSING ═══════ */
  .closing {
    text-align: center;
    padding: 120px 24px 64px;
    border-top: 1px solid var(--brd);
  }

  .closing-t {
    font: 300 clamp(22px, 4vw, 28px)/1.4 var(--fd);
    color: var(--t2);
  }

  .closing-btns {
    margin-top: 32px;
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .closing-btn {
    padding: 16px 36px;
    border: 1px solid var(--brd);
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t2);
    text-decoration: none;
    transition: all var(--dur-slow) var(--ease);
  }

  .closing-btn:hover {
    border-color: var(--brd-h);
    color: var(--t1);
    transform: translateY(-2px);
  }

  .closing-btn--vk {
    background: var(--surf);
    border-color: var(--ac-b);
    color: var(--t1);
  }

  .closing-btn--vk:hover {
    background: var(--surf-h);
    border-color: var(--ac-b2);
    box-shadow: 0 8px 32px rgba(0,0,0,.2);
  }

  .closing-links {
    margin-top: 40px;
    display: flex;
    justify-content: center;
    gap: 24px;
  }

  .closing-links a {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    transition: color var(--dur-slow) var(--ease);
  }

  .closing-links a:hover { color: var(--t2); }

  .closing-copy {
    margin-top: 24px;
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    letter-spacing: .1em;
  }

  /* ═══════ LIGHT THEME ═══════ */
  :global([data-theme="light"]) .hero-glow {
    background:
      radial-gradient(ellipse 55% 45%, rgba(122,95,18,.06) 0%, transparent 70%),
      radial-gradient(ellipse 35% 30%, rgba(122,95,18,.04) 0%, transparent 50%);
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 860px) {
    .proc { padding: 80px 24px; }

    .proc-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .proc-line { display: none; }

    .form-section { padding: 0 24px 80px; }

    .form-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }

  }

  /* ═══════ TRUST SIGNALS ═══════ */
  .trust-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 24px;
    margin-bottom: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--brd);
  }
  .trust-chip {
    font: 400 12px/1.4 var(--fi, Inter, sans-serif);
    letter-spacing: .02em;
    color: var(--t2);
    padding: 6px 0;
    white-space: nowrap;
  }
  .trust-check {
    color: var(--ac);
    font-weight: 500;
    margin-right: 4px;
    opacity: .7;
  }
  .trust-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--t3);
    opacity: .3;
    margin: 0 14px;
    flex-shrink: 0;
  }
  @media (max-width: 640px) {
    .trust-row { flex-wrap: wrap; gap: 6px 16px; justify-content: center; }
    .trust-sep { display: none; }
  }

  /* ═══════ FORM PROGRESS BAR ═══════ */
  .form-progress {
    display: none;
  }
  @media (max-width: 768px) {
    .form-progress {
      display: flex;
      align-items: center;
      gap: 0;
      padding: 16px 0 24px;
    }
    .progress-step {
      display: flex;
      align-items: center;
      gap: 8px;
      opacity: .4;
      transition: opacity var(--dur);
    }
    .progress-step.active { opacity: 1; }
    .progress-step.done { opacity: .7; }
    .progress-num {
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      border: 1.5px solid var(--t3);
      font: 500 12px/1 var(--fi);
      color: var(--t3);
    }
    .progress-step.active .progress-num {
      border-color: var(--ac);
      color: var(--ac);
      background: var(--ac-g);
    }
    .progress-step.done .progress-num {
      border-color: var(--ac);
      color: #09080a;
      background: var(--ac);
    }
    .progress-label {
      font: 400 13px/1 var(--fi);
      color: var(--t3);
    }
    .progress-step.active .progress-label { color: var(--t1); }
    .progress-line {
      flex: 1;
      height: 1px;
      background: var(--brd);
      margin: 0 12px;
    }
  }

  /* ═══════ QUICK CONTACT LINK ═══════ */
  .quick-contact {
    display: block;
    text-align: center;
    padding: 16px 0 0;
    font: 400 14px/1.4 var(--fi);
    color: var(--ac);
    text-decoration: none;
    opacity: .7;
    transition: opacity .2s;
  }
  .quick-contact:hover { opacity: 1; }

  /* ═══════ TRUST ROW REDESIGN ═══════ */
  @media (max-width: 768px) {
    .trust-row {
      display: flex;
      flex-direction: column;
      gap: 6px;
      padding: 16px 0;
      margin-bottom: 16px;
    }
    .trust-chip {
      font-size: 13px;
      color: var(--t2);
      padding: 4px 0;
      line-height: 1.4;
    }
  }

  /* ═══════ FIELD VALIDATION STATES ═══════ */
  .field.is-valid input,
  .field.is-valid textarea {
    border-bottom-color: rgba(34,197,94,.4);
  }
  .field.is-valid::after {
    background: linear-gradient(90deg, rgba(34,197,94,.5), rgba(34,197,94,.3), rgba(34,197,94,.5));
    transform: scaleX(1);
  }
  .field.is-error input,
  .field.is-error textarea {
    border-bottom-color: rgba(239,68,68,.5);
  }
  .field.is-error::after {
    background: linear-gradient(90deg, rgba(239,68,68,.5), rgba(239,68,68,.3), rgba(239,68,68,.5));
    transform: scaleX(1);
  }
  .field-error {
    font: 400 12px/1.4 var(--fi);
    color: #ef4444;
    margin-top: 6px;
    min-height: 0;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: opacity 250ms cubic-bezier(.4,0,.2,1), max-height 250ms cubic-bezier(.4,0,.2,1);
  }
  .field.is-error .field-error {
    opacity: 1;
    max-height: 32px;
  }
  .field-error:empty {
    display: none;
  }

  /* ═══════ MOBILE FORM UX ═══════ */
  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: calc(var(--nav-h) + 32px);
      padding-bottom: 32px;
    }
    .hero-t {
      line-height: 1.1;
      font-size: clamp(32px, 8vw, 44px);
    }
    /* Hero buttons — full width, stacked, rounded */
    .hero-btns {
      flex-direction: column;
      gap: 8px;
      width: 100%;
    }
    .hero-cta {
      width: 100%;
      text-align: center;
      padding: 16px 24px;
      border-radius: var(--rm);
      min-height: 48px;
      font-size: 13px;
    }
    .hero-cta--primary {
      background: linear-gradient(135deg, #d4af37, #f6e27a);
      color: #09080a;
      border-color: transparent;
      font-weight: 600;
    }
    .hero-cta--ghost {
      border-radius: var(--rm);
      border: 1.5px solid var(--ac-b2);
    }
    /* Closing buttons — full width, rounded */
    .closing { padding: 48px 16px 32px; }
    .closing-btns {
      flex-direction: column;
      gap: 8px;
      width: 100%;
    }
    .closing-btn {
      width: 100%;
      text-align: center;
      padding: 14px 16px;
      border-radius: var(--rm);
      min-height: 48px;
      font-size: 14px;
    }
    .closing-btn--vk {
      background: linear-gradient(135deg, #d4af37, #f6e27a);
      color: #09080a;
      border-color: transparent;
      font-weight: 600;
    }
    /* Process section */
    .proc { padding: 48px 16px; }
    .proc-inner { grid-template-columns: 1fr; }
    .proc-line { display: none; }

    .field label {
      font-size: 12px;
    }
    .field input, .field textarea {
      min-height: 52px;
      font-size: 16px; /* prevents iOS zoom on focus */
    }
    .calc-pills {
      overflow-x: auto;
      flex-wrap: wrap;
      gap: 6px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding-bottom: 4px;
    }
    .calc-pills::-webkit-scrollbar { display: none; }
    .pill {
      flex-shrink: 0;
      white-space: nowrap;
      min-height: 44px;
      padding: 10px 16px;
      border-radius: 0;
      border: 1px solid var(--brd);
      background: transparent;
    }
    .pill.active {
      background: var(--ac-g);
      border-color: var(--ac-b2);
      color: var(--ac);
    }
    .pill.active::after { display: none; }
    .submit-btn {
      position: sticky;
      bottom: calc(64px + var(--safe-bottom, 0px));
      z-index: 40;
      min-height: 56px;
      font-size: 15px;
      border-radius: var(--rs);
      background: linear-gradient(135deg, #d4af37, #f6e27a) !important;
      color: #09080a !important;
      border: none !important;
      border-top: none !important;
      font-weight: 600;
      letter-spacing: .06em;
      box-shadow: 0 4px 20px var(--ac-b2);
      text-transform: none;
    }
    .submit-price {
      color: rgba(9,8,10,.68) !important;
    }
    .submit-btn:hover,
    .submit-btn:active {
      background: linear-gradient(135deg, #e6c040, #f6e27a) !important;
      color: #09080a !important;
      transform: none;
    }
    .frm-done {
      padding: 28px 18px 24px;
    }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .w, .hero-sub, .hero-rule, .hero-cta {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }

    .hero-rule { opacity: .2 !important; }
    .hero-glow { animation: none !important; }

    .frm-btn, .hero-cta, .frm-links a, .closing-links a {
      transition: none !important;
    }
  }

  /* ═══════ FORM TOAST ═══════ */
  .form-toast {
    padding: 12px 16px;
    border-radius: var(--rs, 8px);
    font: 400 13px/1.5 var(--fi, Inter, sans-serif);
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: opacity var(--dur), max-height var(--dur), margin var(--dur);
    margin: 0;
  }
  .form-toast--visible {
    opacity: 1;
    max-height: 80px;
    margin-bottom: 12px;
  }
  .form-toast--error {
    background: rgba(220, 38, 38, .12);
    border: 1px solid rgba(220, 38, 38, .25);
    color: #fca5a5;
  }
  :global([data-theme="light"]) .form-toast--error {
    background: rgba(220, 38, 38, .08);
    border-color: rgba(220, 38, 38, .2);
    color: #991b1b;
  }

  /* ══════════════════════════════════════════════════════════════
     EDITORIAL OVERLAY — Phase 5 (Formula + Ratio receipt)
     Only adds; doesn't remove the existing pill/form classes that
     the calculator JS depends on.
     ══════════════════════════════════════════════════════════════ */

  /* Prelude/eyebrow shared with homepage — locally restated */
  .prelude-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: clamp(20px, 3vw, 36px);
    font: 400 11px/1 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--ac);
  }
  .prelude-eyebrow-rule {
    width: 28px; height: 1px; background: var(--ac); display: inline-block;
  }
  .prelude-eyebrow-num {
    font-family: var(--fd);
    font-style: italic;
    font-size: 18px;
    color: var(--ac);
    letter-spacing: 0;
    text-transform: none;
  }
  .prelude-title { max-width: 22ch; margin: 0 auto; }
  .prelude-title .ln { display: block; }
  .prelude-title .it,
  .prelude-lede .it,
  .chapter-h .it,
  .formula-whisper .it,
  .receipt-title .it,
  .receipt-brand .it {
    font-style: italic;
    color: var(--ac);
    font-feature-settings: "swsh", "dlig", "liga";
  }
  .prelude-lede {
    max-width: 56ch;
    margin: 28px auto 0;
    text-wrap: balance;
  }
  .prelude-cue {
    position: absolute;
    bottom: clamp(16px, 4vh, 36px);
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    font: 400 10px/1 var(--fm);
    letter-spacing: .24em;
    text-transform: uppercase;
    color: var(--t3);
    text-decoration: none;
    transition: color var(--dur) var(--ease);
  }
  .prelude-cue:hover { color: var(--ac); }
  .prelude-cue-line {
    width: 1px; height: 36px;
    background: linear-gradient(180deg, var(--ac), transparent);
    opacity: .55;
  }
  @media (max-width: 720px) {
    .prelude-cue { display: none; }
  }

  /* Chapter head — shared editorial pattern (Caput Primum etc.) */
  .chapter-head {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: clamp(24px, 5vw, 80px);
    align-items: start;
    margin-bottom: clamp(40px, 6vw, 64px);
  }
  .chapter-num {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .chapter-num .roman {
    font: italic 400 clamp(48px, 6vw, 72px)/1 var(--fd);
    color: var(--ac);
    letter-spacing: -.02em;
    font-feature-settings: "swsh";
  }
  .chapter-num .chapter-label {
    font: 400 10px/1.4 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--t3);
  }
  .chapter-title-block { max-width: 60ch; }
  .chapter-h {
    font: 400 clamp(30px, 4vw, 56px)/1.02 var(--fd);
    color: var(--t1);
    letter-spacing: -.02em;
    margin: 0 0 clamp(14px, 1.6vw, 22px);
    text-wrap: balance;
    font-feature-settings: "dlig", "liga", "kern";
  }
  .chapter-lede {
    font: 400 clamp(15px, 1.6vw, 18px)/1.6 var(--fi);
    color: var(--t2);
    max-width: 56ch;
  }
  @media (max-width: 760px) {
    .chapter-head { grid-template-columns: 1fr; gap: 14px; }
    .chapter-num { flex-direction: row; align-items: baseline; gap: 14px; }
    .chapter-num .roman { font-size: 40px; }
  }

  /* Method Mini — 4 columns under hero, replaces old .proc */
  .method-mini { padding-top: clamp(72px, 10vw, 120px) !important; }
  .method-mini-head { padding: 0 clamp(20px, 4vw, 48px); margin: 0 auto clamp(40px, 6vw, 64px); max-width: var(--max-w); }
  .method-mini-steps {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: var(--max-w);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--brd);
  }
  .method-mini-step {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: clamp(20px, 2.4vw, 32px) clamp(16px, 2vw, 28px);
    border-right: 1px solid var(--brd);
    position: relative;
  }
  .method-mini-step:last-child { border-right: none; }
  .method-mini-step::before {
    content: '';
    position: absolute;
    top: -1px; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ac), transparent 80%);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform .45s var(--ease, cubic-bezier(.22,.61,.36,1));
  }
  .method-mini-step:hover::before { transform: scaleX(1); }
  .step-no-r {
    font: italic 400 24px/1 var(--fd);
    color: var(--ac);
    font-feature-settings: "swsh";
  }
  .step-latin {
    font: 400 10px/1 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--t3);
  }
  .method-mini .step-t {
    font: 400 clamp(18px, 1.8vw, 22px)/1.2 var(--fd);
    color: var(--t1);
    letter-spacing: -.01em;
  }
  .method-mini .step-d {
    font: 400 13px/1.5 var(--fi);
    color: var(--t2);
    margin: 0;
  }
  @media (max-width: 1000px) {
    .method-mini-steps { grid-template-columns: 1fr 1fr; }
    .method-mini-step:nth-child(2) { border-right: none; }
    .method-mini-step:nth-child(1),
    .method-mini-step:nth-child(2) { border-bottom: 1px solid var(--brd); }
  }
  @media (max-width: 600px) {
    .method-mini-steps { grid-template-columns: 1fr; }
    .method-mini-step { border-right: none; border-bottom: 1px solid var(--brd); }
    .method-mini-step:last-child { border-bottom: none; }
  }

  /* Formula stage — editorial wrapper around existing pills */
  .formula-stage {
    border: 1px solid var(--brd);
    background: var(--surf);
    border-radius: 0;
  }
  .formula-stage-head {
    border-bottom: 1px solid var(--brd);
    padding-bottom: 18px;
    margin-bottom: 24px;
  }
  .formula-headline-price {
    font: italic 400 22px/1 var(--fd) !important;
    color: var(--ac) !important;
    font-feature-settings: "swsh", "tnum";
  }
  .formula-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 18px;
    padding: 18px 0;
    border-top: 1px dashed var(--brd);
    align-items: start;
  }
  .formula-row:first-of-type { border-top: none; }
  .formula-row-label {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
    line-height: 1;
  }
  .formula-row-n {
    font: italic 400 22px/1 var(--fd);
    color: var(--ac);
    font-feature-settings: "swsh";
  }
  .formula-row-t {
    font: 400 14px/1 var(--fi);
    color: var(--t1);
    text-transform: uppercase;
    letter-spacing: .14em;
  }
  .formula-row-latin {
    font: 400 9px/1 var(--fm);
    color: var(--t3);
    letter-spacing: .22em;
    text-transform: uppercase;
  }
  .formula-options { display: flex; flex-wrap: wrap; gap: 8px; }
  .formula-extras .pill {
    display: inline-flex;
    align-items: baseline;
    gap: 12px;
    text-align: left;
  }
  .formula-extras .pill-p {
    font: italic 400 13px/1 var(--fd);
    color: var(--ac);
    opacity: .85;
    font-feature-settings: "swsh", "tnum";
  }
  .formula-extras .pill.active .pill-p { opacity: 1; color: var(--ac3, #f6e27a); }

  @media (max-width: 760px) {
    .formula-row { grid-template-columns: 1fr; gap: 12px; }
    .formula-row-label { padding-bottom: 4px; }

    /* Extras: full-width rows so price never gets clipped on narrow screens */
    .formula-extras { width: 100%; }
    .formula-extras .pill {
      width: 100%;
      justify-content: space-between;
      gap: 16px;
      overflow: visible;
      text-align: left;
    }
    .formula-extras .pill-l {
      flex: 1;
      min-width: 0;
      white-space: normal;
      line-height: 1.25;
    }
    .formula-extras .pill-p {
      flex-shrink: 0;
      white-space: nowrap;
    }
  }

  /* Two-column layout: form + sticky receipt aside */
  .order-flow .order-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: clamp(24px, 3vw, 48px);
    align-items: start;
  }
  @media (max-width: 1024px) {
    .order-flow .order-inner { grid-template-columns: 1fr; }
  }

  /* Ratio receipt panel */
  .formula-receipt {
    position: sticky;
    top: calc(var(--nav-h) + 16px);
    border: 1px solid var(--gold-line, var(--ac-line));
    background: var(--ink-2, var(--bg2));
    padding: clamp(20px, 2.4vw, 32px);
    display: flex;
    flex-direction: column;
    gap: 18px;
    box-shadow: 0 24px 60px -20px rgba(0,0,0,.6);
  }
  :global([data-theme="light"]) .formula-receipt {
    background: #fff;
    box-shadow: 0 4px 14px rgba(60,48,20,.06), 0 18px 40px -12px rgba(60,48,20,.10);
  }
  .formula-receipt-head {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--brd);
  }
  .receipt-title {
    font: 400 12px/1 var(--fi);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--t2);
  }
  .receipt-sep { color: var(--ac); margin: 0 4px; }
  .receipt-brand {
    font: 400 11px/1 var(--fi);
    color: var(--t3);
    letter-spacing: .04em;
  }

  .formula-receipt-rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .receipt-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 8px;
    align-items: baseline;
    font: 400 14px/1.4 var(--fi);
    color: var(--t2);
  }
  .receipt-row .rr-l { color: var(--t1); }
  .receipt-row .rr-d {
    border-bottom: 1px dotted var(--brd);
    height: 0;
    transform: translateY(-4px);
  }
  .receipt-row .rr-r {
    font-variant-numeric: tabular-nums;
    color: var(--t1);
    white-space: nowrap;
  }
  .receipt-row--add .rr-l { color: var(--ac); font-style: italic; }
  .receipt-row--add .rr-r { color: var(--ac); font-weight: 500; }

  .formula-total {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid var(--gold-line, var(--ac-line));
  }
  .formula-total-label {
    font: 400 11px/1 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--t3);
  }
  .formula-total-amount {
    font: 400 clamp(28px, 3.6vw, 42px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: -.01em;
    font-variant-numeric: tabular-nums;
  }
  .formula-total-amount .cur {
    color: var(--ac);
    font-style: italic;
    font-size: .7em;
  }

  .formula-whisper {
    font: 400 12px/1.55 var(--fi);
    color: var(--t3);
    margin: 0;
  }

  /* ══════════════════════════════════════════════════════════════
     EDITORIAL OVERRIDE — Dark Couture restyle (logic untouched)
     All selectors below intentionally match existing ones so "later
     rule wins" at the same specificity. Legacy IDs, data-vals and
     form names are NOT changed above — only visuals get replaced.
     ══════════════════════════════════════════════════════════════ */

  /* ── Prelude ── */
  .hero {
    min-height: auto;
    padding: calc(var(--nav-h) + 48px) clamp(20px, 4vw, 48px) clamp(48px, 8vw, 96px);
    display: block;
    text-align: left;
    overflow: visible;
    background: var(--ink);
  }
  .hero-glow { display: none !important; }
  .hero-inner.ord-prelude-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
    position: relative;
  }

  /* chapter-head (dup from editorial system — scoped styles don't cross pages) */
  .chapter-head {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: clamp(40px, 6vw, 120px);
    align-items: end;
    margin-bottom: clamp(40px, 6vw, 80px);
    padding-bottom: 48px;
    border-bottom: 1px solid var(--line-ref);
    position: relative;
  }
  .chapter-head::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 60px;
    height: 1px;
    background: var(--gold-ref);
  }
  @media (max-width: 900px) {
    .chapter-head { grid-template-columns: 1fr; gap: 28px; padding-bottom: 32px; }
  }
  .chapter-num { display: flex; flex-direction: column; gap: 16px; }
  .chapter-num .roman {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(80px, 9vw, 140px);
    line-height: 0.8;
    color: var(--gold-ref);
    font-weight: 400;
    letter-spacing: -0.03em;
  }
  .chapter-num .chapter-label {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .chapter-title-block { display: flex; flex-direction: column; gap: 24px; }
  .chapter-title-block .chapter-h {
    font-family: var(--fd);
    font-size: clamp(44px, 6vw, 96px);
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: var(--cream);
    font-weight: 400;
    max-width: 16ch;
    margin: 0;
    text-align: left;
    text-shadow: none;
  }
  .chapter-title-block .chapter-h em,
  .chapter-title-block .chapter-h .it {
    font-style: italic;
    color: var(--gold-ref);
    font-weight: 400;
  }
  .chapter-lede {
    max-width: 56ch;
    font-family: var(--fd);
    font-size: clamp(17px, 1.3vw, 20px);
    line-height: 1.55;
    color: var(--cream-2);
    font-weight: 400;
    margin: 0;
  }
  .chapter-lede em, .chapter-lede .it {
    font-style: italic;
    color: var(--gold-ref);
  }

  .ord-prelude-h { max-width: 18ch; }
  .ord-prelude-actions {
    margin-top: clamp(32px, 4vw, 48px);
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .prelude-cue.ord-prelude-cue {
    margin-top: clamp(40px, 6vw, 72px);
    position: static;
    transform: none;
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    color: var(--mute);
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    text-decoration: none;
    transition: color .4s var(--ease-silk);
  }
  .ord-prelude-cue:hover { color: var(--gold-ref); }
  .ord-prelude-cue .prelude-cue-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(180deg, transparent, var(--gold-ref));
  }

  /* ── Process / method-mini restyle ── */
  .proc {
    background: var(--ink);
    padding: clamp(64px, 10vw, 128px) clamp(20px, 4vw, 48px);
  }
  .proc-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
    display: block;
  }
  .proc-line { display: none; }
  .method-mini-steps {
    margin: clamp(40px, 5vw, 64px) 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--line-ref);
    border-top: 1px solid var(--line-ref);
    border-bottom: 1px solid var(--line-ref);
  }
  @media (max-width: 900px) {
    .method-mini-steps { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .method-mini-steps { grid-template-columns: 1fr; }
  }
  .method-mini-step {
    background: var(--ink);
    padding: clamp(28px, 4vw, 44px) clamp(22px, 3vw, 32px);
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    transition: background .5s var(--ease-silk);
  }
  .method-mini-step:hover { background: var(--ink-2); }
  .method-mini-step::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 0; height: 1px;
    background: var(--gold-ref);
    transition: width .7s var(--ease-silk);
  }
  .method-mini-step:hover::before { width: 100%; }
  .method-mini-step .step-no-r {
    font-family: var(--fd);
    font-style: italic;
    font-size: 24px;
    color: var(--gold-ref);
    opacity: 0.8;
    line-height: 1;
  }
  .method-mini-step .step-latin {
    font-family: var(--fd);
    font-style: italic;
    font-size: 13px;
    color: var(--mute);
    line-height: 1;
  }
  .method-mini-step .step-t {
    font-family: var(--fd);
    font-size: clamp(20px, 2vw, 24px);
    font-weight: 500;
    color: var(--cream);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .method-mini-step .step-d {
    font-family: var(--fd);
    font-size: 15px;
    line-height: 1.55;
    color: var(--mute);
    font-style: italic;
    margin: 0;
  }

  /* ── Order flow layout ── */
  .order-flow {
    background: var(--ink);
    padding: clamp(64px, 10vw, 128px) clamp(20px, 4vw, 48px);
  }
  .order-inner,
  .order-flow .order-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: 0;
    background: transparent;
    border: 0;
    align-items: start;
  }
  @media (max-width: 1100px) {
    .order-inner,
    .order-flow .order-inner { grid-template-columns: 1fr; gap: clamp(24px, 4vw, 40px); }
  }
  .order-main {
    background: transparent;
    padding: 0 clamp(20px, 3vw, 56px) 0 0;
    border-right: 1px solid var(--line-ref);
  }
  @media (max-width: 1100px) {
    .order-main { border-right: 0; padding: 0; }
  }
  .order-step {
    padding-bottom: clamp(32px, 4vw, 48px);
    margin-bottom: clamp(32px, 4vw, 48px);
    border-bottom: 1px solid var(--line-ref);
  }
  .order-step:last-of-type { border-bottom: 0; margin-bottom: 24px; }
  .step-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 20px;
    align-items: baseline;
    margin-bottom: clamp(24px, 3vw, 36px);
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line-ref);
  }
  .step-badge {
    font-family: var(--fd);
    font-style: italic;
    font-size: 22px;
    color: var(--gold-ref);
    line-height: 1;
    letter-spacing: 0;
    padding: 0;
    background: transparent;
    border: 0;
  }
  .step-heading {
    font-family: var(--fd);
    font-size: clamp(24px, 2.4vw, 32px);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--cream);
    font-weight: 400;
    margin: 0;
  }
  .formula-stage-head .calc-price,
  .formula-headline-price {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(20px, 2vw, 24px);
    color: var(--gold-ref);
    font-feature-settings: "tnum";
    letter-spacing: 0;
    white-space: nowrap;
  }

  /* ── Formula rows ── */
  .formula-stage { display: block; background: transparent; border: 0; padding: 0; }
  .calc-row.formula-row,
  .formula-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 28px;
    align-items: start;
    padding: clamp(20px, 3vw, 28px) 0;
    border-bottom: 1px solid var(--line-ref);
  }
  .formula-row:last-child { border-bottom: 0; }
  @media (max-width: 640px) {
    .formula-row { grid-template-columns: 1fr; gap: 14px; }
  }
  .formula-row-label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 4px;
  }
  .formula-row-label .formula-row-n,
  .formula-row-n {
    font-family: var(--fd);
    font-style: italic;
    font-size: 32px;
    line-height: 1;
    color: var(--gold-ref);
  }
  .formula-row-label .formula-row-t,
  .formula-row-t {
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .formula-row-latin {
    font-family: var(--fd);
    font-style: italic;
    font-size: 13px;
    color: var(--mute);
    letter-spacing: 0;
  }

  /* ── Pills → editorial formula-opt ── */
  .calc-pills.formula-options,
  .formula-options {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .calc-pills .pill,
  .formula-options .pill {
    padding: 12px 18px;
    background: transparent;
    border: 1px solid var(--line-2-ref);
    color: var(--cream-2);
    font-family: var(--fi);
    font-size: 13px;
    font-weight: 400;
    cursor: pointer;
    position: relative;
    transition: color .45s var(--ease-silk), border-color .45s, background .45s;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    line-height: 1;
    overflow: hidden;
    isolation: isolate;
    border-radius: 0;
    text-transform: none;
    letter-spacing: 0;
  }
  .calc-pills .pill::before,
  .formula-options .pill::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--gold-soft);
    transform: translateY(101%);
    transition: transform .5s var(--ease-kine);
    z-index: -1;
  }
  .calc-pills .pill:hover,
  .formula-options .pill:hover {
    border-color: var(--gold-line);
