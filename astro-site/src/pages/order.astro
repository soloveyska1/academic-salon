    max-height: 0;
    overflow: hidden;
    transition: opacity var(--dur), max-height var(--dur), margin var(--dur);
    margin: 0;
  }
  .form-toast--visible {
    opacity: 1;
    max-height: 80px;
    margin-bottom: 12px;
  }
  .form-toast--error {
    background: rgba(220, 38, 38, .12);
    border: 1px solid rgba(220, 38, 38, .25);
