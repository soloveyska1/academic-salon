---
import Base from '../layouts/Base.astro';
---

<Base title="Заказать работу — Академический Салон" currentPath="/order">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <h1 class="hero-t">
        <span class="w" style="--i:0">Сделаем</span>
        <span class="w" style="--i:1">работу</span>
        <span class="w" style="--i:2">за</span>
        <span class="w" style="--i:3">вас.</span>
      </h1>
      <p class="hero-sub">Курсовые, дипломные, рефераты — индивидуально, в срок, с гарантией</p>
      <div class="hero-rule" aria-hidden="true"></div>
      <div class="hero-btns">
        <a href="https://vk.me/academicsaloon" target="_blank" rel="noopener" class="hero-cta hero-cta--primary">Написать нам</a>
        <a href="#form" class="hero-cta hero-cta--ghost" id="heroScroll">Рассчитать стоимость</a>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="proc">
    <div class="proc-inner">
      <div class="proc-line" aria-hidden="true"></div>
      <div class="step">
        <span class="step-n" aria-hidden="true">01</span>
        <b class="step-t">Тема</b>
        <p class="step-d">Вы описываете задачу и сроки</p>
      </div>
      <div class="step">
        <span class="step-n" aria-hidden="true">02</span>
        <b class="step-t">Работа</b>
        <p class="step-d">Мы пишем и проверяем</p>
      </div>
      <div class="step">
        <span class="step-n" aria-hidden="true">03</span>
        <b class="step-t">Сдача</b>
        <p class="step-d">Вы получаете готовый файл</p>
      </div>
    </div>
  </section>

  <!-- UNIFIED ORDER FLOW -->
  <section class="order-flow" id="form">
    <div class="order-inner">

      <div class="order-main">
        <form class="frm" id="orderForm" action="https://formsubmit.co/academsaloon@mail.ru" method="POST">
          <input type="hidden" name="_subject" value="Новая заявка — Академический Салон" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://bibliosaloon.ru/order" />
          <input type="text" name="_honey" style="display:none" />
          <input type="hidden" name="type" id="hidType" value="Реферат" />
          <input type="hidden" name="deadline" id="hidDeadline" value="2–3 недели" />
          <input type="hidden" name="uniqueness" id="hidUniq" value="70%" />
          <input type="hidden" name="estimated_price" id="hidPrice" value="от 2 500 ₽" />

          <!-- Step 1: Calculator -->
          <div class="order-step">
            <div class="step-head">
              <span class="step-badge">01</span>
              <h2 class="step-heading">Выберите параметры</h2>
              <span class="calc-price" id="calcPrice">от 2 500 ₽</span>
            </div>

            <div class="calc-row">
              <span class="calc-label">Работа</span>
              <div class="calc-pills" id="calcType">
                <button class="pill active" data-val="ref" data-name="Реферат" type="button">Реферат</button>
                <button class="pill" data-val="kont" data-name="Контрольная" type="button">Контрольная</button>
                <button class="pill" data-val="doklad" data-name="Доклад" type="button">Доклад</button>
                <button class="pill" data-val="kurs_t" data-name="Курсовая (теория)" type="button">Курсовая</button>
                <button class="pill" data-val="kurs_e" data-name="Курсовая + эмпирика" type="button">Курсовая + эмпирика</button>
                <button class="pill" data-val="diplom" data-name="Дипломная" type="button">Дипломная</button>
                <button class="pill" data-val="magist" data-name="Магистерская" type="button">Магистерская</button>
              </div>
            </div>

            <div class="calc-row">
              <span class="calc-label">Срок</span>
              <div class="calc-pills" id="calcSpeed">
                <button class="pill" data-val="today" data-name="Сегодня" type="button">Сегодня</button>
                <button class="pill" data-val="rush" data-name="1–3 дня" type="button">1–3 дня</button>
                <button class="pill" data-val="fast" data-name="1 неделя" type="button">1 неделя</button>
                <button class="pill active" data-val="normal" data-name="2–3 недели" type="button">2–3 недели</button>
              </div>
            </div>

            <div class="calc-row">
              <span class="calc-label">Уникальность</span>
              <div class="calc-pills" id="calcUniq">
                <button class="pill active" data-val="70" data-name="70%" type="button">70%</button>
                <button class="pill" data-val="80" data-name="80%" type="button">80%</button>
                <button class="pill" data-val="90" data-name="90%" type="button">90%</button>
              </div>
            </div>
          </div>

          <!-- Step 2: Details -->
          <div class="order-step">
            <div class="step-head">
              <span class="step-badge">02</span>
              <h2 class="step-heading">Опишите задачу</h2>
            </div>

            <div class="fields-row">
              <div class="field">
                <label for="fSubj">Предмет</label>
                <input type="text" id="fSubj" name="subject" placeholder="Например, психология" />
              </div>
              <div class="field">
                <label for="fTopic">Тема работы</label>
                <input type="text" id="fTopic" name="topic" placeholder="Тема или краткое описание" />
              </div>
            </div>

            <div class="field">
              <label for="fComment">Дополнительно</label>
              <textarea id="fComment" name="comment" rows="2" placeholder="Методичка, требования, пожелания..."></textarea>
            </div>
          </div>

          <!-- Submit -->
          <div class="order-submit">
            <button type="submit" class="submit-btn" id="submitBtn">
              <span class="submit-text">Отправить заявку</span>
              <span class="submit-price" id="submitPrice">от 2 500 ₽</span>
            </button>
            <p class="submit-note">Ответим в течение часа</p>
          </div>
        </form>

        <div class="frm-done" id="formDone" style="display:none">
          <span class="done-icon">&#10003;</span>
          <p class="done-title">Заявка отправлена</p>
          <p class="done-desc">Ответим в течение часа в Telegram или VK.</p>
        </div>

        <div class="order-alt">
          <span class="order-alt-text">Или напишите напрямую</span>
          <div class="order-alt-links">
            <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="alt-link" id="tgLink">
              Telegram
            </a>
            <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener" class="alt-link" id="vkLink">
              VK
            </a>
          </div>
        </div>
      </div>

      <aside class="proof-col">
        <p class="proof-label">Реальные отзывы</p>
        <div class="proof-scroll" id="proofScroll">
          <img src="/reviews/1.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/2.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/3.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/8.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/4.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/6.webp" alt="Отзыв" class="proof-img" loading="lazy" />
        </div>
      </aside>

    </div>
  </section>

  <!-- CLOSING -->
  <section class="closing">
    <p class="closing-t">Остались вопросы?<br/>Напишите — ответим за час.</p>
    <div class="closing-btns">
      <a href="https://vk.me/academicsaloon" target="_blank" rel="noopener" class="closing-btn closing-btn--vk">Написать в VK</a>
      <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="closing-btn">Telegram</a>
    </div>
    <nav class="closing-links">
      <a href="/catalog">Каталог</a>
      <a href="/faq">FAQ</a>
      <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
    </nav>
    <p class="closing-copy">© 2022–2026 Академический Салон</p>
  </section>

</Base>

<style>
  :global(.footer) { display: none; }

  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    padding-bottom: 12svh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    width: min(1000px, 90vw);
    height: min(800px, 80vw);
    top: 42%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45%, rgba(200,165,40,.12) 0%, transparent 70%),
      radial-gradient(ellipse 35% 30%, rgba(212,175,55,.06) 0%, transparent 50%);
    animation: glow 10s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes glow {
    0%, 100% { opacity: .5; transform: translate(-50%,-50%) scale(1); }
    50% { opacity: .9; transform: translate(-50%,-50%) scale(1.1); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .hero-t {
    font: 300 clamp(40px, 8vw, 64px)/.95 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    text-wrap: balance;
  }

  .w {
    display: inline-block;
    opacity: 0;
    transform: translateY(24px);
    animation: win .65s cubic-bezier(.25,0,0,1) forwards;
    animation-delay: calc(var(--i) * 110ms + 200ms);
  }

  @keyframes win {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-sub {
    margin-top: 28px;
    font: 400 clamp(13px, 2vw, 15px)/1.6 var(--fi);
    color: var(--t2);
    opacity: 0;
    transform: translateY(12px);
    animation: fin .5s cubic-bezier(.25,0,0,1) .75s forwards;
  }

  .hero-rule {
    width: 60px;
    height: 1px;
    margin: 24px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
    animation: rin .6s cubic-bezier(.25,0,0,1) 1s forwards;
  }

  @keyframes rin { to { opacity: .2; transform: scaleX(1); } }

  .hero-btns {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 32px;
    opacity: 0;
    transform: translateY(12px);
    animation: fin .5s cubic-bezier(.25,0,0,1) 1.2s forwards;
  }

  .hero-cta {
    padding: 18px 44px;
    border: 1px solid rgba(212,175,55,.2);
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t1);
    text-decoration: none;
    transition:
      background .4s cubic-bezier(.25,0,0,1),
      border-color .4s cubic-bezier(.25,0,0,1),
      transform .4s cubic-bezier(.25,0,0,1),
      box-shadow .4s cubic-bezier(.25,0,0,1);
  }

  .hero-cta--primary {
    background: rgba(212,175,55,.08);
    border-color: rgba(212,175,55,.25);
  }

  .hero-cta--primary:hover {
    background: rgba(212,175,55,.12);
    border-color: rgba(212,175,55,.4);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(212,175,55,.08);
  }

  .hero-cta--ghost {
    background: transparent;
    color: var(--t2);
  }

  .hero-cta--ghost:hover {
    border-color: rgba(212,175,55,.3);
    color: var(--t1);
    transform: translateY(-2px);
  }

  @keyframes fin { to { opacity: 1; transform: translateY(0); } }

  /* ═══════ PROCESS ═══════ */
  .proc {
    padding: 120px 48px;
  }

  .proc-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    position: relative;
  }

  .proc-line {
    position: absolute;
    top: 32px;
    left: 60px;
    right: 60px;
    height: 1px;
    background: var(--brd);
  }

  .step {
    position: relative;
    padding-top: 48px;
    padding-left: 16px;
  }

  .step-n {
    position: absolute;
    top: 0;
    left: 0;
    font: 300 72px/1 var(--fm);
    color: var(--ac);
    opacity: .06;
    user-select: none;
  }

  .step-t {
    display: block;
    font: 500 14px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t1);
  }

  .step-d {
    margin-top: 8px;
    font: 400 14px/1.5 var(--fi);
    color: var(--t3);
  }

  /* ═══════ UNIFIED ORDER FLOW ═══════ */
  .order-flow {
    padding: 0 48px 80px;
  }

  .order-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 64px;
    align-items: start;
    border-top: 1px solid var(--brd);
    padding-top: 64px;
  }

  .order-main { min-width: 0; }

  .order-step {
    margin-bottom: 48px;
  }

  .step-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 24px;
  }

  .step-badge {
    font: 300 28px/1 var(--fm);
    color: var(--ac);
    opacity: .15;
  }

  .step-heading {
    font: 300 clamp(20px, 3.5vw, 24px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  .calc-price {
    margin-left: auto;
    font: 300 clamp(24px, 4vw, 32px)/1 var(--fm);
    color: var(--ac);
    font-variant-numeric: tabular-nums;
    letter-spacing: -.02em;
    transition: transform .25s cubic-bezier(.22,1,.36,1);
  }

  .calc-price.is-bumped { transform: scale(1.05); }

  /* Calculator rows */
  .calc-row {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 14px 0;
    border-top: 1px solid var(--brd);
  }

  .calc-label {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    width: 100px;
    flex-shrink: 0;
  }

  .calc-pills { display: flex; gap: 0; flex-wrap: wrap; }

  .pill {
    padding: 8px 14px;
    border: none;
    background: transparent;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    cursor: pointer;
    position: relative;
    transition: color .3s cubic-bezier(.25,0,0,1), opacity .3s;
    opacity: .4;
  }

  .pill + .pill { border-left: 1px solid var(--brd); }
  .pill:hover { opacity: .8; color: var(--t1); }
  .pill.active { opacity: 1; color: var(--t1); }

  .pill.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 14px;
    right: 14px;
    height: 1px;
    background: var(--ac);
  }

  /* Form fields */
  .fields-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .field { margin-bottom: 24px; }

  .field label {
    display: block;
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    margin-bottom: 8px;
  }

  .field input, .field textarea {
    width: 100%;
    padding: 12px 0;
    border: none;
    border-bottom: 1px solid var(--brd);
    background: transparent;
    color: var(--t1);
    font: 400 15px/1.4 var(--fi);
    outline: none;
    transition: border-color .4s cubic-bezier(.25,0,0,1);
  }

  .field input::placeholder, .field textarea::placeholder { color: var(--t3); }
  .field input:focus, .field textarea:focus { border-bottom-color: rgba(212,175,55,.3); }
  .field textarea { resize: vertical; min-height: 56px; }

  /* Submit button */
  .order-submit { padding-top: 8px; }

  .submit-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 20px 40px;
    background: rgba(212,175,55,.08);
    border: 1px solid rgba(212,175,55,.2);
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t1);
    cursor: pointer;
    transition: all .4s cubic-bezier(.25,0,0,1);
  }

  .submit-price {
    font: 400 14px/1 var(--fm);
    color: var(--ac);
    opacity: .7;
  }

  .submit-btn:hover {
    background: rgba(212,175,55,.12);
    border-color: rgba(212,175,55,.4);
    box-shadow: 0 8px 32px rgba(212,175,55,.08);
    transform: translateY(-2px);
  }

  .submit-note {
    margin-top: 12px;
    font: 400 11px/1.4 var(--fi);
    color: var(--t3);
    opacity: .5;
    text-align: center;
  }

  /* Success state */
  .frm-done { text-align: center; padding: 64px 0; }
  .done-icon { font-size: 32px; color: var(--ac); display: block; margin-bottom: 16px; }
  .done-title { font: 300 24px/1.2 var(--fd); color: var(--t1); }
  .done-desc { margin-top: 8px; font: 400 14px/1.4 var(--fi); color: var(--t2); }

  /* Alternative contact */
  .order-alt {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--brd);
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .order-alt-text {
    font: 400 11px/1 var(--fi);
    color: var(--t3);
    opacity: .5;
  }

  .order-alt-links { display: flex; gap: 16px; }

  .alt-link {
    font: 400 12px/1 var(--fi);
    color: var(--t2);
    text-decoration: none;
    transition: color .3s;
  }

  .alt-link:hover { color: var(--ac); }

  /* Proof sidebar */
  .proof-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-height: 700px;
    overflow: hidden;
  }

  .proof-label {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
  }

  .proof-scroll {
    display: flex;
    flex-direction: column;
    gap: 12px;
    overflow-y: auto;
    max-height: 650px;
    padding-right: 6px;
    scrollbar-width: thin;
    scrollbar-color: rgba(212,175,55,.1) transparent;
  }

  .proof-scroll::-webkit-scrollbar { width: 3px; }
  .proof-scroll::-webkit-scrollbar-track { background: transparent; }
  .proof-scroll::-webkit-scrollbar-thumb { background: rgba(212,175,55,.12); border-radius: 2px; }

  .proof-img {
    width: 100%;
    height: auto;
    border-radius: 10px;
    border: 1px solid var(--brd);
    opacity: .8;
    transition: opacity .3s;
  }

  .proof-img:hover { opacity: 1; }

  @media (max-width: 860px) {
    .order-flow { padding: 0 24px 64px; }
    .order-inner { grid-template-columns: 1fr; gap: 48px; }
    .calc-row { flex-direction: column; gap: 10px; align-items: flex-start; }
    .calc-label { width: auto; }
    .calc-pills { gap: 4px; }
    .pill + .pill { border-left: none; }
    .fields-row { grid-template-columns: 1fr; gap: 0; }
    .step-head { flex-wrap: wrap; }
    .calc-price { margin-left: 0; }
    .order-alt { flex-direction: column; align-items: flex-start; gap: 12px; }
  }

  /* old calc/form CSS removed — merged into unified order flow above */
  /* ═══════ CLOSING ═══════ */
  .closing {
    text-align: center;
    padding: 120px 24px 64px;
    border-top: 1px solid var(--brd);
  }

  .closing-t {
    font: 300 clamp(22px, 4vw, 28px)/1.4 var(--fd);
    color: var(--t2);
  }

  .closing-btns {
    margin-top: 32px;
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .closing-btn {
    padding: 16px 36px;
    border: 1px solid var(--brd);
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t2);
    text-decoration: none;
    transition: all .4s cubic-bezier(.25,0,0,1);
  }

  .closing-btn:hover {
    border-color: var(--brd-h);
    color: var(--t1);
    transform: translateY(-2px);
  }

  .closing-btn--vk {
    background: rgba(212,175,55,.06);
    border-color: rgba(212,175,55,.2);
    color: var(--t1);
  }

  .closing-btn--vk:hover {
    background: rgba(212,175,55,.1);
    border-color: rgba(212,175,55,.35);
    box-shadow: 0 8px 32px rgba(212,175,55,.06);
  }

  .closing-links {
    margin-top: 40px;
    display: flex;
    justify-content: center;
    gap: 24px;
  }

  .closing-links a {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .closing-links a:hover { color: var(--t2); }

  .closing-copy {
    margin-top: 24px;
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    letter-spacing: .1em;
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 860px) {
    .proc { padding: 80px 24px; }

    .proc-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .proc-line { display: none; }

    .form-section { padding: 0 24px 80px; }

    .form-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .proof-col { padding-top: 0; }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .w, .hero-sub, .hero-rule, .hero-cta {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }

    .hero-rule { opacity: .2 !important; }
    .hero-glow { animation: none !important; }

    .frm-btn, .hero-cta, .frm-links a, .closing-links a {
      transition: none !important;
    }
  }
</style>

<script>
  function initOrderPage() {
    var prices = {
      ref:    { base: 2500,  today: 2.2, rush: 1.7, fast: 1.35, normal: 1 },
      kont:   { base: 2500,  today: 2.2, rush: 1.7, fast: 1.35, normal: 1 },
      doklad: { base: 2500,  today: 2.2, rush: 1.7, fast: 1.35, normal: 1 },
      kurs_t: { base: 14000, today: 1.8, rush: 1.5, fast: 1.35, normal: 1 },
      kurs_e: { base: 20000, today: 1.8, rush: 1.5, fast: 1.35, normal: 1 },
      diplom: { base: 45000, today: 1.5, rush: 1.3, fast: 1.2,  normal: 1 },
      magist: { base: 60000, today: 1.5, rush: 1.3, fast: 1.2,  normal: 1 },
    };
    var uniqMult = { '70': 1, '80': 1.1, '90': 1.2 };

    var type = 'ref', typeName = 'Реферат';
    var speed = 'normal', speedName = '2–3 недели';
    var uniq = '70', uniqName = '70%';
    var priceText = 'от 2 500 ₽';

    var priceEl = document.getElementById('calcPrice');
    var submitPrice = document.getElementById('submitPrice');
    var hidType = document.getElementById('hidType');
    var hidDeadline = document.getElementById('hidDeadline');
    var hidUniq = document.getElementById('hidUniq');
    var hidPrice = document.getElementById('hidPrice');
    var tgLink = document.getElementById('tgLink');
    var vkLink = document.getElementById('vkLink');

    function update() {
      var p = prices[type] || prices.ref;
      var raw = p.base * (p[speed] || 1) * (uniqMult[uniq] || 1);
      var val = Math.ceil(raw / 500) * 500;
      priceText = 'от ' + val.toLocaleString('ru-RU') + ' \u20BD';

      if (priceEl) {
        priceEl.textContent = priceText;
        priceEl.classList.add('is-bumped');
        setTimeout(function() { priceEl.classList.remove('is-bumped'); }, 250);
      }
      if (submitPrice) submitPrice.textContent = priceText;

      /* Auto-fill hidden form fields */
      if (hidType) hidType.value = typeName;
      if (hidDeadline) hidDeadline.value = speedName;
      if (hidUniq) hidUniq.value = uniqName;
      if (hidPrice) hidPrice.value = priceText;

      /* Update VK/TG links with pre-filled message */
      var msg = encodeURIComponent('Здравствуйте! Хочу заказать: ' + typeName + ', срок: ' + speedName + ', уникальность: ' + uniqName + '.');
      if (vkLink) vkLink.href = 'https://vk.com/im?sel=-227416098&msg=' + msg;
      if (tgLink) tgLink.href = 'https://t.me/academicsaloon?text=' + msg;
    }

    document.querySelectorAll('.calc-pills').forEach(function(group) {
      group.addEventListener('click', function(e) {
        var btn = e.target.closest('.pill');
        if (!btn) return;
        group.querySelectorAll('.pill').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        var id = group.id;
        if (id === 'calcType') { type = btn.dataset.val; typeName = btn.dataset.name; }
        else if (id === 'calcSpeed') { speed = btn.dataset.val; speedName = btn.dataset.name; }
        else if (id === 'calcUniq') { uniq = btn.dataset.val; uniqName = btn.dataset.name; }
        update();
      });
    });

    /* Form submission */
    var form = document.getElementById('orderForm');
    var done = document.getElementById('formDone');

    if (form && done) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var data = new FormData(form);

        fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { 'Accept': 'application/json' }
        }).then(function(res) {
          if (res.ok) {
            form.style.display = 'none';
            done.style.display = 'block';
          }
        }).catch(function() {
          var subj = data.get('type') || '';
          var body = 'Тип: ' + subj +
            '\nПредмет: ' + (data.get('subject') || '') +
            '\nСрок: ' + (data.get('deadline') || '') +
            '\nУникальность: ' + (data.get('uniqueness') || '') +
            '\nЦена: ' + (data.get('estimated_price') || '') +
            '\nТема: ' + (data.get('topic') || '') +
            '\n\n' + (data.get('comment') || '');
          window.location.href = 'mailto:academsaloon@mail.ru?subject=' +
            encodeURIComponent('Заявка: ' + subj) +
            '&body=' + encodeURIComponent(body);
        });
      });
    }

    /* Hero scroll CTA */
    var scrollBtn = document.getElementById('heroScroll');
    if (scrollBtn) {
      scrollBtn.addEventListener('click', function(e) {
        e.preventDefault();
        var target = document.getElementById('form');
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    }

    update();
  }

  initOrderPage();
  document.addEventListener('astro:after-swap', initOrderPage);
</script>
