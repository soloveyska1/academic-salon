---
import Base from '../layouts/Base.astro';
---

<Base title="Заказать работу — Академический Салон" currentPath="/order">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <h1 class="hero-t">
        <span class="w" style="--i:0">Сделаем</span>
        <span class="w" style="--i:1">работу</span>
        <span class="w" style="--i:2">за</span>
        <span class="w" style="--i:3">вас.</span>
      </h1>
      <p class="hero-sub">Курсовые, дипломные, рефераты — индивидуально, в срок, с гарантией</p>
      <div class="hero-rule" aria-hidden="true"></div>
      <div class="hero-btns">
        <a href="https://vk.me/academicsaloon" target="_blank" rel="noopener" class="hero-cta hero-cta--primary">Написать нам</a>
        <a href="#form" class="hero-cta hero-cta--ghost" id="heroScroll">Рассчитать стоимость</a>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="proc">
    <div class="proc-inner">
      <div class="proc-line" aria-hidden="true"></div>
      <div class="step">
        <span class="step-n" aria-hidden="true">01</span>
        <b class="step-t">Тема</b>
        <p class="step-d">Вы описываете задачу и сроки</p>
      </div>
      <div class="step">
        <span class="step-n" aria-hidden="true">02</span>
        <b class="step-t">Работа</b>
        <p class="step-d">Мы пишем и проверяем</p>
      </div>
      <div class="step">
        <span class="step-n" aria-hidden="true">03</span>
        <b class="step-t">Сдача</b>
        <p class="step-d">Вы получаете готовый файл</p>
      </div>
    </div>
  </section>

  <!-- UNIFIED ORDER FLOW -->
  <section class="order-flow" id="form">
    <div class="order-inner">

      <div class="order-main">
        <form class="frm" id="orderForm" enctype="multipart/form-data">
          <input type="hidden" name="workType" id="hidType" value="Реферат" />
          <input type="hidden" name="deadline" id="hidDeadline" value="2–3 недели" />

          <!-- Step 1: Calculator -->
          <div class="order-step">
            <div class="step-head">
              <span class="step-badge">01</span>
              <h2 class="step-heading">Выберите параметры</h2>
              <span class="calc-price" id="calcPrice">от 2 500 ₽</span>
            </div>

            <div class="calc-row">
              <span class="calc-label">Работа</span>
              <div class="calc-pills" id="calcType">
                <button class="pill active" data-val="ref" data-name="Реферат" type="button">Реферат</button>
                <button class="pill" data-val="kont" data-name="Контрольная" type="button">Контрольная</button>
                <button class="pill" data-val="doklad" data-name="Доклад" type="button">Доклад</button>
                <button class="pill" data-val="kurs_t" data-name="Курсовая (теория)" type="button">Курсовая</button>
                <button class="pill" data-val="kurs_e" data-name="Курсовая + эмпирика" type="button">Курсовая + эмпирика</button>
                <button class="pill" data-val="diplom" data-name="Дипломная" type="button">Дипломная</button>
                <button class="pill" data-val="magist" data-name="Магистерская" type="button">Магистерская</button>
              </div>
            </div>

            <div class="calc-row">
              <span class="calc-label">Срок</span>
              <div class="calc-pills" id="calcSpeed">
                <button class="pill" data-val="today" data-name="Сегодня" type="button">Сегодня</button>
                <button class="pill" data-val="rush" data-name="1–3 дня" type="button">1–3 дня</button>
                <button class="pill" data-val="fast" data-name="1 неделя" type="button">1 неделя</button>
                <button class="pill active" data-val="normal" data-name="2–3 недели" type="button">2–3 недели</button>
              </div>
            </div>

            <div class="calc-row">
              <span class="calc-label">Уникальность</span>
              <div class="calc-pills" id="calcUniq">
                <button class="pill active" data-val="70" data-name="70%" type="button">70%</button>
                <button class="pill" data-val="80" data-name="80%" type="button">80%</button>
                <button class="pill" data-val="90" data-name="90%" type="button">90%</button>
              </div>
            </div>
          </div>

          <!-- Step 2: Details -->
          <div class="order-step">
            <div class="step-head">
              <span class="step-badge">02</span>
              <h2 class="step-heading">Опишите задачу</h2>
            </div>

            <div class="fields-row">
              <div class="field">
                <label for="fSubj">Предмет</label>
                <input type="text" id="fSubj" name="subject" placeholder="Например, психология" />
              </div>
              <div class="field">
                <label for="fTopic">Тема работы</label>
                <input type="text" id="fTopic" name="topic" placeholder="Тема или краткое описание" />
              </div>
            </div>

            <div class="materials-row">
              <div class="materials-card materials-card--upload">
                <div class="materials-head">
                  <span class="materials-kicker">Файлы к заявке</span>
                  <p class="materials-title">Загрузите методичку, требования или примеры</p>
                </div>

                <div class="field field--upload">
                  <div class="upload-shell">
                    <input
                      type="file"
                      id="fFiles"
                      name="attachments"
                      multiple
                      accept=".pdf,.doc,.docx,.odt,.rtf,.txt,.xls,.xlsx,.csv,.ppt,.pptx,.jpg,.jpeg,.png,.webp,.heic,.heif,.zip,.rar,.7z"
                    />
                    <span class="upload-trigger">Выбрать файлы</span>
                    <div class="upload-copy">
                      <span class="upload-title">Методичка, требования, примеры, скриншоты</span>
                      <span class="upload-meta">До 6 файлов, суммарно до 45 МБ. Всё уйдёт вместе с заявкой в отдельный Telegram topic.</span>
                    </div>
                  </div>
                  <div class="upload-list" id="fileList" aria-live="polite">
                    <span class="upload-empty">Файлы не выбраны</span>
                  </div>
                </div>
              </div>

              <div class="materials-card materials-card--library">
                <div class="materials-head">
                  <span class="materials-kicker">Библиотека</span>
                  <p class="materials-title">Есть готовая работа и хотите поделиться ею?</p>
                </div>
                <p class="materials-text">
                  Откройте отдельную форму библиотеки. Файл сначала проверится антивирусом, потом попадёт вам в Telegram
                  в отдельный topic на модерацию.
                </p>
                <button type="button" class="library-reveal" id="libraryReveal">
                  Открыть форму библиотеки
                </button>
              </div>
            </div>

            <div class="field">
              <label for="fContact">Куда ответить <span class="required">*</span></label>
              <input type="text" id="fContact" name="contact" placeholder="VK, Telegram или телефон" required />
            </div>

            <div class="field">
              <label for="fComment">Дополнительно</label>
              <textarea id="fComment" name="comment" rows="2" placeholder="Методичка, требования, пожелания..."></textarea>
            </div>
          </div>

          <!-- Submit -->
          <div class="order-submit">
            <button type="submit" class="submit-btn" id="submitBtn">
              <span class="submit-text">Отправить заявку</span>
              <span class="submit-price" id="submitPrice">от 2 500 ₽</span>
            </button>
            <p class="submit-progress" id="orderSubmitStatus" aria-live="polite"></p>
            <div class="submit-meter" id="orderSubmitMeter" aria-hidden="true"><span class="submit-meter-fill"></span></div>
          </div>
        </form>

        <section class="library-share" id="libraryShare">
          <div class="library-share-head">
            <span class="library-share-badge">03</span>
            <div>
              <p class="library-share-kicker">Отдельный поток для библиотеки</p>
              <h2 class="library-share-title">Загрузить готовую работу в библиотеку</h2>
            </div>
          </div>

          <p class="library-share-lead">
            Если работа уже готова и вы хотите ею поделиться, отправьте её здесь. Она не публикуется автоматически:
            сначала файл проверяется антивирусом и приходит вам в Telegram в отдельный topic.
          </p>

          <form class="library-form" id="libraryForm" enctype="multipart/form-data">
            <div class="fields-row fields-row--library">
              <div class="field">
                <label for="libraryTitle">Название работы <span class="required">*</span></label>
                <input type="text" id="libraryTitle" name="title" placeholder="Например, Курсовая по возрастной психологии" required />
              </div>
              <div class="field">
                <label for="libraryContact">Куда ответить <span class="required">*</span></label>
                <input type="text" id="libraryContact" name="contact" placeholder="Telegram, VK, почта или телефон" required />
              </div>
            </div>

            <div class="fields-row fields-row--library">
              <div class="field">
                <label for="librarySubject">Предмет</label>
                <input type="text" id="librarySubject" name="subject" placeholder="Психология, социальная работа, конфликтология..." />
              </div>
              <div class="field">
                <label for="libraryCategory">Категория</label>
                <select id="libraryCategory" name="category" class="field-select">
                  <option value="Другое">Другое</option>
                  <option value="ВКР и дипломы">ВКР и дипломы</option>
                  <option value="Курсовые">Курсовые</option>
                  <option value="Рефераты">Рефераты</option>
                  <option value="Самостоятельные работы">Самостоятельные работы</option>
                  <option value="Отчёты по практике">Отчёты по практике</option>
                  <option value="Методические материалы">Методические материалы</option>
                  <option value="Конспекты лекций">Конспекты лекций</option>
                  <option value="Эссе">Эссе</option>
                  <option value="НПР">НПР</option>
                </select>
              </div>
            </div>

            <div class="field">
              <label for="libraryDescription">Описание</label>
              <textarea
                id="libraryDescription"
                name="description"
                rows="3"
                placeholder="Для какой дисциплины работа, чем полезна, что важно учесть при модерации"
              ></textarea>
            </div>

            <div class="field field--upload field--library-upload">
              <label for="libraryFiles">Файлы <span class="required">*</span></label>
              <div class="upload-shell upload-shell--library">
                <input
                  type="file"
                  id="libraryFiles"
                  name="files"
                  multiple
                  accept=".pdf,.doc,.docx,.odt,.rtf,.txt,.xls,.xlsx,.csv,.ppt,.pptx,.jpg,.jpeg,.png,.webp,.heic,.heif,.zip,.rar,.7z"
                  required
                />
                <span class="upload-trigger">Загрузить работу</span>
                <div class="upload-copy">
                  <span class="upload-title">Файл работы, титульник, приложения, пояснения</span>
                  <span class="upload-meta">До 5 файлов, суммарно до 45 МБ. Сначала антивирус и модерация, потом уже публикация.</span>
                </div>
              </div>
              <div class="upload-list" id="libraryFileList" aria-live="polite">
                <span class="upload-empty">Файлы для библиотеки не выбраны</span>
              </div>
            </div>

            <div class="library-form-actions">
              <button type="submit" class="submit-btn submit-btn--library" id="librarySubmitBtn">
                <span class="submit-text">Отправить в библиотеку</span>
                <span class="submit-price">на модерацию</span>
              </button>
              <p class="submit-progress submit-progress--left" id="librarySubmitStatus" aria-live="polite"></p>
              <div class="submit-meter submit-meter--left" id="librarySubmitMeter" aria-hidden="true"><span class="submit-meter-fill"></span></div>
            </div>
          </form>

          <div class="frm-done frm-done--library" id="libraryDone" style="display:none">
            <span class="done-icon">&#10003;</span>
            <p class="done-title">Работа отправлена в библиотеку</p>
            <p class="done-desc">Файлы приняты. Сейчас они проходят антивирусную проверку и после неё придут вам в Telegram в отдельный topic.</p>
          </div>
        </section>

        <div class="frm-done" id="formDone" style="display:none">
          <span class="done-icon">&#10003;</span>
          <p class="done-title">Заявка отправлена</p>
          <p class="done-desc">Мы получили вашу заявку. Если вы прикрепили файлы, они уже проходят антивирусную проверку в фоне.</p>

          <div class="done-contact">
            <p class="done-contact-text">Хотите уточнить детали или обсудить лично?</p>
            <div class="done-links">
              <a href="https://vk.me/academicsaloon" target="_blank" rel="noopener" class="done-link done-link--vk" id="doneVk">Написать в VK</a>
              <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="done-link" id="doneTg">Telegram</a>
              <a href="mailto:academsaloon@mail.ru" class="done-link">Почта</a>
            </div>
          </div>
        </div>

      </div>

      <aside class="proof-col">
        <div class="proof-header">
          <p class="proof-label">Отзывы</p>
          <div class="proof-nav">
            <button class="proof-arrow" id="proofPrev" type="button" aria-label="Предыдущий">&#8592;</button>
            <span class="proof-counter"><span id="proofCur">1</span> / 6</span>
            <button class="proof-arrow" id="proofNext" type="button" aria-label="Следующий">&#8594;</button>
          </div>
        </div>
        <div class="proof-slider" id="proofSlider">
          <img src="/reviews/1.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/2.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/3.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/8.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/4.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/6.webp" alt="Отзыв" class="proof-img" loading="lazy" />
        </div>
      </aside>

    </div>
  </section>

  <!-- CLOSING -->
  <section class="closing">
    <p class="closing-t">Остались вопросы?<br/>Напишите — ответим за час.</p>
    <div class="closing-btns">
      <a href="https://vk.me/academicsaloon" target="_blank" rel="noopener" class="closing-btn closing-btn--vk">Написать в VK</a>
      <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="closing-btn">Telegram</a>
    </div>
    <nav class="closing-links">
      <a href="/catalog">Каталог</a>
      <a href="/faq">FAQ</a>
      <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
    </nav>
    <p class="closing-copy">© 2022–2026 Академический Салон</p>
  </section>

</Base>

<style>
  :global(.footer) { display: none; }

  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    padding-bottom: 12svh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    width: min(1000px, 90vw);
    height: min(800px, 80vw);
    top: 42%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45%, rgba(200,165,40,.12) 0%, transparent 70%),
      radial-gradient(ellipse 35% 30%, rgba(212,175,55,.06) 0%, transparent 50%);
    animation: glow 10s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes glow {
    0%, 100% { opacity: .5; transform: translate(-50%,-50%) scale(1); }
    50% { opacity: .9; transform: translate(-50%,-50%) scale(1.1); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .hero-t {
    font: 300 clamp(40px, 8vw, 64px)/.95 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    text-wrap: balance;
  }

  .w {
    display: inline-block;
    opacity: 0;
    transform: translateY(24px);
    animation: win .65s cubic-bezier(.25,0,0,1) forwards;
    animation-delay: calc(var(--i) * 110ms + 200ms);
  }

  @keyframes win {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-sub {
    margin-top: 28px;
    font: 400 clamp(13px, 2vw, 15px)/1.6 var(--fi);
    color: var(--t2);
    opacity: 0;
    transform: translateY(12px);
    animation: fin .5s cubic-bezier(.25,0,0,1) .75s forwards;
  }

  .hero-rule {
    width: 60px;
    height: 1px;
    margin: 24px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
    animation: rin .6s cubic-bezier(.25,0,0,1) 1s forwards;
  }

  @keyframes rin { to { opacity: .2; transform: scaleX(1); } }

  .hero-btns {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 32px;
    opacity: 0;
    transform: translateY(12px);
    animation: fin .5s cubic-bezier(.25,0,0,1) 1.2s forwards;
  }

  .hero-cta {
    padding: 18px 44px;
    border: 1px solid rgba(212,175,55,.2);
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t1);
    text-decoration: none;
    transition:
      background .4s cubic-bezier(.25,0,0,1),
      border-color .4s cubic-bezier(.25,0,0,1),
      transform .4s cubic-bezier(.25,0,0,1),
      box-shadow .4s cubic-bezier(.25,0,0,1);
  }

  .hero-cta--primary {
    background: rgba(255,255,255,.03);
    border-color: rgba(212,175,55,.25);
  }

  .hero-cta--primary:hover {
    background: rgba(255,255,255,.05);
    border-color: rgba(212,175,55,.4);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,0,0,.2);
  }

  .hero-cta--ghost {
    background: transparent;
    color: var(--t2);
  }

  .hero-cta--ghost:hover {
    border-color: rgba(212,175,55,.3);
    color: var(--t1);
    transform: translateY(-2px);
  }

  @keyframes fin { to { opacity: 1; transform: translateY(0); } }

  /* ═══════ PROCESS ═══════ */
  .proc {
    padding: 120px 48px;
  }

  .proc-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    position: relative;
  }

  .proc-line {
    position: absolute;
    top: 32px;
    left: 60px;
    right: 60px;
    height: 1px;
    background: var(--brd);
  }

  .step {
    position: relative;
    padding-top: 48px;
    padding-left: 16px;
  }

  .step-n {
    position: absolute;
    top: 0;
    left: 0;
    font: 300 72px/1 var(--fm);
    color: var(--ac);
    opacity: .06;
    user-select: none;
  }

  .step-t {
    display: block;
    font: 500 14px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t1);
  }

  .step-d {
    margin-top: 8px;
    font: 400 14px/1.5 var(--fi);
    color: var(--t3);
  }

  /* ═══════ UNIFIED ORDER FLOW ═══════ */
  .order-flow {
    padding: 0 48px 80px;
  }

  .order-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(380px, 33vw, 460px);
    gap: clamp(40px, 5vw, 72px);
    align-items: start;
    border-top: 1px solid var(--brd);
    padding-top: 64px;
  }

  .order-main { min-width: 0; }

  .order-step {
    margin-bottom: 48px;
  }

  .step-head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 24px;
  }

  .step-badge {
    font: 300 28px/1 var(--fm);
    color: var(--ac);
    opacity: .15;
  }

  .step-heading {
    font: 300 clamp(20px, 3.5vw, 24px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  .calc-price {
    margin-left: auto;
    font: 300 clamp(24px, 4vw, 32px)/1 var(--fm);
    color: var(--ac);
    font-variant-numeric: tabular-nums;
    letter-spacing: -.02em;
    transition: transform .25s cubic-bezier(.22,1,.36,1);
  }

  .calc-price.is-bumped { transform: scale(1.05); }

  /* Calculator rows */
  .calc-row {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 14px 0;
    border-top: 1px solid var(--brd);
  }

  .calc-label {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    width: 100px;
    flex-shrink: 0;
  }

  .calc-pills { display: flex; gap: 0; flex-wrap: wrap; }

  .pill {
    padding: 8px 14px;
    border: none;
    background: transparent;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    cursor: pointer;
    position: relative;
    transition: color .3s cubic-bezier(.25,0,0,1), opacity .3s;
    opacity: .4;
  }

  .pill + .pill { border-left: 1px solid var(--brd); }
  .pill:hover { opacity: .8; color: var(--t1); }
  .pill.active { opacity: 1; color: var(--t1); }

  .pill.active::after {
