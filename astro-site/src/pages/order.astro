  .closing-links {
    margin-top: 40px;
    display: flex;
    justify-content: center;
    gap: 24px;
  }

  .closing-links a {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .closing-links a:hover { color: var(--t2); }

  .closing-copy {
    margin-top: 24px;
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    letter-spacing: .1em;
  }

  /* ═══════ LIGHT THEME ═══════ */
  :global([data-theme="light"]) .hero-glow {
    background:
      radial-gradient(ellipse 55% 45%, rgba(122,95,18,.06) 0%, transparent 70%),
      radial-gradient(ellipse 35% 30%, rgba(122,95,18,.04) 0%, transparent 50%);
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 860px) {
    .proc { padding: 80px 24px; }

    .proc-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .proc-line { display: none; }

    .form-section { padding: 0 24px 80px; }

    .form-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }

  }

  /* ═══════ TRUST SIGNALS ═══════ */
  .trust-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    margin-top: 24px;
