---
import Base from '../layouts/Base.astro';
---

<Base title="Заказать работу — Академический Салон" currentPath="/order">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <h1 class="hero-t">
        <span class="w" style="--i:0">Сделаем</span>
        <span class="w" style="--i:1">работу</span>
        <span class="w" style="--i:2">за</span>
        <span class="w" style="--i:3">вас.</span>
      </h1>
      <p class="hero-sub">Курсовые, дипломные, рефераты — индивидуально, в срок, с гарантией</p>
      <div class="hero-rule" aria-hidden="true"></div>
      <a href="#form" class="hero-cta">Обсудить работу</a>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="proc">
    <div class="proc-inner">
      <div class="proc-line" aria-hidden="true"></div>
      <div class="step">
        <span class="step-n" aria-hidden="true">01</span>
        <b class="step-t">Тема</b>
        <p class="step-d">Вы описываете задачу и сроки</p>
      </div>
      <div class="step">
        <span class="step-n" aria-hidden="true">02</span>
        <b class="step-t">Работа</b>
        <p class="step-d">Мы пишем и проверяем</p>
      </div>
      <div class="step">
        <span class="step-n" aria-hidden="true">03</span>
        <b class="step-t">Сдача</b>
        <p class="step-d">Вы получаете готовый файл</p>
      </div>
    </div>
  </section>

  <!-- CALCULATOR -->
  <section class="calc" id="calc">
    <div class="calc-inner">
      <h2 class="calc-heading">Рассчитать стоимость</h2>

      <div class="calc-row">
        <span class="calc-label">Тип работы</span>
        <div class="calc-pills" id="calcType">
          <button class="pill active" data-val="ref" type="button">Реферат</button>
          <button class="pill" data-val="kont" type="button">Контрольная</button>
          <button class="pill" data-val="doklad" type="button">Доклад</button>
          <button class="pill" data-val="kurs_t" type="button">Курсовая теория</button>
          <button class="pill" data-val="kurs_e" type="button">Курсовая + эмпирика</button>
          <button class="pill" data-val="diplom" type="button">Дипломная</button>
          <button class="pill" data-val="magist" type="button">Магистерская</button>
        </div>
      </div>

      <div class="calc-row">
        <span class="calc-label">Срок</span>
        <div class="calc-pills" id="calcSpeed">
          <button class="pill" data-val="rush" type="button">1–3 дня</button>
          <button class="pill" data-val="fast" type="button">1 неделя</button>
          <button class="pill active" data-val="normal" type="button">2–3 недели</button>
        </div>
      </div>

      <div class="calc-row">
        <span class="calc-label">Уникальность</span>
        <div class="calc-pills" id="calcUniq">
          <button class="pill active" data-val="70" type="button">70%</button>
          <button class="pill" data-val="80" type="button">80%</button>
          <button class="pill" data-val="90" type="button">90%</button>
        </div>
      </div>

      <div class="calc-bottom">
        <div class="calc-price-wrap">
          <span class="calc-price-label">Стоимость</span>
          <span class="calc-price" id="calcPrice">от 2 500 ₽</span>
        </div>
        <a href="#form" class="calc-order" id="calcCta">Оставить заявку</a>
      </div>

      <p class="calc-fine">Точная цена определяется после обсуждения темы и требований</p>
    </div>
  </section>

  <!-- FORM -->
  <section class="form-section" id="form">
    <div class="form-layout">

      <div class="form-col">
        <h2 class="form-heading">Оставить заявку</h2>

        <form class="frm" id="orderForm" action="https://formsubmit.co/academsaloon@mail.ru" method="POST">
          <input type="hidden" name="_subject" value="Новая заявка — Академический Салон" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://bibliosaloon.ru/order" />
          <input type="text" name="_honey" style="display:none" />

          <div class="field">
            <label for="fType">Тип работы</label>
            <select id="fType" name="type" required>
              <option value="" disabled selected>Выберите тип</option>
              <option value="Курсовая">Курсовая</option>
              <option value="ВКР">ВКР / Дипломная</option>
              <option value="Реферат">Реферат</option>
              <option value="Контрольная">Контрольная</option>
              <option value="Другое">Другое</option>
            </select>
          </div>

          <div class="field">
            <label for="fSubj">Предмет</label>
            <input type="text" id="fSubj" name="subject" placeholder="Например, психология" />
          </div>

          <div class="field">
            <label for="fDeadline">Срок сдачи</label>
            <input type="text" id="fDeadline" name="deadline" placeholder="Когда нужна работа?" />
          </div>

          <div class="field">
            <label for="fComment">Комментарий</label>
            <textarea id="fComment" name="comment" rows="3" placeholder="Тема, требования, пожелания..."></textarea>
          </div>

          <button type="submit" class="frm-btn">Отправить заявку</button>
          <p class="frm-note">Ответим в течение часа в Telegram или VK</p>
        </form>

        <div class="frm-done" id="formDone" style="display:none">
          <p class="frm-done-t">Заявка отправлена</p>
          <p class="frm-done-d">Ответим в течение часа.</p>
        </div>

        <div class="frm-alt">
          <p>Или напишите напрямую:</p>
          <div class="frm-links">
            <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
            <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
            <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
          </div>
        </div>
      </div>

      <aside class="proof-col">
        <p class="proof-label">Реальные отзывы</p>
        <div class="proof-scroll" id="proofScroll">
          <img src="/reviews/1.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/2.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/3.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/8.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/4.webp" alt="Отзыв" class="proof-img" loading="lazy" />
          <img src="/reviews/6.webp" alt="Отзыв" class="proof-img" loading="lazy" />
        </div>
      </aside>

    </div>
  </section>

  <!-- CLOSING -->
  <section class="closing">
    <p class="closing-t">Ваша работа — учиться.<br/>Остальное — наша.</p>
    <nav class="closing-links">
      <a href="/catalog">Каталог</a>
      <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
      <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
    </nav>
    <p class="closing-copy">© 2022–2026 Академический Салон</p>
  </section>

</Base>

<style>
  :global(.footer) { display: none; }

  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    padding-bottom: 12svh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    width: min(1000px, 90vw);
    height: min(800px, 80vw);
    top: 42%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45%, rgba(200,165,40,.12) 0%, transparent 70%),
      radial-gradient(ellipse 35% 30%, rgba(212,175,55,.06) 0%, transparent 50%);
    animation: glow 10s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes glow {
    0%, 100% { opacity: .5; transform: translate(-50%,-50%) scale(1); }
    50% { opacity: .9; transform: translate(-50%,-50%) scale(1.1); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .hero-t {
    font: 300 clamp(40px, 8vw, 64px)/.95 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    text-wrap: balance;
  }

  .w {
    display: inline-block;
    opacity: 0;
    transform: translateY(24px);
    animation: win .65s cubic-bezier(.25,0,0,1) forwards;
    animation-delay: calc(var(--i) * 110ms + 200ms);
  }

  @keyframes win {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-sub {
    margin-top: 28px;
    font: 400 clamp(13px, 2vw, 15px)/1.6 var(--fi);
    color: var(--t2);
    opacity: 0;
    transform: translateY(12px);
    animation: fin .5s cubic-bezier(.25,0,0,1) .75s forwards;
  }

  .hero-rule {
    width: 60px;
    height: 1px;
    margin: 24px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
    animation: rin .6s cubic-bezier(.25,0,0,1) 1s forwards;
  }

  @keyframes rin { to { opacity: .2; transform: scaleX(1); } }

  .hero-cta {
    display: inline-block;
    margin-top: 32px;
    padding: 18px 56px;
    border: 1px solid rgba(212,175,55,.2);
    font: 300 italic 15px/1 var(--fd);
    color: var(--t2);
    text-decoration: none;
    opacity: 0;
    transform: translateY(12px);
    animation: fin .5s cubic-bezier(.25,0,0,1) 1.2s forwards;
    transition:
      background .5s cubic-bezier(.25,0,0,1),
      border-color .5s cubic-bezier(.25,0,0,1),
      color .5s cubic-bezier(.25,0,0,1);
  }

  .hero-cta:hover {
    background: rgba(212,175,55,.06);
    border-color: rgba(212,175,55,.3);
    color: var(--t1);
  }

  @keyframes fin { to { opacity: 1; transform: translateY(0); } }

  /* ═══════ PROCESS ═══════ */
  .proc {
    padding: 120px 48px;
  }

  .proc-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    position: relative;
  }

  .proc-line {
    position: absolute;
    top: 32px;
    left: 60px;
    right: 60px;
    height: 1px;
    background: var(--brd);
  }

  .step {
    position: relative;
    padding-top: 48px;
    padding-left: 16px;
  }

  .step-n {
    position: absolute;
    top: 0;
    left: 0;
    font: 300 72px/1 var(--fm);
    color: var(--ac);
    opacity: .06;
    user-select: none;
  }

  .step-t {
    display: block;
    font: 500 14px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t1);
  }

  .step-d {
    margin-top: 8px;
    font: 400 14px/1.5 var(--fi);
    color: var(--t3);
  }

  /* ═══════ CALCULATOR ═══════ */
  .calc {
    padding: 0 48px 80px;
    border-bottom: 1px solid var(--brd);
  }

  .calc-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .calc-heading {
    font: 300 clamp(22px, 4vw, 28px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    margin-bottom: 40px;
  }

  .calc-row {
    display: flex;
    align-items: baseline;
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid var(--brd);
  }

  .calc-row:first-of-type {
    border-top: 1px solid var(--brd);
  }

  .calc-label {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    width: 120px;
    flex-shrink: 0;
  }

  .calc-pills {
    display: flex;
    gap: 0;
    flex-wrap: wrap;
  }

  .pill {
    padding: 8px 16px;
    border: none;
    background: transparent;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    cursor: pointer;
    position: relative;
    transition: color .3s cubic-bezier(.25,0,0,1), opacity .3s;
    opacity: .5;
  }

  .pill + .pill {
    border-left: 1px solid var(--brd);
  }

  .pill:hover {
    opacity: .8;
    color: var(--t1);
  }

  .pill.active {
    opacity: 1;
    color: var(--t1);
  }

  .pill.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 16px;
    right: 16px;
    height: 1px;
    background: var(--ac);
  }

  .calc-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 32px 0 0;
    flex-wrap: wrap;
  }

  .calc-price-wrap {
    display: flex;
    align-items: baseline;
    gap: 16px;
  }

  .calc-price-label {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
  }

  .calc-price {
    font: 300 clamp(28px, 5vw, 36px)/1 var(--fm);
    color: var(--ac);
    font-variant-numeric: tabular-nums;
    letter-spacing: -.02em;
  }

  .calc-order {
    padding: 16px 40px;
    border: 1px solid rgba(212,175,55,.2);
    background: rgba(212,175,55,.06);
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t1);
    text-decoration: none;
    transition: all .4s cubic-bezier(.25,0,0,1);
  }

  .calc-order:hover {
    background: rgba(212,175,55,.1);
    border-color: rgba(212,175,55,.35);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(212,175,55,.06);
  }

  .calc-fine {
    margin-top: 16px;
    font: 400 11px/1.5 var(--fi);
    color: var(--t3);
    opacity: .5;
  }

  @media (max-width: 860px) {
    .calc { padding: 0 24px 64px; }

    .calc-row {
      flex-direction: column;
      gap: 12px;
    }

    .calc-label {
      width: auto;
    }

    .calc-pills {
      gap: 4px;
    }

    .pill + .pill {
      border-left: none;
    }

    .calc-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
  }

  /* ═══════ FORM SECTION ═══════ */
  .form-section {
    padding: 0 48px 120px;
  }

  .form-layout {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 560px 1fr;
    gap: 80px;
    align-items: start;
    border-top: 1px solid var(--brd);
    padding-top: 80px;
  }

  .form-heading {
    font: 300 28px/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    margin-bottom: 40px;
  }

  /* Fields */
  .field {
    margin-bottom: 28px;
  }

  .field label {
    display: block;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    margin-bottom: 8px;
  }

  .field input,
  .field select,
  .field textarea {
    width: 100%;
    padding: 12px 0;
    border: none;
    border-bottom: 1px solid var(--brd);
    background: transparent;
    color: var(--t1);
    font: 400 15px/1.4 var(--fi);
    outline: none;
    transition: border-color .4s cubic-bezier(.25,0,0,1);
    appearance: none;
    -webkit-appearance: none;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--t3);
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    border-bottom-color: rgba(212,175,55,.25);
  }

  .field select {
    cursor: pointer;
    color: var(--t2);
  }

  .field select option {
    background: var(--bg);
    color: var(--t1);
  }

  .field textarea {
    resize: vertical;
    min-height: 72px;
  }

  .frm-btn {
    margin-top: 8px;
    padding: 16px 48px;
    border: 1px solid rgba(212,175,55,.2);
    background: none;
    font: 300 italic 15px/1 var(--fd);
    color: var(--t2);
    cursor: pointer;
    transition:
      background .5s cubic-bezier(.25,0,0,1),
      border-color .5s cubic-bezier(.25,0,0,1),
      color .5s cubic-bezier(.25,0,0,1);
  }

  .frm-btn:hover {
    background: rgba(212,175,55,.06);
    border-color: rgba(212,175,55,.3);
    color: var(--t1);
  }

  .frm-note {
    margin-top: 12px;
    font: 400 12px/1.4 var(--fi);
    color: var(--t3);
  }

  /* Success */
  .frm-done-t {
    font: 300 24px/1.2 var(--fd);
    color: var(--t1);
  }

  .frm-done-d {
    margin-top: 8px;
    font: 400 14px/1.4 var(--fi);
    color: var(--t3);
  }

  /* Alternative contact */
  .frm-alt {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--brd);
  }

  .frm-alt p {
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    margin-bottom: 12px;
  }

  .frm-links {
    display: flex;
    gap: 20px;
  }

  .frm-links a {
    font: 400 13px/1 var(--fi);
    color: var(--t3);
    text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .frm-links a:hover { color: var(--t1); }

  /* Social proof sidebar — photo scroll */
  .proof-col {
    padding-top: 80px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-height: 600px;
    overflow: hidden;
  }

  .proof-label {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
  }

  .proof-scroll {
    display: flex;
    flex-direction: column;
    gap: 16px;
    overflow-y: auto;
    max-height: 520px;
    padding-right: 8px;
    scrollbar-width: thin;
    scrollbar-color: rgba(212,175,55,.15) transparent;
  }

  .proof-scroll::-webkit-scrollbar { width: 4px; }
  .proof-scroll::-webkit-scrollbar-track { background: transparent; }
  .proof-scroll::-webkit-scrollbar-thumb { background: rgba(212,175,55,.15); border-radius: 2px; }

  .proof-img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    border: 1px solid rgba(212,175,55,.06);
    opacity: .85;
    transition: opacity .3s;
  }

  .proof-img:hover {
    opacity: 1;
  }

  /* ═══════ CLOSING ═══════ */
  .closing {
    text-align: center;
    padding: 120px 24px 64px;
    border-top: 1px solid var(--brd);
  }

  .closing-t {
    font: 300 clamp(22px, 4vw, 28px)/1.4 var(--fd);
    color: var(--t2);
  }

  .closing-links {
    margin-top: 40px;
    display: flex;
    justify-content: center;
    gap: 24px;
  }

  .closing-links a {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t3);
    text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .closing-links a:hover { color: var(--t2); }

  .closing-copy {
    margin-top: 24px;
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    letter-spacing: .1em;
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 860px) {
    .proc { padding: 80px 24px; }

    .proc-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .proc-line { display: none; }

    .form-section { padding: 0 24px 80px; }

    .form-layout {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .proof-col { padding-top: 0; }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .w, .hero-sub, .hero-rule, .hero-cta {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }

    .hero-rule { opacity: .2 !important; }
    .hero-glow { animation: none !important; }

    .frm-btn, .hero-cta, .frm-links a, .closing-links a {
      transition: none !important;
    }
  }
</style>

<script>
  /* ═══════ PRICE CALCULATOR ═══════ */
  function initCalc() {
    /*
      Базовые цены (стандарт, 2-3 недели, 70%):
      Реферат / Контрольная / Доклад = 2 500 ₽
      Курсовая теоретическая          = 14 000 ₽
      Курсовая + эмпирическая часть   = 20 000 ₽
      Дипломная (бакалавр)             = 45 000 ₽
      Магистерская                     = 60 000 ₽

      Наценки за срок:
      Стандарт (2-3 недели): x1.0
      Быстро (1 неделя):    x1.35
      Срочно (1-3 дня):     x1.7  (только мелкие работы)
                             x1.5  (курсовые)
                             —     (дипломы: не предлагаем 1-3 дня)

      Наценки за уникальность (от базы 70%):
      70%: x1.0
      80%: x1.1
      90%: x1.2
    */
    var prices = {
      ref:    { base: 2500,  rush: 1.7, fast: 1.35, normal: 1 },
      kont:   { base: 2500,  rush: 1.7, fast: 1.35, normal: 1 },
      doklad: { base: 2500,  rush: 1.7, fast: 1.35, normal: 1 },
      kurs_t: { base: 14000, rush: 1.5, fast: 1.35, normal: 1 },
      kurs_e: { base: 20000, rush: 1.5, fast: 1.35, normal: 1 },
      diplom: { base: 45000, rush: 1.3, fast: 1.2,  normal: 1 },
      magist: { base: 60000, rush: 1.3, fast: 1.2,  normal: 1 },
    };
    var uniqMult = { '70': 1, '80': 1.1, '90': 1.2 };

    var type = 'ref', speed = 'normal', uniq = '70';
    var priceEl = document.getElementById('calcPrice');

    function update() {
      var p = prices[type] || prices.ref;
      var raw = p.base * (p[speed] || 1) * (uniqMult[uniq] || 1);
      /* Round to nearest 500 */
      var val = Math.ceil(raw / 500) * 500;
      if (priceEl) priceEl.textContent = 'от ' + val.toLocaleString('ru-RU') + ' \u20BD';
    }

    document.querySelectorAll('.calc-pills').forEach(function(group) {
      group.addEventListener('click', function(e) {
        var btn = e.target.closest('.pill');
        if (!btn) return;
        group.querySelectorAll('.pill').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        var id = group.id;
        if (id === 'calcType') type = btn.dataset.val;
        else if (id === 'calcSpeed') speed = btn.dataset.val;
        else if (id === 'calcUniq') uniq = btn.dataset.val;
        update();
      });
    });

    var calcCta = document.getElementById('calcCta');
    if (calcCta) {
      calcCta.addEventListener('click', function(e) {
        e.preventDefault();
        var target = document.getElementById('form');
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    }

    update();
  }

  initCalc();

  function initOrder() {
    var form = document.getElementById('orderForm');
    var done = document.getElementById('formDone');

    if (form && done) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var data = new FormData(form);

        fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { 'Accept': 'application/json' }
        }).then(function(res) {
          if (res.ok) {
            form.style.display = 'none';
            done.style.display = 'block';
          }
        }).catch(function() {
          /* Fallback: mailto */
          var subj = data.get('type') || '';
          var body = 'Предмет: ' + (data.get('subject') || '') +
            '\nСрок: ' + (data.get('deadline') || '') +
            '\n\n' + (data.get('comment') || '');
          window.location.href = 'mailto:academsaloon@mail.ru?subject=' +
            encodeURIComponent('Заявка: ' + subj) +
            '&body=' + encodeURIComponent(body);
        });
      });
    }

    /* Smooth scroll to form */
    var cta = document.querySelector('.hero-cta');
    if (cta) {
      cta.addEventListener('click', function(e) {
        e.preventDefault();
        var target = document.getElementById('form');
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    }
  }

  initOrder();
  document.addEventListener('astro:after-swap', initOrder);
</script>
