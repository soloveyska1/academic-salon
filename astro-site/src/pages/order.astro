---
import Base from '../layouts/Base.astro';
---

<Base title="Заказать работу — Библиотека академического салона" description="Закажите курсовую, дипломную, реферат или ВКР индивидуально. Расчёт стоимости онлайн, гарантия сроков, бесплатные доработки." currentPath="/order">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <h1 class="hero-t">
        <span class="w" style="--i:0">Сделаем</span>
        <span class="w" style="--i:1">работу</span>
        <span class="w" style="--i:2">за</span>
        <span class="w" style="--i:3">вас.</span>
      </h1>
      <p class="hero-sub">Курсовые, дипломные, рефераты — индивидуально, в срок, с гарантией</p>
      <div class="hero-rule" aria-hidden="true"></div>
      <div class="hero-btns">
        <a href="https://vk.me/academicsaloon" target="_blank" rel="noopener" class="hero-cta hero-cta--primary">Написать нам</a>
        <a href="#form" class="hero-cta hero-cta--ghost" id="heroScroll">Рассчитать стоимость</a>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="proc">
    <div class="proc-inner">
      <div class="proc-line" aria-hidden="true"></div>
      <div class="step">
        <span class="step-n" aria-hidden="true">01</span>
        <b class="step-t">Тема</b>
        <p class="step-d">Вы описываете задачу и сроки</p>
      </div>
      <div class="step">
        <span class="step-n" aria-hidden="true">02</span>
        <b class="step-t">Работа</b>
        <p class="step-d">Мы пишем и проверяем</p>
      </div>
      <div class="step">
        <span class="step-n" aria-hidden="true">03</span>
        <b class="step-t">Сдача</b>
        <p class="step-d">Вы получаете готовый файл</p>
      </div>
    </div>
  </section>

  <!-- UNIFIED ORDER FLOW -->
  <section class="order-flow" id="form">
    <div class="order-inner">

      <div class="order-main">
        <!-- Mobile progress indicator -->
        <div class="form-progress" id="formProgress">
          <div class="progress-step active" data-step="1">
            <span class="progress-num">1</span>
            <span class="progress-label">Параметры</span>
          </div>
          <div class="progress-line"></div>
          <div class="progress-step" data-step="2">
            <span class="progress-num">2</span>
            <span class="progress-label">Детали</span>
          </div>
        </div>

        <form class="frm" id="orderForm">
          <input type="hidden" name="workType" id="hidType" value="Реферат" />
          <input type="hidden" name="deadline" id="hidDeadline" value="2–3 недели" />

          <!-- Step 1: Calculator -->
          <div class="order-step">
            <div class="step-head">
              <span class="step-badge">01</span>
              <h2 class="step-heading">Выберите параметры</h2>
              <span class="calc-price" id="calcPrice">от 2 500 ₽</span>
            </div>

            <div class="calc-row">
              <span class="calc-label">Работа</span>
              <div class="calc-pills" id="calcType">
                <button class="pill active" data-val="ref" data-name="Реферат" type="button">Реферат</button>
                <button class="pill" data-val="kont" data-name="Контрольная" type="button">Контрольная</button>
                <button class="pill" data-val="doklad" data-name="Доклад" type="button">Доклад</button>
                <button class="pill" data-val="kurs_t" data-name="Курсовая (теория)" type="button">Курсовая</button>
                <button class="pill" data-val="kurs_e" data-name="Курсовая + эмпирика" type="button">Курсовая + эмпирика</button>
                <button class="pill" data-val="diplom" data-name="Дипломная" type="button">Дипломная</button>
                <button class="pill" data-val="magist" data-name="Магистерская" type="button">Магистерская</button>
              </div>
            </div>

            <div class="calc-row">
              <span class="calc-label">Срок</span>
              <div class="calc-pills" id="calcSpeed">
                <button class="pill" data-val="today" data-name="Сегодня" type="button">Сегодня</button>
                <button class="pill" data-val="rush" data-name="1–3 дня" type="button">1–3 дня</button>
                <button class="pill" data-val="fast" data-name="1 неделя" type="button">1 неделя</button>
                <button class="pill active" data-val="normal" data-name="2–3 недели" type="button">2–3 недели</button>
              </div>
            </div>

            <div class="calc-row">
              <span class="calc-label">Уникальность</span>
              <div class="calc-pills" id="calcUniq">
                <button class="pill active" data-val="70" data-name="70%" type="button">70%</button>
                <button class="pill" data-val="80" data-name="80%" type="button">80%</button>
                <button class="pill" data-val="90" data-name="90%" type="button">90%</button>
              </div>
            </div>
          </div>

          <!-- Step 2: Details -->
          <div class="order-step">
            <div class="step-head">
              <span class="step-badge">02</span>
              <h2 class="step-heading">Опишите задачу</h2>
            </div>

            <div class="fields-row">
              <div class="field">
                <label for="fSubj">Предмет</label>
                <input type="text" id="fSubj" name="subject" placeholder="Например, психология" autocapitalize="words" autocomplete="off" spellcheck="false" enterkeyhint="next" />
              </div>
              <div class="field">
                <label for="fTopic">Тема работы</label>
                <input type="text" id="fTopic" name="topic" placeholder="Тема или краткое описание" autocapitalize="sentences" autocomplete="off" enterkeyhint="next" />
              </div>
            </div>

            <div class="field">
              <label for="fContact">Куда ответить <span class="required">*</span></label>
              <input type="text" id="fContact" name="contact" placeholder="VK, Telegram или телефон" required autocapitalize="none" autocorrect="off" spellcheck="false" enterkeyhint="next" />
            </div>

            <div class="field">
              <label for="fComment">Дополнительно</label>
              <textarea id="fComment" name="comment" rows="2" placeholder="Методичка, требования, пожелания..." autocomplete="off" autocapitalize="sentences" enterkeyhint="done"></textarea>
            </div>

            <!-- File attach — inline, minimal -->
            <div class="attach-row" id="attachRow">
              <label class="attach-trigger" tabindex="0" role="button" aria-label="Прикрепить файлы">
                <svg class="attach-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>
                <span class="attach-label">Прикрепить файлы</span>
                <span class="attach-hint">до 6 файлов, 45 МБ</span>
                <input type="file" id="fFiles" multiple accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.txt,.rtf,.odt,.jpg,.jpeg,.png,.webp,.zip,.rar" class="attach-input" />
              </label>
              <div class="attach-chips" id="attachChips"></div>
            </div>
          </div>

          <!-- Submit with trust signals -->
          <div class="order-submit">
            <div class="form-toast" id="formToast" role="alert" aria-live="polite"></div>

            <!-- Trust signals — visible near submit button -->
            <div class="trust-row">
              <span class="trust-chip">✓ Ответ за час</span>
              <span class="trust-chip">✓ Оплата после согласования</span>
              <span class="trust-chip">✓ Бесплатные доработки</span>
            </div>

            <button type="submit" class="submit-btn premium-submit" id="submitBtn" aria-busy="false">
              <span class="premium-submit__seal" aria-hidden="true">АС</span>
              <span class="premium-submit__copy">
                <span class="premium-submit__eyebrow">Запрос в салон</span>
                <span class="submit-text premium-submit__label">Отправить заявку</span>
                <span class="premium-submit__status">Передаём заявку куратору</span>
              </span>
              <span class="submit-price premium-submit__meta" id="submitPrice">от 2 500 ₽</span>
            </button>

            <!-- Quick contact -->
            <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="quick-contact">
              Есть вопросы? Напишите в Telegram →
            </a>
          </div>
        </form>

        <div class="frm-done premium-success" id="formDone" style="display:none">
          <div class="premium-success__crest">
            <span class="premium-success__seal" aria-hidden="true">АС</span>
            <div class="premium-success__folio">
              <span class="premium-success__code">ORD-01</span>
              <span class="premium-success__deck">Заказ принят</span>
            </div>
          </div>
          <span class="premium-success__eyebrow">Куратор увидит заявку в течение часа</span>
          <p class="done-title">Заявка отправлена</p>
          <p class="done-desc">Мы получили вашу заявку и ответим в течение часа.</p>

          <div class="done-contact">
            <p class="done-contact-text">Хотите уточнить детали или обсудить лично?</p>
            <div class="done-links">
              <a href="https://vk.me/academicsaloon" target="_blank" rel="noopener" class="done-link done-link--vk" id="doneVk">Написать в VK</a>
              <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="done-link" id="doneTg">Telegram</a>
              <a href="mailto:academsaloon@mail.ru" class="done-link">Почта</a>
            </div>
          </div>
        </div>

      </div>

    </div>
  </section>

  <!-- CLOSING -->
  <section class="closing">
    <p class="closing-t">Остались вопросы?<br/>Напишите — ответим за час.</p>
    <div class="closing-btns">
      <a href="https://vk.me/academicsaloon" target="_blank" rel="noopener" class="closing-btn closing-btn--vk">Написать в VK</a>
      <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="closing-btn">Telegram</a>
    </div>
    <nav class="closing-links">
      <a href="/catalog">Каталог</a>
      <a href="/about#faq">FAQ</a>
      <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
    </nav>
    <p class="closing-copy">© 2022–2026 Библиотека академического салона</p>
  </section>

</Base>

<style>
  :global(.footer) { display: none; }

  /* ═══════ HERO ═══════ */
  .hero {
    position: relative;
    min-height: 100svh;
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
    padding-bottom: 12svh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-left: 24px;
    padding-right: 24px;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    width: min(1000px, 90vw);
    height: min(800px, 80vw);
    top: 42%;
    left: 50%;
    transform: translate(-50%, -50%);
    background:
      radial-gradient(ellipse 55% 45%, var(--ac-line) 0%, transparent 70%),
      radial-gradient(ellipse 35% 30%, var(--ac-sh) 0%, transparent 50%);
    animation: glow 10s var(--ease) infinite;
    pointer-events: none;
  }

  @keyframes glow {
    0%, 100% { opacity: .5; transform: translate(-50%,-50%) scale(1); }
    50% { opacity: .9; transform: translate(-50%,-50%) scale(1.1); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .hero-t {
    font: 300 clamp(40px, 8vw, 64px)/.95 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    text-wrap: balance;
  }

  .w {
    display: inline-block;
    opacity: 0;
    transform: translateY(24px);
    animation: win var(--dur-slow) var(--ease) forwards;
    animation-delay: calc(var(--i) * 110ms + 200ms);
  }

  @keyframes win {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-sub {
    margin-top: 28px;
    font: 400 clamp(13px, 2vw, 15px)/1.6 var(--fi);
    color: var(--t2);
    opacity: 0;
    transform: translateY(12px);
    animation: fin var(--dur-slow) var(--ease) .75s forwards;
  }

  .hero-rule {
    width: 60px;
    height: 1px;
    margin: 24px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
    animation: rin var(--dur-slow) var(--ease) 1s forwards;
  }

  @keyframes rin { to { opacity: .2; transform: scaleX(1); } }

  .hero-btns {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 32px;
    opacity: 0;
    transform: translateY(12px);
    animation: fin var(--dur-slow) var(--ease) 1.2s forwards;
  }

  .hero-cta {
    padding: 18px 44px;
    border: 1px solid var(--ac-b);
    font: 400 12px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t1);
    text-decoration: none;
    transition:
      background var(--dur-slow) var(--ease),
      border-color var(--dur-slow) var(--ease),
      transform var(--dur-slow) var(--ease),
      box-shadow var(--dur-slow) var(--ease);
  }

  .hero-cta--primary {
    background: var(--surf);
    border-color: var(--ac-b);
  }

  .hero-cta--primary:hover {
    background: var(--surf-h);
    border-color: var(--ac-b3);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,0,0,.2);
  }

  .hero-cta--ghost {
    background: transparent;
    color: var(--t2);
  }

  .hero-cta--ghost:hover {
    border-color: var(--ac-b2);
    color: var(--t1);
    transform: translateY(-2px);
  }

  @keyframes fin { to { opacity: 1; transform: translateY(0); } }

  /* ═══════ PROCESS ═══════ */
  .proc {
    padding: 120px 48px;
  }

  .proc-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
    position: relative;
  }

  .proc-line {
    position: absolute;
    top: 32px;
    left: 60px;
    right: 60px;
    height: 1px;
    background: var(--brd);
  }

  .step {
    position: relative;
    padding-top: 48px;
    padding-left: 16px;
  }

  .step-n {
    position: absolute;
    top: 0;
    left: 0;
    font: 300 72px/1 var(--fm);
    color: var(--ac);
    opacity: .06;
    user-select: none;
  }

  .step-t {
    display: block;
    font: 500 14px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--t1);
  }

  .step-d {
    margin-top: 8px;
    font: 400 14px/1.5 var(--fi);
    color: var(--t3);
  }

  /* ═══════ UNIFIED ORDER FLOW ═══════ */
  .order-flow {
    padding: 0 48px 80px;
  }

  .order-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    max-width: 720px;
    gap: 56px;
    align-items: start;
    border-top: 1px solid var(--brd);
    padding-top: 56px;
  }

  .order-main { min-width: 0; }

  .order-step {
    margin-bottom: 36px;
  }

  .step-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 20px;
  }

  .step-badge {
    font: 300 22px/1 var(--fm);
    color: var(--ac);
    opacity: .12;
  }

  .step-heading {
    font: 300 clamp(18px, 3vw, 22px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  .calc-price {
    margin-left: auto;
    font: 300 clamp(22px, 3.5vw, 28px)/1 var(--fm);
    color: var(--ac);
    font-variant-numeric: tabular-nums;
    letter-spacing: -.02em;
    transition: transform var(--dur) var(--ease-spring);
  }

  .calc-price.is-bumped { transform: scale(1.05); }

  /* Calculator rows */
  .calc-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 0;
    border-top: 1px solid var(--brd);
  }

  .calc-label {
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    width: 100px;
    flex-shrink: 0;
  }

  .calc-pills { display: flex; gap: 0; flex-wrap: wrap; }

  .pill {
    padding: 7px 12px;
    border: none;
    background: transparent;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    cursor: pointer;
    position: relative;
    transition: color var(--dur) var(--ease), opacity var(--dur);
    opacity: .4;
  }

  .pill + .pill { border-left: 1px solid var(--brd); }
  .pill:hover { opacity: .8; color: var(--t1); }
  .pill.active { opacity: 1; color: var(--t1); }

  .pill.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 14px;
    right: 14px;
    height: 1px;
    background: var(--ac);
  }

  /* Form fields */
  .fields-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .field { margin-bottom: 20px; }

  .field label {
    display: block;
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    margin-bottom: 8px;
  }

  .field input, .field textarea {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 12px;
    background: rgba(255,255,255,.03);
    color: var(--t1);
    font: 400 16px/1.5 var(--fi);
    outline: none;
    transition: border-color var(--dur) var(--ease-out),
                box-shadow var(--dur) var(--ease-out),
                background var(--dur);
  }

  .field input::placeholder, .field textarea::placeholder { color: var(--t3); }
  .required { color: var(--ac); opacity: .5; }
  .field input:focus, .field textarea:focus {
    border-color: var(--ac);
    box-shadow: 0 0 0 3px var(--ac-line);
    background: rgba(255,255,255,.05);
  }
  .field textarea { resize: vertical; min-height: 64px; }

  [data-theme="light"] .field input,
  [data-theme="light"] .field textarea {
    border-color: rgba(0,0,0,.1);
    background: rgba(0,0,0,.02);
  }
  [data-theme="light"] .field input:focus,
  [data-theme="light"] .field textarea:focus {
    border-color: var(--ac);
    box-shadow: 0 0 0 3px var(--ac-g);
    background: rgba(0,0,0,.03);
  }

  /* ═══════ FILE ATTACH ═══════ */
  .attach-row { margin-top: 4px; margin-bottom: 8px; }

  .attach-trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
    cursor: pointer;
    transition: color var(--dur) var(--ease);
  }

  .attach-icon {
    color: var(--t3);
    flex-shrink: 0;
    transition: color var(--dur) var(--ease);
  }

  .attach-trigger:hover .attach-icon,
  .attach-trigger:focus-visible .attach-icon { color: var(--ac); }

  .attach-label {
    font: 400 12px/1 var(--fi);
    color: var(--t3);
    transition: color var(--dur) var(--ease);
  }

  .attach-trigger:hover .attach-label { color: var(--t2); }

  .attach-hint {
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    opacity: .4;
    letter-spacing: .02em;
  }

  .attach-input {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    border: 0;
  }

  .attach-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 0;
    transition: margin var(--dur) var(--ease);
  }

  .attach-chips:not(:empty) { margin-top: 8px; }

  .attach-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: var(--surf);
    border: 1px solid var(--brd);
    border-radius: 8px;
    font: 400 11px/1 var(--fi);
    color: var(--t2);
    animation: chip-in var(--dur) var(--ease-spring);
  }

  @keyframes chip-in {
    from { opacity: 0; transform: scale(.9); }
    to { opacity: 1; transform: scale(1); }
  }

  .attach-chip-ext {
    font: 500 9px/1 var(--fm);
    color: var(--ac);
    text-transform: uppercase;
    letter-spacing: .04em;
    opacity: .7;
  }

  .attach-chip-name {
    max-width: 140px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .attach-chip-size {
    font: 400 10px/1 var(--fm);
    color: var(--t3);
    opacity: .5;
  }

  .attach-chip-rm {
    width: 14px; height: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    color: var(--t3);
    font-size: 12px;
    cursor: pointer;
    opacity: .4;
    transition: opacity .2s, color .2s;
    padding: 0;
    line-height: 1;
  }

  .attach-chip-rm:hover { opacity: 1; color: var(--red); }

  .attach-error {
    font: 400 11px/1.4 var(--fi);
    color: var(--red);
    opacity: .8;
    margin-top: 6px;
    animation: chip-in var(--dur) var(--ease-spring);
  }

  /* Submit button */
  .order-submit { padding-top: 8px; }

