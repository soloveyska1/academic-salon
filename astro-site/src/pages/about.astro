---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';
const total = D.length;
---

<Base
  title="Академический Салон — библиотека студенческих работ"
  description="235+ бесплатных работ по психологии, социальной работе и конфликтологии. Или закажите индивидуально."
  currentPath="/about"
>

  <!-- ACT 1 — Hook -->
  <section class="act act-hero">
    <div class="act-glow act-glow--cold" aria-hidden="true"></div>
    <h1 class="a1-t">
      <span class="w" style="--i:0">3 часа ночи.</span>
      <br/>
      <span class="w" style="--i:1">Дедлайн завтра.</span>
      <br/>
      <span class="w w--em" style="--i:2">Знакомо?</span>
    </h1>
    <div class="a1-arrow" aria-hidden="true">↓</div>
  </section>

  <!-- ACT 2 — Empathy -->
  <section class="act rv-group">
    <p class="a2-t rv" style="--d:0">Мы тоже через это прошли.</p>
    <p class="a2-sub rv" style="--d:1">Студенты петербургского вуза, которые решили помогать другим. Так появилась «Кладовая» — телеграм-канал, где делились работами.</p>
  </section>

  <!-- ACT 3 — Growth -->
  <section class="act rv-group">
    <div class="a3-nums">
      <span class="a3-n rv" style="--d:0" data-to="12">0</span>
      <span class="a3-arrow rv" style="--d:0">→</span>
      <span class="a3-n rv" style="--d:1" data-to="50">0</span>
      <span class="a3-arrow rv" style="--d:1">→</span>
      <span class="a3-n rv" style="--d:2" data-to="100">0</span>
      <span class="a3-arrow rv" style="--d:2">→</span>
      <span class="a3-n a3-n--final rv" style="--d:3" data-to={total}>0</span>
    </div>
    <p class="a3-cap rv" style="--d:4">документов в библиотеке. Бесплатно.</p>
  </section>

  <!-- ACT 4 — Evolution -->
  <section class="act rv-group">
    <p class="a4-pre rv" style="--d:0">Telegram стал работать нестабильно. Библиотека переехала в веб.</p>
    <div class="a4-rule rv" style="--d:1" aria-hidden="true"></div>
    <p class="a4-brand rv" style="--d:2">Так появился <span class="a4-gold">Академический Салон</span></p>
  </section>

  <!-- ACT 5 — Values -->
  <section class="act act-vals">
    <div class="val rv-group">
      <span class="val-n rv" style="--d:0">0 ₽</span>
      <p class="val-d rv" style="--d:1">за любой документ из каталога. Без регистрации, без подвоха.</p>
    </div>
    <div class="val rv-group">
      <span class="val-n rv" style="--d:0">100%</span>
      <p class="val-d rv" style="--d:1">антиплагиат на заказные работы. Гарантируем.</p>
    </div>
    <div class="val rv-group">
      <span class="val-n rv" style="--d:0">∞</span>
      <p class="val-d rv" style="--d:1">бесплатных правок. До полного соответствия.</p>
    </div>
    <div class="val rv-group">
      <span class="val-n rv" style="--d:0">1 час</span>
      <p class="val-d rv" style="--d:1">среднее время ответа. Telegram, VK, почта.</p>
    </div>
  </section>

  <!-- ACT 6 — FAQ -->
  <section class="act act-faq">
    <h2 class="faq-t rv-group rv" style="--d:0">Частые вопросы</h2>

    <details class="fq">
      <summary><span>Это бесплатно? В чём подвох?</span><span class="fq-ch">+</span></summary>
      <div class="fq-a"><p>Каталог полностью бесплатный. Подвоха нет — мы собираем работы, которые уже были сданы. Заказ индивидуальных работ — платная услуга, она поддерживает проект.</p></div>
    </details>
    <details class="fq">
      <summary><span>Можно сдать работу из каталога?</span><span class="fq-ch">+</span></summary>
      <div class="fq-a"><p>Работы из каталога — образцы. Можно использовать как основу, но лучше переработать. Нужна уникальная — закажите индивидуально.</p></div>
    </details>
    <details class="fq">
      <summary><span>Какие гарантии?</span><span class="fq-ch">+</span></summary>
      <div class="fq-a"><p>Уникальность в Антиплагиат, выполнение в срок, бесплатные правки пока преподаватель не примет.</p></div>
    </details>
    <details class="fq">
      <summary><span>Сколько стоит?</span><span class="fq-ch">+</span></summary>
      <div class="fq-a"><p>Контрольная от 2 500 ₽, реферат от 3 000 ₽, курсовая от 5 000 ₽, дипломная от 30 000 ₽. Точная цена — после обсуждения.</p></div>
    </details>
    <details class="fq">
      <summary><span>Как быстро?</span><span class="fq-ch">+</span></summary>
      <div class="fq-a"><p>Стандарт — 2 недели. Срочно: неделя, 3 дня, 1 день. Обсуждается индивидуально.</p></div>
    </details>
  </section>

  <!-- ACT 7 — Closing -->
  <section class="act act-end">
    <div class="act-glow act-glow--gold" aria-hidden="true"></div>
    <p class="end-t">Каталог открыт.<br/>Заявки принимаем.</p>
    <div class="end-rule" aria-hidden="true"></div>
    <div class="end-btns">
      <a href="/catalog" class="end-btn">Каталог</a>
      <a href="/order" class="end-btn">Заказать работу</a>
      <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="end-btn">Написать нам</a>
    </div>
    <nav class="end-links">
      <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
      <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
      <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
    </nav>
    <p class="end-copy">© 2022–2026 Академический Салон</p>
  </section>

</Base>

<style>
  :global(.footer) { display: none; }

  /* ═══════ SHARED ═══════ */
  .act {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 32px;
    text-align: center;
    position: relative;
  }

  .act-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .act-glow--cold {
    top: 40%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(100,120,200,.04) 0%, transparent 65%);
    animation: gl 8s ease-in-out infinite;
  }

  .act-glow--gold {
    bottom: -200px;
    background: radial-gradient(circle, rgba(200,165,40,.08) 0%, transparent 65%);
  }

  @keyframes gl {
    0%, 100% { opacity: .5; transform: translate(-50%,-50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%,-50%) scale(1.12); }
  }

  /* Reveal */
  .rv {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity .6s cubic-bezier(.25,0,0,1), transform .6s cubic-bezier(.25,0,0,1);
    transition-delay: calc(var(--d, 0) * 120ms);
  }

  .rv.vis { opacity: 1; transform: translateY(0); }

  /* ═══════ ACT 1 — HOOK ═══════ */
  .act-hero {
    margin-top: calc(var(--nav-h) * -1);
    padding-top: var(--nav-h);
  }

  .a1-t {
    position: relative;
    font: 400 italic clamp(28px, 6vw, 42px)/1.3 var(--fd);
    color: rgba(255,255,255,.85);
    letter-spacing: .01em;
  }

  .w {
    display: inline-block;
    opacity: 0;
    transform: translateY(16px);
    animation: wi .6s cubic-bezier(.25,0,0,1) forwards;
    animation-delay: calc(var(--i) * 100ms + 300ms);
  }

  .w--em { color: var(--ac); opacity: 0; }

  @keyframes wi { to { opacity: 1; transform: translateY(0); } }

  .a1-arrow {
    position: absolute;
    bottom: 48px;
    font: 300 20px/1 var(--fi);
    color: rgba(255,255,255,.2);
    animation: bounce 2s ease-in-out infinite 2s;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  /* ═══════ ACT 2 — EMPATHY ═══════ */
  .a2-t {
    font: 300 clamp(28px, 5vw, 36px)/1.2 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    margin-bottom: 24px;
  }

  .a2-sub {
    font: 400 16px/1.7 var(--fi);
    color: rgba(255,255,255,.5);
    max-width: 520px;
  }

  /* ═══════ ACT 3 — GROWTH ═══════ */
  .a3-nums {
    display: flex;
    align-items: baseline;
    gap: 20px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .a3-n {
    font: 300 clamp(40px, 8vw, 64px)/1 var(--fm);
    color: rgba(255,255,255,.3);
    font-variant-numeric: tabular-nums;
  }

  .a3-n--final {
    color: var(--ac);
    font-size: clamp(48px, 10vw, 72px);
  }

  .a3-arrow {
    font: 300 24px/1 var(--fi);
    color: rgba(255,255,255,.1);
  }

  .a3-cap {
    margin-top: 24px;
    font: 400 14px/1.4 var(--fi);
    color: rgba(255,255,255,.35);
  }

  /* ═══════ ACT 4 — EVOLUTION ═══════ */
  .a4-pre {
    font: 300 italic clamp(20px, 3.5vw, 28px)/1.5 var(--fd);
    color: rgba(255,255,255,.6);
    max-width: 560px;
  }

  .a4-rule {
    width: 80px;
    height: 1px;
    margin: 32px auto;
    background: var(--ac);
    opacity: .2;
    transform: scaleX(0);
    transition: transform .8s cubic-bezier(.25,0,0,1) .2s, opacity .8s cubic-bezier(.25,0,0,1) .2s;
  }

  .a4-rule.vis { transform: scaleX(1); opacity: .2; }

  .a4-brand {
    font: 400 clamp(32px, 6vw, 48px)/1.1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  .a4-gold { color: var(--ac); }

  /* ═══════ ACT 5 — VALUES ═══════ */
  .act-vals {
    min-height: auto;
    padding: 120px 32px;
    gap: 80px;
  }

  .val {
    max-width: 400px;
    text-align: center;
  }

  .val-n {
    display: block;
    font: 300 clamp(36px, 7vw, 48px)/1 var(--fm);
    color: var(--ac);
    margin-bottom: 16px;
  }

  .val-d {
    font: 400 15px/1.7 var(--fi);
    color: rgba(255,255,255,.5);
  }

  /* ═══════ ACT 6 — FAQ ═══════ */
  .act-faq {
    min-height: auto;
    padding: 80px 32px 120px;
    max-width: 640px;
    margin: 0 auto;
    align-items: stretch;
    text-align: left;
  }

  .faq-t {
    font: 300 28px/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    margin-bottom: 32px;
    text-align: center;
  }

  .fq {
    border-bottom: 1px solid rgba(255,255,255,.04);
  }

  .fq summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 18px 0;
    font: 500 15px/1.4 var(--fi);
    color: var(--t1);
    cursor: pointer;
    list-style: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .fq summary::-webkit-details-marker { display: none; }
  .fq summary::marker { display: none; content: ''; }
  .fq summary:hover { color: rgba(201,165,90,.8); }

  .fq-ch {
    font: 300 24px/1 var(--fd);
    color: var(--ac);
    opacity: .3;
    flex-shrink: 0;
    transition: transform .4s cubic-bezier(.25,0,0,1), opacity .4s cubic-bezier(.25,0,0,1);
  }

  .fq summary:hover .fq-ch { opacity: .6; }
  .fq[open] .fq-ch { transform: rotate(45deg); }

  .fq-a { padding: 0 0 20px; }

  .fq-a p {
    font: 400 14px/1.7 var(--fi);
    color: rgba(255,255,255,.5);
  }

  /* ═══════ ACT 7 — CLOSING ═══════ */
  .act-end {
    min-height: 100svh;
  }

  .end-t {
    position: relative;
    font: 300 clamp(28px, 5vw, 36px)/1.3 var(--fd);
    color: var(--t1);
  }

  .end-rule {
    width: 60px;
    height: 1px;
    margin: 28px auto;
    background: var(--ac);
    opacity: .15;
  }

  .end-btns {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .end-btn {
    padding: 14px 40px;
    border: .5px solid rgba(255,255,255,.12);
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: rgba(255,255,255,.5);
    text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1), border-color .4s cubic-bezier(.25,0,0,1);
  }

  .end-btn:hover { color: rgba(255,255,255,.85); border-color: rgba(255,255,255,.25); }

  .end-links {
    margin-top: 40px;
    display: flex;
    justify-content: center;
    gap: 20px;
  }

  .end-links a {
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: rgba(255,255,255,.2);
    text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .end-links a:hover { color: rgba(255,255,255,.6); }

  .end-copy {
    margin-top: 20px;
    font: 400 10px/1 var(--fm);
    color: rgba(255,255,255,.12);
    letter-spacing: .1em;
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 640px) {
    .act { padding: 64px 20px; }
    .a3-nums { gap: 12px; }
    .a3-arrow { font-size: 18px; }
    .act-vals { gap: 56px; padding: 80px 20px; }
    .act-faq { padding: 64px 20px 80px; }
    .end-btns { flex-direction: column; align-items: center; }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .w { opacity: 1; transform: none; animation: none; }
    .rv { opacity: 1; transform: none; transition: none; }
    .a4-rule { transform: scaleX(1); opacity: .2; transition: none; }
    .a1-arrow { animation: none; }
    .act-glow--cold { animation: none; }
    .fq-ch { transition: none; }
    .end-btn, .end-links a, .fq summary { transition: none; }
  }
</style>

<script>
  function initAbout() {
    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* Scroll reveal */
    var groups = document.querySelectorAll('.rv-group');

    if (reduced) {
      document.querySelectorAll('.rv').forEach(function(el) { el.classList.add('vis'); });
    } else {
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (!e.isIntersecting) return;
          var items = e.target.classList.contains('rv')
            ? [e.target]
            : Array.from(e.target.querySelectorAll('.rv'));
          items.forEach(function(el) { el.classList.add('vis'); });
          obs.unobserve(e.target);
        });
      }, { threshold: .3, rootMargin: '0px 0px -40px 0px' });

      groups.forEach(function(g) { obs.observe(g); });
      /* Individual rv items not inside groups */
      document.querySelectorAll('.rv:not(.rv-group .rv)').forEach(function(el) { obs.observe(el); });
    }

    /* Count-up for growth numbers */
    var nums = document.querySelectorAll('[data-to]');
    var numObs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (!e.isIntersecting) return;
        numObs.unobserve(e.target);
        var target = parseInt(e.target.dataset.to || '0');
        var start = performance.now();
        var dur = 1500;
        function tick(now) {
          var t = Math.min((now - start) / dur, 1);
          var ease = 1 - Math.pow(1 - t, 3);
          var val = Math.round(ease * target);
          e.target.textContent = String(val);
          if (t < 1) requestAnimationFrame(tick);
          else e.target.textContent = target + (target >= 100 ? '+' : '');
        }
        requestAnimationFrame(tick);
      });
    }, { threshold: .3 });
    nums.forEach(function(el) { numObs.observe(el); });
  }

  initAbout();
  document.addEventListener('astro:after-swap', initAbout);
</script>
