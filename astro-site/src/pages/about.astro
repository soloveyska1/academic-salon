---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';
const total = D.length;
const fallbackFiles = D.map((d: any) => d.file).filter(Boolean);
---

<Base title="О салоне — Академический Салон" description="Академический Салон с 2020 года: свободный архив из 235+ студенческих работ по психологии, социальной работе и конфликтологии плюс авторский сервис под защиту." currentPath="/about">

  <article class="pg">

    <!-- 1. Opening — editorial Prelude -->
    <header class="opening prelude-about">
      <div class="glow" aria-hidden="true"></div>
      <span class="prelude-eyebrow rv" data-d="0">
        <span class="prelude-eyebrow-rule" aria-hidden="true"></span>
        <span class="prelude-eyebrow-num">I</span>
        Caput · О&nbsp;салоне
      </span>
      <h1 class="opening-t prelude-about-t rv" data-d="100">Академический <em class="it">Салон</em>.</h1>
      <div class="hr rv" data-d="200" aria-hidden="true"></div>
      <p class="opening-sub prelude-about-sub rv" data-d="300">
        Свободный архив&nbsp;— <strong>{total}+ работ</strong> по&nbsp;психологии, социальной работе и&nbsp;смежным гуманитарным дисциплинам. Авторский заказ&nbsp;— текст под&nbsp;вашу тему и&nbsp;руководителя, с&nbsp;сопровождением до&nbsp;защиты. Тихая мастерская с&nbsp;2020&nbsp;года.
      </p>
      <div class="scroll-hint rv" data-d="800" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M7 10l5 5 5-5"/>
        </svg>
      </div>
    </header>

    <!-- 2. Timeline -->
    <section class="tl">
      <header class="chapter-head chapter-head--about rv" data-d="0">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">II</span>
          <span class="chapter-label">Caput Primum · Путь</span>
        </div>
        <h2 class="sec-t chapter-h-about">Как мы сюда <em class="it">пришли</em>.</h2>
      </header>
      <div class="tl-track">
        <div class="tl-line" aria-hidden="true"></div>

        <div class="tl-item tl-item--l rv" data-d="0">
          <span class="tl-year">2020</span>
          <div class="tl-dot" aria-hidden="true"></div>
          <div class="tl-body">
            <span class="tl-title">Начало</span>
            <p class="tl-desc">Телеграм-канал &laquo;Кладовая&raquo; &mdash; студенты одного вуза делятся первыми работами.</p>
          </div>
        </div>

        <div class="tl-item tl-item--r rv" data-d="150">
          <span class="tl-year">2022</span>
          <div class="tl-dot" aria-hidden="true"></div>
          <div class="tl-body">
            <span class="tl-title">Рост</span>
            <p class="tl-desc">100+ работ, расширение дисциплин: психология, социальная работа, конфликтология.</p>
          </div>
        </div>

        <div class="tl-item tl-item--l rv" data-d="300">
          <span class="tl-year">2024</span>
          <div class="tl-dot" aria-hidden="true"></div>
          <div class="tl-body">
            <span class="tl-title">Масштабирование</span>
            <p class="tl-desc">200+ работ в канале, появление индивидуальных заказов и первые постоянные клиенты.</p>
          </div>
        </div>

        <div class="tl-item tl-item--r tl-item--now rv" data-d="450">
          <span class="tl-year">2026</span>
          <div class="tl-dot" aria-hidden="true"></div>
          <div class="tl-body">
            <span class="tl-title">Запуск сайта</span>
            <p class="tl-desc">bibliosaloon.ru &mdash; {total}+ работ, полноценная библиотека, калькулятор заказов, индивидуальный сервис. Начало новой главы.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. Stats — glassmorphism cards -->
    <section class="stats">
      <div class="stats-grid">
        <div class="stat-card rv" data-d="0">
          <span class="stat-icon" aria-hidden="true">&infin;</span>
          <b class="stat-title">Работаем до результата</b>
          <p class="stat-sub">Бесплатные правки до защиты</p>
        </div>
        <div class="stat-card rv" data-d="100">
          <span class="stat-icon" aria-hidden="true">&#9670;</span>
          <b class="stat-title">Антиплагиат</b>
          <p class="stat-sub">Гарантия заявленной уникальности</p>
        </div>
        <div class="stat-card rv" data-d="200">
          <span class="stat-icon" aria-hidden="true">&#9201;</span>
          <b class="stat-title">Сроки от 1 дня</b>
          <p class="stat-sub">Стандарт — 2 недели</p>
        </div>
        <div class="stat-card rv" data-d="300">
          <span class="stat-icon" aria-hidden="true">0&#8381;</span>
          <b class="stat-title"><span data-to={total}>0</span>+ работ бесплатно</b>
          <p class="stat-sub">Без регистрации</p>
        </div>
      </div>
    </section>

    <!-- 4. How it works — editorial Method -->
    <section class="flow">
      <header class="chapter-head chapter-head--about rv" data-d="0">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">III</span>
          <span class="chapter-label">Caput Secundum · Метод</span>
        </div>
        <h2 class="sec-t chapter-h-about">Как <em class="it">работаем</em>.</h2>
      </header>
      <div class="flow-grid">
        <div class="flow-step rv" data-d="0">
          <span class="flow-num" aria-hidden="true">01</span>
          <svg class="flow-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <b class="flow-title">Найдите или опишите</b>
          <p class="flow-desc">Ищите в каталоге бесплатно или опишите задачу для индивидуального заказа</p>
        </div>
        <div class="flow-arrow rv" data-d="100" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </div>
        <div class="flow-step rv" data-d="200">
          <span class="flow-num" aria-hidden="true">02</span>
          <svg class="flow-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          <b class="flow-title">Мы работаем</b>
          <p class="flow-desc">Пишем, проверяем на плагиат, согласовываем структуру</p>
        </div>
        <div class="flow-arrow rv" data-d="300" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </div>
        <div class="flow-step rv" data-d="400">
          <span class="flow-num" aria-hidden="true">03</span>
          <svg class="flow-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <b class="flow-title">Сдаёте и получаете оценку</b>
          <p class="flow-desc">Готовый файл + бесплатные правки, пока преподаватель не примет</p>
        </div>
      </div>
    </section>

    <!-- 5. Pricing — two formats -->
    <section class="pricing">
      <header class="chapter-head chapter-head--about rv" data-d="0">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">IV</span>
          <span class="chapter-label">Caput Tertium · Формат</span>
        </div>
        <h2 class="sec-t chapter-h-about">Два <em class="it">формата</em>.</h2>
      </header>
      <div class="pricing-grid">
        <div class="price-card rv" data-d="100">
          <span class="price-label">Каталог</span>
          <span class="price-value">Бесплатно</span>
          <ul class="price-list">
            <li>Без регистрации</li>
            <li>{total}+ работ</li>
            <li>Все форматы</li>
            <li>Мгновенное скачивание</li>
          </ul>
          <a href="/catalog" class="price-cta">Открыть каталог</a>
        </div>
        <div class="price-card price-card--gold rv" data-d="200">
          <span class="price-badge">Популярное</span>
          <span class="price-label">Индивидуально</span>
          <span class="price-value">от 2 500 &#8381;</span>
          <ul class="price-list">
            <li>Под ваши требования</li>
            <li>Антиплагиат</li>
            <li>Правки до защиты</li>
            <li>Сроки от 1 дня</li>
          </ul>
          <a href="/order" class="price-cta price-cta--gold">Заказать</a>
        </div>
      </div>
    </section>

    <!-- 5. Pullquote -->
    <blockquote class="pq rv" data-d="0">
      <span class="pq-line" aria-hidden="true"></span>
      <em>Мы не корпорация. Мы — те, кто сам через это прошёл.</em>
      <span class="pq-line" aria-hidden="true"></span>
    </blockquote>

    <!-- Random document -->
    <div class="random rv" data-d="0">
      <button class="random-btn" id="randomBtn">Открыть случайную работу</button>
      <p class="random-hint">{total} документов в каталоге — попробуйте наудачу</p>
    </div>

    <!-- 6. FAQ — editorial Q&A -->
    <section class="faq" id="faq">
      <header class="chapter-head chapter-head--about rv" data-d="0">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">V</span>
          <span class="chapter-label">Caput Quartum · Вопросы</span>
        </div>
        <h2 class="sec-t chapter-h-about">Вопросы, <em class="it">которые задают</em>.</h2>
      </header>

      <details class="fq qa-item" open>
        <summary><span class="qa-no">01</span><span class="qa-q">Архив правда бесплатный?</span><span class="fq-x" aria-hidden="true">+</span></summary>
        <div class="fq-body">
          <p>Да. {total}+ работ в&nbsp;каталоге скачиваются <em class="it">без&nbsp;регистрации и&nbsp;оплаты</em>. Это работы, которые студенты сами передали нам после сдачи&nbsp;— берите как образец, забирайте формулировки, отдельные куски. Проект живёт за&nbsp;счёт индивидуальных заказов, а&nbsp;не&nbsp;за&nbsp;счёт доступа к&nbsp;архиву.</p>
        </div>
      </details>

      <details class="fq qa-item">
        <summary><span class="qa-no">02</span><span class="qa-q">Как заказать работу, что происходит после отправки формы?</span><span class="fq-x" aria-hidden="true">+</span></summary>
        <div class="fq-body">
          <p>На&nbsp;<a href="/order">странице заказа</a> выбираете жанр, темп, уникальность и&nbsp;дополнения&nbsp;— видите точную сумму. Описываете тему, прикладываете методичку, оставляете контакт. В&nbsp;течение 15&nbsp;минут в&nbsp;рабочее время отвечает живой человек: уточняет детали, подбирает автора, присылает план. <em class="it">Деньги не&nbsp;берём, пока не&nbsp;согласуем план.</em></p>
        </div>
      </details>

      <details class="fq qa-item">
        <summary><span class="qa-no">03</span><span class="qa-q">В какие сроки реально выполняете?</span><span class="fq-x" aria-hidden="true">+</span></summary>
        <div class="fq-body">
          <p>Спокойно&nbsp;— от&nbsp;2&nbsp;недель до&nbsp;2&nbsp;месяцев в&nbsp;зависимости от&nbsp;типа работы. Срочно&nbsp;— 1–3&nbsp;дня с&nbsp;наценкой. В&nbsp;режиме «сегодня»&nbsp;— беремся только за&nbsp;короткие формы (реферат, контрольная). Диплом и&nbsp;магистерская&nbsp;— минимум 3&nbsp;недели. Если видим, что не&nbsp;успеем как следует&nbsp;— <em class="it">сразу говорим «нет»</em>, а&nbsp;не&nbsp;беремся и&nbsp;срываем.</p>
        </div>
      </details>

      <details class="fq qa-item">
        <summary><span class="qa-no">04</span><span class="qa-q">Что с антиплагиатом и «отчётом», который можно добавить в доп?</span><span class="fq-x" aria-hidden="true">+</span></summary>
        <div class="fq-body">
          <p>Базово гарантируем <em class="it">70%, 80% или&nbsp;90%</em> оригинальности по&nbsp;Антиплагиат.ВУЗ&nbsp;— что выбрали в&nbsp;калькуляторе. Если показатель ниже обещанного по&nbsp;нашей вине&nbsp;— бесплатно переписываем. Дополнение «Антиплагиат-отчёт» (+1&nbsp;500&nbsp;₽)&nbsp;— это PDF-отчёт из&nbsp;системы, который можно приложить к&nbsp;работе; сам уровень уникальности от&nbsp;этой опции не&nbsp;зависит.</p>
        </div>
      </details>

      <details class="fq qa-item">
        <summary><span class="qa-no">05</span><span class="qa-q">Оплата: когда, как, можно ли по частям?</span><span class="fq-x" aria-hidden="true">+</span></summary>
        <div class="fq-body">
          <p>Стандартно <em class="it">50%</em> после согласования плана и&nbsp;договора, <em class="it">50%</em> после защиты (или сдачи, если защита не&nbsp;предусмотрена). Короткие работы (реферат, контрольная)&nbsp;— иногда удобнее целиком после готовности. Предоплату перед планом <em class="it">не&nbsp;берём никогда</em>. Способы: карта, СБП, перевод по&nbsp;реквизитам.</p>
        </div>
      </details>

      <details class="fq qa-item">
        <summary><span class="qa-no">06</span><span class="qa-q">Гарантии до защиты: правки, доработки — как на самом деле?</span><span class="fq-x" aria-hidden="true">+</span></summary>
        <div class="fq-body">
          <p>Правки после замечаний руководителя&nbsp;— <em class="it">бесплатно</em> в&nbsp;течение всего срока сопровождения (до&nbsp;оценки в&nbsp;ведомости). Для дипломной и&nbsp;магистерской дополнительно помогаем с&nbsp;презентацией, речью и&nbsp;репетицией&nbsp;— входит в&nbsp;стоимость, если заказали пакет «под&nbsp;защиту». Доработки по&nbsp;смене темы или разворот требований&nbsp;— обсуждаем отдельно.</p>
        </div>
      </details>

      <details class="fq qa-item">
        <summary><span class="qa-no">07</span><span class="qa-q">Что с конфиденциальностью — не опубликуете мой заказ?</span><span class="fq-x" aria-hidden="true">+</span></summary>
        <div class="fq-body">
          <p>Заказанная работа <em class="it">не&nbsp;попадает в&nbsp;открытый каталог</em> и&nbsp;не&nbsp;публикуется нигде. Автор знает вас только под&nbsp;инициалами. По&nbsp;запросу подписываем NDA. Хранятся только контакт, тема и&nbsp;вложенные файлы&nbsp;— используем их&nbsp;только для выполнения заказа, удаляем по&nbsp;вашему запросу в&nbsp;любой момент.</p>
        </div>
      </details>

      <details class="fq qa-item">
        <summary><span class="qa-no">08</span><span class="qa-q">А если работа не подойдёт, руководитель завернёт?</span><span class="fq-x" aria-hidden="true">+</span></summary>
        <div class="fq-body">
          <p>Если замечания по&nbsp;существу&nbsp;— правим <em class="it">бесплатно</em> в&nbsp;течение всего срока сопровождения, хоть пять итераций. Если защиту проваливают по&nbsp;нашей вине&nbsp;— по&nbsp;договору <em class="it">возвращаем 100% оплаты</em>. Если руководитель меняет требования и&nbsp;это влечёт переработку большого объёма&nbsp;— обсуждаем доплату по-честному, без&nbsp;скрытых наценок.</p>
        </div>
      </details>
    </section>

    <!-- 7. Privacy — editorial -->
    <section class="faq" id="privacy">
      <header class="chapter-head chapter-head--about rv" data-d="0">
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">VI</span>
          <span class="chapter-label">Caput Quintum · Тишина</span>
        </div>
        <h2 class="sec-t chapter-h-about">Конфиденциальность и&nbsp;<em class="it">данные</em>.</h2>
      </header>
      <details class="fq"><summary>Каталог<span class="fq-x" aria-hidden="true">+</span></summary><div class="fq-body"><p>Скачивание работ не требует регистрации. Мы фиксируем только обезличенную статистику просмотров и скачиваний.</p></div></details>
      <details class="fq"><summary>Заказ работы<span class="fq-x" aria-hidden="true">+</span></summary><div class="fq-body"><p>Мы сохраняем контакт (VK, Telegram или телефон), тему и прикреплённые файлы. Данные используются только для выполнения заказа и удаляются по запросу.</p></div></details>
      <details class="fq"><summary>Загрузка в библиотеку<span class="fq-x" aria-hidden="true">+</span></summary><div class="fq-body"><p>Контакт отправителя виден только модератору. Публикуется только документ — без привязки к автору.</p></div></details>
      <details class="fq"><summary>Аналитика<span class="fq-x" aria-hidden="true">+</span></summary><div class="fq-body"><p>Мы используем Яндекс.Метрику для анализа посещаемости. Данные обезличены.</p></div></details>
      <details class="fq"><summary>Cookies и localStorage<span class="fq-x" aria-hidden="true">+</span></summary><div class="fq-body"><p>Сайт использует localStorage для сохранения темы и избранных документов. Никакие cookie не передаются третьим сторонам.</p></div></details>
      <p class="privacy-contact rv" data-d="0">Вопросы: <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a></p>
    </section>

    <!-- 8. Epilogue — editorial close (contacts duplicate global footer intentionally on /about) -->
    <section class="end epilogue-about">
      <div class="glow glow--bot" aria-hidden="true"></div>
      <div class="end-mono" aria-hidden="true">АС</div>
      <div class="hr rv" data-d="0" aria-hidden="true"></div>
      <p class="end-t rv" data-d="200">Готовы <em class="it">начать</em>?</p>
      <div class="end-btns rv" data-d="400">
        <a href="/catalog" class="end-btn">Открыть архив</a>
        <a href="/order" class="end-btn end-btn--gold">Заказать работу</a>
      </div>
      <p class="end-links rv" data-d="600">
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
        <span aria-hidden="true"> · </span>
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
        <span aria-hidden="true"> · </span>
        <a href="https://max.ru/join/lvaRhM9GTze3JfqgW9GsTisLfz-o_IOdVK-ev-_AsH0" target="_blank" rel="noopener">MAX</a>
        <span aria-hidden="true"> · </span>
        <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
      </p>
      <p class="end-copy rv" data-d="700">&copy; MMXX&mdash;MMXXVI · Академический&nbsp;Салон</p>
    </section>

  </article>

  <script is:inline define:vars={{ fallbackFiles }}>
    window.__randomFiles = fallbackFiles;
  </script>

</Base>

<style>
  /* Global editorial footer (Phase 2) is intentionally visible on /about */

  .pg {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ═══════ REVEAL ═══════ */
  .rv {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity .5s var(--ease), transform .5s var(--ease);
  }
  .rv.vis { opacity: 1; transform: translateY(0); }

  /* ═══════ HAIRLINE ═══════ */
  .hr {
    width: 60px;
    height: 1px;
    margin: 24px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
  }
  .hr.vis {
    opacity: .15;
    transform: scaleX(1);
    transition: opacity .8s var(--ease), transform .8s var(--ease);
  }

  /* ═══════ GLOW ═══════ */
  .glow {
    position: absolute;
    width: 600px; height: 500px;
    left: 50%;
    pointer-events: none;
    animation: gl 10s ease-in-out infinite;
  }
  .opening > .glow {
    top: 25%;
    transform: translate(-50%,-50%);
    background: radial-gradient(circle, rgba(200,165,40,.09) 0%, transparent 60%);
  }
  .glow--bot {
    bottom: -100px;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(200,165,40,.07) 0%, transparent 60%);
  }
  @keyframes gl {
    0%, 100% { opacity: .5; }
    50% { opacity: .9; }
  }

  /* ═══════ OPENING ═══════ */
