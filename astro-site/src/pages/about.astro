---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';
const total = D.length;
const fallbackFiles = D.map((d: any) => d.file).filter(Boolean);
const categoriesCount = new Set(D.map((d: any) => d.category).filter(Boolean)).size;
const subjectsCount   = new Set(D.map((d: any) => d.subject).filter(Boolean)).size;
---

<Base title="О салоне — Академический Салон" description="Академический Салон с 2020 года: свободный архив из 235+ студенческих работ по психологии, социальной работе и конфликтологии плюс авторский сервис под защиту." currentPath="/about">

  <article class="pg about-article">

    <!-- ============================================================
         Interactive CODEX — single stage, sticky sidebar + swapping
         canvas. Click a tab to reveal a chapter. No long scroll.
         ============================================================ -->
    <section class="about-stage" aria-label="О салоне">

      <aside class="codex-head" aria-label="Оглавление">
        <div class="codex-head-inner">
          <span class="codex-eyebrow" aria-hidden="true">
            <span class="rule"></span>
            <span class="word">De nobis</span>
          </span>

          <h1 class="codex-h">Архив, который собрали <em class="it">сами студенты</em>.</h1>

          <p class="codex-lede">
            Шесть&nbsp;лет назад мы&nbsp;начали складывать защищённые курсовые в&nbsp;Telegram-канал, чтобы следующие не&nbsp;мучились. Сегодня&nbsp;— {total}&nbsp;работ в&nbsp;свободном архиве, команда авторов под&nbsp;заказ, разговор тридцать минут до&nbsp;плана.
          </p>

          <dl class="codex-facts">
            <div><dt>Основан</dt><dd>в&nbsp;<i class="it">2020</i></dd></div>
            <div><dt>В&nbsp;архиве</dt><dd>{total} <i class="it">работ</i></dd></div>
            <div><dt>Дисциплин</dt><dd>{subjectsCount}+</dd></div>
            <div><dt>Доступ</dt><dd><i class="it">бесплатный</i></dd></div>
          </dl>

          <nav class="codex-nav" role="tablist" aria-label="Главы">
            <button type="button" class="codex-tab is-active" role="tab" aria-selected="true"  data-tab="history"  aria-controls="chap-history">
              <span class="tab-no">I</span>
              <span class="tab-lat">Historia</span>
              <span class="tab-name">История</span>
              <svg class="tab-arrow" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.3"/></svg>
            </button>
            <button type="button" class="codex-tab" role="tab" aria-selected="false" tabindex="-1" data-tab="promises" aria-controls="chap-promises">
              <span class="tab-no">II</span>
              <span class="tab-lat">Fides</span>
              <span class="tab-name">Обещания</span>
              <svg class="tab-arrow" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.3"/></svg>
            </button>
            <button type="button" class="codex-tab" role="tab" aria-selected="false" tabindex="-1" data-tab="authors" aria-controls="chap-authors">
              <span class="tab-no">III</span>
              <span class="tab-lat">Scriptores</span>
              <span class="tab-name">Кто пишет</span>
              <svg class="tab-arrow" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.3"/></svg>
            </button>
            <button type="button" class="codex-tab" role="tab" aria-selected="false" tabindex="-1" data-tab="archive" aria-controls="chap-archive">
              <span class="tab-no">IV</span>
              <span class="tab-lat">Donum</span>
              <span class="tab-name">Архив-подарок</span>
              <svg class="tab-arrow" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.3"/></svg>
            </button>
            <button type="button" class="codex-tab" role="tab" aria-selected="false" tabindex="-1" data-tab="privacy" aria-controls="chap-privacy">
              <span class="tab-no">V</span>
              <span class="tab-lat">Silentium</span>
              <span class="tab-name">Тишина</span>
              <svg class="tab-arrow" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.3"/></svg>
            </button>
          </nav>
        </div>
      </aside>

      <div class="codex-canvas" role="region" aria-live="polite">

        <article class="codex-chapter is-active" id="chap-history" data-tab="history" role="tabpanel">
          <header class="chap-head">
            <span class="chap-eyebrow" aria-hidden="true">
              <span class="rule"></span>
              <span class="word">Caput I · Historia</span>
            </span>
            <h2 class="chap-h">Как <em class="it">это</em> было.</h2>
            <p class="chap-lede">Четыре года, четыре главы. Без прикрас и без «мы всегда были лидерами».</p>
          </header>

          <ol class="history-list" role="list">
            <li class="history-entry">
              <span class="year">2020</span>
              <div class="entry-body">
                <h3>Кладовая.</h3>
                <p>Полтора&nbsp;года&nbsp;— обычный Telegram-канал. Один студент выкладывает свою защищённую курсовую, другой забирает как образец. Десяток работ, сорок подписчиков, никто не&nbsp;думает, что из&nbsp;этого получится что-то больше.</p>
              </div>
            </li>
            <li class="history-entry">
              <span class="year">2022</span>
              <div class="entry-body">
                <h3>Поток.</h3>
                <p>Работ становится сто, подписчиков&nbsp;— сотни. Понимаем: умеем писать не&nbsp;хуже, чем преподаватели требуют. Первые пять заказов&nbsp;— от&nbsp;знакомых, за&nbsp;скромные деньги, с&nbsp;репетицией защиты на&nbsp;кухне.</p>
              </div>
            </li>
            <li class="history-entry">
              <span class="year">2024</span>
              <div class="entry-body">
                <h3>Мастерская.</h3>
                <p>Двести работ в&nbsp;архиве. Команда авторов&nbsp;— каждый ведёт максимум три–четыре работы одновременно. Постоянные клиенты по&nbsp;рекомендациям. Учимся говорить <em class="it">«нет»</em>&nbsp;— главный навык.</p>
              </div>
            </li>
            <li class="history-entry history-entry--now">
              <span class="year">2026</span>
              <div class="entry-body">
                <h3>Салон.</h3>
                <p>Сайт. {total}&nbsp;работ в&nbsp;свободном архиве, калькулятор стоимости, живой чек, кабинет для&nbsp;клиента. Новая глава&nbsp;— название меняется, суть остаётся.</p>
              </div>
            </li>
          </ol>
        </article>

        <article class="codex-chapter" id="chap-promises" data-tab="promises" role="tabpanel" hidden>
          <header class="chap-head">
            <span class="chap-eyebrow" aria-hidden="true">
              <span class="rule"></span>
              <span class="word">Caput II · Fides</span>
            </span>
            <h2 class="chap-h">Что <em class="it">обещаем</em>.</h2>
            <p class="chap-lede">Четыре вещи, которых держимся. Не маркетинг — причины, по которым клиенты возвращаются.</p>
          </header>
          <ol class="promises-list" role="list">
            <li>
              <span class="p-num">Principium I</span>
              <h3>Мы&nbsp;сами были на&nbsp;вашем месте</h3>
              <p>Начинали потому что сами писали курсовые в&nbsp;три ночи перед сдачей. Знаем, каково, когда работа третий раз на&nbsp;правках, а&nbsp;защита послезавтра.</p>
            </li>
            <li>
              <span class="p-num">Principium II</span>
              <h3>Говорим «нет» открыто</h3>
              <p>Если тема не&nbsp;наша, не&nbsp;успеем, не&nbsp;понимаем задачу&nbsp;— сразу «нет». Лучше честный отказ сейчас, чем сорванный срок через месяц.</p>
            </li>
            <li>
              <span class="p-num">Principium III</span>
              <h3>50/50 после плана</h3>
              <p>Никакой предоплаты за&nbsp;«обещание». Сначала план, договор, разговор с&nbsp;автором&nbsp;— потом первые 50%. Остаток&nbsp;— после защиты.</p>
            </li>
            <li>
              <span class="p-num">Principium IV</span>
              <h3>После защиты&nbsp;— ваше</h3>
              <p>Заказанная работа не&nbsp;публикуется. NDA по&nbsp;запросу. Автор знает вас только под&nbsp;инициалами. После сдачи мы&nbsp;исчезаем из&nbsp;вашей жизни.</p>
            </li>
          </ol>
        </article>

        <article class="codex-chapter" id="chap-authors" data-tab="authors" role="tabpanel" hidden>
          <header class="chap-head">
            <span class="chap-eyebrow" aria-hidden="true">
              <span class="rule"></span>
              <span class="word">Caput III · Scriptores</span>
            </span>
            <h2 class="chap-h">Кто <em class="it">пишет</em>.</h2>
            <p class="chap-lede">Без имён, фото и биографий на восемь страниц. Главное — принципы.</p>
          </header>
          <div class="authors-body">
            <p>Нас немного. Каждый автор&nbsp;— с&nbsp;профильным образованием: психология, социальная работа, педагогика, право, экономика. Работают удалённо, ведут <em class="it">не&nbsp;больше трёх–четырёх</em> работ одновременно&nbsp;— иначе не&nbsp;успеть сделать как следует.</p>
            <p>Пишем руками. ИИ используем как инструмент на&nbsp;этапах поиска источников, фактчека и&nbsp;редактуры&nbsp;— но&nbsp;финальный текст всегда проходит через несколько этапов ручной проверки. Научрук не&nbsp;отличит&nbsp;— проверено десятками защит.</p>
            <p>Все из&nbsp;постсоветских вузов&nbsp;— знают, как здесь пишутся курсовые. Не&nbsp;«академически общо», а&nbsp;под методичку <em class="it">вашей</em> кафедры, под конкретного руководителя. Под каждого научрука собираем профиль: что любит, на&nbsp;чём срезает.</p>
          </div>
          <ul class="authors-tiles" role="list">
            <li><span class="mark">§&nbsp;I</span><h4>Ручное письмо</h4><p>ИИ&nbsp;— помощник, не&nbsp;автор. Финал всегда через руки.</p></li>
            <li><span class="mark">§&nbsp;II</span><h4>Профиль научрука</h4><p>Пишем под&nbsp;конкретного руководителя.</p></li>
            <li><span class="mark">§&nbsp;III</span><h4>Одна работа — один автор</h4><p>Никаких конвейеров. Макс 3–4 работы в&nbsp;неделю.</p></li>
          </ul>
        </article>

        <article class="codex-chapter" id="chap-archive" data-tab="archive" role="tabpanel" hidden>
          <header class="chap-head">
            <span class="chap-eyebrow" aria-hidden="true">
              <span class="rule"></span>
              <span class="word">Caput IV · Donum</span>
            </span>
            <h2 class="chap-h">Архив — <em class="it">подарок</em>.</h2>
            <p class="chap-lede">Не воронка, не тизер. Просто архив, из которого можно брать.</p>
          </header>
          <div class="archive-split">
            <div class="archive-prose">
              <p>Архив собран студентами, которые сами присылали свои защищённые работы. <b>{total}&nbsp;документов</b> бесплатно, без&nbsp;регистрации, без&nbsp;рекламы. Это не&nbsp;воронка продаж&nbsp;— это начало, которое мы&nbsp;никогда не&nbsp;закрыли.</p>
              <p>Скачивайте целиком, забирайте куски, ищите формулировки. Ваша тема, скорее всего, там уже есть. Если нет&nbsp;— <a href="/contribute" class="archive-link">поделитесь своей</a> после защиты.</p>
            </div>
            <div class="archive-card">
              <div class="card-row"><span class="lbl">Документов</span><span class="val">{total}</span></div>
              <div class="card-row"><span class="lbl">Категорий</span><span class="val">{categoriesCount}</span></div>
              <div class="card-row"><span class="lbl">Дисциплин</span><span class="val">{subjectsCount}+</span></div>
              <div class="card-foot">
                <a href="/catalog" class="btn btn-gold btn-sm">Открыть каталог</a>
                <button type="button" class="btn btn-ghost-gold btn-sm" id="randomBtn">Случайная работа</button>
              </div>
            </div>
          </div>
        </article>

        <article class="codex-chapter" id="chap-privacy" data-tab="privacy" role="tabpanel" hidden>
          <header class="chap-head">
            <span class="chap-eyebrow" aria-hidden="true">
              <span class="rule"></span>
              <span class="word">Caput V · Silentium</span>
            </span>
            <h2 class="chap-h">Конфиденциальность и <em class="it">данные</em>.</h2>
            <p class="chap-lede">Всё, что вы нам доверяете, остаётся между нами. По запросу — удаляем.</p>
          </header>
          <div class="privacy-list">
            <details class="priv-item" open>
              <summary><span class="p-no">01</span><span class="p-q">Каталог</span><span class="p-chev" aria-hidden="true">+</span></summary>
              <div class="p-body"><p>Скачивание работ не требует регистрации. Фиксируем только обезличенную статистику просмотров — чтобы понимать, какие дисциплины востребованы.</p></div>
            </details>
            <details class="priv-item">
              <summary><span class="p-no">02</span><span class="p-q">Заказ работы</span><span class="p-chev" aria-hidden="true">+</span></summary>
              <div class="p-body"><p>Сохраняем контакт, тему и прикреплённые файлы. Не передаём третьим лицам и удаляем по вашему запросу.</p></div>
            </details>
            <details class="priv-item">
              <summary><span class="p-no">03</span><span class="p-q">Загрузка в библиотеку</span><span class="p-chev" aria-hidden="true">+</span></summary>
              <div class="p-body"><p>Контакт отправителя виден только модератору. Документ обезличивается перед публикацией: убираем ФИО, ВУЗ, научрука, группу.</p></div>
            </details>
            <details class="priv-item">
              <summary><span class="p-no">04</span><span class="p-q">Аналитика</span><span class="p-chev" aria-hidden="true">+</span></summary>
              <div class="p-body"><p>Яндекс.Метрика, данные обезличены, не связываются с вашим контактом и не передаются рекламным сетям.</p></div>
            </details>
            <details class="priv-item">
              <summary><span class="p-no">05</span><span class="p-q">Cookies и localStorage</span><span class="p-chev" aria-hidden="true">+</span></summary>
              <div class="p-body"><p><code>localStorage</code> — только для темы и избранных документов. Рекламных трекеров нет.</p></div>
            </details>
          </div>
          <p class="privacy-contact">Вопросы — <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a></p>
        </article>

      </div>

      <nav class="codex-pager" aria-label="Между главами">
        <button type="button" class="pager-btn pager-prev" id="codexPrev" aria-label="Предыдущая глава">
          <svg viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M12 7H2m3-3L2 7l3 3" stroke="currentColor" stroke-width="1.3"/></svg>
          <span class="pager-lbl">Назад</span>
        </button>
        <span class="pager-counter" id="codexCounter" aria-live="polite">I · V</span>
        <button type="button" class="pager-btn pager-next" id="codexNext" aria-label="Следующая глава">
          <span class="pager-lbl">Дальше</span>
          <svg viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.3"/></svg>
        </button>
      </nav>

    </section>

    <section class="about-pullquote" aria-label="Кредо">
      <div class="about-pullquote-wrap">
        <span class="pq-rule" aria-hidden="true"></span>
        <blockquote class="about-pq">
          <p class="about-pq-line">Мы&nbsp;не&nbsp;корпорация.</p>
          <p class="about-pq-line about-pq-line--gold">Мы&nbsp;— те, кто сам через это прошёл.</p>
        </blockquote>
        <span class="pq-rule" aria-hidden="true"></span>
      </div>
    </section>

    <section class="about-epilogue" aria-label="Начать">
      <div class="about-epilogue-wrap">
        <p class="about-epi-glyph" aria-hidden="true">⁘</p>
        <h2 class="about-epi-h">Готовы <em class="it">начать</em>?</h2>
        <p class="about-epi-sub">Архив — без условий. Заказ — после разговора.</p>
        <div class="about-epi-actions">
          <a href="/catalog" class="btn btn-ghost-gold btn-lg">Открыть архив</a>
          <a href="/order" class="btn btn-gold btn-lg">Заказать работу</a>
        </div>
      </div>
    </section>

  </article>


  <script is:inline define:vars={{ fallbackFiles }}>
    window.__randomFiles = fallbackFiles;
  </script>

</Base>

<style>
  /* Global editorial footer (Phase 2) is intentionally visible on /about */

  .pg {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ═══════ REVEAL ═══════ */
  .rv {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity .5s var(--ease), transform .5s var(--ease);
  }
  .rv.vis { opacity: 1; transform: translateY(0); }

  /* ═══════ HAIRLINE ═══════ */
  .hr {
    width: 60px;
    height: 1px;
    margin: 24px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
  }
  .hr.vis {
    opacity: .15;
    transform: scaleX(1);
    transition: opacity .8s var(--ease), transform .8s var(--ease);
  }

  /* ═══════ GLOW ═══════ */
  .glow {
    position: absolute;
    width: 600px; height: 500px;
    left: 50%;
    pointer-events: none;
    animation: gl 10s ease-in-out infinite;
  }
  .opening > .glow {
    top: 25%;
    transform: translate(-50%,-50%);
    background: radial-gradient(circle, rgba(200,165,40,.09) 0%, transparent 60%);
  }
  .glow--bot {
    bottom: -100px;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(200,165,40,.07) 0%, transparent 60%);
  }
  @keyframes gl {
    0%, 100% { opacity: .5; }
    50% { opacity: .9; }
  }

  /* ═══════ OPENING ═══════ */
  .opening {
    position: relative;
    text-align: center;
    padding: 100px 0 80px;
    overflow: hidden;
  }
  .opening-t {
    position: relative;
    font: 300 clamp(36px, 7vw, 64px)/.92 var(--fd);
    color: var(--t1);
    letter-spacing: -.02em;
    text-wrap: balance;
  }
  .opening-sub {
    position: relative;
    margin-top: 24px;
    font: 400 14px/1.6 var(--fi);
    color: var(--t2);
  }

  /* Scroll indicator */
  .scroll-hint {
    margin-top: 48px;
    color: var(--t3);
    animation: scroll-bob 2s var(--ease) infinite;
  }
  @keyframes scroll-bob {
    0%, 100% { transform: translateY(0); opacity: .4; }
    50% { transform: translateY(6px); opacity: .8; }
  }

  /* ═══════ TIMELINE ═══════ */
  .tl {
    padding: 64px 0 48px;
  }
  .tl-track {
    position: relative;
    margin-top: 48px;
  }
  .tl-line {
    position: absolute;
    left: 50%;
    top: 0; bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, transparent, var(--ac-b2) 10%, var(--ac-b2) 90%, transparent);
    transform: translateX(-50%);
  }
  .tl-item {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 24px;
    padding-bottom: 48px;
    width: 50%;
  }
  .tl-item--l {
    margin-right: auto;
    padding-right: 40px;
    text-align: right;
    flex-direction: row-reverse;
  }
  .tl-item--r {
    margin-left: auto;
    padding-left: 40px;
  }
  .tl-dot {
    position: absolute;
    top: 6px;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--ac);
    box-shadow: 0 0 12px var(--ac-g);
    z-index: 1;
  }
  .tl-item--l .tl-dot { right: -6px; }
  .tl-item--r .tl-dot { left: -6px; }

  .tl-year {
    font: 300 clamp(28px, 5vw, 36px)/1 var(--fm);
    color: var(--ac);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  .tl-title {
    display: block;
    font: 500 15px/1.3 var(--fi);
    color: var(--ac);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-size: 11px;
  }
  .tl-desc {
    font: 400 14px/1.6 var(--fi);
    color: var(--t2);
  }
  .tl-body {
    flex: 1;
    min-width: 0;
  }

  /* ═══════ STATS ═══════ */
  .stats {
    padding: 48px 0;
  }
  .stats-grid {
