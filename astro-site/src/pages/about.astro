---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';

const total = D.length;
const subjects = new Set(D.map((d: any) => d.subject).filter(Boolean)).size;

// 20 random titles for marquee
const sample = D.slice()
  .sort(() => Math.random() - 0.5)
  .slice(0, 20)
  .map((d: any) => d.catalogTitle || d.title || d.filename || 'Документ');

// All file slugs for random button
const slugs = D.map((d: any) => d.file);
---

<Base title="О нас — Академический Салон" currentPath="/about">

  <article class="pg">

    <!-- Opening -->
    <header class="head">
      <div class="head-glow" aria-hidden="true"></div>
      <h1 class="head-t rv" data-d="0">Привет.</h1>
      <p class="head-sub rv" data-d="200">Если ты здесь — значит, дедлайн скоро. Мы знаем это чувство.</p>
    </header>

    <!-- Letter -->
    <section class="letter">
      <p class="prose prose--dc rv" data-d="0">Всё началось с телеграм-канала «Кладовая» — студенты одного петербургского вуза делились работами, чтобы помочь друг другу. Канал вырос до сотен документов по психологии, социальной работе и конфликтологии.</p>

      <p class="prose rv" data-d="100">Когда Telegram стал работать нестабильно, мы перенесли библиотеку в веб. Так появился Академический Салон.</p>
    </section>

    <!-- Pullquote -->
    <blockquote class="pq rv" data-d="0">
      <span class="pq-line" aria-hidden="true"></span>
      <em>Мы не корпорация. Мы — те, кто сам через это прошёл.</em>
      <span class="pq-line" aria-hidden="true"></span>
    </blockquote>

    <!-- Live marquee — real document titles -->
    <section class="tape" aria-label="Работы из каталога">
      <div class="tape-track">
        {[...sample, ...sample].map(title => (
          <span class="tape-item">{title}</span>
        ))}
      </div>
    </section>

    <!-- Numbers + random button -->
    <section class="proof">
      <div class="proof-nums">
        <div class="proof-n">
          <span class="proof-v" data-to={total}>0</span>
          <span class="proof-l">работ</span>
        </div>
        <span class="proof-div" aria-hidden="true"></span>
        <div class="proof-n">
          <span class="proof-v" data-to={subjects}>0</span>
          <span class="proof-l">предметов</span>
        </div>
        <span class="proof-div" aria-hidden="true"></span>
        <div class="proof-n">
          <span class="proof-v" data-to={3}>0</span>
          <span class="proof-l">направления</span>
        </div>
      </div>
      <button class="random-btn" id="randomBtn">Открыть случайную работу</button>
    </section>

    <!-- Letter continues — what you get, conversational -->
    <section class="letter">
      <p class="prose rv" data-d="0">В каталоге {total} работ. Все бесплатные, без регистрации. Скачивай что нужно.</p>

      <p class="prose rv" data-d="100">Если нужна уникальная работа — напиши нам. Сделаем индивидуально: с антиплагиатом, в срок, с бесплатными правками пока преподаватель не примет.</p>

      <p class="prose rv" data-d="200">Среднее время ответа — меньше часа. Пишем в Telegram, VK, на почту.</p>
    </section>

    <!-- FAQ — inline, conversational -->
    <section class="qna">
      <p class="qna-intro rv" data-d="0">Вопросы, которые нам задают чаще всего:</p>

      <details class="fq">
        <summary>Это правда бесплатно?<span class="fq-x">+</span></summary>
        <div class="fq-a"><p>Да. Каталог полностью бесплатный. Заказ индивидуальных работ — платная услуга, она поддерживает проект.</p></div>
      </details>

      <details class="fq">
        <summary>Можно сдать работу из каталога?<span class="fq-x">+</span></summary>
        <div class="fq-a"><p>Как образец — да. Для уникальной — закажите индивидуально.</p></div>
      </details>

      <details class="fq">
        <summary>Какие гарантии?<span class="fq-x">+</span></summary>
        <div class="fq-a"><p>Антиплагиат, выполнение в срок, бесплатные правки до принятия преподавателем.</p></div>
      </details>

      <details class="fq">
        <summary>Сколько стоит заказ?<span class="fq-x">+</span></summary>
        <div class="fq-a"><p>Контрольная от 2 500 ₽, реферат от 3 000 ₽, курсовая от 5 000 ₽, дипломная от 30 000 ₽. Точную цену — после обсуждения.</p></div>
      </details>

      <details class="fq">
        <summary>Как быстро?<span class="fq-x">+</span></summary>
        <div class="fq-a"><p>Стандарт — 2 недели. Срочно: 3 дня или 1 день.</p></div>
      </details>

      <details class="fq">
        <summary>Какая уникальность?<span class="fq-x">+</span></summary>
        <div class="fq-a"><p>Вы выбираете: 60%, 70%, 80% или 90%. Проверка в Антиплагиат. Гарантируем не ниже заявленного.</p></div>
      </details>
    </section>

    <!-- Closing -->
    <section class="end">
      <div class="end-glow" aria-hidden="true"></div>
      <div class="end-hr rv" data-d="0" aria-hidden="true"></div>
      <p class="end-t rv" data-d="200">Каталог открыт. Заявки принимаем.</p>
      <div class="end-btns rv" data-d="400">
        <a href="/catalog" class="end-btn">Каталог</a>
        <a href="/order" class="end-btn">Заказать работу</a>
      </div>
      <p class="end-links rv" data-d="600">
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a> ·
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a> ·
        <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
      </p>
      <p class="end-copy rv" data-d="700">© 2022–2026 Академический Салон</p>
    </section>

  </article>

  <!-- Slugs for random button -->
  <script is:inline define:vars={{ slugs }}>
    window.__slugs = slugs;
  </script>

</Base>

<style>
  :global(.footer) { display: none; }

  .pg {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ═══════ REVEAL ═══════ */
  .rv {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity .5s cubic-bezier(.25,0,0,1), transform .5s cubic-bezier(.25,0,0,1);
  }

  .rv.vis { opacity: 1; transform: translateY(0); }

  /* ═══════ OPENING ═══════ */
  .head {
    position: relative;
    padding: 100px 0 64px;
    overflow: hidden;
  }

  .head-glow {
    position: absolute;
    width: 600px; height: 500px;
    top: 30%; left: 50%;
    transform: translate(-50%,-50%);
    background: radial-gradient(circle, rgba(200,165,40,.09) 0%, transparent 60%);
    pointer-events: none;
    animation: gl 10s ease-in-out infinite;
  }

  @keyframes gl {
    0%, 100% { opacity: .5; transform: translate(-50%,-50%) scale(1); }
    50% { opacity: .9; transform: translate(-50%,-50%) scale(1.1); }
  }

  .head-t {
    position: relative;
    font: 400 italic clamp(40px, 8vw, 56px)/1 var(--fd);
    color: var(--t1);
  }

  .head-sub {
    position: relative;
    margin-top: 20px;
    font: 400 clamp(15px, 2.5vw, 18px)/1.6 var(--fi);
    color: rgba(255,255,255,.45);
    max-width: 480px;
  }

  /* ═══════ LETTER (prose) ═══════ */
  .letter {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 16px 0;
  }

  .prose {
    font: 400 19px/1.85 var(--fd);
    color: rgba(255,255,255,.65);
    letter-spacing: .01em;
  }

  .prose--dc::first-letter {
    float: left;
    font: 400 72px/.75 var(--fd);
    color: rgba(201,165,90,.4);
    padding-right: 12px;
    margin-top: 4px;
  }

  /* ═══════ PULLQUOTE ═══════ */
  .pq {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 64px 0;
    margin: 0;
  }

  .pq em {
    font: 400 italic clamp(22px, 4.5vw, 32px)/1.3 var(--fd);
    color: rgba(255,255,255,.75);
    text-align: center;
    flex-shrink: 0;
  }

  .pq-line {
    flex: 1;
    height: 1px;
    background: rgba(201,165,90,.1);
  }

  /* ═══════ TAPE (marquee) ═══════ */
  .tape {
    overflow: hidden;
    padding: 48px 0;
    border-top: 1px solid rgba(255,255,255,.04);
    border-bottom: 1px solid rgba(255,255,255,.04);
    margin-left: -32px;
    margin-right: -32px;
  }

  .tape-track {
    display: flex;
    gap: 48px;
    white-space: nowrap;
    animation: scroll 60s linear infinite;
    will-change: transform;
  }

  .tape-item {
    font: 300 italic 15px/1 var(--fd);
    color: rgba(255,255,255,.2);
    flex-shrink: 0;
  }

  .tape-item::after {
    content: '·';
    margin-left: 48px;
    color: rgba(201,165,90,.15);
  }

  @keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ═══════ PROOF (numbers + random) ═══════ */
  .proof {
    padding: 56px 0;
    text-align: center;
  }

  .proof-nums {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 40px;
    margin-bottom: 40px;
  }

  .proof-n { text-align: center; }

  .proof-v {
    display: block;
    font: 300 clamp(44px, 9vw, 72px)/1 var(--fm);
    color: var(--ac);
    font-variant-numeric: tabular-nums;
  }

  .proof-l {
    display: block;
    margin-top: 10px;
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: rgba(255,255,255,.25);
  }

  .proof-div {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,.06);
    flex-shrink: 0;
  }

  .random-btn {
    background: none;
    border: 1px solid rgba(201,165,90,.2);
    padding: 16px 44px;
    font: 300 italic 15px/1 var(--fd);
    color: rgba(255,255,255,.6);
    cursor: pointer;
    transition: background .5s cubic-bezier(.25,0,0,1), border-color .5s cubic-bezier(.25,0,0,1), color .5s cubic-bezier(.25,0,0,1);
  }

  .random-btn:hover {
    background: rgba(201,165,90,.06);
    border-color: rgba(201,165,90,.3);
    color: var(--t1);
  }

  /* ═══════ QNA ═══════ */
  .qna {
    padding: 48px 0;
    border-top: 1px solid rgba(255,255,255,.04);
  }

  .qna-intro {
    font: 400 italic 16px/1.5 var(--fd);
    color: rgba(255,255,255,.4);
    margin-bottom: 32px;
  }

  .fq { border-bottom: 1px solid rgba(255,255,255,.04); }

  .fq summary {
    display: flex; justify-content: space-between; align-items: center; gap: 16px;
    padding: 20px 0; font: 500 15px/1.4 var(--fi); color: var(--t1);
    cursor: pointer; list-style: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .fq summary::-webkit-details-marker { display: none; }
  .fq summary::marker { display: none; content: ''; }
  .fq summary:hover { color: rgba(201,165,90,.8); }

  .fq-x {
    font: 300 22px/1 var(--fd); color: var(--ac); opacity: .25; flex-shrink: 0;
    transition: transform .4s cubic-bezier(.25,0,0,1), opacity .4s cubic-bezier(.25,0,0,1);
  }

  .fq summary:hover .fq-x { opacity: .5; }
  .fq[open] .fq-x { transform: rotate(45deg); }

  .fq-a { padding: 0 0 20px; }
  .fq-a p { font: 400 14px/1.7 var(--fi); color: rgba(255,255,255,.5); }

  /* ═══════ CLOSING ═══════ */
  .end {
    position: relative;
    text-align: center;
    padding: 80px 0;
    overflow: hidden;
  }

  .end-glow {
    position: absolute;
    width: 500px; height: 400px;
    bottom: -100px; left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(200,165,40,.07) 0%, transparent 60%);
    pointer-events: none;
  }

  .end-hr {
    width: 60px;
    height: 1px;
    margin: 0 auto 32px;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
  }

  .end-hr.vis { opacity: .15; transform: scaleX(1); transition: opacity .8s cubic-bezier(.25,0,0,1), transform .8s cubic-bezier(.25,0,0,1); }

  .end-t { position: relative; font: 300 32px/1.2 var(--fd); color: var(--t1); }

  .end-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-top: 32px; }

  .end-btn {
    padding: 16px 44px; border: 1px solid rgba(201,165,90,.2);
    font: 300 italic 14px/1 var(--fd); color: rgba(255,255,255,.65);
    text-decoration: none; position: relative;
    transition: background .5s cubic-bezier(.25,0,0,1), border-color .5s cubic-bezier(.25,0,0,1), color .5s cubic-bezier(.25,0,0,1);
  }

  .end-btn:hover { background: rgba(201,165,90,.06); border-color: rgba(201,165,90,.3); color: var(--t1); }

  .end-links {
    margin-top: 40px; font: 400 11px/1 var(--fi);
    text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.25);
  }

  .end-links a { color: inherit; text-decoration: none; transition: color .4s cubic-bezier(.25,0,0,1); }
  .end-links a:hover { color: rgba(255,255,255,.6); }

  .end-copy { margin-top: 48px; font: 400 10px/1 var(--fm); color: rgba(255,255,255,.15); letter-spacing: .1em; }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 640px) {
    .pg { padding: 0 20px; }
    .head { padding: 80px 0 48px; }
    .proof-nums { gap: 24px; }
    .proof-div { display: none; }
    .end-btns { flex-direction: column; align-items: center; }
    .tape { margin-left: -20px; margin-right: -20px; }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .rv { opacity: 1; transform: none; transition: none; }
    .head-glow { animation: none; }
    .tape-track { animation: none; }
    .end-hr { opacity: .15; transform: scaleX(1); transition: none; }
    .fq-x, .fq summary, .end-btn, .end-links a, .random-btn { transition: none; }
  }
</style>

<script is:inline>
(function() {
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* Reveal */
  var items = document.querySelectorAll('.rv');
  if (reduced) {
    items.forEach(function(el) { el.classList.add('vis'); });
  } else {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (!e.isIntersecting) return;
        var d = parseInt(e.target.getAttribute('data-d') || '0');
        setTimeout(function() { e.target.classList.add('vis'); }, d);
        obs.unobserve(e.target);
      });
    }, { threshold: .2, rootMargin: '0px 0px -30px 0px' });
    items.forEach(function(el) { obs.observe(el); });
  }

  /* Count-up */
  var nums = document.querySelectorAll('[data-to]');
  var numObs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (!e.isIntersecting) return;
      numObs.unobserve(e.target);
      var target = parseInt(e.target.dataset.to || '0');
      var start = performance.now();
      function tick(now) {
        var t = Math.min((now - start) / 1500, 1);
        var ease = 1 - Math.pow(1 - t, 3);
        e.target.textContent = String(Math.round(ease * target));
        if (t < 1) requestAnimationFrame(tick);
        else e.target.textContent = target + (target > 10 ? '+' : '');
      }
      requestAnimationFrame(tick);
    });
  }, { threshold: .3 });
  nums.forEach(function(el) { numObs.observe(el); });

  /* Random document button */
  var btn = document.getElementById('randomBtn');
  if (btn && window.__slugs && window.__slugs.length) {
    btn.addEventListener('click', function() {
      var slugs = window.__slugs;
      var slug = slugs[Math.floor(Math.random() * slugs.length)];
      window.location.href = '/doc/' + slug;
    });
  }
})();
</script>
