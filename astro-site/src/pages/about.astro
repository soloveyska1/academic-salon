---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';
const total = D.length;
const subjects = new Set(D.map((d: any) => d.subject).filter(Boolean)).size;
---

<Base title="О нас — Академический Салон" currentPath="/about">

  <article class="pg">

    <!-- 1. Opening -->
    <header class="opening">
      <div class="glow glow--top" aria-hidden="true"></div>
      <h1 class="opening-t rv" data-d="0">Академический Салон</h1>
      <div class="hr rv" data-d="200" aria-hidden="true"></div>
      <p class="opening-sub rv" data-d="400">Бесплатная библиотека студенческих работ и сервис индивидуального выполнения</p>
    </header>

    <div class="dia" aria-hidden="true">◆</div>

    <!-- 2. Story -->
    <section class="story">
      <p class="prose prose--dc rv" data-d="0">Всё началось с телеграм-канала «Кладовая» — студенты одного петербургского вуза делились работами, чтобы помочь друг другу. Канал вырос до сотен документов по психологии, социальной работе и конфликтологии.</p>
      <p class="prose rv" data-d="150">Когда Telegram в России стал работать нестабильно, мы перенесли библиотеку в веб. Так появился Академический Салон — место, где можно найти готовую работу или заказать новую.</p>
      <p class="prose rv" data-d="300">Мы не корпорация. Мы — те, кто сам через это прошёл и знает, каково это — искать материал перед дедлайном.</p>
    </section>

    <div class="dia" aria-hidden="true">◆</div>

    <!-- 3. Numbers -->
    <section class="nums">
      <div class="nums-line" aria-hidden="true"></div>
      <div class="nums-row">
        <div class="num rv" data-d="0">
          <span class="num-v" data-to={total}>0</span>
          <span class="num-l">работ</span>
        </div>
        <span class="num-div" aria-hidden="true"></span>
        <div class="num rv" data-d="200">
          <span class="num-v" data-to={subjects}>0</span>
          <span class="num-l">предметов</span>
        </div>
        <span class="num-div" aria-hidden="true"></span>
        <div class="num rv" data-d="400">
          <span class="num-v" data-to={3}>0</span>
          <span class="num-l">направления</span>
        </div>
      </div>
      <div class="nums-line" aria-hidden="true"></div>
    </section>

    <div class="dia" aria-hidden="true">◆</div>

    <!-- 4. What you get -->
    <section class="what">
      <h2 class="sec-t rv" data-d="0">Что вы получаете</h2>
      <div class="what-item rv" data-d="100">
        <b>Бесплатный доступ</b>
        <p>Вся библиотека открыта, без регистрации и SMS.</p>
      </div>
      <div class="what-item rv" data-d="200">
        <b>Индивидуальный подход</b>
        <p>Каждая работа на заказ пишется под ваши требования.</p>
      </div>
      <div class="what-item rv" data-d="300">
        <b>Антиплагиат</b>
        <p>Гарантируем заявленный процент оригинальности.</p>
      </div>
      <div class="what-item rv" data-d="400">
        <b>Бесплатные правки</b>
        <p>Дорабатываем до полного соответствия.</p>
      </div>
    </section>

    <div class="dia" aria-hidden="true">◆</div>

    <!-- 5. FAQ -->
    <section class="faq">
      <h2 class="sec-t rv" data-d="0">Частые вопросы</h2>

      <details class="fq"><summary>Это бесплатно? В чём подвох?<span class="fq-x">+</span></summary><div class="fq-a"><p>Каталог полностью бесплатный — скачивайте без ограничений. Подвоха нет: мы собираем работы, которые уже были сданы. Заказ индивидуальных работ — платная услуга, она поддерживает проект.</p></div></details>

      <details class="fq"><summary>Можно сдать работу из каталога как свою?<span class="fq-x">+</span></summary><div class="fq-a"><p>Работы из каталога — образцы и источники. Можно использовать как основу, но лучше переработать. Если нужна уникальная — закажите индивидуально.</p></div></details>

      <details class="fq"><summary>Какие гарантии?<span class="fq-x">+</span></summary><div class="fq-a"><p>Заявленная уникальность в Антиплагиат, выполнение в срок, соответствие методичкам и бесплатные правки пока преподаватель не примет работу.</p></div></details>

      <details class="fq"><summary>Сколько стоит?<span class="fq-x">+</span></summary><div class="fq-a"><p>Зависит от типа, сроков и требований. Контрольная от 2 500 ₽, реферат от 3 000 ₽, курсовая от 5 000 ₽, дипломная от 30 000 ₽. Точную цену рассчитаем после обсуждения.</p></div></details>

      <details class="fq"><summary>Как быстро сделаете?<span class="fq-x">+</span></summary><div class="fq-a"><p>Стандарт — 2 недели. При необходимости быстрее: неделя, 3 дня, даже 1 день. Сроки обсуждаются индивидуально.</p></div></details>

      <details class="fq"><summary>Какой уровень уникальности?<span class="fq-x">+</span></summary><div class="fq-a"><p>Вы выбираете: 60%, 70%, 80% или 90%. Проверка в Антиплагиат. Гарантируем не ниже заявленного.</p></div></details>
    </section>

    <div class="dia" aria-hidden="true">◆</div>

    <!-- 6. Closing CTA -->
    <section class="end">
      <div class="glow glow--bot" aria-hidden="true"></div>
      <div class="hr rv" data-d="0" aria-hidden="true"></div>
      <p class="end-t rv" data-d="200">Готовы начать?</p>
      <div class="end-btns rv" data-d="400">
        <a href="/catalog" class="end-btn">Каталог</a>
        <a href="/order" class="end-btn">Заказать работу</a>
      </div>
      <p class="end-links rv" data-d="600">
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a> ·
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a> ·
        <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
      </p>
      <p class="end-copy rv" data-d="700">© 2022–2026 Академический Салон</p>
    </section>

  </article>

</Base>

<style>
  :global(.footer) { display: none; }

  .pg {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ═══════ REVEAL ═══════ */
  .rv {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity .5s cubic-bezier(.25,0,0,1), transform .5s cubic-bezier(.25,0,0,1);
  }

  .rv.vis {
    opacity: 1;
    transform: translateY(0);
  }

  /* ═══════ DIAMOND ═══════ */
  .dia {
    text-align: center;
    font-size: 8px;
    color: var(--ac);
    opacity: .1;
    margin: 48px auto;
    user-select: none;
  }

  /* ═══════ HAIRLINE ═══════ */
  .hr {
    width: 60px;
    height: 1px;
    margin: 20px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
  }

  .hr.vis {
    opacity: .2;
    transform: scaleX(1);
    transition: opacity .7s cubic-bezier(.25,0,0,1), transform .7s cubic-bezier(.25,0,0,1);
  }

  /* ═══════ GLOW ═══════ */
  .glow {
    position: absolute;
    width: 600px;
    height: 500px;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
    animation: glp 10s ease-in-out infinite;
  }

  .glow--top {
    top: 20%;
    background: radial-gradient(circle, rgba(200,165,40,.09) 0%, transparent 60%);
  }

  .glow--bot {
    bottom: -100px;
    background: radial-gradient(circle, rgba(200,165,40,.07) 0%, transparent 60%);
  }

  @keyframes glp {
    0%, 100% { opacity: .6; transform: translateX(-50%) scale(1); }
    50% { opacity: 1; transform: translateX(-50%) scale(1.1); }
  }

  /* ═══════ 1. OPENING ═══════ */
  .opening {
    position: relative;
    text-align: center;
    padding: 100px 0 80px;
    overflow: hidden;
  }

  .opening-t {
    position: relative;
    font: 300 clamp(36px, 7vw, 52px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  .opening-sub {
    position: relative;
    margin-top: 20px;
    font: 400 14px/1.6 var(--fi);
    color: rgba(255,255,255,.45);
  }

  /* ═══════ 2. STORY ═══════ */
  .story {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .prose {
    font: 400 19px/1.85 var(--fd);
    color: rgba(255,255,255,.65);
    letter-spacing: .01em;
  }

  .prose--dc::first-letter {
    float: left;
    font: 400 72px/.75 var(--fd);
    color: rgba(201,165,90,.4);
    padding-right: 12px;
    margin-top: 4px;
  }

  /* ═══════ 3. NUMBERS ═══════ */
  .nums {
    padding: 64px 0;
  }

  .nums-line {
    width: 200px;
    height: 1px;
    margin: 0 auto;
    background: rgba(255,255,255,.04);
  }

  .nums-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 40px;
    padding: 48px 0;
  }

  .num { text-align: center; }

  .num-v {
    display: block;
    font: 300 clamp(44px, 9vw, 72px)/1 var(--fm);
    color: var(--ac);
    font-variant-numeric: tabular-nums;
  }

  .num-l {
    display: block;
    margin-top: 10px;
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: rgba(255,255,255,.25);
  }

  .num-div {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,.06);
    flex-shrink: 0;
  }

  /* ═══════ 4. WHAT YOU GET ═══════ */
  .what {
    padding-bottom: 16px;
  }

  .sec-t {
    font: 300 28px/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    text-align: center;
    margin-bottom: 48px;
  }

  .what-item {
    padding: 20px 0 20px 24px;
    border-left: 2px solid rgba(201,165,90,.15);
    margin-bottom: 24px;
    transition: border-color .5s cubic-bezier(.25,0,0,1);
  }

  .what-item:last-child { margin-bottom: 0; }

  .what-item:hover { border-left-color: rgba(201,165,90,.4); }

  .what-item b {
    display: block;
    font: 500 15px/1.3 var(--fi);
    color: var(--t1);
  }

  .what-item p {
    margin-top: 6px;
    font: 400 14px/1.6 var(--fi);
    color: rgba(255,255,255,.4);
  }

  /* ═══════ 5. FAQ ═══════ */
  .faq { padding-bottom: 16px; }

  .fq {
    border-bottom: 1px solid rgba(255,255,255,.04);
  }

  .fq summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 20px 0;
    font: 500 15px/1.4 var(--fi);
    color: var(--t1);
    cursor: pointer;
    list-style: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .fq summary::-webkit-details-marker { display: none; }
  .fq summary::marker { display: none; content: ''; }
  .fq summary:hover { color: rgba(201,165,90,.8); }

  .fq-x {
    font: 300 22px/1 var(--fd);
    color: var(--ac);
    opacity: .25;
    flex-shrink: 0;
    transition: transform .4s cubic-bezier(.25,0,0,1), opacity .4s cubic-bezier(.25,0,0,1);
  }

  .fq summary:hover .fq-x { opacity: .5; }
  .fq[open] .fq-x { transform: rotate(45deg); }

  .fq-a {
    padding: 0 0 20px;
  }

  .fq-a p {
    font: 400 14px/1.7 var(--fi);
    color: rgba(255,255,255,.5);
  }

  /* ═══════ 6. CLOSING ═══════ */
  .end {
    position: relative;
    text-align: center;
    padding: 100px 0 80px;
    overflow: hidden;
  }

  .end .hr { margin-bottom: 32px; }

  .end-t {
    font: 300 32px/1.2 var(--fd);
    color: var(--t1);
  }

  .end-btns {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 32px;
  }

  .end-btn {
    padding: 16px 44px;
    border: 1px solid rgba(201,165,90,.2);
    font: 300 italic 14px/1 var(--fd);
    color: rgba(255,255,255,.65);
    text-decoration: none;
    transition: background .5s cubic-bezier(.25,0,0,1), border-color .5s cubic-bezier(.25,0,0,1), color .5s cubic-bezier(.25,0,0,1);
  }

  .end-btn:hover {
    background: rgba(201,165,90,.06);
    border-color: rgba(201,165,90,.3);
    color: var(--t1);
  }

  .end-links {
    margin-top: 40px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: rgba(255,255,255,.25);
  }

  .end-links a {
    color: inherit;
    text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .end-links a:hover { color: rgba(255,255,255,.6); }

  .end-copy {
    margin-top: 48px;
    font: 400 10px/1 var(--fm);
    color: rgba(255,255,255,.15);
    letter-spacing: .1em;
  }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 640px) {
    .pg { padding: 0 20px; }
    .opening { padding: 80px 0 56px; }
    .nums-row { gap: 24px; }
    .num-div { display: none; }
    .end-btns { flex-direction: column; align-items: center; }
    .end { padding: 80px 0 64px; }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .rv { opacity: 1; transform: none; transition: none; }
    .hr { opacity: .2; transform: scaleX(1); transition: none; }
    .glow { animation: none; }
    .what-item { transition: none; }
    .fq-x, .fq summary, .end-btn, .end-links a { transition: none; }
  }
</style>

<script is:inline>
(function() {
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* Reveal on scroll */
  var items = document.querySelectorAll('.rv');
  if (reduced) {
    items.forEach(function(el) { el.classList.add('vis'); });
  } else {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (!e.isIntersecting) return;
        var d = parseInt(e.target.getAttribute('data-d') || '0');
        setTimeout(function() { e.target.classList.add('vis'); }, d);
        obs.unobserve(e.target);
      });
    }, { threshold: .2, rootMargin: '0px 0px -30px 0px' });
    items.forEach(function(el) { obs.observe(el); });
  }

  /* Count-up */
  var nums = document.querySelectorAll('[data-to]');
  var numObs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (!e.isIntersecting) return;
      numObs.unobserve(e.target);
      var target = parseInt(e.target.dataset.to || '0');
      var start = performance.now();
      var dur = 1500;
      function tick(now) {
        var t = Math.min((now - start) / dur, 1);
        var ease = 1 - Math.pow(1 - t, 3);
        e.target.textContent = String(Math.round(ease * target));
        if (t < 1) requestAnimationFrame(tick);
        else e.target.textContent = target + (target > 10 ? '+' : '');
      }
      requestAnimationFrame(tick);
    });
  }, { threshold: .3 });
  nums.forEach(function(el) { numObs.observe(el); });
})();
</script>
