---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';
const total = D.length;
const fallbackFiles = D.map((d: any) => d.file).filter(Boolean);
---

<Base title="О нас — Библиотека академического салона" description="Как студенческий телеграм-канал вырос в библиотеку из 235+ работ по психологии и социальной работе. Бесплатный каталог и индивидуальные заказы." currentPath="/about">

  <article class="pg">

    <!-- 1. Opening -->
    <header class="opening">
      <div class="glow" aria-hidden="true"></div>
      <h1 class="opening-t rv" data-d="0">Библиотека академического салона</h1>
      <div class="hr rv" data-d="200" aria-hidden="true"></div>
      <p class="opening-sub rv" data-d="400">Бесплатная библиотека студенческих работ и сервис индивидуального выполнения</p>
      <div class="scroll-hint rv" data-d="800" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M7 10l5 5 5-5"/>
        </svg>
      </div>
    </header>

    <!-- 2. Timeline -->
    <section class="tl">
      <h2 class="sec-t rv" data-d="0">Наш путь</h2>
      <div class="tl-track">
        <div class="tl-line" aria-hidden="true"></div>

        <div class="tl-item tl-item--l rv" data-d="0">
          <span class="tl-year">2020</span>
          <div class="tl-dot" aria-hidden="true"></div>
          <div class="tl-body">
            <span class="tl-title">Начало</span>
            <p class="tl-desc">Телеграм-канал &laquo;Кладовая&raquo; &mdash; студенты одного вуза делятся первыми работами.</p>
          </div>
        </div>

        <div class="tl-item tl-item--r rv" data-d="150">
          <span class="tl-year">2022</span>
          <div class="tl-dot" aria-hidden="true"></div>
          <div class="tl-body">
            <span class="tl-title">Рост</span>
            <p class="tl-desc">100+ работ, расширение дисциплин: психология, социальная работа, конфликтология.</p>
          </div>
        </div>

        <div class="tl-item tl-item--l rv" data-d="300">
          <span class="tl-year">2024</span>
          <div class="tl-dot" aria-hidden="true"></div>
          <div class="tl-body">
            <span class="tl-title">Масштабирование</span>
            <p class="tl-desc">200+ работ в канале, появление индивидуальных заказов и первые постоянные клиенты.</p>
          </div>
        </div>

        <div class="tl-item tl-item--r tl-item--now rv" data-d="450">
          <span class="tl-year">2026</span>
          <div class="tl-dot" aria-hidden="true"></div>
          <div class="tl-body">
            <span class="tl-title">Запуск сайта</span>
            <p class="tl-desc">bibliosaloon.ru &mdash; {total}+ работ, полноценная библиотека, калькулятор заказов, индивидуальный сервис. Начало новой главы.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. Stats — glassmorphism cards -->
    <section class="stats">
      <div class="stats-grid">
        <div class="stat-card rv" data-d="0">
          <span class="stat-icon" aria-hidden="true">&infin;</span>
          <b class="stat-title">Работаем до результата</b>
          <p class="stat-sub">Бесплатные правки до защиты</p>
        </div>
        <div class="stat-card rv" data-d="100">
          <span class="stat-icon" aria-hidden="true">&#9670;</span>
          <b class="stat-title">Антиплагиат</b>
          <p class="stat-sub">Гарантия заявленной уникальности</p>
        </div>
        <div class="stat-card rv" data-d="200">
          <span class="stat-icon" aria-hidden="true">&#9201;</span>
          <b class="stat-title">Сроки от 1 дня</b>
          <p class="stat-sub">Стандарт — 2 недели</p>
        </div>
        <div class="stat-card rv" data-d="300">
          <span class="stat-icon" aria-hidden="true">0&#8381;</span>
          <b class="stat-title"><span data-to={total}>0</span>+ работ бесплатно</b>
          <p class="stat-sub">Без регистрации</p>
        </div>
      </div>
    </section>

    <!-- 4. How it works — visual flow -->
    <section class="flow">
      <h2 class="sec-t rv" data-d="0">Как это работает</h2>
      <div class="flow-grid">
        <div class="flow-step rv" data-d="0">
          <span class="flow-num" aria-hidden="true">01</span>
          <svg class="flow-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <b class="flow-title">Найдите или опишите</b>
          <p class="flow-desc">Ищите в каталоге бесплатно или опишите задачу для индивидуального заказа</p>
        </div>
        <div class="flow-arrow rv" data-d="100" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </div>
        <div class="flow-step rv" data-d="200">
          <span class="flow-num" aria-hidden="true">02</span>
          <svg class="flow-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          <b class="flow-title">Мы работаем</b>
          <p class="flow-desc">Пишем, проверяем на плагиат, согласовываем структуру</p>
        </div>
        <div class="flow-arrow rv" data-d="300" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </div>
        <div class="flow-step rv" data-d="400">
          <span class="flow-num" aria-hidden="true">03</span>
          <svg class="flow-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <b class="flow-title">Сдаёте и получаете оценку</b>
          <p class="flow-desc">Готовый файл + бесплатные правки, пока преподаватель не примет</p>
        </div>
      </div>
    </section>

    <!-- 5. Pricing -->
    <section class="pricing">
      <h2 class="sec-t rv" data-d="0">Два формата</h2>
      <div class="pricing-grid">
        <div class="price-card rv" data-d="100">
          <span class="price-label">Каталог</span>
          <span class="price-value">Бесплатно</span>
          <ul class="price-list">
            <li>Без регистрации</li>
            <li>{total}+ работ</li>
            <li>Все форматы</li>
            <li>Мгновенное скачивание</li>
          </ul>
          <a href="/catalog" class="price-cta">Открыть каталог</a>
        </div>
        <div class="price-card price-card--gold rv" data-d="200">
          <span class="price-badge">Популярное</span>
          <span class="price-label">Индивидуально</span>
          <span class="price-value">от 2 500 &#8381;</span>
          <ul class="price-list">
            <li>Под ваши требования</li>
            <li>Антиплагиат</li>
            <li>Правки до защиты</li>
            <li>Сроки от 1 дня</li>
          </ul>
          <a href="/order" class="price-cta price-cta--gold">Заказать</a>
        </div>
      </div>
    </section>

    <!-- 5. Pullquote -->
    <blockquote class="pq rv" data-d="0">
      <span class="pq-line" aria-hidden="true"></span>
      <em>Мы не корпорация. Мы — те, кто сам через это прошёл.</em>
      <span class="pq-line" aria-hidden="true"></span>
    </blockquote>

    <!-- Random document -->
    <div class="random rv" data-d="0">
      <button class="random-btn" id="randomBtn">Открыть случайную работу</button>
      <p class="random-hint">{total} документов в каталоге — попробуйте наудачу</p>
    </div>

    <!-- 6. FAQ -->
    <section class="faq" id="faq">
      <h2 class="sec-t rv" data-d="0">Частые вопросы</h2>
      <details class="fq">
        <summary>Это бесплатно? В чём подвох?<span class="fq-x" aria-hidden="true">+</span></summary>
        <div class="fq-body"><p>Каталог полностью бесплатный. Подвоха нет — мы собираем работы, которые уже были сданы. Заказ индивидуальных работ — платная услуга, она поддерживает проект.</p></div>
      </details>
      <details class="fq">
        <summary>Можно сдать работу из каталога?<span class="fq-x" aria-hidden="true">+</span></summary>
        <div class="fq-body"><p>Как образец — да. Для уникальной — закажите индивидуально.</p></div>
      </details>
      <details class="fq">
        <summary>Какие гарантии?<span class="fq-x" aria-hidden="true">+</span></summary>
        <div class="fq-body"><p>Антиплагиат, выполнение в срок, бесплатные правки до принятия преподавателем.</p></div>
      </details>
      <details class="fq">
        <summary>Сколько стоит?<span class="fq-x" aria-hidden="true">+</span></summary>
        <div class="fq-body"><p>Контрольная от 2 500 &#8381;, реферат от 3 000 &#8381;, курсовая от 5 000 &#8381;, дипломная от 30 000 &#8381;. Точную цену — после обсуждения.</p></div>
      </details>
      <details class="fq">
        <summary>Как быстро?<span class="fq-x" aria-hidden="true">+</span></summary>
        <div class="fq-body"><p>Стандарт — 2 недели. Срочно: 3 дня или 1 день.</p></div>
      </details>
      <details class="fq">
        <summary>Какая уникальность?<span class="fq-x" aria-hidden="true">+</span></summary>
        <div class="fq-body"><p>Вы выбираете: 60%, 70%, 80% или 90%. Проверка в Антиплагиат. Гарантируем не ниже заявленного.</p></div>
      </details>
    </section>

    <!-- 7. Privacy -->
    <section class="faq" id="privacy">
      <h2 class="sec-t rv" data-d="0">Конфиденциальность</h2>
      <details class="fq"><summary>Каталог<span class="fq-x" aria-hidden="true">+</span></summary><div class="fq-body"><p>Скачивание работ не требует регистрации. Мы фиксируем только обезличенную статистику просмотров и скачиваний.</p></div></details>
      <details class="fq"><summary>Заказ работы<span class="fq-x" aria-hidden="true">+</span></summary><div class="fq-body"><p>Мы сохраняем контакт (VK, Telegram или телефон), тему и прикреплённые файлы. Данные используются только для выполнения заказа и удаляются по запросу.</p></div></details>
      <details class="fq"><summary>Загрузка в библиотеку<span class="fq-x" aria-hidden="true">+</span></summary><div class="fq-body"><p>Контакт отправителя виден только модератору. Публикуется только документ — без привязки к автору.</p></div></details>
      <details class="fq"><summary>Аналитика<span class="fq-x" aria-hidden="true">+</span></summary><div class="fq-body"><p>Мы используем Яндекс.Метрику для анализа посещаемости. Данные обезличены.</p></div></details>
      <details class="fq"><summary>Cookies и localStorage<span class="fq-x" aria-hidden="true">+</span></summary><div class="fq-body"><p>Сайт использует localStorage для сохранения темы и избранных документов. Никакие cookie не передаются третьим сторонам.</p></div></details>
      <p class="privacy-contact rv" data-d="0">Вопросы: <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a></p>
    </section>

    <!-- 8. Closing -->
    <section class="end">
      <div class="glow glow--bot" aria-hidden="true"></div>
      <div class="end-mono" aria-hidden="true">AC</div>
      <div class="hr rv" data-d="0" aria-hidden="true"></div>
      <p class="end-t rv" data-d="200">Готовы начать?</p>
      <div class="end-btns rv" data-d="400">
        <a href="/catalog" class="end-btn">Каталог</a>
        <a href="/order" class="end-btn end-btn--gold">Заказать работу</a>
      </div>
      <p class="end-links rv" data-d="600">
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a> ·
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a> ·
        <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
      </p>
      <p class="end-copy rv" data-d="700">&copy; 2022–2026 Библиотека академического салона</p>
    </section>

  </article>

  <script is:inline define:vars={{ fallbackFiles }}>
    window.__randomFiles = fallbackFiles;
  </script>

</Base>

<style>
  :global(.footer) { display: none; }

  .pg {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ═══════ REVEAL ═══════ */
  .rv {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity .5s var(--ease), transform .5s var(--ease);
  }
  .rv.vis { opacity: 1; transform: translateY(0); }

  /* ═══════ HAIRLINE ═══════ */
  .hr {
    width: 60px;
    height: 1px;
    margin: 24px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
  }
  .hr.vis {
    opacity: .15;
    transform: scaleX(1);
    transition: opacity .8s var(--ease), transform .8s var(--ease);
  }

  /* ═══════ GLOW ═══════ */
  .glow {
    position: absolute;
    width: 600px; height: 500px;
    left: 50%;
    pointer-events: none;
    animation: gl 10s ease-in-out infinite;
  }
  .opening > .glow {
    top: 25%;
    transform: translate(-50%,-50%);
    background: radial-gradient(circle, rgba(200,165,40,.09) 0%, transparent 60%);
  }
  .glow--bot {
    bottom: -100px;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(200,165,40,.07) 0%, transparent 60%);
  }
  @keyframes gl {
    0%, 100% { opacity: .5; }
    50% { opacity: .9; }
  }

  /* ═══════ OPENING ═══════ */
  .opening {
    position: relative;
    text-align: center;
    padding: 100px 0 80px;
    overflow: hidden;
  }
  .opening-t {
    position: relative;
    font: 300 clamp(36px, 7vw, 64px)/.92 var(--fd);
    color: var(--t1);
    letter-spacing: -.02em;
    text-wrap: balance;
  }
  .opening-sub {
    position: relative;
    margin-top: 24px;
    font: 400 14px/1.6 var(--fi);
    color: var(--t2);
  }

  /* Scroll indicator */
  .scroll-hint {
    margin-top: 48px;
    color: var(--t3);
    animation: scroll-bob 2s var(--ease) infinite;
  }
  @keyframes scroll-bob {
    0%, 100% { transform: translateY(0); opacity: .4; }
    50% { transform: translateY(6px); opacity: .8; }
  }

  /* ═══════ TIMELINE ═══════ */
  .tl {
    padding: 64px 0 48px;
  }
  .tl-track {
    position: relative;
    margin-top: 48px;
  }
  .tl-line {
    position: absolute;
    left: 50%;
    top: 0; bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, transparent, var(--ac-b2) 10%, var(--ac-b2) 90%, transparent);
    transform: translateX(-50%);
  }
  .tl-item {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 24px;
    padding-bottom: 48px;
    width: 50%;
  }
  .tl-item--l {
    margin-right: auto;
    padding-right: 40px;
    text-align: right;
    flex-direction: row-reverse;
  }
  .tl-item--r {
    margin-left: auto;
    padding-left: 40px;
  }
  .tl-dot {
    position: absolute;
    top: 6px;
    width: 12px; height: 12px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--ac);
    box-shadow: 0 0 12px var(--ac-g);
    z-index: 1;
  }
  .tl-item--l .tl-dot { right: -6px; }
  .tl-item--r .tl-dot { left: -6px; }

  .tl-year {
    font: 300 clamp(28px, 5vw, 36px)/1 var(--fm);
    color: var(--ac);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  .tl-title {
    display: block;
    font: 500 15px/1.3 var(--fi);
    color: var(--ac);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-size: 11px;
  }
  .tl-desc {
    font: 400 14px/1.6 var(--fi);
    color: var(--t2);
  }
  .tl-body {
    flex: 1;
    min-width: 0;
  }

  /* ═══════ STATS ═══════ */
  .stats {
    padding: 48px 0;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .stat-card {
    background: var(--card);
    border: 1px solid var(--brd);
    border-radius: var(--rs);
    padding: 32px;
    text-align: center;
    backdrop-filter: blur(12px);
    transition:
      transform var(--dur-slow) var(--ease),
      border-color var(--dur-slow) var(--ease),
      box-shadow var(--dur-slow) var(--ease);
  }
  .stat-card:hover {
    transform: scale(1.02);
    border-color: var(--ac-b);
    box-shadow: 0 0 24px var(--ac-g2);
  }
  .stat-icon {
    display: block;
    font-size: 48px;
    line-height: 1;
    color: var(--ac);
    margin-bottom: 16px;
  }
  .stat-title {
    display: block;
    font: 500 15px/1.3 var(--fi);
    color: var(--t1);
    margin-bottom: 8px;
  }
  .stat-sub {
    font: 400 13px/1.5 var(--fi);
    color: var(--t3);
  }

  /* ═══════ TIMELINE "NOW" PULSE ═══════ */
  .tl-item--now .tl-dot::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid var(--ac);
    opacity: 0;
    animation: tl-pulse 2s ease-out infinite;
  }
  @keyframes tl-pulse {
    0% { opacity: .6; transform: scale(1); }
    100% { opacity: 0; transform: scale(2.5); }
  }
  .tl-item--now .tl-title { color: var(--ac); }

  /* ═══════ HOW IT WORKS FLOW ═══════ */
  .flow { padding: 64px 0 48px; }
  .flow-grid {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    margin-top: 8px;
  }
  .flow-step {
    flex: 1;
    max-width: 200px;
    text-align: center;
    padding: 24px 16px;
  }
  .flow-num {
    display: block;
    font: 300 48px/1 var(--fm);
    color: var(--ac);
    opacity: .08;
    margin-bottom: 12px;
  }
  .flow-icon {
    color: var(--ac);
    opacity: .6;
    margin-bottom: 16px;
  }
  .flow-title {
    display: block;
    font: 500 14px/1.3 var(--fi);
    color: var(--t1);
    margin-bottom: 8px;
  }
  .flow-desc {
    font: 400 12px/1.6 var(--fi);
    color: var(--t3);
  }
  .flow-arrow {
    display: flex;
    align-items: center;
    padding-top: 60px;
    color: var(--ac);
    opacity: .15;
    flex-shrink: 0;
  }
  @media (max-width: 640px) {
    .flow-grid {
      flex-direction: column;
      align-items: center;
    }
    .flow-arrow {
      padding-top: 0;
      transform: rotate(90deg);
    }
    .flow-step { max-width: 280px; }
  }

  /* ═══════ PRICING ═══════ */
  .pricing {
    padding: 64px 0 48px;
  }
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 8px;
  }
  .price-card {
    background: var(--card);
    border: 1px solid var(--brd);
    border-radius: var(--rs);
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: border-color var(--dur-slow) var(--ease);
  }
  .price-card--gold {
    border-color: var(--ac-b);
    box-shadow: 0 0 32px var(--ac-g2), inset 0 1px 0 var(--ac-b);
  }
  .price-card--gold:hover {
    border-color: var(--ac-b2);
    box-shadow: 0 0 40px var(--ac-g);
  }
  .price-badge {
    position: absolute;
    top: -12px;
    right: 24px;
    padding: 4px 14px;
    font: 500 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--bg);
    background: var(--ac);
    border-radius: 100px;
  }
  .price-card--gold { position: relative; }
  .price-label {
    font: 500 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: var(--t3);
    margin-bottom: 16px;
  }
  .price-value {
    font: 300 clamp(28px, 5vw, 36px)/1 var(--fm);
    color: var(--t1);
    margin-bottom: 24px;
  }
  .price-card--gold .price-value { color: var(--ac); }

  .price-list {
    list-style: none;
    margin-bottom: 28px;
    flex: 1;
  }
  .price-list li {
    font: 400 14px/1.6 var(--fi);
    color: var(--t2);
    padding: 6px 0;
    border-bottom: 1px solid var(--brd);
  }
  .price-list li:last-child { border-bottom: none; }

  .price-cta {
    display: inline-block;
    padding: 14px 36px;
    border: 1px solid var(--brd);
    border-radius: 0;
    font: 300 italic 14px/1 var(--fd);
    color: var(--t2);
    text-decoration: none;
    transition:
      background var(--dur-slow) var(--ease),
      border-color var(--dur-slow) var(--ease),
      color var(--dur-slow) var(--ease);
  }
  .price-cta:hover {
    background: var(--surf);
    border-color: var(--ac-b2);
    color: var(--t1);
  }
  .price-cta--gold {
    border-color: var(--ac-b);
    color: var(--ac);
  }
  .price-cta--gold:hover {
    background: var(--ac-t);
    border-color: var(--ac);
  }

  /* ═══════ PULLQUOTE ═══════ */
  .pq {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 56px 0;
    margin: 0;
  }
  .pq em {
    font: 400 italic clamp(22px, 4.5vw, 30px)/1.3 var(--fd);
    color: var(--t2);
    text-align: center;
    flex-shrink: 0;
  }
  .pq-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ac-b2), transparent);
  }

  /* ═══════ RANDOM ═══════ */
  .random {
    text-align: center;
    padding: 32px 0 48px;
    border-bottom: 1px solid var(--brd);
  }
  .random-btn {
    background: none;
    border: 1px solid var(--ac-b);
    border-radius: 0;
    padding: 16px 44px;
    font: 300 italic 15px/1 var(--fd);
    color: var(--t2);
    cursor: pointer;
    transition:
      background var(--dur-slow) var(--ease),
      border-color var(--dur-slow) var(--ease),
      color var(--dur-slow) var(--ease);
  }
  .random-btn:hover {
    background: var(--surf);
    border-color: var(--ac-b2);
    color: var(--t1);
  }
  .random-hint {
    margin-top: 12px;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
  }

  /* ═══════ FAQ ═══════ */
  .faq {
    padding: 64px 0 48px;
  }
  .sec-t {
    font: 300 clamp(28px, 5vw, 42px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    text-align: center;
    margin-bottom: 40px;
  }
  .fq { border-bottom: 1px solid var(--brd); }

  .fq summary {
    display: flex; justify-content: space-between; align-items: center; gap: 16px;
    padding: 24px 0; font: 500 16px/1.4 var(--fi); color: var(--t1);
    cursor: pointer; list-style: none;
    transition: color var(--dur-slow) var(--ease);
  }
  .fq summary::-webkit-details-marker { display: none; }
  .fq summary::marker { display: none; content: ''; }
  .fq summary:hover { color: var(--ac); }

  .fq-x {
    font: 300 22px/1 var(--fd); color: var(--ac); opacity: .35; flex-shrink: 0;
    transition: transform var(--dur-slow) var(--ease), opacity var(--dur-slow) var(--ease);
  }
  .fq summary:hover .fq-x { opacity: .7; }
  .fq[open] .fq-x { transform: rotate(45deg); opacity: .6; }

  /* Smooth height animation for FAQ body */
  .fq-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--dur-slow) var(--ease);
    overflow: hidden;
  }
  .fq[open] .fq-body {
    grid-template-rows: 1fr;
  }
  .fq-body > p {
    overflow: hidden;
    padding: 0 0 20px;
    font: 400 14px/1.7 var(--fi);
    color: var(--t2);
  }

  /* ═══════ CLOSING ═══════ */
  .end {
    position: relative;
    text-align: center;
    padding: 80px 0;
    overflow: hidden;
  }
  .end .hr { margin-bottom: 32px; }
  .end-t { position: relative; font: 300 32px/1.2 var(--fd); color: var(--t1); }

  /* Decorative monogram watermark */
  .end-mono {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font: 300 clamp(180px, 30vw, 280px)/1 var(--fd);
    color: var(--ac);
    opacity: .03;
    pointer-events: none;
    user-select: none;
  }

  .end-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-top: 32px; }

  .end-btn {
    padding: 16px 44px; border: 1px solid var(--ac-b); border-radius: 0;
    font: 300 italic 14px/1 var(--fd); color: var(--t2);
    text-decoration: none; position: relative;
    transition:
      background var(--dur-slow) var(--ease),
      border-color var(--dur-slow) var(--ease),
      color var(--dur-slow) var(--ease);
  }
  .end-btn:hover { background: var(--surf); border-color: var(--ac-b2); color: var(--t1); }
  .end-btn--gold { border-color: var(--ac-b2); color: var(--ac); }
  .end-btn--gold:hover { background: var(--ac-t); border-color: var(--ac); }

  .end-links {
    margin-top: 40px; font: 400 11px/1 var(--fi);
    text-transform: uppercase; letter-spacing: .12em; color: var(--t3);
  }
  .end-links a { color: inherit; text-decoration: none; transition: color var(--dur-slow) var(--ease); }
  .end-links a:hover { color: var(--t2); }

  .end-copy { margin-top: 48px; font: 400 10px/1 var(--fm); color: var(--t3); letter-spacing: .1em; }

  .privacy-contact {
    margin-top: 20px;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
  }
  .privacy-contact a {
    color: var(--t2);
    text-decoration: none;
    transition: color var(--dur-slow) var(--ease);
  }
  .privacy-contact a:hover { color: var(--ac); }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 640px) {
    .pg { padding: 0 16px; }
    .opening { padding: 40px 0 32px; }
    .opening-t { line-height: 1.15; }

    /* Timeline — single column on mobile */
    .tl-line { left: 16px; }
    .tl-item,
    .tl-item--l,
    .tl-item--r {
      width: 100%;
      margin: 0;
      padding-left: 40px;
      padding-right: 0;
      text-align: left;
      flex-direction: row;
    }
    .tl-item--l .tl-dot,
    .tl-item--r .tl-dot {
      left: 10px;
      right: auto;
    }

    /* Grids → single column */
    .stats-grid,
    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .end-btns { flex-direction: column; align-items: stretch; gap: 8px; }
    .end-btn { text-align: center; min-height: 48px; border-radius: var(--rm); }
    .fq summary { padding: 16px 0; font-size: 16px; min-height: 48px; word-break: break-word; overflow-wrap: break-word; }
  }

  /* ═══════ LIGHT THEME ═══════ */
  :global([data-theme="light"]) .opening > .glow {
    background: radial-gradient(circle, rgba(122,95,18,.04) 0%, transparent 60%);
  }
  :global([data-theme="light"]) .glow--bot {
    background: radial-gradient(circle, rgba(122,95,18,.03) 0%, transparent 60%);
  }
  :global([data-theme="light"]) .pq-line {
    background: linear-gradient(90deg, transparent, rgba(122,95,18,.2), transparent);
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .rv { opacity: 1; transform: none; transition: none; }
    .hr { opacity: .15; transform: scaleX(1); transition: none; }
    .glow { animation: none; }
    .scroll-hint { animation: none; opacity: .5; }
    .stat-card, .fq-x, .fq summary, .end-btn, .end-links a, .random-btn, .price-cta { transition: none; }
    .fq-body { transition: none; }
  }
</style>

<script is:inline>
(function initAboutReveals() {
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  var items = document.querySelectorAll('.rv');
  if (reduced) {
    items.forEach(function(el) { el.classList.add('vis'); });
  } else {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (!e.isIntersecting) return;
        var d = parseInt(e.target.getAttribute('data-d') || '0');
        setTimeout(function() { e.target.classList.add('vis'); }, d);
        obs.unobserve(e.target);
      });
    }, { threshold: .2, rootMargin: '0px 0px -30px 0px' });
    items.forEach(function(el) { obs.observe(el); });
  }

  /* Counter animation */
  var nums = document.querySelectorAll('[data-to]');
  var numObs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (!e.isIntersecting) return;
      numObs.unobserve(e.target);
      var target = parseInt(e.target.dataset.to || '0');
      var start = performance.now();
      function tick(now) {
        var t = Math.min((now - start) / 1500, 1);
        var ease = 1 - Math.pow(1 - t, 3);
        e.target.textContent = String(Math.round(ease * target));
        if (t < 1) requestAnimationFrame(tick);
        else e.target.textContent = target + (target > 10 ? '+' : '');
      }
      requestAnimationFrame(tick);
    });
  }, { threshold: .3 });
  nums.forEach(function(el) { numObs.observe(el); });

  /* Random button */
  var btn = document.getElementById('randomBtn');
  if (btn && !btn.dataset.bound) {
    btn.dataset.bound = '1';
    btn.addEventListener('click', function() {
      var files = window.__randomFiles || [];
      if (!files.length) return;
      var file = files[Math.floor(Math.random() * files.length)];
      window.location.href = '/doc/' + file;
    });
  }
})();

document.addEventListener('astro:page-load', function() {
  var items = document.querySelectorAll('.rv:not(.vis)');
  if (!items.length) return;
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduced) {
    items.forEach(function(el) { el.classList.add('vis'); });
  } else {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (!e.isIntersecting) return;
        var d = parseInt(e.target.getAttribute('data-d') || '0');
        setTimeout(function() { e.target.classList.add('vis'); }, d);
        obs.unobserve(e.target);
      });
    }, { threshold: .2, rootMargin: '0px 0px -30px 0px' });
    items.forEach(function(el) { obs.observe(el); });
  }
});
</script>

<!-- GSAP About Animations -->
<script>
  var aboutGsapModules;

  function loadAboutGsap() {
    if (!aboutGsapModules) {
      aboutGsapModules = Promise.all([
        import('gsap'),
        import('gsap/ScrollTrigger'),
        import('gsap/SplitText'),
        import('gsap/ScrambleTextPlugin')
      ]).then(function(mods) {
        var gsap = mods[0].gsap;
        var ScrollTrigger = mods[1].ScrollTrigger;
        var SplitText = mods[2].SplitText;
        var ScrambleTextPlugin = mods[3].ScrambleTextPlugin;
        gsap.registerPlugin(ScrollTrigger, SplitText, ScrambleTextPlugin);
        return { gsap, ScrollTrigger, SplitText, ScrambleTextPlugin };
      });
    }
    return aboutGsapModules;
  }

  async function initAboutGSAP() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.innerWidth <= 768) return;
    var mods = await loadAboutGsap();
    var gsap = mods.gsap;
    var ScrollTrigger = mods.ScrollTrigger;
    var SplitText = mods.SplitText;
    ScrollTrigger.getAll().forEach(st => st.kill());

    /* Opening title — kinetic chars */
    const openingT = document.querySelector('.opening-t');
    if (openingT) {
      (openingT as HTMLElement).style.opacity = '1';
      (openingT as HTMLElement).style.transform = 'none';
      const split = new SplitText(openingT, { type: 'chars', charsClass: 'gsap-char' });
      gsap.from(split.chars, {
        opacity: 0, y: 30, rotateX: -45,
        stagger: 0.02, duration: 0.8, ease: 'power3.out', delay: 0.3,
      });
    }

    /* Pullquote — lines draw in, text fades */
    const pq = document.querySelector('.pq');
    if (pq) {
      const lines = pq.querySelectorAll('.pq-line');
      const em = pq.querySelector('em');
      (pq as HTMLElement).style.opacity = '1';
      (pq as HTMLElement).style.transform = 'none';
      gsap.from(lines, {
        scaleX: 0, duration: 0.8, ease: 'power3.inOut',
        scrollTrigger: { trigger: pq, start: 'top 80%', once: true },
      });
      if (em) {
        gsap.from(em, {
          opacity: 0, y: 12, duration: 0.7, delay: 0.3, ease: 'power2.out',
          scrollTrigger: { trigger: pq, start: 'top 80%', once: true },
        });
      }
    }

    /* Counter — ScrambleText */
    document.querySelectorAll('.stat-title [data-to]').forEach(el => {
      const target = el.getAttribute('data-to') || '0';
      const suffix = parseInt(target) > 10 ? '+' : '';
      gsap.to(el, {
        scrambleText: { text: target + suffix, chars: '0123456789', speed: 0.4 },
        duration: 1.5, ease: 'power2.inOut',
        scrollTrigger: { trigger: el, start: 'top 90%', once: true },
      });
    });

    /* Timeline items — stagger */
    const tlItems = document.querySelectorAll('.tl-item');
    if (tlItems.length) {
      tlItems.forEach(item => {
        (item as HTMLElement).style.opacity = '1';
        (item as HTMLElement).style.transform = 'none';
      });
      gsap.from(tlItems, {
        opacity: 0, y: 20, stagger: 0.15,
        duration: 0.7, ease: 'power3.out',
        scrollTrigger: { trigger: '.tl-track', start: 'top 75%', once: true },
      });
    }

    /* Stat cards — stagger */
    const statCards = document.querySelectorAll('.stat-card');
    if (statCards.length) {
      statCards.forEach(c => {
        (c as HTMLElement).style.opacity = '1';
        (c as HTMLElement).style.transform = 'none';
      });
      gsap.from(statCards, {
        opacity: 0, scale: 0.95, stagger: 0.08,
        duration: 0.6, ease: 'power2.out',
        scrollTrigger: { trigger: '.stats', start: 'top 75%', once: true },
      });
    }

    /* FAQ — cascade */
    const fqs = document.querySelectorAll('.fq');
    if (fqs.length) {
      gsap.from(fqs, {
        opacity: 0, y: 12, stagger: 0.06,
        duration: 0.5, ease: 'power2.out',
        scrollTrigger: { trigger: '.faq', start: 'top 80%', once: true },
      });
    }

    /* Closing */
    const endT = document.querySelector('.end-t');
    if (endT) {
      (endT as HTMLElement).style.opacity = '1';
      (endT as HTMLElement).style.transform = 'none';
      const split = new SplitText(endT, { type: 'words', wordsClass: 'gsap-word' });
      gsap.from(split.words, {
        opacity: 0, y: 16, stagger: 0.05,
        duration: 0.6, ease: 'power3.out',
        scrollTrigger: { trigger: endT, start: 'top 85%', once: true },
      });
    }

    ScrollTrigger.refresh();
  }

  document.addEventListener('astro:page-load', initAboutGSAP);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAboutGSAP);
  } else {
    initAboutGSAP();
  }
</script>
