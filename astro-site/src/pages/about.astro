---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';
const total = D.length;
const subjects = new Set(D.map((d: any) => d.subject).filter(Boolean)).size;
---

<Base
  title="Академический Салон — О нас"
  description="235+ бесплатных работ по психологии, социальной работе и конфликтологии."
  currentPath="/about"
>

  <!-- Frame 1: Hook -->
  <section class="fr" data-fr>
    <div class="fr1-glow" aria-hidden="true"></div>
    <p class="fr1-text" id="fr1text">3 часа ночи. Дедлайн завтра.</p>
    <span class="fr1-arrow" aria-hidden="true">↓</span>
  </section>

  <!-- Frame 2: Empathy -->
  <section class="fr" data-fr>
    <p class="fr2-wm" aria-hidden="true">Знакомо?</p>
    <p class="anim" data-d="300">Мы тоже через это прошли.</p>
    <p class="fr2-sub anim" data-d="600">Студенты из Петербурга, которые решили помогать другим.</p>
  </section>

  <!-- Frame 3: Scale -->
  <section class="fr" data-fr>
    <div class="fr3-row">
      <div class="fr3-num anim" data-d="0">
        <span class="fr3-v">{total}+</span>
        <span class="fr3-l">работ</span>
      </div>
      <span class="fr3-div" aria-hidden="true"></span>
      <div class="fr3-num anim" data-d="400">
        <span class="fr3-v">{subjects}+</span>
        <span class="fr3-l">предметов</span>
      </div>
      <span class="fr3-div" aria-hidden="true"></span>
      <div class="fr3-num anim" data-d="800">
        <span class="fr3-v">3</span>
        <span class="fr3-l">направления</span>
      </div>
    </div>
  </section>

  <!-- Frame 4: Values (auto-rotate) -->
  <section class="fr" data-fr>
    <div class="fr4" id="fr4">
      <div class="fr4-slide active">
        <span class="fr4-n">0 ₽</span>
        <p class="fr4-d">Каталог бесплатный. Без регистрации.</p>
      </div>
      <div class="fr4-slide">
        <span class="fr4-n">100%</span>
        <p class="fr4-d">Антиплагиат на заказные работы.</p>
      </div>
      <div class="fr4-slide">
        <span class="fr4-n">∞</span>
        <p class="fr4-d">Бесплатные правки до полного соответствия.</p>
      </div>
      <div class="fr4-slide">
        <span class="fr4-n">&lt;1 ч</span>
        <p class="fr4-d">Среднее время ответа.</p>
      </div>
    </div>
    <div class="fr4-dots" id="fr4dots">
      <button class="fr4-dot active" data-slide="0" aria-label="1"></button>
      <button class="fr4-dot" data-slide="1" aria-label="2"></button>
      <button class="fr4-dot" data-slide="2" aria-label="3"></button>
      <button class="fr4-dot" data-slide="3" aria-label="4"></button>
    </div>
  </section>

  <!-- Frame 5: Brand -->
  <section class="fr" data-fr>
    <div class="fr5-glow" aria-hidden="true"></div>
    <h1 class="fr5-t anim" data-d="0" id="fr5t">Академический Салон</h1>
    <div class="fr5-rule anim" data-d="800" aria-hidden="true"></div>
    <p class="fr5-sub anim" data-d="1000">Библиотека студенческих работ и сервис индивидуального выполнения</p>
  </section>

  <!-- Frame 6: FAQ (no snap) -->
  <section class="fr fr--flow" data-fr>
    <div class="faq">
      <h2 class="faq-h">Частые вопросы</h2>
      <details class="fq"><summary><span>Это бесплатно?</span><span class="fq-x">+</span></summary><div class="fq-a"><p>Каталог полностью бесплатный. Заказ индивидуальных работ — платная услуга.</p></div></details>
      <details class="fq"><summary><span>Можно сдать работу из каталога?</span><span class="fq-x">+</span></summary><div class="fq-a"><p>Как образец — да. Для уникальной — закажите индивидуально.</p></div></details>
      <details class="fq"><summary><span>Какие гарантии?</span><span class="fq-x">+</span></summary><div class="fq-a"><p>Антиплагиат, выполнение в срок, бесплатные правки до принятия.</p></div></details>
      <details class="fq"><summary><span>Сколько стоит?</span><span class="fq-x">+</span></summary><div class="fq-a"><p>Контрольная от 2 500 ₽, реферат от 3 000 ₽, курсовая от 5 000 ₽, дипломная от 30 000 ₽.</p></div></details>
      <details class="fq"><summary><span>Как быстро?</span><span class="fq-x">+</span></summary><div class="fq-a"><p>Стандарт — 2 недели. Срочно: 3 дня или 1 день.</p></div></details>
    </div>
  </section>

  <!-- Frame 7: CTA -->
  <section class="fr" data-fr>
    <div class="fr7-glow" aria-hidden="true"></div>
    <p class="fr7-t anim" data-d="0">Каталог открыт. Заявки принимаем.</p>
    <div class="fr7-rule anim" data-d="400" aria-hidden="true"></div>
    <div class="fr7-btns anim" data-d="600">
      <a href="/catalog" class="fr7-btn">Каталог</a>
      <a href="/order" class="fr7-btn">Заказать работу</a>
      <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="fr7-btn">Написать нам</a>
    </div>
    <nav class="fr7-links anim" data-d="800">
      <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
      <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a>
      <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
    </nav>
    <p class="fr7-copy anim" data-d="900">© 2022–2026 Академический Салон</p>
  </section>

</Base>

<style>
  :global(.footer) { display: none; }
  :global(html) { scroll-snap-type: y mandatory; }

  /* ═══════ FRAME BASE ═══════ */
  .fr {
    scroll-snap-align: start;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 0 32px;
    text-align: center;
  }

  .fr--flow {
    scroll-snap-align: none;
    min-height: auto;
    padding: 80px 32px;
  }

  /* ═══════ ANIM HELPER ═══════ */
  .anim {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity .7s cubic-bezier(.25,0,0,1), transform .7s cubic-bezier(.25,0,0,1);
  }

  .anim.in {
    opacity: 1;
    transform: translateY(0);
  }

  /* ═══════ F1: HOOK ═══════ */
  .fr1-glow {
    position: absolute;
    width: 500px; height: 500px;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    background: radial-gradient(circle, rgba(80,100,180,.03) 0%, transparent 65%);
    pointer-events: none;
  }

  .fr1-text {
    font: 400 italic clamp(28px, 6vw, 48px)/1.3 var(--fd);
    color: rgba(255,255,255,.85);
    position: relative;
  }

  .fr1-text .ch {
    display: inline-block;
    opacity: 0;
    transform: translateY(16px);
    animation: chIn .4s cubic-bezier(.25,0,0,1) forwards;
  }

  @keyframes chIn { to { opacity: 1; transform: translateY(0); } }

  .fr1-arrow {
    position: absolute;
    bottom: 48px;
    font: 300 20px/1 var(--fi);
    color: rgba(255,255,255,.2);
    animation: arrPulse 2s ease-in-out infinite 2s;
  }

  @keyframes arrPulse {
    0%, 100% { opacity: .2; transform: translateY(0); }
    50% { opacity: .4; transform: translateY(6px); }
  }

  /* ═══════ F2: EMPATHY ═══════ */
  .fr2-wm {
    position: absolute;
    font: 300 clamp(80px, 15vw, 200px)/1 var(--fd);
    color: rgba(255,255,255,.04);
    pointer-events: none;
    user-select: none;
  }

  .fr > .anim:not(.fr2-sub) {
    font: 300 italic clamp(22px, 4vw, 28px)/1.3 var(--fd);
    color: rgba(255,255,255,.8);
    position: relative;
  }

  .fr2-sub {
    margin-top: 16px;
    font: 400 15px/1.6 var(--fi);
    color: rgba(255,255,255,.4);
    max-width: 420px;
    position: relative;
  }

  /* ═══════ F3: SCALE ═══════ */
  .fr3-row {
    display: flex;
    align-items: center;
    gap: 48px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .fr3-num { text-align: center; }

  .fr3-num.anim {
    transform: scale(.5) translateY(0);
  }

  .fr3-num.anim.in {
    transform: scale(1);
  }

  .fr3-v {
    display: block;
    font: 300 clamp(56px, 12vw, 96px)/1 var(--fm);
    color: var(--ac);
    font-variant-numeric: tabular-nums;
  }

  .fr3-l {
    display: block;
    margin-top: 8px;
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: rgba(255,255,255,.25);
  }

  .fr3-div {
    width: 1px;
    height: 48px;
    background: rgba(255,255,255,.06);
    flex-shrink: 0;
  }

  /* ═══════ F4: VALUES ═══════ */
  .fr4 { position: relative; width: 100%; max-width: 480px; height: 200px; }

  .fr4-slide {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity .5s cubic-bezier(.25,0,0,1);
  }

  .fr4-slide.active { opacity: 1; }

  .fr4-n {
    font: 300 clamp(64px, 14vw, 120px)/1 var(--fm);
    color: var(--ac);
  }

  .fr4-d {
    margin-top: 16px;
    font: 400 16px/1.5 var(--fi);
    color: rgba(255,255,255,.5);
  }

  .fr4-dots {
    display: flex;
    gap: 10px;
    margin-top: 40px;
  }

  .fr4-dot {
    width: 6px; height: 6px;
    background: rgba(255,255,255,.15);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background .4s cubic-bezier(.25,0,0,1);
  }

  .fr4-dot.active { background: var(--ac); }

  /* ═══════ F5: BRAND ═══════ */
  .fr5-glow {
    position: absolute;
    width: 600px; height: 500px;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    background: radial-gradient(circle, rgba(200,165,40,.08) 0%, transparent 60%);
    pointer-events: none;
    animation: glowPulse 10s ease-in-out infinite;
  }

  @keyframes glowPulse {
    0%, 100% { opacity: .5; transform: translate(-50%,-50%) scale(1); }
    50% { opacity: .9; transform: translate(-50%,-50%) scale(1.1); }
  }

  .fr5-t {
    position: relative;
    font: 300 clamp(28px, 6vw, 56px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .3em;
    transition: letter-spacing 1.2s cubic-bezier(.25,0,0,1), opacity .7s cubic-bezier(.25,0,0,1), transform .7s cubic-bezier(.25,0,0,1);
  }

  .fr5-t.in { letter-spacing: .02em; }

  .fr5-rule {
    width: 80px;
    height: 1px;
    margin: 24px auto 0;
    background: var(--ac);
    transform: scaleX(0);
    transition: transform .8s cubic-bezier(.25,0,0,1), opacity .7s cubic-bezier(.25,0,0,1);
  }

  .fr5-rule.in { opacity: .2; transform: scaleX(1); }

  .fr5-sub {
    position: relative;
    margin-top: 20px;
    font: 400 14px/1.6 var(--fi);
    color: rgba(255,255,255,.4);
    max-width: 440px;
  }

  /* ═══════ F7: CTA ═══════ */
  .fr7-glow {
    position: absolute;
    width: 500px; height: 400px;
    bottom: -150px; left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(200,165,40,.06) 0%, transparent 65%);
    pointer-events: none;
  }

  .fr7-t {
    position: relative;
    font: 300 clamp(22px, 4vw, 32px)/1.3 var(--fd);
    color: var(--t1);
  }

  .fr7-rule {
    width: 60px;
    height: 1px;
    margin: 24px auto;
    background: var(--ac);
    opacity: .15;
    transform: scaleX(0);
    transition: transform .6s cubic-bezier(.25,0,0,1), opacity .6s cubic-bezier(.25,0,0,1);
  }

  .fr7-rule.in { transform: scaleX(1); }

  .fr7-btns { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; }

  .fr7-btn {
    padding: 14px 40px;
    border: .5px solid rgba(255,255,255,.12);
    font: 400 11px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .12em;
    color: rgba(255,255,255,.5);
    text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1), border-color .4s cubic-bezier(.25,0,0,1);
  }

  .fr7-btn:hover { color: rgba(255,255,255,.85); border-color: rgba(255,255,255,.25); }

  .fr7-links { margin-top: 32px; display: flex; gap: 20px; }

  .fr7-links a {
    font: 400 11px/1 var(--fi); text-transform: uppercase; letter-spacing: .1em;
    color: rgba(255,255,255,.2); text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .fr7-links a:hover { color: rgba(255,255,255,.6); }

  .fr7-copy {
    margin-top: 20px;
    font: 400 10px/1 var(--fm);
    color: rgba(255,255,255,.12);
    letter-spacing: .1em;
  }

  /* ═══════ FAQ ═══════ */
  .faq { max-width: 600px; width: 100%; }

  .faq-h { font: 300 28px/1 var(--fd); color: var(--t1); text-align: center; margin-bottom: 32px; }

  .fq { border-bottom: 1px solid rgba(255,255,255,.04); }

  .fq summary {
    display: flex; justify-content: space-between; align-items: center; gap: 16px;
    padding: 18px 0; font: 500 15px/1.4 var(--fi); color: var(--t1);
    cursor: pointer; list-style: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .fq summary::-webkit-details-marker { display: none; }
  .fq summary::marker { display: none; content: ''; }
  .fq summary:hover { color: rgba(201,165,90,.8); }

  .fq-x {
    font: 300 24px/1 var(--fd); color: var(--ac); opacity: .3; flex-shrink: 0;
    transition: transform .4s cubic-bezier(.25,0,0,1), opacity .4s cubic-bezier(.25,0,0,1);
  }

  .fq summary:hover .fq-x { opacity: .6; }
  .fq[open] .fq-x { transform: rotate(45deg); }

  .fq-a { padding: 0 0 20px; }
  .fq-a p { font: 400 14px/1.7 var(--fi); color: rgba(255,255,255,.5); }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 640px) {
    .fr3-row { gap: 24px; }
    .fr3-div { display: none; }
    .fr4-dots { margin-top: 24px; }
    .fr7-btns { flex-direction: column; align-items: center; }
    .fr7-links { flex-wrap: wrap; justify-content: center; }
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    :global(html) { scroll-snap-type: none; }
    .anim { opacity: 1; transform: none; transition: none; }
    .fr1-text .ch { opacity: 1; transform: none; animation: none; }
    .fr1-arrow { animation: none; opacity: .2; }
    .fr5-t { letter-spacing: .02em; transition: none; }
    .fr5-rule { transform: scaleX(1); opacity: .2; transition: none; }
    .fr7-rule { transform: scaleX(1); transition: none; }
    .fr5-glow { animation: none; }
    .fr4-dot, .fq-x, .fr7-btn, .fr7-links a, .fq summary { transition: none; }
  }
</style>

<script is:inline>
(function() {
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* Letter-by-letter for frame 1 */
  var fr1 = document.getElementById('fr1text');
  if (fr1 && !reduced) {
    var text = fr1.textContent;
    fr1.textContent = '';
    for (var i = 0; i < text.length; i++) {
      var span = document.createElement('span');
      span.className = 'ch';
      span.textContent = text[i] === ' ' ? '\u00A0' : text[i];
      span.style.animationDelay = (i * 50 + 300) + 'ms';
      fr1.appendChild(span);
    }
  }

  /* Frame visibility observer — trigger .anim elements */
  if (!reduced) {
    var frames = document.querySelectorAll('[data-fr]');
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        var anims = e.target.querySelectorAll('.anim');
        if (e.isIntersecting) {
          anims.forEach(function(el) {
            var d = parseInt(el.getAttribute('data-d') || '0');
            setTimeout(function() { el.classList.add('in'); }, d);
          });
        } else {
          anims.forEach(function(el) { el.classList.remove('in'); });
        }
      });
    }, { threshold: 0.5 });
    frames.forEach(function(f) { obs.observe(f); });
  }

  /* Frame 4: auto-rotate values */
  var fr4 = document.getElementById('fr4');
  var dots = document.querySelectorAll('.fr4-dot');
  if (fr4 && dots.length) {
    var slides = fr4.querySelectorAll('.fr4-slide');
    var current = 0;
    var timer = null;

    function goTo(i) {
      current = ((i % slides.length) + slides.length) % slides.length;
      slides.forEach(function(s, idx) { s.classList.toggle('active', idx === current); });
      dots.forEach(function(d, idx) { d.classList.toggle('active', idx === current); });
    }

    function startAuto() {
      stopAuto();
      timer = setInterval(function() { goTo(current + 1); }, 3000);
    }

    function stopAuto() { if (timer) { clearInterval(timer); timer = null; } }

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        goTo(parseInt(dot.getAttribute('data-slide') || '0'));
        startAuto();
      });
    });

    /* Only auto-rotate when frame is visible */
    var fr4section = fr4.closest('.fr');
    if (fr4section) {
      var fr4obs = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting) startAuto();
        else stopAuto();
      }, { threshold: 0.5 });
      fr4obs.observe(fr4section);
    }
  }
})();
</script>
