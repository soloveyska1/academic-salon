---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';
const total = D.length;
const fallbackFiles = D.map((d: any) => d.file).filter(Boolean);
const categoriesCount = new Set(D.map((d: any) => d.category).filter(Boolean)).size;
const subjectsCount   = new Set(D.map((d: any) => d.subject).filter(Boolean)).size;
---

<Base title="О салоне — Академический Салон" description="Академический Салон с 2020 года: свободный архив из 235+ студенческих работ по психологии, социальной работе и конфликтологии плюс авторский сервис под защиту." currentPath="/about">

  <article class="pg about-article">

    <!-- ============================================================
         PRELUDE — editorial, без glow
         ============================================================ -->
    <header class="about-prelude" aria-label="О салоне">
      <div class="about-wrap">
        <div class="about-prelude-eyebrow" aria-hidden="true">
          <span class="rule"></span>
          <span class="word">De nobis · о&nbsp;нас</span>
        </div>

        <h1 class="about-prelude-h rv" data-d="100">
          Архив, который собрали <em class="it">сами студенты</em>.
        </h1>

        <p class="about-prelude-lede rv" data-d="200">
          Шесть&nbsp;лет назад мы&nbsp;начали складывать защищённые курсовые в&nbsp;Telegram-канал, чтобы следующие не&nbsp;мучились. Сегодня&nbsp;— <b>{total}&nbsp;работ</b> в&nbsp;свободном архиве, команда авторов под&nbsp;заказ, разговор тридцать минут до&nbsp;плана.
        </p>

        <div class="about-prelude-stats rv" data-d="300" aria-label="В цифрах">
          <div class="col">
            <span class="lbl">Основан</span>
            <span class="val">в&nbsp;<i class="it">2020</i></span>
          </div>
          <div class="col">
            <span class="lbl">В&nbsp;архиве</span>
            <span class="val">{total} <i class="it">работ</i></span>
          </div>
          <div class="col">
            <span class="lbl">Дисциплин</span>
            <span class="val">{subjectsCount}+</span>
          </div>
          <div class="col">
            <span class="lbl">Доступ</span>
            <span class="val"><i class="it">бесплатный</i></span>
          </div>
        </div>
      </div>
    </header>

    <!-- ============================================================
         I · Как это было — editorial-разворот года/абзацы
         ============================================================ -->
    <section class="about-history about-section" aria-label="История">
      <div class="about-wrap">
        <header class="chapter-head rv" data-d="0">
          <div class="chapter-num">
            <span class="roman" aria-hidden="true">I</span>
            <span class="chapter-label">Caput Primum · История</span>
          </div>
          <div class="chapter-title-block">
            <h2 class="chapter-h">Как <em class="it">это</em> было.</h2>
            <p class="chapter-lede">Четыре года, четыре главы. Без&nbsp;прикрас и&nbsp;без&nbsp;«мы&nbsp;всегда были лидерами». Всё началось с&nbsp;канала в&nbsp;Telegram и&nbsp;сорока подписчиков.</p>
          </div>
        </header>

        <ol class="about-history-list" role="list">
          <li class="about-history-entry rv" data-d="0">
            <span class="year">2020</span>
            <div class="entry-body">
              <h3 class="entry-h">Кладовая.</h3>
              <p class="entry-p">Полтора&nbsp;года — обычный Telegram-канал. Один студент выкладывает свою защищённую курсовую, другой забирает как образец для&nbsp;своей. Десяток работ, сорок подписчиков, никто не&nbsp;думает, что из&nbsp;этого получится что-то больше.</p>
            </div>
          </li>

          <li class="about-history-entry rv" data-d="100">
            <span class="year">2022</span>
            <div class="entry-body">
              <h3 class="entry-h">Поток.</h3>
              <p class="entry-p">Работ становится сто, подписчиков&nbsp;— сотни. В&nbsp;какой-то момент мы&nbsp;с&nbsp;ребятами из&nbsp;канала понимаем, что умеем писать не&nbsp;хуже, чем преподаватели требуют. Первые пять заказов&nbsp;— от&nbsp;знакомых, за&nbsp;скромные деньги, с&nbsp;репетицией защиты на&nbsp;кухне.</p>
            </div>
          </li>

          <li class="about-history-entry rv" data-d="200">
            <span class="year">2024</span>
            <div class="entry-body">
              <h3 class="entry-h">Мастерская.</h3>
              <p class="entry-p">Двести работ в&nbsp;архиве. Команда авторов с&nbsp;профильным образованием&nbsp;— каждый ведёт максимум три–четыре работы одновременно. Постоянные клиенты по&nbsp;рекомендациям. Учимся говорить <em class="it">«нет»</em>&nbsp;— выясняется, что это главный навык.</p>
            </div>
          </li>

          <li class="about-history-entry about-history-entry--now rv" data-d="300">
            <span class="year">2026</span>
            <div class="entry-body">
              <h3 class="entry-h">Салон.</h3>
              <p class="entry-p">Сайт. {total}&nbsp;работ в&nbsp;свободном архиве, калькулятор стоимости, живой чек, кабинет для&nbsp;клиента. Новая глава: архив и&nbsp;заказ в&nbsp;одном месте. Название меняется&nbsp;— суть остаётся.</p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- ============================================================
         II · Обещания — 4 tenet-плашки
         ============================================================ -->
    <section class="about-promises about-section" aria-label="Обещания">
      <div class="about-wrap">
        <header class="chapter-head rv" data-d="0">
          <div class="chapter-num">
            <span class="roman" aria-hidden="true">II</span>
            <span class="chapter-label">Caput Secundum · Обещания</span>
          </div>
          <div class="chapter-title-block">
            <h2 class="chapter-h">Что <em class="it">обещаем</em>.</h2>
            <p class="chapter-lede">Четыре вещи, которых держимся. Не&nbsp;маркетинг, а&nbsp;причины, по&nbsp;которым клиенты возвращаются.</p>
          </div>
        </header>

        <ol class="about-tenets" role="list">
          <li class="about-tenet rv" data-d="0">
            <span class="tenet-num">Principium I</span>
            <h3 class="tenet-h">Мы&nbsp;сами были на&nbsp;вашем месте</h3>
            <p class="tenet-p">Начинали потому что сами писали курсовые в&nbsp;три ночи перед сдачей. Знаем, каково это&nbsp;— когда работа у&nbsp;руководителя третий раз на&nbsp;правках, а&nbsp;защита послезавтра.</p>
          </li>
          <li class="about-tenet rv" data-d="100">
            <span class="tenet-num">Principium II</span>
            <h3 class="tenet-h">Говорим «нет» открыто</h3>
            <p class="tenet-p">Если тема не&nbsp;наша, не&nbsp;успеем, не&nbsp;понимаем задачу&nbsp;— сразу «нет». Лучше честный отказ сейчас, чем сорванный срок через месяц.</p>
          </li>
          <li class="about-tenet rv" data-d="200">
            <span class="tenet-num">Principium III</span>
            <h3 class="tenet-h">50/50 после плана</h3>
            <p class="tenet-p">Никакой предоплаты за&nbsp;«обещание». Сначала план работы, договор, разговор с&nbsp;автором&nbsp;— только потом первые 50%. Остаток&nbsp;— после защиты.</p>
          </li>
          <li class="about-tenet rv" data-d="300">
            <span class="tenet-num">Principium IV</span>
            <h3 class="tenet-h">После защиты&nbsp;— ваше</h3>
            <p class="tenet-p">Заказанная работа не&nbsp;публикуется в&nbsp;архиве. NDA по&nbsp;запросу. Автор знает вас только под&nbsp;инициалами. После сдачи мы&nbsp;исчезаем из&nbsp;вашей жизни.</p>
          </li>
        </ol>
      </div>
    </section>

    <!-- ============================================================
         III · Кто пишет — команда без имён
         ============================================================ -->
    <section class="about-authors about-section" aria-label="Авторы">
      <div class="about-wrap">
        <header class="chapter-head rv" data-d="0">
          <div class="chapter-num">
            <span class="roman" aria-hidden="true">III</span>
            <span class="chapter-label">Caput Tertium · Авторы</span>
          </div>
          <div class="chapter-title-block">
            <h2 class="chapter-h">Кто <em class="it">пишет</em>.</h2>
            <p class="chapter-lede">Без&nbsp;имён, фото и&nbsp;биографий на&nbsp;восемь страниц. Главное&nbsp;— принципы работы.</p>
          </div>
        </header>

        <div class="about-authors-body rv" data-d="100">
          <p class="about-authors-p">
            Нас немного. Каждый автор&nbsp;— с&nbsp;профильным образованием: психология, социальная работа, педагогика, право, экономика. Работают удалённо, ведут <em class="it">не&nbsp;больше трёх–четырёх</em> работ одновременно&nbsp;— иначе не&nbsp;успеть сделать как следует.
          </p>
          <p class="about-authors-p">
            Пишем руками. ИИ используем как инструмент на&nbsp;этапах поиска источников, фактчека и&nbsp;редактуры&nbsp;— но&nbsp;финальный текст всегда проходит через несколько этапов нашей ручной проверки. Научрук не&nbsp;отличит&nbsp;— проверено десятками защит.
          </p>
          <p class="about-authors-p">
            Все из&nbsp;постсоветских вузов&nbsp;— знают, как здесь пишутся курсовые. Не&nbsp;«академически общо», а&nbsp;под методичку <em class="it">вашей</em> кафедры, под конкретного руководителя. Под каждого научрука собираем профиль: что любит, на&nbsp;чём срезает.
          </p>
        </div>

        <ul class="about-authors-tiles rv" data-d="200" role="list">
          <li class="authors-tile">
            <span class="authors-mark" aria-hidden="true">§&nbsp;I</span>
            <h4 class="authors-tile-h">Ручное письмо</h4>
            <p class="authors-tile-p">ИИ&nbsp;— помощник, не&nbsp;автор. Финал всегда через руки.</p>
          </li>
          <li class="authors-tile">
            <span class="authors-mark" aria-hidden="true">§&nbsp;II</span>
            <h4 class="authors-tile-h">Профиль научрука</h4>
            <p class="authors-tile-p">Пишем не&nbsp;в&nbsp;пустоту&nbsp;— под конкретного руководителя и&nbsp;его требования.</p>
          </li>
          <li class="authors-tile">
            <span class="authors-mark" aria-hidden="true">§&nbsp;III</span>
            <h4 class="authors-tile-h">Одна работа — один автор</h4>
            <p class="authors-tile-p">Никаких конвейеров. Максимум три–четыре работы на&nbsp;автора в&nbsp;неделю.</p>
          </li>
        </ul>
      </div>
    </section>

    <!-- ============================================================
         IV · Архив-подарок
         ============================================================ -->
    <section class="about-archive about-section" aria-label="Архив">
      <div class="about-wrap">
        <header class="chapter-head rv" data-d="0">
          <div class="chapter-num">
            <span class="roman" aria-hidden="true">IV</span>
            <span class="chapter-label">Caput Quartum · Архив</span>
          </div>
          <div class="chapter-title-block">
            <h2 class="chapter-h">Архив — <em class="it">подарок</em>.</h2>
            <p class="chapter-lede">Не&nbsp;воронка, не&nbsp;тизер, не&nbsp;«зарегистрируйтесь для&nbsp;продолжения». Просто архив, из&nbsp;которого можно брать.</p>
          </div>
        </header>

        <div class="about-archive-split rv" data-d="100">
          <div class="split-prose">
            <p>
              Архив собран студентами, которые сами присылали свои защищённые работы. <b>{total}&nbsp;документов</b> бесплатно, без&nbsp;регистрации, без&nbsp;рекламы. Это не&nbsp;воронка продаж&nbsp;— это начало, которое мы&nbsp;никогда не&nbsp;закрыли.
            </p>
            <p>
              Скачивайте целиком, забирайте куски, ищите формулировки. Ваша тема, скорее всего, там уже есть. Если нет&nbsp;— <a href="/contribute" class="about-inline-link">поделитесь своей</a> после защиты, чтобы помочь следующим.
            </p>
          </div>

          <aside class="split-card">
            <div class="split-card-row">
              <span class="sc-lbl">Документов</span>
              <span class="sc-val">{total}</span>
            </div>
            <div class="split-card-row">
              <span class="sc-lbl">Категорий</span>
              <span class="sc-val">{categoriesCount}</span>
            </div>
            <div class="split-card-row">
              <span class="sc-lbl">Дисциплин</span>
              <span class="sc-val">{subjectsCount}+</span>
            </div>
            <div class="split-card-foot">
              <a href="/catalog" class="btn btn-gold btn-sm">Открыть каталог</a>
              <button type="button" class="btn btn-ghost-gold btn-sm" id="randomBtn">Случайная работа</button>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============================================================
         V · Pullquote — сердце
         ============================================================ -->
    <section class="about-pullquote" aria-label="Кредо">
      <div class="about-wrap about-pullquote-wrap">
        <span class="pq-rule" aria-hidden="true"></span>
        <blockquote class="about-pq rv" data-d="0">
          <p class="about-pq-line">
            Мы&nbsp;не&nbsp;корпорация.
          </p>
          <p class="about-pq-line about-pq-line--gold">
            Мы&nbsp;— те, кто сам через это прошёл.
          </p>
        </blockquote>
        <span class="pq-rule" aria-hidden="true"></span>
      </div>
    </section>

    <!-- ============================================================
         VI · Приватность — editorial details
         ============================================================ -->
    <section class="about-privacy about-section" id="privacy" aria-label="Приватность">
      <div class="about-wrap">
        <header class="chapter-head rv" data-d="0">
          <div class="chapter-num">
            <span class="roman" aria-hidden="true">V</span>
            <span class="chapter-label">Caput Quintum · Тишина</span>
          </div>
          <div class="chapter-title-block">
            <h2 class="chapter-h">Конфиденциальность и&nbsp;<em class="it">данные</em>.</h2>
            <p class="chapter-lede">Всё, что вы&nbsp;нам доверяете, остаётся между нами. По&nbsp;запросу&nbsp;— удаляем.</p>
          </div>
        </header>

        <div class="about-privacy-list rv" data-d="100">
          <details class="about-priv-item" open>
            <summary>
              <span class="p-no">01</span>
              <span class="p-q">Каталог</span>
              <span class="p-chev" aria-hidden="true">+</span>
            </summary>
            <div class="p-body">
              <p>Скачивание работ не&nbsp;требует регистрации. Фиксируем только обезличенную статистику просмотров и&nbsp;скачиваний&nbsp;— чтобы понимать, какие дисциплины востребованы.</p>
            </div>
          </details>

          <details class="about-priv-item">
            <summary>
              <span class="p-no">02</span>
              <span class="p-q">Заказ работы</span>
              <span class="p-chev" aria-hidden="true">+</span>
            </summary>
            <div class="p-body">
              <p>Сохраняем контакт (VK, Telegram, email или&nbsp;телефон), тему и&nbsp;прикреплённые файлы. Данные используются только для&nbsp;выполнения заказа, не&nbsp;передаются третьим лицам и&nbsp;удаляются по&nbsp;вашему запросу в&nbsp;любой момент.</p>
            </div>
          </details>

          <details class="about-priv-item">
            <summary>
              <span class="p-no">03</span>
              <span class="p-q">Загрузка в&nbsp;библиотеку</span>
              <span class="p-chev" aria-hidden="true">+</span>
            </summary>
            <div class="p-body">
              <p>Контакт отправителя виден только модератору и&nbsp;никогда не&nbsp;попадает в&nbsp;публичную карточку. Сам документ обезличивается перед публикацией: убираем ФИО, ВУЗ, научрука, группы.</p>
            </div>
          </details>

          <details class="about-priv-item">
            <summary>
              <span class="p-no">04</span>
              <span class="p-q">Аналитика</span>
              <span class="p-chev" aria-hidden="true">+</span>
            </summary>
            <div class="p-body">
              <p>Используем Яндекс.Метрику для&nbsp;анализа посещаемости. Данные обезличены, не&nbsp;связываются с&nbsp;вашим контактом и&nbsp;не&nbsp;передаются рекламным сетям.</p>
            </div>
          </details>

          <details class="about-priv-item">
            <summary>
              <span class="p-no">05</span>
              <span class="p-q">Cookies и&nbsp;localStorage</span>
              <span class="p-chev" aria-hidden="true">+</span>
            </summary>
            <div class="p-body">
              <p>Сайт использует <code>localStorage</code> для&nbsp;сохранения темы оформления и&nbsp;избранных документов. Никакие cookies не&nbsp;передаются третьим сторонам. Рекламных трекеров нет.</p>
            </div>
          </details>
        </div>

        <p class="about-privacy-contact rv" data-d="200">
          Вопросы по&nbsp;приватности или&nbsp;удалению данных&nbsp;— <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
        </p>
      </div>
    </section>

    <!-- ============================================================
         Epilogue — сжатый CTA
         ============================================================ -->
    <section class="about-epilogue" aria-label="Начать">
      <div class="about-wrap about-epilogue-wrap">
        <p class="about-epi-glyph" aria-hidden="true">⁘</p>
        <h2 class="about-epi-h rv" data-d="0">Готовы <em class="it">начать</em>?</h2>
        <p class="about-epi-sub rv" data-d="100">Архив&nbsp;— без&nbsp;условий. Заказ&nbsp;— после разговора.</p>
        <div class="about-epi-actions rv" data-d="200">
          <a href="/catalog" class="btn btn-ghost-gold btn-lg">Открыть архив</a>
          <a href="/order" class="btn btn-gold btn-lg">Заказать работу</a>
        </div>
      </div>
    </section>

  </article>

  <script is:inline define:vars={{ fallbackFiles }}>
    window.__randomFiles = fallbackFiles;
  </script>

</Base>

<style>
  /* Global editorial footer (Phase 2) is intentionally visible on /about */

  .pg {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ═══════ REVEAL ═══════ */
  .rv {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity .5s var(--ease), transform .5s var(--ease);
  }
  .rv.vis { opacity: 1; transform: translateY(0); }

  /* ═══════ HAIRLINE ═══════ */
  .hr {
    width: 60px;
    height: 1px;
    margin: 24px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
  }
  .hr.vis {
    opacity: .15;
    transform: scaleX(1);
    transition: opacity .8s var(--ease), transform .8s var(--ease);
  }

  /* ═══════ GLOW ═══════ */
  .glow {
    position: absolute;
    width: 600px; height: 500px;
    left: 50%;
    pointer-events: none;
    animation: gl 10s ease-in-out infinite;
  }
  .opening > .glow {
    top: 25%;
    transform: translate(-50%,-50%);
    background: radial-gradient(circle, rgba(200,165,40,.09) 0%, transparent 60%);
  }
  .glow--bot {
    bottom: -100px;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(200,165,40,.07) 0%, transparent 60%);
  }
  @keyframes gl {
    0%, 100% { opacity: .5; }
    50% { opacity: .9; }
  }

  /* ═══════ OPENING ═══════ */
  .opening {
    position: relative;
    text-align: center;
    padding: 100px 0 80px;
    overflow: hidden;
  }
  .opening-t {
    position: relative;
    font: 300 clamp(36px, 7vw, 64px)/.92 var(--fd);
    color: var(--t1);
    letter-spacing: -.02em;
    text-wrap: balance;
  }
  .opening-sub {
    position: relative;
    margin-top: 24px;
    font: 400 14px/1.6 var(--fi);
    color: var(--t2);
  }

  /* Scroll indicator */
  .scroll-hint {
    margin-top: 48px;
    color: var(--t3);
    animation: scroll-bob 2s var(--ease) infinite;
  }
  @keyframes scroll-bob {
    0%, 100% { transform: translateY(0); opacity: .4; }
    50% { transform: translateY(6px); opacity: .8; }
  }

  /* ═══════ TIMELINE ═══════ */
  .tl {
    padding: 64px 0 48px;
  }
  .tl-track {
    position: relative;
    margin-top: 48px;
  }
  .tl-line {
    position: absolute;
    left: 50%;
    top: 0; bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, transparent, var(--ac-b2) 10%, var(--ac-b2) 90%, transparent);
    transform: translateX(-50%);
  }
  .tl-item {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 24px;
    padding-bottom: 48px;
    width: 50%;
  }
  .tl-item--l {
    margin-right: auto;
