---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';
const total = D.length;
const subjectsCount = new Set(D.map((d: any) => d.subject).filter(Boolean)).size;
const fallbackFiles = D.map((d: any) => d.file).filter(Boolean);
---

<Base
  title="О салоне — Академический Салон"
  description="Академический Салон — мастерская и архив студенческих работ с 2020 года. 235+ работ бесплатно, авторский заказ под защиту."
  currentPath="/about"
>

  <!--
    /about — афиша-манифест.
    Один экран, центрировано. Никакого скролла, никаких табов.
    Задача — вызвать доверие и желание остаться, за 5 секунд чтения.
  -->
  <section class="about-poster" aria-label="О салоне">
    <div class="poster-grain" aria-hidden="true"></div>
    <div class="poster-corner poster-corner--tl" aria-hidden="true"></div>
    <div class="poster-corner poster-corner--tr" aria-hidden="true"></div>
    <div class="poster-corner poster-corner--bl" aria-hidden="true"></div>
    <div class="poster-corner poster-corner--br" aria-hidden="true"></div>

    <div class="poster-inner">

      <header class="poster-eyebrow" aria-hidden="true">
        <span class="mark">АС</span>
        <span class="title">Academicus Salo</span>
        <span class="est">MMXX</span>
      </header>

      <blockquote class="poster-manifest">
        <p class="line">Мы&nbsp;не&nbsp;корпорация.</p>
        <p class="line line--gold">Мы&nbsp;— те, кто сам через это прошёл.</p>
      </blockquote>

      <p class="poster-sub">
        Мастерская и&nbsp;свободный архив студенческих работ. С&nbsp;2020&nbsp;года&nbsp;— тихо, без&nbsp;офиса и&nbsp;колл-центра.
      </p>

      <div class="poster-rule" aria-hidden="true">
        <span class="seg"></span>
        <span class="dot"></span>
        <span class="seg"></span>
      </div>

      <dl class="poster-facts">
        <div>
          <dt>Работ</dt>
          <dd><span class="num">{total}</span><span class="plus">+</span></dd>
        </div>
        <div>
          <dt>Дисциплин</dt>
          <dd><span class="num">{subjectsCount}</span><span class="plus">+</span></dd>
        </div>
        <div>
          <dt>С&nbsp;года</dt>
          <dd><span class="num">2020</span></dd>
        </div>
        <div>
          <dt>Доступ</dt>
          <dd><i class="it">бесплатный</i></dd>
        </div>
      </dl>

      <div class="poster-actions">
        <a href="/catalog" class="btn btn-ghost-gold btn-lg">Открыть архив</a>
        <a href="/order" class="btn btn-gold btn-lg">Заказать работу</a>
      </div>

      <footer class="poster-footer">
        <button type="button" class="ft-link ft-link--btn" id="randomBtn" aria-label="Открыть случайную работу">случайная работа</button>
        <span class="ft-sep" aria-hidden="true">·</span>
        <a class="ft-link" href="/contribute">поделиться своей</a>
        <span class="ft-sep" aria-hidden="true">·</span>
        <a class="ft-link" href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
      </footer>

    </div>
  </section>

  <script is:inline define:vars={{ fallbackFiles }}>
    window.__randomFiles = fallbackFiles;
  </script>

</Base>

<style is:global>
  /* ════════════════════════════════════════════════════════════════
     /about — афиша-манифест, один экран
     Высота ровно 100svh за вычетом nav, центрировано, без скролла.
     Dark Couture: obsidian + gold hairlines + Cormorant Garamond.
     ════════════════════════════════════════════════════════════════ */
  .about-poster {
    position: relative;
    min-height: calc(100svh - var(--nav-h));
    display: grid;
    place-items: center;
    padding: clamp(40px, 6vw, 72px) clamp(20px, 4vw, 64px);
    background: radial-gradient(
      ellipse 80% 60% at 50% 45%,
      var(--ink) 0%,
      var(--void) 85%
    );
    overflow: hidden;
    isolation: isolate;
  }

  /* Едва заметная бумажная зернистость */
  .poster-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='260' height='260'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.88 0 0 0 0 0.78 0 0 0 0 0.42 0 0 0 0.35 0'/></filter><rect width='260' height='260' filter='url(%23n)' opacity='0.35'/></svg>");
  }

  /* Четыре уголковых «засечки» рамки постера */
  .poster-corner {
    position: absolute;
    width: 36px;
    height: 36px;
    border-color: var(--gold-line);
    border-style: solid;
    border-width: 0;
    z-index: 1;
    pointer-events: none;
  }
  .poster-corner--tl {
    top: clamp(24px, 4vw, 48px);
    left: clamp(24px, 4vw, 48px);
    border-top-width: 1px;
    border-left-width: 1px;
  }
  .poster-corner--tr {
    top: clamp(24px, 4vw, 48px);
    right: clamp(24px, 4vw, 48px);
    border-top-width: 1px;
    border-right-width: 1px;
  }
  .poster-corner--bl {
    bottom: clamp(24px, 4vw, 48px);
    left: clamp(24px, 4vw, 48px);
    border-bottom-width: 1px;
    border-left-width: 1px;
  }
  .poster-corner--br {
    bottom: clamp(24px, 4vw, 48px);
    right: clamp(24px, 4vw, 48px);
    border-bottom-width: 1px;
    border-right-width: 1px;
  }

  .poster-inner {
    position: relative;
    z-index: 2;
    max-width: 820px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(20px, 3vw, 32px);
    text-align: center;
  }

  /* Eyebrow: монограмма · латинское имя · MMXX */
  .poster-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    color: var(--gold-ref);
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }
  .poster-eyebrow .mark {
    font-family: var(--fd);
    font-style: italic;
    font-size: 20px;
    letter-spacing: -0.02em;
    text-transform: none;
    line-height: 1;
    color: var(--gold-ref);
  }
  .poster-eyebrow .title {
    border-left: 1px solid var(--gold-line);
    border-right: 1px solid var(--gold-line);
    padding: 0 14px;
  }
  .poster-eyebrow .est { font-feature-settings: "tnum"; }

  /* Манифест-заявление */
  .poster-manifest {
    margin: 0;
    padding: 0;
    font-family: var(--fd);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.035em;
    color: var(--cream);
    max-width: 18ch;
  }
  .poster-manifest .line {
    font-size: clamp(40px, 7vw, 92px);
    margin: 0;
  }
  .poster-manifest .line--gold {
    font-style: italic;
    color: var(--gold-ref);
    margin-top: clamp(6px, 1vw, 12px);
  }

  /* Подпись */
  .poster-sub {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(16px, 1.6vw, 20px);
    line-height: 1.5;
    color: var(--cream-2);
    max-width: 54ch;
    margin: 0;
  }

  /* Декоративная линия с точкой */
  .poster-rule {
    display: flex;
    align-items: center;
    gap: 12px;
    width: min(360px, 70%);
  }
  .poster-rule .seg {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-ref));
    opacity: 0.7;
  }
  .poster-rule .seg:last-child {
    background: linear-gradient(90deg, var(--gold-ref), transparent);
  }
  .poster-rule .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold-ref);
    box-shadow: 0 0 8px var(--gold-glow);
    flex-shrink: 0;
  }

  /* Факты в одну строку */
  .poster-facts {
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(20px, 4vw, 48px);
  }
  .poster-facts > div {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    min-width: 0;
  }
  .poster-facts dt {
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .poster-facts dd {
    font-family: var(--fd);
    font-size: clamp(22px, 2.8vw, 32px);
    color: var(--cream);
    margin: 0;
    line-height: 1;
    font-feature-settings: "tnum", "onum";
    display: inline-flex;
    align-items: baseline;
    gap: 2px;
  }
  .poster-facts dd .plus {
    font-family: var(--fd);
    font-style: italic;
    font-size: 0.6em;
    color: var(--gold-ref);
  }
  .poster-facts dd .it {
    font-style: italic;
    color: var(--gold-ref);
    font-size: clamp(18px, 2.2vw, 24px);
  }

  /* CTA — две кнопки */
  .poster-actions {
    margin-top: clamp(4px, 1vw, 12px);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  /* Мелкие ссылки внизу — без давления */
  .poster-footer {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 10px 14px;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .poster-footer .ft-link {
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--mute);
    font: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
    text-decoration: none;
    cursor: pointer;
    transition: color .4s var(--ease-silk);
  }
  .poster-footer .ft-link:hover { color: var(--gold-ref); }
  .poster-footer .ft-sep { opacity: 0.5; }

  /* ── Mobile (≤640px) ── */
  @media (max-width: 640px) {
    .about-poster {
      min-height: calc(100svh - var(--nav-h));
      padding: 32px 20px;
    }
    .poster-inner { gap: 18px; }
    .poster-manifest .line { font-size: clamp(32px, 10vw, 56px); }
    .poster-facts { gap: 18px 24px; }
    .poster-corner { display: none; }
  }

  /* Высокие экраны — чуть больше воздуха */
  @media (min-height: 900px) and (min-width: 900px) {
    .poster-inner { gap: 36px; }
    .poster-manifest .line { font-size: clamp(56px, 7vw, 104px); }
  }
</style>

<script is:inline>
  /* Кнопка «случайная работа» — переход в /doc/<random> */
  (function () {
    function bind() {
      var btn = document.getElementById('randomBtn');
      if (!btn || btn.dataset.bound) return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', function () {
        var files = window.__randomFiles || [];
        if (!files.length) return;
        var file = files[Math.floor(Math.random() * files.length)];
        window.location.href = '/doc/' + file;
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bind);
    } else {
      bind();
    }
    document.addEventListener('astro:page-load', bind);
  })();
</script>
