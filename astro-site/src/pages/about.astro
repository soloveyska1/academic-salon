---
import Base from '../layouts/Base.astro';
import { D } from '../data/catalog.js';
const total = D.length;
const subjects = new Set(D.map((d: any) => d.subject).filter(Boolean)).size;
const slugs = D.map((d: any) => d.file);
---

<Base title="О нас — Библиотека академического салона" description="Как студенческий телеграм-канал вырос в библиотеку из 235+ работ по психологии и социальной работе. Бесплатный каталог и индивидуальные заказы." currentPath="/about">

  <article class="pg">

    <!-- Opening -->
    <header class="opening">
      <div class="glow" aria-hidden="true"></div>
      <h1 class="opening-t rv" data-d="0">Библиотека академического салона</h1>
      <div class="hr rv" data-d="200" aria-hidden="true"></div>
      <p class="opening-sub rv" data-d="400">Бесплатная библиотека студенческих работ и сервис индивидуального выполнения</p>
    </header>

    <!-- Story -->
    <section class="story">
      <p class="prose prose--dc rv" data-d="0">Всё началось с телеграм-канала «Кладовая» — студенты одного петербургского вуза делились работами, чтобы помочь друг другу. Канал вырос до сотен документов по психологии, социальной работе и конфликтологии.</p>
      <p class="prose rv" data-d="150">Когда Telegram стал работать нестабильно, мы перенесли библиотеку в веб. Так появилась Библиотека академического салона — место, где можно найти готовую работу или заказать новую.</p>
    </section>

    <!-- Pullquote -->
    <blockquote class="pq rv" data-d="0">
      <span class="pq-line" aria-hidden="true"></span>
      <em>Мы не корпорация. Мы — те, кто сам через это прошёл.</em>
      <span class="pq-line" aria-hidden="true"></span>
    </blockquote>

    <!-- Numbers -->
    <section class="nums">
      <div class="nums-row">
        <div class="num">
          <span class="num-v" data-to={total}>0</span>
          <span class="num-l">работ</span>
        </div>
        <span class="num-div" aria-hidden="true"></span>
        <div class="num">
          <span class="num-v" data-to={subjects}>0</span>
          <span class="num-l">предметов</span>
        </div>
        <span class="num-div" aria-hidden="true"></span>
        <div class="num">
          <span class="num-v" data-to={3}>0</span>
          <span class="num-l">направления</span>
        </div>
      </div>
    </section>

    <!-- What you get -->
    <section class="what">
      <h2 class="sec-t rv" data-d="0">Что вы получаете</h2>
      <div class="what-item rv" data-d="100">
        <b>Бесплатный доступ</b>
        <p>Вся библиотека открыта, без регистрации и SMS.</p>
      </div>
      <div class="what-item rv" data-d="200">
        <b>Индивидуальный подход</b>
        <p>Каждая работа на заказ пишется под ваши требования.</p>
      </div>
      <div class="what-item rv" data-d="300">
        <b>Антиплагиат</b>
        <p>Гарантируем заявленный процент оригинальности.</p>
      </div>
      <div class="what-item rv" data-d="400">
        <b>Бесплатные правки</b>
        <p>Дорабатываем до полного соответствия.</p>
      </div>
    </section>

    <!-- Random document -->
    <div class="random rv" data-d="0">
      <button class="random-btn" id="randomBtn">Открыть случайную работу</button>
      <p class="random-hint">{total} документов в каталоге — попробуйте наудачу</p>
    </div>

    <!-- FAQ -->
    <section class="faq" id="faq">
      <h2 class="sec-t rv" data-d="0">Частые вопросы</h2>
      <details class="fq"><summary>Это бесплатно? В чём подвох?<span class="fq-x">+</span></summary><div class="fq-a"><p>Каталог полностью бесплатный. Подвоха нет — мы собираем работы, которые уже были сданы. Заказ индивидуальных работ — платная услуга, она поддерживает проект.</p></div></details>
      <details class="fq"><summary>Можно сдать работу из каталога?<span class="fq-x">+</span></summary><div class="fq-a"><p>Как образец — да. Для уникальной — закажите индивидуально.</p></div></details>
      <details class="fq"><summary>Какие гарантии?<span class="fq-x">+</span></summary><div class="fq-a"><p>Антиплагиат, выполнение в срок, бесплатные правки до принятия преподавателем.</p></div></details>
      <details class="fq"><summary>Сколько стоит?<span class="fq-x">+</span></summary><div class="fq-a"><p>Контрольная от 2 500 ₽, реферат от 3 000 ₽, курсовая от 5 000 ₽, дипломная от 30 000 ₽. Точную цену — после обсуждения.</p></div></details>
      <details class="fq"><summary>Как быстро?<span class="fq-x">+</span></summary><div class="fq-a"><p>Стандарт — 2 недели. Срочно: 3 дня или 1 день.</p></div></details>
      <details class="fq"><summary>Какая уникальность?<span class="fq-x">+</span></summary><div class="fq-a"><p>Вы выбираете: 60%, 70%, 80% или 90%. Проверка в Антиплагиат. Гарантируем не ниже заявленного.</p></div></details>
    </section>

    <!-- Team -->
    <section class="what">
      <h2 class="sec-t rv" data-d="0">Кто за этим стоит</h2>
      <div class="what-item rv" data-d="100">
        <b>Основатель</b>
        <p>Выпускник петербургского вуза, создал «Кладовую» на 3 курсе. Координирует весь проект.</p>
      </div>
      <div class="what-item rv" data-d="200">
        <b>Авторы</b>
        <p>Преподаватели и аспиранты гуманитарных направлений. Пишут работы по психологии, социальной работе и конфликтологии.</p>
      </div>
      <div class="what-item rv" data-d="300">
        <b>Поддержка</b>
        <p>Отвечаем в VK и Telegram. Обычно — в течение часа, часто быстрее.</p>
      </div>
    </section>

    <!-- Privacy -->
    <section class="faq" id="privacy">
      <h2 class="sec-t rv" data-d="0">Конфиденциальность</h2>
      <details class="fq"><summary>Каталог<span class="fq-x">+</span></summary><div class="fq-a"><p>Скачивание работ не требует регистрации. Мы фиксируем только обезличенную статистику просмотров и скачиваний.</p></div></details>
      <details class="fq"><summary>Заказ работы<span class="fq-x">+</span></summary><div class="fq-a"><p>Мы сохраняем контакт (VK, Telegram или телефон), тему и прикреплённые файлы. Данные используются только для выполнения заказа и удаляются по запросу.</p></div></details>
      <details class="fq"><summary>Загрузка в библиотеку<span class="fq-x">+</span></summary><div class="fq-a"><p>Контакт отправителя виден только модератору. Публикуется только документ — без привязки к автору.</p></div></details>
      <details class="fq"><summary>Аналитика<span class="fq-x">+</span></summary><div class="fq-a"><p>Мы используем Яндекс.Метрику для анализа посещаемости. Данные обезличены.</p></div></details>
      <details class="fq"><summary>Cookies и localStorage<span class="fq-x">+</span></summary><div class="fq-a"><p>Сайт использует localStorage для сохранения темы и избранных документов. Никакие cookie не передаются третьим сторонам.</p></div></details>
      <p class="privacy-contact rv" data-d="0">Вопросы: <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a></p>
    </section>

    <!-- Closing -->
    <section class="end">
      <div class="glow glow--bot" aria-hidden="true"></div>
      <div class="hr rv" data-d="0" aria-hidden="true"></div>
      <p class="end-t rv" data-d="200">Готовы начать?</p>
      <div class="end-btns rv" data-d="400">
        <a href="/catalog" class="end-btn">Каталог</a>
        <a href="/order" class="end-btn">Заказать работу</a>
      </div>
      <p class="end-links rv" data-d="600">
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a> ·
        <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">VK</a> ·
        <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
      </p>
      <p class="end-copy rv" data-d="700">© 2022–2026 Библиотека академического салона</p>
    </section>

  </article>

  <script is:inline define:vars={{ slugs }}>
    window.__slugs = slugs;
    /* Bind random button immediately */
    var _rb = document.getElementById('randomBtn');
    if (_rb) {
      _rb.onclick = function() {
        var s = window.__slugs;
        if (s && s.length) window.location.href = '/doc/' + s[Math.floor(Math.random() * s.length)];
      };
    }
  </script>

</Base>

<style>
  :global(.footer) { display: none; }

  .pg {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ═══════ REVEAL ═══════ */
  .rv {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity .5s cubic-bezier(.25,0,0,1), transform .5s cubic-bezier(.25,0,0,1);
  }

  .rv.vis { opacity: 1; transform: translateY(0); }

  /* ═══════ HAIRLINE ═══════ */
  .hr {
    width: 60px;
    height: 1px;
    margin: 20px auto 0;
    background: var(--ac);
    opacity: 0;
    transform: scaleX(0);
  }

  .hr.vis {
    opacity: .15;
    transform: scaleX(1);
    transition: opacity .8s cubic-bezier(.25,0,0,1), transform .8s cubic-bezier(.25,0,0,1);
  }

  /* ═══════ GLOW ═══════ */
  .glow {
    position: absolute;
    width: 600px; height: 500px;
    left: 50%;
    pointer-events: none;
    animation: gl 10s ease-in-out infinite;
  }

  .opening > .glow {
    top: 25%;
    transform: translate(-50%,-50%);
    background: radial-gradient(circle, rgba(200,165,40,.09) 0%, transparent 60%);
  }

  .glow--bot {
    bottom: -100px;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(200,165,40,.07) 0%, transparent 60%);
  }

  @keyframes gl {
    0%, 100% { opacity: .5; }
    50% { opacity: .9; }
  }

  /* ═══════ OPENING ═══════ */
  .opening {
    position: relative;
    text-align: center;
    padding: 100px 0 80px;
    overflow: hidden;
  }

  .opening-t {
    position: relative;
    font: 300 clamp(36px, 7vw, 52px)/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
  }

  .opening-sub {
    position: relative;
    margin-top: 20px;
    font: 400 14px/1.6 var(--fi);
    color: var(--t2);
  }

  /* ═══════ STORY ═══════ */
  .story {
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding-bottom: 8px;
  }

  .prose {
    font: 400 19px/1.85 var(--fd);
    color: var(--t2);
    letter-spacing: .01em;
  }

  .prose--dc::first-letter {
    float: left;
    font: 400 72px/.75 var(--fd);
    color: var(--ac-b3);
    padding-right: 12px;
    margin-top: 4px;
  }

  /* ═══════ PULLQUOTE ═══════ */
  .pq {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 56px 0;
    margin: 0;
  }

  .pq em {
    font: 400 italic clamp(22px, 4.5vw, 30px)/1.3 var(--fd);
    color: var(--t2);
    text-align: center;
    flex-shrink: 0;
  }

  .pq-line {
    flex: 1;
    height: 1px;
    background: var(--surf-h);
  }

  /* ═══════ NUMBERS ═══════ */
  .nums {
    padding: 48px 0;
    border-top: 1px solid var(--brd);
    border-bottom: 1px solid var(--brd);
  }

  .nums-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 40px;
  }

  .num { text-align: center; }

  .num-v {
    display: block;
    font: 300 clamp(36px, 7vw, 52px)/1 var(--fm);
    color: var(--ac);
    font-variant-numeric: tabular-nums;
  }

  .num-l {
    display: block;
    margin-top: 8px;
    font: 400 10px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--t3);
  }

  .num-div {
    width: 1px;
    height: 32px;
    background: var(--brd);
    flex-shrink: 0;
  }

  /* ═══════ WHAT YOU GET ═══════ */
  .what {
    padding: 64px 0 48px;
  }

  .sec-t {
    font: 300 28px/1 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    text-align: center;
    margin-bottom: 40px;
  }

  .what-item {
    padding: 20px 0 20px 24px;
    border-left: 2px solid var(--ac-line);
    margin-bottom: 20px;
    transition: border-color .5s cubic-bezier(.25,0,0,1);
  }

  .what-item:last-child { margin-bottom: 0; }
  .what-item:hover { border-left-color: var(--ac-b3); }

  .what-item b {
    display: block;
    font: 500 15px/1.3 var(--fi);
    color: var(--t1);
  }

  .what-item p {
    margin-top: 6px;
    font: 400 14px/1.6 var(--fi);
    color: var(--t3);
  }

  /* ═══════ RANDOM ═══════ */
  .random {
    text-align: center;
    padding: 32px 0 48px;
    border-bottom: 1px solid var(--brd);
  }

  .random-btn {
    background: none;
    border: 1px solid var(--ac-b);
    padding: 16px 44px;
    font: 300 italic 15px/1 var(--fd);
    color: var(--t2);
    cursor: pointer;
    transition: background .5s cubic-bezier(.25,0,0,1), border-color .5s cubic-bezier(.25,0,0,1), color .5s cubic-bezier(.25,0,0,1);
  }

  .random-btn:hover {
    background: var(--surf);
    border-color: var(--ac-b2);
    color: var(--t1);
  }

  .random-hint {
    margin-top: 12px;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
  }

  /* ═══════ FAQ ═══════ */
  .faq {
    padding: 64px 0 48px;
  }

  .fq { border-bottom: 1px solid var(--brd); }

  .fq summary {
    display: flex; justify-content: space-between; align-items: center; gap: 16px;
    padding: 20px 0; font: 500 15px/1.4 var(--fi); color: var(--t1);
    cursor: pointer; list-style: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }

  .fq summary::-webkit-details-marker { display: none; }
  .fq summary::marker { display: none; content: ''; }
  .fq summary:hover { color: var(--ac); }

  .fq-x {
    font: 300 22px/1 var(--fd); color: var(--ac); opacity: .25; flex-shrink: 0;
    transition: transform .4s cubic-bezier(.25,0,0,1), opacity .4s cubic-bezier(.25,0,0,1);
  }

  .fq summary:hover .fq-x { opacity: .5; }
  .fq[open] .fq-x { transform: rotate(45deg); }

  .fq-a { padding: 0 0 20px; }
  .fq-a p { font: 400 14px/1.7 var(--fi); color: var(--t2); }

  /* ═══════ CLOSING ═══════ */
  .end {
    position: relative;
    text-align: center;
    padding: 80px 0;
    overflow: hidden;
  }

  .end .hr { margin-bottom: 32px; }

  .end-t { position: relative; font: 300 32px/1.2 var(--fd); color: var(--t1); }

  .end-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-top: 32px; }

  .end-btn {
    padding: 16px 44px; border: 1px solid var(--ac-b);
    font: 300 italic 14px/1 var(--fd); color: var(--t2);
    text-decoration: none; position: relative;
    transition: background .5s cubic-bezier(.25,0,0,1), border-color .5s cubic-bezier(.25,0,0,1), color .5s cubic-bezier(.25,0,0,1);
  }

  .end-btn:hover { background: var(--surf); border-color: var(--ac-b2); color: var(--t1); }

  .end-links {
    margin-top: 40px; font: 400 11px/1 var(--fi);
    text-transform: uppercase; letter-spacing: .1em; color: var(--t3);
  }

  .end-links a { color: inherit; text-decoration: none; transition: color .4s cubic-bezier(.25,0,0,1); }
  .end-links a:hover { color: var(--t2); }

  .end-copy { margin-top: 48px; font: 400 10px/1 var(--fm); color: var(--t3); letter-spacing: .1em; }

  .privacy-contact {
    margin-top: 20px;
    font: 400 12px/1 var(--fi);
    color: var(--t3);
  }
  .privacy-contact a {
    color: var(--t2);
    text-decoration: none;
    transition: color .4s cubic-bezier(.25,0,0,1);
  }
  .privacy-contact a:hover { color: var(--ac); }

  /* ═══════ MOBILE ═══════ */
  @media (max-width: 640px) {
    .pg { padding: 0 20px; }
    .opening { padding: 80px 0 56px; }
    .nums-row { gap: 24px; }
    .num-div { display: none; }
    .end-btns { flex-direction: column; align-items: center; }
  }

  /* ═══════ LIGHT THEME ═══════ */
  :global([data-theme="light"]) .opening > .glow {
    background: radial-gradient(circle, rgba(122,95,18,.04) 0%, transparent 60%);
  }
  :global([data-theme="light"]) .glow--bot {
    background: radial-gradient(circle, rgba(122,95,18,.03) 0%, transparent 60%);
  }
  :global([data-theme="light"]) .pq-line {
    background: rgba(26,24,20,.06);
  }

  /* ═══════ REDUCED MOTION ═══════ */
  @media (prefers-reduced-motion: reduce) {
    .rv { opacity: 1; transform: none; transition: none; }
    .hr { opacity: .15; transform: scaleX(1); transition: none; }
    .glow { animation: none; }
    .what-item, .fq-x, .fq summary, .end-btn, .end-links a, .random-btn { transition: none; }
  }
</style>

<script is:inline>
(function() {
  var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  var items = document.querySelectorAll('.rv');
  if (reduced) {
    items.forEach(function(el) { el.classList.add('vis'); });
  } else {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (!e.isIntersecting) return;
        var d = parseInt(e.target.getAttribute('data-d') || '0');
        setTimeout(function() { e.target.classList.add('vis'); }, d);
        obs.unobserve(e.target);
      });
    }, { threshold: .2, rootMargin: '0px 0px -30px 0px' });
    items.forEach(function(el) { obs.observe(el); });
  }

  var nums = document.querySelectorAll('[data-to]');
  var numObs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (!e.isIntersecting) return;
      numObs.unobserve(e.target);
      var target = parseInt(e.target.dataset.to || '0');
      var start = performance.now();
      function tick(now) {
        var t = Math.min((now - start) / 1500, 1);
        var ease = 1 - Math.pow(1 - t, 3);
        e.target.textContent = String(Math.round(ease * target));
        if (t < 1) requestAnimationFrame(tick);
        else e.target.textContent = target + (target > 10 ? '+' : '');
      }
      requestAnimationFrame(tick);
    });
  }, { threshold: .3 });
  nums.forEach(function(el) { numObs.observe(el); });

  var btn = document.getElementById('randomBtn');
  if (btn && window.__slugs && window.__slugs.length) {
    btn.addEventListener('click', function() {
      var s = window.__slugs;
      window.location.href = '/doc/' + s[Math.floor(Math.random() * s.length)];
    });
  }
})();
</script>

<!-- ═══════ GSAP About Animations ═══════ -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { SplitText } from 'gsap/SplitText';
  import { ScrambleTextPlugin } from 'gsap/ScrambleTextPlugin';

  gsap.registerPlugin(ScrollTrigger, SplitText, ScrambleTextPlugin);

  function initAboutGSAP() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    ScrollTrigger.getAll().forEach(st => st.kill());

    // Opening title — kinetic chars
    const openingT = document.querySelector('.opening-t');
    if (openingT) {
      (openingT as HTMLElement).style.opacity = '1';
      (openingT as HTMLElement).style.transform = 'none';
      const split = new SplitText(openingT, { type: 'chars', charsClass: 'gsap-char' });
      gsap.from(split.chars, {
        opacity: 0, y: 30, rotateX: -45,
        stagger: 0.02, duration: 0.8, ease: 'power3.out', delay: 0.3,
      });
    }

    // Pullquote — lines draw in, text fades
    const pq = document.querySelector('.pq');
    if (pq) {
      const lines = pq.querySelectorAll('.pq-line');
      const em = pq.querySelector('em');
      (pq as HTMLElement).style.opacity = '1';
      (pq as HTMLElement).style.transform = 'none';

      gsap.from(lines, {
        scaleX: 0, duration: 0.8, ease: 'power3.inOut',
        scrollTrigger: { trigger: pq, start: 'top 80%', once: true },
      });
      if (em) {
        gsap.from(em, {
          opacity: 0, y: 12, duration: 0.7, delay: 0.3, ease: 'power2.out',
          scrollTrigger: { trigger: pq, start: 'top 80%', once: true },
        });
      }
    }

    // Numbers — ScrambleText
    document.querySelectorAll('.num-v[data-to]').forEach(el => {
      const target = el.getAttribute('data-to') || '0';
      const suffix = parseInt(target) > 10 ? '+' : '';
      gsap.to(el, {
        scrambleText: { text: target + suffix, chars: '0123456789', speed: 0.4 },
        duration: 1.5, ease: 'power2.inOut',
        scrollTrigger: { trigger: el, start: 'top 90%', once: true },
      });
    });

    // What-items — stagger from left
    const whatItems = document.querySelectorAll('.what-item');
    if (whatItems.length) {
      whatItems.forEach(item => {
        (item as HTMLElement).style.opacity = '1';
        (item as HTMLElement).style.transform = 'none';
      });
      gsap.from(whatItems, {
        opacity: 0, x: -20, stagger: 0.1,
        duration: 0.6, ease: 'power3.out',
        scrollTrigger: { trigger: '.what', start: 'top 75%', once: true },
      });
    }

    // FAQ — cascade
    const fqs = document.querySelectorAll('.fq');
    if (fqs.length) {
      gsap.from(fqs, {
        opacity: 0, y: 12, stagger: 0.06,
        duration: 0.5, ease: 'power2.out',
        scrollTrigger: { trigger: '.faq', start: 'top 80%', once: true },
      });
    }

    // Closing
    const endT = document.querySelector('.end-t');
    if (endT) {
      (endT as HTMLElement).style.opacity = '1';
      (endT as HTMLElement).style.transform = 'none';
      const split = new SplitText(endT, { type: 'words', wordsClass: 'gsap-word' });
      gsap.from(split.words, {
        opacity: 0, y: 16, stagger: 0.05,
        duration: 0.6, ease: 'power3.out',
        scrollTrigger: { trigger: endT, start: 'top 85%', once: true },
      });
    }

    ScrollTrigger.refresh();
  }

  document.addEventListener('astro:page-load', initAboutGSAP);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAboutGSAP);
  } else {
    initAboutGSAP();
  }
</script>
