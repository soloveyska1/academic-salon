---
/**
 * Главная форма «По рассказам».
 * 9 вопросов + контактные данные + согласия.
 * POST → /api/may9/voice (контракт от Codex).
 *
 * JSON-схема ровно по контракту:
 * { name, email, telegram, relation, heroName, years, place,
 *   answers: { q1..q9 }, publishConsent, pdConsent, contactConsent,
 *   source: "may9_voice", honeypot }
 */

const questions = [
  {
    n: 1,
    label: 'Имя и как звали дома',
    hint: 'Полное имя, если знаете. И обращение в семье — «бабушка Шура», «дядя Миша», «дед Коля».',
    placeholder: 'Например: Анна Григорьевна Соколова, дома — баба Аня',
    rows: 2,
  },
  {
    n: 2,
    label: 'Годы и место',
    hint: 'Годы жизни и где провёл(а) большую часть. Если переезжали — куда и почему.',
    placeholder: 'Например: 1918–1996. Родилась в Курске, в войну была в эвакуации в Саратове, после сорок седьмого вернулась.',
    rows: 2,
  },
  {
    n: 3,
    label: 'Что делал(а) в военные или послевоенные годы',
    hint: 'Фронт, тыл, эвакуация, госпиталь, завод, поле, школа. Что угодно. «Пекла хлеб», «носила воду» — это уже история.',
    placeholder: 'Например: с 14 лет работала на ткацкой фабрике, шили шинели для фронта.',
    rows: 3,
  },
  {
    n: 4,
    label: 'Эпизод, который пересказывали в семье',
    hint: 'Та история, которую слышали несколько раз. Не нужна точность — важна интонация рассказчика.',
    placeholder: 'Например: рассказывала, как в 43-м поменяла материны серьги на полбуханки хлеба. Плакала, что серьги были ещё бабушкины.',
    rows: 4,
  },
  {
    n: 5,
    label: 'Запах, голос или привычка',
    hint: 'То, чего нет в энциклопедии. По чему вы помните этого человека.',
    placeholder: 'Например: вполголоса пела «На сопках Маньчжурии», когда варила варенье. Всегда собирала хлебные крошки в ладонь.',
    rows: 3,
  },
  {
    n: 6,
    label: 'Что знаете точно, а что — со слов',
    hint: 'Разделите, если можете: документ или фото; рассказали родители; сам(а) догадываюсь.',
    placeholder: 'Например: дату рождения знаю по паспорту. Что работала на фабрике — со слов тёти. Что плакала в 43-м — моя догадка.',
    rows: 3,
  },
  {
    n: 7,
    label: 'Что сохранилось — письмо, медаль, фото, запись',
    hint: 'Если есть — опишите одной строкой. Если нет — напишите «не сохранилось».',
    placeholder: 'Например: сохранилась фотография 1947 года и медаль «За доблестный труд».',
    rows: 2,
  },
  {
    n: 8,
    label: 'Что хотите, чтобы знали об этом человеке через 50 лет',
    hint: 'Одна фраза. Та, ради которой вы это записываете.',
    placeholder: 'Например: что прожила тяжёлую жизнь и не озлобилась.',
    rows: 2,
  },
  {
    n: 9,
    label: 'Как вас зовут и кем приходитесь этому человеку',
    hint: 'Можно без фамилии. Можно псевдоним. Это ваша подпись под текстом.',
    placeholder: 'Например: записала Маша, правнучка',
    rows: 1,
  },
];
---

<section class="m9-section" aria-labelledby="m9-form-title" id="form">
  <div class="m9-wrap-narrow">
    <header class="m9-section-head m9-reveal">
      <span class="m9-eyebrow">Расскажите</span>
      <h2 id="m9-form-title" class="m9-h2">
        Девять <em>строк</em>.
      </h2>
      <p class="m9-lede">
        Каждый ответ может быть в&nbsp;два-три предложения. Не&nbsp;старайтесь сделать красиво&nbsp;— это наша работа.
      </p>
    </header>

    <form
      class="m9-form m9-reveal"
      id="m9-form"
      novalidate
      data-state="idle"
      autocomplete="on"
    >
      <!-- О ком -->
      <fieldset class="m9-fieldset">
        <legend class="m9-legend">О ком</legend>

        <div class="m9-field">
          <label class="m9-field-label" for="m9-heroName">
            <span>Имя человека, о&nbsp;котором расскажете</span>
            <span class="m9-req" aria-hidden="true">обязательно</span>
          </label>
          <input
            class="m9-input"
            type="text"
            id="m9-heroName"
            name="heroName"
            required
            maxlength="80"
            placeholder="Например: Соколова Анна Григорьевна"
          />
        </div>

        <div class="m9-row">
          <div class="m9-field">
            <label class="m9-field-label" for="m9-relation">
              <span>Кем приходится</span>
            </label>
            <input
              class="m9-input"
              type="text"
              id="m9-relation"
              name="relation"
              maxlength="60"
              placeholder="Прабабушка / прадед / тётя / соседка"
            />
          </div>
          <div class="m9-field">
            <label class="m9-field-label" for="m9-years">
              <span>Годы жизни</span>
            </label>
            <input
              class="m9-input"
              type="text"
              id="m9-years"
              name="years"
              maxlength="32"
              placeholder="1918–1996"
              inputmode="text"
            />
          </div>
        </div>

        <div class="m9-field">
          <label class="m9-field-label" for="m9-place">
            <span>Место</span>
          </label>
          <input
            class="m9-input"
            type="text"
            id="m9-place"
            name="place"
            maxlength="80"
            placeholder="Город или село — где жили большую часть времени"
          />
        </div>
      </fieldset>

      <!-- 9 ответов -->
      <fieldset class="m9-fieldset">
        <legend class="m9-legend">Девять строк</legend>

        {questions.map((q) => (
          <div class="m9-field">
            <label class="m9-field-label" for={`m9-q${q.n}`}>
              <span class="m9-num">{String(q.n).padStart(2, '0')}</span>
              <span>{q.label}</span>
            </label>
            <p class="m9-field-hint">{q.hint}</p>
            <textarea
              class="m9-textarea"
              id={`m9-q${q.n}`}
              name={`q${q.n}`}
              rows={q.rows}
              maxlength="800"
              placeholder={q.placeholder}
            />
          </div>
        ))}
      </fieldset>

      <!-- Контакты -->
      <fieldset class="m9-fieldset">
        <legend class="m9-legend">Куда прислать</legend>

        <div class="m9-field">
          <label class="m9-field-label" for="m9-name">
            <span>Ваше имя</span>
            <span class="m9-req" aria-hidden="true">обязательно</span>
          </label>
          <input
            class="m9-input"
            type="text"
            id="m9-name"
            name="name"
            required
            maxlength="60"
            placeholder="Маша"
            autocomplete="given-name"
          />
        </div>

        <div class="m9-row">
          <div class="m9-field">
            <label class="m9-field-label" for="m9-email">
              <span>Email</span>
              <span class="m9-req" aria-hidden="true">обязательно</span>
            </label>
            <input
              class="m9-input"
              type="email"
              id="m9-email"
              name="email"
              required
              maxlength="120"
              placeholder="на этот адрес придёт PDF"
              autocomplete="email"
              inputmode="email"
            />
          </div>
          <div class="m9-field">
            <label class="m9-field-label" for="m9-telegram">
              <span>Telegram</span>
            </label>
            <input
              class="m9-input"
              type="text"
              id="m9-telegram"
              name="telegram"
              maxlength="40"
              placeholder="@username — если удобнее писать в Telegram"
            />
          </div>
        </div>
      </fieldset>

      <!-- Honeypot -->
      <div class="m9-honeypot" aria-hidden="true">
        <label>
          Если вы человек, не заполняйте это поле:
          <input
            type="text"
            name="honeypot"
            tabindex="-1"
            autocomplete="off"
            id="m9-honeypot"
          />
        </label>
      </div>

      <!-- Согласия -->
      <div class="m9-consents">
        <label class="m9-consent">
          <input
            type="checkbox"
            name="pdConsent"
            required
            id="m9-pdConsent"
          />
          <span>
            Согласен(-на) на&nbsp;обработку персональных данных&nbsp;—
            <a href="/privacy/" target="_blank" rel="noopener">политика конфиденциальности</a>.
            <span class="m9-req">обязательно</span>
          </span>
        </label>
        <label class="m9-consent">
          <input
            type="checkbox"
            name="contactConsent"
            required
            id="m9-contactConsent"
          />
          <span>
            Можно связаться по&nbsp;email или Telegram, чтобы прислать готовое эссе.
            <span class="m9-req">обязательно</span>
          </span>
        </label>
        <label class="m9-consent">
          <input
            type="checkbox"
            name="publishConsent"
            id="m9-publishConsent"
          />
          <span>
            Можно опубликовать историю в&nbsp;общем архиве (без email и&nbsp;контактов). Если не&nbsp;отметить&nbsp;— текст останется только у&nbsp;вас.
          </span>
        </label>
      </div>

      <!-- Submit -->
      <div class="m9-submit-row">
        <button type="submit" class="m9-btn" id="m9-submit">
          <span>Отправить</span>
        </button>
        <p class="m9-submit-note">
          Эссе придёт на&nbsp;почту в&nbsp;течение пяти&nbsp;дней. Хранение и&nbsp;обработка&nbsp;— по&nbsp;<a href="/privacy/">152-ФЗ</a>.
        </p>
      </div>

      <div class="m9-form-error" id="m9-error" hidden role="alert"></div>
    </form>
  </div>
</section>
