---
/**
 * Глава V — На годы вперёд.
 * Якорный блок перспективы.
 */
---

<section
  class="m9-section m9-section--anchor m9-outlook"
  id="outlook"
  data-chapter="V"
  data-chapter-name="На годы вперёд"
  aria-labelledby="m9-outlook-title"
>
  <div class="m9-wrap-narrow">
    <header class="m9-section-head m9-reveal">
      <p class="m9-chapter">
        <span class="m9-chapter-num">V</span>
        <span class="m9-chapter-name">На годы вперёд</span>
      </p>
      <h2 id="m9-outlook-title" class="m9-h2 m9-h2--lg">
        Двадцать сейчас. <em>Сто</em> к&nbsp;2030-му.
      </h2>
    </header>

    <ul class="m9-outlook-grid m9-reveal" role="list">
      <li class="m9-outlook-item">
        <p class="m9-outlook-year">2026</p>
        <p class="m9-outlook-num" data-count-to="20">20</p>
        <p class="m9-outlook-text">историй <br/>в этом году</p>
      </li>
      <li class="m9-outlook-item">
        <p class="m9-outlook-year">2030</p>
        <p class="m9-outlook-num" data-count-to="100">100</p>
        <p class="m9-outlook-text">в&nbsp;открытом <br/>архиве</p>
      </li>
      <li class="m9-outlook-item">
        <p class="m9-outlook-year">потом</p>
        <p class="m9-outlook-num m9-outlook-num-text"><em>книга</em></p>
        <p class="m9-outlook-text">общий <br/>сборник</p>
      </li>
    </ul>
  </div>
</section>
