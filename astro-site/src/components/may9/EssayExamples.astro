---
/**
 * Глава III — Что мы напишем.
 * Образец готового эссе — два примера с переключением табами.
 */

const examples = [
  {
    id: 'anna',
    tabLabel: 'Длинное',
    tabSubtitle: 'Анна · 1918—1996',
    name: 'Соколова Анна Григорьевна',
    meta: 'Прабабушка · 1918—1996 · Курск — Саратов — Курск',
    portrait: '/may9/examples/portrait-anna.jpg',
    portraitAlt: 'Сепийный портрет пожилой женщины для примера эссе про Анну Григорьевну',
    epigraph: 'Серьги были бабушкины. А есть было нечего.',
    body: [
      'Всю жизнь Анна Григорьевна Соколова собирала хлебные крошки в ладонь. И в восьмидесятые, и в девяностые, и в свой последний год — каждый раз, когда вставала из-за стола. Эту привычку перенял весь дом: правнуки до сих пор сметают крошки в банку с сухарями.',
      'Дома её звали бабой Нюрой. Родилась в Курске в восемнадцатом году. В сорок первом её с матерью увезли в эвакуацию — Саратов, ткацкая фабрика; вернулись только в сорок седьмом. На фронте не была: с четырнадцати лет шила шинели, потом — мешки. После войны там же осталась комендантом общежития.',
      'Главное, что про неё известно, она рассказала сама. Сорок третий, Саратов. Серьги — на полбуханки хлеба. Серьги были материны, ещё до того — бабушкины; плакала всю жизнь, что отдала.',
      'Когда варила варенье, пела вполголоса «На сопках Маньчжурии». Это было лет через сорок после войны, варенье было яблочное, Маша помнит запах. Если бы не варенье, песню бы не вспомнил никто.',
    ],
    signoff: 'записала Маша, правнучка',
  },
  {
    id: 'kolya',
    tabLabel: 'Короткое',
    tabSubtitle: 'Дед Коля · ?—?',
    name: 'Дед Коля',
    meta: 'Прадед · годы неизвестны · где-то под Калугой',
    portrait: '/may9/examples/portrait-kolya.jpg',
    portraitAlt: 'Сепийный портрет пожилого мужчины для примера эссе про деда Колю',
    epigraph: 'Потом, потом.',
    body: [
      'Прадеда звали дед Коля. Полного имени в семье уже не помнит никто. Жил под Калугой, в деревне; всю жизнь работал трактористом в колхозе. На фронте не был — войну провёл ребёнком, в той же деревне.',
      'Главная история — про немцев. Когда вошли в деревню, дед Коля, мать и сёстры три дня просидели в погребе. Имён матери и сестёр не сохранилось. Деревня — «где-то под Калугой».',
      'Любил жареную картошку с салом. На просьбы отвечал «потом, потом», всё откладывал — и не успел. Антон, правнук, записывает то немногое, что осталось: жил, пахал, прятался в погребе, любил картошку. И был.',
    ],
    signoff: 'записал Антон, правнук',
  },
];
---

<section
  class="m9-section m9-section--anchor m9-examples"
  id="essays"
  data-chapter="III"
  data-chapter-name="Что мы напишем"
  aria-labelledby="m9-examples-title"
>
  <div class="m9-wrap-narrow">
    <header class="m9-section-head m9-reveal">
      <p class="m9-chapter">
        <span class="m9-chapter-num">III</span>
        <span class="m9-chapter-name">Что мы напишем</span>
      </p>
      <h2 id="m9-examples-title" class="m9-h2 m9-h2--lg">
        Вот что мы <em>напишем</em>.
      </h2>
      <p class="m9-lede">
        Длинное эссе получается, когда дома много говорили. Короткое&nbsp;— когда знаете не&nbsp;всё. Оба одинаково честные.
      </p>
    </header>

    <div
      class="m9-essay-tabs m9-reveal"
      role="tablist"
      aria-label="Образцы эссе"
    >
      {examples.map((ex, i) => (
        <button
          type="button"
          class="m9-tab"
          role="tab"
          id={`m9-tab-${ex.id}`}
          aria-controls={`m9-panel-${ex.id}`}
          aria-selected={i === 0 ? 'true' : 'false'}
          data-essay-tab={ex.id}
          tabindex={i === 0 ? '0' : '-1'}
        >
          <span class="m9-tab-label">{ex.tabLabel}</span>
          <span class="m9-tab-subtitle">{ex.tabSubtitle}</span>
        </button>
      ))}
    </div>

    {examples.map((ex, i) => (
      <article
        class="m9-essay m9-reveal"
        id={`m9-panel-${ex.id}`}
        role="tabpanel"
        aria-labelledby={`m9-tab-${ex.id}`}
        data-essay-panel={ex.id}
        hidden={i !== 0}
      >
        <header class="m9-essay-head">
          <p class="m9-essay-meta">{ex.meta}</p>
          <h3 class="m9-essay-name">{ex.name}</h3>
        </header>

        <figure class="m9-essay-portrait">
          <img src={ex.portrait} alt={ex.portraitAlt} width="900" height="1124" loading={i === 0 ? 'eager' : 'lazy'} decoding="async" />
        </figure>

        <p class="m9-essay-epigraph">{ex.epigraph}</p>

        <div class="m9-essay-body">
          {ex.body.map((p, idx) => (
            <p class={idx === 0 ? 'm9-essay-p m9-essay-p-first' : 'm9-essay-p'}>{p}</p>
          ))}
        </div>

        <footer class="m9-essay-foot">
          <span class="m9-essay-signoff">{ex.signoff}</span>
          <span class="m9-essay-stamp">Май · MMXXVI</span>
        </footer>
      </article>
    ))}

    <p class="m9-essay-note m9-reveal">
      Черновик собирает нейросеть из&nbsp;ваших ответов. Дальше&nbsp;— редактор Академического Салона: правит, перечитывает, отправляет.
    </p>
  </div>
</section>

<script>
  // Локальный таб-свитчер для образцов эссе. Без зависимостей.
  (() => {
    const tabs = document.querySelectorAll<HTMLButtonElement>('[data-essay-tab]');
    const panels = document.querySelectorAll<HTMLElement>('[data-essay-panel]');
    if (!tabs.length || !panels.length) return;

    function activate(id: string, focus = false) {
      tabs.forEach((t) => {
        const active = t.dataset.essayTab === id;
        t.setAttribute('aria-selected', active ? 'true' : 'false');
        t.tabIndex = active ? 0 : -1;
      });
      panels.forEach((p) => {
        p.hidden = p.dataset.essayPanel !== id;
      });
      if (focus) {
        const target = Array.from(tabs).find((t) => t.dataset.essayTab === id);
        target?.focus();
      }
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => activate(tab.dataset.essayTab ?? ''));
      tab.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
          e.preventDefault();
          const dir = e.key === 'ArrowRight' ? 1 : -1;
          const next = (i + dir + tabs.length) % tabs.length;
          const id = tabs[next].dataset.essayTab ?? '';
          activate(id, true);
        }
      });
    });
  })();
</script>
