---
/**
 * Таймлайн «что произойдёт после отправки».
 * Снимает тревогу неизвестности, показывает прозрачный процесс.
 */

const steps = [
  {
    when: 'Сегодня',
    title: 'Заполнили',
    body: 'Ответы и&nbsp;контакты сохранились. Видеть их&nbsp;будет только редактор. Сразу узнаете свой номер&nbsp;— какой по&nbsp;счёту из&nbsp;двадцати в&nbsp;этом году.',
  },
  {
    when: '1–2 дня',
    title: 'Читаем',
    body: 'Редактор читает ответы и&nbsp;собирает черновик. Если что-то непонятно&nbsp;— напишет на&nbsp;ту&nbsp;же почту.',
  },
  {
    when: 'До 5 дней',
    title: 'PDF на почту',
    body: 'Готовое эссе приходит на&nbsp;ту&nbsp;почту, которую указали.&nbsp;PDF&nbsp;— можно распечатать, переслать родителям, положить в&nbsp;семейный альбом.',
  },
];
---

<section class="m9-section m9-after" aria-labelledby="m9-after-title">
  <div class="m9-wrap-narrow">
    <header class="m9-section-head m9-reveal">
      <span class="m9-eyebrow">После отправки</span>
      <h2 id="m9-after-title" class="m9-h2">
        Что будет <em>дальше</em>.
      </h2>
    </header>

    <ol class="m9-timeline m9-reveal" role="list">
      {steps.map((s, i) => (
        <li class="m9-step">
          <span class="m9-step-num">{String(i + 1).padStart(2, '0')}</span>
          <div class="m9-step-body">
            <p class="m9-step-when">{s.when}</p>
            <h3 class="m9-step-title">{s.title}</h3>
            <p class="m9-step-text" set:html={s.body}></p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
