---
/**
 * Stage 54 — «Сейчас читают» / Popular widget.
 *
 * Static markup ships hidden; runtime fetches /api/doc-stats/popular and
 * resolves filenames against the slim catalog index injected via
 * define:vars. Silent degradation when the API is empty/down.
 *
 * Used in two places:
 *   - <PopularNow heading="Сейчас читают" /> — Home, after Stats
 *   - <PopularNow variant="recovery" /> — /404 page recovery suggestions
 */
import { D } from '../data/catalog.js';

interface Props {
  heading?: string;
  variant?: 'default' | 'recovery';
  limit?: number;
}

const {
  heading = 'Сейчас читают в архиве',
  variant = 'default',
  limit = 6,
} = Astro.props;

// Slim index — only what the widget needs to render. Cuts ~200KB
// vs full catalog injection. file → { title, subject }.
const bySlug: Record<string, { t: string; s: string }> = {};
for (const d of D as any[]) {
  if (!d || !d.file) continue;
  bySlug[d.file] = {
    t: d.catalogTitle || d.title || d.filename || d.file,
    s: d.subject || '',
  };
}
---

<section
  class:list={['popular-now', variant === 'recovery' && 'popular-now--recovery']}
  data-popular-limit={limit}
  aria-label={heading}
  hidden
>
  <header class="popular-now-head">
    <h2 class="popular-now-h">{heading}</h2>
    <a class="popular-now-link" href="/catalog">в&nbsp;архив →</a>
  </header>
  <ol class="popular-now-list" id="popularList"></ol>
</section>

<script is:inline define:vars={{ bySlug }}>
  // Make the slim catalog index available to popular-runtime.js
  window.academicSalonPopular = window.academicSalonPopular || { bySlug };
</script>
<script src="/scripts/popular-runtime.js" defer></script>

<style>
  .popular-now {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: clamp(40px, 6vw, 72px) clamp(20px, 4vw, 48px);
  }
  .popular-now--recovery {
    padding-top: 0;
    padding-bottom: clamp(32px, 4vw, 48px);
  }
  .popular-now-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 24px;
    margin-bottom: clamp(20px, 3vw, 32px);
    padding-bottom: 14px;
    border-bottom: 1px solid var(--brd);
  }
  .popular-now-h {
    margin: 0;
    font: 400 clamp(20px, 2.4vw, 28px)/1.2 var(--fd);
    color: var(--t1);
    letter-spacing: -.01em;
  }
  .popular-now-link {
    font: 400 12px/1 var(--fm);
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--ac);
    text-decoration: none;
    white-space: nowrap;
  }
  .popular-now-link:hover { color: var(--ac2, var(--ac-link, var(--ac))); }

  .popular-now-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1px;
    background: var(--brd);
    border: 1px solid var(--brd);
  }
  /* Items are inserted at runtime by popular-runtime.js, so they don't
     carry Astro's scoped data-astro-cid attribute — keep these globals. */
  :global(.popular-now-item) {
    background: var(--bg);
  }
  :global(.popular-now-item-link) {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 18px 20px;
    text-decoration: none;
    color: inherit;
    height: 100%;
    transition: background var(--dur, .25s) var(--ease, ease);
  }
  :global(.popular-now-item-link:hover) { background: rgba(212,175,55,.04); }
  :global(.popular-now-item-title) {
    font: 400 15px/1.4 var(--fi);
    color: var(--t1);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.popular-now-item-meta) {
    margin-top: auto;
    font: 400 11px/1 var(--fm);
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--t3);
    display: flex;
    gap: 6px;
    align-items: baseline;
  }
  :global(.popular-now-item-meta .pop-stat) {
    color: var(--ac);
    font-style: italic;
    font-family: var(--fd);
    text-transform: none;
    letter-spacing: 0;
    font-feature-settings: 'tnum';
  }
</style>
