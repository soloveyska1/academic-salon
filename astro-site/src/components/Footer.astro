---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="footer-logo">
          <svg viewBox="0 0 400 400" width="44" height="44" aria-hidden="true">
            <defs>
              <linearGradient id="fg-bg" x1=".5" y1="0" x2=".5" y2="1">
                <stop offset="0" stop-color="#2a2418"/>
                <stop offset=".4" stop-color="#1a1610"/>
                <stop offset="1" stop-color="#0e0c08"/>
              </linearGradient>
              <linearGradient id="fg-gold" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#d4af37"/>
                <stop offset=".5" stop-color="#c9a030"/>
                <stop offset="1" stop-color="#b8922a"/>
              </linearGradient>
            </defs>
            <circle cx="200" cy="200" r="200" fill="url(#fg-bg)"/>
            <text x="200" y="185" text-anchor="middle" font-family="'Playfair Display','Georgia',serif" font-size="52" font-weight="700" fill="url(#fg-gold)" letter-spacing="2">АКАДЕМИЧЕСКИЙ</text>
            <text x="200" y="245" text-anchor="middle" font-family="'Playfair Display','Georgia',serif" font-size="52" font-weight="700" fill="url(#fg-gold)" letter-spacing="2">САЛОН</text>
          </svg>
        </span>
        <div>
          <div class="footer-name">Библиотека академического салона</div>
          <div class="footer-desc">Студенческие работы по психологии и социальной работе</div>
        </div>
      </div>

      <div class="footer-cols">
        <div class="footer-col">
          <div class="footer-col-title">Навигация</div>
          <a href="/">Главная</a>
          <a href="/catalog">Каталог</a>
          <a href="/order">Заказать работу</a>
          <a href="/faq">Частые вопросы</a>
        </div>
        <div class="footer-col">
          <div class="footer-col-title">Контакты</div>
          <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">ВКонтакте</a>
          <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
          <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
        </div>
        <div class="footer-col">
          <div class="footer-col-title">Информация</div>
          <a href="https://telegra.ph/Pravovye-dokumenty-servisa-Akademicheskij-Salon-03-26-2" target="_blank" rel="noopener">Правовые документы</a>
          <span class="footer-stat">236 документов в библиотеке</span>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">&copy; 2026 Библиотека академического салона</span>
      <a href="https://telegra.ph/Pravovye-dokumenty-servisa-Akademicheskij-Salon-03-26-2" target="_blank" rel="noopener" class="footer-legal">Правовая информация</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--sp-24);
    padding: var(--sp-12) 0 var(--sp-8);
    border-top: 1px solid var(--brd);
    position: relative;
  }
  .footer::before {
    content: '';
    position: absolute;
    top: 0; left: 20%; right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212,175,55,.15), transparent);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--sp-12);
    margin-bottom: var(--sp-10);
  }

  .footer-brand {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-4);
  }
  .footer-logo {
    flex-shrink: 0;
    display: flex;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 0 0 1px rgba(212,175,55,.12);
  }
  .footer-logo svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  .footer-name {
    font-family: var(--fd);
    font-size: 16px;
    font-weight: 800;
    color: var(--t1);
    margin-bottom: 4px;
  }
  .footer-desc {
    font-size: 13px;
    color: var(--t3);
    line-height: 1.5;
    max-width: 260px;
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-8);
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .footer-col-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--t3);
    margin-bottom: var(--sp-2);
  }
  .footer-col a, .footer-stat {
    font-size: 13px;
    color: var(--t2);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
    padding: 2px 0;
  }
  .footer-col a:hover { color: var(--ac2) }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--sp-6);
    border-top: 1px solid var(--brd);
  }
  .footer-copy {
    font-size: 12px;
    color: var(--t3);
  }
  .footer-legal {
    font-size: 12px;
    color: var(--t3);
    text-decoration: none;
    transition: color var(--dur-fast);
  }
  .footer-legal:hover { color: var(--ac2) }

  @media (max-width: 768px) {
    .footer-top { grid-template-columns: 1fr; gap: var(--sp-8) }
    .footer-cols { grid-template-columns: 1fr; gap: var(--sp-6) }
  }
</style>
