---
import { D } from '../data/catalog.js';
const docCount = D.length;
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="footer-logo">
          <svg viewBox="0 0 200 200" width="44" height="44" aria-hidden="true">
            <defs>
              <linearGradient id="ft-bg" x1=".5" y1="0" x2=".5" y2="1">
                <stop offset="0" stop-color="#1a1610"/>
                <stop offset="1" stop-color="#0e0c08"/>
              </linearGradient>
              <linearGradient id="ft-g" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#f6e27a"/>
                <stop offset=".45" stop-color="#d4af37"/>
                <stop offset="1" stop-color="#a08520"/>
              </linearGradient>
            </defs>
            <circle cx="100" cy="100" r="100" fill="url(#ft-bg)"/>
            <g fill="none" stroke="url(#ft-g)" stroke-linecap="round" stroke-linejoin="round" transform="translate(100,104)">
              <line x1="-42" y1="48" x2="-6" y2="-52" stroke-width="7"/>
              <line x1="16" y1="48" x2="-6" y2="-52" stroke-width="7"/>
              <line x1="-30" y1="16" x2="10" y2="16" stroke-width="5"/>
              <path d="M48 -24 C40 -46, 22 -50, 16 -34" stroke-width="7"/>
              <path d="M16 40 C22 54, 40 50, 48 28" stroke-width="7"/>
            </g>
          </svg>
        </span>
        <div>
          <div class="footer-name">Академический Салон</div>
          <div class="footer-desc">Библиотека студенческих работ и сервис индивидуального выполнения. Тихая мастерская с 2020 года.</div>
          <div class="footer-host">bibliosaloon.ru</div>
        </div>
      </div>

      <div class="footer-cols">
        <div class="footer-col">
          <div class="footer-col-title"><span class="footer-col-n" aria-hidden="true">I</span> Мастерская</div>
          <a href="/">Главная</a>
          <a href="/catalog">Каталог</a>
          <a href="/about">О нас</a>
          <a href="/contribute">Поделиться работой</a>
        </div>
        <div class="footer-col">
          <div class="footer-col-title"><span class="footer-col-n" aria-hidden="true">II</span> Заказать</div>
          <a href="/order">Форма заказа</a>
          <a href="/order#pricing">Цены и сроки</a>
          <a href="/about#faq">Частые вопросы</a>
          <a href="/me">Личный кабинет</a>
        </div>
        <div class="footer-col">
          <div class="footer-col-title"><span class="footer-col-n" aria-hidden="true">III</span> На связи</div>
          <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
          <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">ВКонтакте</a>
          <a href="https://max.ru/join/lvaRhM9GTze3JfqgW9GsTisLfz-o_IOdVK-ev-_AsH0" target="_blank" rel="noopener">MAX</a>
          <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
        </div>
        <div class="footer-col">
          <div class="footer-col-title"><span class="footer-col-n" aria-hidden="true">IV</span> Документы</div>
          <a href="/terms">Пользовательское соглашение</a>
          <a href="/privacy">Конфиденциальность</a>
          <span class="footer-stat">{docCount} работ в каталоге</span>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">&copy; MMXX&mdash;MMXXVI · Академический Салон</span>
      <span class="footer-whisper">Сделано тихо, для тех, кому важен текст</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--sp-24);
    padding: var(--sp-16) 0 var(--sp-10);
    border-top: 1px solid var(--brd);
    position: relative;
  }
  .footer::before {
    content: '';
    position: absolute;
    top: 0; left: 20%; right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ac-line), transparent);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--sp-16);
    margin-bottom: var(--sp-12);
  }

  .footer-brand {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-4);
  }
  .footer-logo {
    flex-shrink: 0;
    display: flex;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 0 0 1px var(--ac-b), 0 0 12px var(--ac-g2);
    transition: box-shadow var(--dur-slow) var(--ease);
  }
  .footer-brand:hover .footer-logo {
    box-shadow: 0 0 0 1px var(--ac-b2), 0 0 16px var(--ac-g);
  }
  .footer-logo svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  .footer-name {
    font: italic 400 18px/1.2 var(--fd);
    color: var(--t1);
    letter-spacing: .01em;
    margin-bottom: 6px;
    font-feature-settings: "swsh", "dlig", "liga";
    transition: color var(--dur-slow) var(--ease);
  }
  .footer-brand:hover .footer-name { color: var(--ac-link, var(--ac)); }
  .footer-desc {
    font: 400 12px/1.6 var(--fi);
    color: var(--t3);
    max-width: 260px;
  }
  .footer-host {
    margin-top: 10px;
    font: 400 10px/1 var(--fm);
    letter-spacing: .28em;
    text-transform: uppercase;
    color: var(--t3);
    opacity: .7;
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-10, 40px);
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .footer-col-title {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font: 400 10px/1 var(--fi);
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--t3);
    margin-bottom: 4px;
  }
  .footer-col-n {
    font: italic 400 14px/1 var(--fd);
    color: var(--ac);
    letter-spacing: 0;
    text-transform: none;
    opacity: .75;
  }
  .footer-col a, .footer-stat {
    font: 400 13px/1.4 var(--fi);
    color: var(--t2);
    text-decoration: none;
    transition: color var(--dur-slow) var(--ease);
  }
  .footer-col a:hover { color: var(--ac-link, var(--ac)); }
  .footer-col a:focus-visible {
    outline: 1px solid var(--ac-b);
    outline-offset: 3px;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--sp-8);
    border-top: 1px solid var(--brd);
    position: relative;
  }
  .footer-bottom::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 25%;
    right: 25%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ac-line), transparent);
  }
  .footer-copy {
    font: italic 400 12px/1.4 var(--fd);
    color: var(--t3);
    /* opacity stripped — combining .75 with --t3 dropped contrast to
       2.28:1, well below WCAG AA. The bumped t3 alone reads cleanly. */
    letter-spacing: .04em;
    font-variant-numeric: tabular-nums;
  }
  .footer-whisper {
    font: 400 11px/1.4 var(--fi);
    color: var(--t3);
    opacity: .55;
    letter-spacing: .03em;
  }

  @media (max-width: 1024px) {
    .footer-cols { grid-template-columns: repeat(2, 1fr); gap: var(--sp-8, 32px); }
  }

  @media (max-width: 768px) {
    .footer-top { grid-template-columns: 1fr; gap: var(--sp-8, 16px); }
    /* Hide nav columns — bottom nav handles navigation */
    .footer-cols { display: none; }
    .footer { padding: 24px 0 16px; margin-top: 32px; }
    .footer-bottom { padding-top: 16px; flex-direction: column; gap: 8px; align-items: center; text-align: center; }
    .footer-name { font-size: 16px; }
    .footer-desc { font-size: 13px; text-align: left; }
  }

  /* Light theme */
  :global([data-theme="light"]) .footer-logo svg circle {
    fill: #eee9de;
  }
</style>
