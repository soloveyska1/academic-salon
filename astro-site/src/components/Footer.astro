---
import { D } from '../data/catalog.js';
const docCount = D.length;
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="footer-logo">
          <svg viewBox="0 0 200 200" width="44" height="44" aria-hidden="true">
            <defs>
              <linearGradient id="ft-bg" x1=".5" y1="0" x2=".5" y2="1">
                <stop offset="0" stop-color="#1a1610"/>
                <stop offset="1" stop-color="#0e0c08"/>
              </linearGradient>
              <linearGradient id="ft-g" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#f6e27a"/>
                <stop offset=".45" stop-color="#d4af37"/>
                <stop offset="1" stop-color="#a08520"/>
              </linearGradient>
            </defs>
            <circle cx="100" cy="100" r="100" fill="url(#ft-bg)"/>
            <g fill="none" stroke="url(#ft-g)" stroke-linecap="round" stroke-linejoin="round" transform="translate(100,104)">
              <line x1="-42" y1="48" x2="-6" y2="-52" stroke-width="7"/>
              <line x1="16" y1="48" x2="-6" y2="-52" stroke-width="7"/>
              <line x1="-30" y1="16" x2="10" y2="16" stroke-width="5"/>
              <path d="M48 -24 C40 -46, 22 -50, 16 -34" stroke-width="7"/>
              <path d="M16 40 C22 54, 40 50, 48 28" stroke-width="7"/>
            </g>
          </svg>
        </span>
        <div>
          <div class="footer-name">Библиотека академического салона</div>
          <div class="footer-desc">Студенческие работы по психологии и социальной работе</div>
        </div>
      </div>

      <div class="footer-cols">
        <div class="footer-col">
          <div class="footer-col-title">Навигация</div>
          <a href="/">Главная</a>
          <a href="/catalog">Каталог</a>
          <a href="/order">Заказать работу</a>
          <a href="/contribute">Поделиться работой</a>
          <a href="/about#faq">Частые вопросы</a>
        </div>
        <div class="footer-col">
          <div class="footer-col-title">Контакты</div>
          <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener">ВКонтакте</a>
          <a href="https://t.me/academicsaloon" target="_blank" rel="noopener">Telegram</a>
          <a href="mailto:academsaloon@mail.ru">academsaloon@mail.ru</a>
        </div>
        <div class="footer-col">
          <div class="footer-col-title">Информация</div>
          <a href="https://telegra.ph/Pravovye-dokumenty-servisa-Akademicheskij-Salon-03-26-2" target="_blank" rel="noopener">Правовые документы</a>
          <a href="/about#privacy">Конфиденциальность</a>
          <span class="footer-stat">{docCount} документов в библиотеке</span>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">&copy; 2026 Библиотека академического салона</span>
      <a href="https://telegra.ph/Pravovye-dokumenty-servisa-Akademicheskij-Salon-03-26-2" target="_blank" rel="noopener" class="footer-legal">Правовая информация</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--sp-24);
    padding: var(--sp-16) 0 var(--sp-10);
    border-top: 1px solid var(--brd);
    position: relative;
  }
  .footer::before {
    content: '';
    position: absolute;
    top: 0; left: 20%; right: 20%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--ac-line), transparent);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--sp-16);
    margin-bottom: var(--sp-12);
  }

  .footer-brand {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-4);
  }
  .footer-logo {
    flex-shrink: 0;
    display: flex;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 0 0 1px var(--ac-g);
  }
  .footer-logo svg {
    display: block;
    width: 100%;
    height: 100%;
  }
  .footer-name {
    font: 400 15px/1.3 var(--fd);
    color: var(--t1);
    letter-spacing: .02em;
    margin-bottom: 6px;
  }
  .footer-desc {
    font: 400 12px/1.6 var(--fi);
    color: var(--t3);
    max-width: 240px;
  }

  .footer-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-10);
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col-title {
    font: 400 10px/1 var(--fi);
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--t3);
    margin-bottom: 4px;
  }
  .footer-col a, .footer-stat {
    font: 400 13px/1.4 var(--fi);
    color: var(--t2);
    text-decoration: none;
    transition: color var(--dur) var(--ease);
  }
  .footer-col a:hover { color: var(--t1); }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--sp-8);
    border-top: 1px solid var(--brd);
  }
  .footer-copy {
    font: 400 11px/1 var(--fi);
    color: var(--t3);
    opacity: .6;
  }
  .footer-legal {
    font: 400 11px/1 var(--fi);
    color: var(--t3);
    opacity: .6;
    text-decoration: none;
    transition: opacity var(--dur) var(--ease);
  }
  .footer-legal:hover { opacity: 1; }

  @media (max-width: 768px) {
    .footer-top { grid-template-columns: 1fr; gap: var(--sp-8, 16px); }
    /* Hide nav columns — bottom nav handles navigation */
    .footer-cols { display: none; }
    .footer { padding: 24px 0 16px; margin-top: 32px; }
    .footer-bottom { padding-top: 16px; flex-direction: column; gap: 8px; align-items: center; }
    .footer-name { font-size: 14px; }
    .footer-desc { font-size: 13px; text-align: left; }
  }

  /* Light theme */
  :global([data-theme="light"]) .footer-logo svg circle {
    fill: #eee9de;
  }
</style>
