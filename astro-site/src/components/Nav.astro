---
const { currentPath = '/' } = Astro.props;
const links = [
  { href: '/',           label: 'Салон',         numeral: '⁘'  },
  { href: '/catalog',    label: 'Каталог',       numeral: 'I'   },
  { href: '/order',      label: 'Заказать',      numeral: 'II'  },
  { href: '/anti-ai',    label: 'Чистка от ИИ',  numeral: 'III' },
  { href: '/contribute', label: 'Поделиться',    numeral: 'IV'  },
  { href: '/about',      label: 'О нас',         numeral: 'V'   },
];
---

<nav class="nav" id="nav">
  <a href="/" class="nav-logo" aria-label="Академический Салон — на главную">
    <span class="nav-logo-icon" aria-hidden="true">
      <img src="/logo-mark.svg" alt="" width="36" height="36" loading="eager" decoding="async" />
    </span>
    <span class="nav-logo-text">
      <span class="nav-logo-name">Академический Салон</span>
      <span class="nav-logo-sub">Мастерская · с 2020</span>
    </span>
  </a>

  <div class="nav-links" id="navLinks">
    {links.map(link => (
      <a
        href={link.href}
        class:list={['nav-link', { active: currentPath === link.href }]}
        aria-current={currentPath === link.href ? 'page' : undefined}
      >
        <span class="nav-link-n" aria-hidden="true">{link.numeral}</span>
        <span class="nav-link-label">{link.label}</span>
      </a>
    ))}
  </div>

  <div class="nav-hours" aria-label="Текущее время в Москве" id="navHours">
    <span class="nav-hours-label">На связи · МСК</span>
    <span class="nav-hours-val">
      <span class="nav-hours-dot" aria-hidden="true"></span>
      <span id="navTime">—</span>
    </span>
  </div>

  <div class="nav-actions">
    <!-- Global search trigger — opens command palette. Skipped on
         /catalog (in-page search input already focused there). -->
    {currentPath !== '/catalog' && currentPath !== '/catalog/' && (
      <button
        class="nav-search-btn"
        id="navSearchBtn"
        type="button"
        aria-label="Поиск по архиву (нажмите /)"
        title="Поиск · /"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <kbd class="nav-search-kbd" aria-hidden="true">/</kbd>
      </button>
    )}

    <!-- Stage 61 — language switch. Toggles between Russian site and
         /en starter page. Hidden on /en itself (we link back via the
         page footer). -->
    {currentPath !== '/en' && currentPath !== '/en/' && (
      <a class="nav-lang" id="navLang" href="/en" aria-label="English summary">EN</a>
    )}

    <!-- Profile / cabinet entry (visible on every page) -->
    <a class="nav-profile" id="navProfile" href="/me#profile" aria-label="Профиль кабинета">
      <svg class="nav-profile-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      <span class="nav-profile-dot" aria-hidden="true"></span>
    </a>

    <!-- Theme toggle -->
    <button class="theme-toggle" id="themeToggle" type="button" aria-label="Переключить тему">
      <svg class="theme-icon theme-icon--sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="theme-icon theme-icon--moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>

    <!-- Hamburger button (mobile only) -->
    <button class="nav-burger" id="navBurger" type="button" aria-label="Открыть меню" aria-expanded="false">
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>
  </div>
</nav>

<!-- Mobile bottom sheet menu -->
<div class="sheet-backdrop" id="sheetBackdrop" aria-hidden="true"></div>
<div class="bottom-sheet" id="mobileMenu" aria-hidden="true" inert role="dialog" aria-label="Меню">
  <div class="sheet-handle" aria-hidden="true"><span></span></div>
  <div class="sheet-content">
    {links.map((link, i) => (
      <a
        href={link.href}
        class:list={['sheet-link', { active: currentPath === link.href }]}
        style={`--i:${i}`}
        aria-current={currentPath === link.href ? 'page' : undefined}
      >
        <span class="sheet-link-label">{link.label}</span>
        <span class="sheet-link-n" aria-hidden="true">{link.numeral}</span>
      </a>
    ))}
    <a
      href="/me#profile"
      class:list={['sheet-link', 'sheet-link-me', { active: currentPath === '/me' }]}
      style={`--i:${links.length}`}
      aria-current={currentPath === '/me' ? 'page' : undefined}
    >
      <span class="sheet-link-label">Мой кабинет</span>
      <span class="sheet-link-n" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </span>
    </a>
    <div class="sheet-divider"></div>
    <div class="sheet-contacts">
      <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="sheet-contact">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2.5L2 10l7 3 3 7 9.5-18z"/><line x1="9" y1="13" x2="13.5" y2="8.5"/></svg>
        Telegram
      </a>
      <a href="https://vk.com/academicsaloon" target="_blank" rel="noopener" class="sheet-contact">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 2H7a5 5 0 00-5 5v10a5 5 0 005 5h10a5 5 0 005-5V7a5 5 0 00-5-5z"/><path d="M12.5 16.5c-3.5 0-5.5-2.5-5.6-5h2c.1 1.8 1.3 2.5 2.3 2.7V11.5c-1.5-.2-3-1-3-3.5 0-1.7 1.2-2.9 3-3v3c.8.1 1.7-.4 2-1.5h1.8c-.3 1.4-1.2 2.2-1.8 2.5v1c.7-.1 1.5-.8 2-2h1.7c-.4 2-1.8 3.5-3.5 4v2.5h-1z"/></svg>
        VK
      </a>
      <a href="https://max.ru/join/lvaRhM9GTze3JfqgW9GsTisLfz-o_IOdVK-ev-_AsH0" target="_blank" rel="noopener" class="sheet-contact">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 20V5a1 1 0 011-1h16a1 1 0 011 1v15a1 1 0 01-1 1H4a1 1 0 01-1-1z"/><path d="M7 17V9l5 5 5-5v8"/></svg>
        MAX
      </a>
      <a href="mailto:academsaloon@mail.ru" class="sheet-contact">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/></svg>
        Почта
      </a>
    </div>
    <div class="sheet-divider"></div>
    <button class="sheet-reading" id="readingToggle" type="button">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
      <span id="readingLabel">Режим чтения</span>
    </button>
  </div>
</div>

<!-- ═══════ BOTTOM TAB BAR (mobile) ═══════ -->
<nav class="btm-nav" id="btmNav" aria-label="Быстрая навигация">
  <a href="/" class:list={['btm-item', { active: currentPath === '/' }]}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
    <span>Главная</span>
  </a>
  <a href="/catalog" class:list={['btm-item', { active: currentPath === '/catalog' }]}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
    <span>Каталог</span>
  </a>
  <a href="/order" class:list={['btm-item', { active: currentPath === '/order' }]}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    <span>Заказать</span>
  </a>
  <a href="/contribute" class:list={['btm-item', { active: currentPath === '/contribute' }]}>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
    <span>Поделиться</span>
  </a>
  <button class="btm-item" id="btmMore" type="button">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>
    <span>Ещё</span>
  </button>
</nav>

<!-- ============================================================
     GLOBAL SEARCH PALETTE
     Лениво грузит /search-index.json при первом открытии. Hotkeys:
     "/" в любом месте (кроме input/textarea), Cmd/Ctrl+K, click по
     иконке поиска в Nav. ↑/↓ навигация, Enter — открыть, Esc — закрыть.
     ============================================================ -->
<div class="navsearch-overlay" id="navSearchOverlay" aria-hidden="true" hidden>
  <div class="navsearch-backdrop" id="navSearchBackdrop" aria-hidden="true"></div>
  <div class="navsearch-dialog" role="dialog" aria-modal="true" aria-label="Поиск по архиву">
    <div class="navsearch-input-wrap">
      <svg class="navsearch-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        type="search"
        id="navSearchInput"
        class="navsearch-input"
        placeholder="Введите запрос…"
        autocomplete="off"
        autocorrect="off"
        spellcheck="false"
        aria-label="Поиск по архиву"
      />
      <kbd class="navsearch-kbd-hint" aria-hidden="true">esc</kbd>
    </div>
    <ol class="navsearch-list" id="navSearchList" role="listbox" aria-label="Результаты" aria-live="polite"></ol>
    <footer class="navsearch-foot">
      <span class="navsearch-meta" id="navSearchMeta">Введите запрос — найдём по 244 работам</span>
      <a href="/catalog" class="navsearch-all" id="navSearchAll">Все в каталоге →</a>
    </footer>
  </div>
</div>

<script>
  function initNav() {
    const win = window as Window & { __academicSalonNavCleanup?: () => void };
    if (typeof win.__academicSalonNavCleanup === 'function') {
      win.__academicSalonNavCleanup();
      win.__academicSalonNavCleanup = undefined;
    }

    let lastY = 0;
    let ticking = false;
    const nav = document.getElementById('nav');

    function updateNav() {
      const y = window.scrollY;
      if (y > 60) {
        nav?.classList.add('scrolled');
        if (y > lastY && y > 200) {
          nav?.classList.add('hidden');
        } else {
          nav?.classList.remove('hidden');
        }
      } else {
        nav?.classList.remove('scrolled', 'hidden');
      }
      lastY = y;
      ticking = false;
    }

    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(updateNav);
        ticking = true;
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });

    // ═══════ BOTTOM SHEET MENU ═══════
    const burger = document.getElementById('navBurger');
    const menu = document.getElementById('mobileMenu');
    const backdrop = document.getElementById('sheetBackdrop');
    const menuLinkHandlers = new Map<HTMLAnchorElement, (event: MouseEvent) => void>();

    function navigateToHref(href: string | null, target?: string | null) {
      if (!href || href.startsWith('#')) return;
      if (target === '_blank') {
        window.open(href, '_blank', 'noopener');
        return;
      }
      if (href.startsWith('mailto:') || href.startsWith('tel:') || href.startsWith('http://') || href.startsWith('https://')) {
        window.location.href = href;
        return;
      }
      const url = new URL(href, window.location.href);
      if (url.origin === window.location.origin
        && url.pathname === window.location.pathname
        && url.search === window.location.search
        && url.hash) {
        if (window.location.hash === url.hash) {
          window.dispatchEvent(new HashChangeEvent('hashchange'));
        } else {
          window.location.hash = url.hash;
        }
        return;
      }
      window.location.assign(href);
    }

    /**
     * Make the page background inert while the sheet is open — keyboard
     * focus and screen-reader output stay inside the dialog.
     */
    function setSheetBgInert(on: boolean) {
      const targets = [
        document.getElementById('main'),
        document.querySelector('.salon-footer'),
        document.querySelector('.btm-bar'),
      ].filter(Boolean) as HTMLElement[];
      for (const el of targets) {
        if (on) el.setAttribute('inert', '');
        else el.removeAttribute('inert');
      }
    }

    function openMenu() {
      burger?.classList.add('is-open');
      burger?.setAttribute('aria-expanded', 'true');
      menu?.classList.add('is-open');
      menu?.setAttribute('aria-hidden', 'false');
      // Stage 48 — `inert` removes children from the focus / a11y tree.
      // Closing again puts them back. Pairs with aria-hidden so the
      // bottom-sheet is fully hidden from screen readers AND keyboards.
      menu?.removeAttribute('inert');
      setSheetBgInert(true);
      backdrop?.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      // Move focus into the dialog so screen readers announce it.
      const firstLink = menu?.querySelector<HTMLElement>('a, button');
      setTimeout(() => firstLink?.focus(), 80);
    }

    function closeMenu() {
      burger?.classList.remove('is-open');
      burger?.setAttribute('aria-expanded', 'false');
      menu?.classList.remove('is-open');
      menu?.setAttribute('aria-hidden', 'true');
      menu?.setAttribute('inert', '');
      setSheetBgInert(false);
      backdrop?.classList.remove('is-open');
      document.body.style.overflow = '';
      // Return focus to the trigger so keyboard users keep their place.
      burger?.focus();
    }

    const onBurgerClick = () => {
      const isOpen = burger.classList.contains('is-open');
      isOpen ? closeMenu() : openMenu();
    };
    burger?.addEventListener('click', onBurgerClick);

    // Close on backdrop tap
    backdrop?.addEventListener('click', closeMenu);

    // Close on link click
    const menuLinks = Array.from(menu?.querySelectorAll('a') || []);
    menuLinks.forEach(a => {
      const onMenuLinkClick = (event: MouseEvent) => {
        const href = a.getAttribute('href');
        const target = a.getAttribute('target');
        closeMenu();

        if (!href || href.startsWith('http://') || href.startsWith('https://') || href.startsWith('mailto:') || href.startsWith('tel:') || target === '_blank') {
          return;
        }

        event.preventDefault();
        requestAnimationFrame(() => navigateToHref(href, target));
      };

      menuLinkHandlers.set(a as HTMLAnchorElement, onMenuLinkClick);
      a.addEventListener('click', onMenuLinkClick);
    });

    // Close on Escape
    const onKeyDown = (e: KeyboardEvent) => {
      if (e.key === 'Escape') closeMenu();
    };
    document.addEventListener('keydown', onKeyDown);

    // Swipe-to-dismiss on bottom sheet handle
    let handle: Element | null = null;
    let onHandleTouchStart: ((e: TouchEvent) => void) | undefined;
    let onHandleTouchMove: ((e: TouchEvent) => void) | undefined;
    let onHandleTouchEnd: (() => void) | undefined;
    if (menu) {
      let startY = 0;
      let currentY = 0;
      let isDragging = false;

      handle = menu.querySelector('.sheet-handle');
      if (handle) {
        onHandleTouchStart = (e: TouchEvent) => {
          startY = e.touches[0].clientY;
          isDragging = true;
          menu.style.transition = 'none';
        };
        handle.addEventListener('touchstart', onHandleTouchStart, { passive: true });

        onHandleTouchMove = (e: TouchEvent) => {
          if (!isDragging) return;
          currentY = e.touches[0].clientY;
          const diff = Math.max(0, currentY - startY);
          menu.style.transform = `translateY(${diff}px)`;
        };
        handle.addEventListener('touchmove', onHandleTouchMove, { passive: true });

        onHandleTouchEnd = () => {
          if (!isDragging) return;
          isDragging = false;
          menu.style.transition = '';
          const diff = currentY - startY;
          if (diff > 80) {
            closeMenu();
          }
          menu.style.transform = '';
        };
        handle.addEventListener('touchend', onHandleTouchEnd);
      }
    }

    // ═══════ BOTTOM TAB BAR — "More" button ═══════
    const btmMore = document.getElementById('btmMore');
    if (btmMore) {
      btmMore.addEventListener('click', openMenu);
    }

    // ═══════ THEME TOGGLE ═══════
    const toggle = document.getElementById('themeToggle');
    const html = document.documentElement;

    // Restore saved theme (safe for private-mode Safari / disabled storage)
    let saved: string | null = null;
    try { saved = localStorage.getItem('theme'); } catch (_) {}
    if (saved) {
      html.setAttribute('data-theme', saved);
    }

    const onThemeToggle = () => {
      const current = html.getAttribute('data-theme');
      const next = current === 'light' ? 'dark' : 'light';

      // Circle-wipe transition if View Transition API supported
      if (document.startViewTransition && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const rect = toggle.getBoundingClientRect();
        const x = rect.left + rect.width / 2;
        const y = rect.top + rect.height / 2;
        const endRadius = Math.hypot(
          Math.max(x, window.innerWidth - x),
          Math.max(y, window.innerHeight - y)
        );

        const transition = document.startViewTransition(() => {
          if (next === 'dark') {
            html.removeAttribute('data-theme');
          } else {
            html.setAttribute('data-theme', next);
          }
        });

        transition.ready.then(() => {
          document.documentElement.animate(
            {
              clipPath: [
                `circle(0px at ${x}px ${y}px)`,
                `circle(${endRadius}px at ${x}px ${y}px)`,
              ],
            },
            {
              duration: 500,
              easing: 'cubic-bezier(.4,0,.2,1)',
              pseudoElement: '::view-transition-new(root)',
            }
          );
        });
      } else {
        if (next === 'dark') {
          html.removeAttribute('data-theme');
        } else {
          html.setAttribute('data-theme', next);
        }
      }
      try { localStorage.setItem('theme', next); } catch (_) {}
    };
    toggle?.addEventListener('click', onThemeToggle);

    // ═══════ READING MODE TOGGLE ═══════
    const readingBtn = document.getElementById('readingToggle');
    const readingLabel = document.getElementById('readingLabel');

    // Restore
    let readingSaved: string | null = null;
    try { readingSaved = localStorage.getItem('reading'); } catch (_) {}
    if (readingSaved === 'on') {
      html.setAttribute('data-reading', 'on');
      if (readingLabel) readingLabel.textContent = 'Режим чтения ✓';
    }

    const onReadingToggle = () => {
      const on = html.getAttribute('data-reading') === 'on';
      if (on) {
        html.removeAttribute('data-reading');
        try { localStorage.removeItem('reading'); } catch (_) {}
        if (readingLabel) readingLabel.textContent = 'Режим чтения';
      } else {
        html.setAttribute('data-reading', 'on');
        try { localStorage.setItem('reading', 'on'); } catch (_) {}
        if (readingLabel) readingLabel.textContent = 'Режим чтения ✓';
      }
    };
    readingBtn?.addEventListener('click', onReadingToggle);

    updateNav();

    // ═══════ PROFILE INDICATOR ═══════
    // One lightweight whoami call decides whether to show the signed-in dot
    // on the profile icon. The result is cached in sessionStorage so we don't
    // re-fetch on every View Transition.
    const navProfile = document.getElementById('navProfile');
    if (navProfile) {
      navProfile.addEventListener('click', event => {
        const href = navProfile.getAttribute('href');
        if (!href) return;
        const url = new URL(href, window.location.href);
        if (url.origin !== window.location.origin
          || url.pathname !== window.location.pathname
          || url.search !== window.location.search
          || !url.hash) {
          return;
        }
        event.preventDefault();
        if (window.location.hash === url.hash) {
          window.dispatchEvent(new HashChangeEvent('hashchange'));
        } else {
          window.location.hash = url.hash;
        }
      });
      let cached: string | null = null;
      try { cached = sessionStorage.getItem('me:signed-in'); } catch (_) {}
      if (cached === '1') {
        navProfile.setAttribute('data-signed-in', 'true');
      }
      fetch('/api/me/whoami', { credentials: 'same-origin', cache: 'no-store' })
        .then(r => r.ok ? r.json() : null)
        .then(data => {
          const isIn = !!(data && data.ok && data.contact);
          if (isIn) {
            navProfile.setAttribute('data-signed-in', 'true');
            try { sessionStorage.setItem('me:signed-in', '1'); } catch (_) {}
          } else {
            navProfile.removeAttribute('data-signed-in');
            try { sessionStorage.removeItem('me:signed-in'); } catch (_) {}
          }
        })
        .catch(() => {});
    }

    // ═══════ MOSCOW-TIME TICKER (aligned to minute, battery-friendly) ═══════
    const timeEl = document.getElementById('navTime');
    let timeTimeout: number | undefined;
    let timeInterval: number | undefined;

    function formatMoscowTime() {
      try {
        return new Intl.DateTimeFormat('ru-RU', {
          hour: '2-digit',
          minute: '2-digit',
          hour12: false,
          timeZone: 'Europe/Moscow',
        }).format(new Date());
      } catch (_) {
        // Fallback: manual UTC+3 if Intl timeZone unsupported
        const now = new Date();
        const msk = new Date(now.getTime() + (now.getTimezoneOffset() + 180) * 60000);
        return String(msk.getHours()).padStart(2, '0') + ':' + String(msk.getMinutes()).padStart(2, '0');
      }
    }

    function renderTime() {
      if (timeEl) timeEl.textContent = formatMoscowTime();
    }

    if (timeEl) {
      renderTime();
      // Align first update to the next whole minute boundary, then tick every 60s.
      const msToNextMinute = 60_000 - (Date.now() % 60_000);
      timeTimeout = window.setTimeout(() => {
        renderTime();
        timeInterval = window.setInterval(renderTime, 60_000);
      }, msToNextMinute);
    }

    // #25: Same-page nav link scrolls to top
    const navLinksDesktop = Array.from(document.querySelectorAll<HTMLAnchorElement>('.nav-link'));
    navLinksDesktop.forEach(a => {
      a.addEventListener('click', (e) => {
        if (a.getAttribute('href') === window.location.pathname) {
          e.preventDefault();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });
    });
    const btmItems = Array.from(document.querySelectorAll<HTMLAnchorElement>('.btm-item[href]'));
    btmItems.forEach(a => {
      a.addEventListener('click', (e) => {
        if (a.getAttribute('href') === window.location.pathname) {
          e.preventDefault();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });
    });

    win.__academicSalonNavCleanup = function() {
      closeMenu();
      window.removeEventListener('scroll', onScroll);
      burger?.removeEventListener('click', onBurgerClick);
      backdrop?.removeEventListener('click', closeMenu);
      menuLinks.forEach(a => {
        const handler = menuLinkHandlers.get(a as HTMLAnchorElement);
        if (handler) {
          a.removeEventListener('click', handler);
        }
      });
      menuLinkHandlers.clear();
      document.removeEventListener('keydown', onKeyDown);
      if (handle && onHandleTouchStart) handle.removeEventListener('touchstart', onHandleTouchStart);
      if (handle && onHandleTouchMove) handle.removeEventListener('touchmove', onHandleTouchMove);
      if (handle && onHandleTouchEnd) handle.removeEventListener('touchend', onHandleTouchEnd);
      toggle?.removeEventListener('click', onThemeToggle);
      readingBtn?.removeEventListener('click', onReadingToggle);
      if (timeTimeout) window.clearTimeout(timeTimeout);
      if (timeInterval) window.clearInterval(timeInterval);
    };
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>

<script>
  /* ============================================================
     GLOBAL SEARCH PALETTE — boot
     Lazy: index загружается только когда юзер впервые открывает.
     Persistent across view-transitions: cleanup → re-bind.
     ============================================================ */
  type SearchDoc = { f: string; t: string; s: string; c: string; k: string };

  function initNavSearch() {
    const w = window as Window & { __navSearchCleanup?: () => void };
    if (typeof w.__navSearchCleanup === 'function') {
      w.__navSearchCleanup();
      w.__navSearchCleanup = undefined;
    }

    const overlay = document.getElementById('navSearchOverlay');
    const backdrop = document.getElementById('navSearchBackdrop');
    const dialog = overlay?.querySelector<HTMLElement>('.navsearch-dialog');
    const input = document.getElementById('navSearchInput') as HTMLInputElement | null;
    const list = document.getElementById('navSearchList') as HTMLOListElement | null;
    const meta = document.getElementById('navSearchMeta');
    const trigger = document.getElementById('navSearchBtn');

    if (!overlay || !input || !list) return;

    let docs: SearchDoc[] | null = null;
    let loadingPromise: Promise<SearchDoc[]> | null = null;
    let activeIndex = -1;
    let currentResults: SearchDoc[] = [];
    let isOpen = false;
    let prevFocus: HTMLElement | null = null;

    function loadIndex(): Promise<SearchDoc[]> {
      if (docs) return Promise.resolve(docs);
      if (loadingPromise) return loadingPromise;
      loadingPromise = fetch('/search-index.json', { credentials: 'omit' })
        .then((r) => r.ok ? r.json() : { docs: [] })
        .then((j) => {
          docs = (j.docs || []) as SearchDoc[];
          if (meta) meta.textContent = `Готово — ищем среди ${docs.length} работ`;
          return docs;
        })
        .catch(() => {
          docs = [];
          return docs;
        });
      return loadingPromise;
    }

    function escapeHtml(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function highlight(text: string, query: string): string {
      const safe = escapeHtml(text);
      if (!query) return safe;
      const q = query.toLowerCase();
      const lower = text.toLowerCase();
      let out = '', i = 0;
      while (i < text.length) {
        const idx = lower.indexOf(q, i);
        if (idx === -1) {
          out += escapeHtml(text.slice(i));
          break;
        }
        out += escapeHtml(text.slice(i, idx));
        out += '<mark>' + escapeHtml(text.slice(idx, idx + q.length)) + '</mark>';
        i = idx + q.length;
      }
      return out;
    }

    function score(doc: SearchDoc, words: string[]): number {
      const titleLow = doc.t.toLowerCase();
      const subjLow = doc.s.toLowerCase();
      const catLow = doc.c.toLowerCase();
      const typeLow = doc.k.toLowerCase();
      let total = 0;
      for (const w of words) {
        let wScore = 0;
        if (titleLow.includes(w)) wScore += 6;
        if (subjLow.includes(w)) wScore += 3;
        if (catLow.includes(w)) wScore += 2;
        if (typeLow.includes(w)) wScore += 2;
        if (titleLow.startsWith(w)) wScore += 4;
        if (wScore === 0) return 0;
        total += wScore;
      }
      return total;
    }

    function render(query: string) {
      if (!docs) {
        list!.innerHTML = '<li class="navsearch-empty">Загружаем индекс…</li>';
        return;
      }
      const trimmed = query.trim().toLowerCase();
      if (!trimmed) {
        list!.innerHTML = '';
        if (meta) meta.textContent = `Введите запрос — найдём по ${docs.length} работам`;
        currentResults = [];
        activeIndex = -1;
        return;
      }
      const words = trimmed.split(/\s+/).filter(Boolean);
      const scored: { d: SearchDoc; sc: number }[] = [];
      for (const d of docs) {
        const sc = score(d, words);
        if (sc > 0) scored.push({ d, sc });
      }
      scored.sort((a, b) => b.sc - a.sc);
      currentResults = scored.slice(0, 10).map((x) => x.d);
      activeIndex = currentResults.length ? 0 : -1;

      if (currentResults.length === 0) {
        list!.innerHTML = `<li class="navsearch-empty">Ничего не нашли. <a href="/order">Заказать похожую</a> или <a href="/catalog?q=${encodeURIComponent(trimmed)}">в каталог</a>.</li>`;
        if (meta) meta.textContent = '0 совпадений';
        return;
      }

      list!.innerHTML = currentResults.map((d, i) => {
        const meta2 = [d.k || d.c, d.s].filter(Boolean).join(' · ');
        return `<li class="navsearch-item${i === 0 ? ' is-active' : ''}" role="option" data-i="${i}">
          <a href="/doc/${escapeHtml(d.f)}" class="navsearch-link">
            <span class="navsearch-title">${highlight(d.t, trimmed)}</span>
            <span class="navsearch-meta-row">${escapeHtml(meta2)}</span>
          </a>
        </li>`;
      }).join('');

      if (meta) meta.textContent = `${scored.length} совпадени${scored.length === 1 ? 'е' : scored.length < 5 ? 'я' : 'й'}`;
    }

    /**
     * Inert background — modern browsers support `inert` natively,
     * which removes everything outside the dialog from the focus
     * order, screen-reader output, and pointer events.
     */
    function setBackgroundInert(on: boolean) {
      const targets = [
        document.getElementById('nav'),
        document.getElementById('main'),
        document.querySelector('.salon-footer'),
        document.querySelector('.btm-bar'),
      ].filter(Boolean) as HTMLElement[];
      for (const el of targets) {
        if (on) el.setAttribute('inert', '');
        else el.removeAttribute('inert');
      }
    }

    function open() {
      if (isOpen) return;
      isOpen = true;
      prevFocus = document.activeElement as HTMLElement | null;
      overlay!.hidden = false;
      overlay!.setAttribute('aria-hidden', 'false');
      requestAnimationFrame(() => overlay!.classList.add('is-open'));
      setBackgroundInert(true);
      // Focus on next tick so the field is editable immediately
      setTimeout(() => input!.focus(), 50);
      loadIndex().then(() => render(input!.value));
      document.body.style.overflow = 'hidden';
    }

    function close() {
      if (!isOpen) return;
      isOpen = false;
      overlay!.classList.remove('is-open');
      overlay!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      setBackgroundInert(false);
      setTimeout(() => {
        if (!isOpen) overlay!.hidden = true;
      }, 200);
      if (prevFocus && prevFocus.focus) prevFocus.focus();
    }

    function moveActive(delta: number) {
      if (currentResults.length === 0) return;
      activeIndex = (activeIndex + delta + currentResults.length) % currentResults.length;
      list!.querySelectorAll('.navsearch-item').forEach((el, i) => {
        el.classList.toggle('is-active', i === activeIndex);
      });
      const active = list!.querySelector<HTMLElement>('.navsearch-item.is-active');
      if (active) active.scrollIntoView({ block: 'nearest' });
    }

    function activate() {
      if (activeIndex < 0) return;
      const link = list!.querySelector<HTMLAnchorElement>(`.navsearch-item[data-i="${activeIndex}"] a`);
      if (link) link.click();
    }

    const onTriggerClick = () => open();
    const onBackdropClick = () => close();
    const onInput = () => render(input!.value);

    function onKey(e: KeyboardEvent) {
      const target = e.target as HTMLElement | null;
      const isTyping = target && (
        target.tagName === 'INPUT' ||
        target.tagName === 'TEXTAREA' ||
        target.isContentEditable
      );

      // "/" anywhere outside an input field opens the palette.
      if (!isOpen && !isTyping && e.key === '/' && !e.metaKey && !e.ctrlKey) {
        // Skip on /catalog — page-level search input owns "/" there.
        if (location.pathname.replace(/\/$/, '') === '/catalog') return;
        e.preventDefault();
        open();
        return;
      }

      // Cmd/Ctrl+K — universal command-palette shortcut.
      if (!isOpen && (e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        open();
        return;
      }

      if (!isOpen) return;

      if (e.key === 'Escape') {
        e.preventDefault();
        close();
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        moveActive(1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        moveActive(-1);
      } else if (e.key === 'Enter') {
        if (document.activeElement === input) {
          e.preventDefault();
          activate();
        }
      }
    }

    trigger?.addEventListener('click', onTriggerClick);
    backdrop?.addEventListener('click', onBackdropClick);
    input.addEventListener('input', onInput);
    document.addEventListener('keydown', onKey);

    w.__navSearchCleanup = () => {
      trigger?.removeEventListener('click', onTriggerClick);
      backdrop?.removeEventListener('click', onBackdropClick);
      input.removeEventListener('input', onInput);
      document.removeEventListener('keydown', onKey);
    };
  }

  initNavSearch();
  document.addEventListener('astro:after-swap', initNavSearch);
</script>
