---
import { D } from '../../data/catalog.js';

const ARCHIVE_CATEGORIES: readonly string[] = [
  'ВКР и дипломы',
  'Курсовые',
  'Рефераты',
  'Отчёты по практике',
  'Самостоятельные работы',
  'Эссе',
  'Конспекты лекций',
  'Методические материалы',
  'НПР',
  'Другое',
];
const archiveCounts: Record<string, number> = Object.fromEntries(
  ARCHIVE_CATEGORIES.map((c) => [c, D.filter((d: any) => d.category === c).length])
);
const archiveTotal: number = D.length;

const archiveShortType: Record<string, string> = {
  'ВКР и дипломы': 'ВКР',
  'Курсовые': 'Курс.',
  'Рефераты': 'Реф.',
  'Отчёты по практике': 'Практика',
  'Самостоятельные работы': 'Самост.',
  'Эссе': 'Эссе',
  'Конспекты лекций': 'Конспект',
  'Методические материалы': 'Методич.',
  'НПР': 'НПР',
  'Другое': 'Другое',
};

interface ArchiveRow {
  no: number;
  title: string;
  category: string;
  shortType: string;
  subject: string;
  year: string;
  href: string;
}
const yearRe = /(?:19|20)\d{2}/;
function extractYearStr(doc: any): string {
  const blob = [doc.filename, doc.newFilename, doc.title, doc.catalogTitle, doc.text]
    .filter(Boolean)
    .join(' ');
  const m = blob.match(yearRe);
  return m ? m[0] : '';
}

// Last 25 in D order (catalog.json's natural sort). Newest-first on the page.
const archiveSlice = D.slice(Math.max(0, D.length - 25));
const archiveRows: ArchiveRow[] = archiveSlice
  .map((doc: any, i: number): ArchiveRow => ({
    no: D.length - (archiveSlice.length - 1 - i),
    title: doc.catalogTitle || doc.title || doc.filename || 'Работа',
    category: doc.category || 'Другое',
    shortType: archiveShortType[doc.category] || doc.category || 'Другое',
    subject: doc.subject || '',
    year: extractYearStr(doc),
    href: '/doc/' + doc.file,
  }))
  .reverse();
---

  <section id="archive" class="archive rv" aria-label="Архив работ">
    <div class="archive-inner">
      <header class="chapter-head" data-reveal>
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">V</span>
          <span class="chapter-label">Caput Quintum · Глава пятая</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">Архив <em class="it">работ</em>.</h2>
          <p class="chapter-lede">Последние работы из&nbsp;публичного архива&nbsp;— для&nbsp;чтения, для&nbsp;вдохновения, для&nbsp;ориентира. Скачиваются без&nbsp;регистрации. Всего в&nbsp;архиве&nbsp;— <b class="archive-total">{archiveTotal}</b>&nbsp;работ.</p>
        </div>
      </header>

      <div class="archive-head">
        <div class="archive-filters" role="tablist" aria-label="Фильтр по категории">
          <button type="button" class="archive-filter is-active" data-cat="__all" aria-pressed="true">
            <span class="ft-name">Все</span>
            <span class="ft-n">{archiveTotal}</span>
          </button>
          {ARCHIVE_CATEGORIES.map((cat) => (
            <button type="button" class="archive-filter" data-cat={cat} aria-pressed="false">
              <span class="ft-name">{archiveShortType[cat] || cat}</span>
              <span class="ft-n">{archiveCounts[cat]}</span>
            </button>
          ))}
        </div>
        <div class="archive-count">
          показано <b id="archiveShown">{archiveRows.length}</b> из&nbsp;<b>{archiveTotal}</b>
        </div>
      </div>

      <div class="archive-index" aria-hidden="true">
        <div>№</div>
        <div>Название</div>
        <div>Тип</div>
        <div>Дисциплина</div>
        <div class="t-right">Год</div>
      </div>

      <div class="archive-list" id="archiveList" data-reveal data-reveal-delay="1">
        {archiveRows.map((r) => (
          <a class="archive-row" href={r.href} data-category={r.category} aria-label={`Открыть: ${r.title}`}>
            <div class="archive-no">№&nbsp;{r.no}</div>
            <div class="archive-title">{r.title}</div>
            <div class="archive-type">{r.shortType}</div>
            <div class="archive-field">{r.subject || '—'}</div>
            <div class="archive-year">{r.year ? <>{' '}<span class="star" aria-hidden="true">✦</span>{r.year}</> : '—'}</div>
          </a>
        ))}
      </div>

      <div class="archive-empty" id="archiveEmpty" hidden>
        В&nbsp;этой категории работ пока нет в&nbsp;публичном архиве. Покажем весь список&nbsp;— нажмите <em class="it">Все</em> или <a href="/catalog">откройте полный архив</a>.
      </div>

      <div class="archive-foot">
        <div class="archive-foot-line">Показано <b>{archiveRows.length}</b> из&nbsp;<b>{archiveTotal}</b> работ</div>
        <a href="/catalog" class="btn btn-ghost-gold btn-sm">
          Полный архив
          <svg viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8m-3-3l3 3-3 3" stroke="currentColor" stroke-width="1.2"/></svg>
        </a>
      </div>
    </div>
  </section>

<style>
  /* ================================================================
     ARCHIVE — editorial list with 10-category filter (step 2.7)
     Ported 1-to-1 from bundle. No legacy .archive-row/* collisions.
     ================================================================ */
  .archive {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px);
    background: var(--ink);
    position: relative;
  }
  .archive-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
  }
  .chapter-lede .archive-total {
    color: var(--gold);
    font-family: var(--fi);
    font-style: normal;
    font-weight: 500;
    font-feature-settings: "tnum";
  }

  /* Filters + counter */
  .archive-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
    gap: 24px;
    flex-wrap: wrap;
  }
  .archive-filters {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    max-width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .archive-filters::-webkit-scrollbar { display: none; }
  .archive-filter {
    padding: 10px 14px;
    background: transparent;
    border: 1px solid transparent;
    color: var(--mute);
    font-family: var(--fi);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color .4s var(--ease-silk), border-color .4s;
    line-height: 1;
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    white-space: nowrap;
  }
  .archive-filter:hover { color: var(--cream); }
  .archive-filter.is-active {
    color: var(--gold);
    border-color: var(--gold-line);
  }
  .archive-filter .ft-n {
    font-family: var(--fd);
    font-style: italic;
    font-size: 12px;
    color: var(--mute);
    letter-spacing: 0;
    text-transform: none;
    font-feature-settings: "tnum";
  }
  .archive-filter.is-active .ft-n { color: var(--gold); }
  .archive-count {
    font-family: var(--fd);
    font-style: italic;
    font-size: 15px;
    color: var(--mute);
    white-space: nowrap;
  }
  .archive-count b {
    color: var(--gold);
    font-style: normal;
    font-family: var(--fi);
    font-feature-settings: "tnum";
    font-weight: 500;
    font-size: 13px;
    padding: 0 2px;
  }

  /* Header index row + list */
  .archive-index {
    display: grid;
    grid-template-columns: 72px 2fr 1fr 1fr 80px;
    gap: 20px;
    padding: 12px 20px;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mute);
    border-bottom: 1px solid var(--line);
  }
  .archive-index .t-right { text-align: right; }
  @media (max-width: 900px) {
    .archive-index { display: none; }
  }

  .archive-list {
    display: flex;
    flex-direction: column;
  }
  .archive-row {
    display: grid;
    grid-template-columns: 72px 2fr 1fr 1fr 80px;
    gap: 20px;
    padding: 20px;
    border-bottom: 1px solid var(--line);
    align-items: center;
    transition: background .4s var(--ease-silk);
    position: relative;
    text-decoration: none;
    color: inherit;
  }
  .archive-row::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--gold);
    transform: scaleY(0);
    transition: transform .5s var(--ease-silk);
  }
  .archive-row:hover::before { transform: scaleY(1); }
  .archive-row:hover { background: var(--gold-soft); }
  .archive-row:hover .archive-title { color: var(--gold); transform: translateX(6px); }
  .archive-title { transition: color .4s var(--ease-silk), transform .4s var(--ease-silk); }

  .archive-no {
    font-family: var(--fd);
    font-style: italic;
    font-size: 15px;
    color: var(--mute);
    font-feature-settings: "tnum";
    line-height: 1;
  }
  .archive-title {
    font-family: var(--fd);
    font-size: clamp(16px, 1.3vw, 19px);
    color: var(--cream);
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: -0.005em;
    transition: color .4s;
  }
  .archive-type {
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .archive-field {
    font-family: var(--fd);
    font-style: italic;
    font-size: 14px;
    color: var(--cream-2);
  }
  .archive-year {
    font-family: var(--fd);
    font-style: italic;
    font-size: 14px;
    color: var(--mute);
    text-align: right;
    font-feature-settings: "onum";
    white-space: nowrap;
  }
  .archive-year .star {
    color: var(--gold);
    margin-right: 4px;
    font-style: normal;
  }

  @media (max-width: 900px) {
    .archive-row {
      grid-template-columns: auto 1fr auto;
      grid-template-areas:
        "no title year"
        ".  meta  meta";
      gap: 6px 12px;
      padding: 16px 0;
    }
    .archive-no { grid-area: no; }
    .archive-title { grid-area: title; font-size: 15px; }
    .archive-year { grid-area: year; }
    .archive-type, .archive-field { grid-area: meta; display: inline; }
    .archive-type { margin-right: 10px; }
  }

  .archive-empty {
    padding: 48px 20px;
    text-align: center;
    font-family: var(--fd);
    font-style: italic;
    font-size: 17px;
    color: var(--cream-2);
    border-bottom: 1px solid var(--line);
  }
  .archive-empty a {
    color: var(--gold);
    border-bottom: 1px solid var(--gold-line);
  }

  .archive-foot {
    margin-top: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
  }
  .archive-foot-line {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(16px, 1.6vw, 18px);
    color: var(--cream-2);
  }
  .archive-foot-line b {
    color: var(--gold);
    font-weight: 400;
    font-style: normal;
    font-family: var(--fi);
    font-feature-settings: "tnum";
    font-size: 15px;
    padding: 0 2px;
  }
  .archive-foot .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .archive-foot .btn svg { width: 12px; height: 12px; }
</style>

<!-- Plain JS in /public/scripts/ — Astro v6's hoisted-script bundler
     drops <script> blocks from this component. See Calendar.astro for
     the same fix. -->
<script src="/scripts/archive-filter.js" defer></script>

