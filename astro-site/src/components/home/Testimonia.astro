---
import { reviewImages } from '../../data/reviewImages';

const row1 = reviewImages.filter((r) => r.row === 1);
const row2 = reviewImages.filter((r) => r.row === 2);

// Aggregate rating from the explicit grades only — keeps the visible
// number defensible (matches what's actually in screenshots). Fed
// into both the visible badge and the AggregateRating JSON-LD which
// Base.astro doesn't carry by default.
const graded = reviewImages.filter((r) => typeof r.rating === 'number');
const ratingValue = graded.length
  ? +(graded.reduce((s, r) => s + (r.rating || 0), 0) / graded.length).toFixed(1)
  : 5;
const reviewCount = reviewImages.length;
const fullStars = Math.round(ratingValue);
---

  <!-- AggregateRating schema — surfaces the « ★ 4.7 · 10 reviews »
       line in SERP rich results. Visible content below mirrors it
       exactly; bestRating: 5, worstRating: 4 (we don't publish anything
       lower because we don't have anything lower yet). -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Service',
    'name': 'Академический Салон — мастерская студенческих работ',
    'provider': {
      '@type': 'Organization',
      'name': 'Академический Салон',
      'url': 'https://bibliosaloon.ru',
    },
    'areaServed': 'RU',
    'aggregateRating': {
      '@type': 'AggregateRating',
      'ratingValue': ratingValue,
      'reviewCount': reviewCount,
      'bestRating': 5,
      'worstRating': 4,
    },
  })} />

  <section id="testimonia" class="reviews testimonia rv" aria-label="Свидетельства">
    <header class="chapter-head testimonia-head" data-reveal>
      <div class="chapter-num">
        <span class="roman" aria-hidden="true">VII</span>
        <span class="chapter-label">Caput Septimum · Глава седьмая</span>
      </div>
      <div class="chapter-title-block">
        <h2 class="chapter-h">Свидетельства и <em class="it">гарантии</em>.</h2>
        <p class="chapter-lede">Не&nbsp;выученные «спасибо за&nbsp;работу», а&nbsp;живые скриншоты переписок. Авторы разрешили опубликовать&nbsp;— хотели поделиться. Тапните по&nbsp;любой, чтобы открыть на&nbsp;весь экран.</p>
        <p class="testimonia-rating" aria-label={`Средняя оценка: ${ratingValue} из 5, ${reviewCount} свидетельств`}>
          <span class="testimonia-rating-stars" aria-hidden="true">
            {Array.from({ length: 5 }).map((_, i) => (
              <span class={i < fullStars ? 'star is-on' : 'star'}>★</span>
            ))}
          </span>
          <span class="testimonia-rating-val">{ratingValue}</span>
          <span class="testimonia-rating-sep" aria-hidden="true">/</span>
          <span class="testimonia-rating-best">5</span>
          <span class="testimonia-rating-dot" aria-hidden="true">·</span>
          <span class="testimonia-rating-count">{reviewCount} свидетельств</span>
        </p>
      </div>
    </header>
    <div class="reviews-wall">
      <!-- Row 1: scrolls left -->
      <div class="rw-row rw-row--left">
        <div class="rw-track">
          {row1.map((r) => (
            <img src={`/reviews/${r.file}`} alt={r.alt} width={r.w} height={r.h} class="rw-img" loading="lazy" decoding="async" fetchpriority="low" />
          ))}
          {/* Duplicate set — keeps the marquee loop seamless. */}
          {row1.map((r) => (
            <img src={`/reviews/${r.file}`} alt="" width={r.w} height={r.h} class="rw-img" aria-hidden="true" loading="lazy" decoding="async" fetchpriority="low" />
          ))}
        </div>
      </div>
      <!-- Row 2: scrolls right -->
      <div class="rw-row rw-row--right">
        <div class="rw-track">
          {row2.map((r) => (
            <img src={`/reviews/${r.file}`} alt={r.alt} width={r.w} height={r.h} class="rw-img" loading="lazy" decoding="async" fetchpriority="low" />
          ))}
          {row2.map((r) => (
            <img src={`/reviews/${r.file}`} alt="" width={r.w} height={r.h} class="rw-img" aria-hidden="true" loading="lazy" decoding="async" fetchpriority="low" />
          ))}
        </div>
      </div>
    </div>

    <!-- Lightbox — click to enlarge any review -->
    <div class="lightbox" id="reviewLightbox" aria-hidden="true" inert>
      <button class="lb-close" id="lbClose" aria-label="Закрыть">&times;</button>
      <button class="lb-prev" id="lbPrev" aria-label="Назад">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <img class="lb-img" id="lbImg" alt="" width="1200" height="1600" loading="lazy" />
      <button class="lb-next" id="lbNext" aria-label="Вперёд">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
      </button>
      <span class="lb-counter" id="lbCounter"></span>
    </div>

    <!-- ── Guarantees (step 2.9) ── -->
    <hr class="testimonia-rule" aria-hidden="true" />
    <div class="guarantees" role="list" aria-label="Гарантии мастерской">
      <article class="guarantee" role="listitem">
        <span class="guarantee-mark" aria-hidden="true">§&nbsp;I</span>
        <h3>Оригинальность</h3>
        <p>Ручное письмо по&nbsp;вашей теме. Проверка антиплагиатом входит в&nbsp;работу; отдельный отчёт&nbsp;— опция в&nbsp;калькуляторе.</p>
      </article>
      <article class="guarantee" role="listitem">
        <span class="guarantee-mark" aria-hidden="true">§&nbsp;II</span>
        <h3>До&nbsp;защиты</h3>
        <p>Правки после научрука&nbsp;— бесплатно. Если попросят переделать главу&nbsp;— переделываем.</p>
      </article>
      <article class="guarantee" role="listitem">
        <span class="guarantee-mark" aria-hidden="true">§&nbsp;III</span>
        <h3>Правки</h3>
        <p>Бесплатные правки по&nbsp;замечаниям в&nbsp;рамках согласованного формата. Новое ТЗ&nbsp;— отдельный разговор.</p>
      </article>
      <article class="guarantee" role="listitem">
        <span class="guarantee-mark" aria-hidden="true">§&nbsp;IV</span>
        <h3>Конфиденциальность</h3>
        <p>Заказ не&nbsp;публикуется в&nbsp;архиве, данные не&nbsp;передаются третьим лицам. Имя и&nbsp;тема&nbsp;— только между нами.</p>
      </article>
    </div>
  </section>

<style>
  /* ================================================================
     TESTIMONIA — review wall + lightbox + chapter framing + guarantees
     Combined from 4 source blocks in the original index.astro:
     - 2. REVIEWS (wall)         629-708
     - LIGHTBOX (fullscreen)     710-816
     - IV. TESTIMONIA (chapter)  944-958
     - TESTIMONIA — additions    1376-1447
     ================================================================ */
  .reviews {
    padding: 120px 0;
    background: var(--bg);
    overflow: hidden;
  }

  .reviews-head {
    text-align: center;
    padding: 0 24px;
    margin-bottom: 48px;
  }

  .reviews-sub {
    font: 400 14px/1.6 var(--fi);
    color: var(--t3);
    margin-top: 12px;
  }

  /* Auto-scrolling review wall */
  .reviews-wall {
    display: flex;
    flex-direction: column;
    gap: 12px;
    mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
  }

  .rw-row {
    overflow: hidden;
  }

  .rw-track {
    display: flex;
    gap: 12px;
    width: max-content;
  }

  .rw-row--left .rw-track {
    animation: rw-scroll-left 50s linear infinite;
  }

  .rw-row--right .rw-track {
    animation: rw-scroll-right 55s linear infinite;
  }

  @keyframes rw-scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes rw-scroll-right {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  .rw-img {
    height: 200px;
    width: auto;
    flex-shrink: 0;
    display: block;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,.06);
    object-fit: cover;
    cursor: pointer;
    transition: transform .3s var(--ease), border-color .3s;
  }

  .rw-img:hover {
    transform: scale(1.03);
    border-color: rgba(212,175,55,.15);
    box-shadow: 0 0 0 2px rgba(255,255,255,.15);
  }

  /* Pause on hover */
  .reviews-wall:hover .rw-track {
    animation-play-state: paused;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,.92);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    opacity: 0;
    visibility: hidden;
    transition: opacity .3s ease, visibility .3s;
    padding: 48px;
  }

  .lightbox.is-open {
    opacity: 1;
    visibility: visible;
  }

  .lb-img {
    max-width: min(90vw, 500px);
    max-height: 85vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 12px;
    box-shadow: 0 32px 80px rgba(0,0,0,.5);
    transition: transform .3s ease;
  }

  .lightbox.is-open .lb-img {
    animation: lb-enter .3s ease-out;
  }

  @keyframes lb-enter {
    from { opacity: 0; transform: scale(.92); }
    to { opacity: 1; transform: scale(1); }
  }

  .lb-close {
    position: absolute;
    top: 16px;
    right: 20px;
    width: 44px;
    height: 44px;
    border: none;
    background: none;
    color: var(--t2);
    font-size: 28px;
    cursor: pointer;
    z-index: 2;
    transition: color .2s;
  }

  .lb-close:hover { color: #fff; }

  .lb-prev,
  .lb-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 50%;
    background: rgba(255,255,255,.05);
    color: var(--t2);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: border-color .2s, color .2s, background .2s;
  }

  .lb-prev { left: 20px; }
  .lb-next { right: 20px; }

  .lb-prev:hover,
  .lb-next:hover {
    border-color: rgba(255,255,255,.3);
    color: #fff;
    background: rgba(255,255,255,.1);
  }

  .lb-counter {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font: 400 13px/1 var(--fm);
    color: var(--t3);
    letter-spacing: .1em;
  }

  @media (max-width: 639px) {
    .lightbox { padding: 20px; }
    .lb-prev, .lb-next { width: 40px; height: 40px; }
    .lb-prev { left: 8px; }
    .lb-next { right: 8px; }
    .lb-img { max-width: 92vw; }
  }

  .testimonia {
    padding-top: clamp(80px, 12vw, 160px);
    padding-bottom: clamp(80px, 12vw, 160px);
    border-top: 1px solid var(--brd);
  }
  .testimonia-head {
    max-width: var(--max-w);
    margin: 0 auto clamp(40px, 6vw, 72px);
    padding: 0 clamp(20px, 4vw, 48px);
  }

  /* AggregateRating visible badge — mirrors the Service.aggregateRating
     JSON-LD above so search engines see real DOM evidence. */
  .testimonia-rating {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    margin: 18px 0 0;
    padding: 8px 14px;
    border: 1px solid var(--gold-line);
    border-radius: 999px;
    background: var(--gold-soft);
    font: 400 14px/1 var(--fd);
    color: var(--cream-2);
    font-feature-settings: 'tnum';
  }
  .testimonia-rating-stars {
    display: inline-flex;
    gap: 1px;
    transform: translateY(2px);
    font-size: 14px;
    line-height: 1;
    color: var(--mute-2, #5A5344);
  }
  .testimonia-rating-stars .star.is-on { color: var(--gold-ref); }
  .testimonia-rating-val {
    font-family: var(--fd);
    font-style: italic;
    font-size: 18px;
    color: var(--gold-ref);
    letter-spacing: -.01em;
  }
  .testimonia-rating-sep,
  .testimonia-rating-dot { color: var(--mute); }
  .testimonia-rating-best { color: var(--cream-2); font-size: 13px; }
  .testimonia-rating-count {
    font-family: var(--fm);
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--mute);
  }

  .testimonia-rule {
    border: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-line) 20%, var(--gold-line) 80%, transparent);
    margin: clamp(60px, 8vw, 96px) 0 0;
  }

  .guarantees {
    margin-top: clamp(48px, 6vw, 80px);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  @media (max-width: 1000px) { .guarantees { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px)  { .guarantees { grid-template-columns: 1fr; } }

  .guarantee {
    background: var(--ink);
    padding: clamp(28px, 4vw, 44px) clamp(22px, 3vw, 36px);
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: background .5s var(--ease-silk);
    min-height: 240px;
    position: relative;
  }
  .guarantee:hover { background: var(--ink-2); }
  .guarantee::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold);
    transition: width .7s var(--ease-silk);
  }
  .guarantee:hover::before { width: 100%; }

  .guarantee-mark {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(28px, 3vw, 36px);
    color: var(--gold);
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .guarantee h3 {
    font-family: var(--fd);
    font-size: clamp(20px, 2vw, 24px);
    font-weight: 500;
    color: var(--cream);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .guarantee p {
    font-family: var(--fd);
    font-size: 15px;
    line-height: 1.55;
    color: var(--mute);
    letter-spacing: 0.005em;
    margin: 0;
    margin-top: auto;
  }
</style>
