---
const monthNames = ['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];
const calendarNow = new Date();
const calendarCurMonth = calendarNow.getMonth();

type CalendarState = 'closed' | 'tight' | 'free';
interface CalendarCell {
  name: string;
  state: CalendarState;
  booked: number;
  title: string;
  sub: string;
}
/* Default state: past months are 'closed', everything from the current
   month onward is 'free' / 'открыто'. Admin can override individual
   months via /admin/calendar (per-day overrides bubble up to the row
   here through applyMonthOverrides() — see <script> below). The old
   90/80/50 % mock numbers were misleading because they implied a
   booking system the site doesn't actually have. */
const calendarCells: CalendarCell[] = monthNames.map((name, i): CalendarCell => {
  if (i < calendarCurMonth) {
    return { name, state: 'closed', booked: 0, title: '—', sub: 'прошёл' };
  }
  return { name, state: 'free', booked: 0, title: '', sub: 'открыто' };
});
---

  <section
    id="calendar"
    class="calendar rv"
    aria-label="Календарь мастерской"
    data-calendar-year={calendarNow.getFullYear()}
    data-calendar-month={calendarCurMonth}
    data-calendar-today={calendarNow.getDate()}
  >
    <div class="calendar-inner">
      <header class="chapter-head" data-reveal>
        <div class="chapter-num">
          <span class="roman" aria-hidden="true">II</span>
          <span class="chapter-label">Caput Secundum · Глава вторая</span>
        </div>
        <div class="chapter-title-block">
          <h2 class="chapter-h">Календарь <em class="it">мастерской</em>.</h2>
          <p class="chapter-lede">Загрузка авторских работ по&nbsp;месяцам MMXXVI&nbsp;— чтобы вы&nbsp;видели, плотно&nbsp;ли идёт месяц, и&nbsp;могли написать заранее, если&nbsp;нужен спокойный срок.</p>
        </div>
      </header>

      <div class="calendar-intro">
        <p class="chapter-lede">
          Это не&nbsp;система бронирования, а&nbsp;честная карта загрузки. Пик приходится на&nbsp;май и&nbsp;декабрь (сессия и&nbsp;защиты); спокойнее всего&nbsp;— в&nbsp;июле, августе, феврале.
        </p>
        <div class="calendar-legend" aria-hidden="true">
          <div class="row"><span class="dot free"></span><span>окна открыты</span></div>
          <div class="row"><span class="dot tight"></span><span>плотно</span></div>
          <div class="row"><span class="dot closed"></span><span>прошёл</span></div>
        </div>
      </div>

      <div class="calendar-track">
        <div class="calendar-months" role="list" id="calendarMonths">
          {calendarCells.map((m, idx) => (
            <button
              type="button"
              class:list={['month', m.state]}
              style={`--booked: ${m.booked}%`}
              role="listitem"
              data-month-index={idx}
              data-month-name={m.name}
              data-month-state={m.state}
              aria-label={`${m.name} — ${m.sub}. Открыть дни месяца`}
            >
              <span class="month-name">{m.name}</span>
              <span class="month-node" aria-hidden="true"></span>
              <span class="month-stat">
                <b>{m.title}</b>
                {m.sub}
              </span>
              <span class="month-bar" aria-hidden="true"></span>
            </button>
          ))}
        </div>
      </div>

      <aside class="calendar-hint">
        <div class="roman" aria-hidden="true">!</div>
        <div class="body">
          <h3>Напишите заранее&nbsp;— и&nbsp;окно подберём</h3>
          <p>Чем раньше расскажете о&nbsp;задаче, тем спокойнее обоим: подберём автора под тему, а&nbsp;вы&nbsp;не&nbsp;упрётесь в&nbsp;срочность.</p>
        </div>
        <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-gold btn-sm">Написать в&nbsp;Telegram</a>
      </aside>
    </div>

    <!-- Day grid dialog — opens when user clicks on a month -->
    <dialog class="cal-modal" id="calModal" aria-labelledby="calModalTitle">
      <div class="cal-modal-body">
        <button type="button" class="cal-close" id="calModalClose" aria-label="Закрыть">
          <svg viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.3"/></svg>
        </button>

        <header class="cal-modal-head">
          <span class="cal-modal-eyebrow" aria-hidden="true">
            <span class="rule"></span>
            <span class="word">Месяц</span>
          </span>
          <h3 class="cal-modal-title" id="calModalTitle">—</h3>
          <p class="cal-modal-sub" id="calModalSub">Декоративная карта загрузки. Точные даты&nbsp;— в&nbsp;Telegram.</p>
        </header>

        <div class="cal-modal-legend" aria-hidden="true">
          <span class="row"><span class="dot free"></span>свободно</span>
          <span class="row"><span class="dot tight"></span>плотно</span>
          <span class="row"><span class="dot busy"></span>занято</span>
          <span class="row"><span class="dot today"></span>сегодня</span>
          <span class="row"><span class="dot closed"></span>прошёл</span>
        </div>

        <div class="cal-modal-weekdays" aria-hidden="true">
          <span>пн</span><span>вт</span><span>ср</span><span>чт</span><span>пт</span><span>сб</span><span>вс</span>
        </div>
        <div class="cal-modal-grid" id="calModalGrid" role="grid" aria-label="Дни месяца"></div>

        <footer class="cal-modal-foot">
          <p class="cal-modal-note" id="calModalNote">—</p>
          <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-gold btn-sm">
            Подобрать дату в&nbsp;Telegram
          </a>
        </footer>
      </div>
    </dialog>
  </section>

<style>
  /* ================================================================
     CALENDAR — decorative 12-month load timeline (step 2.3)
     No legacy .calendar-* collisions, classes ported 1-to-1 from
     bundle. Cells are inert (role=listitem, no cursor/click).
     ================================================================ */
  .calendar {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px);
    background: var(--ink);
    position: relative;
  }
  .calendar-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
  }

  .calendar-intro {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: clamp(32px, 5vw, 60px);
    align-items: end;
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--line);
  }
  .calendar-legend {
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .calendar-legend .row {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .calendar-legend .dot {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
    border-radius: 50%;
  }
  .calendar-legend .dot.free {
    background: var(--gold);
    box-shadow: 0 0 8px var(--gold-glow);
  }
  .calendar-legend .dot.tight { background: var(--cream-3); }
  .calendar-legend .dot.closed {
    background: var(--mute-2);
    border: 1px solid var(--mute);
    box-sizing: border-box;
  }

  .calendar-track {
    position: relative;
    padding: 60px 0;
  }
  .calendar-track::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-line) 8%, var(--gold-line) 92%, transparent);
  }

  .calendar-months {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 0;
    position: relative;
  }
  .month {
    position: relative;
    padding: 10px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform .6s var(--ease-silk);
    min-width: 0;
    /* Reset native <button> chrome so the dots stand alone instead of
       sitting in a row of grey rectangles with white outset borders. */
    background: transparent;
    border: 0;
    appearance: none;
    -webkit-appearance: none;
    color: inherit;
    cursor: pointer;
    font: inherit;
  }
  .month:hover { transform: translateY(-2px); }

  .month-name {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(14px, 1.2vw, 17px);
    color: var(--cream);
    margin-bottom: 36px;
    line-height: 1;
    transition: color .4s;
  }
  .month.closed .month-name { color: var(--mute); }
  .month:hover .month-name { color: var(--gold); }

  .month-node {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 16px;
    height: 16px;
    background: var(--ink);
    border: 1px solid var(--gold-line);
    border-radius: 50%;
    transition: transform .4s var(--ease-silk), box-shadow .4s;
    z-index: 2;
  }
  .month.free .month-node {
    background: var(--gold);
    border-color: var(--gold);
    box-shadow:
      0 0 0 5px rgba(201, 162, 76, 0.18),
      0 0 0 10px rgba(201, 162, 76, 0.06),
      0 0 24px var(--gold-glow);
  }
  .month.tight .month-node {
    background: var(--cream-3);
    border-color: var(--cream-3);
    box-shadow: 0 0 0 4px rgba(200, 188, 160, 0.16);
  }
  .month.closed .month-node {
    background: var(--mute-2);
    border-color: var(--mute);
  }
  .month:hover .month-node { transform: translate(-50%, -50%) scale(1.4); }

  .month-stat {
    margin-top: 36px;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cream-3);
    line-height: 1.3;
    padding: 0 4px;
  }
  .month-stat b {
    font-family: var(--fd);
    font-style: italic;
    font-size: 15px;
    color: var(--gold);
    font-weight: 400;
    display: block;
    letter-spacing: 0;
    margin-bottom: 4px;
    text-transform: none;
  }
  .month.closed .month-stat { color: var(--mute); }
  .month.closed .month-stat b { color: var(--mute); }

  .month-bar {
    margin-top: 8px;
    width: 70%;
    height: 2px;
    background: var(--line-2);
    position: relative;
    overflow: hidden;
  }
  .month-bar::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: var(--booked, 40%);
    background: var(--gold);
  }
  .month.closed .month-bar::before { background: var(--mute); }
  .month.tight .month-bar::before { background: var(--cream-3); }

  @media (max-width: 1000px) {
    .calendar-months { grid-template-columns: repeat(6, 1fr); gap: 40px 0; }
    .calendar-track::before { display: none; }
  }
  @media (max-width: 600px) {
    .calendar-months { grid-template-columns: repeat(3, 1fr); gap: 32px 0; }
    .month-name { margin-bottom: 28px; }
    .month-stat { margin-top: 28px; font-size: 8px; }
  }
  @media (max-width: 900px) {
    .calendar-intro { grid-template-columns: 1fr; gap: 24px; }
  }

  /* Bottom hint card */
  .calendar-hint {
    margin-top: clamp(48px, 6vw, 72px);
    padding: clamp(28px, 4vw, 40px);
    border: 1px solid var(--gold-line);
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 32px;
    align-items: center;
    background: linear-gradient(180deg, var(--gold-soft), transparent);
    position: relative;
  }
  .calendar-hint::before {
    content: "";
    position: absolute;
    top: 0;
    left: 20px;
    width: 32px;
    height: 1px;
    background: var(--gold);
  }
  .calendar-hint .roman {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(48px, 6vw, 60px);
    line-height: 0.9;
    color: var(--gold);
  }
  .calendar-hint .body h3 {
    font-family: var(--fd);
    font-weight: 500;
    font-size: clamp(20px, 2vw, 26px);
    margin-bottom: 8px;
    color: var(--cream);
    letter-spacing: -0.01em;
  }
  .calendar-hint .body p {
    font-family: var(--fd);
    font-size: 15px;
    font-style: italic;
    color: var(--cream-2);
    margin: 0;
  }
  @media (max-width: 720px) {
    .calendar-hint {
      grid-template-columns: 1fr;
      text-align: left;
      padding: 24px;
      gap: 18px;
    }
    .calendar-hint .btn { justify-self: start; }
  }

  .cal-modal {
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--cream);
    max-width: min(640px, 92vw);
    width: 100%;
    max-height: 90vh;
    margin: auto;
    overflow: visible;
  }
  .cal-modal::backdrop {
    background: rgba(10, 9, 8, 0.82);
    backdrop-filter: blur(16px) saturate(140%);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
  }
  .cal-modal:not([open]) { display: none; }
  .cal-modal-body {
    background: var(--ink-2);
    border: 1px solid var(--gold-line);
    padding: clamp(24px, 4vw, 40px);
    position: relative;
    max-height: 90vh;
    overflow-y: auto;
  }
  .cal-modal-body::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }

  .cal-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 36px;
    height: 36px;
    border: 1px solid var(--line-2);
    background: transparent;
    color: var(--mute);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color .4s var(--ease-silk), border-color .4s;
  }
  .cal-close:hover { color: var(--gold); border-color: var(--gold); }
  .cal-close svg { width: 12px; height: 12px; }

  .cal-modal-head {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 24px;
    max-width: calc(100% - 48px);
  }
  .cal-modal-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .cal-modal-eyebrow .rule {
    width: 24px;
    height: 1px;
    background: var(--gold);
  }
  .cal-modal-title {
    font-family: var(--fd);
    font-size: clamp(32px, 4vw, 44px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--cream);
    margin: 0;
  }
  .cal-modal-title em {
    font-style: italic;
    color: var(--gold);
  }
  .cal-modal-sub {
    font-family: var(--fd);
    font-style: italic;
    font-size: 15px;
    line-height: 1.45;
    color: var(--mute);
    margin: 0;
  }

  .cal-modal-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    padding: 12px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    margin-bottom: 18px;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .cal-modal-legend .row {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .cal-modal-legend .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .cal-modal-legend .dot.free   { background: var(--gold); box-shadow: 0 0 6px var(--gold-glow); }
  .cal-modal-legend .dot.tight  { background: rgba(201,162,76, 0.45); border: 1px solid var(--gold); box-sizing: border-box; }
  .cal-modal-legend .dot.busy   { background: var(--gold); border: 1px solid var(--gold); box-sizing: border-box; opacity: .85; }
  .cal-modal-legend .dot.today  { background: var(--gold-hi); outline: 1px solid var(--gold); outline-offset: 2px; }
  .cal-modal-legend .dot.closed { background: var(--mute-2); border: 1px solid var(--mute); box-sizing: border-box; }

  .cal-modal-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
    margin-bottom: 8px;
    font-family: var(--fm);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mute);
    text-align: center;
  }

  .cal-modal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  .cal-day {
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--fd);
    font-size: clamp(14px, 1.6vw, 17px);
    font-feature-settings: "tnum";
    color: var(--cream-2);
    position: relative;
    border: 1px solid var(--gold-line);
    border-radius: 6px;
    background: var(--ink-3);
    transition: background .3s var(--ease-silk), color .3s, border-color .3s, transform .25s var(--ease-silk);
  }
  .cal-day.empty {
    background: transparent;
    border-color: transparent;
  }
  .cal-day.closed {
    color: var(--mute-2);
    background: transparent;
    border-color: rgba(132, 123, 102, 0.18);
    text-decoration: line-through;
    text-decoration-color: rgba(132, 123, 102, 0.4);
  }
  .cal-day.free {
    background: var(--ink-3);
    border-color: rgba(201, 162, 76, 0.22);
    color: var(--cream);
  }
  /* Weekends are quieter — adds visual rhythm even without overrides. */
  .cal-day.free.weekend {
    background: var(--ink-2);
    border-color: rgba(201, 162, 76, 0.12);
    color: var(--cream-3);
  }
  .cal-day.tight {
    background: linear-gradient(135deg, rgba(201,162,76, 0.20), rgba(201,162,76, 0.10));
    color: var(--cream);
    border-color: rgba(201,162,76, 0.48);
    box-shadow: inset 0 0 0 1px rgba(201,162,76, 0.18);
  }
  .cal-day.busy {
    background: linear-gradient(135deg, rgba(201,162,76, 0.42), rgba(201,162,76, 0.24));
    color: var(--ink);
    border-color: rgba(201,162,76, 0.78);
    font-weight: 500;
  }
  .cal-day.today {
    background: var(--gold);
    color: var(--ink);
    font-weight: 500;
    border-color: var(--gold);
    box-shadow: 0 0 0 2px var(--gold-glow), 0 0 24px var(--gold-glow);
    transform: scale(1.04);
  }
  [data-theme="light"] .cal-day.free {
    background: var(--ink-2);
    border-color: rgba(122,95,18, 0.18);
  }
  [data-theme="light"] .cal-day.tight {
    background: linear-gradient(135deg, rgba(122,95,18, 0.14), rgba(122,95,18, 0.06));
    border-color: rgba(122,95,18, 0.38);
  }
  [data-theme="light"] .cal-day.busy {
    background: linear-gradient(135deg, rgba(122,95,18, 0.28), rgba(122,95,18, 0.14));
    border-color: rgba(122,95,18, 0.6);
    color: var(--cream);
  }
  .cal-day.free:hover,
  .cal-day.tight:hover,
  .cal-day.busy:hover {
    border-color: var(--gold);
    color: var(--gold);
    cursor: default;
  }

  .cal-modal-foot {
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    align-items: center;
  }
  .cal-modal-note {
    font-family: var(--fd);
    font-style: italic;
    font-size: 14px;
    line-height: 1.4;
    color: var(--cream-2);
    margin: 0;
    max-width: 40ch;
  }
  @media (max-width: 560px) {
    .cal-modal-foot { grid-template-columns: 1fr; }
    .cal-modal-note { text-align: left; }
  }
</style>


<!-- Plain JS in /public/scripts/ — Astro v6's hoisted-script bundler
     silently drops <script> blocks from this component (likely some
     interaction with the second <style is:global> we used to have
     here); a static src= is the most reliable shape. -->
<script src="/scripts/calendar-runtime.js" defer></script>
