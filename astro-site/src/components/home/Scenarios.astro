---
import { ORDER_PACKAGES } from '../../data/orderPackages';
---

<section id="scenarios" class="scenarios rv" aria-labelledby="scenariosTitle">
  <div class="scenarios-inner">
    <header class="chapter-head" data-reveal>
      <div class="chapter-num">
        <span class="roman" aria-hidden="true">III</span>
        <span class="chapter-label">Caput Tertium · Глава третья</span>
      </div>
      <div class="chapter-title-block">
        <h2 class="chapter-h" id="scenariosTitle">Учебные <em class="it">сценарии</em>.</h2>
        <p class="chapter-lede">Не&nbsp;скидочный набор, а&nbsp;способ собрать учебную нагрузку в&nbsp;один план&nbsp;— один куратор, один стиль, общий дедлайн&nbsp;— без хаоса разрозненных переписок.</p>
      </div>
    </header>

    <div class="scenarios-grid" role="list">
      {ORDER_PACKAGES.map((pkg, i) => (
        <article class="scenario" role="listitem" data-reveal data-reveal-delay={i % 2}>
          <span class="scenario-mark" aria-hidden="true"></span>

          <div class="scenario-head">
            <span class="scenario-eyebrow" aria-hidden="true">
              <span class="rule"></span>
              <span class="word">Сценарий</span>
            </span>
            <h3 class="scenario-title">{pkg.name}</h3>
          </div>

          <p class="scenario-outcome">{pkg.outcome}</p>

          <ul class="scenario-items">
            {pkg.items.map((item) => (
              <li>
                <span class="dot" aria-hidden="true"></span>
                <span class="t">{item}</span>
              </li>
            ))}
          </ul>

          <p class="scenario-audience">{pkg.audience}</p>

          <footer class="scenario-foot">
            <div class="scenario-meta">
              <span class="scenario-price">от&nbsp;{pkg.priceFrom.toLocaleString('ru-RU')}&nbsp;₽</span>
              <span class="scenario-sep" aria-hidden="true">·</span>
              <span class="scenario-timeline">{pkg.timeline}</span>
            </div>
            <a class="scenario-cta" href={`/order?package=${pkg.code}`} aria-label={`Собрать пакет: ${pkg.name}`}>
              <span>Собрать пакет</span>
              <svg viewBox="0 0 14 10" fill="none" aria-hidden="true">
                <path d="M1 5h12M9 1l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </footer>
        </article>
      ))}
    </div>

    <aside class="scenarios-hint" data-reveal>
      <div class="roman" aria-hidden="true">?</div>
      <div class="body">
        <h3>Не&nbsp;уверены, какой сценарий ваш?</h3>
        <p>Опишите задачу&nbsp;— подберём подходящий план и&nbsp;согласуем срок. Никаких обязательств до&nbsp;ответа куратора.</p>
      </div>
      <a href="https://t.me/academicsaloon" target="_blank" rel="noopener" class="btn btn-gold btn-sm">Обсудить в&nbsp;Telegram</a>
    </aside>
  </div>
</section>

<style>
  /* ================================================================
     SCENARIOS — Caput Tertium. Four study-scenario cards on --ink.
     Visual language matches Calendar/Formula: gold-line frames, fd
     italic accents, fm uppercase eyebrows, gold-glow on hover.
     No new tokens, no sale language.
     ================================================================ */
  .scenarios {
    padding: clamp(56px, 8vw, 110px) clamp(20px, 4vw, 48px);
    background: var(--ink);
    position: relative;
  }
  .scenarios::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(120px, 20vw, 240px);
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-line), transparent);
  }
  .scenarios-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
  }

  .scenarios-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(18px, 2vw, 24px);
    margin-top: clamp(36px, 4.5vw, 56px);
  }
  @media (max-width: 900px) {
    .scenarios-grid { grid-template-columns: 1fr; }
  }

  .scenario {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: clamp(14px, 1.6vw, 20px);
    padding: clamp(24px, 2.8vw, 36px);
    border: 1px solid var(--gold-line);
    background: linear-gradient(180deg, var(--gold-soft), transparent 55%);
    transition:
      border-color .5s var(--ease-silk),
      box-shadow .5s var(--ease-silk),
      transform .5s var(--ease-silk);
  }
  .scenario:hover {
    border-color: var(--gold);
    box-shadow: var(--shadow-glow);
    transform: translateY(-2px);
  }
  .scenario-mark {
    position: absolute;
    top: 0;
    left: clamp(20px, 3vw, 32px);
    width: 32px;
    height: 1px;
    background: var(--gold);
  }

  .scenario-head {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .scenario-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--fm);
    font-size: 10px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .scenario-eyebrow .rule {
    width: 24px;
    height: 1px;
    background: var(--gold);
  }
  .scenario-title {
    font-family: var(--fd);
    font-weight: 500;
    font-size: clamp(26px, 2.6vw, 34px);
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--cream);
    margin: 0;
  }

  .scenario-outcome {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(17px, 1.5vw, 21px);
    line-height: 1.4;
    color: var(--cream-2);
    margin: 0;
    max-width: 36ch;
  }

  .scenario-items {
    list-style: none;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 12px 0;
  }
  .scenario-items li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-family: var(--fd);
    font-size: 15px;
    line-height: 1.45;
    color: var(--cream-2);
  }
  .scenario-items li .dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    margin-top: 9px;
    border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 6px var(--gold-glow);
  }
  .scenario-items li .t { flex: 1; }

  .scenario-audience {
    font-family: var(--fd);
    font-style: italic;
    font-size: 13px;
    line-height: 1.5;
    color: var(--mute);
    margin: 0;
  }

  .scenario-foot {
    margin-top: auto;
    padding-top: clamp(8px, 1vw, 14px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
  }
  .scenario-meta {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    font-family: var(--fd);
  }
  .scenario-price {
    font-style: italic;
    font-size: clamp(20px, 1.8vw, 24px);
    color: var(--gold);
    letter-spacing: -0.005em;
  }
  .scenario-sep {
    color: var(--mute-2);
    font-size: 14px;
  }
  .scenario-timeline {
    font-family: var(--fm);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cream-3);
  }

  .scenario-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 18px;
    border: 1px solid var(--gold-line);
    color: var(--cream);
    text-decoration: none;
    font-family: var(--fm);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    background: transparent;
    transition:
      color .4s var(--ease-silk),
      border-color .4s var(--ease-silk),
      background .4s var(--ease-silk);
  }
  .scenario-cta svg {
    width: 14px;
    height: 10px;
    transition: transform .45s var(--ease-silk);
  }
  .scenario:hover .scenario-cta {
    border-color: var(--gold);
    color: var(--gold);
  }
  .scenario:hover .scenario-cta svg { transform: translateX(4px); }
  .scenario-cta:focus-visible {
    outline: 1px solid var(--gold);
    outline-offset: 2px;
  }

  /* Hint card — mirrors Calendar's bottom aside, kept slightly quieter
     so it doesn't compete with chapter-head. */
  .scenarios-hint {
    margin-top: clamp(32px, 4vw, 56px);
    padding: clamp(24px, 3vw, 36px);
    border: 1px solid var(--gold-line);
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 32px;
    align-items: center;
    background: linear-gradient(180deg, var(--gold-soft), transparent);
    position: relative;
  }
  .scenarios-hint::before {
    content: "";
    position: absolute;
    top: 0;
    left: 20px;
    width: 32px;
    height: 1px;
    background: var(--gold);
  }
  .scenarios-hint .roman {
    font-family: var(--fd);
    font-style: italic;
    font-size: clamp(48px, 6vw, 60px);
    line-height: 0.9;
    color: var(--gold);
  }
  .scenarios-hint .body h3 {
    font-family: var(--fd);
    font-weight: 500;
    font-size: clamp(20px, 2vw, 26px);
    margin: 0 0 8px;
    color: var(--cream);
    letter-spacing: -0.01em;
  }
  .scenarios-hint .body p {
    font-family: var(--fd);
    font-size: 15px;
    font-style: italic;
    color: var(--cream-2);
    margin: 0;
  }
  @media (max-width: 720px) {
    .scenarios-hint {
      grid-template-columns: 1fr;
      text-align: left;
      padding: 24px;
      gap: 18px;
    }
    .scenarios-hint .btn { justify-self: start; }
  }
</style>
