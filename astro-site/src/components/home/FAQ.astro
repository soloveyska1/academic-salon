---
import { qaItems } from '../../data/faq';
---

<section id="qa" class="qa rv" aria-label="Частые вопросы">
  <div class="qa-inner">
    <header class="chapter-head" data-reveal>
      <div class="chapter-num">
        <span class="roman" aria-hidden="true">VIII</span>
        <span class="chapter-label">Caput Octavum · Глава восьмая</span>
      </div>
      <div class="chapter-title-block">
        <h2 class="chapter-h">Частые <em class="it">вопросы</em>.</h2>
        <p class="chapter-lede">Десять вопросов, которые задают чаще всего.</p>
      </div>
    </header>

    <div class="qa-list" data-reveal data-reveal-delay="1">
      {qaItems.map((item) => (
        <details class="qa-item">
          <summary>
            <span class="qa-no">{item.no}.</span>
            <span class="qa-q" set:html={item.q}></span>
            <span class="qa-chev" aria-hidden="true">
              <svg viewBox="0 0 12 12" fill="none"><path d="M2 6h8M6 2v8" stroke="currentColor" stroke-width="1.3"/></svg>
            </span>
          </summary>
          <div class="qa-a">
            <span class="qa-a-spacer" aria-hidden="true"></span>
            <div class="qa-a-body" set:html={item.a}></div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  /* ================================================================
     Q&A — editorial dictionary-style FAQ (step 2.10)
     Ported 1-to-1 from bundle css/06-*. No legacy .qa-* collisions.
     ================================================================ */
  .qa {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px);
    background: var(--ink);
    position: relative;
  }
  .qa-inner {
    max-width: var(--wrap-wide);
    margin: 0 auto;
  }

  .qa-list {
    max-width: 980px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }
  .qa-item {
    padding: 28px 0;
    border-bottom: 1px solid var(--line);
    cursor: pointer;
    position: relative;
  }
  .qa-item summary {
    list-style: none;
    display: grid;
    grid-template-columns: 60px 1fr auto;
    gap: 28px;
    align-items: baseline;
    cursor: pointer;
  }
  .qa-item summary::-webkit-details-marker { display: none; }

  .qa-no {
    font-family: var(--fd);
    font-style: italic;
    font-size: 18px;
    color: var(--gold);
    line-height: 1;
    font-feature-settings: "tnum";
    letter-spacing: 0;
  }
  .qa-q {
    font-family: var(--fd);
    font-size: clamp(20px, 2vw, 28px);
    color: var(--cream);
    line-height: 1.25;
    letter-spacing: -0.015em;
    font-weight: 400;
    transition: color .5s var(--ease-silk);
  }
  .qa-item:hover .qa-q { color: var(--gold); }

  .qa-chev {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    transition: transform .5s var(--ease-silk);
    flex-shrink: 0;
  }
  .qa-chev svg { width: 12px; height: 12px; }
  .qa-item[open] .qa-chev { transform: rotate(45deg); }

  .qa-a {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 28px;
    margin-top: 0;
    overflow: hidden;
    max-height: 0;
    transition: max-height .6s var(--ease-silk), margin-top .6s;
  }
  .qa-item[open] .qa-a {
    max-height: 800px;
    margin-top: 22px;
  }
  .qa-a-spacer {
    font-family: var(--fd);
    font-style: italic;
    font-size: 14px;
    color: var(--mute);
    padding-top: 4px;
    text-align: left;
  }
  .qa-a-spacer::before { content: "Ans."; }
  .qa-a-body {
    font-family: var(--fd);
    font-size: clamp(15px, 1.4vw, 17px);
    line-height: 1.65;
    color: var(--cream-2);
    max-width: 64ch;
    font-weight: 400;
    padding-bottom: 4px;
  }
  .qa-a-body em {
    font-style: italic;
    color: var(--gold);
  }
  .qa-a-body a {
    color: var(--gold);
    border-bottom: 1px solid var(--gold-line);
    padding-bottom: 1px;
  }

  @media (max-width: 720px) {
    .qa-item summary { grid-template-columns: auto 1fr auto; gap: 14px; }
    .qa-a { grid-template-columns: 1fr; gap: 0; }
    .qa-a-spacer { display: none; }
  }
</style>
