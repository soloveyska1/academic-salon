---
/* Pure static section: closing CTA with 4 contact channels.
 * No props, no scripts, all hrefs go to external messengers/email. */
---

  <section id="contact" class="epilogue rv" aria-label="Контакты">
    <div class="epilogue-inner">
      <div class="epilogue-glyph" aria-hidden="true">⁘</div>

      <h2 class="epilogue-h">Напишите. <em class="it">Мы&nbsp;на&nbsp;связи</em>.</h2>
      <p class="epilogue-sub">Отвечает живой человек, не&nbsp;бот. Разговор ни&nbsp;к&nbsp;чему не&nbsp;обязывает.</p>

      <div class="epilogue-channels" role="list" data-reveal data-reveal-delay="2">
        <a class="channel" href="https://t.me/academicsaloon" target="_blank" rel="noopener" role="listitem" aria-label="Написать в Telegram — самый быстрый ответ">
          <span class="channel-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3l15.97-6.16c.73-.33 1.43.18 1.15 1.3l-2.72 12.81c-.19.91-.74 1.13-1.5.71L12.6 16.3l-1.99 1.93c-.23.23-.42.42-.83.42z"/></svg>
          </span>
          <span class="channel-name">Telegram</span>
          <span class="channel-handle">@academicsaloon</span>
          <span class="channel-note">самый быстрый ответ</span>
        </a>

        <a class="channel" href="https://vk.com/academicsaloon" target="_blank" rel="noopener" role="listitem" aria-label="Написать ВКонтакте">
          <span class="channel-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M7 9c.4 3.5 2.7 6 5.5 6h.5v-2c0-.5.2-.7.6-.7.5 0 1.4.8 2.4 2.5h2c-.4-1.4-1.4-2.5-2.2-2.9.8-.6 1.7-1.7 2.1-3.1h-2c-.7 1.6-1.5 2.5-2.4 2.7-.4.1-.5 0-.5-.4V9h-2v3.4c0 .4-.2.6-.5.6-.7 0-1.6-1.4-2-3.6"/></svg>
          </span>
          <span class="channel-name">ВКонтакте</span>
          <span class="channel-handle">/academicsaloon</span>
          <span class="channel-note">основная страница</span>
        </a>

        <a class="channel" href="https://max.ru/join/lvaRhM9GTze3JfqgW9GsTisLfz-o_IOdVK-ev-_AsH0" target="_blank" rel="noopener" role="listitem" aria-label="Написать в MAX">
          <span class="channel-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 16V9l5 5 5-5v7"/></svg>
          </span>
          <span class="channel-name">MAX</span>
          <span class="channel-handle">join · academicsaloon</span>
          <span class="channel-note">мессенджер VK</span>
        </a>

        <a class="channel" href="mailto:academsaloon@mail.ru" role="listitem" aria-label="Написать на email">
          <span class="channel-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="5" width="18" height="14" rx="1"/><path d="M3 7l9 6 9-6"/></svg>
          </span>
          <span class="channel-name">Письмо</span>
          <span class="channel-handle">academsaloon@mail.ru</span>
          <span class="channel-note">если больше 100 слов</span>
        </a>
      </div>

    </div>
  </section>

<style>
     V. EPILOGUE — final CTA + contact channels
     ---------------------------------------------------------------- */
  .epilogue {
    padding: clamp(80px, 12vw, 160px) clamp(20px, 4vw, 48px) clamp(48px, 6vw, 80px);
    background: var(--bg);
    border-top: 1px solid var(--brd);
    text-align: center;
  }
  .epilogue-inner {
    max-width: 1080px;
    margin: 0 auto;
  }
  .epilogue-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-bottom: clamp(20px, 3vw, 32px);
    font: 400 11px/1 var(--fm);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--ac);
  }
  .epilogue-h {
    font: 400 clamp(40px, 6vw, 96px)/.98 var(--fd);
    color: var(--t1);
    letter-spacing: -.025em;
    margin: 0 0 clamp(16px, 2vw, 24px);
    text-wrap: balance;
  }
  .epilogue-h .it {
    font-style: italic;
    color: var(--ac);
    font-feature-settings: "swsh", "dlig";
  }
  .epilogue-sub {
    font: 400 clamp(15px, 1.6vw, 18px)/1.6 var(--fi);
    color: var(--t2);
    max-width: 56ch;
    margin: 0 auto clamp(40px, 6vw, 64px);
  }
  .epilogue-channels {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--brd);
    border-bottom: 1px solid var(--brd);
    margin-bottom: clamp(40px, 6vw, 72px);
  }
  .channel {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    padding: clamp(24px, 3vw, 36px);
    border-right: 1px solid var(--brd);
    text-decoration: none;
    text-align: left;
    color: var(--t1);
    transition: background var(--dur) var(--ease), color var(--dur) var(--ease);
    position: relative;
  }
  .channel:last-child { border-right: none; }
  .channel:hover {
    background: var(--ac-t);
    color: var(--ac);
  }
  .channel:focus-visible {
    outline: 2px solid var(--ac-b);
    outline-offset: -4px;
  }
  .channel-icon {
    display: inline-flex;
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ac-line);
    border-radius: 50%;
    color: var(--ac);
    transition: border-color var(--dur) var(--ease);
  }
  .channel-icon svg { width: 18px; height: 18px; }
  .channel:hover .channel-icon { border-color: var(--ac); }
  .channel-name {
    font: 400 13px/1 var(--fi);
    text-transform: uppercase;
    letter-spacing: .14em;
    color: var(--t1);
    margin-top: 4px;
  }
  .channel:hover .channel-name { color: var(--ac); }
  .channel-handle {
    font: italic 400 17px/1.2 var(--fd);
    color: var(--t2);
    word-break: break-all;
    font-feature-settings: "dlig";
  }
  .channel-note {
    font: 400 11px/1.4 var(--fm);
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--t3);
    margin-top: auto;
  }

  .epilogue-signoff {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  .epilogue-signoff .hairline-edit {
    width: 48px;
    height: 1px;
    background: var(--ac);
    opacity: .4;
  }
  .epilogue-copy {
    font: italic 400 14px/1.4 var(--fd);
    color: var(--t2);
    letter-spacing: .04em;
    font-variant-numeric: tabular-nums;
  }
  .epilogue-whisper {
    font: 400 11px/1.5 var(--fi);
    color: var(--t3);
    opacity: .65;
    letter-spacing: .03em;
  }

  @media (max-width: 1000px) {
    .epilogue-channels { grid-template-columns: repeat(2, 1fr); }
    .channel:nth-child(2) { border-right: none; }
    .channel:nth-child(1),
    .channel:nth-child(2) { border-bottom: 1px solid var(--brd); }
  }
  @media (max-width: 560px) {
    .epilogue-channels { grid-template-columns: 1fr; }
    .channel { border-right: none; border-bottom: 1px solid var(--brd); }
    .channel:last-child { border-bottom: none; }
  }

  /* ================================================================
     EPILOGUE — decorative glyph instead of numbered eyebrow (2.11)
     ================================================================ */
  .epilogue-glyph {
    font-family: var(--fd);
    font-size: clamp(32px, 3vw, 40px);
    color: var(--gold);
    text-align: center;
    letter-spacing: 0.3em;
    margin: 0 0 clamp(24px, 3vw, 32px);
    line-height: 1;
    opacity: 0.9;
  }
</style>
