---
/*
  CSS-ПУЛЬТ — Stages 1-2
  Floating dev panel. Hidden by default.
  Activation: ?pult=1 (sticky for tab session) or Shift+P hotkey.

  Stage 1: shell, drag, hotkeys, persisted state.
  Stage 2: live colour token editing for opaque hex tokens
           (--bg*, --t*, --ac*, semantic). Overrides persist in
           localStorage['pult:overrides']; pre-paint apply lives in
           Base.astro <head> to avoid FOUC.
*/
---

<div
  class="pult-root"
  id="pult-root"
  role="dialog"
  aria-label="CSS-пульт"
  aria-hidden="true"
  data-open="0"
  data-min="0"
>
  <header class="pult-head" id="pult-head">
    <span class="pult-dot" aria-hidden="true"></span>
    <span class="pult-title">CSS-<b>пульт</b> · v0.3</span>
    <button type="button" class="pult-btn" data-pult-action="min" aria-label="Свернуть">–</button>
    <button type="button" class="pult-btn" data-pult-action="close" aria-label="Закрыть">×</button>
  </header>

  <nav class="pult-tabs" role="tablist" aria-label="Разделы пульта">
    <button type="button" class="pult-tab" role="tab" data-pult-tab="colors" aria-selected="true">Цвет</button>
    <button type="button" class="pult-tab" role="tab" data-pult-tab="type" aria-selected="false">Типо</button>
    <button type="button" class="pult-tab" role="tab" data-pult-tab="radius" aria-selected="false">Радиус</button>
    <button type="button" class="pult-tab" role="tab" data-pult-tab="export" aria-selected="false">Экспорт</button>
  </nav>

  <div class="pult-body">
    <section class="pult-pane" data-pult-pane="colors" data-active="1" role="tabpanel">
      <div class="pult-colors" id="pult-colors"></div>
      <div class="pult-pane-foot">
        <button type="button" class="pult-reset-all" data-pult-action="reset-all-colors">
          Сбросить всё
        </button>
      </div>
    </section>
    <section class="pult-pane" data-pult-pane="type" role="tabpanel">
      <div class="pult-sizes" id="pult-sizes"></div>
      <div class="pult-pane-foot">
        <button type="button" class="pult-reset-all" data-pult-action="reset-all-sizes">
          Сбросить всё
        </button>
      </div>
    </section>
    <section class="pult-pane" data-pult-pane="radius" role="tabpanel">
      <div class="pult-radius" id="pult-radius"></div>
      <div class="pult-pane-foot">
        <button type="button" class="pult-reset-all" data-pult-action="reset-all-radius">
          Сбросить всё
        </button>
      </div>
    </section>
    <section class="pult-pane" data-pult-pane="export" role="tabpanel">
      <div class="pult-placeholder">
        <span class="pult-kicker">Этап 4</span>
        <span class="pult-head-line">Экспорт</span>
        <p>Дифф как CSS-патч для вставки в design-tokens.css, сохранение пресетов.</p>
      </div>
    </section>
  </div>

  <footer class="pult-foot">
    <span>type + radii · stage 3/4</span>
    <a href="?pult=0" data-pult-action="hide-link">скрыть</a>
  </footer>
</div>

<script is:inline>
  (function initPult() {
    if (typeof window === 'undefined') return;

    var STORAGE_POS       = 'pult:pos';
    var STORAGE_MIN       = 'pult:min';
    var STORAGE_TAB       = 'pult:tab';
    var STORAGE_OVERRIDES = 'pult:overrides';
    var SESSION_ON        = 'pult:session';

    // Version shown in the panel header. Bumped each stage.
    var PULT_VERSION = '0.3';

    // Stage 2 — opaque hex colour tokens grouped for the Цвет pane.
    // Non-opaque / rgba tokens (--brd, --ac-g*, --glass, ...) are
    // intentionally excluded — native color picker can't express alpha.
    var COLOR_TOKENS = [
      { group: 'Фон', tokens: [
        { name: '--bg',  label: 'основной фон' },
        { name: '--bg2', label: 'фон тон 2' },
        { name: '--bg3', label: 'фон тон 3' },
        { name: '--bg4', label: 'фон тон 4' }
      ]},
      { group: 'Текст', tokens: [
        { name: '--t1', label: 'основной' },
        { name: '--t2', label: 'вторичный' },
        { name: '--t3', label: 'приглушённый' }
      ]},
      { group: 'Золото', tokens: [
        { name: '--ac',  label: 'акцент' },
        { name: '--ac2', label: 'светлее' },
        { name: '--ac3', label: 'ещё светлее' },
        { name: '--ac4', label: 'кремовый' }
      ]},
      { group: 'Семантика', tokens: [
        { name: '--red',    label: 'ошибка' },
        { name: '--green',  label: 'успех' },
        { name: '--purple', label: 'инфо' }
      ]}
    ];

    // Stage 3 — numeric px tokens (range sliders).
    var SIZE_TOKENS = [
      { group: 'Размеры шрифта', min: 8, max: 64, step: 1, tokens: [
        { name: '--fs-xs',   label: 'xs — мелочи' },
        { name: '--fs-sm',   label: 'sm — подписи' },
        { name: '--fs-base', label: 'base — тело' },
        { name: '--fs-md',   label: 'md — лид' },
        { name: '--fs-lg',   label: 'lg — заголовки' },
        { name: '--fs-xl',   label: 'xl — крупные' },
        { name: '--fs-2xl',  label: '2xl — hero' }
      ]}
    ];

    var RADIUS_TOKENS = [
      { group: 'Радиусы', min: 0, max: 40, step: 1, tokens: [
        { name: '--r',  label: 'большой (карточки)' },
        { name: '--rm', label: 'средний (кнопки)' },
        { name: '--rs', label: 'малый (инпуты)' },
        { name: '--rx', label: 'экстра (фокус)' }
      ]}
    ];

    function safeGet(store, key) {
      try { return store.getItem(key); } catch (_) { return null; }
    }
    function safeSet(store, key, value) {
      try { store.setItem(key, value); } catch (_) {}
    }
    function safeDel(store, key) {
      try { store.removeItem(key); } catch (_) {}
    }

    // ═══════ STAGE 2 — COLOUR OVERRIDES ═══════

    function readOverrides() {
      var raw = safeGet(localStorage, STORAGE_OVERRIDES);
      if (!raw) return {};
      try {
        var parsed = JSON.parse(raw);
        return (parsed && typeof parsed === 'object') ? parsed : {};
      } catch (_) { return {}; }
    }

    function writeOverrides(map) {
      var keys = Object.keys(map);
      if (!keys.length) { safeDel(localStorage, STORAGE_OVERRIDES); return; }
      safeSet(localStorage, STORAGE_OVERRIDES, JSON.stringify(map));
    }

    function readCurrentValue(token) {
      try {
        return getComputedStyle(document.documentElement).getPropertyValue(token).trim();
      } catch (_) { return ''; }
    }

    function toPx(value) {
      if (value == null) return 0;
      var str = String(value).trim();
      var m = str.match(/^(-?\d*\.?\d+)\s*px$/);
      if (m) return parseFloat(m[1]);
      var n = parseFloat(str);
      return isNaN(n) ? 0 : n;
    }

    function toHex(color) {
      if (!color) return '#000000';
      color = String(color).trim().toLowerCase();
      if (color.charAt(0) === '#') {
        if (color.length === 7) return color;
        if (color.length === 4) {
          return '#' + color.charAt(1) + color.charAt(1)
                     + color.charAt(2) + color.charAt(2)
                     + color.charAt(3) + color.charAt(3);
        }
      }
      var m = color.match(/rgba?\(\s*(\d+)\s*,\s*(\d+)\s*,\s*(\d+)/);
      if (m) {
        var r = parseInt(m[1], 10);
        var g = parseInt(m[2], 10);
        var b = parseInt(m[3], 10);
        var hex = '#';
        [r, g, b].forEach(function (n) {
          var s = Math.max(0, Math.min(255, n)).toString(16);
          hex += s.length === 1 ? '0' + s : s;
        });
        return hex;
      }
      return '#000000';
    }

    function renderColorRows(container) {
      if (!container) return;
      var overrides = readOverrides();
      var html = '';
      for (var gi = 0; gi < COLOR_TOKENS.length; gi++) {
        var group = COLOR_TOKENS[gi];
        html += '<div class="pult-group">';
        html += '<h3 class="pult-group-title">' + group.group + '</h3>';
        for (var ti = 0; ti < group.tokens.length; ti++) {
          var tok = group.tokens[ti];
          var current = readCurrentValue(tok.name);
          var hex = toHex(current);
          var overridden = Object.prototype.hasOwnProperty.call(overrides, tok.name);
          html += '<div class="pult-row" data-pult-token="' + tok.name + '"'
               +  (overridden ? ' data-overridden="1"' : '') + '>';
          html += '<div class="pult-row-text">';
          html += '<code class="pult-token-name">' + tok.name + '</code>';
          html += '<span class="pult-token-label">' + tok.label + '</span>';
          html += '</div>';
          html += '<div class="pult-row-controls">';
          html += '<code class="pult-hex">' + hex + '</code>';
          html += '<input type="color" class="pult-color" value="' + hex
               +  '" aria-label="' + tok.name + '">';
          html += '<button type="button" class="pult-btn pult-reset" data-pult-reset="'
               +  tok.name + '" aria-label="Сбросить ' + tok.name + '" title="Сбросить">↺</button>';
          html += '</div>';
          html += '</div>';
        }
        html += '</div>';
      }
      container.innerHTML = html;
    }

    function renderSliderRows(container, groups) {
      if (!container) return;
      var overrides = readOverrides();
      var html = '';
      for (var gi = 0; gi < groups.length; gi++) {
        var group = groups[gi];
        var min = group.min != null ? group.min : 0;
        var max = group.max != null ? group.max : 64;
        var step = group.step != null ? group.step : 1;
        html += '<div class="pult-group">';
        html += '<h3 class="pult-group-title">' + group.group + '</h3>';
        for (var ti = 0; ti < group.tokens.length; ti++) {
          var tok = group.tokens[ti];
          var current = readCurrentValue(tok.name);
          var px = toPx(current);
          var overridden = Object.prototype.hasOwnProperty.call(overrides, tok.name);
          html += '<div class="pult-row pult-row-slider" data-pult-token="' + tok.name + '"'
               +  (overridden ? ' data-overridden="1"' : '') + '>';
          html += '<div class="pult-row-text">';
          html += '<code class="pult-token-name">' + tok.name + '</code>';
          html += '<span class="pult-token-label">' + tok.label + '</span>';
          html += '</div>';
          html += '<input type="range" class="pult-slider" min="' + min + '" max="' + max
               +  '" step="' + step + '" value="' + px + '" aria-label="' + tok.name + '">';
          html += '<code class="pult-px">' + px + 'px</code>';
          html += '<button type="button" class="pult-btn pult-reset" data-pult-reset="'
               +  tok.name + '" aria-label="Сбросить ' + tok.name + '" title="Сбросить">↺</button>';
          html += '</div>';
        }
        html += '</div>';
      }
      container.innerHTML = html;
    }

    function onSliderInput(e) {
      var input = e.target;
      if (!input || !input.classList || !input.classList.contains('pult-slider')) return;
      var row = input.closest('[data-pult-token]');
      if (!row) return;
      var token = row.getAttribute('data-pult-token');
      var value = input.value + 'px';
      document.documentElement.style.setProperty(token, value);
      var overrides = readOverrides();
      overrides[token] = value;
      writeOverrides(overrides);
      row.setAttribute('data-overridden', '1');
      var pxEl = row.querySelector('.pult-px');
      if (pxEl) pxEl.textContent = input.value + 'px';
    }

    function onColorInput(e) {
      var input = e.target;
      if (!input || !input.classList || !input.classList.contains('pult-color')) return;
      var row = input.closest('[data-pult-token]');
      if (!row) return;
      var token = row.getAttribute('data-pult-token');
      var value = input.value;
      document.documentElement.style.setProperty(token, value);
      var overrides = readOverrides();
      overrides[token] = value;
      writeOverrides(overrides);
      row.setAttribute('data-overridden', '1');
      var hexEl = row.querySelector('.pult-hex');
      if (hexEl) hexEl.textContent = value;
    }

    function resetToken(token, row) {
      document.documentElement.style.removeProperty(token);
      var overrides = readOverrides();
      delete overrides[token];
      writeOverrides(overrides);
      if (!row) return;
      row.removeAttribute('data-overridden');
      var fresh = readCurrentValue(token);
      var hexEl = row.querySelector('.pult-hex');
      var colorInput = row.querySelector('.pult-color');
      var slider = row.querySelector('.pult-slider');
      var pxEl = row.querySelector('.pult-px');
      if (hexEl && colorInput) {
        var hex = toHex(fresh);
        hexEl.textContent = hex;
        colorInput.value = hex;
      }
      if (slider && pxEl) {
        var px = toPx(fresh);
        slider.value = px;
        pxEl.textContent = px + 'px';
      }
    }

    function clearTokensInGroups(groups) {
      var overrides = readOverrides();
      var changed = false;
      groups.forEach(function (g) {
        g.tokens.forEach(function (t) {
          if (Object.prototype.hasOwnProperty.call(overrides, t.name)) {
            document.documentElement.style.removeProperty(t.name);
            delete overrides[t.name];
            changed = true;
          }
        });
      });
      if (changed) writeOverrides(overrides);
    }

    function resetAllColors() {
      clearTokensInGroups(COLOR_TOKENS);
      var c = document.getElementById('pult-colors');
      if (c) renderColorRows(c);
    }

    function resetAllSizes() {
      clearTokensInGroups(SIZE_TOKENS);
      var c = document.getElementById('pult-sizes');
      if (c) renderSliderRows(c, SIZE_TOKENS);
    }

    function resetAllRadius() {
      clearTokensInGroups(RADIUS_TOKENS);
      var c = document.getElementById('pult-radius');
      if (c) renderSliderRows(c, RADIUS_TOKENS);
    }

    // ═══════ SHELL (stage 1) ═══════

    function shouldActivate() {
      try {
        var params = new URLSearchParams(window.location.search);
        if (params.get('pult') === '1') {
          safeSet(sessionStorage, SESSION_ON, '1');
          return true;
        }
        if (params.get('pult') === '0') {
          safeDel(sessionStorage, SESSION_ON);
          return false;
        }
      } catch (_) {}
      return safeGet(sessionStorage, SESSION_ON) === '1';
    }

    var dragState = null;

    function clampToViewport(x, y, el) {
      var w = el.offsetWidth || 340;
      var h = el.offsetHeight || 200;
      var maxX = window.innerWidth - w - 4;
      var maxY = window.innerHeight - h - 4;
      if (maxX < 4) maxX = 4;
      if (maxY < 4) maxY = 4;
      return {
        x: Math.max(4, Math.min(x, maxX)),
        y: Math.max(4, Math.min(y, maxY))
      };
    }

    function applyPosition(el) {
      var raw = safeGet(localStorage, STORAGE_POS);
      if (!raw) return;
      try {
        var pos = JSON.parse(raw);
        if (typeof pos.x !== 'number' || typeof pos.y !== 'number') return;
        var c = clampToViewport(pos.x, pos.y, el);
        el.style.left = c.x + 'px';
        el.style.top = c.y + 'px';
        el.style.right = 'auto';
        el.style.bottom = 'auto';
      } catch (_) {}
    }

    function setOpen(el, open) {
      el.setAttribute('data-open', open ? '1' : '0');
      el.setAttribute('aria-hidden', open ? 'false' : 'true');
    }

    function setMinimized(el, min) {
      el.setAttribute('data-min', min ? '1' : '0');
      safeSet(localStorage, STORAGE_MIN, min ? '1' : '0');
    }

    function activateTab(root, tabName) {
      var tabs = root.querySelectorAll('[data-pult-tab]');
      tabs.forEach(function (t) {
        t.setAttribute('aria-selected', t.getAttribute('data-pult-tab') === tabName ? 'true' : 'false');
      });
      var panes = root.querySelectorAll('[data-pult-pane]');
      panes.forEach(function (p) {
        p.setAttribute('data-active', p.getAttribute('data-pult-pane') === tabName ? '1' : '0');
      });
      safeSet(localStorage, STORAGE_TAB, tabName);
    }

    function hidePult(el) {
      setOpen(el, false);
      safeDel(sessionStorage, SESSION_ON);
    }

    function showPult(el) {
      setOpen(el, true);
      safeSet(sessionStorage, SESSION_ON, '1');
    }

    function togglePult(el) {
      if (el.getAttribute('data-open') === '1') hidePult(el);
      else showPult(el);
    }

    function onPointerDown(e, el, head) {
      if (e.target.closest('.pult-btn')) return;
      if (e.button != null && e.button !== 0) return;
      var rect = el.getBoundingClientRect();
      dragState = {
        el: el,
        offsetX: e.clientX - rect.left,
        offsetY: e.clientY - rect.top,
        pointerId: e.pointerId
      };
      el.setAttribute('data-dragging', '1');
      try { head.setPointerCapture(e.pointerId); } catch (_) {}
      e.preventDefault();
    }

    function onPointerMove(e) {
      if (!dragState) return;
      var el = dragState.el;
      var nx = e.clientX - dragState.offsetX;
      var ny = e.clientY - dragState.offsetY;
      var c = clampToViewport(nx, ny, el);
      el.style.left = c.x + 'px';
      el.style.top = c.y + 'px';
      el.style.right = 'auto';
      el.style.bottom = 'auto';
    }

    function onPointerUp(e, head) {
      if (!dragState) return;
      var el = dragState.el;
      try { head.releasePointerCapture(dragState.pointerId); } catch (_) {}
      el.removeAttribute('data-dragging');
      var rect = el.getBoundingClientRect();
      safeSet(localStorage, STORAGE_POS, JSON.stringify({ x: rect.left, y: rect.top }));
      dragState = null;
    }

    var wired = false;
    var keyListener = null;

    function init() {
      var el = document.getElementById('pult-root');
      if (!el) return;

      // Restore state (regardless of activation — so when opened, it remembers)
      applyPosition(el);
      if (safeGet(localStorage, STORAGE_MIN) === '1') setMinimized(el, true);
      var savedTab = safeGet(localStorage, STORAGE_TAB);
      if (savedTab) activateTab(el, savedTab);

      // Stage 2-3 — populate editor panes (pre-paint apply is done in Base.astro head).
      renderColorRows(document.getElementById('pult-colors'));
      renderSliderRows(document.getElementById('pult-sizes'),  SIZE_TOKENS);
      renderSliderRows(document.getElementById('pult-radius'), RADIUS_TOKENS);

      if (shouldActivate()) setOpen(el, true);
      else setOpen(el, false);

      if (wired) return;
      wired = true;

      var head = document.getElementById('pult-head');

      // Drag
      if (head) {
        head.addEventListener('pointerdown', function (e) { onPointerDown(e, el, head); });
        head.addEventListener('pointermove', onPointerMove);
        head.addEventListener('pointerup', function (e) { onPointerUp(e, head); });
        head.addEventListener('pointercancel', function (e) { onPointerUp(e, head); });
      }

      // Action buttons
      el.addEventListener('click', function (e) {
        var actionBtn = e.target.closest('[data-pult-action]');
        if (actionBtn) {
          var action = actionBtn.getAttribute('data-pult-action');
          if (action === 'close') { hidePult(el); return; }
          if (action === 'min') {
            var isMin = el.getAttribute('data-min') === '1';
            setMinimized(el, !isMin);
            return;
          }
          if (action === 'hide-link') {
            e.preventDefault();
            hidePult(el);
            return;
          }
          if (action === 'reset-all-colors') { resetAllColors(); return; }
          if (action === 'reset-all-sizes')  { resetAllSizes();  return; }
          if (action === 'reset-all-radius') { resetAllRadius(); return; }
        }
        var resetBtn = e.target.closest('[data-pult-reset]');
        if (resetBtn) {
          var token = resetBtn.getAttribute('data-pult-reset');
          resetToken(token, resetBtn.closest('[data-pult-token]'));
          return;
        }
        var tabBtn = e.target.closest('[data-pult-tab]');
        if (tabBtn) {
          activateTab(el, tabBtn.getAttribute('data-pult-tab'));
        }
      });

      // Colour pickers + sliders — live preview + persist on every input
      el.addEventListener('input', function (e) {
        onColorInput(e);
        onSliderInput(e);
      });

      // Hotkeys — Shift+P toggle, Esc close
      keyListener = function (e) {
        if (e.shiftKey && !e.ctrlKey && !e.metaKey && !e.altKey && (e.key === 'P' || e.key === 'p')) {
          var tag = (e.target && e.target.tagName) || '';
          if (tag === 'INPUT' || tag === 'TEXTAREA' || (e.target && e.target.isContentEditable)) return;
          e.preventDefault();
          togglePult(el);
          return;
        }
        if (e.key === 'Escape' && el.getAttribute('data-open') === '1') {
          hidePult(el);
        }
      };
      document.addEventListener('keydown', keyListener);

      // Reclamp on resize (viewport shrink shouldn't orphan the panel)
      window.addEventListener('resize', function () {
        var raw = safeGet(localStorage, STORAGE_POS);
        if (!raw) return;
        try {
          var pos = JSON.parse(raw);
          var c = clampToViewport(pos.x, pos.y, el);
          el.style.left = c.x + 'px';
          el.style.top = c.y + 'px';
        } catch (_) {}
      });
    }

    // Initial + after view transitions (Astro ClientRouter re-runs scripts
    // in <head>/<body>, but we guard via `wired` flag above.)
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
    } else {
      init();
    }
    document.addEventListener('astro:page-load', init);
  })();
</script>
